    c = c1, ct = c/10 + k, z = 0
  ELSEIF (iter==l2)
    c = c2, ct = c/10 + k, z = 0
  ELSEIF (iter==l3)
    c = c3, ct = c/10 + k, z = 0
  ELSEIF (iter==l4)
    c = c4, ct = c/10 + k, z = 0
  ENDIF
  z = c*z^2/conj(z+c) + ct
  iter=iter+1
bailout:
  real(z-pixel2)<=bailout
default:
  title = "carr3005Btna"
  maxiter = 700
  magn = 1.2
  center = (0,.1)
  periodicity = 0
  method = multipass
  helpfile = "http://www.astrolathe.com/formulas.htm"
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \

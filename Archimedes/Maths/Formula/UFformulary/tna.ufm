Storm {
;  by Ted Nason 1996/2003  astrolathe@comcast.net
init:
  z = @start
loop:
  float bb = 1 - |z|
  float u = (1 + @mult1*real(z)) * (1 + @mult2*real(z) + @mult3*imag(z)^2) / bb + real(#pixel)
  float v = @mult4*real(z) / bb + imag(#pixel)
  float xx = (@mult5*u * real(z) + @mult6*v * imag(z)) / |z| + real(#pixel)
  float yy = (@mult7*v * real(z) + @mult8*u * imag(z)) / |z| + imag(#pixel)
  z = xx + flip(yy)
bailout:
  |z| <= @bailout
default:
  title = "Storm"
  center = (0,0)
  periodicity = 0
  method = multipass
  helpfile = "http://www.astrolathe.com/formulas.htm"
  param start
    caption = "Starting point"
    default = (0.05,0.05)
    hint = "Perturbation. Use (0.05,0.05) for the standard set."
  endparam
  float param mult1
    caption = "multiplier 1"
    default = 1
  endparam
  float param mult2
    caption = "multiplier 2"
    default = -1
  endparam
  float param mult3
    caption = "multiplier 3"
    default = -1
  endparam
  float param mult4
    caption = "multiplier 4"
    default = 2
  endparam
  float param mult5
    caption = "multiplier 5"
    default = 1
  endparam
  float param mult6
    caption = "multiplier 6"
    default = 1
  endparam
  float param mult7
    caption = "multiplier 7"
    default = 1
  endparam
  float param mult8
    caption = "multiplier 8"
    default = -1
  endparam
  float param bailout
    caption = "Bailout value"
    default = 1000
    min = 0
  endparam
switch:
  type = "Storm-Julia"
  seed = #pixel
  bailout = bailout
  mult1 = mult1
  mult2 = mult2
  mult3 = mult3
  mult4 = mult4
  mult5 = mult5
  mult6 = mult6
  mult7 = mult7
  mult8 = mult8
}



  const1=const1
  power1=power1
  power2=power2
  start=start
}


amber {
; originally bwp26
; modified for UF3 by Ted Nason Feb 2004 astrolathe@comcast.net
; this formula was only modified to allow for the Julia switch
; and was not otherwise modified
init:
  z = #pixel
loop:
  a = z ^ 3 + (#pixel - 1) * z - #pixel
  b = @Coeff1 * z ^ 2 + #pixel - 1
  z = z - @Coeff2 * a / b
bailout:
  |z| <= @bailout
default:
  title = "amber"
  periodicity = 0
  method = multipass
  helpfile = "http://www.astrolathe.com/formulas.htm"
  param Coeff1
    caption = "Coefficient 1"
    default = (1, 0)
  endparam
  param Coeff2
    caption = "Coefficient 2"
    default = (1, 0)
  endparam
  param Bailout
    caption = "Bailout Value"
    default = 4.0
  endparam
switch:
  type = "amber-Julia"
  seed = #pixel
  bailout = bailout
  Coeff1 = Coeff1
  Coeff2 = Coeff2
}


amber-Julia{
; originally bwp26
; modified for UF3 by Ted Nason Feb 2004 astrolathe@comcast.net
; this formula was only modified to allow for the Julia switch
; and was not otherwise modified
init:
  z = #pixel
loop:
  a = z ^ 3 + (@seed - 1) * z - @seed
  b = @Coeff1 * z ^ 2 + @seed - 1
  z = z - @Coeff2 * a / b
bailout:
  |z| <= @bailout
default:
  title = "amber-Julia"
  center = (0,0)
  periodicity = 0
  method = multipass
  helpfile = "http://www.astrolathe.com/formulas.htm"
  float param bailout
    caption = "Bailout value"
    default = 100
    min = 0
  endparam
switch:
  type = "amber"
  Coeff1 = Coeff1
  Coeff2 = Coeff2
  bailout = bailout
}


Moth {
;  by Ted Nason 1996/2003  astrolathe@comcast.net
init:
  z = @start
loop:
  float a = 1 - real(z)
  float dd = a^2 + imag(z)^2
  float d = real(z)^2 - imag(z)^2
  float xx = (@mult1*d*a + @mult2*real(z)*imag(z)^2)/dd + real(#pixel)
  float yy = imag(z)*(@mult3*real(z)*a + @mult4*d)/dd + imag(#pixel)
  z = xx + flip(yy)
bailout:
  |z| <= @bailout
default:
  title = "Moth"
  center = (0,0)
  periodicity = 0
  method = multipass
  helpfile = "http://www.astrolathe.com/formulas.htm"
  param start
    caption = "Starting point"
    default = (0,0)
    hint = "Perturbation. Use (0,0) for the standard set."
  endparam
  float param bailout
    caption = "Bailout value"
    default = 100
    min = 0
  endparam
  float param mult1
    caption = "multiplier 1"
    default = 1
  endparam
  float param mult2
    caption = "multiplier 2"
    default = 2
  endparam
  float param mult3
    caption = "multiplier 3"
    default = 2
  endparam
  float param mult4
    caption = "multiplier 4"
    default = -1
  endparam
switch:
  type = "Moth-Julia"
  seed = #pixel
  bailout = bailout
  mult1 = mult1
  mult2 = mult2
  mult3 = mult3
  mult4 = mult4
}



; these formulas were all changed 7-2-05 in minor ways
; which do NOT affect backward compatibility
; i.e., changes in hints or email address of author
; no substantive changes were made

GammaFn {
;  by Ted Nason 2004  astrolathe@comcast.net
init:
  z = @start
  int iter = 0
loop:
  iter = iter + 1
  z = (#pixel^2)*(exp(z))*(1+z/iter)*exp(-z/iter)
bailout:
  |z| <= @bailout
default:
  title = "GammaFn"
  periodicity = 0
  method = multipass
  helpfile = "http://www.astrolathe.com/formulas.htm"
  center = (0,0)
  param start
    caption = "Starting point"
    default = (0,0)
    hint = "Perturbation. Use (0,0) for the standard set."
  endparam
  float param bailout
    caption = "bailout"
    default = 1000
    min = 0
  endparam
switch:
  type = "GammaFn-Julia"
  seed = #pixel
  bailout = bailout
  start=start
}


GammaFn-Julia {
;  by Ted Nason 2004  astrolathe@comcast.net
init:
  z = #pixel
  int iter = 0
loop:
  iter = iter + 1
  z = (@seed^2)*(exp(z))*(1+z/iter)*exp(-z/iter)
bailout:
  |z| <= @bailout
default:
  title = "GammaFn-Julia"
  periodicity = 0
  method = multipass
  helpfile = "http://www.astrolathe.com/formulas.htm"
  center = (0,0)
  param start

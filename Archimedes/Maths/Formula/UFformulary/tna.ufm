  z=flip(conj(1.25*pixel2))-flip(.01/pixel2) \
    -conj(.001/pixel2)+.4
  c = conj(b5)
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = (-.7956,-.132)
  ct = c/10 + k
  l1=round(real(p1)),l2=round(imag(p1))

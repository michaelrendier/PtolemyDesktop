;  by Ted Nason 1996/2003  astrolathe@comcast.net
; z = c*(z^2+1)/(z*(z^2-1))  p.154
init:
  z = #pixel
loop:
  z = @seed*(z^2+1)/(z*(z^2-1))
bailout:
  |z| <= @bailout
default:
  title = "rationalC-Julia"
  center = (0,0)
  periodicity = 0
  method = multipass
  helpfile = "http://www.astrolathe.com/formulas.htm"
  param start
    caption = "Starting point"
    default = (0.1,0.1)
    hint = "Perturbation. Use (0.1,0.1) for the standard set."
  endparam
  float param bailout
    caption = "Bailout value"
    default = 1000
    min = 0
  endparam
switch:
  type = "rationalC"
  bailout = bailout
}


rationalD {
;  by Ted Nason 1996/2003  astrolathe@comcast.net
; z = not- z^4/(1-z)  p.70  p.154
init:
  z = @start
loop:
  float u = real(z)^2 - imag(z)^2
  float v = 2*real(z)*imag(z)
  float d = u^2 - v^2
  float a = 1 - u
  float dd = a ^ 2 + v ^ 2
  float xx = (d * a + 2 * u * v ^ 2) / dd + real(#pixel)
  float yy = v * (2 * u * a - d) / dd + imag(#pixel)
  z = xx + flip(yy)
bailout:
  |z| <= @bailout
default:
  title = "rationalD"
  center = (0,0)
  periodicity = 0
  method = multipass
  helpfile = "http://www.astrolathe.com/formulas.htm"
  param start
    caption = "Starting point"
    default = (0.1,0.1)
    hint = "Perturbation. Use (0.1,0.1) for the standard set."
  endparam
  float param bailout
    caption = "Bailout value"
    default = 1000
    min = 0
  endparam
switch:
  type = "rationalD-Julia"
  seed = #pixel
  bailout = bailout
}



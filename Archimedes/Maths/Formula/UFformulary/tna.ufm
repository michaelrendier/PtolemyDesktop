Storm-Moth-Julia {
;  by Ted Nason 1996/2003  astrolathe@comcast.net
init:
  z = #pixel
loop:
  float bb = 1 - |z|
  float u = (1 + @mult1*real(z)) * (1 + @mult2*real(z) + @mult3*imag(z)^2) / bb + real(@seed)
  float v = @mult4*real(z) / bb + imag(@seed)
  float xx = (@mult5*u * real(z) + @mult6*v * imag(z)) / |z| + real(@seed)
  float a = 1 - real(z)
  float dd = a^2 + imag(z)^2
  float d = real(z)^2 - imag(z)^2
  float yy = imag(z)*(@mult7*real(z)*a + @mult8*d)/dd + imag(@seed)
  z = xx + flip(yy)
bailout:
  |z| <= @bailout
default:
  title = "Storm-Moth-Julia"
  center = (0,0)
  periodicity = 0
  method = multipass
  helpfile = "http://www.astrolathe.com/formulas.htm"
  param seed
    caption = "Julia seed"
    default = (-1.25, 0)
  endparam
  param bailout
    caption = "Bailout value"
    default = 10000
    min = 1.0
  endparam
  float param mult1
    caption = "multiplier 1"
    default = 1
  endparam
  float param mult2
    caption = "multiplier 2"
    default = -1
  endparam
  float param mult3
    caption = "multiplier 3"
    default = -1
  endparam
  float param mult4
    caption = "multiplier 4"
    default = 2
  endparam
  float param mult5
    caption = "multiplier 5"
    default = 1
  endparam
  float param mult6
    caption = "multiplier 6"
    default = 1
  endparam
  float param mult7
    caption = "multiplier 7"
    default = 2
  endparam
  float param mult8
    caption = "multiplier 8"
    default = -1
  endparam
switch:
  type = "Storm-Moth"  
  bailout = bailout
  mult1 = mult1
  mult2 = mult2
  mult3 = mult3
  mult4 = mult4
  mult5 = mult5
  mult6 = mult6
  mult7 = mult7
  mult8 = mult8
}



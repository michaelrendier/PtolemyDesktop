  bailout = bailout
  start=start
}


Egg {
;  by Ted Nason 1996/2003  astrolathe@comcast.net
init:
  z = @start
loop:
  z = #pixel*(z^@power1+@const1)/z^@power2
bailout:
  |z| <= @bailout
default:
  title = "Egg"
  periodicity = 0
  method = multipass
  helpfile = "http://www.astrolathe.com/formulas.htm"
  center = (0,0)
  param start
    caption = "Starting point"
    default = (0.1,0.1)
    hint = "Use (0,1) for the standard set."
  endparam
  param power1
    caption = "power1"
    default = (2,0)
    hint = "power in numerator"
  endparam
  param power2
    caption = "power2"
    default = (1,0)
    hint = "This defines the power in the denominator. Use (1,0) \
            for the standard set."
  endparam
  param const1
    caption = "constant 1"
    default = (1,0)
    hint = "constant in the numerator"
  endparam
  float param bailout
    caption = "bailout"
    default = 1000
    min = 0
  endparam
switch:
  type = "Egg-Julia"
  seed = #pixel
  bailout = bailout
  const1=const1
  power1=power1
  power2=power2
  start=start
}


Egg-Julia {
;  by Ted Nason 1996/2003  astrolathe@comcast.net
init:
  z = #pixel
loop:
  z = @seed*(z^@power1+@const1)/z^@power2
bailout:
  |z| <= @bailout
default:
  title = "Egg-Julia"

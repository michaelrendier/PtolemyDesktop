init:
  z = #pixel
loop:
  z = (z+real(@seed))*(z+flip(imag(@seed)))
bailout:
  |z| <= @bailout
default:
  title = "pq-split-Julia"
  center = (0,0)
  periodicity = 0
  method = multipass
  helpfile = "http://www.astrolathe.com/formulas.htm"
  param start
    caption = "Starting point"
    default = (0.1,0.1)
    hint = "Perturbation. Use (0.1,0.1) for the standard set."
  endparam
  float param bailout
    caption = "Bailout value"
    default = 1000
    min = 0
  endparam
switch:
  type = "pq-split"
  bailout = bailout
}



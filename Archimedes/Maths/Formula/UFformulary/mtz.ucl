Tiling{
;The method of determining the distance between a
;pixel and a segment has been taken from
;Kerry's LKM - Line coloring algoritm

global:

  int k=0 ; number of lines
  complex d[75,2]
  
  $DEFINE debug
  ;designing the initial figure
  
  If @tip==0 
  d[1,1]=(0,-1)/8, d[1,0]=(2,1)/8
  d[2,1]=(2,1)/8, d[2,0]=(2,2)/8
  d[3,1]=(2,2)/8, d[3,0]=(3,2)/8
  d[4,1]=(3,2)/8, d[4,0]=(5,4)/8 
  d[5,1]=(3,4)/8, d[5,0]=(5,2)/8
  d[6,1]=(0,1)/8, d[6,0]=(2,-1)/8
  k=6
  endif
  
If @tip==1 
  d[1,1]=(0,0)/12, d[1,0]=(2,3)/12
  d[2,1]=(4,3)/12, d[2,0]=(2,3)/12
  d[3,1]=(2,3)/12, d[3,0]=(0,6)/12
  d[4,1]=(0,6)/12, d[4,0]=(3,8)/12
  
  d[5,1]=(3,8)/12, d[5,0]=(3,10)/12
  d[6,1]=(3,10)/12, d[6,0]=(0,12)/12
  d[7,1]=(6,0)/12, d[7,0]=(4,3)/12
  d[8,1]=(6,0)/12, d[8,0]=(9,2)/12
  
  d[9,1]=(9,2)/12, d[9,0]=(9,4)/12
  d[10,1]=(9,2)/12, d[10,0]=(12,0)/12
  d[11,1]=(4,3)/12, d[11,0]=(8,9)/12;
  d[12,1]=(9,4)/12, d[12,0]=(3,8)/12;
  
  d[13,1]=(9,4)/12, d[13,0]=(12,6)/12
  d[14,1]=(10,9)/12, d[14,0]=(12,6)/12
  d[15,1]=(10,9)/12, d[15,0]=(8,9)/12
  d[16,1]=(8,9)/12, d[16,0]=(6,12)/12

  d[17,1]=(3,10)/12, d[17,0]=(6,12)/12
  d[18,1]=(10,9)/12, d[18,0]=(12,12)/12 
  k=18
  endif

If @tip==2 

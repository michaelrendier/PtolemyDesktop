  d[5,1]=(2,2), d[5,0]=(4,2)
  d[6,1]=(4,2), d[6,0]=(5,0)
  d[7,1]=(5,2), d[7,0]=(4,0)
  d[8,1]=(2.5,1), d[8,0]=(3.5,3)

  k=8
  int counter=0   
  repeat
  counter=counter+1
    d[counter,1]=real(d[counter,1])/9+flip(imag(d[counter,1])/6)  
    d[counter,0]=real(d[counter,0])/9+flip(imag(d[counter,0])/6)  
    until counter == k
  endif
 
If @tip==5 
  d[1,1]=(1,-1), d[1,0]=(1,2)
  d[2,1]=(1,2), d[2,0]=(3,4)

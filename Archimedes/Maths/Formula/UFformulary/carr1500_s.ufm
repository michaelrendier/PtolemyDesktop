; Updated for UF2 by Erik Reckase, Jan 2000
; Julia

init:
  z = (conj(1/#pixel)/sqr(1/#pixel))/@scale
  c = cotanh(1/#pixel)/cosh(1/#pixel)

loop:
  z = fn1(fn2(fn3(sqr(z)+c)))
  c = ((1+flip(imag(sqrt(sin(c-0.1/#pixel)))))*real(sqrt(tan(c)))/9+z)

bailout:
  |real(z)| <= @bailout

default:
  title = "Carr 1551S"
  method = multipass
  periodicity = 0
  maxiter = 100
  magn = .9
  center = (0,0)

heading 
  caption = "Parameters"
endheading

param scale
  caption = "Scale"
  default = 1.0
  hint = "Select a value to scale the image elements."
endparam
param bailout
  caption = "Bailout"
  default = 4
  hint = "Select a bailout value for the formula."
endparam


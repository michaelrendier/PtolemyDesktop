Carr1086S {
; A "Modified Carr" formula, based on the original with permission.
; Functionality added by Sharon S. Schultz, May, 2003.
; DISECTED MANDELBROT
; TO GENERATE "STANDARD" MANDELBROT, SET P1 = 0,0 & ALL FN = IDENT
; Converted for UF by Erik Reckase, February 22, 2000
; SOURCE: 24Carr.frm

init:
  z = (1/pixel)/@scale
  cx = flip(real(1/pixel))
  cy = flip(imag(z))
  k = 2+p1
  
loop:
  zx = real(z)
  zy = imag(z)
  x = z*(zx*zx-zy*zy)+cx
  y = cx*(k*zx*zy)+cy
  z = fn1(fn2(fn3(((1/z^z*z+z)/(pixel-cx*cx))/1.32)))
  
bailout:
  |z| < (@bailout+p2)

default:
title = "Carr-1086S"
method = multipass

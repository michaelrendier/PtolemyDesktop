Carr1012S {
; A "Modified Carr" formula, based on the original with permission.
; Functionality added by Sharon S. Schultz, May, 2003.
; SJMand variant
; Converted for UF by Erik Reckase, February 22, 2000
; SOURCE: 24Carr.frm

init:
  z = ((real(pixel))+1.224*(flip(imag(pixel))))/@scale
  c = 2.224+(1.099,0)*(real(pixel))+flip(imag(pixel))
  
loop:
  z = fn1(fn2(fn3(z*1/c)))
  z = z*1/c
  
bailout:
  |real(z)| <= @bailout


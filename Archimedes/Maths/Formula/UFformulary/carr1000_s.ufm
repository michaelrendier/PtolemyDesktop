Carr1010Sa {
; A "Modified Carr" formula, based on the original with permission.
; Functionality added by Sharon S. Schultz, May, 2003.
; Piece of Barnsley thrown in here
; Converted for UF by Erik Reckase, February 22, 2000
; SOURCE: 24Carr.frm

init:
  z = (1/(pixel*pixel+2))/@scale
  
  if (|3.324| <= 0)
   z = 1
  else
   z = 0
  endif

  c = ((0.1,0.36)*z+3.324)
  
loop:
  z = fn1(fn2(fn3(z*z+1/c)))
  
bailout:
  |real(z)| <= @bailout

default:
title = "Carr-1010Sa"
method = multipass
periodicity = 0
center = (0,0)
maxiter = 100

heading
caption = "Parameters"

  z = (sinh((1/pixel)/(0.95,0)))/@scale
  c = conj(cos((1/pixel)/(0.95,0)))
  
loop:
  z = fn1(fn2(fn3((pixel-z*z)/(pixel-c*c))))
  
bailout:
  |real(z)| <= @bailout
  

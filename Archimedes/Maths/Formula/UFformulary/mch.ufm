    caption = "BailOut"
    default = 1.0E-20
  endparam
  param seed
    caption = "Seed"
    default = (0.0, 0.0)
    hint = "Perturbs the set."
  endparam
  func init
    caption = "Initial function"
    default = ident()
    hint = "Applied once for each pixel."

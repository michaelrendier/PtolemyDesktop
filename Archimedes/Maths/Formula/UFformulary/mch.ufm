  complex den = z^c + a*z^(@myN-1.0)
  if den != 0
    z = @iterfunc((a*z^@myN + b)/den) + @seed
    delta = |z-oldz|
    oldz = z
  else
    delta = @bailout
  endif
bailout:
; This section should contain a boolean expression, such as
; |z| < 4. When this expression becomes false, the iteration

    caption = "Function A1"
    visible = @showfn1 && @seq != 2
  endfunc
  float param ampA1
    default = 1.0
    caption = "Amplitude A1"
    visible = @showfn1 && @seq != 2
  endparam
  float param dAmpA1
    default = 0.0
    caption = "Delta Amplitude A1"
    visible = @showfn1 && @seq != 2 && @progressive
  endparam
  float param freqA1

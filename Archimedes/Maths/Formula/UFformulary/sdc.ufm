  float param p6pB
    caption = "B"
    default = 1.0
    visible = @perturb==6     ; Quadrup Two
  endparam
  
  float param p6pC
    caption = "C"
    default = 1.0
    visible = @perturb==6     ; Quadrup Two
  endparam

  float param p7pA
    caption = "A"
    default = 3.14
    visible = @perturb==7     ; Quadrup Two
  endparam
  
  func p7fn                  ; Martin
    caption = "Martin Function"
    default = sin()
    visible = @perturb==7
  endfunc
  
  float param p8pA            ; Chip
    caption = "a"
    default = -1.5
    visible = @perturb==8
  endparam

  float param p8pB            ; Chip
    caption = "b"
    default = -1.9
    visible = @perturb==8
  endparam

  float param p8pC            ; Chip
    caption = "c"
    default = 1.0
    visible = @perturb==8
  endparam
  
  heading
    caption = "Slope Parameters"
    visible = @slope==true
  endheading   

  float param offset
    caption = "Orbit Separation"
    default = 0.01
    hint = "Defines how far apart the simultaneous orbits are.  Smaller \
            distances will produce more accurate results."
    visible = @slope==true
  endparam
  param zmode
    caption = "Height Value"
    default = 5
    enum = "smallest |z|" "smallest |real(z)|" \
           "smallest |imag(z)|" "smallest summ(z)" "smallest |atan(z)|" \
           "smoothed iteration"
    hint = "Specifies what will be used to construct a height value."
    visible = @slope==true
  endparam
  param xfer
    caption = "Height Transfer"
    default = 0
    enum = "linear" "log" "sqrt" "cuberoot" "exp" "sqr" "cube" "sin" "cos" "tan"
    hint = "This function will be applied to the height value \
            before a slope is calculated."
    visible = @slope==true
  endparam
  param zscale
    caption = "Height Pre-Scale"
    default = 100.0
    hint = "Specifies the ratio between height and distance.  Higher \
            values will exaggerate differences between high and low. \
            In general, you will want to use smaller numbers here."
    visible = @slope==true
  endparam
  param zscale2
    caption = "Height Post-Scale"
    default = 100.0
    hint = "Specifies the ratio between height and distance; like \
            Height Pre-Scale, except that this value is applied after \
            the transfer function."
    visible = @slope==true
  endparam
  param everyiter
    caption = "Every Iteration"
    default = true
    hint = "If set, the surface normal will be computed at every \
            iteration.  If you are using a coloring algorithm which \
            processes every iteration, you will need this."
    visible = @slope==true
  endparam  
  bool param accident
    caption = "Accident"
    default = false
    visible = @slope==true
  endparam
  

}

;_______________________________________________________
;«¤»Ą«¤»§«¤»Ą«¤»§«¤»Ą«¤»§«¤»Ą«¤»§«¤»Ą«¤»§«¤»Ą«¤»§«¤»Ą«¤»
;ŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻ
sdc-slopeisleofchaos {
; inspired by work by Jon Osuch & George Martin
; May, 2004, Susan D. Chambless
; slope method from Ron Barrett
; Slope modification, January, 2004, Susan Chambless
init:
  ;default to Mandelbrot
   complex z1 = @z0
   complex z2 = z1
   complex z3 = z1
   complex c1 = #pixel
   complex c2 = c1 + @offset
   complex c3 = c1 + flip(@offset)
   if( @mode == "Julia" )
     z1 = #pixel
     z2 = z1 + @offset
     z3 = z1 + flip(@offset)
     c1 = @seed
     c2 = c1
     c3 = c1
   endif
   
   ;;; slope stuff
   int done = 2
   float e1 = 0.0; potentials
   float e2 = 0.0
   float e3 = 0.0
   float vx = 0.0; normal vector
   float vy = 0.0
   float vz = 0.0
   float vd = 0.0
   float d1 = 0.0; distances
   float d2 = 0.0
   float d3 = 0.0
   float s1 = 1.0e20; smallest distances
   float s2 = 1.0e20
   float s3 = 1.0e20
   float iterexp1 = 0.0
   float iterexp2 = 0.0
   float iterexp3 = 0.0
  
   int iter = 1
   int   seed = random(@randomseed)
  
loop:
  bool  formula1 = false
  
  iter = iter + 1
  
  if (@method == 1 || @method == 2) ; select formula
  
    ; Determine formula to be used:
    if ( @seq == 0 )                  ; First formula
      formula1 = true
    elseif ( @seq == 1 )              ; Second formula
      formula1 = false
    elseif ( @seq==3 )
      seed = random(seed)
      if ( abs(seed)/#randomrange < @prob1 )
        formula1 = true
      else
        formula1 = false
      endif
      if (@invertMod == true)
        formula1 = !formula1
      endif
    elseif ( @seq == 2 ); Modulation
      if (iter % @modBy < @modCmp)
        formula1 = true
      else
        formula1 = false
      endif
      if (@invertMod == true)
        formula1 = !formula1
      endif
    elseif ( @seq==3 )
      seed = random(seed)
      if ( abs(seed)/#randomrange < @prob1 )
        formula1 = true
      else
        formula1 = false
      endif
      if (@invertMod == true)
        formula1 = !formula1
      endif
    endif
  endif
    
  if (@method == 0)
    z1=@fn1(z1) + c1
    z2=@fn1(z2) + c2
    z3=@fn1(z3) + c3

    z1=@fn2(z1)/@fn3(z1) + c1
    z2=@fn2(z2)/@fn3(z2) + c2
    z3=@fn2(z3)/@fn3(z3) + c3

  elseif (@method == 1)      
    if (formula1 == true)
      z1=@fn1(z1) + c1
      z2=@fn1(z2) + c2
      z3=@fn1(z3) + c3
    else  ;formula 2
      if (@operation == "/")
        z1=@fn2(z1)/(@fn3(z1)+0.000001) + c1
        z2=@fn2(z2)/(@fn3(z2)+0.000001) + c2
        z3=@fn2(z3)/(@fn3(z3)+0.000001) + c3
      elseif (@operation == "*")
        z1=@fn2(z1)*(@fn3(z1)) + c1
        z2=@fn2(z2)*(@fn3(z2)) + c2
        z3=@fn2(z3)*(@fn3(z3)) + c3
      elseif (@operation == "+")
        z1=@fn2(z1)+(@fn3(z1)) + c1
        z2=@fn2(z2)+(@fn3(z2)) + c2
        z3=@fn2(z3)+(@fn3(z3)) + c3
      elseif (@operation == "-")
        z1=@fn2(z1)-(@fn3(z1)) + c1
        z2=@fn2(z2)-(@fn3(z2)) + c2
        z3=@fn2(z3)-(@fn3(z3)) + c3
      elseif (@operation == "^")
        z1=@fn2(z1)^(@fn3(z1)) + c1
        z2=@fn2(z2)^(@fn3(z2)) + c2
        z3=@fn2(z3)^(@fn3(z3)) + c3
      endif
    endif
  elseif (@method == 2)
    if (formula1 == true)
      z1 = flip(@fn1(z1)+.00001) + c1
      z2 = flip(@fn1(z2)+.00001) + c2
      z3 = flip(@fn1(z3)+.00001) + c3
    else ; formula2
      if (@operation == "/")
        z1=@fn2(z1)/(@fn3(z1)+0.000001) + c1
        z2=@fn2(z2)/(@fn3(z2)+0.000001) + c2
        z3=@fn2(z3)/(@fn3(z3)+0.000001) + c3
      elseif (@operation == "*")
        z1=@fn2(z1)*(@fn3(z1)) + c1
        z2=@fn2(z2)*(@fn3(z2)) + c2
        z3=@fn2(z3)*(@fn3(z3)) + c3
      elseif (@operation == "+")
        z1=@fn2(z1)+(@fn3(z1)) + c1
        z2=@fn2(z2)+(@fn3(z2)) + c2
        z3=@fn2(z3)+(@fn3(z3)) + c3
      elseif (@operation == "-")
        z1=@fn2(z1)-(@fn3(z1)) + c1
        z2=@fn2(z2)-(@fn3(z2)) + c2
        z3=@fn2(z3)-(@fn3(z3)) + c3
      elseif (@operation == "^")
        z1=@fn2(z1)^(@fn3(z1)) + c1
        z2=@fn2(z2)^(@fn3(z2)) + c2
        z3=@fn2(z3)^(@fn3(z3)) + c3
      endif
    endif
  endif
  
  z1 = @overallfn(z1)
  z2 = @overallfn(z2)
  z3 = @overallfn(z3)
  
  if (@oddevenC == 1)
    c1 = -c1
    c2 = -c2
    c3 = -c3
  elseif (@oddevenC == 2)
    c1 = conj(c1)
    c2 = conj(c2)
    c3 = conj(c3)
  elseif (@oddevenC == 3)
    c1 = flip(c1)
    c2 = flip(c2)
    c3 = flip(c3)
  elseif (@oddevenC == 4)
    c1 = recip(c1)
    c2 = recip(c2)
    c3 = recip(c3)
  endif
  
  z1 = z1/@finmult
  z2 = z2/@finmult
  z3 = z3/@finmult
  
  if (@slope == true)
  ;;;;  process slope  
    IF (@zmode == 5)
      iterexp1 = iterexp1 + exp(-cabs(z1))
      iterexp2 = iterexp2 + exp(-cabs(z2))
      iterexp3 = iterexp3 + exp(-cabs(z3))
    ENDIF
    done = done + 1; increment iteration counter
  
    IF (@zmode == 0)                      ; smallest |z|
      d1 = |z1|; get current distances from origin
      d2 = |z2|
      d3 = |z3|
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 1)                  ; smallest |real(z)|
      d1 = abs(real(z1)); get current distances from i axis
      d2 = abs(real(z2))
      d3 = abs(real(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 2)                  ; smallest |imag(z)|
      d1 = abs(imag(z1)); get current distances from r axis
      d2 = abs(imag(z2))
      d3 = abs(imag(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 3)                  ; smallest |real(z)|+|imag(z)|
      d1 = abs(real(z1))+abs(imag(z1)); get current distances from i axis
      d2 = abs(real(z2))+abs(imag(z2))
      d3 = abs(real(z3))+abs(imag(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 4)                  ; smallest |atan(z)|
      d1 = abs(atan2(z1)); get current angles
      d2 = abs(atan2(z2))
      d3 = abs(atan2(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ENDIF
  
    IF (@bailout < |z1| ||                \
        @everyiter ||\
        done == #maxiter + 2); done, or every iteration, or last
      ; determine continuous iteration (height) for each point
      IF (@zmode >= 0 && @zmode <= 4) ; height based on smallest |z|
        e1 = s1 * @zscale
        e2 = s2 * @zscale
        e3 = s3 * @zscale
      ELSEIF (@zmode == 5)
        e1 = iterexp1 * @zscale
        e2 = iterexp2 * @zscale
        e3 = iterexp3 * @zscale
      ENDIF
  
      ; apply transfer function
      ; a function is not used because these are floats
      ; and not all functions apply to floats
      IF (@xfer == 1); log
        e1 = log(e1)
        e2 = log(e2)
        e3 = log(e3)
      ELSEIF (@xfer == 2); sqrt
        e1 = sqrt(e1)
        e2 = sqrt(e2)
        e3 = sqrt(e3)
      ELSEIF (@xfer == 3); cuberoot
        e1 = (e1)^(1/3)
        e2 = (e2)^(1/3)
        e3 = (e3)^(1/3)
      ELSEIF (@xfer == 4); exp
        e1 = exp(e1)
        e2 = exp(e2)
        e3 = exp(e3)
      ELSEIF (@xfer == 5); sqr
        e1 = sqr(e1)
        e2 = sqr(e2)
        e3 = sqr(e3)
      ELSEIF (@xfer == 6); cube
        e1 = (e1)^3
        e2 = (e2)^3
        e3 = (e3)^3
      ELSEIF (@xfer == 7); sin
        e1 = sin(e1)
        e2 = sin(e2)
        e3 = sin(e3)
      ELSEIF (@xfer == 8); cos
        e1 = cos(e1)
        e2 = cos(e2)
        e3 = cos(e3)
      ELSEIF (@xfer == 9); tan
        e1 = tan(e1)
        e2 = tan(e2)
        e3 = tan(e3)
      ENDIF
  
      ; apply post-scale
      e1 = e1 * @zscale2
      e2 = e2 * @zscale2
      e3 = e3 * @zscale2
  
        vx = e2-e1
        vy = e3-e1
        vz = -@offset
        ; normalize vector
        vd = 1/sqrt(sqr(vx)+sqr(vy)+sqr(vz))
        vx = vx*vd
        vy = vy*vd
        vz = vz*vd
        z = vx + flip(vy); fudge z from vector
    ELSE; didn't compute z this time
      z = z1; use primary iteration value to keep periodicity working
    ENDIF
  else
    z = z1
  endif
  IF (@bailout < |z1|)                  ; we're done
    done = 0
  ENDIF

    
bailout:
  (done > 0)
  
  
switch:
  type       = "sdc-slopeisleofchaos"
  version    = @version
  bailout    = @bailout
  mode       = @switchmode
  switchMode = @mode
  seed       = #pixel
  z0         = @z0
  fn1        = @fn1
  fn2        = @fn2
  fn3        = @fn3
  modBy      = @modBy
  modCmp     = @modCmp
  seq        = @seq
  randomseed = @randomseed
  prob1      = @prob1
  invertMod  = @invertMod
  method     = @method
  oddevenC   = @oddevenC
  finmult    = @finmult
  operation  = @operation
  overallfn  = @overallfn
  
  slope      = @slope
  offset     = @offset
  zmode      = @zmode
  xfer       = @xfer
  zscale     = @zscale
  zscale2    = @zscale2
  everyiter  = @everyiter

default:
  title = "Slope Isle of Chaos"
  method = multipass
  periodicity = 0
  magn = 1
  maxiter = 100

  float param version
    default = 0.0
    visible = false
  endparam

  param mode
    caption = "Current Mode"
    default = 0
    enum = "Mandelbrot" "Julia"
    visible = false
  endparam
  
  param switchMode
    caption = "Switch Mode"
    default = 1
    enum = "Mandelbrot" "Julia"
    visible = false
  endparam

  heading
    caption = "Mandlebrot Mode"
    visible = @mode==0
  endheading
  
  heading
    caption = "Julia Mode"
    visible = @mode==1
  endheading

  param bailout
    caption = "Bailout"
    default = 4
  endparam
  
  param method
    caption = "Loop Method"
    enum = "1" "2" "3" ;"4"
    default = 0
  endparam
  
  param seq
    caption = "Sequence Method"
    enum = "Formula 1" "Formula 2" "Sequenced" "Random Blend"
    default = 2
    visible = @method>0
  endparam
  
  int param modBy
    default = 10
    caption = "Mod By"
    hint = "Iteration Modulated by This"
    visible = @method>0 && @seq==2
  endparam
  
  int param modCmp
    default = 5
    caption = "Mod Compare"
    hint = "Modulated Iteration < this -> formula 1"
    visible = @method>0 && @seq==2
  endparam
  
  int param randomseed
    caption = "Random Seed"
    default = 123456
    visible = @seq==3
    hint = "Influences the order in which the two formulas are used."
  endparam
  float param prob1
    caption = "Prob for Formula 1"
    default = 0.5
    min = 0.0
    max = 1.0
    visible = @seq==3
    hint = "Determines how often Formula 1 is used.  Probability for Formula 2 is (1.0 - Probability for Formula 1)" 
  endparam
  bool param invertMod
    caption = "Invert Sequence?"
    hint = "Inverse the order of formulas used"
    visible = @seq==2 || @seq==3
  endparam

  param operation
    caption = "Operation"
    enum = "/" "*" "-" "+" "^"
    default = 0
    visible = @method>0
  endparam
  
  param z0
    caption = "Initial Z"
    default = (0.0, 0.0)
    visible = @mode==0
  endparam
  
  param seed
    caption = "Julia Seed"
    default = (0.0, 0.0)
    visible = @mode==1
  endparam
  
  func fn1
    caption = "Function 1"
    default = sqr()
  endfunc
  
  func fn2
    caption = "Function 2"
    default = sin()
  endfunc
  
  func fn3
    caption = "Function 3"
    default = cos()
  endfunc
  
  func overallfn
    caption = "Overall Function"
    default = ident()
  endfunc
  
  param oddevenC
    caption = "Odd/Even Method For C"
    enum = "None" "-C" "conj(C)" "flip(C)" "recip(C)"
  endparam
  
  float param finmult
    caption = "Final Multiplier"
    default = 1.0
    min = .01
    max = 10
  endparam
   
  bool param slope
    caption = "Apply slope?"
    default = true
  endparam

  
  heading
    caption = "Slope Parameters"
    visible = @slope == true
  endheading   

  float param offset
    caption = "Orbit Separation"
    default = 0.005
    hint = "Defines how far apart the simultaneous orbits are.  Smaller \
            distances will produce more accurate results."
    visible = @slope == true
  endparam
  param zmode
    caption = "Height Value"
    default = 5
    enum = "smallest |z|" "smallest |real(z)|" \
           "smallest |imag(z)|" "smallest summ(z)" "smallest |atan(z)|" \
           "smoothed iteration"
    hint = "Specifies what will be used to construct a height value."
    visible = @slope == true
  endparam
  param xfer
    caption = "Height Transfer"
    default = 0
    enum = "linear" "log" "sqrt" "cuberoot" "exp" "sqr" "cube" "sin" "cos" "tan"
    hint = "This function will be applied to the height value \
            before a slope is calculated."
    visible = @slope == true
  endparam
  param zscale
    caption = "Height Pre-Scale"
    default = 1.0
    hint = "Specifies the ratio between height and distance.  Higher \
            values will exaggerate differences between high and low. \
    In general, you will want to use smaller numbers here."
    visible = @slope == true
  endparam
  param zscale2
    caption = "Height Post-Scale"
    default = 1.0
    hint = "Specifies the ratio between height and distance; like \
            Height Pre-Scale, except that this value is applied after \
    the transfer function."
    visible = @slope == true
  endparam
  param everyiter
    caption = "Every Iteration"
    default = true
    hint = "If set, the surface normal will be computed at every \
            iteration.  If you are using a coloring algorithm which \
    processes every iteration, you will need this."
    visible = @slope == true
  endparam  

    
}

;_______________________________________________________
;«¤»Ą«¤»§«¤»Ą«¤»§«¤»Ą«¤»§«¤»Ą«¤»§«¤»Ą«¤»§«¤»Ą«¤»§«¤»Ą«¤»
;ŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻ
sdc-slope-manjul2 {
; Simple mandelbrot-julia switch
; Template for many of my formulae
; Jazzed up with a couple of functions

init:
  ;default to Mandelbrot
   complex c1 = #pixel
   complex c2 = c1 + @offset
   complex c3 = c1 + flip(@offset)
   complex z1 = @z0
   complex z2 = z1
   complex z3 = z1
   if( @mode == "Julia" )
     z1 = #pixel
     z2 = z1 + @offset
     z3 = z1 + flip(@offset)
     c1 = @seed
     c2 = c1
     c3 = c1
   endif

   int   seed = random(@randomseed)
   int   iter = 0
   
   ;;; slope stuff
   int done = 2
   float e1 = 0.0; potentials
   float e2 = 0.0
   float e3 = 0.0
   float vx = 0.0; normal vector
   float vy = 0.0
   float vz = 0.0
   float vd = 0.0
   float d1 = 0.0; distances
   float d2 = 0.0
   float d3 = 0.0
   float s1 = 1.0e20; smallest distances
   float s2 = 1.0e20
   float s3 = 1.0e20
   float iterexp1 = 0.0
   float iterexp2 = 0.0
   float iterexp3 = 0.0
   
loop:
  ; Determine formula to be used:
  bool  formula1 = false 
  if ( @seq == 1 )                  ; First formula
    formula1 = true
  elseif ( @seq == 2 )              ; Second formula
    formula1 = false
  elseif ( @seq==3 )
    seed = random(seed)
    if ( abs(seed)/#randomrange < @prob1 )
      formula1 = true
    else
      formula1 = false
     endif
    if (@invertMod == true)
      formula1 = !formula1
    endif
  elseif ( @seq == 0 ); Modulation
    if (iter % @modBy < @modCmp)
      formula1 = true
    else
      formula1 = false
    endif
    if (@invertMod == true)
      formula1 = !formula1
    endif
  endif
  
  iter = iter + 1
  
  if (formula1 == true)
    if (@dmethod1 == 0)
      if (@method1 == 0)
        z1 = @fn11(z1^@pow1) + c1
        z2 = @fn11(z2^@pow1) + c2
        z3 = @fn11(z3^@pow1) + c3
      else
        z1 = @fn11(z1)^@pow1 + c1
        z2 = @fn11(z2)^@pow1 + c2
        z3 = @fn11(z3)^@pow1 + c3
      endif
    elseif (@dmethod1 == 1)
      float x1 = real(z1)
      float x2 = real(z2)
      float x3 = real(z3)
      float y1 = imag(z1)
      float y2 = imag(z2)
      float y3 = imag(z3)
      
      if (@method1 == 0)
        x1 = real( @fn11(x1^@pow1) )
        x2 = real( @fn11(x2^@pow1) )
        x3 = real( @fn11(x3^@pow1) )
        y1 = real( @fn12(y1^@pow1) )
        y2 = real( @fn12(y2^@pow1) )
        y3 = real( @fn12(y3^@pow1) )
      else
        x1 = real( @fn11(x1)^@pow1 )
        x2 = real( @fn11(x2)^@pow1 )
        x3 = real( @fn11(x3)^@pow1 )
        y1 = real( @fn12(y1)^@pow1 )
        y2 = real( @fn12(y2)^@pow1 )
        y3 = real( @fn12(y3)^@pow1 )
      endif    
      z1 = x1 + flip(y1) + c1
      z2 = x2 + flip(y2) + c2
      z3 = x3 + flip(y3) + c3
    else  ; dmethod1 ==2
      r1  = cabs(z1)
      r2  = cabs(z2)
      r3  = cabs(z3)
      th1 = atan2(z1)
      th2 = atan2(z2)
      th3 = atan2(z3)
      rf1 = r1^@pow1
      rf2 = r2^@pow1
      rf3 = r3^@pow1
      if (@method1 == 0)
        x1 = real(@fn11(rf1*cos(@pow1*th1)))
        x2 = real(@fn11(rf2*cos(@pow1*th2)))
        x3 = real(@fn11(rf3*cos(@pow1*th3)))
        y1 = real(@fn12(rf1*sin(@pow1*th1)))
        y2 = real(@fn12(rf2*sin(@pow1*th2)))
        y3 = real(@fn12(rf3*sin(@pow1*th3)))
      else
        x1 = real(rf1*(cos(@fn11(@pow1*th1))))
        x2 = real(rf2*(cos(@fn11(@pow1*th2))))
        x3 = real(rf3*(cos(@fn11(@pow1*th3))))
        y1 = real(rf1*(sin(@fn12(@pow1*th1))))
        y2 = real(rf2*(sin(@fn12(@pow1*th2))))
        y3 = real(rf3*(sin(@fn12(@pow1*th3))))
      endif    
      z1 = x1 + flip(y1) + c1
      z2 = x2 + flip(y2) + c2
      z3 = x3 + flip(y3) + c3
    endif
  else ;formula 2
    if (@dmethod2 == 0)
      if (@method2 == 0)
        z1 = @fn21(z1^@pow2) + c1
        z2 = @fn21(z2^@pow2) + c2
        z3 = @fn21(z3^@pow2) + c3
      else
        z1 = @fn21(z1)^@pow2 + c1
        z2 = @fn21(z2)^@pow2 + c2
        z3 = @fn21(z3)^@pow2 + c3
      endif
    elseif (@dmethod2 == 1)
      float x1 = real(z1)
      float x2 = real(z2)
      float x3 = real(z3)
      float y1 = imag(z1)
      float y2 = imag(z2)
      float y3 = imag(z3)
      
      if (@method2 == 0)
        x1 = real( @fn21(x1^@pow2) )
        x2 = real( @fn21(x2^@pow2) )
        x3 = real( @fn21(x3^@pow2) )
        y1 = real( @fn22(y1^@pow2) )
        y2 = real( @fn22(y2^@pow2) )
        y3 = real( @fn22(y3^@pow2) )
      else
        x1 = real( @fn21(x1)^@pow2 )
        x2 = real( @fn21(x2)^@pow2 )
        x3 = real( @fn21(x3)^@pow2 )
        y1 = real( @fn22(y1)^@pow2 )
        y2 = real( @fn22(y2)^@pow2 )
        y3 = real( @fn22(y3)^@pow2 )
      endif 
      z1 = x1 + flip(y1) + c1
      z2 = x2 + flip(y2) + c2
      z3 = x3 + flip(y3) + c3
    else  ; dmethod2 ==2
      r1  = cabs(z1)
      r2  = cabs(z2)
      r3  = cabs(z3)
      th1 = atan2(z1)
      th2 = atan2(z2)
      th3 = atan2(z3)
      rf1 = r1^@pow2
      rf2 = r2^@pow2
      rf3 = r3^@pow2
      if (@method1 == 0)
        x1 = real(@fn21(rf1*cos(@pow2*th1)))
        x2 = real(@fn21(rf2*cos(@pow2*th2)))
        x3 = real(@fn21(rf3*cos(@pow2*th3)))
        y1 = real(@fn22(rf1*sin(@pow2*th1)))
        y2 = real(@fn22(rf2*sin(@pow2*th2)))
        y3 = real(@fn22(rf3*sin(@pow2*th3)))
      else
        x1 = real(rf1*(cos(@fn21(@pow2*th1))))
        x2 = real(rf2*(cos(@fn21(@pow2*th2))))
        x3 = real(rf3*(cos(@fn21(@pow2*th3))))
        y1 = real(rf1*(sin(@fn22(@pow2*th1))))
        y2 = real(rf2*(sin(@fn22(@pow2*th2))))
        y3 = real(rf3*(sin(@fn22(@pow2*th3))))
      endif    
      z1 = x1 + flip(y1) + c1
      z2 = x2 + flip(y2) + c2
      z3 = x3 + flip(y3) + c3
    endif  
  endif
  

    
  if (@slope == true)
  ;;;;  process slope  
    IF (@zmode == 5)
      iterexp1 = iterexp1 + exp(-cabs(z1))
      iterexp2 = iterexp2 + exp(-cabs(z2))
      iterexp3 = iterexp3 + exp(-cabs(z3))
    ENDIF
    done = done + 1; increment iteration counter
  
    IF (@zmode == 0)                      ; smallest |z|
      d1 = |z1|; get current distances from origin
      d2 = |z2|
      d3 = |z3|
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 1)                  ; smallest |real(z)|
      d1 = abs(real(z1)); get current distances from i axis
      d2 = abs(real(z2))
      d3 = abs(real(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 2)                  ; smallest |imag(z)|
      d1 = abs(imag(z1)); get current distances from r axis
      d2 = abs(imag(z2))
      d3 = abs(imag(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 3)                  ; smallest |real(z)|+|imag(z)|
      d1 = abs(real(z1))+abs(imag(z1)); get current distances from i axis
      d2 = abs(real(z2))+abs(imag(z2))
      d3 = abs(real(z3))+abs(imag(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 4)                  ; smallest |atan(z)|
      d1 = abs(atan2(z1)); get current angles
      d2 = abs(atan2(z2))
      d3 = abs(atan2(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ENDIF
  
    IF (@bailout < |z1| ||                \
        @everyiter ||\
        done == #maxiter + 2); done, or every iteration, or last
      ; determine continuous iteration (height) for each point
      IF (@zmode >= 0 && @zmode <= 4) ; height based on smallest |z|
        e1 = s1 * @zscale
        e2 = s2 * @zscale
        e3 = s3 * @zscale
      ELSEIF (@zmode == 5)
        e1 = iterexp1 * @zscale
        e2 = iterexp2 * @zscale
        e3 = iterexp3 * @zscale
      ENDIF
  
      ; apply transfer function
      ; a function is not used because these are floats
      ; and not all functions apply to floats
      IF (@xfer == 1); log
        e1 = log(e1)
        e2 = log(e2)
        e3 = log(e3)
      ELSEIF (@xfer == 2); sqrt
        e1 = sqrt(e1)
        e2 = sqrt(e2)
        e3 = sqrt(e3)
      ELSEIF (@xfer == 3); cuberoot
        e1 = (e1)^(1/3)
        e2 = (e2)^(1/3)
        e3 = (e3)^(1/3)
      ELSEIF (@xfer == 4); exp
        e1 = exp(e1)
        e2 = exp(e2)
        e3 = exp(e3)
      ELSEIF (@xfer == 5); sqr
        e1 = sqr(e1)
        e2 = sqr(e2)
        e3 = sqr(e3)
      ELSEIF (@xfer == 6); cube
        e1 = (e1)^3
        e2 = (e2)^3
        e3 = (e3)^3
      ELSEIF (@xfer == 7); sin
        e1 = sin(e1)
        e2 = sin(e2)
        e3 = sin(e3)
      ELSEIF (@xfer == 8); cos
        e1 = cos(e1)
        e2 = cos(e2)
        e3 = cos(e3)
      ELSEIF (@xfer == 9); tan
        e1 = tan(e1)
        e2 = tan(e2)
        e3 = tan(e3)
      ENDIF
  
      ; apply post-scale
      e1 = e1 * @zscale2
      e2 = e2 * @zscale2
      e3 = e3 * @zscale2
  
        vx = e2-e1
        vy = e3-e1
        vz = -@offset
        ; normalize vector
        vd = 1/sqrt(sqr(vx)+sqr(vy)+sqr(vz))
        vx = vx*vd
        vy = vy*vd
        vz = vz*vd
        z = vx + flip(vy); fudge z from vector
    ELSE; didn't compute z this time
      z = z1; use primary iteration value to keep periodicity working
    ENDIF
  else
    z = z1
  endif
  IF (@bailout < |z1|)                  ; we're done
    done = 0
  ENDIF

    
bailout:
  (done > 0)
  
switch:
  type       = "sdc-slope-manjul2"
  bailout    = @bailout
  mode       = @switchmode
  switchMode = @mode
  version    = @version
  seed       = #pixel   ;;; backward compatibility

  seq        = @seq
  modBy      = @modBy
  modCmp     = @modCmp
  randomseed = @randomseed
  prob1      = @prob1
  invertMod  = @invertMod
  doprogressive = @doprogressive
 
  fn11       = @fn11
  fn12       = @fn12
  pow1       = @pow1
  method1    = @method1
  dmethod1   = @dmethod1

  fn21       = @fn21
  fn22       = @fn22
  pow2       = @pow2
  method2    = @method2
  dmethod2   = @dmethod2
 
  slope      = @slope
  offset     = @offset
  zmode      = @zmode
  xfer       = @xfer
  zscale     = @zscale
  zscale2    = @zscale2
  everyiter  = @everyiter

  
default:
  title = "Slope ManJul 2"
  method = multipass
  periodicity = 0
  magn = 1
  center = (-0.5, 0.0)
  maxiter = 100

  param mode
    caption = "Current Mode"
    default = 0
    enum = "Mandelbrot" "Julia"
    visible = false
  endparam
  
  param switchMode
    caption = "Switch Mode"
    default = 1
    enum = "Mandelbrot" "Julia"
    visible = false
  endparam
  
  float param version
    default = 1.2
    visible = false
  endparam

  heading
    caption = "Mandlebrot Mode"
    visible = @mode==0
  endheading
  
  heading
    caption = "Julia Mode"
    visible = @mode==1
  endheading
  
  float param bailout
    caption = "Bailout"
    default = 4.0
  endparam
    
  param seed
    caption = "Julia Seed"
    default = (0.0, 0.0)
    visible = @mode==1
  endparam
  
  param z0
    caption = "Initial Z"
    default = (0.0, 0.0)
    visible = @mode==0
  endparam

  bool param slope
    caption = "Apply slope?"
    default = true
  endparam

  int param seq
    enum = "Modulation" "First Formula" "Second Formula" "Random"
    default = 1
    caption = "Formula Sequence"
  endparam
  
  int param modBy
    default = 10
    caption = "Mod By"
    hint = "Iterations are counted in cycles of this size."
    visible = @seq==0
  endparam
  
  int param modCmp
    default = 5
    caption = "Mod Compare"
    hint = "Determines how many times Formula 1 is used before using \
            Formula 2 in each cycle."
    visible = @seq==0
  endparam
  int param randomseed
    caption = "Random Seed"
    default = 123456
    visible = @seq==3
    hint = "Influences the order in which the two formulas are used."
  endparam
  float param prob1
    caption = "Prob for Formula 1"
    default = 0.5
    min = 0.0
    max = 1.0
    visible = @seq==3
    hint = "Determines how often Formula 1 is used.  Probability for Formula 2 is (1.0 - Probability for Formula 1)" 
  endparam

  bool param invertMod
    caption = "Invert Sequence?"
    hint = "Inverse the order of formulas used"
    visible = @seq==0 || @seq==3
  endparam
    
  heading
    caption = "Formula 1"
    visible = @seq != 2
  endheading
  
  param method1
    caption = "Method 1"
    enum = "f(z^p)" "f(z)^p"
    default = 0
    visible = @seq != 2
  endparam
  
  param dmethod1
    Caption = "Dissection Method 1"
    enum = "None" "Intriguing Mistake" "Corrected"
    default = 0
    visible = @seq != 2
  endparam

  param pow1
    caption = "Power 1"
    default = (1.0, 0.0)
    visible = @seq != 2
  endparam
  
  func fn11
    caption = "Function 1"
    default = sqr()
    visible = @seq != 2
  endfunc

  func fn12
    caption = "2nd Function 1"
    default = sqr()
    visible = @seq != 2 && @dmethod1!=0
  endfunc
  
  heading
    caption = "Formula 2"
    visible = @seq != 1
  endheading
  
  param method2
    caption = "Method 2"
    enum = "f(z^p)" "f(z)^p"
    default = 0
    visible = @seq != 1
  endparam
  
  param dmethod2
    Caption = "Dissection Method 2"
    enum = "None" "Intriguing Mistake" "Corrected"
    default = 0
    visible = @seq != 1
  endparam

  param pow2
    caption = "Power 2"
    default = (2.0, 0.0)
    visible = @seq != 1
  endparam
  
  func fn21
    caption = "Function 2"
    default = sqr()
    visible = @seq != 1
  endfunc

  func fn22
    caption = "2nd Function 2"
    default = sqr()
    visible = @seq != 1 && @dmethod2 != 0
  endfunc

  
  heading
    caption = "Slope Parameters"
    visible = @slope == true
  endheading   

  float param offset
    caption = "Orbit Separation"
    default = 0.005
    hint = "Defines how far apart the simultaneous orbits are.  Smaller \
            distances will produce more accurate results."
    visible = @slope == true
  endparam
  param zmode
    caption = "Height Value"
    default = 5
    enum = "smallest |z|" "smallest |real(z)|" \
           "smallest |imag(z)|" "smallest summ(z)" "smallest |atan(z)|" \
           "smoothed iteration"
    hint = "Specifies what will be used to construct a height value."
    visible = @slope == true
  endparam
  param xfer
    caption = "Height Transfer"
    default = 0
    enum = "linear" "log" "sqrt" "cuberoot" "exp" "sqr" "cube" "sin" "cos" "tan"
    hint = "This function will be applied to the height value \
            before a slope is calculated."
    visible = @slope == true
  endparam
  param zscale
    caption = "Height Pre-Scale"
    default = 1.0
    hint = "Specifies the ratio between height and distance.  Higher \
            values will exaggerate differences between high and low. \
    In general, you will want to use smaller numbers here."
    visible = @slope == true
  endparam
  param zscale2
    caption = "Height Post-Scale"
    default = 1.0
    hint = "Specifies the ratio between height and distance; like \
            Height Pre-Scale, except that this value is applied after \
    the transfer function."
    visible = @slope == true
  endparam
  param everyiter
    caption = "Every Iteration"
    default = true
    hint = "If set, the surface normal will be computed at every \
            iteration.  If you are using a coloring algorithm which \
    processes every iteration, you will need this."
    visible = @slope == true
  endparam  

    
}

;_______________________________________________________
;«¤»Ą«¤»§«¤»Ą«¤»§«¤»Ą«¤»§«¤»Ą«¤»§«¤»Ą«¤»§«¤»Ą«¤»§«¤»Ą«¤»
;ŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻ
sdc-slopecentiolier {

; Susan D. Chambless, May, 2003
      ; based on DM0 by Denis Magar
      
init:

  ;default to Mandelbrot
   complex c1 = #pixel
   complex c2 = c1 + @offset
   complex c3 = c1 + flip(@offset)
   complex z1 = @z0
   complex z2 = z1
   complex z3 = z1
   if( @mode == "Julia" )
     z1 = #pixel
     z2 = z1 + @offset
     z3 = z1 + flip(@offset)
     c1 = @seed
     c2 = c1
     c3 = c1
   endif
   
   z1 = @initfcn(z1)
   z2 = @initfcn(z2)
   z3 = @initfcn(z3)
  
   int   seed = random(@randomseed)
   int   iter = 0

   ;;; slope stuff
   int done = 2
   float e1 = 0.0; potentials
   float e2 = 0.0
   float e3 = 0.0
   float vx = 0.0; normal vector
   float vy = 0.0
   float vz = 0.0
   float vd = 0.0
   float d1 = 0.0; distances
   float d2 = 0.0
   float d3 = 0.0
   float s1 = 1.0e20; smallest distances
   float s2 = 1.0e20
   float s3 = 1.0e20
   float iterexp1 = 0.0
   float iterexp2 = 0.0
   float iterexp3 = 0.0
loop:

  ; Determine formula to be used:
  bool  formula1 = false 
  if ( @seq == 1 )                  ; First formula
    formula1 = true
  elseif ( @seq == 2 )              ; Second formula
    formula1 = false
  elseif ( @seq==3 )
    seed = random(seed)
    if ( abs(seed)/#randomrange < @prob1 )
      formula1 = true
    else
      formula1 = false
     endif
    if (@invertMod == true)
      formula1 = !formula1
    endif
  elseif ( @seq == 0 ); Modulation
    if (iter % @modBy < @modCmp)
      formula1 = true
    else
      formula1 = false
    endif
    if (@invertMod == true)
      formula1 = !formula1
    endif
  endif
  
  iter = iter + 1

  if (formula1 == true)
    if @op11 == 0
      pp11 = z1 + c1
      pp12 = z2 + c2
      pp13 = z3 + c3
    elseif @op11 == 1
      pp11 = z1 - c1
      pp12 = z2 - c2
      pp13 = z3 - c3
    elseif @op11 == 2
      pp11 = z1 * c1
      pp12 = z2 * c2
      pp13 = z3 * c3
    elseif @op11 == 3
      pp11 = z1 / c1
      pp12 = z2 / c2
      pp13 = z3 / c3
    else
      pp11 = z1 ^ c1
      pp12 = z2 ^ c2
      pp13 = z3 ^ c3
    endif
  
    if (@recip1  == 1 || @recip1  == 3)
      if pp11 == 0 
        pp11 = 1e-20
      endif  
      if pp12 == 0 
        pp11 = 1e-20
      endif  
      if pp12 == 0 
        pp13 = 1e-20
      endif  
      pp11 = 1/pp11
      pp12 = 1/pp12
      pp13 = 1/pp13
    endif
    
    if @op12 == 0
      pp21 = c1 + @fn11(@fn12(pp11))
      pp22 = c2 + @fn11(@fn12(pp12))
      pp23 = c3 + @fn11(@fn12(pp13))
    elseif @op12 == 1
      pp21 = c1 - @fn11(@fn12(pp11))
      pp22 = c2 - @fn11(@fn12(pp12))
      pp23 = c3 - @fn11(@fn12(pp13))
    elseif @op12 == 2
      pp21 = c1 * @fn11(@fn12(pp11))
      pp22 = c2 * @fn11(@fn12(pp12))
      pp23 = c3 * @fn11(@fn12(pp13))
    elseif @op12 == 3
      pp21 = c1 / @fn11(@fn12(pp11))
      pp22 = c2 / @fn11(@fn12(pp12))
      pp23 = c3 / @fn11(@fn12(pp13))
    else
      pp21 = c1 ^ @fn11(@fn12(pp11))
      pp22 = c2 ^ @fn11(@fn12(pp12))
      pp23 = c3 ^ @fn11(@fn12(pp13))
    endif
    
    if (@recip2  == 2 || @recip2  == 3)
      if pp21 == 0
        pp21 = 1e-20
      endif 
      if pp22 == 0
        pp22 = 1e-20
      endif 
      if pp23 == 0
        pp23 = 1e-20
      endif 
      pp21 = 1/pp21
      pp22 = 1/pp22
      pp23 = 1/pp23
    endif
  else
    if @op21 == 0
      pp11 = z1 + c1
      pp12 = z2 + c2
      pp13 = z3 + c3
    elseif @op21 == 1
      pp11 = z1 - c1
      pp12 = z2 - c2
      pp13 = z3 - c3
    elseif @op21 == 2
      pp11 = z1 * c1
      pp12 = z2 * c2
      pp13 = z3 * c3
    elseif @op21 == 3
      pp11 = z1 / c1
      pp12 = z2 / c2
      pp13 = z3 / c3
    else
      pp11 = z1 ^ c1
      pp12 = z2 ^ c2
      pp13 = z3 ^ c3
    endif
  
    if (@recip1  == 1 || @recip1  == 3)
      if pp11 == 0 
        pp11 = 1e-20
      endif  
      if pp12 == 0 
        pp11 = 1e-20
      endif  
      if pp12 == 0 
        pp13 = 1e-20
      endif  
      pp11 = 1/pp11
      pp12 = 1/pp12
      pp13 = 1/pp13
    endif
    
    if @op22 == 0
      pp21 = c1 + @fn21(@fn22(pp11))
      pp22 = c2 + @fn21(@fn22(pp12))
      pp23 = c3 + @fn21(@fn22(pp13))
    elseif @op22 == 1
      pp21 = c1 - @fn21(@fn22(pp11))
      pp22 = c2 - @fn21(@fn22(pp12))
      pp23 = c3 - @fn21(@fn22(pp13))
    elseif @op22 == 2
      pp21 = c1 * @fn21(@fn22(pp11))
      pp22 = c2 * @fn21(@fn22(pp12))
      pp23 = c3 * @fn21(@fn22(pp13))
    elseif @op22 == 3
      pp21 = c1 / @fn21(@fn22(pp11))
      pp22 = c2 / @fn21(@fn22(pp12))
      pp23 = c3 / @fn21(@fn22(pp13))
    else
      pp21 = c1 ^ @fn21(@fn22(pp11))
      pp22 = c2 ^ @fn21(@fn22(pp12))
      pp23 = c3 ^ @fn21(@fn22(pp13))
    endif
    
    if (@recip1  == 2 || @recip1  == 3)
      if pp21 == 0
        pp21 = 1e-20
      endif 
      if pp22 == 0
        pp22 = 1e-20
      endif 
      if pp23 == 0
        pp23 = 1e-20
      endif 
      pp21 = 1/pp21
      pp22 = 1/pp22
      pp23 = 1/pp23
    endif

  endif
  
  z1 = pp21
  z2 = pp22
  z3 = pp23
  
  if (@slope == true)
  ;;;;  process slope  
    IF (@zmode == 5)
      iterexp1 = iterexp1 + exp(-cabs(z1))
      iterexp2 = iterexp2 + exp(-cabs(z2))
      iterexp3 = iterexp3 + exp(-cabs(z3))
    ENDIF
    done = done + 1; increment iteration counter
  
    IF (@zmode == 0)                      ; smallest |z|
      d1 = |z1|; get current distances from origin
      d2 = |z2|
      d3 = |z3|
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 1)                  ; smallest |real(z)|
      d1 = abs(real(z1)); get current distances from i axis
      d2 = abs(real(z2))
      d3 = abs(real(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 2)                  ; smallest |imag(z)|
      d1 = abs(imag(z1)); get current distances from r axis
      d2 = abs(imag(z2))
      d3 = abs(imag(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 3)                  ; smallest |real(z)|+|imag(z)|
      d1 = abs(real(z1))+abs(imag(z1)); get current distances from i axis
      d2 = abs(real(z2))+abs(imag(z2))
      d3 = abs(real(z3))+abs(imag(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 4)                  ; smallest |atan(z)|
      d1 = abs(atan2(z1)); get current angles
      d2 = abs(atan2(z2))
      d3 = abs(atan2(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ENDIF
  
    IF (@bailout < |z1| ||                \
        @everyiter ||\
        done == #maxiter + 2); done, or every iteration, or last
      ; determine continuous iteration (height) for each point
      IF (@zmode >= 0 && @zmode <= 4) ; height based on smallest |z|
        e1 = s1 * @zscale
        e2 = s2 * @zscale
        e3 = s3 * @zscale
      ELSEIF (@zmode == 5)
        e1 = iterexp1 * @zscale
        e2 = iterexp2 * @zscale
        e3 = iterexp3 * @zscale
      ENDIF
  
      ; apply transfer function
      ; a function is not used because these are floats
      ; and not all functions apply to floats
      IF (@xfer == 1); log
        e1 = log(e1)
        e2 = log(e2)
        e3 = log(e3)
      ELSEIF (@xfer == 2); sqrt
        e1 = sqrt(e1)
        e2 = sqrt(e2)
        e3 = sqrt(e3)
      ELSEIF (@xfer == 3); cuberoot
        e1 = (e1)^(1/3)
        e2 = (e2)^(1/3)
        e3 = (e3)^(1/3)
      ELSEIF (@xfer == 4); exp
        e1 = exp(e1)
        e2 = exp(e2)
        e3 = exp(e3)
      ELSEIF (@xfer == 5); sqr
        e1 = sqr(e1)
        e2 = sqr(e2)
        e3 = sqr(e3)
      ELSEIF (@xfer == 6); cube
        e1 = (e1)^3
        e2 = (e2)^3
        e3 = (e3)^3
      ELSEIF (@xfer == 7); sin
        e1 = sin(e1)
        e2 = sin(e2)
        e3 = sin(e3)
      ELSEIF (@xfer == 8); cos
        e1 = cos(e1)
        e2 = cos(e2)
        e3 = cos(e3)
      ELSEIF (@xfer == 9); tan
        e1 = tan(e1)
        e2 = tan(e2)
        e3 = tan(e3)
      ENDIF
  
      ; apply post-scale
      e1 = e1 * @zscale2
      e2 = e2 * @zscale2
      e3 = e3 * @zscale2
  
        vx = e2-e1
        vy = e3-e1
        vz = -@offset
        ; normalize vector
        vd = 1/sqrt(sqr(vx)+sqr(vy)+sqr(vz))
        vx = vx*vd
        vy = vy*vd
        vz = vz*vd
        z = vx + flip(vy); fudge z from vector
    ELSE; didn't compute z this time
      z = z1; use primary iteration value to keep periodicity working
    ENDIF
  else
    z = z1
  endif
  IF (@bailout < |z1|)                  ; we're done
    done = 0
  ENDIF

    
bailout:
  (done > 0)
  
switch:
  type = "sdc-slopecentiolier"
  version    = @version
  mode       = @switchmode
  switchMode = mode
  bailout    = @bailout
  seed       = #pixel
  z0         = @z0
  initfcn    = @initfcn

  op11       = @op11
  op12       = @op12
  recip1     = @recip1
  fn11       = @fn11
  fn12       = @fn12

  op21       = @op21
  op22       = @op22
  recip2     = @recip2
  fn21       = @fn21
  fn22       = @fn22

  seq        = @seq
  modBy      = @modBy
  modCmp     = @modCmp
  randomseed = @randomseed
  prob1      = @prob1
  invertMod  = @invertMod
  doprogressive = @doprogressive
  
  slope      = @slope
  offset     = @offset
  zmode      = @zmode
  xfer       = @xfer
  zscale     = @zscale
  zscale2    = @zscale2
  everyiter  = @everyiter

default:

  title="Slope Centiolier"
  method = multipass
  periodicity = 0
  
  float param version
    default = 0.0
    visible = false
  endparam

  param mode
    caption = "Current Mode"
    default = 0
    enum = "Mandelbrot" "Julia"
    hint = "Shows current mode"
  endparam
  
  param switchMode
    caption = "Switch Mode"
    default = 1
    enum = "Mandelbrot" "Julia"
    hint = "Shows mode to switch to"
    visible = false
  endparam
  
  param bailout
   caption="Bailout"
   default=4.0
   endparam
   
  complex param z0
    caption = "z0"
    default = (0,0)
    hint = "Perturbation for the Mandelbrot."
    visible = @mode==0
  endparam

  param seed
   caption="Julia Seed"
   default=(0.5,0.0)
   visible = @mode==1
   endparam
   
  int param seq
    enum = "Modulation" "First Formula" "Second Formula" "Random"
    default = 1
    caption = "Formula Sequence"
  endparam
  
  int param modBy
    default = 10
    caption = "Mod By"
    hint = "Iterations are counted in cycles of this size."
    visible = @seq==0
  endparam
  
  int param modCmp
    default = 5
    caption = "Mod Compare"
    hint = "Determines how many times Formula 1 is used before using \
            Formula 2 in each cycle."
    visible = @seq==0
  endparam
  int param randomseed
    caption = "Random Seed"
    default = 123456
    visible = @seq==3
    hint = "Influences the order in which the two formulas are used."
  endparam
  float param prob1
    caption = "Prob for Formula 1"
    default = 0.5
    min = 0.0
    max = 1.0
    visible = @seq==3
    hint = "Determines how often Formula 1 is used.  Probability for Formula 2 is (1.0 - Probability for Formula 1)" 
  endparam

  bool param invertMod
    caption = "Invert Sequence?"
    hint = "Inverse the order of formulas used"
    visible = @seq==0 || @seq==3
  endparam

  func initfcn
   caption = "Initial Function"
   default = ident()
   endfunc
   
  heading
    caption = "Formula 1"
    visible = @seq != 2
  endheading
   param op11
    caption = "Operator 1"
    enum = "+" "-" "*" "/" "^ (exponent)"
    hint = "P1 [op2] fn1(fn2(z [op1] P1))"
    default = 0
    visible = @seq != 2
   endparam
  
  param op12
   caption = "Operator 2"
   enum = "+" "-" "*" "/" "^ (exponent)"
   hint = "P1 [op2] fn1(fn2(z [op1] P1))"
   default = 2
    visible = @seq != 2
   endparam
  
  param recip1
   caption="Reciprocate"
   enum = "None" "Recip Oper1" "Recip Oper2" "Both"
   default = 0
    visible = @seq != 2
   endparam
   
  func fn11
   caption = "Function 1"
   default = asin()
    visible = @seq != 2
   endfunc
   
  func fn12
   caption = "Function 2"
   default = sqr()
    visible = @seq != 2
   endfunc

  heading
    caption = "Formula 2"
    visible = @seq != 1
  endheading
   param op21
    caption = "Operator 1"
    enum = "+" "-" "*" "/" "^ (exponent)"
    hint = "P1 [op1] fn1(fn2(z [op2] P1))"
    default = 0
    visible = @seq != 1
   endparam
  
  param op22
   caption = "Operator 2"
   enum = "+" "-" "*" "/" "^ (exponent)"
   hint = "P1 [op2] fn1(fn2(z [op1] P1))"
   default = 2
    visible = @seq != 1
   endparam
  
  param recip2
   caption="Reciprocate"
   enum = "None" "Recip Oper1" "Recip Oper2" "Both"
   default = 0
    visible = @seq != 1
   endparam
   
  func fn21
   caption = "Function 1"
   default = asin()
    visible = @seq != 1
   endfunc
   
  func fn22
   caption = "Function 2"
   default = sqr()
    visible = @seq != 1
   endfunc


  heading
    caption = "Slope Parameters"
  endheading
  bool param slope
    caption = "Apply slope?"
    default = true
  endparam

  float param offset
    caption = "Orbit Separation"
    default = 0.0001
    hint = "Defines how far apart the simultaneous orbits are.  Smaller \
            distances will produce more accurate results."
    visible = @slope == true
  endparam
  param zmode
    caption = "Height Value"
    default = 5
    enum = "smallest |z|" "smallest |real(z)|" \
           "smallest |imag(z)|" "smallest summ(z)" "smallest |atan(z)|" \
           "smoothed iteration"
    hint = "Specifies what will be used to construct a height value."
    visible = @slope == true
  endparam
  param xfer
    caption = "Height Transfer"
    default = 0
    enum = "linear" "log" "sqrt" "cuberoot" "exp" "sqr" "cube" "sin" "cos" "tan"
    hint = "This function will be applied to the height value \
            before a slope is calculated."
    visible = @slope == true
  endparam
  param zscale
    caption = "Height Pre-Scale"
    default = 1.0
    hint = "Specifies the ratio between height and distance.  Higher \
            values will exaggerate differences between high and low. \
    In general, you will want to use smaller numbers here."
    visible = @slope == true
  endparam
  param zscale2
    caption = "Height Post-Scale"
    default = 1.0
    hint = "Specifies the ratio between height and distance; like \
            Height Pre-Scale, except that this value is applied after \
    the transfer function."
    visible = @slope == true
  endparam
  param everyiter
    caption = "Every Iteration"
    default = true
    hint = "If set, the surface normal will be computed at every \
            iteration.  If you are using a coloring algorithm which \
    processes every iteration, you will need this."
    visible = @slope == true
  endparam  

}
;_______________________________________________________
;«¤»Ą«¤»§«¤»Ą«¤»§«¤»Ą«¤»§«¤»Ą«¤»§«¤»Ą«¤»§«¤»Ą«¤»§«¤»Ą«¤»
;ŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻŻ


sdc-slope-henonesque {
; Source: _b.frm; cites hubert.frm
; Susan Chambless, March, 2005
; 
init:
  ;default to Mandelbrot
   complex c1 = #pixel
   complex c2 = c1 + @offset
   complex c3 = c1 + flip(@offset)
   complex z1 = @z0
   complex z2 = z1
   complex z3 = z1
   if( @mode == "Julia" )
     z1 = #pixel
     z2 = z1 + @offset
     z3 = z1 + flip(@offset)
     c1 = @seed
     c2 = c1
     c3 = c1
   endif
   a1 = real(c1)
   a2 = real(c2)
   a3 = real(c3)
   b1 = imag(c1)
   b2 = imag(c2)
   b3 = imag(c3)
   w1 = z1
   w2 = z2
   w3 = z3
   
   ;;; slope stuff
   int done = 2
   float e1 = 0.0; potentials
   float e2 = 0.0
   float e3 = 0.0
   float vx = 0.0; normal vector
   float vy = 0.0
   float vz = 0.0
   float vd = 0.0
   float d1 = 0.0; distances
   float d2 = 0.0
   float d3 = 0.0
   float s1 = 1.0e20; smallest distances
   float s2 = 1.0e20
   float s3 = 1.0e20
   float iterexp1 = 0.0
   float iterexp2 = 0.0
   float iterexp3 = 0.0
   
   z1 = @fn0(z1)
   z2 = @fn0(z2)
   z3 = @fn0(z3)
   
loop:
  
  tz1 = @fn3(a1) - @fn2(b1*w1) - @fn1(z1)
  tz2 = @fn3(a2) - @fn2(b2*w2) - @fn1(z2)
  tz3 = @fn3(a3) - @fn2(b3*w3) - @fn1(z3)
  w1 = z1
  w2 = z2
  w3 = z3
  z1 = tz1
  z2 = tz2
  z3 = tz3
    
  if (@slope == true)
  ;;;;  process slope  
    IF (@zmode == 5)
      iterexp1 = iterexp1 + exp(-cabs(z1))
      iterexp2 = iterexp2 + exp(-cabs(z2))
      iterexp3 = iterexp3 + exp(-cabs(z3))
    ENDIF
    done = done + 1; increment iteration counter
  
    IF (@zmode == 0)                      ; smallest |z|
      d1 = |z1|; get current distances from origin
      d2 = |z2|
      d3 = |z3|
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 1)                  ; smallest |real(z)|
      d1 = abs(real(z1)); get current distances from i axis
      d2 = abs(real(z2))
      d3 = abs(real(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 2)                  ; smallest |imag(z)|
      d1 = abs(imag(z1)); get current distances from r axis
      d2 = abs(imag(z2))
      d3 = abs(imag(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 3)                  ; smallest |real(z)|+|imag(z)|
      d1 = abs(real(z1))+abs(imag(z1)); get current distances from i axis
      d2 = abs(real(z2))+abs(imag(z2))
      d3 = abs(real(z3))+abs(imag(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 4)                  ; smallest |atan(z)|
      d1 = abs(atan2(z1)); get current angles
      d2 = abs(atan2(z2))
      d3 = abs(atan2(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ENDIF
  
    IF (@bailout < z1*z1+|w1| || \
        @everyiter || \
        done == #maxiter + 2); done, or every iteration, or last
      ; determine continuous iteration (height) for each point
      IF (@zmode >= 0 && @zmode <= 4) ; height based on smallest |z|
        e1 = s1 * @zscale
        e2 = s2 * @zscale
        e3 = s3 * @zscale
      ELSEIF (@zmode == 5)
        e1 = iterexp1 * @zscale
        e2 = iterexp2 * @zscale
        e3 = iterexp3 * @zscale
      ENDIF
  
      ; apply transfer function
      ; a function is not used because these are floats
      ; and not all functions apply to floats
      IF (@xfer == 1); log
        e1 = log(e1)
        e2 = log(e2)
        e3 = log(e3)
      ELSEIF (@xfer == 2); sqrt
        e1 = sqrt(e1)
        e2 = sqrt(e2)
        e3 = sqrt(e3)
      ELSEIF (@xfer == 3); cuberoot
        e1 = (e1)^(1/3)
        e2 = (e2)^(1/3)
        e3 = (e3)^(1/3)
      ELSEIF (@xfer == 4); exp
        e1 = exp(e1)
        e2 = exp(e2)
        e3 = exp(e3)
      ELSEIF (@xfer == 5); sqr
        e1 = sqr(e1)
        e2 = sqr(e2)
        e3 = sqr(e3)
      ELSEIF (@xfer == 6); cube
        e1 = (e1)^3
        e2 = (e2)^3
        e3 = (e3)^3
      ELSEIF (@xfer == 7); sin
        e1 = sin(e1)
        e2 = sin(e2)
        e3 = sin(e3)
      ELSEIF (@xfer == 8); cos
        e1 = cos(e1)
        e2 = cos(e2)
        e3 = cos(e3)
      ELSEIF (@xfer == 9); tan
        e1 = tan(e1)
        e2 = tan(e2)
        e3 = tan(e3)
      ENDIF
  
      ; apply post-scale
      e1 = e1 * @zscale2
      e2 = e2 * @zscale2
      e3 = e3 * @zscale2
  
        vx = e2-e1
        vy = e3-e1
        vz = -@offset
        ; normalize vector
        vd = 1/sqrt(sqr(vx)+sqr(vy)+sqr(vz))
        vx = vx*vd
        vy = vy*vd
        vz = vz*vd
        z = vx + flip(vy); fudge z from vector
    ELSE; didn't compute z this time
      z = z1; use primary iteration value to keep periodicity working
    ENDIF
  else
    z = z1
  endif
  IF (@bailout < |z1|)                  ; we're done
    done = 0
  ENDIF

    
bailout:
  (done > 0)
  
switch:
  type       = "sdc-slope-henonesque"
  bailout    = @bailout
  mode       = @switchmode
  switchMode = @mode
  version    = @version
  seed       = #pixel
  z0         = @z0
  fn0        = @fn0
  fn1        = @fn1
  fn2        = @fn2
  fn3        = @fn3
  
  slope      = @slope
  offset     = @offset
  zmode      = @zmode
  xfer       = @xfer
  zscale     = @zscale
  zscale2    = @zscale2
  everyiter  = @everyiter

  
default:
  title = "Slope Henonesque"
  method = multipass
  periodicity = 0
  magn = 1
  maxiter = 250

  param mode
    caption = "Current Mode"
    default = 0
    enum = "Mandelbrot" "Julia"
    visible = false
  endparam
  
  param switchMode
    caption = "Switch Mode"
    default = 1
    enum = "Mandelbrot" "Julia"
    visible = false
  endparam
  
  float param version
    default = 1.0
    visible = false
  endparam

  heading
    caption = "Mandlebrot Mode"
    visible = @mode==0
  endheading
  
  heading
    caption = "Julia Mode"
    visible = @mode==1
  endheading
  
  float param bailout
    caption = "Bailout"
    default = 42.0
  endparam
    
  param seed
    caption = "Julia Seed"
    default = (0.0, 0.0)
    visible = @mode==1
  endparam
  
  param z0
    caption = "Initial Z"
    default = (0.1, 0.0)
    visible = @mode==0
  endparam
    
  func fn0
    caption = "Initial Function"
    default = ident()
  endfunc
    
  func fn1
    caption = "Function 1"
    default = sqr()
  endfunc
    
  func fn2
    caption = "Function 2"
    default = ident()
  endfunc
    
  func fn3
    caption = "Function 3"
    default = ident()
  endfunc
    
  bool param slope
    caption = "Apply slope?"
    default = true
  endparam

  
  heading
    caption = "Slope Parameters"
    visible = @slope == true
  endheading   

  float param offset
    caption = "Orbit Separation"
    default = 0.00001
    hint = "Defines how far apart the simultaneous orbits are.  Smaller \
            distances will produce more accurate results."
    visible = @slope == true
  endparam
  param zmode
    caption = "Height Value"
    default = 5
    enum = "smallest |z|" "smallest |real(z)|" \
           "smallest |imag(z)|" "smallest summ(z)" "smallest |atan(z)|" \
           "smoothed iteration"
    hint = "Specifies what will be used to construct a height value."
    visible = @slope == true
  endparam
  param xfer
    caption = "Height Transfer"
    default = 0
    enum = "linear" "log" "sqrt" "cuberoot" "exp" "sqr" "cube" "sin" "cos" "tan"
    hint = "This function will be applied to the height value \
            before a slope is calculated."
    visible = @slope == true
  endparam
  param zscale
    caption = "Height Pre-Scale"
    default = 1.0
    hint = "Specifies the ratio between height and distance.  Higher \
            values will exaggerate differences between high and low. \
    In general, you will want to use smaller numbers here."
    visible = @slope == true
  endparam
  param zscale2
    caption = "Height Post-Scale"
    default = 1.0
    hint = "Specifies the ratio between height and distance; like \
            Height Pre-Scale, except that this value is applied after \
    the transfer function."
    visible = @slope == true
  endparam
  param everyiter
    caption = "Every Iteration"
    default = true
    hint = "If set, the surface normal will be computed at every \
            iteration.  If you are using a coloring algorithm which \
    processes every iteration, you will need this."
    visible = @slope == true
  endparam  

    
}

sdc-slopelepidoptera {
; inspired by SzegediButterfly 1 & 2
; slope methodology by Ron Barrett
; Susan Chambless, January 2005
init:
  ;default to Mandelbrot
   complex c1 = #pixel
   complex c2 = c1 + @offset
   complex c3 = c1 + flip(@offset)
   complex z1 = @z0
   complex z2 = z1
   complex z3 = z1
   if( @mode == "Julia" )
     z1 = #pixel
     z2 = z1 + @offset
     z3 = z1 + flip(@offset)
     c1 = @seed
     c2 = c1
     c3 = c1
   endif
   complex f1 = @factor1
   complex f2 = @factor2
   
   ;;; slope stuff
   int done = 2
   float e1 = 0.0; potentials
   float e2 = 0.0
   float e3 = 0.0
   float vx = 0.0; normal vector
   float vy = 0.0
   float vz = 0.0
   float vd = 0.0
   float d1 = 0.0; distances
   float d2 = 0.0
   float d3 = 0.0
   float s1 = 1.0e20; smallest distances
   float s2 = 1.0e20
   float s3 = 1.0e20
   float iterexp1 = 0.0
   float iterexp2 = 0.0
   float iterexp3 = 0.0
   
  
loop:
  float x1 = real(z1)
  float x2 = real(z2)
  float x3 = real(z3)
  float y1 = imag(z1)
  float y2 = imag(z2)
  float y3 = imag(z3)
  complex a11=0.0, complex a12=0.0, complex a13=0.0
  complex a21=0.0, complex a22=0.0, complex a23=0.0
  complex a31=0.0, complex a32=0.0, complex a33=0.0
  complex a41=0.0, complex a42=0.0, complex a43=0.0
  complex b11=0.0, complex b12=0.0, complex b13=0.0
  complex b21=0.0, complex b22=0.0, complex b23=0.0
  
  if (@method == "1")
    a11 = @fn1(@fn2(y1))
    a12 = @fn1(@fn2(y2))
    a13 = @fn1(@fn2(y3))
    
    a21 = @fn3(@fn4(x1))
    a22 = @fn3(@fn4(x2))
    a23 = @fn3(@fn4(x3))
 
    a31 = @fn5(@fn6(x1))
    a32 = @fn5(@fn6(x2))
    a33 = @fn5(@fn6(x3))
 
    a41 = @fn7(@fn8(y1))
    a42 = @fn7(@fn8(y2))
    a43 = @fn7(@fn8(y3))
  elseif (@method == "2")                           
    a11 = @fn1(@fn2(x1))
    a12 = @fn1(@fn2(x2))
    a13 = @fn1(@fn2(x3))
    
    a21 = @fn3(@fn4(y1))
    a22 = @fn3(@fn4(y2))
    a23 = @fn3(@fn4(y3))
    
    a31 = @fn5(@fn6(y1))
    a32 = @fn5(@fn6(y2))
    a33 = @fn5(@fn6(y3))
    
    a41 = @fn7(@fn8(x1))
    a42 = @fn7(@fn8(x2))
    a43 = @fn7(@fn8(x3))
  elseif (@method == "3")                           
    a11 = @fn1(@fn2(x1))
    a12 = @fn1(@fn2(x2))
    a13 = @fn1(@fn2(x3))
 
    a21 = @fn3(@fn4(y1))
    a22 = @fn3(@fn4(y2))
    a23 = @fn3(@fn4(y3))
 
    a31 = @fn5(@fn6(x1))
    a32 = @fn5(@fn6(x2))
    a33 = @fn5(@fn6(x3))
 
    a41 = @fn7(@fn8(y1))
    a42 = @fn7(@fn8(y2))
    a43 = @fn7(@fn8(y3))
 elseif (@method == "4")                           
    a11 = @fn1(@fn2(x1))
    a12 = @fn1(@fn2(x2))
    a13 = @fn1(@fn2(x3))

    a21 = @fn3(@fn4(x1))
    a22 = @fn3(@fn4(x2))
    a23 = @fn3(@fn4(x3))

    a31 = @fn5(@fn6(y1))
    a32 = @fn5(@fn6(y2))
    a33 = @fn5(@fn6(y3))

    a41 = @fn7(@fn8(y1))
    a42 = @fn7(@fn8(y2))
    a43 = @fn7(@fn8(y3))
  else
  endif
  
  if (@op1 == "+")
    b11 = a11 + a21
    b12 = a12 + a22
    b13 = a13 + a23
  elseif  (@op1 == "-")
    b11 = a11 - a21
    b12 = a12 - a22
    b13 = a13 - a23
  elseif  (@op1 == "*")
    b11 = a11 * a21
    b12 = a12 * a22
    b13 = a13 * a23
  elseif  (@op1 == "/")
    b11 = a11 / a21
    b12 = a12 / a22
    b13 = a13 / a23
  elseif  (@op1 == "^")
    b11 = a11 ^ a21
    b12 = a12 ^ a22
    b13 = a13 ^ a23
  else
  endif
  if (@op3 == "+")
    b21 = a31 + a41
    b22 = a32 + a42
    b23 = a33 + a43
  elseif (@op3 == "-")
    b21 = a31 - a41
    b22 = a32 - a42
    b23 = a33 - a43
  elseif (@op3 == "*")
    b21 = a31 * a41
    b22 = a32 * a42
    b23 = a33 * a43
  elseif (@op3 == "/")
    b21 = a31 / a41
    b22 = a32 / a42
    b23 = a33 / a43
  elseif (@op3 == "^")
    b21 = a31 ^ a41
    b22 = a32 ^ a42
    b23 = a33 ^ a43
  else
  endif
  if (@op2 == "+")
    z1 = (f1*b11 + f2*b21)
    z2 = (f1*b12 + f2*b22)
    z3 = (f1*b13 + f2*b23)
  elseif (@op2 == "-")
    z1 = (f1*b11 - f2*b21)
    z2 = (f1*b12 - f2*b22)
    z3 = (f1*b13 - f2*b23)
  elseif (@op2 == "*")
    z1 = (f1*b11 * f2*b21)
    z2 = (f1*b12 * f2*b22)
    z3 = (f1*b13 * f2*b23)
  elseif (@op2 == "/")
    z1 = (f1*b11 / f2*b21)
    z2 = (f1*b12 / f2*b22)
    z3 = (f1*b13 / f2*b23)
  elseif (@op2 == "^")
    z1 = (f1*b11 ^ f2*b21)
    z2 = (f1*b12 ^ f2*b22)
    z3 = (f1*b13 ^ f2*b23)
  else
  endif
  if (@op4 == "+")
    z1 = z1 + c1
    z2 = z2 + c2
    z3 = z3 + c3
  elseif (@op4 == "-")
    z1 = z1 - c1
    z2 = z2 - c2
    z3 = z3 - c3
  elseif (@op4 == "*")
    z1 = z1 * c1
    z2 = z2 * c2
    z3 = z3 * c3
  elseif (@op4 == "/")
    z1 = z1 / c1
    z2 = z2 / c2
    z3 = z3 / c3
  elseif (@op4 == "^")
    z1 = z1 ^ c1
    z2 = z2 ^ c2
    z3 = z3 ^ c3
  else
  endif
  
  f1 = f1 + @factor1delta
  f2 = f2 + @factor2delta    
    
  if (@slope == true)
  ;;;;  process slope  
    IF (@zmode == 5)
      iterexp1 = iterexp1 + exp(-cabs(z1))
      iterexp2 = iterexp2 + exp(-cabs(z2))
      iterexp3 = iterexp3 + exp(-cabs(z3))
    ENDIF
    done = done + 1; increment iteration counter
  
    IF (@zmode == 0)                      ; smallest |z|
      d1 = |z1|; get current distances from origin
      d2 = |z2|
      d3 = |z3|
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 1)                  ; smallest |real(z)|
      d1 = abs(real(z1)); get current distances from i axis
      d2 = abs(real(z2))
      d3 = abs(real(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 2)                  ; smallest |imag(z)|
      d1 = abs(imag(z1)); get current distances from r axis
      d2 = abs(imag(z2))
      d3 = abs(imag(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 3)                  ; smallest |real(z)|+|imag(z)|
      d1 = abs(real(z1))+abs(imag(z1)); get current distances from i axis
      d2 = abs(real(z2))+abs(imag(z2))
      d3 = abs(real(z3))+abs(imag(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 4)                  ; smallest |atan(z)|
      d1 = abs(atan2(z1)); get current angles
      d2 = abs(atan2(z2))
      d3 = abs(atan2(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ENDIF
  
    IF (@bailout < |z1| ||                \
        @everyiter ||\
        done == #maxiter + 2); done, or every iteration, or last
      ; determine continuous iteration (height) for each point
      IF (@zmode >= 0 && @zmode <= 4) ; height based on smallest |z|
        e1 = s1 * @zscale
        e2 = s2 * @zscale
        e3 = s3 * @zscale
      ELSEIF (@zmode == 5)
        e1 = iterexp1 * @zscale
        e2 = iterexp2 * @zscale
        e3 = iterexp3 * @zscale
      ENDIF
  
      ; apply transfer function
      ; a function is not used because these are floats
      ; and not all functions apply to floats
      IF (@xfer == 1); log
        e1 = log(e1)
        e2 = log(e2)
        e3 = log(e3)
      ELSEIF (@xfer == 2); sqrt
        e1 = sqrt(e1)
        e2 = sqrt(e2)
        e3 = sqrt(e3)
      ELSEIF (@xfer == 3); cuberoot
        e1 = (e1)^(1/3)
        e2 = (e2)^(1/3)
        e3 = (e3)^(1/3)
      ELSEIF (@xfer == 4); exp
        e1 = exp(e1)
        e2 = exp(e2)
        e3 = exp(e3)
      ELSEIF (@xfer == 5); sqr
        e1 = sqr(e1)
        e2 = sqr(e2)
        e3 = sqr(e3)
      ELSEIF (@xfer == 6); cube
        e1 = (e1)^3
        e2 = (e2)^3
        e3 = (e3)^3
      ELSEIF (@xfer == 7); sin
        e1 = sin(e1)
        e2 = sin(e2)
        e3 = sin(e3)
      ELSEIF (@xfer == 8); cos
        e1 = cos(e1)
        e2 = cos(e2)
        e3 = cos(e3)
      ELSEIF (@xfer == 9); tan
        e1 = tan(e1)
        e2 = tan(e2)
        e3 = tan(e3)
      ENDIF
  
      ; apply post-scale
      e1 = e1 * @zscale2
      e2 = e2 * @zscale2
      e3 = e3 * @zscale2
  
        vx = e2-e1
        vy = e3-e1
        vz = -@offset
        ; normalize vector
        vd = 1/sqrt(sqr(vx)+sqr(vy)+sqr(vz))
        vx = vx*vd
        vy = vy*vd
        vz = vz*vd
        z = vx + flip(vy); fudge z from vector
    ELSE; didn't compute z this time
      z = z1; use primary iteration value to keep periodicity working
    ENDIF
  else
    z = z1
  endif
  IF (@bailout < |z1|)                  ; we're done
    done = 0
  ENDIF
    
bailout:
  (done > 0)
  
switch:
  type       = "sdc-slopelepidoptera"
  bailout    = @bailout
  mode       = @switchmode
  switchMode = @mode
  version    = @version
  method     = @method
  seed       = #pixel
  z0         = #pixel
  factor1    = @factor1 
  factor1delta = @factor1delta 
  factor2    = @factor2
  factor2delta = @factor2delta
  op1        = @op1
  op2        = @op2
  op3        = @op3
  op4        = @op4
  fn1        = @fn1
  fn2        = @fn2
  fn3        = @fn3
  fn4        = @fn4
  fn5        = @fn5
  fn6        = @fn6
  fn7        = @fn7
  fn8        = @fn8
  
  slope      = @slope
  offset     = @offset
  zmode      = @zmode
  xfer       = @xfer
  zscale     = @zscale
  zscale2    = @zscale2
  everyiter  = @everyiter

default:
  title = "Slope Lepidoptera"
  method = multipass
  periodicity = 0
  magn = .6
  maxiter = 100

  param mode
    caption = "Current Mode"
    default = 0
    enum = "Mandelbrot" "Julia"
    visible = false
  endparam
  
  param switchMode
    caption = "Switch Mode"
    default = 1
    enum = "Mandelbrot" "Julia"
    visible = false
  endparam
  
  param version
    caption = "Version"
    default = 1.1
    visible = false
  endparam

  heading
    caption = "Mandlebrot Mode"
    visible = @mode==0
  endheading
  
  heading
    caption = "Julia Mode"
    visible = @mode==1
  endheading

  param bailout
    caption = "Bailout"
    default = 127
  endparam
   
 
  param seed
    caption = "Julia Seed"
    default = (0.0, 0.0)
    visible = @mode==1
  endparam
  
  param z0
    caption = "Initial Z"
    default = (0.0, 0.0)
    visible = @mode==0
  endparam
  
  param method
    caption = "Method"
    enum = "1" "2" "3" "4"
    default = 0
  endparam
  
  param op1
    caption = "Operator 1"
    enum = "+" "-" "*" "/" "^"
    default = 1        
  endparam
 
  param op2
    caption = "Operator 2"
    enum = "+" "-" "*" "/" "^"
    default = 0       
  endparam
 
  param op3
    caption = "Operator 3"
    enum = "+" "-" "*" "/" "^"
    default = 1        
  endparam
 
  param op4
    caption = "Operator 4"
    enum = "+" "-" "*" "/" "^"
    default = 0     
  endparam
 
  param factor1 
    caption = "Factor 1"
    default = (1.0, 0.0)
  endparam
  param factor1delta 
    caption = "Factor 1 Delta"
    default = (0.0, 0.0)
  endparam
  
  param factor2 
    caption = "Factor 2"
    default = (0.0, 1.0)
  endparam
  param factor2delta 
    caption = "Factor 2 Delta"
    default = (0.0, 0.0)
  endparam
  
  func fn1
    caption = "Function 1"
    default = sqr()
  endfunc
  
  func fn2
    caption = "Function 2"
    default = abs()
  endfunc
  
  func fn3
    caption = "Function 3"
    default = sqrt()
  endfunc
  
  func fn4
    caption = "Function 4"
    default = abs()
  endfunc
  
  func fn5
    caption = "Function 5"
    default = sqr()
  endfunc

  func fn6
    caption = "Function 6"
    default = ident()
  endfunc
  
  func fn7
    caption = "Function 7"
    default = sqrt()
    visible = @version > 1.0
  endfunc

  func fn8
    caption = "Function 8"
    default = abs()
    visible = @version > 1.0
  endfunc

  bool param slope
    caption = "Apply slope?"
    default = true
  endparam

  
  heading
    caption = "Slope Parameters"
    visible = @slope == true
  endheading   

  float param offset
    caption = "Orbit Separation"
    default = 0.005
    hint = "Defines how far apart the simultaneous orbits are.  Smaller \
            distances will produce more accurate results."
    visible = @slope == true
  endparam
  param zmode
    caption = "Height Value"
    default = 5
    enum = "smallest |z|" "smallest |real(z)|" \
           "smallest |imag(z)|" "smallest summ(z)" "smallest |atan(z)|" \
           "smoothed iteration"
    hint = "Specifies what will be used to construct a height value."
    visible = @slope == true
  endparam
  param xfer
    caption = "Height Transfer"
    default = 0
    enum = "linear" "log" "sqrt" "cuberoot" "exp" "sqr" "cube" "sin" "cos" "tan"
    hint = "This function will be applied to the height value \
            before a slope is calculated."
    visible = @slope == true
  endparam
  param zscale
    caption = "Height Pre-Scale"
    default = 1.0
    hint = "Specifies the ratio between height and distance.  Higher \
            values will exaggerate differences between high and low. \
    In general, you will want to use smaller numbers here."
    visible = @slope == true
  endparam
  param zscale2
    caption = "Height Post-Scale"
    default = 1.0
    hint = "Specifies the ratio between height and distance; like \
            Height Pre-Scale, except that this value is applied after \
    the transfer function."
    visible = @slope == true
  endparam
  param everyiter
    caption = "Every Iteration"
    default = true
    hint = "If set, the surface normal will be computed at every \
            iteration.  If you are using a coloring algorithm which \
    processes every iteration, you will need this."
    visible = @slope == true
  endparam  

    
}

sdc-slopePopPlus {
global:
init:
  ;default to Mandelbrot
   complex c1 = #pixel
   complex c2 = c1 + @offset
   complex c3 = c1 + flip(@offset)
   complex z1 = @z0
   complex z2 = z1
   complex z3 = z1
   if( @mode == "Julia" )
     z1 = #pixel
     z2 = z1 + @offset
     z3 = z1 + flip(@offset)
     c1 = @startseed
     c2 = c1
     c3 = c1
   endif
  ;default to Mandelbrot

   int iter = 0
   int seed = random(@randomseed)

   ;;; slope stuff
   int done = 2
   float e1 = 0.0; potentials
   float e2 = 0.0
   float e3 = 0.0
   float vx = 0.0; normal vector
   float vy = 0.0
   float vz = 0.0
   float vd = 0.0
   float d1 = 0.0; distances
   float d2 = 0.0
   float d3 = 0.0
   float s1 = 1.0e20; smallest distances
   float s2 = 1.0e20
   float s3 = 1.0e20
   float iterexp1 = 0.0
   float iterexp2 = 0.0
   float iterexp3 = 0.0

loop:

  iter = iter + 1
  ; Determine scenario to be used:
  bool  scenario1 = false
  if ( @seq == 1 )                  ; First scenario
    scenario1 = true
  elseif ( @seq == 2 )              ; Second scenario
    scenario1 = false
  elseif (@seq == 0 )
    if ( iter % @modBy < @modCmp ); Modulation
       scenario1 = true
    endif
    if (@invertMod == true)
       scenario1 = !scenario1
    endif
  elseif ( @seq==3 )
    seed = random(seed)
    if ( abs(seed)/#randomrange < @prob1 )
      scenario1 = true
    endif
    if (@invertMod == true)
      scenario1 = !scenario1
    endif
  else
    Scenario1 = false
  endif

  if(scenario1 == true)
    z1 = @fn11(z1)*@p1*(1.0 - @fn12(z1))*c1
    z2 = @fn11(z2)*@p1*(1.0 - @fn12(z2))*c2
    z3 = @fn11(z3)*@p1*(1.0 - @fn12(z3))*c3
  else
    z1 = @fn21(z1)*@p2*(1.0 - @fn22(z1))*c1
    z2 = @fn21(z2)*@p2*(1.0 - @fn22(z2))*c2
    z3 = @fn21(z3)*@p2*(1.0 - @fn22(z3))*c3
  endif

  if (@slope == true)
  ;;;;  process slope
    IF (@zmode == 5)
      iterexp1 = iterexp1 + exp(-cabs(z1))
      iterexp2 = iterexp2 + exp(-cabs(z2))
      iterexp3 = iterexp3 + exp(-cabs(z3))
    ENDIF
    done = done + 1; increment iteration counter

    IF (@zmode == 0)                      ; smallest |z|
      d1 = |z1|; get current distances from origin
      d2 = |z2|
      d3 = |z3|
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 1)                  ; smallest |real(z)|
      d1 = abs(real(z1)); get current distances from i axis
      d2 = abs(real(z2))
      d3 = abs(real(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 2)                  ; smallest |imag(z)|
      d1 = abs(imag(z1)); get current distances from r axis
      d2 = abs(imag(z2))
      d3 = abs(imag(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 3)                  ; smallest |real(z)|+|imag(z)|
      d1 = abs(real(z1))+abs(imag(z1)); get current distances from i axis
      d2 = abs(real(z2))+abs(imag(z2))
      d3 = abs(real(z3))+abs(imag(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 4)                  ; smallest |atan(z)|
      d1 = abs(atan2(z1)); get current angles
      d2 = abs(atan2(z2))
      d3 = abs(atan2(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ENDIF

    IF (@bailout < |z1| ||                \
        @everyiter ||\
        done == #maxiter + 2); done, or every iteration, or last
      ; determine continuous iteration (height) for each point
      IF (@zmode >= 0 && @zmode <= 4) ; height based on smallest |z|
        e1 = s1 * @zscale
        e2 = s2 * @zscale
        e3 = s3 * @zscale
      ELSEIF (@zmode == 5)
        e1 = iterexp1 * @zscale
        e2 = iterexp2 * @zscale
        e3 = iterexp3 * @zscale
      ENDIF

      ; apply transfer function
      ; a function is not used because these are floats
      ; and not all functions apply to floats
      IF (@xfer == 1); log
        e1 = log(e1)
        e2 = log(e2)
        e3 = log(e3)
      ELSEIF (@xfer == 2); sqrt
        e1 = sqrt(e1)
        e2 = sqrt(e2)
        e3 = sqrt(e3)
      ELSEIF (@xfer == 3); cuberoot
        e1 = (e1)^(1/3)
        e2 = (e2)^(1/3)
        e3 = (e3)^(1/3)
      ELSEIF (@xfer == 4); exp
        e1 = exp(e1)
        e2 = exp(e2)
        e3 = exp(e3)
      ELSEIF (@xfer == 5); sqr
        e1 = sqr(e1)
        e2 = sqr(e2)
        e3 = sqr(e3)
      ELSEIF (@xfer == 6); cube
        e1 = (e1)^3
        e2 = (e2)^3
        e3 = (e3)^3
      ELSEIF (@xfer == 7); sin
        e1 = sin(e1)
        e2 = sin(e2)
        e3 = sin(e3)
      ELSEIF (@xfer == 8); cos
        e1 = cos(e1)
        e2 = cos(e2)
        e3 = cos(e3)
      ELSEIF (@xfer == 9); tan
        e1 = tan(e1)
        e2 = tan(e2)
        e3 = tan(e3)
      ENDIF

      ; apply post-scale
      e1 = e1 * @zscale2
      e2 = e2 * @zscale2
      e3 = e3 * @zscale2

        vx = e2-e1
        vy = e3-e1
        vz = -@offset
        ; normalize vector
        vd = 1/sqrt(sqr(vx)+sqr(vy)+sqr(vz))
        vx = vx*vd
        vy = vy*vd
        vz = vz*vd
        z = vx + flip(vy); fudge z from vector
    ELSE; didn't compute z this time
      z = z1; use primary iteration value to keep periodicity working
    ENDIF
  else
    z = z1
  endif
  IF (@bailout < |z1| )                  ; we're done
    done = 0
  ENDIF

bailout:
  (done > 0)

switch:
  type = "sdc-slopePopPlus"
  version    = @version
  bailout    = @bailout
  startseed  = #pixel
  mode       = @switchmode
  switchMode = @mode

  seq        = @seq
  modBy      = @modBy
  modCmp     = @modCmp
  randomseed = @randomseed
  prob1      = @prob1
  invertMod  = @invertMod
  
  z0         = @z0
  p1         = @p1
  fn11       = @fn11
  fn12       = @fn12
  p2         = @p2
  fn21       = @fn21
  fn22       = @fn22
  
  slope      = @slope
  offset     = @offset
  zmode      = @zmode
  xfer       = @xfer
  zscale     = @zscale
  zscale2    = @zscale2
  everyiter  = @everyiter

default:
  title = "Slope Population Plus"
  method = multipass
  periodicity = 0
  magn = 1
  maxiter = 100

  float param version
    default = 0.0
    visible = false
  endparam

  param mode
    caption = "Current Mode"
    default = 0
    enum = "Mandelbrot" "Julia"
    visible = false
  endparam

  param switchMode
    caption = "Switch Mode"
    default = 1
    enum = "Mandelbrot" "Julia"
    visible = false
  endparam

  heading
    caption = "Mandlebrot Mode"
    visible = @mode==0
  endheading

  heading
    caption = "Julia Mode"
    visible = @mode==1
  endheading

  float param bailout
    caption = "Bailout"
    default = 4.0
  endparam

  complex param startseed
    caption = "Julia seed"
    default = ( -.8, -.1 )
    visible = @mode==1
  endparam

  complex param z0
    caption = "Initial Z value"
    default = (0.5, 0.0)
    visible = @mode==0
  endparam

  int param seq
    enum = "Modulation" "First Scenario" "Second Scenario" "Random"
    default = 0
    caption = "Scenario Sequence"
  endparam

  int param modBy
    default = 10
    caption = "Mod By"
    hint = "Iteration Modulated by This"
    visible = @seq==0
  endparam

  int param modCmp
    default = 5
    caption = "Mod Compare"
    hint = "Modulated Iteration < this -> formula 1"
    visible = @seq==0
  endparam
  int param randomseed
    caption = "Random Seed"
    default = 123456
    visible = @seq==3
  endparam
  float param prob1
    caption = "Prob for Func 1"
    default = 0.5
    min = 0.0
    max = 1.0
    visible = @seq==3
  endparam
  bool param invertMod
    caption = "Invert Sequence?"
    default = False
    visible = @seq==0 || @seq==3
  endparam

  bool param slope
    caption = "Apply slope?"
    default = true
    hint = "Use Lighting in dmj.ucl or one of the 3D Texturizer \
           formulas in reb.ucl with the slope applied. \
           Unset for a non-slope version registered with the\
           slope version.  Generally, unset 'Apply Slope? \
           for other formulas."
  endparam

  heading
    caption = "Scenario 1"
    visible = @seq!=2
  endheading

  complex param p1
    caption = "Constant"
    default = (1.0, 0.0)
    visible = @seq!=2
  endparam

  func fn11
    caption = "First Function"
    default = ident()
    visible = @seq!=2
  endfunc

  func fn12
    caption = "Second Function"
    default = ident()
    visible = @seq!=2
  endfunc

  heading
    caption = "Scenario 2"
    visible = @seq!=2
  endheading

  complex param p2
    caption = "Constant"
    default = (1.0, 0.0)
    visible = @seq!=1
  endparam

  func fn21
    caption = "First Function"
    default = ident()
    visible = @seq!=1
  endfunc

  func fn22
    caption = "Second Function"
    default = ident()
    visible = @seq!=1
  endfunc
  
  heading
    caption = "Extra Functions"
  endheading

  heading
    caption = "Slope Parameters"
    visible = @slope==true
  endheading

  float param offset
    caption = "Orbit Separation"
    default = 0.001
    hint = "Defines how far apart the simultaneous orbits are.  Smaller \
            distances will produce more accurate results."
    visible = @slope==true
  endparam
  param zmode
    caption = "Height Value"
    default = 5
    enum = "smallest |z|" "smallest |real(z)|" \
           "smallest |imag(z)|" "smallest summ(z)" "smallest |atan(z)|" \
           "smoothed iteration"
    hint = "Specifies what will be used to construct a height value."
    visible = @slope==true
  endparam
  param xfer
    caption = "Height Transfer"
    default = 0
    enum = "linear" "log" "sqrt" "cuberoot" "exp" "sqr" "cube" "sin" "cos" "tan"
    hint = "This function will be applied to the height value \
            before a slope is calculated."
    visible = @slope==true
  endparam
  param zscale
    caption = "Height Pre-Scale"
    default = 1.0
    hint = "Specifies the ratio between height and distance.  Higher \
            values will exaggerate differences between high and low. \
            In general, you will want to use smaller numbers here."
    visible = @slope==true
  endparam
  param zscale2
    caption = "Height Post-Scale"
    default = 1.0
    hint = "Specifies the ratio between height and distance; like \
            Height Pre-Scale, except that this value is applied after \
            the transfer function."
    visible = @slope==true
  endparam
  param everyiter
    caption = "Every Iteration"
    default = true
    hint = "If set, the surface normal will be computed at every \
            iteration.  If you are using a coloring algorithm which \
            processes every iteration, you will need this."
    visible = @slope==true
  endparam

}

sdc-slope-barns-manjul {
; August, 2005 - added more functions and parameters
; This formula is a joint effort with Gilles Nadeau, who has
; generously allowed me to publish it. 

init:
  ;default to Mandelbrot
   complex c1 = #pixel
   complex c2 = c1 + @offset
   complex c3 = c1 + flip(@offset)
   complex z1 = @z0
   complex z2 = z1
   complex z3 = z1
   if( @mode == "Julia" )
     z1 = #pixel
     z2 = z1 + @offset
     z3 = z1 + flip(@offset)
     c1 = @seed
     c2 = c1
     c3 = c1
   endif
   
   z1 = @initfn(z1)
   z2 = @initfn(z2)
   z3 = @initfn(z3)
   c1 = @initfn(c1)
   c2 = @initfn(c2)
   c3 = @initfn(c3)
   
   pp1 = @p1
   pp2 = @p2
   pp3 = @p3
   pp4 = @p4
   pp5 = @p5
   
   ;;; slope stuff
   int done = 2
   float e1 = 0.0; potentials
   float e2 = 0.0
   float e3 = 0.0
   float vx = 0.0; normal vector
   float vy = 0.0
   float vz = 0.0
   float vd = 0.0
   float d1 = 0.0; distances
   float d2 = 0.0
   float d3 = 0.0
   float s1 = 1.0e20; smallest distances
   float s2 = 1.0e20
   float s3 = 1.0e20
   float iterexp1 = 0.0
   float iterexp2 = 0.0
   float iterexp3 = 0.0
   
loop:
  z1 = @loopfn5(pp5*@loopfn4(pp4*c1 * @loopfn3(pp3*@loopfn2(pp2*@loopfn1(pp1*z1)))) - c1)
  z2 = @loopfn5(pp5*@loopfn4(pp4*c2 * @loopfn3(pp3*@loopfn2(pp2*@loopfn1(pp1*z2)))) - c2)
  z3 = @loopfn5(pp5*@loopfn4(pp4*c3 * @loopfn3(pp3*@loopfn2(pp2*@loopfn1(pp1*z3)))) - c3)

  if @progression == true
     if @op1 == "+"
       pp1 = pp1 + @dp1add
     elseif  @op1 == "*"
       pp1 = pp1 * @dp1mult
     elseif  @op1 == "+ then *"
       pp1 = (pp1 + @dp1add) * @dp1mult
     elseif  @op1 == "* then +"
       pp1 = (pp1 * @dp1mult) + @dp1add
     endif
     if @op2 == "+"
       pp2 = pp2 + @dp2add
     elseif  @op2 == "*"
       pp2 = pp2 * @dp2mult
     elseif  @op2 == "+ then *"
       pp2 = (pp2 + @dp2add) * @dp2mult
     elseif  @op2 == "* then +"
       pp2 = (pp2 * @dp2mult) + @dp2add
     endif
     if @op3 == "+"
       pp3 = pp3 + @dp3add
     elseif  @op3 == "*"
       pp3 = pp3 * @dp3mult
     elseif  @op3 == "+ then *"
       pp3 = (pp3 + @dp3add) * @dp3mult
     elseif  @op3 == "* then +"
       pp3 = (pp3 * @dp3mult) + @dp3add
     endif
     if @op4 == "+"
       pp4 = pp4 + @dp4add
     elseif  @op4 == "*"
       pp4 = pp4 * @dp4mult
     elseif  @op4 == "+ then *"
       pp4 = (pp4 + @dp4add) * @dp4mult
     elseif  @op4 == "* then +"
       pp4 = (pp4 * @dp4mult) + @dp4add
     endif
     if @op5 == "+"
       pp5 = pp5 + @dp5add
     elseif  @op5 == "*"
       pp5 = pp5 * @dp5mult
     elseif  @op5 == "+ then *"
       pp5 = (pp5 + @dp5add) * @dp5mult
     elseif  @op5 == "* then +"
       pp5 = (pp5 * @dp5mult) + @dp5add
     endif
  endif
    
  if (@slope == true)
  ;;;;  process slope  
    IF (@zmode == 5)
      iterexp1 = iterexp1 + exp(-cabs(z1))
      iterexp2 = iterexp2 + exp(-cabs(z2))
      iterexp3 = iterexp3 + exp(-cabs(z3))
    ENDIF
    done = done + 1; increment iteration counter
  
    IF (@zmode == 0)                      ; smallest |z|
      d1 = |z1|; get current distances from origin
      d2 = |z2|
      d3 = |z3|
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 1)                  ; smallest |real(z)|
      d1 = abs(real(z1)); get current distances from i axis
      d2 = abs(real(z2))
      d3 = abs(real(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 2)                  ; smallest |imag(z)|
      d1 = abs(imag(z1)); get current distances from r axis
      d2 = abs(imag(z2))
      d3 = abs(imag(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 3)                  ; smallest |real(z)|+|imag(z)|
      d1 = abs(real(z1))+abs(imag(z1)); get current distances from i axis
      d2 = abs(real(z2))+abs(imag(z2))
      d3 = abs(real(z3))+abs(imag(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 4)                  ; smallest |atan(z)|
      d1 = abs(atan2(z1)); get current angles
      d2 = abs(atan2(z2))
      d3 = abs(atan2(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ENDIF
  
    IF (@bailout < |z1| ||                \
        @everyiter ||\
        done == #maxiter + 2); done, or every iteration, or last
      ; determine continuous iteration (height) for each point
      IF (@zmode >= 0 && @zmode <= 4) ; height based on smallest |z|
        e1 = s1 * @zscale
        e2 = s2 * @zscale
        e3 = s3 * @zscale
      ELSEIF (@zmode == 5)
        e1 = iterexp1 * @zscale
        e2 = iterexp2 * @zscale
        e3 = iterexp3 * @zscale
      ENDIF
  
      ; apply transfer function
      ; a function is not used because these are floats
      ; and not all functions apply to floats
      IF (@xfer == 1); log
        e1 = log(e1)
        e2 = log(e2)
        e3 = log(e3)
      ELSEIF (@xfer == 2); sqrt
        e1 = sqrt(e1)
        e2 = sqrt(e2)
        e3 = sqrt(e3)
      ELSEIF (@xfer == 3); cuberoot
        e1 = (e1)^(1/3)
        e2 = (e2)^(1/3)
        e3 = (e3)^(1/3)
      ELSEIF (@xfer == 4); exp
        e1 = exp(e1)
        e2 = exp(e2)
        e3 = exp(e3)
      ELSEIF (@xfer == 5); sqr
        e1 = sqr(e1)
        e2 = sqr(e2)
        e3 = sqr(e3)
      ELSEIF (@xfer == 6); cube
        e1 = (e1)^3
        e2 = (e2)^3
        e3 = (e3)^3
      ELSEIF (@xfer == 7); sin
        e1 = sin(e1)
        e2 = sin(e2)
        e3 = sin(e3)
      ELSEIF (@xfer == 8); cos
        e1 = cos(e1)
        e2 = cos(e2)
        e3 = cos(e3)
      ELSEIF (@xfer == 9); tan
        e1 = tan(e1)
        e2 = tan(e2)
        e3 = tan(e3)
      ENDIF
  
      ; apply post-scale
      e1 = e1 * @zscale2
      e2 = e2 * @zscale2
      e3 = e3 * @zscale2
  
        vx = e2-e1
        vy = e3-e1
        vz = -@offset
        ; normalize vector
        vd = 1/sqrt(sqr(vx)+sqr(vy)+sqr(vz))
        vx = vx*vd
        vy = vy*vd
        vz = vz*vd
        z = vx + flip(vy); fudge z from vector
    ELSE; didn't compute z this time
      z = z1; use primary iteration value to keep periodicity working
    ENDIF
  else
    z = z1
  endif
  IF (@bailout < |z1|)                  ; we're done
    done = 0
  ENDIF

    
bailout:
  (done > 0)
  
switch:
  type       = "sdc-slope-barns-manjul"
  bailout    = @bailout
  mode       = @switchmode
  switchMode = @mode
  version    = @version
  seed       = #pixel
  
  initfn     = @initfn
  loopfn1    = @loopfn1
  loopfn2    = @loopfn2
  loopfn3    = @loopfn3
  loopfn4    = @loopfn4
  loopfn5    = @loopfn5
  progression= @progression
  p1         = @p1
  p2         = @p2
  p3         = @p3
  p4         = @p4
  p5         = @p5
  op1        = @op1
  dp1add     = @dp1add
  dp1mult    = @dp1mult
  op2        = @op2
  dp2add     = @dp2add
  dp2mult    = @dp2mult
  op3        = @op3
  dp3add     = @dp3add
  dp3mult    = @dp3mult
  op4        = @op4
  dp4add     = @dp4add
  dp4mult    = @dp4mult
  op5        = @op5
  dp5add     = @dp5add
  dp5mult    = @dp5mult

  slope      = @slope
  offset     = @offset
  zmode      = @zmode
  xfer       = @xfer
  zscale     = @zscale
  zscale2    = @zscale2
  everyiter  = @everyiter

  
default:
  title = "Slope Barnsley 1 ManJul"
  method = multipass
  periodicity = 0
  magn = 0.75
  maxiter = 100

  param mode
    caption = "Current Mode"
    default = 0
    enum = "Mandelbrot" "Julia"
    visible = false
  endparam
  
  param switchMode
    caption = "Switch Mode"
    default = 1
    enum = "Mandelbrot" "Julia"
    visible = false
  endparam
  
  float param version
    default = 1.0
    visible = false
  endparam

  heading
    caption = "Mandlebrot Mode"
    visible = @mode==0
  endheading
  
  heading
    caption = "Julia Mode"
    visible = @mode==1
  endheading
  
  float param bailout
    caption = "Bailout"
    default = 4.0
  endparam
    
  param seed
    caption = "Julia Seed"
    default = (0.6, 1.1)
    visible = @mode==1
  endparam
  
  param z0
    caption = "Initial Z"
    default = (0.0, 0.0)
    visible = @mode==0
  endparam
    
  heading
    caption = "Parameters"
  endheading
  
  bool param progression
    caption = "Progression?"
    default = false
  endparam
  
  param p1
    caption = "Parameter 1"
    default = (1.0, 0.0)
  endparam
  param op1
    caption = "Delta 1 Op"
    enum = "+" "*" "+ then *" "* then +"
    default = 0
    visible = @progression==true
  endparam
  param dp1add
    caption = "Delta 1 +"
    default = (0.0, 0.0)
    visible = @progression==true && @op1!=1
  endparam
  param dp1mult
    caption = "Delta 1 *"
    default = (1.0, 0.0)
    visible = @progression==true && @op1!=0
  endparam

  param p2
    caption = "Parameter 2"
    default = (1.0, 0.0)
  endparam
  param op2
    caption = "Delta 2 Op"
    enum = "+" "*" "+ then *" "* then +"
    default = 0
    visible = @progression==true
  endparam
  param dp2add
    caption = "Delta 2 +"
    default = (0.0, 0.0)
    visible = @progression==true && @op2!=1
  endparam
  param dp2mult
    caption = "Delta 2 *"
    default = (1.0, 0.0)
    visible = @progression==true && @op2!=0
  endparam

  param p3
    caption = "Parameter 3"
    default = (1.0, 0.0)
  endparam
  param op3
    caption = "Delta 3 Op"
    enum = "+" "*" "+ then *" "* then +"
    default = 0
    visible = @progression==true
  endparam
  param dp3add
    caption = "Delta 3 +"
    default = (0.0, 0.0)
    visible = @progression==true && @op3!=1
  endparam
  param dp3mult
    caption = "Delta 3 *"
    default = (1.0, 0.0)
    visible = @progression==true && @op3!=0
  endparam

  param p4
    caption = "Parameter 4"
    default = (1.0, 0.0)
  endparam
  param op4
    caption = "Delta 4 Op"
    enum = "+" "*" "+ then *" "* then +"
    default = 0
    visible = @progression==true
  endparam
  param dp4add
    caption = "Delta 4 +"
    default = (0.0, 0.0)
    visible = @progression==true && @op4!=1
  endparam
  param dp4mult
    caption = "Delta 4 *"
    default = (1.0, 0.0)
    visible = @progression==true && @op4!=0
  endparam

  param p5
    caption = "Parameter 5"
    default = (1.0, 0.0)
  endparam
  param op5
    caption = "Delta 5 Op"
    enum = "+" "*" "+ then *" "* then +"
    default = 0
    visible = @progression==true
  endparam
  param dp5add
    caption = "Delta 5 +"
    default = (0.0, 0.0)
    visible = @progression==true && @op5!=1
  endparam
  param dp5mult
    caption = "Delta 5 *"
    default = (1.0, 0.0)
    visible = @progression==true && @op5!=0
  endparam

  heading
    caption = "Functions"
  endheading

  func initfn
    caption = "Initial Function"
    default = ident()
  endfunc

  func loopfn1
    caption = "Loop Function 1"
    default = sqr()
  endfunc
  
  func loopfn2
    caption = "Loop Function 2"
    default = sqrt()
  endfunc
  
  func loopfn3
    caption = "Loop Function 3"
    default = ident()
  endfunc

  func loopfn4
    caption = "Loop Function 4"
    default = ident()
  endfunc

  func loopfn5
    caption = "Loop Function 5"
    default = ident()
  endfunc

  heading
    caption = "Slope Parameters"
  endheading

  bool param slope
    caption = "Apply slope?"
    default = true
  endparam

  float param offset
    caption = "Orbit Separation"
    default = 0.00000001
    hint = "Defines how far apart the simultaneous orbits are.  Smaller \
            distances will produce more accurate results."
    visible = @slope == true
  endparam
  param zmode
    caption = "Height Value"
    default = 5
    enum = "smallest |z|" "smallest |real(z)|" \
           "smallest |imag(z)|" "smallest summ(z)" "smallest |atan(z)|" \
           "smoothed iteration"
    hint = "Specifies what will be used to construct a height value."
    visible = @slope == true
  endparam
  param xfer
    caption = "Height Transfer"
    default = 0
    enum = "linear" "log" "sqrt" "cuberoot" "exp" "sqr" "cube" "sin" "cos" "tan"
    hint = "This function will be applied to the height value \
            before a slope is calculated."
    visible = @slope == true
  endparam
  param zscale
    caption = "Height Pre-Scale"
    default = 10.0
    hint = "Specifies the ratio between height and distance.  Higher \
            values will exaggerate differences between high and low. \
    In general, you will want to use smaller numbers here."
    visible = @slope == true
  endparam
  param zscale2
    caption = "Height Post-Scale"
    default = 10.0
    hint = "Specifies the ratio between height and distance; like \
            Height Pre-Scale, except that this value is applied after \
    the transfer function."
    visible = @slope == true
  endparam
  param everyiter
    caption = "Every Iteration"
    default = true
    hint = "If set, the surface normal will be computed at every \
            iteration.  If you are using a coloring algorithm which \
    processes every iteration, you will need this."
    visible = @slope == true
  endparam  

    
}

sdc-slope-barns2-manjul {
; August, 2005 - added more functions and parameters
; This formula is a joint effort with Gilles Nadeau, who has
; generously allowed me to publish it. 

init:
  ;default to Mandelbrot
   complex c1 = #pixel
   complex c2 = c1 + @offset
   complex c3 = c1 + flip(@offset)
   complex z1 = @z0
   complex z2 = z1
   complex z3 = z1
   if( @mode == "Julia" )
     z1 = #pixel
     z2 = z1 + @offset
     z3 = z1 + flip(@offset)
     c1 = @seed
     c2 = c1
     c3 = c1
   endif
   
   z1 = @initfn1(z1)
   z2 = @initfn1(z2)
   z3 = @initfn1(z3)
   c1 = @initfn1(c1)
   c2 = @initfn1(c2)
   c3 = @initfn1(c3)
   
   pp11 = @p11
   pp12 = @p12
   pp13 = @p13
   pp14 = @p14
   pp15 = @p15

   pp21 = @p21
   pp22 = @p22
   pp23 = @p23
   pp24 = @p24
   pp25 = @p25
   
   int iter = 0
   int seed = random(@randomseed)

   ;;; slope stuff
   int done = 2
   float e1 = 0.0; potentials
   float e2 = 0.0
   float e3 = 0.0
   float vx = 0.0; normal vector
   float vy = 0.0
   float vz = 0.0
   float vd = 0.0
   float d1 = 0.0; distances
   float d2 = 0.0
   float d3 = 0.0
   float s1 = 1.0e20; smallest distances
   float s2 = 1.0e20
   float s3 = 1.0e20
   float iterexp1 = 0.0
   float iterexp2 = 0.0
   float iterexp3 = 0.0
   
loop:
  iter = iter + 1
  ; Determine scenario to be used:
  bool  scenario1 = false
  if ( @seq == 1 )                  ; First scenario
    scenario1 = true
  elseif ( @seq == 2 )              ; Second scenario
    scenario1 = false
  elseif (@seq == 0 )
    if ( iter % @modBy < @modCmp ); Modulation
       scenario1 = true
    endif
    if (@invertMod == true)
       scenario1 = !scenario1
    endif
  elseif ( @seq==3 )
    seed = random(seed)
    if ( abs(seed)/#randomrange < @prob1 )
      scenario1 = true
    endif
    if (@invertMod == true)
      scenario1 = !scenario1
    endif
  else
    Scenario1 = false
  endif

  if(scenario1 == true)
    if (@threshold1 == false)
      z1 = @loopfn15(pp15*@loopfn14(pp14*c1 * @loopfn13(pp13*@loopfn12(pp12*@loopfn11(pp11*z1)))) - c1)
      z2 = @loopfn15(pp15*@loopfn14(pp14*c2 * @loopfn13(pp13*@loopfn12(pp12*@loopfn11(pp11*z2)))) - c2)
      z3 = @loopfn15(pp15*@loopfn14(pp14*c3 * @loopfn13(pp13*@loopfn12(pp12*@loopfn11(pp11*z3)))) - c3)
    else
      if real(z1) >= @thresh1
        z1 = @loopfn15(pp15*@loopfn14(pp14*-c1 * @loopfn13(pp13*@loopfn12(pp12*@loopfn11(pp11*(z1+1.0))))))
        z2 = @loopfn15(pp15*@loopfn14(pp14*-c2 * @loopfn13(pp13*@loopfn12(pp12*@loopfn11(pp11*(z2+1.0))))))
        z3 = @loopfn15(pp15*@loopfn14(pp14*-c3 * @loopfn13(pp13*@loopfn12(pp12*@loopfn11(pp11*(z3+1.0))))))
      else
        z1 = @loopfn15(pp15*@loopfn14(pp14*c1 * @loopfn13(pp13*@loopfn12(pp12*@loopfn11(pp11*(z1-1.0))))))
        z2 = @loopfn15(pp15*@loopfn14(pp14*c2 * @loopfn13(pp13*@loopfn12(pp12*@loopfn11(pp11*(z2-1.0))))))
        z3 = @loopfn15(pp15*@loopfn14(pp14*c3 * @loopfn13(pp13*@loopfn12(pp12*@loopfn11(pp11*(z3-1.0))))))
      endif
    endif
  else   ; scenario 2
    if (@threshold2 == false)
      z1 = @loopfn25(pp25*@loopfn24(pp24*c1 * @loopfn23(pp23*@loopfn22(pp22*@loopfn21(pp21*z1)))) - c1)
      z2 = @loopfn25(pp25*@loopfn24(pp24*c2 * @loopfn23(pp23*@loopfn22(pp22*@loopfn21(pp21*z2)))) - c2)
      z3 = @loopfn25(pp25*@loopfn24(pp24*c3 * @loopfn23(pp23*@loopfn22(pp22*@loopfn21(pp21*z3)))) - c3)
    else
      if real(z1) >= @thresh2
        z1 = @loopfn25(pp25*@loopfn24(pp24*-c1 * @loopfn23(pp23*@loopfn22(pp22*@loopfn21(pp21*(z1+1.0))))))
        z2 = @loopfn25(pp25*@loopfn24(pp24*-c2 * @loopfn23(pp23*@loopfn22(pp22*@loopfn21(pp21*(z2+1.0))))))
        z3 = @loopfn25(pp25*@loopfn24(pp24*-c3 * @loopfn23(pp23*@loopfn22(pp22*@loopfn21(pp21*(z3+1.0))))))
      else
        z1 = @loopfn25(pp25*@loopfn24(pp24*c1 * @loopfn23(pp23*@loopfn22(pp22*@loopfn21(pp21*(z1-1.0))))))
        z2 = @loopfn25(pp25*@loopfn24(pp24*c2 * @loopfn23(pp23*@loopfn22(pp22*@loopfn21(pp21*(z2-1.0))))))
        z3 = @loopfn25(pp25*@loopfn24(pp24*c3 * @loopfn23(pp23*@loopfn22(pp22*@loopfn21(pp21*(z3-1.0))))))
      endif
    endif
  endif

  if @progression == true
     if @op11 == "+"
       pp11 = pp11 + @dp11add
     elseif  @op11 == "*"
       pp11 = pp11 * @dp11mult
     elseif  @op11 == "+ then *"
       pp11 = (pp11 + @dp11add) * @dp11mult
     elseif  @op11 == "* then +"
       pp11 = (pp11 * @dp11mult) + @dp11add
     endif
     if @op12 == "+"
       pp12 = pp12 + @dp12add
     elseif  @op12 == "*"
       pp12 = pp12 * @dp12mult
     elseif  @op12 == "+ then *"
       pp12 = (pp12 + @dp12add) * @dp12mult
     elseif  @op12 == "* then +"
       pp12 = (pp12 * @dp12mult) + @dp12add
     endif
     if @op13 == "+"
       pp13 = pp13 + @dp13add
     elseif  @op13 == "*"
       pp13 = pp13 * @dp13mult
     elseif  @op13 == "+ then *"
       pp13 = (pp13 + @dp13add) * @dp13mult
     elseif  @op13 == "* then +"
       pp13 = (pp13 * @dp13mult) + @dp13add
     endif
     if @op14 == "+"
       pp14 = pp14 + @dp14add
     elseif  @op14 == "*"
       pp14 = pp14 * @dp14mult
     elseif  @op14 == "+ then *"
       pp14 = (pp14 + @dp14add) * @dp14mult
     elseif  @op14 == "* then +"
       pp14 = (pp14 * @dp14mult) + @dp14add
     endif
     if @op15 == "+"
       pp15 = pp15 + @dp15add
     elseif  @op15 == "*"
       pp15 = pp15 * @dp15mult
     elseif  @op15 == "+ then *"
       pp15 = (pp15 + @dp15add) * @dp15mult
     elseif  @op15 == "* then +"
       pp15 = (pp15 * @dp15mult) + @dp15add
     endif
     if @op21 == "+"
       pp21 = pp21 + @dp21add
     elseif  @op21 == "*"
       pp21 = pp21 * @dp21mult
     elseif  @op21 == "+ then *"
       pp21 = (pp21 + @dp21add) * @dp21mult
     elseif  @op21 == "* then +"
       pp21 = (pp21 * @dp21mult) + @dp21add
     endif
     if @op22 == "+"
       pp22 = pp22 + @dp22add
     elseif  @op22 == "*"
       pp22 = pp22 * @dp22mult
     elseif  @op22 == "+ then *"
       pp22 = (pp22 + @dp22add) * @dp22mult
     elseif  @op22 == "* then +"
       pp22 = (pp22 * @dp22mult) + @dp22add
     endif
     if @op23 == "+"
       pp23 = pp23 + @dp23add
     elseif  @op23 == "*"
       pp23 = pp23 * @dp23mult
     elseif  @op23 == "+ then *"
       pp23 = (pp23 + @dp23add) * @dp23mult
     elseif  @op23 == "* then +"
       pp23 = (pp23 * @dp23mult) + @dp23add
     endif
     if @op24 == "+"
       pp24 = pp24 + @dp24add
     elseif  @op24 == "*"
       pp24 = pp24 * @dp24mult
     elseif  @op24 == "+ then *"
       pp24 = (pp24 + @dp24add) * @dp24mult
     elseif  @op24 == "* then +"
       pp24 = (pp24 * @dp24mult) + @dp24add
     endif
     if @op25 == "+"
       pp25 = pp25 + @dp25add
     elseif  @op25 == "*"
       pp25 = pp25 * @dp25mult
     elseif  @op25 == "+ then *"
       pp25 = (pp25 + @dp25add) * @dp25mult
     elseif  @op25 == "* then +"
       pp25 = (pp25 * @dp25mult) + @dp25add
     endif
  endif
    
  if (@slope == true)
  ;;;;  process slope  
    IF (@zmode == 5)
      iterexp1 = iterexp1 + exp(-cabs(z1))
      iterexp2 = iterexp2 + exp(-cabs(z2))
      iterexp3 = iterexp3 + exp(-cabs(z3))
    ENDIF
    done = done + 1; increment iteration counter
  
    IF (@zmode == 0)                      ; smallest |z|
      d1 = |z1|; get current distances from origin
      d2 = |z2|
      d3 = |z3|
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 1)                  ; smallest |real(z)|
      d1 = abs(real(z1)); get current distances from i axis
      d2 = abs(real(z2))
      d3 = abs(real(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 2)                  ; smallest |imag(z)|
      d1 = abs(imag(z1)); get current distances from r axis
      d2 = abs(imag(z2))
      d3 = abs(imag(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 3)                  ; smallest |real(z)|+|imag(z)|
      d1 = abs(real(z1))+abs(imag(z1)); get current distances from i axis
      d2 = abs(real(z2))+abs(imag(z2))
      d3 = abs(real(z3))+abs(imag(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 4)                  ; smallest |atan(z)|
      d1 = abs(atan2(z1)); get current angles
      d2 = abs(atan2(z2))
      d3 = abs(atan2(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ENDIF
  
    IF (@bailout < |z1| ||                \
        @everyiter ||\
        done == #maxiter + 2); done, or every iteration, or last
      ; determine continuous iteration (height) for each point
      IF (@zmode >= 0 && @zmode <= 4) ; height based on smallest |z|
        e1 = s1 * @zscale
        e2 = s2 * @zscale
        e3 = s3 * @zscale
      ELSEIF (@zmode == 5)
        e1 = iterexp1 * @zscale
        e2 = iterexp2 * @zscale
        e3 = iterexp3 * @zscale
      ENDIF
  
      ; apply transfer function
      ; a function is not used because these are floats
      ; and not all functions apply to floats
      IF (@xfer == 1); log
        e1 = log(e1)
        e2 = log(e2)
        e3 = log(e3)
      ELSEIF (@xfer == 2); sqrt
        e1 = sqrt(e1)
        e2 = sqrt(e2)
        e3 = sqrt(e3)
      ELSEIF (@xfer == 3); cuberoot
        e1 = (e1)^(1/3)
        e2 = (e2)^(1/3)
        e3 = (e3)^(1/3)
      ELSEIF (@xfer == 4); exp
        e1 = exp(e1)
        e2 = exp(e2)
        e3 = exp(e3)
      ELSEIF (@xfer == 5); sqr
        e1 = sqr(e1)
        e2 = sqr(e2)
        e3 = sqr(e3)
      ELSEIF (@xfer == 6); cube
        e1 = (e1)^3
        e2 = (e2)^3
        e3 = (e3)^3
      ELSEIF (@xfer == 7); sin
        e1 = sin(e1)
        e2 = sin(e2)
        e3 = sin(e3)
      ELSEIF (@xfer == 8); cos
        e1 = cos(e1)
        e2 = cos(e2)
        e3 = cos(e3)
      ELSEIF (@xfer == 9); tan
        e1 = tan(e1)
        e2 = tan(e2)
        e3 = tan(e3)
      ENDIF
  
      ; apply post-scale
      e1 = e1 * @zscale2
      e2 = e2 * @zscale2
      e3 = e3 * @zscale2
  
        vx = e2-e1
        vy = e3-e1
        vz = -@offset
        ; normalize vector
        vd = 1/sqrt(sqr(vx)+sqr(vy)+sqr(vz))
        vx = vx*vd
        vy = vy*vd
        vz = vz*vd
        z = vx + flip(vy); fudge z from vector
    ELSE; didn't compute z this time
      z = z1; use primary iteration value to keep periodicity working
    ENDIF
  else
    z = z1
  endif
  IF (@bailout < |z1|)                  ; we're done
    done = 0
  ENDIF

    
bailout:
  (done > 0)
  
switch:
  type       = "sdc-slope-barns2-manjul"
  bailout    = @bailout
  mode       = @switchmode
  switchMode = @mode
  version    = @version
  seed       = #pixel
  
  seq        = @seq
  modBy      = @modBy
  modCmp     = @modCmp
  randomseed = @randomseed
  prob1      = @prob1
  invertMod  = @invertMod

  threshold1 = @threshold1
  thresh1    = @thresh1
  initfn1    = @initfn1
  loopfn11   = @loopfn11
  loopfn12   = @loopfn12
  loopfn13   = @loopfn13
  loopfn14   = @loopfn14
  loopfn15   = @loopfn15
  progression= @progression
  p11         = @p11
  p12         = @p12
  p13         = @p13
  p14         = @p14
  p15         = @p15
  op11        = @op11
  dp11add     = @dp11add
  dp11mult    = @dp11mult
  op12        = @op12
  dp12add     = @dp12add
  dp12mult    = @dp12mult
  op13        = @op13
  dp13add     = @dp13add
  dp13mult    = @dp13mult
  op14        = @op14
  dp14add     = @dp14add
  dp14mult    = @dp14mult
  op15        = @op15
  dp15add     = @dp15add
  dp15mult    = @dp15mult

  threshold2 = @threshold2
  thresh2    = @thresh2
  loopfn21   = @loopfn21
  loopfn22   = @loopfn22
  loopfn23   = @loopfn23
  loopfn24   = @loopfn24
  loopfn25   = @loopfn25
  progression= @progression
  p21         = @p21
  p22         = @p22
  p23         = @p23
  p24         = @p24
  p25         = @p25
  op21        = @op21
  dp21add     = @dp21add
  dp21mult    = @dp21mult
  op22        = @op22
  dp22add     = @dp22add
  dp22mult    = @dp22mult
  op23        = @op23
  dp23add     = @dp23add
  dp23mult    = @dp23mult
  op24        = @op24
  dp24add     = @dp24add
  dp24mult    = @dp24mult
  op25        = @op25
  dp25add     = @dp25add
  dp25mult    = @dp25mult

  slope      = @slope
  offset     = @offset
  zmode      = @zmode
  xfer       = @xfer
  zscale     = @zscale
  zscale2    = @zscale2
  everyiter  = @everyiter

  
default:
  title = "Slope Barnsley 2 ManJul"
  method = multipass
  periodicity = 0
  magn = 0.75
  maxiter = 100

  param mode
    caption = "Current Mode"
    default = 0
    enum = "Mandelbrot" "Julia"
    visible = false
  endparam
  
  param switchMode
    caption = "Switch Mode"
    default = 1
    enum = "Mandelbrot" "Julia"
    visible = false
  endparam
  
  float param version
    default = 1.0
    visible = false
  endparam

  heading
    caption = "Mandlebrot Mode"
    visible = @mode==0
  endheading
  
  heading
    caption = "Julia Mode"
    visible = @mode==1
  endheading
  
  float param bailout
    caption = "Bailout"
    default = 4.0
  endparam
    
  param seed
    caption = "Julia Seed"
    default = (0.6, 1.1)
    visible = @mode==1
  endparam
  
  param z0
    caption = "Initial Z"
    default = (0.0, 0.0)
    visible = @mode==0
  endparam
    
  heading
    caption = "Sequencing"
  endheading
  int param seq
    enum = "Modulation" "First Scenario" "Second Scenario" "Random"
    default = 1
    caption = "Scenario Sequence"
  endparam
  int param modBy
    default = 10
    caption = "Mod By"
    hint = "Iteration Modulated by This"
    visible = @seq==0
  endparam
  int param modCmp
    default = 5
    caption = "Mod Compare"
    hint = "Modulated Iteration < this -> formula 1"
    visible = @seq==0
  endparam
  int param randomseed
    caption = "Random Seed"
    default = 123456
    visible = @seq==3
  endparam
  float param prob1
    caption = "Prob for Func 1"
    default = 0.5
    min = 0.0
    max = 1.0
    visible = @seq==3
  endparam
  bool param invertMod
    caption = "Invert Sequence?"
    default = False
    visible = @seq==0 || @seq==3
  endparam

  heading
    caption = "Parameters & Functions"
  endheading
  func initfn1
    caption = "Initial Function"
    default = ident()
  endfunc
  
  bool param progression
    caption = "Progression?"
    default = false
  endparam
  

  heading
    caption = "Scenario 1"
    visible = @seq!=2
  endheading
  bool param threshold1
    caption = "Threshold?"
    default = false
    visible = @seq!=2
  endparam
  float param thresh1
    caption = "Threshold Value"
    default = 0.0
    visible = @seq!=2&&@threshold1==true
  endparam
  param p11
    caption = "Parameter 1"
    default = (1.0, 0.0)
    visible = @seq!=2
  endparam
  param op11
    caption = "Delta 1 Op"
    enum = "+" "*" "+ then *" "* then +"
    default = 0
    visible = @progression==true&&@seq!=2
  endparam
  param dp11add
    caption = "Delta 1 +"
    default = (0.0, 0.0)
    visible = @progression==true&&@seq!=2 && @op11!=1
  endparam
  param dp11mult
    caption = "Delta 1 *"
    default = (1.0, 0.0)
    visible = @progression==true&&@seq!=2 && @op11!=0
  endparam
  param p12
    caption = "Parameter 2"
    default = (1.0, 0.0)
    visible = @seq!=2
  endparam
  param op12
    caption = "Delta 2 Op"
    enum = "+" "*" "+ then *" "* then +"
    default = 0
    visible = @progression==true&&@seq!=2
  endparam
  param dp12add
    caption = "Delta 2 +"
    default = (0.0, 0.0)
    visible = @progression==true&&@seq!=2 && @op12!=1
  endparam
  param dp12mult
    caption = "Delta 2 *"
    default = (1.0, 0.0)
    visible = @progression==true&&@seq!=2 && @op12!=0
  endparam
  param p13
    caption = "Parameter 3"
    default = (1.0, 0.0)
    visible = @seq!=2
  endparam
  param op13
    caption = "Delta 3 Op"
    enum = "+" "*" "+ then *" "* then +"
    default = 0
    visible = @progression==true&&@seq!=2
  endparam
  param dp13add
    caption = "Delta 3 +"
    default = (0.0, 0.0)
    visible = @progression==true&&@seq!=2 && @op13!=1
  endparam
  param dp13mult
    caption = "Delta 3 *"
    default = (1.0, 0.0)
    visible = @progression==true&&@seq!=2 && @op13!=0
  endparam
  param p14
    caption = "Parameter 4"
    default = (1.0, 0.0)
    visible = @seq!=2
  endparam
  param op14
    caption = "Delta 4 Op"
    enum = "+" "*" "+ then *" "* then +"
    default = 0
    visible = @progression==true&&@seq!=2
  endparam
  param dp14add
    caption = "Delta 4 +"
    default = (0.0, 0.0)
    visible = @progression==true&&@seq!=2 && @op14!=1
  endparam
  param dp14mult
    caption = "Delta 4 *"
    default = (1.0, 0.0)
    visible = @progression==true&&@seq!=2 && @op14!=0
  endparam
  param p15
    caption = "Parameter 5"
    default = (1.0, 0.0)
    visible = @seq!=2
  endparam
  param op15
    caption = "Delta 5 Op"
    enum = "+" "*" "+ then *" "* then +"
    default = 0
    visible = @progression==true&&@seq!=2
  endparam
  param dp15add
    caption = "Delta 5 +"
    default = (0.0, 0.0)
    visible = @progression==true&&@seq!=2 && @op15!=1
  endparam
  param dp15mult
    caption = "Delta 5 *"
    default = (1.0, 0.0)
    visible = @progression==true&&@seq!=2 && @op15!=0
  endparam
  func loopfn11
    caption = "Loop Function 1"
    default = sqr()
    visible = @seq!=2
  endfunc
  func loopfn12
    caption = "Loop Function 2"
    default = sqrt()
    visible = @seq!=2
  endfunc
  func loopfn13
    caption = "Loop Function 3"
    default = ident()
    visible = @seq!=2
  endfunc
  func loopfn14
    caption = "Loop Function 4"
    default = ident()
    visible = @seq!=2
  endfunc
  func loopfn15
    caption = "Loop Function 5"
    default = ident()
    visible = @seq!=2
  endfunc

  heading
    caption = "Scenario 2"
    visible = @seq!=1
  endheading
  bool param threshold2
    caption = "Threshold?"
    default = false
    visible = @seq!=1
  endparam
  float param thresh2
    caption = "Threshold Value"
    default = 0.0
    visible = @seq!=1&&@threshold2==true
  endparam
  param p21
    caption = "Parameter 1"
    default = (1.0, 0.0)
    visible = @seq!=1
  endparam
  param op21
    caption = "Delta 1 Op"
    enum = "+" "*" "+ then *" "* then +"
    default = 0
    visible = @progression==true&&@seq!=1
  endparam
  param dp21add
    caption = "Delta 1 +"
    default = (0.0, 0.0)
    visible = @progression==true&&@seq!=1 && @op21!=1
  endparam
  param dp21mult
    caption = "Delta 1 *"
    default = (1.0, 0.0)
    visible = @progression==true&&@seq!=1 && @op21!=0
  endparam
  param p22
    caption = "Parameter 2"
    default = (1.0, 0.0)
    visible = @seq!=1
  endparam
  param op22
    caption = "Delta 2 Op"
    enum = "+" "*" "+ then *" "* then +"
    default = 0
    visible = @progression==true&&@seq!=1
  endparam
  param dp22add
    caption = "Delta 2 +"
    default = (0.0, 0.0)
    visible = @progression==true&&@seq!=1 && @op22!=1
  endparam
  param dp22mult
    caption = "Delta 2 *"
    default = (1.0, 0.0)
    visible = @progression==true&&@seq!=1 && @op22!=0
  endparam
  param p23
    caption = "Parameter 3"
    default = (1.0, 0.0)
    visible = @seq!=1
  endparam
  param op23
    caption = "Delta 3 Op"
    enum = "+" "*" "+ then *" "* then +"
    default = 0
    visible = @progression==true&&@seq!=1
  endparam
  param dp23add
    caption = "Delta 3 +"
    default = (0.0, 0.0)
    visible = @progression==true&&@seq!=1 && @op23!=1
  endparam
  param dp23mult
    caption = "Delta 3 *"
    default = (1.0, 0.0)
    visible = @progression==true&&@seq!=1 && @op23!=0
  endparam
  param p24
    caption = "Parameter 4"
    default = (1.0, 0.0)
    visible = @seq!=1
  endparam
  param op24
    caption = "Delta 4 Op"
    enum = "+" "*" "+ then *" "* then +"
    default = 0
    visible = @progression==true&&@seq!=1
  endparam
  param dp24add
    caption = "Delta 4 +"
    default = (0.0, 0.0)
    visible = @progression==true&&@seq!=1 && @op24!=1
  endparam
  param dp24mult
    caption = "Delta 4 *"
    default = (1.0, 0.0)
    visible = @progression==true&&@seq!=1 && @op24!=0
  endparam
  param p25
    caption = "Parameter 5"
    default = (1.0, 0.0)
    visible = @seq!=1
  endparam
  param op25
    caption = "Delta 5 Op"
    enum = "+" "*" "+ then *" "* then +"
    default = 0
    visible = @progression==true&&@seq!=1
  endparam
  param dp25add
    caption = "Delta 5 +"
    default = (0.0, 0.0)
    visible = @progression==true&&@seq!=1 && @op25!=1
  endparam
  param dp25mult
    caption = "Delta 5 *"
    default = (1.0, 0.0)
    visible = @progression==true&&@seq!=1 && @op25!=0
  endparam
  func loopfn21
    caption = "Loop Function 1"
    default = cos()
    visible = @seq!=1
  endfunc
  func loopfn22
    caption = "Loop Function 2"
    default = ident()
    visible = @seq!=1
  endfunc
  func loopfn23
    caption = "Loop Function 3"
    default = ident()
    visible = @seq!=1
  endfunc
  func loopfn24
    caption = "Loop Function 4"
    default = ident()
    visible = @seq!=1
  endfunc
  func loopfn25
    caption = "Loop Function 5"
    default = ident()
    visible = @seq!=1
  endfunc

  heading
    caption = "Slope Parameters"
  endheading

  bool param slope
    caption = "Apply slope?"
    default = true
  endparam

  float param offset
    caption = "Orbit Separation"
    default = 0.00000001
    hint = "Defines how far apart the simultaneous orbits are.  Smaller \
            distances will produce more accurate results."
    visible = @slope == true
  endparam
  param zmode
    caption = "Height Value"
    default = 5
    enum = "smallest |z|" "smallest |real(z)|" \
           "smallest |imag(z)|" "smallest summ(z)" "smallest |atan(z)|" \
           "smoothed iteration"
    hint = "Specifies what will be used to construct a height value."
    visible = @slope == true
  endparam
  param xfer
    caption = "Height Transfer"
    default = 0
    enum = "linear" "log" "sqrt" "cuberoot" "exp" "sqr" "cube" "sin" "cos" "tan"
    hint = "This function will be applied to the height value \
            before a slope is calculated."
    visible = @slope == true
  endparam
  param zscale
    caption = "Height Pre-Scale"
    default = 1.0
    hint = "Specifies the ratio between height and distance.  Higher \
            values will exaggerate differences between high and low. \
    In general, you will want to use smaller numbers here."
    visible = @slope == true
  endparam
  param zscale2
    caption = "Height Post-Scale"
    default = 1.0
    hint = "Specifies the ratio between height and distance; like \
            Height Pre-Scale, except that this value is applied after \
    the transfer function."
    visible = @slope == true
  endparam
  param everyiter
    caption = "Every Iteration"
    default = true
    hint = "If set, the surface normal will be computed at every \
            iteration.  If you are using a coloring algorithm which \
    processes every iteration, you will need this."
    visible = @slope == true
  endparam  

    
}

sdc-SlopeSeqManJul {
global:
init:
  ;default to Mandelbrot
   complex c1 = #pixel
   complex c2 = c1 + @offset
   complex c3 = c1 + flip(@offset)
   complex z1 = @z0
   complex z2 = z1
   complex z3 = z1
   complex lastz11 = @perturb1
   complex lastz12 = lastz11
   complex lastz13 = lastz12
   complex lastz21 = @perturb2
   complex lastz22 = lastz21
   complex lastz23 = lastz21
   if( @mode == "Julia" )
     z1 = #pixel
     z2 = z1 + @offset
     z3 = z1 + flip(@offset)
     c1 = @startseed
     c2 = c1
     c3 = c1
   endif
   
   z1 = @initfn(z1)
   z2 = @initfn(z2)
   z3 = @initfn(z3)
   
   if (@version < 0.9)
     lastz11 = lastz21 = z1
     lastz12 = lastz22 = z2
     lastz13 = lastz23 = z3
   endif

   int iter = 0
   int seed = random(@randomseed)

   ;;; slope stuff
   int done = 2
   float e1 = 0.0; potentials
   float e2 = 0.0
   float e3 = 0.0
   float vx = 0.0; normal vector
   float vy = 0.0
   float vz = 0.0
   float vd = 0.0
   float d1 = 0.0; distances
   float d2 = 0.0
   float d3 = 0.0
   float s1 = 1.0e20; smallest distances
   float s2 = 1.0e20
   float s3 = 1.0e20
   float iterexp1 = 0.0
   float iterexp2 = 0.0
   float iterexp3 = 0.0

loop:

  iter = iter + 1
  ; Determine scenario to be used:
  bool  scenario1 = false
  if ( @seq == 1 )                  ; First scenario
    scenario1 = true
  elseif ( @seq == 2 )              ; Second scenario
    scenario1 = false
  elseif (@seq == 0 )
    if ( iter % @modBy < @modCmp ); Modulation
       scenario1 = true
    endif
    if (@invertMod == true)
       scenario1 = !scenario1
    endif
  elseif ( @seq==3 )
    seed = random(seed)
    if ( abs(seed)/#randomrange < @prob1 )
      scenario1 = true
    endif
    if (@invertMod == true)
      scenario1 = !scenario1
    endif
  else
    Scenario1 = false
  endif

  if(scenario1 == true)
    if @form1 == 0    ;Mandelbrot
      z1 = @fn11(z1^@exp101) + c1
      z2 = @fn11(z2^@exp101) + c2
      z3 = @fn11(z3^@exp101) + c3
    elseif @form1 == 1 ; Phoenix
      ;;z(n+1) = z(n)^a + c*z(n)^b + p*z(n-1)
      newz1 = @fn11(z1^@exp111) + @fn12(c1*z1^@exp112) +  @p11*lastz11
      newz2 = @fn11(z2^@exp111) + @fn12(c2*z2^@exp112) +  @p11*lastz12
      newz3 = @fn11(z3^@exp111) + @fn12(c3*z3^@exp112) +  @p11*lastz13
      lastz11 = z1
      lastz12 = z2
      lastz13 = z3
      z1 = newz1
      z2 = newz2
      z3 = newz3
    elseif @form1 == 2  ; Pop Plus
      z1 = @fn11(z1)*@p12*(1.0 - @fn12(z1))*c1
      z2 = @fn11(z2)*@p12*(1.0 - @fn12(z2))*c2
      z3 = @fn11(z3)*@p12*(1.0 - @fn12(z3))*c3
    elseif @form1 == 3  ; PhoenixBarnsley
      newz1 = c1 * @fn11(@fn12(@fn13(z1))) - c1 + @p13*lastz11
      newz2 = c2 * @fn11(@fn12(@fn13(z2))) - c2 + @p13*lastz12
      newz3 = c3 * @fn11(@fn12(@fn13(z3))) - c3 + @p13*lastz13
      lastz11 = z1
      lastz12 = z2
      lastz13 = z3
      z1 = newz1
      z2 = newz2
      z3 = newz3
    endif
  else
    if @form2 == 0    ;Mandelbrot
      z1 = @fn21(z1^@exp201) + c1
      z2 = @fn21(z2^@exp201) + c2
      z3 = @fn21(z3^@exp201) + c3
    elseif @form2 == 1 ; Phoenix
      ;;z(n+1) = z(n)^a + c*z(n)^b + p*z(n-1)
      newz1 = @fn21(z1^@exp211) + @fn22(c1*z1^@exp212) +  @p21*lastz21
      newz2 = @fn21(z2^@exp211) + @fn22(c2*z2^@exp212) +  @p21*lastz22
      newz3 = @fn21(z3^@exp211) + @fn22(c3*z3^@exp212) +  @p21*lastz23
      lastz21 = z1
      lastz22 = z2
      lastz23 = z3
      z1 = newz1
      z2 = newz2
      z3 = newz3
    elseif @form2 == 2 ; Pop +
      z1 = @fn21(z1)*@p22*(1.0 - @fn22(z1))*c1
      z2 = @fn21(z2)*@p22*(1.0 - @fn22(z2))*c2
      z3 = @fn21(z3)*@p22*(1.0 - @fn22(z3))*c3
    elseif @form2 == 3  ; PhoenixBarnsley
      newz1 = c1 * @fn21(@fn22(@fn23(z1))) - c1 + @p23*lastz21
      newz2 = c2 * @fn21(@fn22(@fn23(z2))) - c2 + @p23*lastz22
      newz3 = c3 * @fn21(@fn22(@fn23(z3))) - c3 + @p23*lastz23
      lastz21 = z1
      lastz22 = z2
      lastz23 = z3
      z1 = newz1
      z2 = newz2
      z3 = newz3
    endif
  endif

  if (@slope == true)
  ;;;;  process slope
    IF (@zmode == 5)
      iterexp1 = iterexp1 + exp(-cabs(z1))
      iterexp2 = iterexp2 + exp(-cabs(z2))
      iterexp3 = iterexp3 + exp(-cabs(z3))
    ENDIF
    done = done + 1; increment iteration counter

    IF (@zmode == 0)                      ; smallest |z|
      d1 = |z1|; get current distances from origin
      d2 = |z2|
      d3 = |z3|
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 1)                  ; smallest |real(z)|
      d1 = abs(real(z1)); get current distances from i axis
      d2 = abs(real(z2))
      d3 = abs(real(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 2)                  ; smallest |imag(z)|
      d1 = abs(imag(z1)); get current distances from r axis
      d2 = abs(imag(z2))
      d3 = abs(imag(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 3)                  ; smallest |real(z)|+|imag(z)|
      d1 = abs(real(z1))+abs(imag(z1)); get current distances from i axis
      d2 = abs(real(z2))+abs(imag(z2))
      d3 = abs(real(z3))+abs(imag(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 4)                  ; smallest |atan(z)|
      d1 = abs(atan2(z1)); get current angles
      d2 = abs(atan2(z2))
      d3 = abs(atan2(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ENDIF

    IF (@bailout < |z1| ||                \
        @everyiter ||\
        done == #maxiter + 2); done, or every iteration, or last
      ; determine continuous iteration (height) for each point
      IF (@zmode >= 0 && @zmode <= 4) ; height based on smallest |z|
        e1 = s1 * @zscale
        e2 = s2 * @zscale
        e3 = s3 * @zscale
      ELSEIF (@zmode == 5)
        e1 = iterexp1 * @zscale
        e2 = iterexp2 * @zscale
        e3 = iterexp3 * @zscale
      ENDIF

      ; apply transfer function
      ; a function is not used because these are floats
      ; and not all functions apply to floats
      IF (@xfer == 1); log
        e1 = log(e1)
        e2 = log(e2)
        e3 = log(e3)
      ELSEIF (@xfer == 2); sqrt
        e1 = sqrt(e1)
        e2 = sqrt(e2)
        e3 = sqrt(e3)
      ELSEIF (@xfer == 3); cuberoot
        e1 = (e1)^(1/3)
        e2 = (e2)^(1/3)
        e3 = (e3)^(1/3)
      ELSEIF (@xfer == 4); exp
        e1 = exp(e1)
        e2 = exp(e2)
        e3 = exp(e3)
      ELSEIF (@xfer == 5); sqr
        e1 = sqr(e1)
        e2 = sqr(e2)
        e3 = sqr(e3)
      ELSEIF (@xfer == 6); cube
        e1 = (e1)^3
        e2 = (e2)^3
        e3 = (e3)^3
      ELSEIF (@xfer == 7); sin
        e1 = sin(e1)
        e2 = sin(e2)
        e3 = sin(e3)
      ELSEIF (@xfer == 8); cos
        e1 = cos(e1)
        e2 = cos(e2)
        e3 = cos(e3)
      ELSEIF (@xfer == 9); tan
        e1 = tan(e1)
        e2 = tan(e2)
        e3 = tan(e3)
      ENDIF

      ; apply post-scale
      e1 = e1 * @zscale2
      e2 = e2 * @zscale2
      e3 = e3 * @zscale2

        vx = e2-e1
        vy = e3-e1
        vz = -@offset
        ; normalize vector
        vd = 1/sqrt(sqr(vx)+sqr(vy)+sqr(vz))
        vx = vx*vd
        vy = vy*vd
        vz = vz*vd
        z = vx + flip(vy); fudge z from vector
    ELSE; didn't compute z this time
      z = z1; use primary iteration value to keep periodicity working
    ENDIF
  else
    z = z1
  endif
  IF (@bailout < |z1| )                  ; we're done
    done = 0
  ENDIF

bailout:
  (done > 0)

switch:
  type = "sdc-SlopeSeqManJul"
  version    = @version
  bailout    = @bailout
  startseed  = #pixel
  mode       = @switchmode
  switchMode = @mode

  seq        = @seq
  modBy      = @modBy
  modCmp     = @modCmp
  randomseed = @randomseed
  prob1      = @prob1
  invertMod  = @invertMod
  
  z0         = @z0
  
  form1      = @form1
  perturb1   = @perturb1
  exp101     = @exp101
  exp111     = @exp111
  exp112     = @exp112
  p11        = @p11
  p12        = @p12
  p13        = @p13
  fn11       = @fn11
  fn12       = @fn12
  fn13       = @fn13

  form2      = @form2
  perturb2   = @perturb2
  exp201     = @exp201
  exp211     = @exp211
  exp212     = @exp212
  p21        = @p21
  p22        = @p22
  p23        = @p23
  fn21       = @fn21
  fn22       = @fn22
  fn23       = @fn23

  slope      = @slope
  offset     = @offset
  zmode      = @zmode
  xfer       = @xfer
  zscale     = @zscale
  zscale2    = @zscale2
  everyiter  = @everyiter

default:
  title = "Slope Sequence ManJul"
  method = multipass
  periodicity = 0
  magn = 1
  maxiter = 100

  float param version
    default = 1.0
    visible = false
  endparam

  param mode
    caption = "Current Mode"
    default = 0
    enum = "Mandelbrot" "Julia"
    visible = false
  endparam

  param switchMode
    caption = "Switch Mode"
    default = 1
    enum = "Mandelbrot" "Julia"
    visible = false
  endparam

  heading
    caption = "Mandlebrot Mode"
    visible = @mode==0
  endheading

  heading
    caption = "Julia Mode"
    visible = @mode==1
  endheading

  float param bailout
    caption = "Bailout"
    default = 4.0
  endparam

  complex param startseed
    caption = "Julia seed"
    default = ( -.8, -.1 )
    visible = @mode==1
  endparam

  complex param z0
    caption = "z0"
    default = (0.0, 0.0)
    visible = @mode==0
  endparam
  
  func initfn
    caption = "Initial Function"
    default = ident()
  endfunc

  int param seq
    enum = "Modulation" "First Scenario" "Second Scenario" "Random"
    default = 1
    caption = "Scenario Sequence"
  endparam

  int param modBy
    default = 10
    caption = "Mod By"
    hint = "Iteration Modulated by This"
    visible = @seq==0
  endparam

  int param modCmp
    default = 5
    caption = "Mod Compare"
    hint = "Modulated Iteration < this -> formula 1"
    visible = @seq==0
  endparam
  int param randomseed
    caption = "Random Seed"
    default = 123456
    visible = @seq==3
  endparam
  float param prob1
    caption = "Prob for Func 1"
    default = 0.5
    min = 0.0
    max = 1.0
    visible = @seq==3
  endparam
  bool param invertMod
    caption = "Invert Sequence?"
    default = False
    visible = @seq==0 || @seq==3
  endparam

  heading
    caption = "Scenario 1"
    visible = @seq!=2
  endheading
  param form1
    caption = "Formula Type"
    enum = "Mandelbrot"       \
           "Phoenix"          \
           "Population +"     \
           "PhoenixBarnsley"
    default = 0
    visible = @seq!=2
  endparam
  param perturb1
    caption = "Perturbation"
    default = (0.0, 0.0)
    visible = @seq!=2 && (@form1==1 || @form1==3)
  endparam
  complex param exp101           ; Mandelbrot
    caption = "Exponent 1"
    default = (2.0, 0.0)
    visible = @seq!=2 && @form1==0
  endparam
  complex param exp111           ; Phoenix
    caption = "Exponent 1"
    default = (2.0, 0.0)
    visible = @seq!=2 && @form1==1
  endparam
  complex param exp112
    caption = "Exponent 2"
    default = (0.0, 0.0)
    visible = @seq!=2 && @form1==1
  endparam
  complex param p11
    caption = "Phoenix Distortion"
    default = (0.0, 0.5)
    visible = @seq!=2 && @form1==1
  endparam
  complex param p12              ; Pop +
    caption = "Parameter 1"
    default = (0.0, 0.5)
    visible = @seq!=2 && @form1==2
  endparam
  complex param p13              ; PhoenixBarnsley
    caption = "Phoenix Distortion"
    default = (0.5, 0.0)
    visible = @seq!=2 && @form1==3
  endparam
  func fn11
    caption = "First Function"
    default = ident()
    visible = @seq!=2
  endfunc
  func fn12
    caption = "Second Function"
    default = ident()
    visible = @seq!=2 && (@form1==1  || @form1==3)
  endfunc
  func fn13
    caption = "Third Function"
    default = ident()
    visible = @seq!=2 && (@form1==3)
  endfunc


  heading
    caption = "Scenario 2"
    visible = @seq!=1
  endheading

  param form2
    caption = "Formula Type"
    enum = "Mandelbrot"       \
           "Phoenix"          \
           "Population +"     \
           "PhoenixBarnsley"
    default = 1
    visible = @seq!=1
  endparam
  param perturb2
    caption = "Perturbation"
    default = (0.0, 0.0)
    visible = @seq!=1 && (@form2==1 || @form2==3)
  endparam
  complex param exp201         ; Mandelbrot
    caption = "Exponent 1"
    default = (2.0, 0.0)
    visible = @seq!=1 && @form2==0
  endparam
  complex param exp211        ; Phoenix
    caption = "Exponent 1"
    default = (2.0, 0.0)
    visible = @seq!=1 && @form2==1
  endparam
  complex param exp212
    caption = "Exponent 2"
    default = (0.0, 0.0)
    visible = @seq!=1 && @form2==1
  endparam
  complex param p21
    caption = "Phoenix Distortion"
    default = (0.5, 0.0)
    visible = @seq!=1 && @form2==1
  endparam
  complex param p22
    caption = "Parameter 1"        ; Pop +
    default = (0.5, 0.0)
    visible = @seq!=1 && @form2==2
  endparam
  complex param p23
    caption = "Phoenix Distortion" ; PhoenixBarnsley
    default = (0.5, 0.0)
    visible = @seq!=1 && @form2==3
  endparam
  func fn21
    caption = "First Function"
    default = ident()
    visible = @seq!=1
  endfunc
  func fn22
    caption = "Second Function"
    default = ident()
    visible = @seq!=1 && (@form2==1 || @form2==3)
  endfunc
  func fn23
    caption = "Third Function"
    default = ident()
    visible = @seq!=1 && (@form2==3)
  endfunc


  heading
    caption = "Slope Parameters"
  endheading
  bool param slope
    caption = "Apply slope?"
    default = true
    hint = "Use Lighting in dmj.ucl or one of the 3D Texturizer \
           formulas in reb.ucl with the slope applied. \
           Unset for a non-slope version registered with the\
           slope version.  Generally, unset 'Apply Slope? \
           for other formulas."
  endparam
  float param offset
    caption = "Orbit Separation"
    default = 0.001
    hint = "Defines how far apart the simultaneous orbits are.  Smaller \
            distances will produce more accurate results."
    visible = @slope==true
  endparam
  param zmode
    caption = "Height Value"
    default = 5
    enum = "smallest |z|" "smallest |real(z)|" \
           "smallest |imag(z)|" "smallest summ(z)" "smallest |atan(z)|" \
           "smoothed iteration"
    hint = "Specifies what will be used to construct a height value."
    visible = @slope==true
  endparam
  param xfer
    caption = "Height Transfer"
    default = 0
    enum = "linear" "log" "sqrt" "cuberoot" "exp" "sqr" "cube" "sin" "cos" "tan"
    hint = "This function will be applied to the height value \
            before a slope is calculated."
    visible = @slope==true
  endparam
  param zscale
    caption = "Height Pre-Scale"
    default = 1.0
    hint = "Specifies the ratio between height and distance.  Higher \
            values will exaggerate differences between high and low. \
            In general, you will want to use smaller numbers here."
    visible = @slope==true
  endparam
  param zscale2
    caption = "Height Post-Scale"
    default = 1.0
    hint = "Specifies the ratio between height and distance; like \
            Height Pre-Scale, except that this value is applied after \
            the transfer function."
    visible = @slope==true
  endparam
  param everyiter
    caption = "Every Iteration"
    default = true
    hint = "If set, the surface normal will be computed at every \
            iteration.  If you are using a coloring algorithm which \
            processes every iteration, you will need this."
    visible = @slope==true
  endparam

}

sdc-hilbert1 {
; This is a modification of Sam Monnier's Hilbert
; coloring as a slope formula.  Thanks to Sam and
; to Ron Barnett for the slope part.
; Susan, February, 2006


init:
  complex zt1 = abs(#pixel/2) - @ur
  complex zt2 = zt1 + @offset
  complex zt3 = zt1 + flip(@offset)
  float del1 = -1e20
  float del2 = -1e20
  float del3 = -1e20
  int iter = 0
  int ttype = 0

   ;;; slope stuff
   int done = 2
   float e1 = 0.0; potentials
   float e2 = 0.0
   float e3 = 0.0
   float vx = 0.0; normal vector
   float vy = 0.0
   float vz = 0.0
   float vd = 0.0
   float d1 = 0.0; distances
   float d2 = 0.0
   float d3 = 0.0
   float s1 = 1.0e20; smallest distances
   float s2 = 1.0e20
   float s3 = 1.0e20
   float iterexp1 = 0.0
   float iterexp2 = 0.0
   float iterexp3 = 0.0
   
loop:
  iter = iter + 1
  if ttype == 0
    if real(zt1) < 0 && imag(zt1) < 0
        zt1 = -conj(2*zt1 + @ur)
        zt2 = -conj(2*zt2 + @ur)
        zt3 = -conj(2*zt3 + @ur)
      elseif real(zt1) > 0 && imag(zt1) < 0
        zt1 = 1i*(2*zt1 + @ul)
        zt2 = 1i*(2*zt2 + @ul)
        zt3 = 1i*(2*zt3 + @ul)
      elseif real(zt1) > 0 && imag(zt1) > 0
        zt1 = 1i*conj(2*zt1 + @ll)
        zt2 = 1i*conj(2*zt2 + @ll)
        zt3 = 1i*conj(2*zt3 + @ll)
      elseif real(zt1) < 0 && imag(zt1) > 0
        zt1 = 2*zt1 + @lr
        zt2 = 2*zt2 + @lr
        zt3 = 2*zt3 + @lr
        ttype = 1
    endif
 else
      if real(zt1) < 0 && imag(zt1) < 0
        zt1 = 1i*(2*zt1 + @ur)
        zt2 = 1i*(2*zt2 + @ur)
        zt3 = 1i*(2*zt3 + @ur)
        ttype = 0
      elseif real(zt1) > 0 && imag(zt1) < 0
        zt1 = -1i*(2*zt1 + @ul)
        zt2 = -1i*(2*zt2 + @ul)
        zt3 = -1i*(2*zt3 + @ul)
        ttype = 0
      elseif real(zt1) > 0 && imag(zt1) > 0
        zt1 = 2*zt1 + @ll
        zt2 = 2*zt2 + @ll
        zt3 = 2*zt3 + @ll
        ttype = 0
      elseif real(zt1) < 0 && imag(zt1) > 0
        zt1 = -conj(2*zt1 + @lr)
        zt2 = -conj(2*zt2 + @lr)
        zt3 = -conj(2*zt3 + @lr)
        ttype = 0
      endif
  endif
  
  z1 = zt1      ; keep zt1 unchanged in the loop
  z2 = zt2
  z3 = zt3
  
  if @style == 0
    z1 = z1 + (1,1)
    z2 = z2 + (1,1)
    z3 = z3 + (1,1)
    if ttype == 0
      if abs(real(z1))-1 > del1
        del1 = abs(real(z1))-1
        del2 = abs(real(z2))-1
        del3 = abs(real(z3))-1
      endif
     if abs(imag(z1))-1 > del1
        del1 = abs(imag(z1))-1
        del2 = abs(imag(z2))-1
        del3 = abs(imag(z3))-1
      endif
    else
      del1 = imag(z1)-1
      del2 = imag(z2)-1
      del3 = imag(z3)-1
    endif
  elseif @style == 1 || @style == 2
    if ttype == 0
      del1 = cabs(z1+@ur)-.5
      del2 = cabs(z2+@ur)-.5
      del3 = cabs(z3+@ur)-.5
    else
      if @style == 1
        del1 = imag(z1)
        del2 = imag(z2)
        del3 = imag(z3)
      else
        del1 = imag(z1) - (real(z1)^2-.25)^2*3
        del2 = imag(z2) - (real(z2)^2-.25)^2*3
        del3 = imag(z3) - (real(z3)^2-.25)^2*3
      endif
    endif
  elseif @style == 3

    if ttype == 0
      z1 = z1 + @ur
      z2 = z2 + @ur
      z3 = z3 + @ur
      del1 = abs(real(z1)) + abs(imag(z1)) - .5
      del2 = abs(real(z2)) + abs(imag(z2)) - .5
      del3 = abs(real(z3)) + abs(imag(z3)) - .5
    else
      ;d = imag(z)-.5
      del1 = abs(real(z1)) - imag(z1) - .5
      del2 = abs(real(z2)) - imag(z2) - .5
      del3 = abs(real(z3)) - imag(z3) - .5
    endif
  endif

  z1 = abs(del1)^@power
  z2 = abs(del2)^@power
  z3 = abs(del3)^@power

   if (@slope == true)
;;;  process slope
     IF (@zmode == 5)
       iterexp1 = iterexp1 + exp(-cabs(z1))
       iterexp2 = iterexp2 + exp(-cabs(z2))
       iterexp3 = iterexp3 + exp(-cabs(z3))
     ENDIF
     done = done + 1; increment iteration counter

     IF (@zmode == 0)                      ; smallest |z|
       d1 = |z1|; get current distances from origin
       d2 = |z2|
       d3 = |z3|
       IF (d1 < s1); update smallest distances
         s1 = d1
       ENDIF
       IF (d2 < s2)
         s2 = d2
       ENDIF
       IF (d3 < s3)
         s3 = d3
       ENDIF
     ELSEIF (@zmode == 1)                  ; smallest |real(z)|
       d1 = abs(real(z1)); get current distances from i axis
       d2 = abs(real(z2))
       d3 = abs(real(z3))
       IF (d1 < s1); update smallest distances
         s1 = d1
       ENDIF
       IF (d2 < s2)
         s2 = d2
       ENDIF
       IF (d3 < s3)
         s3 = d3
       ENDIF
     ELSEIF (@zmode == 2)                  ; smallest |imag(z)|
       d1 = abs(imag(z1)); get current distances from r axis
       d2 = abs(imag(z2))
       d3 = abs(imag(z3))
       IF (d1 < s1); update smallest distances
         s1 = d1
       ENDIF
       IF (d2 < s2)
         s2 = d2
       ENDIF
       IF (d3 < s3)
         s3 = d3
       ENDIF
     ELSEIF (@zmode == 3)                  ; smallest |real(z)|+|imag(z)|
       d1 = abs(real(z1))+abs(imag(z1)); get current distances from i axis
       d2 = abs(real(z2))+abs(imag(z2))
       d3 = abs(real(z3))+abs(imag(z3))
       IF (d1 < s1); update smallest distances
         s1 = d1
       ENDIF
       IF (d2 < s2)
         s2 = d2
       ENDIF
       IF (d3 < s3)
         s3 = d3
       ENDIF
     ELSEIF (@zmode == 4)                  ; smallest |atan(z)|
       d1 = abs(atan2(z1)); get current angles
       d2 = abs(atan2(z2))
       d3 = abs(atan2(z3))
       IF (d1 < s1); update smallest distances
         s1 = d1
       ENDIF
       IF (d2 < s2)
         s2 = d2
       ENDIF
       IF (d3 < s3)
         s3 = d3
       ENDIF
     ENDIF

     IF (iter >= @niter ||                \
         @everyiter ||\
         done == #maxiter + 2); done, or every iteration, or last
     ; determine continuous iteration (height) for each point
       IF (@zmode >= 0 && @zmode <= 4) ; height based on smallest |z|
         e1 = s1 * @zscale
         e2 = s2 * @zscale
         e3 = s3 * @zscale
       ELSEIF (@zmode == 5)
         e1 = iterexp1 * @zscale
         e2 = iterexp2 * @zscale
         e3 = iterexp3 * @zscale
       ENDIF

;  apply transfer function
;  a function is not used because these are floats
;  and not all functions apply to floats
       IF (@xfer == 1); log
         e1 = log(e1)
         e2 = log(e2)
         e3 = log(e3)
       ELSEIF (@xfer == 2); sqrt
         e1 = sqrt(e1)
         e2 = sqrt(e2)
         e3 = sqrt(e3)
       ELSEIF (@xfer == 3); cuberoot
         e1 = (e1)^(1/3)
         e2 = (e2)^(1/3)
         e3 = (e3)^(1/3)
       ELSEIF (@xfer == 4); exp
         e1 = exp(e1)
         e2 = exp(e2)
         e3 = exp(e3)
       ELSEIF (@xfer == 5); sqr
         e1 = sqr(e1)
         e2 = sqr(e2)
         e3 = sqr(e3)
       ELSEIF (@xfer == 6); cube
         e1 = (e1)^3
         e2 = (e2)^3
         e3 = (e3)^3
       ELSEIF (@xfer == 7); sin
         e1 = sin(e1)
         e2 = sin(e2)
         e3 = sin(e3)
       ELSEIF (@xfer == 8); cos
         e1 = cos(e1)
         e2 = cos(e2)
         e3 = cos(e3)
       ELSEIF (@xfer == 9); tan
         e1 = tan(e1)
         e2 = tan(e2)
         e3 = tan(e3)
       ENDIF

; apply post-scale
       e1 = e1 * @zscale2
       e2 = e2 * @zscale2
       e3 = e3 * @zscale2

         vx = e2-e1
         vy = e3-e1
         vz = -@offset
; normalize vector
         vd = 1/sqrt(sqr(vx)+sqr(vy)+sqr(vz))
         vx = vx*vd
         vy = vy*vd
         vz = vz*vd
         z = vx + flip(vy); fudge z from vector
     ELSE; didn't compute z this time
       z = z1; use primary iteration value to keep periodicity working
     ENDIF
   else
     z = z1
   endif
   IF (iter >=@niter)                  ; we're done
     done = 0
   ENDIF
bailout:
  ;iter < @niter
  (done > 0)
  
default:
  title = "Hilbertesque"
  method = multipass

  float param version
    default = 1
    visible = false
  endparam

  param style
    caption = "Style"
    default = 0
    enum = "Square" "Round I" "Round II" "Diagonal"
  endparam

  param power
    caption = "Thickness"
    default = .1
  endparam

  int param niter
    caption = "Number of iterations"
    default = 4
  endparam
  
  complex param ur
   caption = "Upper Right"
   default = (0.5, 0.5)
  endparam
  complex param lr
   caption = "Lower Right"
   default = (0.5, -0.5)
  endparam
  complex param ll
   caption = "Lower Left"
   default = (-0.5, -0.5)
  endparam
  complex param ul
   caption = "Upper Left"
   default = (-0.5, 0.5)
  endparam

  bool param slope
    caption = "Apply slope?"
    default = false
  endparam


  heading
    caption = "Slope Parameters"
    visible = @slope == true
  endheading

  float param offset
    caption = "Orbit Separation"
    default = 0.005
    hint = "Defines how far apart the simultaneous orbits are.  Smaller \
            distances will produce more accurate results."
    visible = @slope == true
  endparam
  param zmode
    caption = "Height Value"
    default = 5
    enum = "smallest |z|" "smallest |real(z)|" \
           "smallest |imag(z)|" "smallest summ(z)" "smallest |atan(z)|" \
           "smoothed iteration"
    hint = "Specifies what will be used to construct a height value."
    visible = @slope == true
  endparam
  param xfer
    caption = "Height Transfer"
    default = 0
    enum = "linear" "log" "sqrt" "cuberoot" "exp" "sqr" "cube" "sin" "cos" "tan"
    hint = "This function will be applied to the height value \
            before a slope is calculated."
    visible = @slope == true
  endparam
  param zscale
    caption = "Height Pre-Scale"
    default = 1.0
    hint = "Specifies the ratio between height and distance.  Higher \
            values will exaggerate differences between high and low. \
    In general, you will want to use smaller numbers here."
    visible = @slope == true
  endparam
  param zscale2
    caption = "Height Post-Scale"
    default = 1.0
    hint = "Specifies the ratio between height and distance; like \
            Height Pre-Scale, except that this value is applied after \
    the transfer function."
    visible = @slope == true
  endparam
  param everyiter
    caption = "Every Iteration"
    default = true
    hint = "If set, the surface normal will be computed at every \
            iteration.  If you are using a coloring algorithm which \
    processes every iteration, you will need this."
    visible = @slope == true
  endparam

switch:
; This section is optional and can be used to specify a formula
; in the same file that forms a switch pair with this formula.
; This is the case for example with Mandelbrot and Julia sets.
}

sdc-hilbert1+anv {
; This is a modification of Sam Monnier's Hilbert
; coloring as a slope formula.  Thanks to Sam and
; to Ron Barnett for the slope part.
; Susan, February, 2006
; Andre Vandergoten suggested some modifications to
; Hilbert one formula.  They change some of the
; Hilbert-ness, so I have incorporated them as a
; variation.
; Susan, February, 2006


init:
  complex zt1 = abs(#pixel/@alfa) - @ur
  complex zt2 = zt1 + @offset
  complex zt3 = zt1 + flip(@offset)
  zt1 = zt3
  float del1 = -1e20
  float del2 = -1e20
  float del3 = -1e20
  int iter = 0
  int ttype = 0

   ;;; slope stuff
   int done = 2
   float e1 = 0.0; potentials
   float e2 = 0.0
   float e3 = 0.0
   float vx = 0.0; normal vector
   float vy = 0.0
   float vz = 0.0
   float vd = 0.0
   float d1 = 0.0; distances
   float d2 = 0.0
   float d3 = 0.0
   float s1 = 1.0e20; smallest distances
   float s2 = 1.0e20
   float s3 = 1.0e20
   float iterexp1 = 0.0
   float iterexp2 = 0.0
   float iterexp3 = 0.0

loop:
  iter = iter + 1
  ;if ttype == 0
  if (@mod1)
    if real(zt1) < 0 && imag(zt1) < 0
        zt1 = -conj(2*zt1 + @ur)
        zt2 = -conj(2*zt2 + @ur)
        zt3 = -conj(2*zt3 + @ur)
      elseif real(zt1) > 0 && imag(zt1) < 0
        zt1 = 1i*(2*zt1 + @ul)
        zt2 = 1i*(2*zt2 + @ul)
        zt3 = 1i*(2*zt3 + @ul)
      elseif real(zt1) > 0 && imag(zt1) > 0
        zt1 = 1i*conj(2*zt1 + @ll)
        zt2 = 1i*conj(2*zt2 + @ll)
        zt3 = 1i*conj(2*zt3 + @ll)
      elseif real(zt1) < 0 && imag(zt1) > 0
        zt1 = 2*zt1 + @lr
        zt2 = 2*zt2 + @lr
        zt3 = 2*zt3 + @lr
        ;ttype = 0
       endif
 else
   if (@mod2)
      if real(zt1) < 0 && imag(zt1) < 0
        zt1 = 1i*(2*zt1 + @ur)
        zt2 = 1i*(2*zt2 + @ur)
        zt3 = 1i*(2*zt3 + @ur)
        ;ttype = 0
      elseif real(zt1) > 0 && imag(zt1) < 0
        zt1 = -1i*(2*zt1 + @ul)
        zt2 = -1i*(2*zt2 + @ul)
        zt3 = -1i*(2*zt3 + @ul)
        ;ttype = 0
      elseif real(zt1) > 0 && imag(zt1) > 0
        zt1 = 2*zt1 + @ll
        zt2 = 2*zt2 + @ll
        zt3 = 2*zt3 + @ll
        ;ttype = 0
      elseif real(zt1) < 0 && imag(zt1) > 0
        zt1 = -conj(2*zt1 + @lr)
        zt2 = -conj(2*zt2 + @lr)
        zt3 = -conj(2*zt3 + @lr)
        ;ttype = 0
      endif
    endif
  endif

  z1 = zt1      ; keep zt1 unchanged in the loop
  z2 = zt2
  z3 = zt3

  if @style == 0
    z1 = z1 + (1,1)
    z2 = z2 + (1,1)
    z3 = z3 + (1,1)
    if ttype == 0
      if abs(real(z1))-1 > del1
        del1 = abs(real(z1))-1
        del2 = abs(real(z2))-1
        del3 = abs(real(z3))-1
      endif
     if abs(imag(z1))-1 > del1
        del1 = abs(imag(z1))-1
        del2 = abs(imag(z2))-1
        del3 = abs(imag(z3))-1
      endif
    else
      del1 = imag(z1)-1
      del2 = imag(z2)-1
      del3 = imag(z3)-1
    endif
  elseif @style == 1 || @style == 2
    if ttype == 0
      del1 = cabs(z1+@ur)-.5
      del2 = cabs(z2+@ur)-.5
      del3 = cabs(z3+@ur)-.5
    else
      if @style == 1
        del1 = imag(z1)
        del2 = imag(z2)
        del3 = imag(z3)
      else
        del1 = imag(z1) - (real(z1)^2-.25)^2*3
        del2 = imag(z2) - (real(z2)^2-.25)^2*3
        del3 = imag(z3) - (real(z3)^2-.25)^2*3
      endif
    endif
  elseif @style == 3

    if ttype == 0
      z1 = z1 + @ur
      z2 = z2 + @ur
      z3 = z3 + @ur
      del1 = abs(real(z1)) + abs(imag(z1)) - .5
      del2 = abs(real(z2)) + abs(imag(z2)) - .5
      del3 = abs(real(z3)) + abs(imag(z3)) - .5
    else
      ;d = imag(z)-.5
      del1 = abs(real(z1)) - imag(z1) - .5
      del2 = abs(real(z2)) - imag(z2) - .5
      del3 = abs(real(z3)) - imag(z3) - .5
    endif
  endif

  z1 = abs(del1)^@power
  z2 = abs(del2)^@power
  z3 = abs(del3)^@power

   if (@slope == true)
;;;  process slope
     IF (@zmode == 5)
       iterexp1 = iterexp1 + exp(-cabs(z1))
       iterexp2 = iterexp2 + exp(-cabs(z2))
       iterexp3 = iterexp3 + exp(-cabs(z3))
     ENDIF
     done = done + 1; increment iteration counter

     IF (@zmode == 0)                      ; smallest |z|
       d1 = |z1|; get current distances from origin
       d2 = |z2|
       d3 = |z3|
       IF (d1 < s1); update smallest distances
         s1 = d1
       ENDIF
       IF (d2 < s2)
         s2 = d2
       ENDIF
       IF (d3 < s3)
         s3 = d3
       ENDIF
     ELSEIF (@zmode == 1)                  ; smallest |real(z)|
       d1 = abs(real(z1)); get current distances from i axis
       d2 = abs(real(z2))
       d3 = abs(real(z3))
       IF (d1 < s1); update smallest distances
         s1 = d1
       ENDIF
       IF (d2 < s2)
         s2 = d2
       ENDIF
       IF (d3 < s3)
         s3 = d3
       ENDIF
     ELSEIF (@zmode == 2)                  ; smallest |imag(z)|
       d1 = abs(imag(z1)); get current distances from r axis
       d2 = abs(imag(z2))
       d3 = abs(imag(z3))
       IF (d1 < s1); update smallest distances
         s1 = d1
       ENDIF
       IF (d2 < s2)
         s2 = d2
       ENDIF
       IF (d3 < s3)
         s3 = d3
       ENDIF
     ELSEIF (@zmode == 3)                  ; smallest |real(z)|+|imag(z)|
       d1 = abs(real(z1))+abs(imag(z1)); get current distances from i axis
       d2 = abs(real(z2))+abs(imag(z2))
       d3 = abs(real(z3))+abs(imag(z3))
       IF (d1 < s1); update smallest distances
         s1 = d1
       ENDIF
       IF (d2 < s2)
         s2 = d2
       ENDIF
       IF (d3 < s3)
         s3 = d3
       ENDIF
     ELSEIF (@zmode == 4)                  ; smallest |atan(z)|
       d1 = abs(atan2(z1)); get current angles
       d2 = abs(atan2(z2))
       d3 = abs(atan2(z3))
       IF (d1 < s1); update smallest distances
         s1 = d1
       ENDIF
       IF (d2 < s2)
         s2 = d2
       ENDIF
       IF (d3 < s3)
         s3 = d3
       ENDIF
     ENDIF

     IF (iter >= @niter ||                \
         @everyiter ||\
         done == #maxiter + 2); done, or every iteration, or last
     ; determine continuous iteration (height) for each point
       IF (@zmode >= 0 && @zmode <= 4) ; height based on smallest |z|
         e1 = s1 * @zscale
         e2 = s2 * @zscale
         e3 = s3 * @zscale
       ELSEIF (@zmode == 5)
         e1 = iterexp1 * @zscale
         e2 = iterexp2 * @zscale
         e3 = iterexp3 * @zscale
       ENDIF

;  apply transfer function
;  a function is not used because these are floats
;  and not all functions apply to floats
       ;heading
          ;caption = "FuncSwitches"
       ;endheading
       IF (@xfer == 1); log
         e1 = log(e1)
         e2 = log(e2)
         e3 = log(e3)
       ELSEIF (@xfer == 2); sqrt
         e1 = sqrt(e1)+log(e1)
         e2 = sqrt(e2)+log(e1)
         e3 = sqrt(e3)+log(e1)
       ELSEIF (@xfer == 3); cuberoot
         e1 = (e1)^(1/3)
         e2 = (e2)^(1/3)
         e3 = (e3)^(1/3)
       ELSEIF (@xfer == 4); exp
         e1 = exp(e1)
         e2 = exp(e2)
         e3 = exp(e3)
       ELSEIF (@xfer == 5); sqr
         e1 = sqr(e1)
         e2 = sqr(e2)
         e3 = sqr(e3)
       ELSEIF (@xfer == 6); cube
         e1 = (e1)^3
         e2 = (e2)^3
         e3 = (e3)^3
       ELSEIF (@xfer == 7); sin
         e1 = sin(e1)
         e2 = sin(e2)
         e3 = sin(e3)
       ELSEIF (@xfer == 8); cos
         e1 = cos(e1)
         e2 = cos(e2)
         e3 = cos(e3)
       ELSEIF (@xfer == 9); tan
         e1 = tan(e1)
         e2 = tan(e2)
         e3 = tan(e3)
       ENDIF
; apply post-scale
       e1 = e1 * @zscale2
       e2 = e2 * @zscale2
       e3 = e3 * @zscale2

         vx = e2-e1
         vy = e3-e1
         vz = -@offset
; normalize vector
         vd = 1/sqrt(sqr(vx)+sqr(vy)+sqr(vz))
         vx = vx*vd
         vy = vy*vd
         vz = vz*vd
         z = vx + flip(vy); fudge z from vector
     ELSE; didn't compute z this time
       z = z1; use primary iteration value to keep periodicity working
     ENDIF
   else
     z = z1
   endif
   IF (iter >=@niter)                  ; we're done
     done = 0
   ENDIF
bailout:
  iter < @niter
  ;(done > 0)

default:
  title = "Hilbertesque-ANVariation"
  method = multipass

  float param version
    default = 1
    visible = false
  endparam
  float param alfa
     caption = "Initial factor"
     default  = 1.0
  endparam

  param style
    caption = "Style"
    default = 0
    enum = "Square" "Round I" "Round II" "Diagonal"
  endparam

  bool param mod1
      caption = "Modification 1"
      default = true
  endparam
  bool param mod2
      caption = "Modification 2"
      default = true
  endparam
  param power
    caption = "Thickness"
    default = .1
  endparam

  int param niter
    caption = "Number of iterations"
    default = 4
  endparam

  complex param ur
   caption = "Upper Right"
   default = (0.5, 0.5)
  endparam
  complex param lr
   caption = "Lower Right"
   default = (0.5, -0.5)
  endparam
  complex param ll
   caption = "Lower Left"
   default = (-0.5, -0.5)
  endparam
  complex param ul
   caption = "Upper Left"
   default = (-0.5, 0.5)
  endparam

  bool param slope
    caption = "Apply slope?"
    default = true
  endparam


  heading
    caption = "Slope Parameters"
    visible = @slope == true
  endheading

  float param offset
    caption = "Orbit Separation"
    default = 0.005
    hint = "Defines how far apart the simultaneous orbits are.  Smaller \
            distances will produce more accurate results."
    visible = @slope == true
  endparam
  param zmode
    caption = "Height Value"
    default = 5
    enum = "smallest |z|" "smallest |real(z)|" \
           "smallest |imag(z)|" "smallest summ(z)" "smallest |atan(z)|" \
           "smoothed iteration"
    hint = "Specifies what will be used to construct a height value."
    visible = @slope == true
  endparam
  param xfer
    caption = "Height Transfer"
    default = 0
    enum = "linear" "log" "sqrt" "cuberoot" "exp" "sqr" "cube" "sin" "cos" "tan"
    hint = "This function will be applied to the height value \
            before a slope is calculated."
    visible = @slope == true
  endparam

  param zscale
    caption = "Height Pre-Scale"
    default = 1.0
    hint = "Specifies the ratio between height and distance.  Higher \
            values will exaggerate differences between high and low. \
    In general, you will want to use smaller numbers here."
    visible = @slope == true
  endparam
  param zscale2
    caption = "Height Post-Scale"
    default = 1.0
    hint = "Specifies the ratio between height and distance; like \
            Height Pre-Scale, except that this value is applied after \
    the transfer function."
    visible = @slope == true
  endparam
  param everyiter
    caption = "Every Iteration"
    default = true
    hint = "If set, the surface normal will be computed at every \
            iteration.  If you are using a coloring algorithm which \
    processes every iteration, you will need this."
    visible = @slope == true
  endparam


switch:
; This section is optional and can be used to specify a formula
; in the same file that forms a switch pair with this formula.
; This is the case for example with Mandelbrot and Julia sets.

}

sdc-slope-midrid {
; Middle Riddle set
; gleaned from sci.nonlinear newsgroup posting
; by Roger Bagula, Mar 30, 2006

global:
   complex pg = @pt0
   complex pf = (1.0, 0.0) - pg
   if (@rpt0 == true)
     pg = real(pg)
     pf = 1.0 - pg
   endif
   ;$define DEBUG
   ;print("pg ", pg, ", pf ", pf)

init:
  ;default to Mandelbrot
   complex c1 = #pixel
   complex c2 = c1 + @offset
   complex c3 = c1 + flip(@offset)
   complex z1 = @z0
   complex z2 = z1
   complex z3 = z1
   if( @mode == "Julia" )
     z1 = #pixel
     z2 = z1 + @offset
     z3 = z1 + flip(@offset)
     c1 = @seed
     c2 = c1
     c3 = c1
   endif
   
   ;;; slope stuff
   int done = 2
   float e1 = 0.0; potentials
   float e2 = 0.0
   float e3 = 0.0
   float vx = 0.0; normal vector
   float vy = 0.0
   float vz = 0.0
   float vd = 0.0
   float d1 = 0.0; distances
   float d2 = 0.0
   float d3 = 0.0
   float s1 = 1.0e20; smallest distances
   float s2 = 1.0e20
   float s3 = 1.0e20
   float iterexp1 = 0.0
   float iterexp2 = 0.0
   float iterexp3 = 0.0

loop:
  ;;;  f(z,c)=z^2+c   - Mandelbrot set
  f1 = @fn1(z1^@pow1) + c1
  f2 = @fn1(z2^@pow1) + c2
  f3 = @fn1(z3^@pow1) + c3
  ;;;  g(z,c)=c*z^2+1 - Feigenbaum set
  g1 = @fn2(c1*z1^@pow2) + 1.0
  g2 = @fn2(c2*z2^@pow2) + 1.0
  g3 = @fn2(c3*z3^@pow2) + 1.0
  ;;;  h(z,c,t)=(1-t)*f(z,c)+t*g(z,c)   ;; blend
  z1 = pf*f1 + pg*g1
  z2 = pf*f2 + pg*g2
  z3 = pf*f3 + pg*g3

  if (@slope == true)
  ;;;;  process slope
    IF (@zmode == 5)
      iterexp1 = iterexp1 + exp(-cabs(z1))
      iterexp2 = iterexp2 + exp(-cabs(z2))
      iterexp3 = iterexp3 + exp(-cabs(z3))
    ENDIF
    done = done + 1; increment iteration counter

    IF (@zmode == 0)                      ; smallest |z|
      d1 = |z1|; get current distances from origin
      d2 = |z2|
      d3 = |z3|
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 1)                  ; smallest |real(z)|
      d1 = abs(real(z1)); get current distances from i axis
      d2 = abs(real(z2))
      d3 = abs(real(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 2)                  ; smallest |imag(z)|
      d1 = abs(imag(z1)); get current distances from r axis
      d2 = abs(imag(z2))
      d3 = abs(imag(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 3)                  ; smallest |real(z)|+|imag(z)|
      d1 = abs(real(z1))+abs(imag(z1)); get current distances from i axis
      d2 = abs(real(z2))+abs(imag(z2))
      d3 = abs(real(z3))+abs(imag(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 4)                  ; smallest |atan(z)|
      d1 = abs(atan2(z1)); get current angles
      d2 = abs(atan2(z2))
      d3 = abs(atan2(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ENDIF

    IF (@bailout < |z1| ||                \
        @everyiter ||\
        done == #maxiter + 2); done, or every iteration, or last
      ; determine continuous iteration (height) for each point
      IF (@zmode >= 0 && @zmode <= 4) ; height based on smallest |z|
        e1 = s1 * @zscale
        e2 = s2 * @zscale
        e3 = s3 * @zscale
      ELSEIF (@zmode == 5)
        e1 = iterexp1 * @zscale
        e2 = iterexp2 * @zscale
        e3 = iterexp3 * @zscale
      ENDIF

      ; apply transfer function
      ; a function is not used because these are floats
      ; and not all functions apply to floats
      IF (@xfer == 1); log
        e1 = log(e1)
        e2 = log(e2)
        e3 = log(e3)
      ELSEIF (@xfer == 2); sqrt
        e1 = sqrt(e1)
        e2 = sqrt(e2)
        e3 = sqrt(e3)
      ELSEIF (@xfer == 3); cuberoot
        e1 = (e1)^(1/3)
        e2 = (e2)^(1/3)
        e3 = (e3)^(1/3)
      ELSEIF (@xfer == 4); exp
        e1 = exp(e1)
        e2 = exp(e2)
        e3 = exp(e3)
      ELSEIF (@xfer == 5); sqr
        e1 = sqr(e1)
        e2 = sqr(e2)
        e3 = sqr(e3)
      ELSEIF (@xfer == 6); cube
        e1 = (e1)^3
        e2 = (e2)^3
        e3 = (e3)^3
      ELSEIF (@xfer == 7); sin
        e1 = sin(e1)
        e2 = sin(e2)
        e3 = sin(e3)
      ELSEIF (@xfer == 8); cos
        e1 = cos(e1)
        e2 = cos(e2)
        e3 = cos(e3)
      ELSEIF (@xfer == 9); tan
        e1 = tan(e1)
        e2 = tan(e2)
        e3 = tan(e3)
      ENDIF

      ; apply post-scale
      e1 = e1 * @zscale2
      e2 = e2 * @zscale2
      e3 = e3 * @zscale2

        vx = e2-e1
        vy = e3-e1
        vz = -@offset
        ; normalize vector
        vd = 1/sqrt(sqr(vx)+sqr(vy)+sqr(vz))
        vx = vx*vd
        vy = vy*vd
        vz = vz*vd
        z = vx + flip(vy); fudge z from vector
    ELSE; didn't compute z this time
      z = z1; use primary iteration value to keep periodicity working
    ENDIF
  else
    z = z1
  endif
  IF (@bailout < |z1|)                  ; we're done
    done = 0
  ENDIF


bailout:
  (done > 0)

switch:
  type       = "sdc-slope-midrid"
  bailout    = @bailout
  mode       = @switchmode
  switchMode = @mode
  version    = @version
  seed       = #pixel
  fn1        = @fn1
  fn2        = @fn2
  pow1       = @pow1
  pow2       = @pow2
  pt0        = @pt0
  rpt0       = @rpt0

  slope      = @slope
  offset     = @offset
  zmode      = @zmode
  xfer       = @xfer
  zscale     = @zscale
  zscale2    = @zscale2
  everyiter  = @everyiter


default:
  title = "Slope MiddleRiddle ManJul"
  method = multipass
  periodicity = 0
  center = (-3.5, 0.0)
  magn = 0.4
  maxiter = 100

  param mode
    caption = "Current Mode"
    default = 0
    enum = "Mandelbrot" "Julia"
    visible = false
  endparam

  param switchMode
    caption = "Switch Mode"
    default = 1
    enum = "Mandelbrot" "Julia"
    visible = false
  endparam

  float param version
    default = 1.0
    visible = false
  endparam

  heading
    caption = "Mandlebrot Mode"
    visible = @mode==0
  endheading

  heading
    caption = "Julia Mode"
    visible = @mode==1
  endheading

  float param bailout
    caption = "Bailout"
    default = 1000.0
  endparam

  complex param seed
    caption = "Julia Seed"
    default = (0.0, 0.0)
    visible = @mode==1
  endparam

  complex param z0
    caption = "Initial Z"
    default = (0.0, 0.0)
    visible = @mode==0
  endparam
  
  complex param pt0
    caption = "Parameter T"
    hint = "Ranges from 0.0 - 1.0"
    ;min = (0.0, 0.0)
    ;max = (1.0, 1.0)
    default = (0.125, 0.0)
  endparam
  
  bool param rpt0
    caption = "Use only real part?"
    hint = "Confine Parameter T to a real number?"
    default = true
  endparam
  
  heading
    caption = "Mandelbrot Part"
  endheading

  param pow1
    caption = "Power 1"
    default = (2.0, 0.0)
  endparam

  func fn1
    caption = "Function 1"
    default = ident()
  endfunc

  heading
    caption = "Feigenbaum Part"
  endheading

  param pow2
    caption = "Power 2"
    default = (2.0, 0.0)
  endparam

  func fn2
    caption = "Function 2"
    default = ident()
  endfunc

  bool param slope
    caption = "Apply slope?"
    default = true
  endparam


  heading
    caption = "Slope Parameters"
    visible = @slope == true
  endheading

  float param offset
    caption = "Orbit Separation"
    default = 0.005
    hint = "Defines how far apart the simultaneous orbits are.  Smaller \
            distances will produce more accurate results."
    visible = @slope == true
  endparam
  param zmode
    caption = "Height Value"
    default = 5
    enum = "smallest |z|" "smallest |real(z)|" \
           "smallest |imag(z)|" "smallest summ(z)" "smallest |atan(z)|" \
           "smoothed iteration"
    hint = "Specifies what will be used to construct a height value."
    visible = @slope == true
  endparam
  param xfer
    caption = "Height Transfer"
    default = 0
    enum = "linear" "log" "sqrt" "cuberoot" "exp" "sqr" "cube" "sin" "cos" "tan"
    hint = "This function will be applied to the height value \
            before a slope is calculated."
    visible = @slope == true
  endparam
  param zscale
    caption = "Height Pre-Scale"
    default = 1.0
    hint = "Specifies the ratio between height and distance.  Higher \
            values will exaggerate differences between high and low. \
    In general, you will want to use smaller numbers here."
    visible = @slope == true
  endparam
  param zscale2
    caption = "Height Post-Scale"
    default = 1.0
    hint = "Specifies the ratio between height and distance; like \
            Height Pre-Scale, except that this value is applied after \
    the transfer function."
    visible = @slope == true
  endparam
  param everyiter
    caption = "Every Iteration"
    default = true
    hint = "If set, the surface normal will be computed at every \
            iteration.  If you are using a coloring algorithm which \
    processes every iteration, you will need this."
    visible = @slope == true
  endparam


}

sdc-SlopeMixMaster {
;  Version 1.0  -- adds Simurgh to Slope Seq ManJul
global:
init:
  ;default to Mandelbrot
   complex c1 = #pixel
   complex c2 = c1 + @offset
   complex c3 = c1 + flip(@offset)
   complex z1 = @z0
   complex z2 = z1
   complex z3 = z1
   complex lastz11 = @perturb1
   complex lastz12 = lastz11
   complex lastz13 = lastz12
   complex lastz21 = @perturb2
   complex lastz22 = lastz21
   complex lastz23 = lastz21
   complex lastlastz11 = @perturb1
   complex lastlastz12 = lastlastz11
   complex lastlastz13 = lastlastz12
   complex lastlastz21 = @perturb2
   complex lastlastz22 = lastlastz21
   complex lastlastz23 = lastlastz21
   if( @mode == "Julia" )
     z1 = #pixel
     z2 = z1 + @offset
     z3 = z1 + flip(@offset)
     c1 = @startseed
     c2 = c1
     c3 = c1
   endif
   
   z1 = @initfn(z1)
   z2 = @initfn(z2)
   z3 = @initfn(z3)
   
   int iter = 0
   int seed = random(@randomseed)

   ;;; slope stuff
   int done = 2
   float e1 = 0.0; potentials
   float e2 = 0.0
   float e3 = 0.0
   float vx = 0.0; normal vector
   float vy = 0.0
   float vz = 0.0
   float vd = 0.0
   float d1 = 0.0; distances
   float d2 = 0.0
   float d3 = 0.0
   float s1 = 1.0e20; smallest distances
   float s2 = 1.0e20
   float s3 = 1.0e20
   float iterexp1 = 0.0
   float iterexp2 = 0.0
   float iterexp3 = 0.0

loop:

  iter = iter + 1
  ; Determine scenario to be used:
  bool  scenario1 = false
  if ( @seq == 1 )                  ; First scenario
    scenario1 = true
  elseif ( @seq == 2 )              ; Second scenario
    scenario1 = false
  elseif (@seq == 0 )
    if ( iter % @modBy < @modCmp ); Modulation
       scenario1 = true
    endif
    if (@invertMod == true)
       scenario1 = !scenario1
    endif
  elseif ( @seq==3 )
    seed = random(seed)
    if ( abs(seed)/#randomrange < @prob1 )
      scenario1 = true
    endif
    if (@invertMod == true)
      scenario1 = !scenario1
    endif
  else
    Scenario1 = false
  endif

  if(scenario1 == true)
    if @form1 == 0    ;Mandelbrot
      z1 = @fn11(z1^@exp101) + c1
      z2 = @fn11(z2^@exp101) + c2
      z3 = @fn11(z3^@exp101) + c3
    elseif @form1 == 1 ; Phoenix
      ;;z(n+1) = z(n)^a + c*z(n)^b + p*z(n-1)
      newz1 = @fn11(z1^@exp111) + @fn12(c1*z1^@exp112) +  @p11*lastz11
      newz2 = @fn11(z2^@exp111) + @fn12(c2*z2^@exp112) +  @p11*lastz12
      newz3 = @fn11(z3^@exp111) + @fn12(c3*z3^@exp112) +  @p11*lastz13
      lastz11 = z1
      lastz12 = z2
      lastz13 = z3
      z1 = newz1
      z2 = newz2
      z3 = newz3
    elseif @form1 == 2  ; Pop Plus
      z1 = @fn11(z1)*@p12*(1.0 - @fn12(z1))*c1
      z2 = @fn11(z2)*@p12*(1.0 - @fn12(z2))*c2
      z3 = @fn11(z3)*@p12*(1.0 - @fn12(z3))*c3
    elseif @form1 == 3  ; PhoenixBarnsley
      newz1 = c1 * @fn11(@fn12(@fn13(z1))) - c1 + @p13*lastz11
      newz2 = c2 * @fn11(@fn12(@fn13(z2))) - c2 + @p13*lastz12
      newz3 = c3 * @fn11(@fn12(@fn13(z3))) - c3 + @p13*lastz13
      lastz11 = z1
      lastz12 = z2
      lastz13 = z3
      z1 = newz1
      z2 = newz2
      z3 = newz3
    elseif @form1 == 4  ; Simurgh
      ; z[n+1] = s*z[n]^a + t*z[n]^b + c*z[n]^d + p*z[n-1] + q*z[n-2]
      term11 = @fn11(@fn12(@fn13(@p141*(z1^@exp141))))
      term12 = @fn11(@fn12(@fn13(@p141*(z2^@exp141))))
      term13 = @fn11(@fn12(@fn13(@p141*(z3^@exp141))))
      term21 = @fn14(@fn15(@fn16(@p142*(z1^@exp142))))
      term22 = @fn14(@fn15(@fn16(@p142*(z2^@exp142))))
      term23 = @fn14(@fn15(@fn16(@p142*(z3^@exp142))))
      term31 = c1*(z1^@exp143)
      term32 = c2*(z2^@exp143)
      term33 = c3*(z3^@exp143)
      term41 = @p143*lastz11
      term42 = @p143*lastz12
      term43 = @p143*lastz13
      term51 = @p144*lastlastz11
      term52 = @p144*lastlastz12
      term53 = @p144*lastlastz13
      newz1 = term11 + term21 + term31 + term41 + term51
      newz2 = term12 + term22 + term32 + term42 + term52
      newz3 = term13 + term23 + term33 + term43 + term53
      lastlastz11 = lastz11
      lastlastz12 = lastz12
      lastlastz13 = lastz13
      lastz11 = z1
      lastz12 = z2
      lastz13 = z3
      z1 = newz1
      z2 = newz2
      z3 = newz3
     elseif @form1 == 5  ; Barnsley Variants
       float testValue
       if @m15 == 0
         testValue = real(z1)
       elseif @m15 == 1
         testValue = real(z1) * imag(c1) + real(c1) * imag(z1)
       else  ; @m15 == 2
         testValue = real(z1)
       endif
       if @m15 == 0 || @m15 == 1
         if testValue >= @t15
           z1 = @fn15(@p155*@fn14(@p154*c1 * @fn13(@p153*@fn12(@p152*@fn11(@p151*(z1-1.0))))))
           z2 = @fn15(@p155*@fn14(@p154*c2 * @fn13(@p153*@fn12(@p152*@fn11(@p151*(z2-1.0))))))
           z3 = @fn15(@p155*@fn14(@p154*c3 * @fn13(@p153*@fn12(@p152*@fn11(@p151*(z3-1.0))))))
         else
           z1 = @fn15(@p155*@fn14(@p154*c1 * @fn13(@p153*@fn12(@p152*@fn11(@p151*(z1+1.0))))))
           z2 = @fn15(@p155*@fn14(@p154*c2 * @fn13(@p153*@fn12(@p152*@fn11(@p151*(z2+1.0))))))
           z3 = @fn15(@p155*@fn14(@p154*c3 * @fn13(@p153*@fn12(@p152*@fn11(@p151*(z3+1.0))))))
         endif
       elseif @m15 == 2
         if testValue > @t15
           ; z(n+1) = (real(z(n))^2 - imag(z(n))^2 - 1 + real(c) * real(z(n)) + i * (2*real(z((n)) * imag(z((n)) + imag(c) * real(z(n))
           z1 = @fn13(@p153*@fn12(@p152*@fn11(@p151*(z1*z1 - 1.0))))
           z2 = @fn13(@p153*@fn12(@p152*@fn11(@p151*(z2*z2 - 1.0))))
           z3 = @fn13(@p153*@fn12(@p152*@fn11(@p151*(z3*z3 - 1.0))))
         else
           ; sqr(#z) - 1 + #pixel * real(#z)
           z1 = @fn13(@p153*@fn12(@p152*@fn11(@p151*(z1*z1 - 1.0)))) + @fn15(@p155*@fn14(@p154*(c1 * real(z1))))
           z2 = @fn13(@p153*@fn12(@p152*@fn11(@p151*(z2*z2 - 1.0)))) + @fn15(@p155*@fn14(@p154*(c2 * real(z2))))
           z3 = @fn13(@p153*@fn12(@p152*@fn11(@p151*(z3*z3 - 1.0)))) + @fn15(@p155*@fn14(@p154*(c3 * real(z3))))
         endif
     elseif @m15 == 3
         if testValue > @t15
           ; z(n+1) = (real(z(n))^2 - imag(z(n))^2 - 1 + real(c) * real(z(n)) + i * (2*real(z((n)) * imag(z((n)) + imag(c) * real(z(n))
           z1 = @fn13(@p153*@fn12(@p152*@fn11(@p151*(z1*z1 - 1.0))))*c1
           z2 = @fn13(@p153*@fn12(@p152*@fn11(@p151*(z2*z2 - 1.0))))*c2
           z3 = @fn13(@p153*@fn12(@p152*@fn11(@p151*(z3*z3 - 1.0))))*c3
         else
           ; sqr(#z) - 1 + #pixel * real(#z)
           z1 = @fn15(@p155*@fn14(@p154*(z1*z1 + 1.0)))*c1
           z2 = @fn15(@p155*@fn14(@p154*(z2*z2 + 1.0)))*c2
           z3 = @fn15(@p155*@fn14(@p154*(z3*z3 + 1.0)))*c3
         endif
     elseif @m15 == 4
         if testValue > @t15
           ; z(n+1) = fn1(fn1(z*(z-p1))+fn3(c*(c-p2)))
           z1 = @fn11(@fn12(z1*(z1-@p151)) + @fn13(c1*(c1-@p152)))
           z2 = @fn11(@fn12(z2*(z2-@p151)) + @fn13(c2*(c2-@p152)))
           z3 = @fn11(@fn12(z3*(z3-@p151)) + @fn13(c3*(c3-@p152)))
         else
           ; z(n+1) = fn1(fn1(z*(z+p1))+fn3(c*(c+p2)))
           z1 = @fn11(@fn12(z1*(z1+@p151)) + @fn13(c1*(c1+@p152)))
           z2 = @fn11(@fn12(z2*(z2+@p151)) + @fn13(c2*(c2+@p152)))
           z3 = @fn11(@fn12(z3*(z3+@p151)) + @fn13(c3*(c3+@p152)))
         endif
      endif
    elseif @form1 == 6  ; Feigenbaum
      ;;;  g(z,c)=c*z^2+1 - Feigenbaum set
      z1 = @fn11(c1*z1^@exp161) + @p161
      z2 = @fn11(c2*z2^@exp161) + @p161
      z3 = @fn11(c3*z3^@exp161) + @p161
    elseif @form1 == 7  ; Celtic
      ;;;                   Celtic set
      z1 = z1^@exp171
      z2 = z2^@exp171
      z3 = z3^@exp171
      z1 = z1 - @fn11(real(z1)) + @fn12(real(z1)) - c1
      z2 = z2 - @fn11(real(z2)) + @fn12(real(z2)) - c2
      z3 = z3 - @fn11(real(z3)) + @fn12(real(z3)) - c3
    endif
  else
    if @form2 == 0    ;Mandelbrot
      z1 = @fn21(z1^@exp201) + c1
      z2 = @fn21(z2^@exp201) + c2
      z3 = @fn21(z3^@exp201) + c3
    elseif @form2 == 1 ; Phoenix
      ;;z(n+1) = z(n)^a + c*z(n)^b + p*z(n-1)
      newz1 = @fn21(z1^@exp211) + @fn22(c1*z1^@exp212) +  @p21*lastz21
      newz2 = @fn21(z2^@exp211) + @fn22(c2*z2^@exp212) +  @p21*lastz22
      newz3 = @fn21(z3^@exp211) + @fn22(c3*z3^@exp212) +  @p21*lastz23
      lastz21 = z1
      lastz22 = z2
      lastz23 = z3
      z1 = newz1
      z2 = newz2
      z3 = newz3
    elseif @form2 == 2 ; Pop +
      z1 = @fn21(z1)*@p22*(1.0 - @fn22(z1))*c1
      z2 = @fn21(z2)*@p22*(1.0 - @fn22(z2))*c2
      z3 = @fn21(z3)*@p22*(1.0 - @fn22(z3))*c3
    elseif @form2 == 3  ; PhoenixBarnsley
      newz1 = c1 * @fn21(@fn22(@fn23(z1))) - c1 + @p23*lastz21
      newz2 = c2 * @fn21(@fn22(@fn23(z2))) - c2 + @p23*lastz22
      newz3 = c3 * @fn21(@fn22(@fn23(z3))) - c3 + @p23*lastz23
      lastz21 = z1
      lastz22 = z2
      lastz23 = z3
      z1 = newz1
      z2 = newz2
      z3 = newz3
    elseif @form2 == 4  ; Simurgh
      ; z[n+1] = s*z[n]^a + t*z[n]^b + c*z[n]^d + p*z[n-1] + q*z[n-2]
      term11 = @fn21(@fn22(@fn23(@p241*(z1^@exp241))))
      term12 = @fn21(@fn22(@fn23(@p241*(z2^@exp241))))
      term13 = @fn21(@fn22(@fn23(@p241*(z3^@exp241))))
      term21 = @fn24(@fn25(@fn26(@p242*(z1^@exp242))))
      term22 = @fn24(@fn25(@fn26(@p242*(z2^@exp242))))
      term23 = @fn24(@fn25(@fn26(@p242*(z3^@exp242))))
      term31 = c1*(z1^@exp243)
      term32 = c2*(z2^@exp243)
      term33 = c3*(z3^@exp243)
      term41 = @p243*lastz21
      term42 = @p243*lastz22
      term43 = @p243*lastz23
      term51 = @p244*lastlastz21
      term52 = @p244*lastlastz22
      term53 = @p244*lastlastz23
      newz1 = term11 + term21 + term31 + term41 + term51
      newz2 = term12 + term22 + term32 + term42 + term52
      newz3 = term13 + term23 + term33 + term43 + term53
      lastlastz21 = lastz21
      lastlastz22 = lastz22
      lastlastz23 = lastz23
      lastz21 = z1
      lastz22 = z2
      lastz23 = z3
      z1 = newz1
      z2 = newz2
      z3 = newz3
     elseif @form2 == 5
       if @m25 == 0
         testValue = real(z1)
       elseif @m25 == 1
         testValue = real(z1) * imag(c1) + real(c1) * imag(z1)
       else  ; @m25 == 2
         testValue = real(z1)
       endif
       if @m25 == 0 || @m25 == 1
         if testValue >= @t25
           z1 = @fn25(@p255*@fn24(@p254*c1 * @fn23(@p253*@fn22(@p252*@fn21(@p251*(z1-1.0))))))
           z2 = @fn25(@p255*@fn24(@p254*c2 * @fn23(@p253*@fn22(@p252*@fn21(@p251*(z2-1.0))))))
           z3 = @fn25(@p255*@fn24(@p254*c3 * @fn23(@p253*@fn22(@p252*@fn21(@p251*(z3-1.0))))))
         else
           z1 = @fn25(@p255*@fn24(@p254*c1 * @fn23(@p253*@fn22(@p252*@fn21(@p251*(z1+1.0))))))
           z2 = @fn25(@p255*@fn24(@p254*c2 * @fn23(@p253*@fn22(@p252*@fn21(@p251*(z2+1.0))))))
           z3 = @fn25(@p255*@fn24(@p254*c3 * @fn23(@p253*@fn22(@p252*@fn21(@p251*(z3+1.0))))))
         endif
     elseif @m25 == 2
         if testValue > @t25
           ; z(n+1) = (real(z(n))^2 - imag(z(n))^2 - 1 + real(c) * real(z(n)) + i * (2*real(z((n)) * imag(z((n)) + imag(c) * real(z(n))
           z1 = @fn23(@p253*@fn22(@p252*@fn21(@p251*(z1*z1 - 1.0))))
           z2 = @fn23(@p253*@fn22(@p252*@fn21(@p251*(z2*z2 - 1.0))))
           z3 = @fn23(@p253*@fn22(@p252*@fn21(@p251*(z3*z3 - 1.0))))
         else
           ; sqr(#z) - 1 + #pixel * real(#z)
           z1 = @fn23(@p253*@fn22(@p252*@fn21(@p251*(z1*z1 - 1.0)))) + @fn25(@p255*@fn24(@p254*(c1 * real(z1))))
           z2 = @fn23(@p253*@fn22(@p252*@fn21(@p251*(z2*z2 - 1.0)))) + @fn25(@p255*@fn24(@p254*(c2 * real(z2))))
           z3 = @fn23(@p253*@fn22(@p252*@fn21(@p251*(z3*z3 - 1.0)))) + @fn25(@p255*@fn24(@p254*(c3 * real(z3))))
         endif
     elseif @m25 == 3
         if testValue > @t25
           ;
           z1 = @fn23(@p253*@fn22(@p252*@fn21(@p251*(z1*z1 - 1.0))))*c1
           z2 = @fn23(@p253*@fn22(@p252*@fn21(@p251*(z2*z2 - 1.0))))*c2
           z3 = @fn23(@p253*@fn22(@p252*@fn21(@p251*(z3*z3 - 1.0))))*c3
         else
           ;
           z1 = @fn25(@p255*@fn24(@p254*(z1*z1 + 1.0)))*c1
           z2 = @fn25(@p255*@fn24(@p254*(z2*z2 + 1.0)))*c2
           z3 = @fn25(@p255*@fn24(@p254*(z3*z3 + 1.0)))*c3
         endif
     elseif @m25 == 4
         if testValue > @t25
           ; z(n+1) = fn1(fn2(z*(z-p1))+fn3(c*(c-p2)))
           z1 = @fn21(@fn22(z1*(z1-@p251)) + @fn23(c1*(c1-@p252)))
           z2 = @fn21(@fn22(z2*(z2-@p251)) + @fn23(c2*(c2-@p252)))
           z3 = @fn21(@fn22(z3*(z3-@p251)) + @fn23(c3*(c3-@p252)))
         else
           ; z(n+1) = fn1(fn2(z*(z+p1))+fn3(c*(c+p2)))
           z1 = @fn21(@fn22(z1*(z1+@p251)) + @fn23(c1*(c1+@p252)))
           z2 = @fn21(@fn22(z2*(z2+@p251)) + @fn23(c2*(c2+@p252)))
           z3 = @fn21(@fn22(z3*(z3+@p251)) + @fn23(c3*(c3+@p252)))
         endif
      endif
    elseif @form2 == 6  ; Feigenbaum
      ;;;  g(z,c)=c*z^2+1 - Feigenbaum set
      z1 = @fn21(c1*z1^@exp261) + @p261
      z2 = @fn21(c2*z2^@exp261) + @p261
      z3 = @fn21(c3*z3^@exp261) + @p261
    elseif @form2 == 7  ; Celtic
      ;;;                   Celtic set
      z1 = z1^@exp271
      z2 = z2^@exp271
      z3 = z3^@exp271
      z1 = z1 - @fn21(real(z1)) + @fn22(real(z1)) - c1
      z2 = z2 - @fn21(real(z2)) + @fn22(real(z2)) - c2
      z3 = z3 - @fn21(real(z3)) + @fn22(real(z3)) - c3
    endif

  endif

  if (@slope == true)
  ;;;;  process slope
    IF (@zmode == 5)
      iterexp1 = iterexp1 + exp(-cabs(z1))
      iterexp2 = iterexp2 + exp(-cabs(z2))
      iterexp3 = iterexp3 + exp(-cabs(z3))
    ENDIF
    done = done + 1; increment iteration counter

    IF (@zmode == 0)                      ; smallest |z|
      d1 = |z1|; get current distances from origin
      d2 = |z2|
      d3 = |z3|
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 1)                  ; smallest |real(z)|
      d1 = abs(real(z1)); get current distances from i axis
      d2 = abs(real(z2))
      d3 = abs(real(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 2)                  ; smallest |imag(z)|
      d1 = abs(imag(z1)); get current distances from r axis
      d2 = abs(imag(z2))
      d3 = abs(imag(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 3)                  ; smallest |real(z)|+|imag(z)|
      d1 = abs(real(z1))+abs(imag(z1)); get current distances from i axis
      d2 = abs(real(z2))+abs(imag(z2))
      d3 = abs(real(z3))+abs(imag(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 4)                  ; smallest |atan(z)|
      d1 = abs(atan2(z1)); get current angles
      d2 = abs(atan2(z2))
      d3 = abs(atan2(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ENDIF

    IF (@bailout < |z1| ||                \
        @everyiter ||\
        done == #maxiter + 2); done, or every iteration, or last
      ; determine continuous iteration (height) for each point
      IF (@zmode >= 0 && @zmode <= 4) ; height based on smallest |z|
        e1 = s1 * @zscale
        e2 = s2 * @zscale
        e3 = s3 * @zscale
      ELSEIF (@zmode == 5)
        e1 = iterexp1 * @zscale
        e2 = iterexp2 * @zscale
        e3 = iterexp3 * @zscale
      ENDIF

      ; apply transfer function
      ; a function is not used because these are floats
      ; and not all functions apply to floats
      IF (@xfer == 1); log
        e1 = log(e1)
        e2 = log(e2)
        e3 = log(e3)
      ELSEIF (@xfer == 2); sqrt
        e1 = sqrt(e1)
        e2 = sqrt(e2)
        e3 = sqrt(e3)
      ELSEIF (@xfer == 3); cuberoot
        e1 = (e1)^(1/3)
        e2 = (e2)^(1/3)
        e3 = (e3)^(1/3)
      ELSEIF (@xfer == 4); exp
        e1 = exp(e1)
        e2 = exp(e2)
        e3 = exp(e3)
      ELSEIF (@xfer == 5); sqr
        e1 = sqr(e1)
        e2 = sqr(e2)
        e3 = sqr(e3)
      ELSEIF (@xfer == 6); cube
        e1 = (e1)^3
        e2 = (e2)^3
        e3 = (e3)^3
      ELSEIF (@xfer == 7); sin
        e1 = sin(e1)
        e2 = sin(e2)
        e3 = sin(e3)
      ELSEIF (@xfer == 8); cos
        e1 = cos(e1)
        e2 = cos(e2)
        e3 = cos(e3)
      ELSEIF (@xfer == 9); tan
        e1 = tan(e1)
        e2 = tan(e2)
        e3 = tan(e3)
      ENDIF

      ; apply post-scale
      e1 = e1 * @zscale2
      e2 = e2 * @zscale2
      e3 = e3 * @zscale2

        vx = e2-e1
        vy = e3-e1
        vz = -@offset
        ; normalize vector
        vd = 1/sqrt(sqr(vx)+sqr(vy)+sqr(vz))
        vx = vx*vd
        vy = vy*vd
        vz = vz*vd
        z = vx + flip(vy); fudge z from vector
    ELSE; didn't compute z this time
      z = z1; use primary iteration value to keep periodicity working
    ENDIF
  else
    z = z1
  endif
  IF (@bailout < |z1| )                  ; we're done
    done = 0
  ENDIF

bailout:
  (done > 0)

switch:
  type = "sdc-SlopeMixMaster"
  version    = @version
  bailout    = @bailout
  startseed  = #pixel
  mode       = @switchmode
  switchMode = @mode

  seq        = @seq
  modBy      = @modBy
  modCmp     = @modCmp
  randomseed = @randomseed
  prob1      = @prob1
  invertMod  = @invertMod
  
  z0         = @z0
  
  form1      = @form1
  perturb1   = @perturb1
  exp101     = @exp101
  exp111     = @exp111
  exp112     = @exp112
  exp141     = @exp141
  exp142     = @exp142
  exp143     = @exp143
  exp161     = @exp161
  exp171     = @exp171
  p11        = @p11
  p12        = @p12
  p13        = @p13
  p141       = @p141
  p142       = @p142
  p143       = @p143
  p144       = @p144
  m15        = @m15
  t15        = @t15
  p151       = @p151
  p152       = @p152
  p153       = @p153
  p154       = @p154
  p155       = @p155
  p161       = @p161
  fn11       = @fn11
  fn12       = @fn12
  fn13       = @fn13
  fn14       = @fn14
  fn16       = @fn15
  fn16       = @fn16

  form2      = @form2
  perturb2   = @perturb2
  exp201     = @exp201
  exp211     = @exp211
  exp212     = @exp212
  exp241     = @exp241
  exp242     = @exp242
  exp243     = @exp243
  exp261     = @exp261
  exp271     = @exp271
  p21        = @p21
  p22        = @p22
  p23        = @p23
  p241       = @p241
  p242       = @p242
  p243       = @p243
  p244       = @p244
  m25        = @m25
  t25        = @t25
  p251       = @p251
  p252       = @p252
  p253       = @p253
  p254       = @p254
  p255       = @p255
  p261       = @p261
  fn21       = @fn21
  fn22       = @fn22
  fn23       = @fn23
  fn24       = @fn24
  fn26       = @fn25
  fn26       = @fn26

  slope      = @slope
  offset     = @offset
  zmode      = @zmode
  xfer       = @xfer
  zscale     = @zscale
  zscale2    = @zscale2
  everyiter  = @everyiter

default:
  title = "Slope Mix Master"
  method = multipass
  periodicity = 0
  magn = 1
  maxiter = 100

   float param version
     default = 1.123
     visible = false
   endparam

  param mode
    caption = "Current Mode"
    default = 0
    enum = "Mandelbrot" "Julia"
    visible = false
  endparam

   param switchMode
     caption = "Switch Mode"
     default = 1
     enum = "Mandelbrot" "Julia"
     visible = false
   endparam

   heading
     caption = "Mandlebrot Mode"
     visible = @mode==0
   endheading

   heading
     caption = "Julia Mode"
     visible = @mode==1
   endheading

   float param bailout
     caption = "Bailout"
     default = 4.0
   endparam

   complex param startseed
     caption = "Julia seed"
     default = ( -.8, -.1 )
     visible = @mode==1
   endparam

   complex param z0
     caption = "z0"
     default = (0.01, 0.0)
     visible = @mode==0
   endparam

   func initfn
     caption = "Initial Function"
     default = ident()
   endfunc

   int param seq
     enum = "Modulation" "First Scenario" "Second Scenario" "Random"
     default = 1
     caption = "Scenario Sequence"
   endparam

   int param modBy
     default = 10
     caption = "Mod By"
     hint = "Iteration Modulated by This"
     visible = @seq==0
   endparam

  int param modCmp
    default = 5
    caption = "Mod Compare"
    hint = "Modulated Iteration < this -> formula 1"
    visible = @seq==0
  endparam
   int param randomseed
     caption = "Random Seed"
     default = 123456
     visible = @seq==3
   endparam
   float param prob1
     caption = "Prob for Func 1"
     default = 0.5
     min = 0.0
     max = 1.0
     visible = @seq==3
   endparam
   bool param invertMod
     caption = "Invert Sequence?"
     default = False
     visible = @seq==0 || @seq==3
   endparam

   heading
     caption = "Scenario 1"
     visible = @seq!=2
   endheading
  param form1
    caption = "Formula Type"
    enum = "Mandelbrot"         \
           "Phoenix"            \
           "Population +"       \
           "PhoenixBarnsley"    \
           "Simurgh"            \
           "Barnsley Variants"  \
           "Feigenbaum"         \
           "Celtic"
    default = 0
    visible = @seq!=2
  endparam
  param perturb1
    caption = "Perturbation"
    default = (0.0, 0.0)
    visible = @seq!=2 && (@form1==1 || \
                          @form1==3 || \
                          @form1==4)
  endparam
  complex param exp101           ; Mandelbrot
    caption = "Exponent 1"
    default = (2.0, 0.0)
    visible = @seq!=2 && @form1==0
  endparam
  complex param exp111           ; Phoenix
    caption = "Exponent 1"
    default = (2.0, 0.0)
    visible = @seq!=2 && @form1==1
  endparam
  complex param exp112
    caption = "Exponent 2"
    default = (0.0, 0.0)
    visible = @seq!=2 && @form1==1
  endparam
  complex param exp141           ; Phoenix
    caption = "Exponent 1"
    default = (2.0, 0.0)
    visible = @seq!=2 && @form1==4
  endparam
  complex param exp142
    caption = "Exponent 2"
    default = (0.0, 0.0)
    visible = @seq!=2 && @form1==4
  endparam
  complex param exp143
    caption = "Phoenix Exponent"
    default = (0.0, 0.0)
    visible = @seq!=2 && @form1==4
  endparam
  complex param exp161           ; Feigenbaum
    caption = "Exponent 1"
    default = (2.0, 0.0)
    visible = @seq!=2 && @form1==6
  endparam
  complex param exp171           ; Celtic
    caption = "Exponent 1"
    default = (2.0, 0.0)
    visible = @seq!=2 && @form1==7
  endparam
  complex param p11
    caption = "Phoenix Distortion"
    default = (0.5, 0.0)
    visible = @seq!=2 && @form1==1
  endparam
  complex param p12              ; Pop +
    caption = "Parameter 1"
    default = (0.0, 0.5)
    visible = @seq!=2 && @form1==2
  endparam
  complex param p13              ; PhoenixBarnsley
    caption = "Phoenix Distortion"
    default = (0.5, 0.0)
    visible = @seq!=2 && @form1==3
  endparam
  complex param p141              ; Simurgh
    caption = "Scale 1"
    default = (1.0, 0.0)
    visible = @seq!=2 && @form1==4
  endparam
  complex param p142
    caption = "Scale 2"
    default = (0.0, 0.0)
    visible = @seq!=2 && @form1==4
  endparam
  complex param p143
    caption = "Phoenix Distortion"
    default = (0.0, 0.0)
    visible = @seq!=2 && @form1==4
  endparam
  complex param p144
    caption = "Simurgh Distortion"
    default = (0.5, 0.0)
    visible = @seq!=2 && @form1==4
  endparam
  param m15                        ; Barnsley
    caption = "Barnsley Method"
    enum = "1" "2" "3" "4" "5"
    default = 0
    visible = @seq!=2 && @form1==5
  endparam
  float param t15
    caption = "Threshold"
    default = 0.0
    visible = @seq!=2 && @form1==5
  endparam
  complex param p151
    caption = "Parameter 1"
    default = (1.0, 0.0)
    visible = @seq!=2 && @form1==5
  endparam
  complex param p152
    caption = "Parameter 2"
    default = (1.0, 0.0)
    visible = @seq!=2 && @form1==5
  endparam
  complex param p153
    caption = "Parameter 3"
    default = (1.0, 0.0)
    visible = @seq!=2 && @form1==5 && @m15!=4
  endparam
  complex param p154
    caption = "Parameter 4"
    default = (1.0, 0.0)
    visible = @seq!=2 && @form1==5 && @m15!=4
  endparam
  complex param p155
    caption = "Parameter 5"
    default = (1.0, 0.0)
    visible = @seq!=2 && @form1==5 && @m15!=4
  endparam
  complex param p161               ;  Feigenbaum
    caption = "Parameter 1"
    default = (1.0, 0.0)
    visible = @seq!=2 && @form1==6
  endparam
  func fn11
    caption = "First Function"
    default = ident()
    visible = @seq!=2
  endfunc
  func fn12
    caption = "Second Function"
    default = ident()
    visible = @seq!=2 && (@form1==1  || \
                          @form1==3  || \
                          @form1==4  || \
                          @form1==5  || \
                          @form1==7)
  endfunc
   func fn13
     caption = "Third Function"
     default = ident()
     visible = @seq!=2 && (@form1==3  || \
                           @form1==4  || \
                           @form1==5)
   endfunc
   func fn14
     caption = "Fourth Function"
     default = ident()
     visible = @seq!=2 && (@form1==4 || \
                           (@form1==5 && @m15!=4))
   endfunc
   func fn15
     caption = "Fifth Function"
     default = ident()
     visible = @seq!=2 && (@form1==4 || \
                          (@form1==5 && @m15!=4))
   endfunc
   func fn16
     caption = "Sixth Function"
     default = ident()
     visible = @seq!=2 && (@form1==4)
   endfunc

   heading
     caption = "Scenario 2"
     visible = @seq!=1
   endheading

  param form2
    caption = "Formula Type"
    enum = "Mandelbrot"       \
           "Phoenix"          \
           "Population +"     \
           "PhoenixBarnsley"  \
           "Simurgh"          \
           "Barnsley Variants"\
           "Feigenbaum"       \
           "Celtic"
    default = 1
    visible = @seq!=1
  endparam
   param perturb2
     caption = "Perturbation"
     default = (0.0, 0.0)
     visible = @seq!=1 && (@form2==1 || \
                           @form2==3 || \
                           @form2==4)
   endparam
   complex param exp201         ; Mandelbrot
     caption = "Exponent 1"
     default = (2.0, 0.0)
     visible = @seq!=1 && @form2==0
   endparam
   complex param exp211        ; Phoenix
     caption = "Exponent 1"
     default = (2.0, 0.0)
     visible = @seq!=1 && @form2==1
   endparam
   complex param exp212
     caption = "Exponent 2"
     default = (0.0, 0.0)
     visible = @seq!=1 && @form2==1
   endparam
   complex param exp241           ; Phoenix
     caption = "Exponent 1"
     default = (2.0, 0.0)
     visible = @seq!=1 && @form2==4
   endparam
   complex param exp242
     caption = "Exponent 2"
     default = (0.0, 0.0)
     visible = @seq!=1 && @form2==4
   endparam
   complex param exp243
     caption = "Phoenix Exponent"
     default = (0.0, 0.0)
     visible = @seq!=1 && @form2==4
   endparam
   complex param exp261           ; Feigenbaum
     caption = "Exponent 1"
     default = (2.0, 0.0)
     visible = @seq!=1 && @form2==6
   endparam
  complex param exp271           ; Celtic
    caption = "Exponent 1"
    default = (2.0, 0.0)
    visible = @seq!=1 && @form2==7
  endparam
   complex param p21
     caption = "Phoenix Distortion"
     default = (0.5, 0.0)
     visible = @seq!=1 && @form2==1
   endparam
   complex param p22
     caption = "Parameter 1"        ; Pop +
     default = (0.5, 0.0)
     visible = @seq!=1 && @form2==2
   endparam
   complex param p23
     caption = "Phoenix Distortion" ; PhoenixBarnsley
     default = (0.5, 0.0)
     visible = @seq!=1 && @form2==3
   endparam
   complex param p241              ; Simurgh
     caption = "Scale 1"
     default = (1.0, 0.0)
     visible = @seq!=1 && @form2==4
   endparam
   complex param p242
     caption = "Scale 2"
     default = (0.0, 0.0)
     visible = @seq!=1 && @form2==4
   endparam
   complex param p243
     caption = "Phoenix Distortion"
     default = (0.0, 0.0)
     visible = @seq!=1 && @form2==4
   endparam
   complex param p244
     caption = "Simurgh Distortion"
     default = (0.5, 0.0)
     visible = @seq!=1 && @form2==4
   endparam
  param m25                        ; Barnsley
    caption = "Barnsley Method"
    enum = "1" "2" "3" "4" "5"
    default = 0
    visible = @seq!=1 && @form2==5
  endparam
  float param t25
    caption = "Threshold"
    default = 0.0
    visible = @seq!=1 && @form2==5
  endparam
  complex param p251
    caption = "Parameter 1"
    default = (1.0, 0.0)
    visible = @seq!=1 && @form2==5
  endparam
  complex param p252
    caption = "Parameter 2"
    default = (1.0, 0.0)
    visible = @seq!=1 && @form2==5
  endparam
  complex param p253
    caption = "Parameter 3"
    default = (1.0, 0.0)
    visible = @seq!=1 && @form2==5 && @m25!=4
  endparam
  complex param p254
    caption = "Parameter 4"
    default = (1.0, 0.0)
    visible = @seq!=1 && @form2==5 && @m25!=4
  endparam
  complex param p255
    caption = "Parameter 5"
    default = (1.0, 0.0)
    visible = @seq!=1 && @form2==5 && @m25!=4
  endparam
  complex param p261
    caption = "Parameter 1"
    default = (1.0, 0.0)
    visible = @seq!=1 && @form1==6
  endparam
   func fn21
     caption = "First Function"
     default = ident()
     visible = @seq!=1
   endfunc
   func fn22
     caption = "Second Function"
     default = ident()
     visible = @seq!=1 && (@form2==1 || \
                           @form2==3 || \
                           @form2==4 || \
                           @form2==5 || \
                           @form2==7 )
   endfunc
   func fn23
     caption = "Third Function"
     default = ident()
     visible = @seq!=1 && (@form2==3 || \
                           @form2==4 || \
                           @form2==5 )

   endfunc
   func fn24
     caption = "Fourth Function"
     default = ident()
     visible = @seq!=1 && (@form2==4 || \
                          (@form2==5 && @m25!=4))
   endfunc
   func fn25
     caption = "Fifth Function"
     default = ident()
     visible = @seq!=1 && (@form2==4 || \
                          (@form2==5 && @m25!=4))
   endfunc
   func fn26
     caption = "Sixth Function"
     default = ident()
     visible = @seq!=1 && (@form2==4)
   endfunc


  heading
    caption = "Slope Parameters"
  endheading
  bool param slope
    caption = "Apply slope?"
    default = true
    hint = "Use Lighting in dmj.ucl or one of the 3D Texturizer \
           formulas in reb.ucl with the slope applied. \
           Unset for a non-slope version registered with the\
           slope version.  Generally, unset 'Apply Slope? \
           for other formulas."
  endparam
  float param offset
    caption = "Orbit Separation"
    default = 0.001
    hint = "Defines how far apart the simultaneous orbits are.  Smaller \
            distances will produce more accurate results."
    visible = @slope==true
  endparam
  param zmode
    caption = "Height Value"
    default = 5
    enum = "smallest |z|" "smallest |real(z)|" \
           "smallest |imag(z)|" "smallest summ(z)" "smallest |atan(z)|" \
           "smoothed iteration"
    hint = "Specifies what will be used to construct a height value."
    visible = @slope==true
  endparam
  param xfer
    caption = "Height Transfer"
    default = 0
    enum = "linear" "log" "sqrt" "cuberoot" "exp" "sqr" "cube" "sin" "cos" "tan"
    hint = "This function will be applied to the height value \
            before a slope is calculated."
    visible = @slope==true
  endparam
  param zscale
    caption = "Height Pre-Scale"
    default = 1.0
    hint = "Specifies the ratio between height and distance.  Higher \
            values will exaggerate differences between high and low. \
            In general, you will want to use smaller numbers here."
    visible = @slope==true
  endparam
  param zscale2
    caption = "Height Post-Scale"
    default = 1.0
    hint = "Specifies the ratio between height and distance; like \
            Height Pre-Scale, except that this value is applied after \
            the transfer function."
    visible = @slope==true
  endparam
  param everyiter
    caption = "Every Iteration"
    default = true
    hint = "If set, the surface normal will be computed at every \
            iteration.  If you are using a coloring algorithm which \
            processes every iteration, you will need this."
    visible = @slope==true
  endparam

}

sdc-slope-hypercomplex-dynamic {
; June, 2006 -- Gilles added Loop type 3, which produces
; a Barnsleyish effect.
;
; June, 2005 -- Gilles Nadeau pointed out to me that the hypercomplex
; version of embrangle is within a sign (and some settings)
; of being the formula for popcorn julia...
; I have made adjustments...
;
; This version of the Embrangle formula is truly a
; collaborative effort..it just happens to reside
; in my folder.
;
; Slope stuff by Ron Barnett
;
; adapted from Davka's 3 function TDDS2
; I have been mostly interested in the Julia form
;
init:
  ;default to Mandelbrot
   complex c1 = #pixel
   complex c2 = c1 + @offset
   complex c3 = c1 + flip(@offset)
   complex z1 = ( 0.0, 0.0 )
   complex z2 = z1
   complex z3 = z1
   complex dd1 = @cjk
   complex dd2 = dd1
   complex dd3 = dd1
   complex w1 = ( 0.0, 0.0 )
   complex w2 = ( 0.0, 0.0 )
   complex w3 = ( 0.0, 0.0 )
   if( @loop == "2" )
     z1 = ( 0.0, 0.0 ) + c1
     z2 = ( 0.0, 0.0 ) + c2
     z3 = ( 0.0, 0.0 ) + c3
     w1 = ( 0.0, 0.0 ) + dd1
     w2 = ( 0.0, 0.0 ) + dd2
     w3 = ( 0.0, 0.0 ) + dd3
   endif
   if( @mode == "Julia" )
     z1 = #pixel
     z2 = z1 + @offset
     z3 = z1 + flip(@offset)
     c1 = @startseed
     c2 = c1
     c3 = c1
     w1 = @zjk
     w2 = @zjk
     w3 = @zjk
     dd1 = @cjk
     dd2 = dd1
     dd3 = dd1
   endif
   complex a1 = ( 0.0, 0.0 )
   complex b1 = ( 0.0, 0.0 )
   complex hc1 = ( 0.0, 0.0 )
   complex hc2 = ( 0.0, 0.0 )
   complex hc3 = ( 0.0, 0.0 )
   complex hd1 = ( 0.0, 0.0 )
   complex hd2 = ( 0.0, 0.0 )
   complex hd3 = ( 0.0, 0.0 )
   int   iter=0
   int   seed = random(@randomseed)

   ;;; slope stuff
   int done = 2
   float e1 = 0.0; potentials
   float e2 = 0.0
   float e3 = 0.0
   float vx = 0.0; normal vector
   float vy = 0.0
   float vz = 0.0
   float vd = 0.0
   float d1 = 0.0; distances
   float d2 = 0.0
   float d3 = 0.0
   float s1 = 1.0e20; smallest distances
   float s2 = 1.0e20
   float s3 = 1.0e20
   float iterexp1 = 0.0
   float iterexp2 = 0.0
   float iterexp3 = 0.0

loop:
  complex cc11 = real(c1) - imag(dd1) + flip(imag(c1) + real(dd1))
  complex cc12 = real(c2) - imag(dd2) + flip(imag(c2) + real(dd2))
  complex cc13 = real(c3) - imag(dd3) + flip(imag(c3) + real(dd3))
  complex cc21 = real(c1) + imag(dd1) + flip(imag(c1) - real(dd1))
  complex cc22 = real(c2) + imag(dd2) + flip(imag(c2) - real(dd2))
  complex cc23 = real(c3) + imag(dd3) + flip(imag(c3) - real(dd3))
  float xa1 = real( z1 ) - imag( w1 )
  float xa2 = real( z2 ) - imag( w2 )
  float xa3 = real( z3 ) - imag( w3 )
  float ya1 = imag( z1 ) + real( w1 )
  float ya2 = imag( z2 ) + real( w2 )
  float ya3 = imag( z3 ) + real( w3 )
  float xb1 = real( z1 ) + imag( w1 )
  float xb2 = real( z2 ) + imag( w2 )
  float xb3 = real( z3 ) + imag( w3 )
  float yb1 = imag( z1 ) - real( w1 )
  float yb2 = imag( z2 ) - real( w2 )
  float yb3 = imag( z3 ) - real( w3 )
  float oldxa1 = xa1
  float oldxa2 = xa2
  float oldxa3 = xa3
  float oldya1 = ya1
  float oldya2 = ya2
  float oldya3 = ya3
  float oldxb1 = xb1
  float oldxb2 = xb2
  float oldxb3 = xb3
  float oldyb1 = yb1
  float oldyb2 = yb2
  float oldyb3 = yb3
  float xxa1 = 0
  float xxa2 = 0
  float xxa3 = 0
  float yya1 = 0
  float yya2 = 0
  float yya3 = 0
  float xxb1 = 0
  float xxb2 = 0
  float xxb3 = 0
  float yyb1 = 0
  float yyb2 = 0
  float yyb3 = 0
  bool  formula1 = false

  iter = iter + 1
  ; Determine formula to be used:
  if (@version > 0.9)
    if ( @seq == 1 )                  ; First Formula
      formula1 = true
    elseif ( @seq == 2 )              ; Second Formula
      formula1 = false
    elseif ( @seq==0 )
      if (iter%@modBy < @modCmp ); Modulation
        formula1 = true
      endif
      if (@invertMod == true)
        formula1 = !formula1
      endif
    elseif ( @seq==3 )
      seed = random(seed)
      if ( abs(seed)/#randomrange < @prob1 )
        formula1 = true
      endif
      if (@invertMod == true)
        formula1 = !formula1
      endif
    else
      formula1 = false
    endif
  else
    if ( @seq == 1 )                  ; First Formula
      formula1 = true
    elseif ( @seq == 2 )              ; Second Formula
      formula1 = false
    elseif ( iter % @modBy < @modCmp ); Modulation
      formula1 = true
    endif
  endif


  if (formula1 == true)
      xxa1 = @multiplier1 * \
              @ampA1 * real(@fcnA1(@freqA1 * oldya1 + \
              @ampB1 * real(@fcnB1(@freqB1 * oldya1 + \
              @ampC1 * real(@fcnC1(@freqC1 * oldya1 + \
              @ampD1 * real(@fcnD1(@freqD1 * oldya1 ))))))))
      yya1 = @multiplier1 * \
              @ampE1 * real(@fcnE1(@freqE1 * oldxa1 + \
              @ampF1 * real(@fcnF1(@freqF1 * oldxa1 + \
              @ampG1 * real(@fcnG1(@freqG1 * oldxa1 + \
              @ampH1 * real(@fcnH1(@freqH1 * oldxa1 ))))))))
      xxb1 = @multiplier1 * \
              @ampA1 * real(@fcnA1(@freqA1 * oldyb1 + \
              @ampB1 * real(@fcnB1(@freqB1 * oldyb1 + \
              @ampC1 * real(@fcnC1(@freqC1 * oldyb1 + \
              @ampD1 * real(@fcnD1(@freqD1 * oldyb1 ))))))))
      yyb1 = @multiplier1 * \
              @ampE1 * real(@fcnE1(@freqE1 * oldxb1 + \
              @ampF1 * real(@fcnF1(@freqF1 * oldxb1 + \
              @ampG1 * real(@fcnG1(@freqG1 * oldxb1 + \
              @ampH1 * real(@fcnH1(@freqH1 * oldxb1 ))))))))

      if (@slope)
        xxa2 = @multiplier1 * \
                @ampA1 * real(@fcnA1(@freqA1 * oldya2 + \
                @ampB1 * real(@fcnB1(@freqB1 * oldya2 + \
                @ampC1 * real(@fcnC1(@freqC1 * oldya2 + \
                @ampD1 * real(@fcnD1(@freqD1 * oldya2 ))))))))
        yya2 = @multiplier1 * \
                @ampE1 * real(@fcnE1(@freqE1 * oldxa2 + \
                @ampF1 * real(@fcnF1(@freqF1 * oldxa2 + \
                @ampG1 * real(@fcnG1(@freqG1 * oldxa2 + \
                @ampH1 * real(@fcnH1(@freqH1 * oldxa2 ))))))))
        xxb2 = @multiplier1 * \
                @ampA1 * real(@fcnA1(@freqA1 * oldyb2 + \
                @ampB1 * real(@fcnB1(@freqB1 * oldyb2 + \
                @ampC1 * real(@fcnC1(@freqC1 * oldyb2 + \
                @ampD1 * real(@fcnD1(@freqD1 * oldyb2 ))))))))
        yyb2 = @multiplier1 * \
                @ampE1 * real(@fcnE1(@freqE1 * oldxb2 + \
                @ampF1 * real(@fcnF1(@freqF1 * oldxb2 + \
                @ampG1 * real(@fcnG1(@freqG1 * oldxb2 + \
                @ampH1 * real(@fcnH1(@freqH1 * oldxb2 ))))))))

        xxa3 = @multiplier1 * \
                @ampA1 * real(@fcnA1(@freqA1 * oldya3 + \
                @ampB1 * real(@fcnB1(@freqB1 * oldya3 + \
                @ampC1 * real(@fcnC1(@freqC1 * oldya3 + \
                @ampD1 * real(@fcnD1(@freqD1 * oldya3 ))))))))
        yya3 = @multiplier1 * \
                @ampE1 * real(@fcnE1(@freqE1 * oldxa3 + \
                @ampF1 * real(@fcnF1(@freqF1 * oldxa3 + \
                @ampG1 * real(@fcnG1(@freqG1 * oldxa3 + \
                @ampH1 * real(@fcnH1(@freqH1 * oldxa3 ))))))))
        xxb3 = @multiplier1 * \
                @ampA1 * real(@fcnA1(@freqA1 * oldyb3 + \
                @ampB1 * real(@fcnB1(@freqB1 * oldyb3 + \
                @ampC1 * real(@fcnC1(@freqC1 * oldyb3 + \
                @ampD1 * real(@fcnD1(@freqD1 * oldyb3 ))))))))
        yyb3 = @multiplier1 * \
                @ampE1 * real(@fcnE1(@freqE1 * oldxb3 + \
                @ampF1 * real(@fcnF1(@freqF1 * oldxb3 + \
                @ampG1 * real(@fcnG1(@freqG1 * oldxb3 + \
                @ampH1 * real(@fcnH1(@freqH1 * oldxb3 ))))))))
     endif
     if (@op1 == 0)        ;;;  "---- (Popcorn)"
       xa1 = oldxa1 - xxa1
       ya1 = oldya1 - yya1
       xb1 = oldxb1 - xxb1
       yb1 = oldyb1 - yyb1
     elseif (@op1 == 1)    ;;;  "+-+- (Emb1rangle) "
       xa1 = oldxa1 + xxa1
       ya1 = oldya1 - yya1
       xb1 = oldxb1 + xxb1
       yb1 = oldyb1 - yyb1
     elseif (@op1 == 2)               ;;;  "-+-+"
       xa1 = oldxa1 - xxa1
       ya1 = oldya1 + yya1
       xb1 = oldxb1 - xxb1
       yb1 = oldyb1 + yyb1
     elseif (@op1 == 3)               ;;;  "++++"
       xa1 = oldxa1 + xxa1
       ya1 = oldya1 + yya1
       xb1 = oldxb1 + xxb1
       yb1 = oldyb1 + yyb1
     elseif (@op1 == 4)               ;;;  "-+++"
       xa1 = oldxa1 - xxa1
       ya1 = oldya1 + yya1
       xb1 = oldxb1 + xxb1
       yb1 = oldyb1 + yyb1
     elseif (@op1 == 5)               ;;;  "--++"
       xa1 = oldxa1 - xxa1
       ya1 = oldya1 - yya1
       xb1 = oldxb1 + xxb1
       yb1 = oldyb1 + yyb1
     elseif (@op1 == 6)               ;;;  "---+"
       xa1 = oldxa1 - xxa1
       ya1 = oldya1 - yya1
       xb1 = oldxb1 - xxb1
       yb1 = oldyb1 + yyb1
     elseif (@op1 == 7)               ;;;  "+---"
       xa1 = oldxa1 + xxa1
       ya1 = oldya1 - yya1
       xb1 = oldxb1 - xxb1
       yb1 = oldyb1 - yyb1
     elseif (@op1 == 8)               ;;;  "++--"
       xa1 = oldxa1 + xxa1
       ya1 = oldya1 + yya1
       xb1 = oldxb1 - xxb1
       yb1 = oldyb1 - yyb1
     elseif (@op1 == 9)               ;;;  "+++-"
       xa1 = oldxa1 + xxa1
       ya1 = oldya1 + yya1
       xb1 = oldxb1 + xxb1
       yb1 = oldyb1 - yyb1
     elseif (@op1 == 10)              ;;;  "-++-"
       xa1 = oldxa1 - xxa1
       ya1 = oldya1 + yya1
       xb1 = oldxb1 + xxb1
       yb1 = oldyb1 - yyb1
     elseif (@op1 == 11)              ;;;  "+--+"
       xa1 = oldxa1 + xxa1
       ya1 = oldya1 - yya1
       xb1 = oldxb1 - xxb1
       yb1 = oldyb1 + yyb1
     elseif (@op1 == 12)              ;;;  "+-++"
       xa1 = oldxa1 + xxa1
       ya1 = oldya1 - yya1
       xb1 = oldxb1 + xxb1
       yb1 = oldyb1 + yyb1
     elseif (@op1 == 13)              ;;;  "++-+"
       xa1 = oldxa1 + xxa1
       ya1 = oldya1 + yya1
       xb1 = oldxb1 - xxb1
       yb1 = oldyb1 + yyb1
     elseif (@op1 == 14)              ;;;  "-+--"
       xa1 = oldxa1 - xxa1
       ya1 = oldya1 + yya1
       xb1 = oldxb1 - xxb1
       yb1 = oldyb1 - yyb1
     elseif (@op1 == 15)              ;;;  "--+-"
       xa1 = oldxa1 - xxa1
       ya1 = oldya1 - yya1
       xb1 = oldxb1 + xxb1
       yb1 = oldyb1 - yyb1
     endif
     if (@slope)
       if (@op1 == 0)        ;;;  "---- (Popcorn)"
         xa2 = oldxa2 - xxa2
         ya2 = oldya2 - yya2
         xb2 = oldxb2 - xxb2
         yb2 = oldyb2 - yyb2
         xa3 = oldxa3 - xxa3
         ya3 = oldya3 - yya3
         xb3 = oldxb3 - xxb3
         yb3 = oldyb3 - yyb3
       elseif (@op1 == 1)    ;;;  "+-+- (Embrangle) "
         xa2 = oldxa2 + xxa2
         ya2 = oldya2 - yya2
         xb2 = oldxb2 + xxb2
         yb2 = oldyb2 - yyb2
         xa3 = oldxa3 + xxa3
         ya3 = oldya3 - yya3
         xb3 = oldxb3 + xxb3
         yb3 = oldyb3 - yyb3
       elseif (@op1 == 2)               ;;;  "-+-+"
         xa2 = oldxa2 - xxa2
         ya2 = oldya2 + yya2
         xb2 = oldxb2 - xxb2
         yb2 = oldyb2 + yyb2
         xa3 = oldxa3 - xxa3
         ya3 = oldya3 + yya3
         xb3 = oldxb3 - xxb3
         yb3 = oldyb3 + yyb3
       elseif (@op1 == 3)               ;;;  "++++"
         xa2 = oldxa2 + xxa2
         ya2 = oldya2 + yya2
         xb2 = oldxb2 + xxb2
         yb2 = oldyb2 + yyb2
         xa3 = oldxa3 + xxa3
         ya3 = oldya3 + yya3
         xb3 = oldxb3 + xxb3
         yb3 = oldyb3 + yyb3
       elseif (@op1 == 4)               ;;;  "-+++"
         xa2 = oldxa2 - xxa2
         ya2 = oldya2 + yya2
         xb2 = oldxb2 + xxb2
         yb2 = oldyb2 + yyb2
         xa3 = oldxa3 - xxa3
         ya3 = oldya3 + yya3
         xb3 = oldxb3 + xxb3
         yb3 = oldyb3 + yyb3
       elseif (@op1 == 5)               ;;;  "--++"
         xa2 = oldxa2 - xxa2
         ya2 = oldya2 - yya2
         xb2 = oldxb2 + xxb2
         yb2 = oldyb2 + yyb2
         xa3 = oldxa3 - xxa3
         ya3 = oldya3 - yya3
         xb3 = oldxb3 + xxb3
         yb3 = oldyb3 + yyb3
       elseif (@op1 == 6)               ;;;  "---+"
         xa2 = oldxa2 - xxa2
         ya2 = oldya2 - yya2
         xb2 = oldxb2 - xxb2
         yb2 = oldyb2 + yyb2
         xa3 = oldxa3 - xxa3
         ya3 = oldya3 - yya3
         xb3 = oldxb3 - xxb3
         yb3 = oldyb3 + yyb3
       elseif (@op1 == 7)               ;;;  "+---"
         xa2 = oldxa2 + xxa2
         ya2 = oldya2 - yya2
         xb2 = oldxb2 - xxb2
         yb2 = oldyb2 - yyb2
         xa3 = oldxa3 + xxa3
         ya3 = oldya3 - yya3
         xb3 = oldxb3 - xxb3
         yb3 = oldyb3 - yyb3
       elseif (@op1 == 8)               ;;;  "++--"
         xa2 = oldxa2 + xxa2
         ya2 = oldya2 + yya2
         xb2 = oldxb2 - xxb2
         yb2 = oldyb2 - yyb2
         xa3 = oldxa3 + xxa3
         ya3 = oldya3 + yya3
         xb3 = oldxb3 - xxb3
         yb3 = oldyb3 - yyb3
       elseif (@op1 == 9)               ;;;  "+++-"
         xa2 = oldxa2 + xxa2
         ya2 = oldya2 + yya2
         xb2 = oldxb2 + xxb2
         yb2 = oldyb2 - yyb2
         xa3 = oldxa3 + xxa3
         ya3 = oldya3 + yya3
         xb3 = oldxb3 + xxb3
         yb3 = oldyb3 - yyb3
       elseif (@op1 == 10)              ;;;  "-++-"
         xa2 = oldxa2 - xxa2
         ya2 = oldya2 + yya2
         xb2 = oldxb2 + xxb2
         yb2 = oldyb2 - yyb2
         xa3 = oldxa3 - xxa3
         ya3 = oldya3 + yya3
         xb3 = oldxb3 + xxb3
         yb3 = oldyb3 - yyb3
       elseif (@op1 == 11)              ;;;  "+--+"
         xa3 = oldxa2 + xxa2
         ya2 = oldya2 - yya2
         xb2 = oldxb2 - xxb2
         yb2 = oldyb2 + yyb2
         xa3 = oldxa3 + xxa3
         ya3 = oldya3 - yya3
         xb3 = oldxb3 - xxb3
         yb3 = oldyb3 + yyb3
       elseif (@op1 == 12)              ;;;  "+-++"
         xa2 = oldxa2 + xxa2
         ya2 = oldya2 - yya2
         xb2 = oldxb2 + xxb2
         yb2 = oldyb2 + yyb2
         xa3 = oldxa3 + xxa3
         ya3 = oldya3 - yya3
         xb3 = oldxb3 + xxb3
         yb3 = oldyb3 + yyb3
       elseif (@op1 == 13)              ;;;  "++-+"
         xa2 = oldxa2 + xxa2
         ya2 = oldya2 + yya2
         xb2 = oldxb2 - xxb2
         yb2 = oldyb2 + yyb2
         xa3 = oldxa3 + xxa3
         ya3 = oldya3 + yya3
         xb3 = oldxb3 - xxb3
         yb3 = oldyb3 + yyb3
       elseif (@op1 == 14)              ;;;  "-+--"
         xa2 = oldxa2 - xxa2
         ya2 = oldya2 + yya2
         xb2 = oldxb2 - xxb2
         yb2 = oldyb2 - yyb2
         xa3 = oldxa3 - xxa3
         ya3 = oldya3 + yya3
         xb3 = oldxb3 - xxb3
         yb3 = oldyb3 - yyb3
       elseif (@op1 == 15)              ;;;  "--+-"
         xa2 = oldxa2 - xxa2
         ya2 = oldya2 - yya2
         xb2 = oldxb2 + xxb2
         yb2 = oldyb2 - yyb2
         xa3 = oldxa3 - xxa3
         ya3 = oldya3 - yya3
         xb3 = oldxb3 + xxb3
         yb3 = oldyb3 - yyb3
       endif
     endif
  else ;;;;;;formula 2
      xxa1 = @multiplier2 * \
              @ampA2 * real(@fcnA2(@freqA2 * oldya1 + \
              @ampB2 * real(@fcnB2(@freqB2 * oldya1 + \
              @ampC2 * real(@fcnC2(@freqC2 * oldya1 + \
              @ampD2 * real(@fcnD2(@freqD2 * oldya1 ))))))))

      yya1 = @multiplier2 * \
              @ampE2 * real(@fcnE2(@freqE2 * oldxa1 + \
              @ampF2 * real(@fcnF2(@freqF2 * oldxa1 + \
              @ampG2 * real(@fcnG2(@freqG2 * oldxa1 + \
              @ampH2 * real(@fcnH2(@freqH2 * oldxa1 ))))))))

      xxb1 = @multiplier2 * \
              @ampA2 * real(@fcnA2(@freqA2 * oldyb1 + \
              @ampB2 * real(@fcnB2(@freqB2 * oldyb1 + \
              @ampC2 * real(@fcnC2(@freqC2 * oldyb1 + \
              @ampD2 * real(@fcnD2(@freqD2 * oldyb1 ))))))))

      yyb1 = @multiplier2 * \
              @ampE2 * real(@fcnE2(@freqE2 * oldxb1 + \
              @ampF2 * real(@fcnF2(@freqF2 * oldxb1 + \
              @ampG2 * real(@fcnG2(@freqG2 * oldxb1 + \
              @ampH2 * real(@fcnH2(@freqH2 * oldxb1 ))))))))
      if (@slope)
        xxa2 = @multiplier2 * \
                @ampA2 * real(@fcnA2(@freqA2 * oldya2 + \
                @ampB2 * real(@fcnB2(@freqB2 * oldya2 + \
                @ampC2 * real(@fcnC2(@freqC2 * oldya2 + \
                @ampD2 * real(@fcnD2(@freqD2 * oldya2 ))))))))
        yya2 = @multiplier2 * \
                @ampE2 * real(@fcnE2(@freqE2 * oldxa2 + \
                @ampF2 * real(@fcnF2(@freqF2 * oldxa2 + \
                @ampG2 * real(@fcnG2(@freqG2 * oldxa2 + \
                @ampH2 * real(@fcnH2(@freqH2 * oldxa2 ))))))))
        xxb2 = @multiplier2 * \
                @ampA2 * real(@fcnA2(@freqA2 * oldyb2 + \
                @ampB2 * real(@fcnB2(@freqB2 * oldyb2 + \
                @ampC2 * real(@fcnC2(@freqC2 * oldyb2 + \
                @ampD2 * real(@fcnD2(@freqD2 * oldyb2 ))))))))
        yyb2 = @multiplier2 * \
                @ampE2 * real(@fcnE2(@freqE2 * oldxb2 + \
                @ampF2 * real(@fcnF2(@freqF2 * oldxb2 + \
                @ampG2 * real(@fcnG2(@freqG2 * oldxb2 + \
                @ampH2 * real(@fcnH2(@freqH2 * oldxb2 ))))))))

        xxa3 = @multiplier2 * \
                @ampA2 * real(@fcnA2(@freqA2 * oldya3 + \
                @ampB2 * real(@fcnB2(@freqB2 * oldya3 + \
                @ampC2 * real(@fcnC2(@freqC2 * oldya3 + \
                @ampD2 * real(@fcnD2(@freqD2 * oldya3 ))))))))
        yya3 = @multiplier2 * \
                @ampE2 * real(@fcnE2(@freqE2 * oldxa3 + \
                @ampF2 * real(@fcnF2(@freqF2 * oldxa3 + \
                @ampG2 * real(@fcnG2(@freqG2 * oldxa3 + \
                @ampH2 * real(@fcnH2(@freqH2 * oldxa3 ))))))))
        xxb3 = @multiplier2 * \
                @ampA2 * real(@fcnA2(@freqA2 * oldyb3 + \
                @ampB2 * real(@fcnB2(@freqB2 * oldyb3 + \
                @ampC2 * real(@fcnC2(@freqC2 * oldyb3 + \
                @ampD2 * real(@fcnD2(@freqD2 * oldyb3 ))))))))
        yyb3 = @multiplier2 * \
                @ampE2 * real(@fcnE2(@freqE2 * oldxb3 + \
                @ampF2 * real(@fcnF2(@freqF2 * oldxb3 + \
                @ampG2 * real(@fcnG2(@freqG2 * oldxb3 + \
                @ampH2 * real(@fcnH2(@freqH2 * oldxb3 ))))))))
     endif
     if (@op2 == 0)        ;;;  "---- (Popcorn)"
       xa1 = oldxa1 - xxa1
       ya1 = oldya1 - yya1
       xb1 = oldxb1 - xxb1
       yb1 = oldyb1 - yyb1
     elseif (@op2 == 1)    ;;;  "+-+- (Emb1rangle) "
       xa1 = oldxa1 + xxa1
       ya1 = oldya1 - yya1
       xb1 = oldxb1 + xxb1
       yb1 = oldyb1 - yyb1
     elseif (@op2 == 2)               ;;;  "-+-+"
       xa1 = oldxa1 - xxa1
       ya1 = oldya1 + yya1
       xb1 = oldxb1 - xxb1
       yb1 = oldyb1 + yyb1
     elseif (@op2 == 3)               ;;;  "++++"
       xa1 = oldxa1 + xxa1
       ya1 = oldya1 + yya1
       xb1 = oldxb1 + xxb1
       yb1 = oldyb1 + yyb1
     elseif (@op2 == 4)               ;;;  "-+++"
       xa1 = oldxa1 - xxa1
       ya1 = oldya1 + yya1
       xb1 = oldxb1 + xxb1
       yb1 = oldyb1 + yyb1
     elseif (@op2 == 5)               ;;;  "--++"
       xa1 = oldxa1 - xxa1
       ya1 = oldya1 - yya1
       xb1 = oldxb1 + xxb1
       yb1 = oldyb1 + yyb1
     elseif (@op2 == 6)               ;;;  "---+"
       xa1 = oldxa1 - xxa1
       ya1 = oldya1 - yya1
       xb1 = oldxb1 - xxb1
       yb1 = oldyb1 + yyb1
     elseif (@op2 == 7)               ;;;  "+---"
       xa1 = oldxa1 + xxa1
       ya1 = oldya1 - yya1
       xb1 = oldxb1 - xxb1
       yb1 = oldyb1 - yyb1
     elseif (@op2 == 8)               ;;;  "++--"
       xa1 = oldxa1 + xxa1
       ya1 = oldya1 + yya1
       xb1 = oldxb1 - xxb1
       yb1 = oldyb1 - yyb1
     elseif (@op2 == 9)               ;;;  "+++-"
       xa1 = oldxa1 + xxa1
       ya1 = oldya1 + yya1
       xb1 = oldxb1 + xxb1
       yb1 = oldyb1 - yyb1
     elseif (@op2 == 10)              ;;;  "-++-"
       xa1 = oldxa1 - xxa1
       ya1 = oldya1 + yya1
       xb1 = oldxb1 + xxb1
       yb1 = oldyb1 - yyb1
     elseif (@op2 == 11)              ;;;  "+--+"
       xa1 = oldxa1 + xxa1
       ya1 = oldya1 - yya1
       xb1 = oldxb1 - xxb1
       yb1 = oldyb1 + yyb1
     elseif (@op2 == 12)              ;;;  "+-++"
       xa1 = oldxa1 + xxa1
       ya1 = oldya1 - yya1
       xb1 = oldxb1 + xxb1
       yb1 = oldyb1 + yyb1
     elseif (@op2 == 13)              ;;;  "++-+"
       xa1 = oldxa1 + xxa1
       ya1 = oldya1 + yya1
       xb1 = oldxb1 - xxb1
       yb1 = oldyb1 + yyb1
     elseif (@op2 == 14)              ;;;  "-+--"
       xa1 = oldxa1 - xxa1
       ya1 = oldya1 + yya1
       xb1 = oldxb1 - xxb1
       yb1 = oldyb1 - yyb1
     elseif (@op2 == 15)              ;;;  "--+-"
       xa1 = oldxa1 - xxa1
       ya1 = oldya1 - yya1
       xb1 = oldxb1 + xxb1
       yb1 = oldyb1 - yyb1
     endif
     if (@slope)
       if (@op2 == 0)        ;;;  "---- (Popcorn)"
         xa2 = oldxa2 - xxa2
         ya2 = oldya2 - yya2
         xb2 = oldxb2 - xxb2
         yb2 = oldyb2 - yyb2
         xa3 = oldxa3 - xxa3
         ya3 = oldya3 - yya3
         xb3 = oldxb3 - xxb3
         yb3 = oldyb3 - yyb3
       elseif (@op2 == 1)    ;;;  "+-+- (Embrangle) "
         xa2 = oldxa2 + xxa2
         ya2 = oldya2 - yya2
         xb2 = oldxb2 + xxb2
         yb2 = oldyb2 - yyb2
         xa3 = oldxa3 + xxa3
         ya3 = oldya3 - yya3
         xb3 = oldxb3 + xxb3
         yb3 = oldyb3 - yyb3
       elseif (@op2 == 2)               ;;;  "-+-+"
         xa2 = oldxa2 - xxa2
         ya2 = oldya2 + yya2
         xb2 = oldxb2 - xxb2
         yb2 = oldyb2 + yyb2
         xa3 = oldxa3 - xxa3
         ya3 = oldya3 + yya3
         xb3 = oldxb3 - xxb3
         yb3 = oldyb3 + yyb3
       elseif (@op2 == 3)               ;;;  "++++"
         xa2 = oldxa2 + xxa2
         ya2 = oldya2 + yya2
         xb2 = oldxb2 + xxb2
         yb2 = oldyb2 + yyb2
         xa3 = oldxa3 + xxa3
         ya3 = oldya3 + yya3
         xb3 = oldxb3 + xxb3
         yb3 = oldyb3 + yyb3
       elseif (@op2 == 4)               ;;;  "-+++"
         xa2 = oldxa2 - xxa2
         ya2 = oldya2 + yya2
         xb2 = oldxb2 + xxb2
         yb2 = oldyb2 + yyb2
         xa3 = oldxa3 - xxa3
         ya3 = oldya3 + yya3
         xb3 = oldxb3 + xxb3
         yb3 = oldyb3 + yyb3
       elseif (@op2 == 5)               ;;;  "--++"
         xa2 = oldxa2 - xxa2
         ya2 = oldya2 - yya2
         xb2 = oldxb2 + xxb2
         yb2 = oldyb2 + yyb2
         xa3 = oldxa3 - xxa3
         ya3 = oldya3 - yya3
         xb3 = oldxb3 + xxb3
         yb3 = oldyb3 + yyb3
       elseif (@op2 == 6)               ;;;  "---+"
         xa2 = oldxa2 - xxa2
         ya2 = oldya2 - yya2
         xb2 = oldxb2 - xxb2
         yb2 = oldyb2 + yyb2
         xa3 = oldxa3 - xxa3
         ya3 = oldya3 - yya3
         xb3 = oldxb3 - xxb3
         yb3 = oldyb3 + yyb3
       elseif (@op2 == 7)               ;;;  "+---"
         xa2 = oldxa2 + xxa2
         ya2 = oldya2 - yya2
         xb2 = oldxb2 - xxb2
         yb2 = oldyb2 - yyb2
         xa3 = oldxa3 + xxa3
         ya3 = oldya3 - yya3
         xb3 = oldxb3 - xxb3
         yb3 = oldyb3 - yyb3
       elseif (@op2 == 8)               ;;;  "++--"
         xa2 = oldxa2 + xxa2
         ya2 = oldya2 + yya2
         xb2 = oldxb2 - xxb2
         yb2 = oldyb2 - yyb2
         xa3 = oldxa3 + xxa3
         ya3 = oldya3 + yya3
         xb3 = oldxb3 - xxb3
         yb3 = oldyb3 - yyb3
       elseif (@op2 == 9)               ;;;  "+++-"
         xa2 = oldxa2 + xxa2
         ya2 = oldya2 + yya2
         xb2 = oldxb2 + xxb2
         yb2 = oldyb2 - yyb2
         xa3 = oldxa3 + xxa3
         ya3 = oldya3 + yya3
         xb3 = oldxb3 + xxb3
         yb3 = oldyb3 - yyb3
       elseif (@op2 == 10)              ;;;  "-++-"
         xa2 = oldxa2 - xxa2
         ya2 = oldya2 + yya2
         xb2 = oldxb2 + xxb2
         yb2 = oldyb2 - yyb2
         xa3 = oldxa3 - xxa3
         ya3 = oldya3 + yya3
         xb3 = oldxb3 + xxb3
         yb3 = oldyb3 - yyb3
       elseif (@op2 == 11)              ;;;  "+--+"
         xa3 = oldxa2 + xxa2
         ya2 = oldya2 - yya2
         xb2 = oldxb2 - xxb2
         yb2 = oldyb2 + yyb2
         xa3 = oldxa3 + xxa3
         ya3 = oldya3 - yya3
         xb3 = oldxb3 - xxb3
         yb3 = oldyb3 + yyb3
       elseif (@op2 == 12)              ;;;  "+-++"
         xa2 = oldxa2 + xxa2
         ya2 = oldya2 - yya2
         xb2 = oldxb2 + xxb2
         yb2 = oldyb2 + yyb2
         xa3 = oldxa3 + xxa3
         ya3 = oldya3 - yya3
         xb3 = oldxb3 + xxb3
         yb3 = oldyb3 + yyb3
       elseif (@op2 == 13)              ;;;  "++-+"
         xa2 = oldxa2 + xxa2
         ya2 = oldya2 + yya2
         xb2 = oldxb2 - xxb2
         yb2 = oldyb2 + yyb2
         xa3 = oldxa3 + xxa3
         ya3 = oldya3 + yya3
         xb3 = oldxb3 - xxb3
         yb3 = oldyb3 + yyb3
       elseif (@op2 == 14)              ;;;  "-+--"
         xa2 = oldxa2 - xxa2
         ya2 = oldya2 + yya2
         xb2 = oldxb2 - xxb2
         yb2 = oldyb2 - yyb2
         xa3 = oldxa3 - xxa3
         ya3 = oldya3 + yya3
         xb3 = oldxb3 - xxb3
         yb3 = oldyb3 - yyb3
       elseif (@op2 == 15)              ;;;  "--+-"
         xa2 = oldxa2 - xxa2
         ya2 = oldya2 - yya2
         xb2 = oldxb2 + xxb2
         yb2 = oldyb2 - yyb2
         xa3 = oldxa3 - xxa3
         ya3 = oldya3 - yya3
         xb3 = oldxb3 + xxb3
         yb3 = oldyb3 - yyb3
       endif
     endif
  endif


  a1 = xa1 + flip(ya1)
  b1 = xb1 + flip(yb1)

  if @loop == "1"
    hc1 = @hfn(a1) + cc11
    hd1 = @hfn(b1) + cc21
  elseif @loop == "2"
    hc1 = @hfn(a1) * cc11
    hd1 = @hfn(b1) * cc21
  elseif @loop == "3 - Barnsleyish"
    hc1 = @hfn(sqrt(sqr(a1))) * cc11  - cc11
    hd1 = @hfn(sqrt(sqr(b1))) * cc21  - cc21
  endif
  z1 = (real(hc1) + real(hd1) + flip(imag(hc1) + imag(hd1))) / 2
  w1 = (imag(hc1) - imag(hd1) + flip(real(hd1) - real(hc1))) / 2

  if (@slope == true)
    a2 = xa2 + flip(ya2)
    b2 = xb2 + flip(yb2)
    a3 = xa3 + flip(ya3)
    b3 = xb3 + flip(yb3)

    if @loop == "1"
      hc2 = @hfn(a2) + cc12
      hd2 = @hfn(b2) + cc22
      hc3 = @hfn(a3) + cc13
      hd3 = @hfn(b3) + cc23
    elseif @loop == "2"
      hc2 = @hfn(a2) * cc12
      hd2 = @hfn(b2) * cc22
      hc3 = @hfn(a3) * cc13
      hd3 = @hfn(b3) * cc23
    elseif @loop == "3 - Barnsleyish"
      hc2 = @hfn(sqrt(sqr(a2))) * cc12  - cc12
      hd2 = @hfn(sqrt(sqr(b2))) * cc22  - cc22
      hc3 = @hfn(sqrt(sqr(a3))) * cc13  - cc13
      hd3 = @hfn(sqrt(sqr(b3))) * cc23  - cc23
    endif
    z2 = (real(hc2) + real(hd2) + flip(imag(hc2) + imag(hd2))) / 2
    w2 = (imag(hc2) - imag(hd2) + flip(real(hd2) - real(hc2))) / 2
    z3 = (real(hc3) + real(hd3) + flip(imag(hc3) + imag(hd3))) / 2
    w3 = (imag(hc3) - imag(hd3) + flip(real(hd3) - real(hc3))) / 2
  endif

  if (@slope == true)
  ;;;;  process slope
    IF (@zmode == 5)
      iterexp1 = iterexp1 + exp(-cabs(z1))
      iterexp2 = iterexp2 + exp(-cabs(z2))
      iterexp3 = iterexp3 + exp(-cabs(z3))
    ENDIF
    done = done + 1; increment iteration counter

    IF (@zmode == 0)                      ; smallest |z|
      d1 = |z1|; get current distances from origin
      d2 = |z2|
      d3 = |z3|
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 1)                  ; smallest |real(z)|
      d1 = abs(real(z1)); get current distances from i axis
      d2 = abs(real(z2))
      d3 = abs(real(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 2)                  ; smallest |imag(z)|
      d1 = abs(imag(z1)); get current distances from r axis
      d2 = abs(imag(z2))
      d3 = abs(imag(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 3)                  ; smallest |real(z)|+|imag(z)|
      d1 = abs(real(z1))+abs(imag(z1)); get current distances from i axis
      d2 = abs(real(z2))+abs(imag(z2))
      d3 = abs(real(z3))+abs(imag(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ELSEIF (@zmode == 4)                  ; smallest |atan(z)|
      d1 = abs(atan2(z1)); get current angles
      d2 = abs(atan2(z2))
      d3 = abs(atan2(z3))
      IF (d1 < s1); update smallest distances
        s1 = d1
      ENDIF
      IF (d2 < s2)
        s2 = d2
      ENDIF
      IF (d3 < s3)
        s3 = d3
      ENDIF
    ENDIF

    IF (@bailout < |z1| + |w1| ||                \
        @everyiter ||\
        done == #maxiter + 2); done, or every iteration, or last
      ; determine continuous iteration (height) for each point
      IF (@zmode >= 0 && @zmode <= 4) ; height based on smallest |z|
        e1 = s1 * @zscale
        e2 = s2 * @zscale
        e3 = s3 * @zscale
      ELSEIF (@zmode == 5)
        e1 = iterexp1 * @zscale
        e2 = iterexp2 * @zscale
        e3 = iterexp3 * @zscale
      ENDIF

      ; apply transfer function
      ; a function is not used because these are floats
      ; and not all functions apply to floats
      IF (@xfer == 1); log
        e1 = log(e1)
        e2 = log(e2)
        e3 = log(e3)
      ELSEIF (@xfer == 2); sqrt
        e1 = sqrt(e1)
        e2 = sqrt(e2)
        e3 = sqrt(e3)
      ELSEIF (@xfer == 3); cuberoot
        e1 = (e1)^(1/3)
        e2 = (e2)^(1/3)
        e3 = (e3)^(1/3)
      ELSEIF (@xfer == 4); exp
        e1 = exp(e1)
        e2 = exp(e2)
        e3 = exp(e3)
      ELSEIF (@xfer == 5); sqr
        e1 = sqr(e1)
        e2 = sqr(e2)
        e3 = sqr(e3)
      ELSEIF (@xfer == 6); cube
        e1 = (e1)^3
        e2 = (e2)^3
        e3 = (e3)^3
      ELSEIF (@xfer == 7); sin
        e1 = sin(e1)
        e2 = sin(e2)
        e3 = sin(e3)
      ELSEIF (@xfer == 8); cos
        e1 = cos(e1)
        e2 = cos(e2)
        e3 = cos(e3)
      ELSEIF (@xfer == 9); tan
        e1 = tan(e1)
        e2 = tan(e2)
        e3 = tan(e3)
      ENDIF

      ; apply post-scale
      e1 = e1 * @zscale2
      e2 = e2 * @zscale2
      e3 = e3 * @zscale2

        vx = e2-e1
        vy = e3-e1
        vz = -@offset
        ; normalize vector
        vd = 1/sqrt(sqr(vx)+sqr(vy)+sqr(vz))
        vx = vx*vd
        vy = vy*vd
        vz = vz*vd
        z = vx + flip(vy); fudge z from vector
    ELSE; didn't compute z this time
      z = z1; use primary iteration value to keep periodicity working
    ENDIF
  else
    z = z1
  endif
  IF (@bailout < |z1| + |w1|)                  ; we're done
    done = 0
  ENDIF

bailout:
  (done > 0)

switch:
  type = "sdc-slope-hypercomplex-dynamic"
  version    = @version
  bailout    = @bailout
  hfn        = @hfn
  loop       = @loop
  seq        = @seq
  modBy      = @modBy
  modCmp     = @modCmp
  randomseed = @randomseed
  prob1      = @prob1

  mode       = @switchmode
  switchMode = mode
  startseed  = #pixel
  cjk = @cjk


  multiplier1= @multiplier1
  op1    = @op1
  fcnA1  = @fcnA1
  ampA1 = @ampA1
  freqA1 = @freqA1
  fcnB1  = @fcnB1
  ampB1 = @ampB1
  freqB1 = @freqB1
  fcnC1  = @fcnC1
  ampC1 = @ampC1
  freqC1 = @freqC1
  fcnD1  = @fcnD1
  ampD1 = @ampD1
  freqD1 = @freqD1
  fcnE1  = @fcnE1
  ampE1 = @ampE1
  freqE1 = @freqE1
  fcnF1  = @fcnF1
  ampF1 = @ampF1
  freqF1 = @freqF1
  fcnG1  = @fcnG1
  ampG1 = @ampG1
  freqG1 = @freqG1
  fcnH1  = @fcnH1
  ampH1 = @ampH1
  freqH1 = @freqH1

  multiplier2 = @multiplier2
  op2    = @op2
  fcnA2  = @fcnA2
  ampA2 = @ampA2
  freqA2 = @freqA2
  fcnB2  = @fcnB2
  ampB2 = @ampB2
  freqB2 = @freqB2
  fcnC2  = @fcnC2
  ampC2 = @ampC2
  freqC2 = @freqC2
  fcnD2  = @fcnD2
  ampD2 = @ampD2
  freqD2 = @freqD2
  ampE2 = @ampE2
  freqE2 = @freqE2
  fcnF2  = @fcnF2
  ampF2 = @ampF2
  freqF2 = @freqF2
  fcnG2  = @fcnG2
  ampG2 = @ampG2
  freqG2 = @freqG2
  fcnH2  = @fcnH2
  ampH2 = @ampH2
  freqH2 = @freqH2

  slope      = @slope
  offset     = @offset
  zmode      = @zmode
  xfer       = @xfer
  zscale     = @zscale
  zscale2    = @zscale2
  everyiter  = @everyiter

default:
  title = "Slope Hypercomplex Dynamic"
  method = multipass
  periodicity = 0
  magn = 0.7
  maxiter = 149

  float param version
    default = 1.1
    visible = false
  endparam

  param mode
    caption = "Current Mode"
    default = 1
    enum = "Mandelbrot" "Julia"
    hint = "Shows current mode"
  endparam

  param switchMode
    caption = "Switch Mode"
    default = 0
    enum = "Mandelbrot" "Julia"
    hint = "Shows mode to switch to"
  endparam

  param loop
    caption = "Loop Type"
    enum = "1" \
           "2" \
           "3 - Barnsleyish"
    default = 0
  endparam

  float param bailout
    default = 4.0
    caption = "Bailout"
  endparam

  int param seq
    enum = "Modulation" "First Formula" "Second Formula" "Random"
    default = 1
    caption = "Formula Sequence"
  endparam

  int param modBy
    default = 10
    caption = "Mod By"
    hint = "Iteration Modulated by This"
    visible = @seq==0
  endparam

  int param modCmp
    default = 5
    caption = "Mod Compare"
    hint = "Modulated Iteration < this -> formula 1"
    visible = @seq==0
  endparam
  int param randomseed
    caption = "Random Seed"
    default = 123456
    visible = @seq==3
  endparam
  float param prob1
    caption = "Prob for Func 1"
    default = 0.5
    min = 0.0
    max = 1.0
    visible = @seq==3
  endparam
  bool param invertMod
    caption = "Invert Sequence?"
    default = False
    visible = @seq==0 || @seq==3
  endparam

  bool param slope
    caption = "Apply slope?"
    default = true
    hint = "Use Lighting in dmj.ucl or one of the 3D Texturizer \
           formulas in reb.ucl with the slope applied. \
           Unset for a non-slope version registered with the\
           slope version.  Generally, unset 'Apply Slope? \
           for other formulas."
  endparam

  complex param startSeed
    caption = "Start/Seed"
    default = (0,0)
    hint = "Perturbation for the Mandelbrot, seed for the Julia."
  endparam

  complex param cjk
    caption = "(cj, ck)"
    default = (0,0)
  endparam

  complex param zjk
    caption = "(zj, zk)"
    default = (0,0)
    visible = @mode == "Julia"
  endparam

  func hfn
    caption = "Z Function"
    default = ident()
  endfunc

  heading
    caption = "Function 1"
    visible = @seq == 0 || @seq == 1 || @seq == 3
  endheading

  float param multiplier1
    default = .05
    caption = "Multiplier"
    hint = ".1 - Embrangle, .05 - Popcorn"
    enabled = @seq == 0 || @seq == 1 || @seq == 3
    visible = @seq == 0 || @seq == 1 || @seq == 3
  endparam

  param op1
    caption = "Function 1 operators"
    enum = "---- (Popcorn)" \
           "+-+- (Embrangle)" \
           "-+-+" \
           "++++" \
           "-+++" \
           "--++" \
           "---+" \
           "+---" \
           "++--" \
           "+++-" \
           "-++-" \
           "+--+" \
           "+-++" \
           "++-+" \
           "-+--" \
           "--+-"
    default = 0
    enabled = @seq == 0 || @seq == 1 || @seq == 3
    visible = @seq == 0 || @seq == 1 || @seq == 3
  endparam

  func fcnA1
    default = sin()
    caption = "Function A1"
    enabled = @seq == 0 || @seq == 1 || @seq == 3
    visible = @seq == 0 || @seq == 1 || @seq == 3
  endfunc
  float param ampA1

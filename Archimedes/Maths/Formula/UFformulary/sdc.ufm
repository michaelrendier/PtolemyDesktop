    default = -2.0
    visible = @method==9
  endparam

  float param m9pC            ; Chip
    caption = "c"
    default = 0.2
    visible = @method==9
  endparam
  
  float param m10pA         ; DeJong 
    caption = "a"
    default = 2.01
    visible = @method==10
  endparam

  float param m10pB         ; DeJong 
    caption = "b"
    default = -2.53
    visible = @method==10
  endparam

  float param m10pC         ; DeJong 
    caption = "c"
    default = 1.61
    visible = @method==10
  endparam

  float param m10pD         ; DeJong 
    caption = "d"
    default = -.33
    visible = @method==10
  endparam
  
  func m10f1

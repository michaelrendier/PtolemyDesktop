    visible = @opvar && ( @seq != 2 )
  endparam
  
  param cng2
    caption = "OpChange 2"
    enum = "++++""+++-""++-+""+-++""-+++""++--""+--+"\
     "--++""+-+-""-+-+""-++-""+---""-+--""--+-""---+"\

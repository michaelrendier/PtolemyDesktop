  dAmpC3 = @dAmpC3
  dAmpD3 = @dAmpD3
  dAmpA4 = @dAmpA4
  dAmpB4 = @dAmpB4
  dAmpC4 = @dAmpC4
  dAmpD4 = @dAmpD4
  dFreqA1 = @dFreqA1
  dFreqB1 = @dFreqB1
  dFreqC1 = @dFreqC1
  dFreqD1 = @dFreqD1
  dFreqA2 = @dFreqA2
  dFreqB2 = @dFreqB2
  dFreqC2 = @dFreqC2
  dFreqD2 = @dFreqD2
  dFreqA3 = @dFreqA3
  dFreqB3 = @dFreqB3
  dFreqC3 = @dFreqC3

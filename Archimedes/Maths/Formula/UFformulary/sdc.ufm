    default = false
  endparam

  heading
    caption = "Operator Params"
    visible = @opvar
  endheading
  param op1
    caption = "Operator 1"
    enum = "+++""++-""+-+""-++""+--""--+""-+-""---"
    default = 0
    visible = @opvar
  endparam
  param op2
    caption = "Operator 2"
    enum = "+++""++-""+-+""-++""+--""--+""-+-""---"
    default = 0

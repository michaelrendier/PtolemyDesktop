caption="Alt Variant"
enum="1""2"
endparam
param af
caption="Apollo Function"
enum="ident""flip""abs""sqr""cos""flipconj""flipabs"\
"flipsqr""flipcos""sqr cos""cube""ident+recip""ident+flip"\
"flip+sqr""flip+cos""sqr+exp""cos+exp"\
"flip-sqr""flip-cos""cos-exp""ident-cos"\
"cube-cos""expcube+flip""coscube+sqr""flipcube-flip"

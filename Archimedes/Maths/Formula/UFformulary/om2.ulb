class OM_TalisX2(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
c=@pf(pz)
pz=-@p1*c/(2*(-@p1)*c)+2*(1-@p1)
i=0
return pz
endfunc
private:
complex c
int i
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if @av==0
if i==0
pz=pz^2+c
c=c^2/(c+@p2)+pz
i=1
else
a=pz^2+c
b=c*pz*(1-pz)
pz=(1-@p1)*a+@p1*b
i=0
endif
else
if i==0
a=pz^2+c
b=c*pz*(1-pz)
pz=(1-@p1)*a+@p1*b
i=1
else
pz=pz^2+c
c=c^2/(c+@p2)+pz
i=0
endif
endif
return pz
endfunc

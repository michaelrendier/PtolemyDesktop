class OM_TalisPRI(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
if @mj==0
pz=@sp
c=@pf(fpixel)
else
pz=@pf(pz)
c=@js
endif
i=0
return pz
endfunc
private:
int i
complex c
complex func Iterate(complex pz)
if @mj==1
pz=(@zp1+0.05)*pz+@zp2
else
pz=@zp1*pz+@zp2
endif
if i==0
pz=((((pz^@pow+c)^@pow+c)^@pow+c)^@pow+c)^@pow+c
i=1
elseif i==1
pz=(((pz^@pow+c)^@pow+c)^@pow+c)^@pow+c
i=2
elseif i==2
pz=((pz^@pow+c)^@pow+c)^@pow+c
i=3
elseif i==3
pz=(pz^@pow+c)^@pow+c
i=4
elseif i==4
pz=pz^@pow+c
i=0
endif
c=c^2/(c+@p1)+pz
return pz
endfunc

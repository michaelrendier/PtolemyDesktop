bp=(1+@apa*1i)*sqr(cos(real(bx)+flip(by)))+@apa2*1i
cp=(1+@apa*1i)*sqr(cos(real(cx)+flip(cy)))+@apa2*1i
p=(1+@apa*1i)*sqr(cos(real(x)+flip(y)))+@apa2*1i
elseif @af==10

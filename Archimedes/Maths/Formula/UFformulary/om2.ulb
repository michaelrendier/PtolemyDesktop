class OM_KleinKoatrone(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
ang=2*pi/3
if @kv==0
c1=(1+@fp*1i)*(exp((0,0)*ang))+@fp2*1i
c2=(1+@fp*1i)*(exp((0,1)*ang))+@fp2*1i
c3=(1+@fp*1i)*(exp((0,2)*ang))+@fp2*1i
elseif @kv==1
c1=(1+@fp*1i)*flip(exp((0,0)*ang))+@fp2*1i
c2=(1+@fp*1i)*flip(exp((0,1)*ang))+@fp2*1i
c3=(1+@fp*1i)*flip(exp((0,2)*ang))+@fp2*1i
else
c1=(1+@fp*1i)*acos(exp((0,0)*ang))+@fp2*1i
c2=(1+@fp*1i)*acos(exp((0,1)*ang))+@fp2*1i
c3=(1+@fp*1i)*acos(exp((0,2)*ang))+@fp2*1i
endif
r=sqrt(3)/2
pz=@pf(pz)
z1=pz
z2=pz
c=@js
i=0
return pz
endfunc
private:
complex c1
complex c2
complex c3
float r
complex z1
complex z2
int i
complex c
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
If @av==0
if i==0
b=pz^2+@p3*(pz-c)*pz^2
z2=pz^2+@p4*(pz^2+c)*pz^2
z1=@p5*b+@p6
pz=pz^2+z1^2+z2^2
i=1
else
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
endif
i=0
endif
else
if i==0
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
endif
i=1
else
b=pz^2+@p3*(pz-c)*pz^2
z2=pz^2+@p4*(pz^2+c)*pz^2
z1=@p5*b+@p6
pz=pz^2+z1^2+z2^2
i=0
endif
endif
return pz
endfunc

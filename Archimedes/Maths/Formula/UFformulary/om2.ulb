}

class OM_Omnigopa(common.ulb:DivergentFormula) {

public:
complex func Init(complex pz)
fpixel=pz
if @mj==0
pz=@sp
c=@pf(fpixel)
else
pz=@pf(pz)
c=@js
endif
i=0
return pz
endfunc
private:
complex c
int i
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if @av==0
if i==0
pz=pz^@pow*exp(@p1/pz)+c
i=1
else
x1=real(pz)
y1=imag(pz)
x2=3*x1*y1^2-x1^3+@p2
y1=y1^3-3*x1^2*y1
pz=x2+flip(y1)
i=0
endif
else
if i==0
x1=real(pz)
y1=imag(pz)
x2=3*x1*y1^2-x1^3+@p2
y1=y1^3-3*x1^2*y1
pz=x2+flip(y1)
i=1
else
pz=pz^@pow*exp(@p1/pz)+c
i=0
endif
endif
return pz
endfunc
default:
title="Omnigopa"
param version
caption="Version"
default=100
visible=@version<100
endparam
param mj
caption="M/J"
enum="M""J"
endparam
param av
caption="Alt Variant"
enum="1""2"
endparam
param sp
caption="Start Parameter"
default=(-0.5,0)
visible=@mj==0
endparam
param js
caption="Julia Seed"
default=(-1.16,0)
visible=@mj==1
endparam
param p1
caption="Morph 1"
default=(1,0)
endparam
param p2
caption="Morph 2"
default=(-1.1,0)
endparam
param pow
caption="Exponent"
default=2
endparam
param zp1
caption="Z Parameter 1"
default=(1,0)
endparam
param zp2
caption="Z Parameter 2"
default=(0,0)
endparam
func pf
caption="Pixel Function"
default=ident()
endfunc
param p_power
visible=false
endparam
float param p_bailout
caption="Bailout"
default=400.0
exponential=true
endparam
}

class OM_SquatchJ(common.ulb:DivergentFormula) {
; This is a modification of CQuatJ in sdc.ufm
; Thanks to Susan D. Chambless, Junichi Sato and Gilles Nadeau
public:
complex func Init(complex pz)
z0=@pf(pz)
z1=@p1
z2=@p2
z3=@p3
q0=@p4
q1=@p5
q2=@p6
if @v==0 || @v==1
q3=@p7
else
q3=@p7+0.215
endif
return pz
endfunc
private:
complex z0
complex z1
complex z2
complex z3
complex q0
complex q1
complex q2
complex q3
complex func Iterate(complex pz)
if @v==0
w0=@fn1(z0)^2-z1^3-z2^2-z3^3
w1=2*z0*z1
w2=2*z0*z2
w3=2*z0*z3
z0=w0+q0
z1=w1+q1
z2=w2+q2
z3=w3+q3
elseif @v==1
x0=z0+q0
x1=z1+q1
x2=z2+q2
x3=z3+q3
z0=@fn1(x0)^2-x1^3-x2^2-x3^3
z1=2*x0*x1
z2=2*x0*x2
z3=2*x0*x3
elseif @v==2
w0=@fn1(z0)^2-z1^4-z2^2-z3^3
w1=2*z0*z1
w2=2*z0*z2
w3=2*z0*z3
z0=w0+q0
z1=w1+q1
z2=w2+q2
z3=w3+q3
else
x0=z0+q0
x1=z1+q1
x2=z2+q2
x3=z3+q3
z0=@fn1(x0)^2-x1^4-x2^2-x3^3
z1=2*x0*x1
z2=2*x0*x2
z3=2*x0*x3
endif
pz=z0+z1+z2+z3
return pz
endfunc
default:
title="Squatch J"
param version
caption="Version"
default=100
visible=@version<100
endparam
param v
caption="Variant"
enum="1""2""3""4"
endparam
param p1
caption="Mutation 1"
default=(0,0)
endparam
param p2
caption="Mutation 2"
default=(0,0)
endparam
param p3
caption="Mutation 3"
default=(0,0)
endparam
param p4
caption="Mutation 4"
default=(-0.745,0)
endparam
param p5
caption="Mutation 5"
default=(0.113,0.05)
endparam
param p6
caption="Mutation 6"
default=(0,0)
endparam
param p7
caption="Mutation 7"
default=(0,0)
endparam
func fn1
caption="Squatch Function"
default=ident()
endfunc
func pf
caption="Pixel Function"
default=ident()
endfunc
param p_power
visible=false
endparam
float param p_bailout
caption="Bailout"
default=100.0
exponential=true
endparam
}

class OM_SquatchM(common.ulb:DivergentFormula) {
; This is a modification of CQuatM in sdc.ufm
; Thanks to Susan D. Chambless, Junichi Sato and Gilles Nadeau
public:
complex func Init(complex pz)
z0=(0,0)
z1=(0,0)
z2=(0,0)
z3=(0,0)
q0=@pf(pz)
q1=@p1
q2=@p2
q3=@p3
return pz
endfunc
private:
complex z0
complex z1
complex z2
complex z3
complex q0
complex q1
complex q2
complex q3
complex func Iterate(complex pz)
if @v==0
w0 =z0^2-z1^2-z2^2-z3^2
w1=2*z0*z1
w2=2*z0*z2
w3=2*z0*z3
z0=w0^2+@fn1(q0)
z1=w1^2+@fn1(q1)
z2=w2^2+@fn1(q2)
z3=w3^2+@fn1(q3)
elseif @v==1
w0=z0^2-z1^2-z2^2-z3^2
w1=2*z0*z1
w2=2*z0*z2
w3=2*z0*z3
z0=w0^3+@fn1(q0)
z1=w1^3+@fn1(q1)
z2=w2^3+@fn1(q2)
z3=w3^3+@fn1(q3)
elseif @v==2
w0=z0^2-z1^2-z2^2-z3^2
w1=2*z0*z1
w2=2*z0*z2
w3=2*z0*z3
z0=w0+@fn1(q0)^2
z1=w1+@fn1(q1)^2
z2=w2+@fn1(q2)^2
z3=w3+@fn1(q3)^2
elseif @v==3
w0=z0^2-z1^2-z2^2-z3^2
w1=2*z0*z1
w2=2*z0*z2
w3=2*z0*z3
z0=w0+@fn1(q0)^3
z1=w1+@fn1(q1)^3
z2=w2+@fn1(q2)^3
z3=w3+@fn1(q3)^3
endif
pz=z0+z1+z2+z3
return pz
endfunc
default:
title="Squatch M"
param version
caption="Version"
default=100
visible=@version<100
endparam
param v
caption="Variant"
enum="1" "2""3""4"
endparam
param p1
caption="Mutation 1"
default=(0.25,0)
endparam
param p2
caption="Mutation 2"
default=(0.25,0)
endparam
param p3
caption="Mutation 3"
default=(0.25,0)
endparam
func fn1
caption="Squatch Function"
default=ident()
endfunc
func pf
caption="Pixel Function"
default=ident()
endfunc
param p_power
visible=false
endparam
float param p_bailout
caption="Bailout"
default=100.0
exponential=true
endparam
}

class OM_TalisX3(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
if @mj==0
pz=@sp
c=@pf(fpixel)
else
pz=@pf(pz)
c=@js
endif
a=pz
i=0
return pz
endfunc
private:
complex c
complex a
int i
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if @av==0
if i==0
pz=pz^2+c
c=c^2/(c+@tp)+pz
i=1
else
if @v==1
pz=pz*a+c
a=@fn1(@p1*c+pz)/@p3
c=@fn2(@p2*pz+a)/@p3
elseif @v==2
pz=pz*a-c
a=@fn1(@p1*pz)/(@p3-1.1)+a
c=@fn2(@p2*c-pz)/(@p3-1.1)
else
pz=pz*a+c
a=@fn1(@p1*pz+c)/@p3
c=@fn2(@p2*a+c)/@p3
endif
i=0
endif
else
if i==0
if @v==1
pz=pz*a+c
a=@fn1(@p1*c+pz)/@p3
c=@fn2(@p2*pz+a)/@p3
elseif @v==2
pz=pz*a-c
a=@fn1(@p1*pz)/(@p3-1.1)+a
c=@fn2(@p2*c-pz)/(@p3-1.1)
else
pz=pz*a+c
a=@fn1(@p1*pz+c)/@p3
c=@fn2(@p2*a+c)/@p3
endif
i=1
else
pz=pz^2+c
c=c^2/(c+@tp)+pz
i=0
endif
endif
return pz
endfunc
default:
title="Talis X 3"
param version
caption="Version"
default=100
visible=@version<100
endparam
param mj
caption="M/J"
enum="M""J"
endparam
param av
caption="Alt Variant"
enum="1""2"
endparam
param v
caption="X Variant"
enum="1""2""3"
endparam
param sp
caption="Start Parameter"
default=(0.5,0)
visible=@mj==0
endparam
param js
caption="Julia Seed"
default=(-0.425,0)
visible=@mj==1
endparam
param tp
caption="Talis Parameter"
default=(-0.9,0)
endparam
param p1
caption="X Parameter 1"
default=(-1,0)
endparam
param p2
caption="X Parameter 2"
default=(1,0)
endparam
param p3
caption="X Parameter 3"
default=(-1,0)
endparam
func fn1
caption="X Function 1"
default=ident()
endfunc
func fn2
caption="X Function 2"
default=ident()
endfunc
func pf
caption="Pixel Function"
default=ident()
endfunc
param zp1
caption="Z Parameter 1"
default=(1,0)
endparam
param zp2
caption="Z Parameter 2"
default=(0,0)
endparam
param p_power
visible=false
endparam
float param p_bailout
caption="Bailout"
default=400000.0
exponential=true
endparam
}

class OM_TheRiddle(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
if @mj==0
pz=@sp
c=@pf(fpixel)
else
pz=@pf(pz)
c=@js
endif
return pz
endfunc
private:
complex c
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
b=pz^2+1/(pz^2+c)+c
c=pz
pz=b
return pz
endfunc
default:
title="The Riddle"
param version
caption="Version"
default=100
visible=@version<100
endparam
param mj
caption="M/J"
enum="M""J"
endparam
param sp
caption="Start Parameter"
default=(0,0)
visible=@mj==0
endparam
param js

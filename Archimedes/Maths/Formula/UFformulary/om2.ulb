class OM_HydraPRI(common.ulb:DivergentFormula) {
;Thanks to Noel Giffin
public:
complex func Init(complex pz)
fpixel=pz
if @mj==0
pz=@sp
c=@pf(fpixel)
else
pz=@pf(pz)
c=@js
endif
i=0
return pz
endfunc
private:
complex c
int i
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if @v==0
k=pz
if i==0
pz=(((((pz^@pow+c)^@pow+c)^@pow+c)^@pow+c)^@pow+c)
i=1
elseif i==1
pz=((((pz^@pow+c)^@pow+c)^@pow+c)^@pow+c)
i=2
elseif i==2
pz=(((pz^@pow+c)^@pow+c)^@pow+c)
i=3
elseif i==3
pz=((pz^@pow+c)^@pow+c)
i=4
else
pz=(pz^@pow+c)
i=0
endif
c=@p1*@fn1(k)
else
if i==0
k=((((pz^@pow+c)^@pow+c)^@pow+c)^@pow+c)
pz=(((((pz^@pow+c)^@pow+c)^@pow+c)^@pow+c)^@pow+c)
i=1
elseif i==1
k=(((pz^@pow+c)^@pow+c)^@pow+c)
pz=((((pz^@pow+c)^@pow+c)^@pow+c)^@pow+c)
i=2
elseif i==2
k=((pz^@pow+c)^@pow+c)
pz=(((pz^@pow+c)^@pow+c)^@pow+c)
i=3
elseif i==3
k=(pz^@pow+c)
pz=((pz^@pow+c)^@pow+c)
i=4
else
k=pz
pz=(pz^@pow+c)
i=0
endif
c=(@p1+0.385763)*@fn1(k)
endif
return pz
endfunc

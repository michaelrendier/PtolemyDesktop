class OM_KleinTransform(common.ulb:UserTransform) {
public:
func init(complex pz)
if @kg==0
ang=2*pi/3
c1=(1+@fp*1i)*@fn1(@fn2(exp((0,0)*ang)))+@fp2*1i
c2=(1+@fp*1i)*@fn1(@fn2(exp((0,1)*ang)))+@fp2*1i
c3=(1+@fp*1i)*@fn1(@fn2(exp((0,2)*ang)))+@fp2*1i
r=sqrt(3)/2
elseif @kg==1
ang=pi/3
c1=(1+@fp*1i)*@fn1(@fn2((0,0)))+@fp2*1i
c2=(1+@fp*1i)*@fn1(@fn2((1,0)))+@fp2*1i
c3=(1+@fp*1i)*@fn1(@fn2(exp((0,1)*ang)))+@fp2*1i
c4=(1+@fp*1i)*@fn1(@fn2(exp((0,2)*ang)))+@fp2*1i
c5=(1+@fp*1i)*@fn1(@fn2(exp((0,3)*ang)))+@fp2*1i
c6=(1+@fp*1i)*@fn1(@fn2(exp((0,4)*ang)))+@fp2*1i
c7=(1+@fp*1i)*@fn1(@fn2(exp((0,5)*ang)))+@fp2*1i
r=0.5
endif
endfunc
complex func Iterate(complex pz)
if @kg==0
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
endif
elseif @kg==1
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
elseif |pz-c4|<r^2
pz=r*conj(r/(pz-c4))+c4
elseif |pz-c5|<r^2
pz=r*conj(r/(pz-c5))+c5
elseif |pz-c6|<r^2
pz=r*conj(r/(pz-c6))+c6
elseif |pz-c7|<r^2
pz=r*conj(r/(pz-c7))+c7
endif
endif
pz=@zp1*@zf(pz)+@zp2
return pz
endfunc
private:
complex c1
complex c2
complex c3
complex c4
complex c5
complex c6
complex c7
float r
default:
title="Klein Transform"
int param version
caption="Version"
default=100
visible=@version<100
endparam
param kg
caption="Klein Group"
enum="3""7"
endparam
param fp
caption="Klein Parameter 1"
default=0.0
endparam
param fp2
caption="Klein Parameter 2"
default=(0,0)
endparam
func fn1
caption="Klein Function 1"
default=ident()
endfunc
func fn2
caption="Klein Function 2"
default=ident()
endfunc
func zf
caption="Z Function"
default=ident()
endfunc
param zp1
caption="Z Parameter 1"
default=(1,0)
endparam
param zp2
caption="Z Parameter 2"
default=(0,0)
endparam
}

class OM_3AltKlein(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
ang=2*pi/3
c1=(1+@fp*1i)*@fn1(exp((0,0)*ang))+@fp4*1i
c2=(1+@fp*1i)*@fn1(exp((0,1)*ang))+@fp4*1i
c3=(1+@fp*1i)*@fn1(exp((0,2)*ang))+@fp4*1i
r=sqrt(3)/2
angb=pi/3
c1b=(1+@fp2*1i)*@fn2((0,0))+@fp5*1i
c2b=(1+@fp2*1i)*@fn2((1,0))+@fp5*1i
c3b=(1+@fp2*1i)*@fn2(exp((0,1)*angb))+@fp5*1i
c4b=(1+@fp2*1i)*@fn2(exp((0,2)*angb))+@fp5*1i
c5b=(1+@fp2*1i)*@fn2(exp((0,3)*angb))+@fp5*1i
c6b=(1+@fp2*1i)*@fn2(exp((0,4)*angb))+@fp5*1i
c7b=(1+@fp2*1i)*@fn2(exp((0,5)*angb))+@fp5*1i
rb=0.5
a=pi/3
c1c=(1+@fp3*1i)*@fn3((0,2))+@fp6*1i
c2c=(1+@fp3*1i)*@fn3(2*(sin(a)+flip(cos(a))))+@fp6*1i
c3c=(1+@fp3*1i)*@fn3(2*(sin(2*a)+flip(cos(2*a))))+@fp6*1i
c4c=(1+@fp3*1i)*@fn3((0,-2))+@fp6*1i
c5c=(1+@fp3*1i)*@fn3(2*(sin(4*a)+flip(cos(4*a))))+@fp6*1i
c6c=(1+@fp3*1i)*@fn3(2*(sin(5*a)+flip(cos(5*a))))+@fp6*1i
pz=@pf(pz)
i=0
return pz
endfunc
private:
complex c1
complex c2
complex c3
float r
complex c1b
complex c2b
complex c3b
complex c4b
complex c5b
complex c6b
complex c7b
float rb

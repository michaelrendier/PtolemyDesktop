class OM_ExtractfromKanaYagLic(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
if @mj==1
pz=@pf(pz)
c1=@js1
c2=@js2
else
pz=@sp
c1=@pp1*@pf(fpixel)
c2=@pp2*@pf(fpixel)
endif
return pz
endfunc
private:
complex c1
complex c2
complex fpixel
complex func Iterate(complex pz)
if @mj==0
pz=@zp1*pz+@zp2
else
pz=(@zp1+0.45)*pz+@zp2
endif
pz=(2*pz^3+1-c1)/(3*pz^2-c1)
pz=pz^3+(c2-1)*pz-c2
return pz
endfunc

class OM_PartialReverseIterationJulia(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
pz=@pf(pz)
c=@js
i=0
return pz
endfunc
private:
int i
complex c
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if i==0
pz=((((pz^@pow+c)^@pow+c)^@pow+c)^@pow+c)^@pow+c
i=1
elseif i==1
pz=(((pz^@pow+c)^@pow+c)^@pow+c)^@pow+c
i=2
elseif i==2
pz=((pz^@pow+c)^@pow+c)^@pow+c
i=3
elseif i==3
pz=(pz^@pow+c)^@pow+c
i=4
elseif i==4
pz=pz^@pow+c
i=0
endif
return pz
endfunc

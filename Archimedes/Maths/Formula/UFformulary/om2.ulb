^@pow1+c*((pz^@pow1+c*pz^@pow2+@p1*a)^@pow1+c*(pz^@pow1+c*pz^@pow2+@p1*a)^@pow2+@p1*a)^@pow2+@p1*a)\
^@pow1+c*(((pz^@pow1+c*pz^@pow2+@p1*a)^@pow1+c*(pz^@pow1+c*pz^@pow2+@p1*a)^@pow2+@p1*a)\
^@pow1+c*((pz^@pow1+c*pz^@pow2+@p1*a)^@pow1+c*(pz^@pow1+c*pz^@pow2+@p1*a)^@pow2+@p1*a)^@pow2+@p1*a)^@pow2+@p1*a)
pz=b
i=1
elseif i==1
b=((((pz^@pow1+c*pz^@pow2+@p1*a)^@pow1+c*(pz^@pow1+c*pz^@pow2+@p1*a)^@pow2+@p1*a)\
^@pow1+c*((pz^@pow1+c*pz^@pow2+@p1*a)^@pow1+c*(pz^@pow1+c*pz^@pow2+@p1*a)^@pow2+@p1*a)^@pow2+@p1*a)\
^@pow1+c*(((pz^@pow1+c*pz^@pow2+@p1*a)^@pow1+c*(pz^@pow1+c*pz^@pow2+@p1*a)^@pow2+@p1*a)\
^@pow1+c*((pz^@pow1+c*pz^@pow2+@p1*a)^@pow1+c*(pz^@pow1+c*pz^@pow2+@p1*a)^@pow2+@p1*a)^@pow2+@p1*a)^@pow2+@p1*a)
a=(((pz^@pow1+c*pz^@pow2+@p1*a)^@pow1+c*(pz^@pow1+c*pz^@pow2+@p1*a)^@pow2+@p1*a)\
^@pow1+c*((pz^@pow1+c*pz^@pow2+@p1*a)^@pow1+c*(pz^@pow1+c*pz^@pow2+@p1*a)^@pow2+@p1*a)^@pow2+@p1*a)
pz=b

c2=(1+@fp*1i)*cabs(sin(exp((0,1)*ang)))+(@fp2+(0,-0.19))*1i
c3=(1+@fp*1i)*cabs(sin(exp((0,2)*ang)))+(@fp2+(0,-0.19))*1i
elseif @ff==11
c1=(1+@fp*1i)*cabs(sinh(exp((0,0)*ang)))+(@fp2+(0,0.025))*1i
c2=(1+@fp*1i)*cabs(sinh(exp((0,1)*ang)))+(@fp2+(0,0.025))*1i
c3=(1+@fp*1i)*cabs(sinh(exp((0,2)*ang)))+(@fp2+(0,0.025))*1i
elseif @ff==12
c1=(1+@fp*1i)*sqr(flip(exp((0,0)*ang)))+@fp2*1i
c2=(1+@fp*1i)*sqr(flip(exp((0,1)*ang)))+@fp2*1i

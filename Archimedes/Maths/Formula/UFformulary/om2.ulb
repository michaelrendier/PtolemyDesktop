default=(0.5,0)
visible=@mj==1
endparam
param pow
caption="Exponent"
default=2
endparam
param p1
caption="Morph 1"
default=(2,0)
endparam
param p2
caption="Morph 2"
default=1.0
endparam
param zp1
caption="Z Parameter 1"
default=(1,0)
endparam

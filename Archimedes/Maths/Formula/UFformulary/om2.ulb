class OM_KleinTransform2(common.ulb:UserTransform) {
; Thanks to Felix Klein and Morgan L. Owens
public:
func init(complex pz)
ang2=2*pi/3
c1b=(1+@fp3*1i)*(@fn2(exp((0,0)*ang2)))+@fp4*1i
c2b=(1+@fp3*1i)*(@fn2(exp((0,1)*ang2)))+@fp4*1i
c3b=(1+@fp3*1i)*(@fn2(exp((0,2)*ang2)))+@fp4*1i
r2=sqrt(3)/2
ang=pi/3
c1=(1+@fp*1i)*@fn1((0,0))+@fp2*1i
c2=(1+@fp*1i)*@fn1((1,0))+@fp2*1i
c3=(1+@fp*1i)*@fn1(exp((0,1)*ang))+@fp2*1i
c4=(1+@fp*1i)*@fn1(exp((0,2)*ang))+@fp2*1i
c5=(1+@fp*1i)*@fn1(exp((0,3)*ang))+@fp2*1i
c6=(1+@fp*1i)*@fn1(exp((0,4)*ang))+@fp2*1i
c7=(1+@fp*1i)*@fn1(exp((0,5)*ang))+@fp2*1i
r=0.5
endfunc
complex func Iterate(complex pz)
if @av==0
if |pz-c1b|<r2^2
pz=r2*conj(r2/(pz-c1b))+c1b
elseif |pz-c2b|<r2^2
pz=r2*conj(r2/(pz-c2b))+c2b
elseif |pz-c3b|<r2^2
pz=r2*conj(r2/(pz-c3b))+c3b
endif
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
elseif |pz-c4|<r^2
pz=r*conj(r/(pz-c4))+c4
elseif |pz-c5|<r^2
pz=r*conj(r/(pz-c5))+c5
elseif |pz-c6|<r^2
pz=r*conj(r/(pz-c6))+c6
elseif |pz-c7|<r^2
pz=r*conj(r/(pz-c7))+c7
endif
else
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
elseif |pz-c4|<r^2
pz=r*conj(r/(pz-c4))+c4
elseif |pz-c5|<r^2
pz=r*conj(r/(pz-c5))+c5
elseif |pz-c6|<r^2
pz=r*conj(r/(pz-c6))+c6
elseif |pz-c7|<r^2
pz=r*conj(r/(pz-c7))+c7
endif
if |pz-c1b|<r2^2
pz=r2*conj(r2/(pz-c1b))+c1b
elseif |pz-c2b|<r2^2
pz=r2*conj(r2/(pz-c2b))+c2b
elseif |pz-c3b|<r2^2
pz=r2*conj(r2/(pz-c3b))+c3b
endif
endif
pz=@zp1*@zf(pz)+@zp2
return pz
endfunc
private:
complex c1
complex c2
complex c3
complex c4
complex c5
complex c6
complex c7
complex c1b
complex c2b
complex c3b
float r
float r2
default:
title="Klein Transform 2"
int param version
caption="Version"
default=100
visible=@version<100
endparam
param av
caption="Alt Variant"
enum="1""2"
endparam
param fp
caption="Klein Parameter 1"
default=0.0
endparam
param fp2
caption="Klein Parameter 2"
default=(0,0)
endparam
param fp3
caption="Klein Parameter 3"
default=0.0
endparam
param fp4
caption="Klein Parameter 4"
default=(0,0)
endparam
func fn1
caption="Klein Function 1"
default=ident()
endfunc
func fn2
caption="Klein Function 2"
default=ident()
endfunc
func zf
caption="Z Function"
default=ident()
endfunc
param zp1
caption="Z Parameter 1"
default=(1,0)
endparam
param zp2
caption="Z Parameter 2"
default=(0,0)
endparam

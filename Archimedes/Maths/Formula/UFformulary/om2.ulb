class OM_Psyagorath(common.ulb:DivergentFormula) {
; A modification of "pythagorean" in dan.ufm, Thanks to Daniele Lupo.
public:
complex func Init(complex pz)
fpixel=pz
c=@pf(fpixel)
k1=(0,0)
k2=(0,0)
return pz
endfunc
private:
complex c
complex k1
complex k2
complex func Iterate(complex pz)
a=k1^2-k2^2
b=2*k1*k2
pz=a+b
k1=a+@fn1(c)+@p1
k2=b+@fn2(c)+@p2
return pz
endfunc
default:
title="Psyagorath"
param version
caption="Version"
default=100
visible=@version<100
endparam
param p1
caption="Morph 1"
default=(0,0)
endparam
param p2
caption="Morph 2"
default=(0,0)
endparam
func fn1
caption="Funktion 1"
default=ident()
endfunc
func fn2
caption="Funktion 2"
default=ident()
endfunc
func pf
caption="Funktion 3"
default=ident()
endfunc
param p_power
visible=false
endparam
float param p_bailout
caption="Bailout"
default=400.0
exponential=true
endparam
}

class OM_Steganographica(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
if @mj==1
pz=@pf(pz)
c1=@js1
c2=@js2
else
pz=@sp
c1=@pp1*@pf(fpixel)
c2=@pp2*@pf(fpixel)
endif
return pz
endfunc
private:
complex c1
complex c2
complex fpixel
complex func Iterate(complex pz)
if @mj==0
pz=@zp1*pz+@zp2
else
pz=(@zp1+0.45)*pz+@zp2
endif
pz=(2*pz^3+1-c1)/(3*pz^2-c1)
x=real(pz)
y=imag(pz)
d=3*x*y^2-x^3+c2
y=y^3-3*x^2*y
pz=d+flip(y)
return pz
endfunc
default:
title="Steganographica"
param version
caption="Version"
default=100
visible=@version<100
endparam
param mj
caption="M/J"
enum="M""J"
endparam
param sp
caption="Start Parameter"
default=(-2,0)
visible=@mj==0
endparam
param js1
caption="Julia Seed 1"
default=(0.625,0)
visible=@mj==1
endparam
param js2
caption="Julia Seed 2"
default=(0.565,0)
visible=@mj==1
endparam
param pp1
caption="Pixel Parameter 1"
default=(-0.5,0)
visible=@mj==0
endparam
param pp2
caption="Pixel Parameter 2"
default=(1,0)
visible=@mj==0
endparam
func pf
caption="Pixel Function"
default=ident()
endfunc
param zp1
caption="Z Parameter 1"
default=(0.9,0)
endparam
param zp2
caption="Z Parameter 2"
default=(0,0)
endparam
param p_power
visible=false
endparam
float param p_bailout
caption="Bailout"
default=40.0
exponential=true
endparam
}

class OM_AngulancyJ(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
z1=real(pz)
z2=imag(pz)*1i
z3=@p3
return pz
endfunc
private:
complex z1
complex z2
complex z3
complex func Iterate(complex pz)
t1=z1*z1+2*z2*z3
t2=z3*z3+2*z1*z2
t3=z2*z2+2*z3*z1
z1=t1+@p1
z2=t2+@p2
z3=t3+@p3
pz=z1^2+z2^2+z3^2
return pz
endfunc
default:
title="Angulancy J"
param version
caption="Version"
default=100
visible=@version<100
endparam
param p1
caption="Angulancy Parameter 1"
default=(-0.5,0)
endparam
param p2
caption="Angulancy Parameter 2"
default=(-0.5,0)
endparam
param p3
caption="Angulancy Parameter 3"
default=(0.25,0)
endparam
param p_power
visible=false
endparam
float param p_bailout
caption="Bailout"
default=64.0
exponential=true
endparam
}

class OM_AngulancyM(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
c1=real(pz)
c2=imag(pz)*1i
c3=@p1
z1=@sp1
z2=@sp2
z3=@sp3
return pz
endfunc
private:
complex c1
complex c2
complex c3
complex z1
complex z2
complex z3
complex func Iterate(complex pz)
t1=z1*z1+2*z2*z3
t2=z3*z3+2*z1*z2
t3=z2*z2+2*z3*z1
z1=t1+c1
z2=t2+c2
z3=t3+c3
pz=z1^2+z2^2+z3^2
return pz
endfunc
default:
title="Angulancy M"

pz=@zp1*pz+@zp2
if @av==0
if inte==0
if |pz-ap|<ar^2
pz=ar*conj(ar/(pz-ap))+ap
elseif |pz-bp|<br^2
pz=br*conj(br/(pz-bp))+bp
elseif |pz-cp|<cr^2
pz=cr*conj(cr/(pz-cp))+cp
elseif |pz-p|<r^2
pz=r*conj(r/(pz-p))+p
endif
inte=1
else
if inte2==0
pz=((((pz^@pow+@js)^@pow+@js)^@pow+@js)^@pow+@js)^@pow+@js
inte2=1
elseif inte2==1
pz=(((pz^@pow+@js)^@pow+@js)^@pow+@js)^@pow+@js
inte2=2
elseif inte2==2
pz=((pz^@pow+@js)^@pow+@js)^@pow+@js
inte2=3
elseif inte2==3
pz=(pz^@pow+@js)^@pow+@js
inte2=4
elseif inte2==4
pz=pz^@pow+@js
inte2=0
endif
inte=0
endif
else
if inte==0
if inte2==0
pz=((((pz^@pow+@js)^@pow+@js)^@pow+@js)^@pow+@js)^@pow+@js
inte2=1
elseif inte2==1
pz=(((pz^@pow+@js)^@pow+@js)^@pow+@js)^@pow+@js
inte2=2
elseif inte2==2
pz=((pz^@pow+@js)^@pow+@js)^@pow+@js
inte2=3
elseif inte2==3
pz=(pz^@pow+@js)^@pow+@js
inte2=4
elseif inte2==4
pz=pz^@pow+@js
inte2=0
endif
inte=1
else
if |pz-ap|<ar^2
pz=ar*conj(ar/(pz-ap))+ap
elseif |pz-bp|<br^2
pz=br*conj(br/(pz-bp))+bp
elseif |pz-cp|<cr^2
pz=cr*conj(cr/(pz-cp))+cp
elseif |pz-p|<r^2
pz=r*conj(r/(pz-p))+p
endif
inte=0
endif
endif
return pz
endfunc

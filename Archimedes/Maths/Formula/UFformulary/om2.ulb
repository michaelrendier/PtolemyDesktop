endif
endfunc
private:
complex c1b
complex c2b
complex c3b
complex c4b
complex c5b
complex c6b
complex c7b
float r3
float ax
float ay
float ar
float bx
float by
float br
float cx
float cy
float cr
float h
float a
float b
float c
float d
float ee
float f
float g
float l
float i
float j
float k
float m
float n
float o
float r
float r1
float r2
float x
float y
complex ap
complex bp
complex cp
complex p
complex func Iterate(complex pz)
if @av==0
if |pz-c1b|<r3^2
pz=r3*conj(r3/(pz-c1b))+c1b
elseif |pz-c2b|<r3^2
pz=r3*conj(r3/(pz-c2b))+c2b
elseif |pz-c3b|<r3^2
pz=r3*conj(r3/(pz-c3b))+c3b
elseif |pz-c4b|<r3^2
pz=r3*conj(r3/(pz-c4b))+c4b
elseif |pz-c5b|<r3^2
pz=r3*conj(r3/(pz-c5b))+c5b
elseif |pz-c6b|<r3^2
pz=r3*conj(r3/(pz-c6b))+c6b
elseif |pz-c7b|<r3^2
pz=r3*conj(r3/(pz-c7b))+c7b
endif
if(|pz-ap|<ar^2)
pz=ar*conj(ar/(pz-ap))+ap
elseif(|pz-bp|<br^2)
pz=br*conj(br/(pz-bp))+bp
elseif(|pz-cp|<cr^2)
pz=cr*conj(cr/(pz-cp))+cp
elseif(|pz-p|<r^2)
pz=r*conj(r/(pz-p))+p
endif
else
if(|pz-ap|<ar^2)
pz=ar*conj(ar/(pz-ap))+ap
elseif(|pz-bp|<br^2)
pz=br*conj(br/(pz-bp))+bp
elseif(|pz-cp|<cr^2)
pz=cr*conj(cr/(pz-cp))+cp
elseif(|pz-p|<r^2)
pz=r*conj(r/(pz-p))+p
endif
if |pz-c1b|<r3^2
pz=r3*conj(r3/(pz-c1b))+c1b
elseif |pz-c2b|<r3^2
pz=r3*conj(r3/(pz-c2b))+c2b
elseif |pz-c3b|<r3^2
pz=r3*conj(r3/(pz-c3b))+c3b
elseif |pz-c4b|<r3^2
pz=r3*conj(r3/(pz-c4b))+c4b
elseif |pz-c5b|<r3^2
pz=r3*conj(r3/(pz-c5b))+c5b
elseif |pz-c6b|<r3^2
pz=r3*conj(r3/(pz-c6b))+c6b
elseif |pz-c7b|<r3^2
pz=r3*conj(r3/(pz-c7b))+c7b
endif
endif
pz=@zp1*@zf(pz)+@zp2
return pz
endfunc
default:
title="Apollo Klein Transform 2"
int param version
caption="Version"
default=100
visible=@version<100
endparam

class OM_Arcanumba(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
if @mj==1
pz=@pf(pz)
c1=@js1
c2=@js2
else
pz=@sp
c1=@pp1*@pf(fpixel)
c2=@pp2*@pf(fpixel)
endif
i=0
a=@p1
i2=a
return pz
endfunc
private:
complex c1
complex c2
complex fpixel
int i
int i2
int a
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if @av==0
if i==0
if i2==a
a=1
i2=@p1
pz=pz^i2+c1
else
pz=pz^i2+c1
endif
i=1
else
a2=@p2*pz+@p3
pz=pz*a2*c2
pz=@fn3(a2)+(pz*c2)
i=0
endif
else
if i==0
a2=@p2*pz+@p3
pz=pz*a2*c2
pz=@fn3(a2)+(pz*c2)
i=1
else
if i2==a
a=1
i2=@p1
pz=pz^i2+c1
else
pz=pz^i2+c1
endif
i=0
endif
endif
return pz
endfunc

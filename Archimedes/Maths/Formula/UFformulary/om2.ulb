elseif @ff==15
c1=(1+@fp*1i)*log(sinh(exp((0,0)*ang)))+(@fp2+0.687)*1i
c2=(1+@fp*1i)*log(sinh(exp((0,1)*ang)))+(@fp2+0.687)*1i
c3=(1+@fp*1i)*log(sinh(exp((0,2)*ang)))+(@fp2+0.687)*1i
elseif @ff==16
c1=(1+@fp*1i)*sqr(flip(exp((0,0)*ang)))+(@fp2+1.5)*1i
c2=(1+@fp*1i)*sqr(flip(exp((0,1)*ang)))+(@fp2+1.5)*1i
c3=(1+@fp*1i)*sqr(flip(exp((0,2)*ang)))+(@fp2+1.5)*1i
elseif @ff==17
c1=(1+@fp*1i)*sin(cabs(exp((0,0)*ang)))+(@fp2+0.4644)*1i
c2=(1+@fp*1i)*sin(cabs(exp((0,1)*ang)))+(@fp2+0.4644)*1i
c3=(1+@fp*1i)*sin(cabs(exp((0,2)*ang)))+(@fp2+0.4644)*1i
elseif @ff==18
c1=(1+@fp*1i)*sinh(flip(exp((0,0)*ang)))+(@fp2+0.225)*1i
c2=(1+@fp*1i)*sinh(flip(exp((0,1)*ang)))+(@fp2+0.225)*1i
c3=(1+@fp*1i)*sinh(flip(exp((0,2)*ang)))+(@fp2+0.225)*1i
elseif @ff==19
c1=(1+@fp*1i)*sinh(cabs(exp((0,0)*ang)))+(@fp2-0.68)*1i
c2=(1+@fp*1i)*sinh(cabs(exp((0,1)*ang)))+(@fp2-0.68)*1i
c3=(1+@fp*1i)*sinh(cabs(exp((0,2)*ang)))+(@fp2-0.68)*1i
endif
r=sqrt(3)/2
pz=@pf(pixel)
c=@js
a=@p1
i2=a
i=0
return pz
endfunc
private:
complex c1
complex c2
complex c3
float r
complex c
int i
int i2
int a
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if @av==0
if i==0
If i2==a
a=1
i2=@p1
pz=pz^i2+c
else
pz=pz^i2+c
endif
i2=i2-1
i=1
else
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
endif
i=0
endif
else
if i==0
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
endif
i=1
else
If i2==a
a=1
i2=@p1
pz=pz^i2+c
else
pz=pz^i2+c
endif
i2=i2-1
i=0
endif
endif
return pz
endfunc
default:
title="Felix and Julia 10"
param version
caption="Version"
default=100
visible=@version<100
endparam
param av
caption="Alt Variant"
enum="1""2"
endparam
param ff
caption="Felix Function"
enum="ident""flip""cabs""log""sin""sinh""flipcabs"\
"fliplog""flipsin""flipsinh""cabslog""logflip""logcabs"\
"loglog""logsin""logsinh""sqrflip""sincabs""sinhflip""sinhcabs"
endparam
param fp
caption="Felix Parameter 1"
default=0.0
endparam
param fp2
caption="Felix Parameter 2"
default=(0,0)
endparam
param js
caption="Julia Seed"
default=(0.46,0)
endparam
param p1
caption="Julia Exponent"
default=4
endparam
func pf
caption="Pixel Function"
default=ident()
endfunc
param zp1
caption="Z Parameter 1"
default=(1,0)
endparam
param zp2
caption="Z Parameter 2"
default=(0,0)
endparam
param p_power
visible=false
endparam
float param p_bailout
caption="Bailout"
default=400000.0
exponential=true
endparam
}

class OM_FelixandJulia9(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
ang=2*pi/3
if @ff==0
c1=(1+@fp*1i)*(exp((0,0)*ang))+@fp2*1i
c2=(1+@fp*1i)*(exp((0,1)*ang))+@fp2*1i
c3=(1+@fp*1i)*(exp((0,2)*ang))+@fp2*1i
elseif @ff==1
c1=(1+@fp*1i)*flip(exp((0,0)*ang))+@fp2*1i
c2=(1+@fp*1i)*flip(exp((0,1)*ang))+@fp2*1i
c3=(1+@fp*1i)*flip(exp((0,2)*ang))+@fp2*1i
elseif @ff==2
c1=(1+@fp*1i)*cabs(exp((0,0)*ang))+@fp2*1i
c2=(1+@fp*1i)*cabs(exp((0,1)*ang))+@fp2*1i
c3=(1+@fp*1i)*cabs(exp((0,2)*ang))+@fp2*1i
elseif @ff==3
c1=(1+@fp*1i)*log(exp((0,0)*ang))+@fp2*1i
c2=(1+@fp*1i)*log(exp((0,1)*ang))+@fp2*1i
c3=(1+@fp*1i)*log(exp((0,2)*ang))+@fp2*1i
elseif @ff==4
c1=(1+@fp*1i)*sin(exp((0,0)*ang))+@fp2*1i
c2=(1+@fp*1i)*sin(exp((0,1)*ang))+@fp2*1i
c3=(1+@fp*1i)*sin(exp((0,2)*ang))+@fp2*1i
elseif @ff==5
c1=(1+@fp*1i)*sinh(exp((0,0)*ang))+@fp2*1i
c2=(1+@fp*1i)*sinh(exp((0,1)*ang))+@fp2*1i
c3=(1+@fp*1i)*sinh(exp((0,2)*ang))+@fp2*1i
elseif @ff==6
c1=(1+@fp*1i)*flip(cabs(exp((0,0)*ang)))+@fp2*1i
c2=(1+@fp*1i)*flip(cabs(exp((0,1)*ang)))+@fp2*1i
c3=(1+@fp*1i)*flip(cabs(exp((0,2)*ang)))+@fp2*1i
elseif @ff==7
c1=(1+@fp*1i)*flip(log(exp((0,0)*ang)))+@fp2*1i
c2=(1+@fp*1i)*flip(log(exp((0,1)*ang)))+@fp2*1i
c3=(1+@fp*1i)*flip(log(exp((0,2)*ang)))+@fp2*1i
elseif @ff==8
c1=(1+@fp*1i)*flip(sin(exp((0,0)*ang)))+@fp2*1i
c2=(1+@fp*1i)*flip(sin(exp((0,1)*ang)))+@fp2*1i
c3=(1+@fp*1i)*flip(sin(exp((0,2)*ang)))+@fp2*1i
elseif @ff==9
c1=(1+@fp*1i)*flip(sinh(exp((0,0)*ang)))+@fp2*1i
c2=(1+@fp*1i)*flip(sinh(exp((0,1)*ang)))+@fp2*1i
c3=(1+@fp*1i)*flip(sinh(exp((0,2)*ang)))+@fp2*1i
elseif @ff==10
c1=(1+@fp*1i)*cabs(log(exp((0,0)*ang)))+@fp2*1i
c2=(1+@fp*1i)*cabs(log(exp((0,1)*ang)))+@fp2*1i
c3=(1+@fp*1i)*cabs(log(exp((0,2)*ang)))+@fp2*1i
elseif @ff==11
c1=(1+@fp*1i)*log(flip(exp((0,0)*ang)))+@fp2*1i
c2=(1+@fp*1i)*log(flip(exp((0,1)*ang)))+@fp2*1i
c3=(1+@fp*1i)*log(flip(exp((0,2)*ang)))+@fp2*1i
elseif @ff==12
c1=(1+@fp*1i)*log(cabs(exp((0,0)*ang)))+@fp2*1i
c2=(1+@fp*1i)*log(cabs(exp((0,1)*ang)))+@fp2*1i
c3=(1+@fp*1i)*log(cabs(exp((0,2)*ang)))+@fp2*1i
elseif @ff==13
c1=(1+@fp*1i)*log(log(exp((0,0)*ang)))+@fp2*1i
c2=(1+@fp*1i)*log(log(exp((0,1)*ang)))+@fp2*1i
c3=(1+@fp*1i)*log(log(exp((0,2)*ang)))+@fp2*1i
elseif @ff==14
c1=(1+@fp*1i)*log(sin(exp((0,0)*ang)))+@fp2*1i
c2=(1+@fp*1i)*log(sin(exp((0,1)*ang)))+@fp2*1i
c3=(1+@fp*1i)*log(sin(exp((0,2)*ang)))+@fp2*1i
elseif @ff==15
c1=(1+@fp*1i)*log(sinh(exp((0,0)*ang)))+@fp2*1i
c2=(1+@fp*1i)*log(sinh(exp((0,1)*ang)))+@fp2*1i
c3=(1+@fp*1i)*log(sinh(exp((0,2)*ang)))+@fp2*1i
elseif @ff==16
c1=(1+@fp*1i)*sqr(flip(exp((0,0)*ang)))+@fp2*1i
c2=(1+@fp*1i)*sqr(flip(exp((0,1)*ang)))+@fp2*1i
c3=(1+@fp*1i)*sqr(flip(exp((0,2)*ang)))+@fp2*1i
elseif @ff==17
c1=(1+@fp*1i)*sin(cabs(exp((0,0)*ang)))+@fp2*1i
c2=(1+@fp*1i)*sin(cabs(exp((0,1)*ang)))+@fp2*1i
c3=(1+@fp*1i)*sin(cabs(exp((0,2)*ang)))+@fp2*1i
elseif @ff==18
c1=(1+@fp*1i)*sinh(flip(exp((0,0)*ang)))+@fp2*1i
c2=(1+@fp*1i)*sinh(flip(exp((0,1)*ang)))+@fp2*1i
c3=(1+@fp*1i)*sinh(flip(exp((0,2)*ang)))+@fp2*1i
elseif @ff==19
c1=(1+@fp*1i)*sinh(cabs(exp((0,0)*ang)))+@fp2*1i
c2=(1+@fp*1i)*sinh(cabs(exp((0,1)*ang)))+@fp2*1i
c3=(1+@fp*1i)*sinh(cabs(exp((0,2)*ang)))+@fp2*1i
endif
r=sqrt(3)/2
pz=@pf(pixel)
c=@js
i=0
return pz
endfunc
private:
complex c1
complex c2
complex c3
float r
complex c
int i
complex func Iterate(complex pz)
if @av==0
if i==0
a=@p1*pz+@p2
pz=pz*a*c
pz=@fn3(a)+(pz*c)
i=1
else
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
endif
i=0
endif
else
if i==0
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
endif
i=1
else
a=@p1*pz+@p2
pz=pz*a*c
pz=@fn3(a)+(pz*c)
i=0
endif
endif
return pz
endfunc

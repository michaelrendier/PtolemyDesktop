class OM_Felix(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
if @v==0
ang=2*pi/3
c1=(1+@fp*1i)*@fn1(@fn2(exp((0,0)*ang)))+@fp2*1i
c2=(1+@fp*1i)*@fn1(@fn2(exp((0,1)*ang)))+@fp2*1i
c3=(1+@fp*1i)*@fn1(@fn2(exp((0,2)*ang)))+@fp2*1i
r=sqrt(3)/2
elseif @v==1
a=pi/3
c1=(1+@fp*1i)*@fn1(@fn2((0,2)))+@fp2*1i
c2=(1+@fp*1i)*@fn1(@fn2(2*(sin(a)+flip(cos(a)))))+@fp2*1i
c3=(1+@fp*1i)*@fn1(@fn2(2*(sin(2*a)+flip(cos(2*a)))))+@fp2*1i
c4=(1+@fp*1i)*@fn1(@fn2((0,-2)))+@fp2*1i
c5=(1+@fp*1i)*@fn1(@fn2(2*(sin(4*a)+flip(cos(4*a)))))+@fp2*1i
c6=(1+@fp*1i)*@fn1(@fn2(2*(sin(5*a)+flip(cos(5*a)))))+@fp2*1i
else
ang=pi/3
c1=(1+@fp*1i)*@fn1(@fn2((0,0)))+@fp2*1i
c2=(1+@fp*1i)*@fn1(@fn2((1,0)))+@fp2*1i
c3=(1+@fp*1i)*@fn1(@fn2(exp((0,1)*ang)))+@fp2*1i
c4=(1+@fp*1i)*@fn1(@fn2(exp((0,2)*ang)))+@fp2*1i
c5=(1+@fp*1i)*@fn1(@fn2(exp((0,3)*ang)))+@fp2*1i
c6=(1+@fp*1i)*@fn1(@fn2(exp((0,4)*ang)))+@fp2*1i
c7=(1+@fp*1i)*@fn1(@fn2(exp((0,5)*ang)))+@fp2*1i
r=0.5
endif
pz=@pf(pz)
return pz
endfunc
private:
complex c1
complex c2
complex c3
complex c4
complex c5
complex c6
complex c7
float r
complex fpixel
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if @v==0
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
endif
elseif @v==1
if cabs(pz-c1)<1
pz=conj(1/(pz-c1))+c1
elseif cabs(pz-c2)<1
pz=conj(1/(pz-c2))+c2
elseif cabs(pz-c3)<1
pz=conj(1/(pz-c3))+c3
elseif cabs(pz-c4)<1
pz=conj(1/(pz-c4))+c4
elseif cabs(pz-c5)<1
pz=conj(1/(pz-c5))+c5
elseif cabs(pz-c6)<1
pz=conj(1/(pz-c6))+c6
endif
else
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
elseif |pz-c4|<r^2
pz=r*conj(r/(pz-c4))+c4
elseif |pz-c5|<r^2
pz=r*conj(r/(pz-c5))+c5
elseif |pz-c6|<r^2
pz=r*conj(r/(pz-c6))+c6
elseif |pz-c7|<r^2
pz=r*conj(r/(pz-c7))+c7
endif
endif
pz=pz+@app*@pf(fpixel)
return pz
endfunc

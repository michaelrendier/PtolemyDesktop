pz=pz+b-z1
if d==0
d=1
endif
if @mj==1
a=pz/(1+a)+(0.3*@p2+0.2*real(3^c2))*a*(1+1/d)
b=a/(1+b)+(0.3*@p3+0.2*imag(3^c2))*b*(1+1/d)
else
a=pz/(1+a)+(0.3*@p2+0.2*c2)*a*(1+1/d)
b=a/(1+b)+(0.3*@p3+0.2*c2)*b*(1+1/d)
endif
d=1+@p4/(a+b)
i=0
endif
else
if i==0
z1=pz
pz=pz*a
pz=pz+b-z1
if d==0
d=1
endif
if @mj==1
a=pz/(1+a)+(0.3*@p2+0.2*real(3^c2))*a*(1+1/d)
b=a/(1+b)+(0.3*@p3+0.2*imag(3^c2))*b*(1+1/d)
else
a=pz/(1+a)+(0.3*@p2+0.2*c2)*a*(1+1/d)
b=a/(1+b)+(0.3*@p3+0.2*c2)*b*(1+1/d)
endif
d=1+@p4/(a+b)
i=1
else
f=pz
pz=f^2+a1+c1
a1=f
i=0
endif
endif
return pz
endfunc

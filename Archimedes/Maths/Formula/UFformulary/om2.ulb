elseif @ff==8
c1=(1+(@fp-0.14)*1i)*flip(sin(exp((0,0)*ang)))+@fp2*1i
c2=(1+(@fp-0.14)*1i)*flip(sin(exp((0,1)*ang)))+@fp2*1i

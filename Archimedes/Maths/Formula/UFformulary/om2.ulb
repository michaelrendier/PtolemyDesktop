class OM_ApolloKleinTransform3(common.ulb:UserTransform) {
public:
func init(complex pz)
ang=2*pi/3
c1=(1+@fp*1i)*@fn1(@fn2(exp((0,0)*ang)))+@fp2*1i
c2=(1+@fp*1i)*@fn1(@fn2(exp((0,1)*ang)))+@fp2*1i
c3=(1+@fp*1i)*@fn1(@fn2(exp((0,2)*ang)))+@fp2*1i
r=sqrt(3)/2
i3=0
a=@p1
b[i3]=4
c[i3]=4
d[i3]=4
f=@p2
g=0.61803398
while i3<4
b[i3]=a
c[i3]=f
d[i3]=1+a*f
i3=i3+1
endwhile
endfunc
complex func Iterate(complex pz)
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
endif
g=g*(1-g)
int i4=trunc(g*4)
if i4==4
i4=3
endif
pz=(pz+b[i4])/(c[i4]*pz+d[i4])
pz=@zp1*@zf(pz)+@zp2
return pz
endfunc
private:
complex c1
complex c2
complex c3
float r
int i3
complex a
complex b[0]
complex c[0]
complex d[0]
complex f
float g
default:
title="Apollo Klein Transform 3"
int param version
caption="Version"
default=100
visible=@version<100
endparam
param p1
caption="Apollo Parameter 1"
default=(-0.25,0)
endparam
param p2
caption="Apollo Parameter 2"
default=(1,0)
endparam
param fp
caption="Klein Parameter 1"
default=0.0
endparam
param fp2
caption="Klein Parameter 2"
default=(0,0)
endparam
func fn1
caption="Klein Function 1"
default=ident()
endfunc
func fn2
caption="Klein Function 2"
default=ident()
endfunc
func zf
caption="Z Function"
default=ident()
endfunc
param zp1
caption="Z Parameter 1"
default=(1,0)
endparam
param zp2
caption="Z Parameter 2"
default=(0,0)
endparam
}

class OM_ApolloTransform(common.ulb:UserTransform) {
;Thanks to Ron Barnett, Morgan l. Owens and Apollonius of Perga
public:
func init(complex pz)
ax=7
ay=7
ar=1
bx=-1
by=0
br=1
cx=1
cy=0
cr=1
h=sqr(ax)+ay^2-ar^2
a=2*(ar-br)
b=2*(ax-bx)
c=2*(ay-by)
d=h-(bx^2+by^2-br^2)
ee=2*(ar-cr)
f=2*(ax-cx)
g=2*(ay-cy)
h=h-(cx^2+cy^2-cr^2)
l=(b*g-c*f)
i=(d*g-c*h)/l
j=(a*g-c*ee)/l
k=(b*h-d*f)/l
l=(b*ee-a*f)/l
m=2*(1-2*l^2)
n=2*(cr+(i-cx)*j+(k-cy)*l)
o=2*(cr^2-(i-cx)^2-(k-cy)^2)
r=sqrt(sqr(n)-m*o)
r1=(-n-r)/m
r2=(-n+r)/m
if r1>0
r=r1
else
r=r2
endif
x=i-j*r
y=k-l*r
if @af==0
ap=(1+@apa*1i)*(real(ax)+flip(ay))+@apa2*1i
bp=(1+@apa*1i)*(real(bx)+flip(by))+@apa2*1i
cp=(1+@apa*1i)*(real(cx)+flip(cy))+@apa2*1i
p=(1+@apa*1i)*(real(x)+flip(y))+@apa2*1i
elseif @af==1
ap=(1+@apa*1i)*flip(real(ax)+flip(ay))+@apa2*1i
bp=(1+@apa*1i)*flip(real(bx)+flip(by))+@apa2*1i
cp=(1+@apa*1i)*flip(real(cx)+flip(cy))+@apa2*1i
p=(1+@apa*1i)*flip(real(x)+flip(y))+@apa2*1i
elseif @af==2
ap=(1+@apa*1i)*abs(real(ax)+flip(ay))+@apa2*1i
bp=(1+@apa*1i)*abs(real(bx)+flip(by))+@apa2*1i
cp=(1+@apa*1i)*abs(real(cx)+flip(cy))+@apa2*1i
p=(1+@apa*1i)*abs(real(x)+flip(y))+@apa2*1i
elseif @af==3
ap=(1+@apa*1i)*sqr(real(ax)+flip(ay))+@apa2*1i
bp=(1+@apa*1i)*sqr(real(bx)+flip(by))+@apa2*1i
cp=(1+@apa*1i)*sqr(real(cx)+flip(cy))+@apa2*1i
p=(1+@apa*1i)*sqr(real(x)+flip(y))+@apa2*1i
elseif @af==4

complex c2
int i
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if @av==0
if i==0
k=pz
pz=pz^@pow+c
c=@p1*@fn1(k)
i=1
else
pz=pz^2+@ap*((pz-1i)/(pz+1i))^@pow2+c2
i=0
endif
else
if i==0
pz=pz^2+@ap*((pz-1i)/(pz+1i))^@pow2+c2
i=1
else
k=pz
pz=pz^@pow+c
c=@p1*@fn1(k)
i=0
endif
endif
return pz
endfunc

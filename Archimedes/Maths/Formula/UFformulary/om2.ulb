}

class OM_ApolloGopalsamy2(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
ax=7
ay=7
ar=1
bx=-1
by=0
br=1
cx=1
cy=0
cr=1
h=sqr(ax)+ay^2-ar^2
a=2*(ar-br)
b=2*(ax-bx)
c=2*(ay-by)
d=h-(bx^2+by^2-br^2)
ee=2*(ar-cr)
f=2*(ax-cx)
g=2*(ay-cy)
h=h-(cx^2+cy^2-cr^2)
l=(b*g-c*f)
i=(d*g-c*h)/l
j=(a*g-c*ee)/l
k=(b*h-d*f)/l
l=(b*ee-a*f)/l
m=2*(1-2*l^2)
n=2*(cr+(i-cx)*j+(k-cy)*l)
o=2*(cr^2-(i-cx)^2-(k-cy)^2)
r=sqrt(sqr(n)-m*o)
r1=(-n-r)/m
r2=(-n+r)/m
if r1>0
r=r1
else
r=r2
endif
x=i-j*r
y=k-l*r
if @apv==0
ap=(1+@ap*1i)*(real(ax)+flip(ay))+@ap2*1i
bp=(1+@ap*1i)*(real(bx)+flip(by))+@ap2*1i
cp=(1+@ap*1i)*(real(cx)+flip(cy))+@ap2*1i
p=(1+@ap*1i)*(real(x)+flip(y))+@ap2*1i
elseif @apv==1
ap=(1+(@ap-0.39)*1i)*flip(cos(real(ax)+flip(ay)))+@ap2*1i
bp=(1+(@ap-0.39)*1i)*flip(cos(real(bx)+flip(by)))+@ap2*1i
cp=(1+(@ap-0.39)*1i)*flip(cos(real(cx)+flip(cy)))+@ap2*1i
p=(1+(@ap-0.39)*1i)*flip(cos(real(x)+flip(y)))+@ap2*1i
elseif @apv==2
ap=(1+@ap*1i)*flip(real(ax)+flip(ay))+(@ap2+0.7)*1i
bp=(1+@ap*1i)*flip(real(bx)+flip(by))+(@ap2+0.7)*1i
cp=(1+@ap*1i)*flip(real(cx)+flip(cy))+(@ap2+0.7)*1i
p=(1+@ap*1i)*flip(real(x)+flip(y))+(@ap2+0.7)*1i
elseif @apv==3
ap=(1+(@ap-0.2)*1i)*abs(real(ax)+flip(ay))+@ap2*1i
bp=(1+(@ap-0.2)*1i)*abs(real(bx)+flip(by))+@ap2*1i
cp=(1+(@ap-0.2)*1i)*abs(real(cx)+flip(cy))+@ap2*1i
p=(1+(@ap-0.2)*1i)*abs(real(x)+flip(y))+@ap2*1i
elseif @apv==4
ap=(1+@ap*1i)*cos(real(ax)+flip(ay))+@ap2*1i
bp=(1+@ap*1i)*cos(real(bx)+flip(by))+@ap2*1i
cp=(1+@ap*1i)*cos(real(cx)+flip(cy))+@ap2*1i
p=(1+@ap*1i)*cos(real(x)+flip(y))+@ap2*1i
elseif @apv==5
ap=(1+@ap*1i)*sqr(cos(real(ax)+flip(ay)))+@ap2*1i
bp=(1+@ap*1i)*sqr(cos(real(bx)+flip(by)))+@ap2*1i
cp=(1+@ap*1i)*sqr(cos(real(cx)+flip(cy)))+@ap2*1i
p=(1+@ap*1i)*sqr(cos(real(x)+flip(y)))+@ap2*1i
endif
pz=@pf(pz)
inte=0
return pz
endfunc
private:
float ax
float ay
float ar
float bx
float by
float br
float cx
float cy
float cr
float h
float a
float b
float c
float d
float ee
float f
float g
float l
float i
float j
float k
float m
float n
float o
float r
float r1
float r2
float x
float y
complex ap
complex bp
complex cp
complex p
complex fpixel
int inte
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if @av==0
if inte==0
if |pz-ap|<ar^2
pz=ar*conj(ar/(pz-ap))+ap
elseif |pz-bp|<br^2
pz=br*conj(br/(pz-bp))+bp
elseif |pz-cp|<cr^2
pz=cr*conj(cr/(pz-cp))+cp
elseif |pz-p|<r^2
pz=r*conj(r/(pz-p))+p
endif
inte=1
else
x1=real(pz)
y1=imag(pz)
x2=3*x1*y1^2-x1^3+@gp
y1=y1^3-3*x1^2*y1
pz=x2+flip(y1)+@app*@pf(fpixel)
inte=0
endif
else
if inte==0
x1=real(pz)
y1=imag(pz)
x2=3*x1*y1^2-x1^3+@gp
y1=y1^3-3*x1^2*y1
pz=x2+flip(y1)+@app*@pf(fpixel)
inte=1
else
if |pz-ap|<ar^2
pz=ar*conj(ar/(pz-ap))+ap
elseif |pz-bp|<br^2
pz=br*conj(br/(pz-bp))+bp
elseif |pz-cp|<cr^2
pz=cr*conj(cr/(pz-cp))+cp
elseif |pz-p|<r^2
pz=r*conj(r/(pz-p))+p
endif
inte=0
endif
endif
return pz
endfunc

kc[i3]=kf
kd[i3]=1+ka*kf
i3=i3+1
endwhile
endfunc
complex func Iterate(complex pz)
if(|pz-ap|<ar^2)
pz=ar*conj(ar/(pz-ap))+ap
elseif(|pz-bp|<br^2)
pz=br*conj(br/(pz-bp))+bp
elseif(|pz-cp|<cr^2)
pz=cr*conj(cr/(pz-cp))+cp
elseif(|pz-p|<r^2)
pz=r*conj(r/(pz-p))+p
endif
kg=kg*(1-kg)
int i4=trunc(kg*4)
if i4==4
i4=3
endif
pz=(pz+kb[i4])/(kc[i4]*pz+kd[i4])
pz=@zp1*@zf(pz)+@zp2
return pz
endfunc

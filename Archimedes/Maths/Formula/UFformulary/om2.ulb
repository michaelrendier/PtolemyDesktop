elseif @ff==7
c1=(1+@fp*1i)*flip(log(exp((0,0)*ang)))+(@fp2+(0,0.6))*1i
c2=(1+@fp*1i)*flip(log(exp((0,1)*ang)))+(@fp2+(0,0.6))*1i

complex fpixel
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if @av==0
if i==0
if |pz-c1b|<rb^2
pz=rb*conj(rb/(pz-c1b))+c1b
elseif |pz-c2b|<rb^2
pz=rb*conj(rb/(pz-c2b))+c2b
elseif |pz-c3b|<rb^2
pz=rb*conj(rb/(pz-c3b))+c3b
elseif |pz-c4b|<rb^2
pz=rb*conj(rb/(pz-c4b))+c4b
elseif |pz-c5b|<rb^2
pz=rb*conj(rb/(pz-c5b))+c5b
elseif |pz-c6b|<rb^2
pz=rb*conj(rb/(pz-c6b))+c6b
elseif |pz-c7b|<rb^2
pz=rb*conj(rb/(pz-c7b))+c7b
endif
pz=pz+@app1*@pf(fpixel)
i=1
elseif i==1
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
endif
pz=pz+@app2*@pf(fpixel)
i=2
else
if cabs(pz-c1c)<1
pz=conj(1/(pz-c1c))+c1c
elseif cabs(pz-c2c)<1
pz=conj(1/(pz-c2c))+c2c
elseif cabs(pz-c3c)<1
pz=conj(1/(pz-c3c))+c3c
elseif cabs(pz-c4c)<1
pz=conj(1/(pz-c4c))+c4c
elseif cabs(pz-c5c)<1
pz=conj(1/(pz-c5c))+c5c
elseif cabs(pz-c6c)<1
pz=conj(1/(pz-c6c))+c6c
endif
pz=pz+@app3*@pf(fpixel)
i=0
endif
elseif @av==1
if i==0
if |pz-c1b|<rb^2
pz=rb*conj(rb/(pz-c1b))+c1b
elseif |pz-c2b|<rb^2
pz=rb*conj(rb/(pz-c2b))+c2b
elseif |pz-c3b|<rb^2
pz=rb*conj(rb/(pz-c3b))+c3b
elseif |pz-c4b|<rb^2
pz=rb*conj(rb/(pz-c4b))+c4b
elseif |pz-c5b|<rb^2
pz=rb*conj(rb/(pz-c5b))+c5b
elseif |pz-c6b|<rb^2
pz=rb*conj(rb/(pz-c6b))+c6b
elseif |pz-c7b|<rb^2
pz=rb*conj(rb/(pz-c7b))+c7b
endif

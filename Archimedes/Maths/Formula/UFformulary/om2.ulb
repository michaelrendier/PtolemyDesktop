class OM_FelixandNikolai(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
ang=2*pi/3
c1=(1+@fp*1i)*@fn1(exp((0,0)*ang))+@fp3*1i
c2=(1+@fp*1i)*@fn1(exp((0,1)*ang))+@fp3*1i
c3=(1+@fp*1i)*@fn1(exp((0,2)*ang))+@fp3*1i
r=sqrt(3)/2
ang2=pi/3
c1b=(1+@fp2*1i)*@fn2((0,0))+@fp4*1i
c2b=(1+@fp2*1i)*@fn2((1,0))+@fp4*1i
c3b=(1+@fp2*1i)*@fn2(exp((0,1)*ang2))+@fp4*1i
c4=(1+@fp2*1i)*@fn2(exp((0,2)*ang2))+@fp4*1i
c5=(1+@fp2*1i)*@fn2(exp((0,3)*ang2))+@fp4*1i
c6=(1+@fp2*1i)*@fn2(exp((0,4)*ang2))+@fp4*1i
c7=(1+@fp2*1i)*@fn2(exp((0,5)*ang2))+@fp4*1i
r2=0.5
pz=@pf(pz)
i=0
return pz

elseif @af==13
ap=(1+@apa*1i)*(flip(real(ax)+flip(ay))+sqr(real(ax)+flip(ay)))+@apa2*1i
bp=(1+@apa*1i)*(flip(real(bx)+flip(by))+sqr(real(bx)+flip(by)))+@apa2*1i

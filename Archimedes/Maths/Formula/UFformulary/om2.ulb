class OM_ApolloMagnetica(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
ax=7
ay=7
ar=1
bx=-1
by=0
br=1
cx=1
cy=0
cr=1
h=sqr(ax)+ay^2-ar^2
a=2*(ar-br)
b=2*(ax-bx)
c=2*(ay-by)
d=h-(bx^2+by^2-br^2)
ee=2*(ar-cr)
f=2*(ax-cx)
g=2*(ay-cy)
h=h-(cx^2+cy^2-cr^2)
l=(b*g-c*f)
i=(d*g-c*h)/l
j=(a*g-c*ee)/l
k=(b*h-d*f)/l
l=(b*ee-a*f)/l
m=2*(1-2*l^2)
n=2*(cr+(i-cx)*j+(k-cy)*l)
o=2*(cr^2-(i-cx)^2-(k-cy)^2)
r=sqrt(sqr(n)-m*o)
r1=(-n-r)/m
r2=(-n+r)/m
if r1>0
r=r1
else
r=r2
endif
x=i-j*r
y=k-l*r
ap=(1+@apa*1i)*sqr(real(ax)+flip(ay))+@apa2*1i
bp=(1+@apa*1i)*sqr(real(bx)+flip(by))+@apa2*1i
cp=(1+@apa*1i)*sqr(real(cx)+flip(cy))+@apa2*1i
p=(1+@apa*1i)*sqr(real(x)+flip(y))+@apa2*1i
pz=@pf(pz)
inte=0
return pz
endfunc
private:
int inte
float ax
float ay
float ar
float bx
float by
float br
float cx
float cy
float cr
float h
float a
float b
float c
float d
float ee
float f
float g
float l
float i
float j
float k
float m
float n
float o
float r
float r1
float r2
float x
float y
complex ap
complex bp
complex cp
complex p
complex fpixel
complex func Iterate(complex pz)
if @zv==0
pz=@zp1*pz+@zp2
elseif @zv==1
pz=@zp1*recip(pz)+@zp2
else
pz=@zp1*flip(pz)+@zp2
endif
if @av==0
if inte==0
if(|pz-ap|<ar^2)
pz=ar*conj(ar/(pz-ap))+ap
elseif(|pz-bp|<br^2)
pz=br*conj(br/(pz-bp))+bp
elseif(|pz-cp|<cr^2)
pz=cr*conj(cr/(pz-cp))+cp
elseif(|pz-p|<r^2)
pz=r*conj(r/(pz-p))+p
endif
pz=pz+@app*@pf(fpixel)
inte=1
else
pz=((pz^2+@p1-1)/(2*pz+@p1-2))^2
inte=0
endif
else
if inte==0
pz=((pz^2+(@p1+0.25)-1)/(2*pz+(@p1+0.25)-2))^2
inte=1
else
if(|pz-ap|<ar^2)
pz=ar*conj(ar/(pz-ap))+ap
elseif(|pz-bp|<br^2)
pz=br*conj(br/(pz-bp))+bp
elseif(|pz-cp|<cr^2)
pz=cr*conj(cr/(pz-cp))+cp
elseif(|pz-p|<r^2)
pz=r*conj(r/(pz-p))+p
endif
pz=pz+@app*@pf(fpixel)
inte=0
endif
endif
return pz
endfunc
default:
title="Apollo Magnetica"
param version
caption="Version"
default=100
visible=@version<100
endparam
param av
caption="Alt Variant"
enum="1""2"
endparam
param zv
caption="Z Variant"
enum="1""2""3"
endparam
param p1
caption="Magnet Parameter"
default=(2,0)
endparam
param apa
caption="Apollo Parameter 1"
default=0.0
endparam
param apa2
caption="Apollo Parameter 2"
default=(0,2)
endparam
func pf
caption="Pixel Function"
default=ident()
endfunc
param zp1
caption="Z Parameter 1"
default=(-1.07,0)
endparam
param zp2
caption="Z Parameter 2"
default=(0,0)
endparam
param app
caption="Distortion"
default=(0,0)
endparam
param p_power
visible=false
endparam
float param p_bailout
caption="Bailout"
default=40.0
exponential=true
endparam
}

class OM_ApolloStohminy(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
ax=7
ay=7
ar=1
bx=-1
by=0
br=1
cx=1
cy=0
cr=1
h=sqr(ax)+ay^2-ar^2
a=2*(ar-br)
b=2*(ax-bx)
c=2*(ay-by)
d=h-(bx^2+by^2-br^2)
ee=2*(ar-cr)
f=2*(ax-cx)
g=2*(ay-cy)
h=h-(cx^2+cy^2-cr^2)
l=(b*g-c*f)
i=(d*g-c*h)/l
j=(a*g-c*ee)/l
k=(b*h-d*f)/l
l=(b*ee-a*f)/l
m=2*(1-2*l^2)
n=2*(cr+(i-cx)*j+(k-cy)*l)
o=2*(cr^2-(i-cx)^2-(k-cy)^2)
r=sqrt(sqr(n)-m*o)
r1=(-n-r)/m
r2=(-n+r)/m
if r1>0
r=r1
else
r=r2
endif
x=i-j*r
y=k-l*r
if @apv==0
ap=(1+@ap*1i)*(real(ax)+flip(ay))+@ap2*1i
bp=(1+@ap*1i)*(real(bx)+flip(by))+@ap2*1i
cp=(1+@ap*1i)*(real(cx)+flip(cy))+@ap2*1i
p=(1+@ap*1i)*(real(x)+flip(y))+@ap2*1i
elseif @apv==1
ap=(1+@ap*1i)*cos(real(ax)+flip(ay))+(@ap2+1)*1i
bp=(1+@ap*1i)*cos(real(bx)+flip(by))+(@ap2+1)*1i
cp=(1+@ap*1i)*cos(real(cx)+flip(cy))+(@ap2+1)*1i
p=(1+@ap*1i)*cos(real(x)+flip(y))+(@ap2+1)*1i
elseif @apv==2
ap=(1+(@ap+1)*1i)*flip(real(ax)+flip(ay))+@ap2*1i
bp=(1+(@ap+1)*1i)*flip(real(bx)+flip(by))+@ap2*1i
cp=(1+(@ap+1)*1i)*flip(real(cx)+flip(cy))+@ap2*1i
p=(1+(@ap+1)*1i)*flip(real(x)+flip(y))+@ap2*1i
else
ap=(1+@ap*1i)*sqr(flip(real(ax)+flip(ay)))+@ap2*1i
bp=(1+@ap*1i)*sqr(flip(real(bx)+flip(by)))+@ap2*1i
cp=(1+@ap*1i)*sqr(flip(real(cx)+flip(cy)))+@ap2*1i
p=(1+@ap*1i)*sqr(flip(real(x)+flip(y)))+@ap2*1i
endif
pz=@pf(pz)
inte=0
return pz
endfunc
private:
float ax
float ay
float ar
float bx
float by
float br
float cx
float cy
float cr
float h
float a
float b
float c
float d
float ee
float f
float g
float l
float i
float j
float k
float m
float n
float o
float r
float r1
float r2
float x
float y
complex ap
complex bp
complex cp
complex p
int inte
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if @av==0
if inte==0
if |pz-ap|<ar^2
pz=ar*conj(ar/(pz-ap))+ap
elseif |pz-bp|<br^2
pz=br*conj(br/(pz-bp))+bp
elseif |pz-cp|<cr^2
pz=cr*conj(cr/(pz-cp))+cp
elseif |pz-p|<r^2
pz=r*conj(r/(pz-p))+p
endif
inte=1
else
pz=@p1*(pz^2+@p2*pz+c)^3/(27*pz^4)
inte=0
endif
else
if inte==0
pz=@p1*(pz^2+@p2*pz+c)^3/(27*pz^4)
inte=1
else
if |pz-ap|<ar^2
pz=ar*conj(ar/(pz-ap))+ap
elseif |pz-bp|<br^2
pz=br*conj(br/(pz-bp))+bp
elseif |pz-cp|<cr^2
pz=cr*conj(cr/(pz-cp))+cp
elseif |pz-p|<r^2
pz=r*conj(r/(pz-p))+p
endif
inte=0
endif
endif
return pz
endfunc
default:
title="Apollo Stohminy"
param version
caption="Version"
default=100
visible=@version<100
endparam
param av
caption="Alt Variant"
enum="1""2"
endparam
param p1
caption="Stohminy Parameter 1"
default=(-0.3,0)
endparam
param p2
caption="Stohminy Parameter 2"
default=(2.25,0)
endparam
param apv
caption="Apollo Variant"
enum="1""2""3""4"
endparam
param ap
caption="Apollo Parameter 1"
default=0.0
endparam
param ap2
caption="Apollo Parameter 2"
default=(0,0)
endparam
func pf
caption="Pixel Function"
default=ident()
endfunc
param zp1
caption="Z Parameter 1"
default=(2.75,0)
endparam
param zp2
caption="Z Parameter 2"
default=(0,0)
endparam
param p_power
visible=false
endparam
float param p_bailout
caption="Bailout"
default=4000.0
exponential=true
endparam
}

class OM_ApolloTransform2(common.ulb:UserTransform) {
;Thanks to Ron Barnett, Morgan l. Owens, Paul Dervyshire and Apollonius of Perga
public:
func init(complex pz)
ax=7
ay=7
ar=1
bx=-1
by=0
br=1
cx=1
cy=0
cr=1
h=sqr(ax)+ay^2-ar^2
a=2*(ar-br)
b=2*(ax-bx)
c=2*(ay-by)
d=h-(bx^2+by^2-br^2)
ee=2*(ar-cr)
f=2*(ax-cx)
g=2*(ay-cy)
h=h-(cx^2+cy^2-cr^2)
l=(b*g-c*f)
i=(d*g-c*h)/l
j=(a*g-c*ee)/l
k=(b*h-d*f)/l
l=(b*ee-a*f)/l
m=2*(1-2*l^2)
n=2*(cr+(i-cx)*j+(k-cy)*l)
o=2*(cr^2-(i-cx)^2-(k-cy)^2)
r=sqrt(sqr(n)-m*o)
r1=(-n-r)/m
r2=(-n+r)/m

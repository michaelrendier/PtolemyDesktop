class OM_ArthurversustheHydra(common.ulb:DivergentFormula) {
;Thanks to Noel Giffin and Arthur Cayley
public:
complex func Init(complex pz)
fpixel=pz
if @mj==1
pz=@pf(pz)
c=@js
c2=@js2
else
pz=@sp
c=@pf(fpixel)
c2=@pf(fpixel)
endif
i=0
return pz
endfunc

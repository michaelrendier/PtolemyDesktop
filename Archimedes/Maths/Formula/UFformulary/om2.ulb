c3=(1+@fp*1i)*sinh(sinh(exp((0,2)*ang)))+(@fp2+(0,0.20278))*1i
endif
r=sqrt(3)/2
pz=@pf(pixel)
c=@js
a=(0,0)
b=@p1
i2=1
i=0
return pz
endfunc
private:
complex c1
complex c2
complex c3
float r
complex c
int i
int i2
float b
complex a
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if @av==0
if i==0
a=(sin(pz+b))^(2+i2)+(cos(pz+b))^(2+i2)
pz=a*(pz^@pow+c)
i2=i2+1
i=1
else
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
endif
i=0
endif
else
if i==0
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
endif
i=1
else
a=(sin(pz+b))^(2+i2)+(cos(pz+b))^(2+i2)
pz=a*(pz^@pow+c)
i2=i2+1
i=0
endif
endif
return pz
endfunc

elseif @af==2
ap=(1+@apa*1i)*abs(real(ax)+flip(ay))+@apa2*1i
bp=(1+@apa*1i)*abs(real(bx)+flip(by))+@apa2*1i
cp=(1+@apa*1i)*abs(real(cx)+flip(cy))+@apa2*1i
p=(1+@apa*1i)*abs(real(x)+flip(y))+@apa2*1i
elseif @af==3
ap=(1+@apa*1i)*sqr(real(ax)+flip(ay))+@apa2*1i
bp=(1+@apa*1i)*sqr(real(bx)+flip(by))+@apa2*1i
cp=(1+@apa*1i)*sqr(real(cx)+flip(cy))+@apa2*1i
p=(1+@apa*1i)*sqr(real(x)+flip(y))+@apa2*1i
elseif @af==4
ap=(1+@apa*1i)*cos(real(ax)+flip(ay))+@apa2*1i
bp=(1+@apa*1i)*cos(real(bx)+flip(by))+@apa2*1i
cp=(1+@apa*1i)*cos(real(cx)+flip(cy))+@apa2*1i
p=(1+@apa*1i)*cos(real(x)+flip(y))+@apa2*1i
elseif @af==5
ap=(1+@apa*1i)*flip(conj(real(ax)+flip(ay)))+@apa2*1i
bp=(1+@apa*1i)*flip(conj(real(bx)+flip(by)))+@apa2*1i
cp=(1+@apa*1i)*flip(conj(real(cx)+flip(cy)))+@apa2*1i
p=(1+@apa*1i)*flip(conj(real(x)+flip(y)))+@apa2*1i
elseif @af==6
ap=(1+@apa*1i)*flip(abs(real(ax)+flip(ay)))+@apa2*1i
bp=(1+@apa*1i)*flip(abs(real(bx)+flip(by)))+@apa2*1i
cp=(1+@apa*1i)*flip(abs(real(cx)+flip(cy)))+@apa2*1i
p=(1+@apa*1i)*flip(abs(real(x)+flip(y)))+@apa2*1i
elseif @af==7
ap=(1+@apa*1i)*flip(sqr(real(ax)+flip(ay)))+@apa2*1i
bp=(1+@apa*1i)*flip(sqr(real(bx)+flip(by)))+@apa2*1i
cp=(1+@apa*1i)*flip(sqr(real(cx)+flip(cy)))+@apa2*1i
p=(1+@apa*1i)*flip(sqr(real(x)+flip(y)))+@apa2*1i
elseif @af==8
ap=(1+@apa*1i)*flip(cos(real(ax)+flip(ay)))+@apa2*1i
bp=(1+@apa*1i)*flip(cos(real(bx)+flip(by)))+@apa2*1i
cp=(1+@apa*1i)*flip(cos(real(cx)+flip(cy)))+@apa2*1i
p=(1+@apa*1i)*flip(cos(real(x)+flip(y)))+@apa2*1i
elseif @af==9

class OM_numma(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
if @mj==0
pz=@sp
c=@pf(fpixel)
else
pz=@pf(pz)
c=@js
endif
inte=0
i=0
i2=1
i3=1
return pz
endfunc
private:
complex c
int inte
int i
int i2
int i3
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if inte==0
i=i+1
if i!=i3
pz=pz^2+c
else
i2=i2+1
i3=i2*i2
pz=pz+c
endif
inte=1
else
pz=@p1*(pz^2-pz+@p3)^3/(pz^2*(pz-@p3)^2)+@p2
inte=0
endif
return pz
endfunc

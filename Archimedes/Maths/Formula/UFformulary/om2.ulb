elseif |pz-c6|<r2^2
pz=r2*conj(r2/(pz-c6))+c6
elseif |pz-c7|<r2^2
pz=r2*conj(r2/(pz-c7))+c7
endif
i=1
elseif i==1
pz=pz^@pow+@p1*exp(-((pz-@p2)^2/@p3^2))+c
i=2
else
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
endif
i=0
endif
endif
return pz
endfunc

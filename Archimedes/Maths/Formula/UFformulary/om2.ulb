class OM_Incremodus(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
if @mj==0
pz=@sp
c=@pf(fpixel)
else
pz=@pf(pz)
c=@js
endif
i=0
a=0.0
c1=cos(@p1)+1i*sin(@p1)
return pz
endfunc
private:
complex c
int i
float a
complex c1
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if i>=a
c=pz+c*c1
a=a+@p2
i=0
endif
i=i+1
pz=pz^@pow+c
return pz
endfunc

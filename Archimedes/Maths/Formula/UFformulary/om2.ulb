pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
endif
i=1
else
pz=@p1*pz^2*(@p3+pz^2)/(pz*(@p2+pz))+@app*@pf(fpixel)
i=0
endif
endif
return pz
endfunc

class OM_LiberAvisIgneae(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
z1=@pf(pz)
z2=@pf(pz)
pz=(0,0)
a=(0,0)
b=(0,0)
i=0
return pz
endfunc
private:
complex z1
complex z2
complex a
complex b
int i
complex fpixel
complex func Iterate(complex pz)
pz=pz+@p5
if @mj==1
if i==0
pz=pz+@p1*z1+(1-@p1)*z2
pz=pz*z2+@p2
z1=z2
z2=pz
i=1
else
b=pz^@pow1+pz^@pow2*@p3+@p4*a
a=pz
pz=b
i=0
endif
else
if i==0
pz=pz+@p1*z1+(1-@p1)*z2
pz=pz*z2+@p2*@pf(fpixel)
z1=z2
z2=pz
i=1
else
b=pz^@pow1+pz^@pow2*@p3*@pf(fpixel)+@p4*a
a=pz
pz=b
i=0
endif
endif
return pz
endfunc

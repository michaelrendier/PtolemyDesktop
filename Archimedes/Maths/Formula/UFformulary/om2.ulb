class OM_ApolloTLP(common.ulb:DivergentFormula) {
;Thanks to Chris M.Thomasson, Ron Barnett, Morgan L. Owens and Apollonius of Perga.
public:
complex func Init(complex pz)
ax=7
ay=7
ar=1
bx=-1
by=0
br=1
cx=1
cy=0
cr=1
h=sqr(ax)+ay^2-ar^2
a=2*(ar-br)
b=2*(ax-bx)
c=2*(ay-by)
d=h-(bx^2+by^2-br^2)
ee=2*(ar-cr)
f=2*(ax-cx)
g=2*(ay-cy)
h=h-(cx^2+cy^2-cr^2)
l=(b*g-c*f)
i=(d*g-c*h)/l
j=(a*g-c*ee)/l
k=(b*h-d*f)/l
l=(b*ee-a*f)/l
m=2*(1-2*l^2)
n=2*(cr+(i-cx)*j+(k-cy)*l)
o=2*(cr^2-(i-cx)^2-(k-cy)^2)
r=sqrt(sqr(n)-m*o)
r1=(-n-r)/m
r2=(-n+r)/m
if r1>0
r=r1
else
r=r2
endif
x=i-j*r
y=k-l*r
ap=(1+@ap)*sqr(flip(real(ax)+flip(ay)))+@ap2
bp=(1+@ap)*sqr(flip(real(bx)+flip(by)))+@ap2
cp=(1+@ap)*sqr(flip(real(cx)+flip(cy)))+@ap2
p=(1+@ap)*sqr(flip(real(x)+flip(y)))+@ap2
pz=@pf(pz)
inte=0
nnn=@p5
return pz
endfunc

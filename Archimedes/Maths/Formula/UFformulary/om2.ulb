class OM_StoneofAntinomia1(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
if @mj==1
pz=@pf(pz)
c1=@js1
c2=@js2
else
pz=@sp
c1=@p1*@pf(fpixel)
c2=@p2*@pf(fpixel)
endif
a=pz
i=0
return pz
endfunc
private:
complex a
complex c1
complex c2
int i
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if @av==0
if i==0
b=pz
pz=b^2+a+c1
a=b
i=1
else
x=real(pz)
y=imag(pz)
d=3*x*y^2-x^3+c2
y=y^3-3*x^2*y
pz=d+flip(y)
i=0
endif
else
if i==0
x=real(pz)
y=imag(pz)
d=3*x*y^2-x^3+c2
y=y^3-3*x^2*y
pz=d+flip(y)
i=1
else
b=pz
pz=b^2+a+c1
a=b
i=0
endif
endif
return pz
endfunc

cp=(1+@apa*1i)*(flip(real(cx)+flip(cy))^3-flip(real(cx)+flip(cy)))+@apa2*1i
p=(1+@apa*1i)*(flip(real(x)+flip(y))^3-flip(real(x)+flip(y)))+@apa2*1i
endif
endfunc
private:
complex c1
complex c2
complex c3
float fkr
float ax
float ay
float ar
float bx
float by
float br
float cx
float cy
float cr
float h
float a
float b
float c
float d
float ee
float f
float g
float l
float i
float j
float k
float m
float n
float o
float r
float r1
float r2
float x
float y
complex ap
complex bp
complex cp
complex p
complex func Iterate(complex pz)
if @av==0
if |pz-c1|<fkr^2
pz=fkr*conj(fkr/(pz-c1))+c1
elseif |pz-c2|<fkr^2
pz=fkr*conj(fkr/(pz-c2))+c2
elseif |pz-c3|<fkr^2
pz=fkr*conj(fkr/(pz-c3))+c3
endif
if(|pz-ap|<ar^2)
pz=ar*conj(ar/(pz-ap))+ap
elseif(|pz-bp|<br^2)
pz=br*conj(br/(pz-bp))+bp
elseif(|pz-cp|<cr^2)
pz=cr*conj(cr/(pz-cp))+cp
elseif(|pz-p|<r^2)
pz=r*conj(r/(pz-p))+p
endif
else
if(|pz-ap|<ar^2)
pz=ar*conj(ar/(pz-ap))+ap
elseif(|pz-bp|<br^2)
pz=br*conj(br/(pz-bp))+bp
elseif(|pz-cp|<cr^2)
pz=cr*conj(cr/(pz-cp))+cp
elseif(|pz-p|<r^2)
pz=r*conj(r/(pz-p))+p
endif
if |pz-c1|<fkr^2
pz=fkr*conj(fkr/(pz-c1))+c1
elseif |pz-c2|<fkr^2
pz=fkr*conj(fkr/(pz-c2))+c2
elseif |pz-c3|<fkr^2
pz=fkr*conj(fkr/(pz-c3))+c3
endif
endif
pz=@zp1*@zf(pz)+@zp2
return pz
endfunc
default:
title="Apollo Klein Transform"
int param version
caption="Version"
default=100
visible=@version<100
endparam
param av
caption="Alt Variant"
enum="1""2"
endparam
param fkv
caption="Klein Function"
enum="ident""flip""cabs""log""sin""sinh"\
"flipcabs""fliplog""flipsin""flipsinh""cabslog"\
"cabssin""cabssinh""logflip""loglog""sinflip"\
"sincabs""sinsin""sinsinh""sinhflip""sinhcabs"
endparam
param af
caption="Apollo Function"
enum="ident""flip""abs""sqr""cos""flipconj""flipabs"\
"flipsqr""flipcos""sqr cos""cube""ident+recip""ident+flip"\
"flip+sqr""flip+cos""sqr+exp""cos+exp"\
"flip-sqr""flip-cos""cos-exp""ident-cos"\
"cube-cos""expcube+flip""coscube+sqr""flipcube-flip"
endparam
param fp
caption="Klein Parameter 1"
default=0.0
endparam
param fp2
caption="Klein Parameter 2"
default=(0,0)
endparam
param apa
caption="Apollo Parameter 1"
default=0.0
endparam
param apa2
caption="Apollo Parameter 2"
default=(0,0)
endparam
func zf
caption="Z Function"
default=ident()
endfunc
param zp1
caption="Z Parameter 1"
default=(1,0)
endparam
param zp2
caption="Z Parameter 2"
default=(0,0)
endparam
}

class OM_ApolloKleinTransform2(common.ulb:UserTransform) {
;Thanks to Ron Barnett, Morgan l. Owens, Felix Klein and Apollonius of Perga
public:
func init(complex pz)
ang2=pi/3
if @fkv==0
c1b=(1+@fp1*1i)*((0,0))+@fp2*1i
c2b=(1+@fp1*1i)*((1,0))+@fp2*1i
c3b=(1+@fp1*1i)*(exp((0,1)*ang2))+@fp2*1i
c4b=(1+@fp1*1i)*(exp((0,2)*ang2))+@fp2*1i
c5b=(1+@fp1*1i)*(exp((0,3)*ang2))+@fp2*1i
c6b=(1+@fp1*1i)*(exp((0,4)*ang2))+@fp2*1i
c7b=(1+@fp1*1i)*(exp((0,5)*ang2))+@fp2*1i
elseif @fkv==1
c1b=(1+@fp1*1i)*flip((0,0))+@fp2*1i
c2b=(1+@fp1*1i)*flip((1,0))+@fp2*1i
c3b=(1+@fp1*1i)*flip(exp((0,1)*ang2))+@fp2*1i
c4b=(1+@fp1*1i)*flip(exp((0,2)*ang2))+@fp2*1i
c5b=(1+@fp1*1i)*flip(exp((0,3)*ang2))+@fp2*1i
c6b=(1+@fp1*1i)*flip(exp((0,4)*ang2))+@fp2*1i
c7b=(1+@fp1*1i)*flip(exp((0,5)*ang2))+@fp2*1i
elseif @fkv==2
c1b=(1+@fp1*1i)*cabs((0,0))+@fp2*1i
c2b=(1+@fp1*1i)*cabs((1,0))+@fp2*1i
c3b=(1+@fp1*1i)*cabs(exp((0,1)*ang2))+@fp2*1i
c4b=(1+@fp1*1i)*cabs(exp((0,2)*ang2))+@fp2*1i
c5b=(1+@fp1*1i)*cabs(exp((0,3)*ang2))+@fp2*1i
c6b=(1+@fp1*1i)*cabs(exp((0,4)*ang2))+@fp2*1i
c7b=(1+@fp1*1i)*cabs(exp((0,5)*ang2))+@fp2*1i
elseif @fkv==3
c1b=(1+@fp1*1i)*sqr((0,0))+@fp2*1i
c2b=(1+@fp1*1i)*sqr((1,0))+@fp2*1i
c3b=(1+@fp1*1i)*sqr(exp((0,1)*ang2))+@fp2*1i
c4b=(1+@fp1*1i)*sqr(exp((0,2)*ang2))+@fp2*1i
c5b=(1+@fp1*1i)*sqr(exp((0,3)*ang2))+@fp2*1i
c6b=(1+@fp1*1i)*sqr(exp((0,4)*ang2))+@fp2*1i
c7b=(1+@fp1*1i)*sqr(exp((0,5)*ang2))+@fp2*1i
elseif @fkv==4
c1b=(1+@fp1*1i)*flip(cabs((0,0)))+@fp2*1i
c2b=(1+@fp1*1i)*flip(cabs((1,0)))+@fp2*1i
c3b=(1+@fp1*1i)*flip(cabs(exp((0,1)*ang2)))+@fp2*1i
c4b=(1+@fp1*1i)*flip(cabs(exp((0,2)*ang2)))+@fp2*1i
c5b=(1+@fp1*1i)*flip(cabs(exp((0,3)*ang2)))+@fp2*1i
c6b=(1+@fp1*1i)*flip(cabs(exp((0,4)*ang2)))+@fp2*1i
c7b=(1+@fp1*1i)*flip(cabs(exp((0,5)*ang2)))+@fp2*1i
elseif @fkv==5
c1b=(1+@fp1*1i)*flip(sqr((0,0)))+@fp2*1i
c2b=(1+@fp1*1i)*flip(sqr((1,0)))+@fp2*1i
c3b=(1+@fp1*1i)*flip(sqr(exp((0,1)*ang2)))+@fp2*1i
c4b=(1+@fp1*1i)*flip(sqr(exp((0,2)*ang2)))+@fp2*1i
c5b=(1+@fp1*1i)*flip(sqr(exp((0,3)*ang2)))+@fp2*1i
c6b=(1+@fp1*1i)*flip(sqr(exp((0,4)*ang2)))+@fp2*1i
c7b=(1+@fp1*1i)*flip(sqr(exp((0,5)*ang2)))+@fp2*1i
elseif @fkv==6
c1b=(1+@fp1*1i)*((0,0))^3+@fp2*1i
c2b=(1+@fp1*1i)*((1,0))^3+@fp2*1i
c3b=(1+@fp1*1i)*(exp((0,1)*ang2))^3+@fp2*1i
c4b=(1+@fp1*1i)*(exp((0,2)*ang2))^3+@fp2*1i
c5b=(1+@fp1*1i)*(exp((0,3)*ang2))^3+@fp2*1i
c6b=(1+@fp1*1i)*(exp((0,4)*ang2))^3+@fp2*1i
c7b=(1+@fp1*1i)*(exp((0,5)*ang2))^3+@fp2*1i
elseif @fkv==7
c1b=(1+@fp1*1i)*flip((0,0))^3+@fp2*1i
c2b=(1+@fp1*1i)*flip((1,0))^3+@fp2*1i
c3b=(1+@fp1*1i)*flip(exp((0,1)*ang2))^3+@fp2*1i
c4b=(1+@fp1*1i)*flip(exp((0,2)*ang2))^3+@fp2*1i
c5b=(1+@fp1*1i)*flip(exp((0,3)*ang2))^3+@fp2*1i
c6b=(1+@fp1*1i)*flip(exp((0,4)*ang2))^3+@fp2*1i
c7b=(1+@fp1*1i)*flip(exp((0,5)*ang2))^3+@fp2*1i
endif
r3=0.5
ax=7
ay=7
ar=1
bx=-1
by=0
br=1
cx=1
cy=0
cr=1
h=sqr(ax)+ay^2-ar^2
a=2*(ar-br)
b=2*(ax-bx)
c=2*(ay-by)
d=h-(bx^2+by^2-br^2)
ee=2*(ar-cr)
f=2*(ax-cx)
g=2*(ay-cy)
h=h-(cx^2+cy^2-cr^2)
l=(b*g-c*f)
i=(d*g-c*h)/l
j=(a*g-c*ee)/l
k=(b*h-d*f)/l
l=(b*ee-a*f)/l
m=2*(1-2*l^2)
n=2*(cr+(i-cx)*j+(k-cy)*l)
o=2*(cr^2-(i-cx)^2-(k-cy)^2)
r=sqrt(sqr(n)-m*o)
r1=(-n-r)/m
r2=(-n+r)/m
if r1>0
r=r1
else
r=r2
endif
x=i-j*r
y=k-l*r
if @af==0
ap=(1+@apa*1i)*(real(ax)+flip(ay))+@apa2*1i
bp=(1+@apa*1i)*(real(bx)+flip(by))+@apa2*1i
cp=(1+@apa*1i)*(real(cx)+flip(cy))+@apa2*1i
p=(1+@apa*1i)*(real(x)+flip(y))+@apa2*1i
elseif @af==1
ap=(1+@apa*1i)*flip(real(ax)+flip(ay))+@apa2*1i

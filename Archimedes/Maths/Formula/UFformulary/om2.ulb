class OM_MoebiusKleinMod(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
ang=2*pi/3
c1=(1+@fp*1i)*@fn1(@fn2(exp((0,0)*ang)))+@fp2*1i
c2=(1+@fp*1i)*@fn1(@fn2(exp((0,1)*ang)))+@fp2*1i
c3=(1+@fp*1i)*@fn1(@fn2(exp((0,2)*ang)))+@fp2*1i
r=sqrt(3)/2
pz=@pf(pz)
i=0
return pz
endfunc
private:
complex c1
complex c2
complex c3
float r
int i
complex fpixel
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if @av==0
if i==0
pz=pz^2+@app*@pf(fpixel)
pz=(@p1*pz+@p2)/(@p3*pz+@p4)
i=1
else
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
endif
i=0
endif
else
if i==0
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
endif
i=1
else
pz=pz^2+@app*@pf(fpixel)
pz=(@p1*pz+@p2)/(@p3*pz+@p4)
i=0
endif
endif
return pz
endfunc

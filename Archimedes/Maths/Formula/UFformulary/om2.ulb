public:
complex func Init(complex pz)
fpixel=pz
i=0
k1=0.0
complex k2=(0,0)
while i<#maxiter
k2=k2^2+@p1
k3[i]=k2*@p2
k4=cabs(k3[i])
if k4>k1
k1=k4
endif
i=i+1
endwhile
i2=0
i3=0
if @mj==0
pz=@sp
c1=@pp1*@pf(fpixel)
c2=@pp2*@pf(fpixel)
else
pz=@pf(pz)
c1=@js1
c2=@js2
endif
z1=(0,0)
z2=(0,0)
z3=(0,0)
i4=0
return pz
endfunc
private:
float k1
complex k3[#maxiter]
float k4
int i
int i2
int i3
int i4
complex c1
complex c2
complex z1
complex z2
complex z3
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if @av==0

class OM_TheAlternativeSonsofBonacci(common.ulb:DivergentFormula) {
; Thanks to Kerry Mitchell and Leonardo of Pisa, not necessarily in that order.
public:
complex func Init(complex pz)
fpixel=pz
a1=@pf(pz)
a2=@pf(pz)
a3=@pf(pz)
pz=(0,0)
i=0
if @mj==1
c=@p4
else
c=@p4*@pf(fpixel)
endif
return pz
endfunc
private:
complex a1
complex a2
complex a3
complex c
int i
complex func Iterate(complex pz)
if @av==0
if i==0
pz=@p1*a1+(1-@p1)*a2
pz=pz*a2+c
a1=a2
a2=pz
i=1
else
pz=@p2*a1+(1-@p2)*a3
pz=pz*(@p3*a2+(1-@p3)*a3)
pz=pz*a3+c
a1=a2
a2=a3
a3=pz
i=0
endif
else
if i==0
pz=@p2*a1+(1-@p2)*a3
pz=pz*(@p3*a2+(1-@p3)*a3)
pz=pz*a3+c
a1=a2
a2=a3
a3=pz
i=1
else
pz=@p1*a1+(1-@p1)*a2
pz=pz*a2+c
a1=a2
a2=pz
i=0
endif
endif
return pz
endfunc

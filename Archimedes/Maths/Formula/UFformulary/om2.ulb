z3=pz
pz=@p3*pz^@pow2+@p4*z1*z2+c2
z1=pz
pz=@p3*pz^@pow2+@p4*z2*z3+c2
z2=pz
pz=@p3*pz^@pow2+@p4*z3*z1+c2
i4=1
else
i3=i2
i3=#maxiter-1-i2
k5=k3[i3]
pz=pz^@pow1+c1+k5
i2=i2+1
i4=0
endif
endif
return pz
endfunc

class OM_TheSwornBookofAmurlof(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
if @mj==0
pz=@sp
c=@pf(fpixel)
else
pz=@pf(pz)
c=@js
endif
return pz
endfunc
private:
complex c
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
k=pz+c
pz=k^2+@p1/cosh(k)-0.23*exp(k*c)
c=c+pz
return pz
endfunc

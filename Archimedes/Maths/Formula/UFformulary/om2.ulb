class OM_TheSecretTreatiseofMofarlu(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
if @mj==0
pz=@sp
c=@pf(fpixel)
else
pz=@pf(pz)
c=@js
endif
return pz
endfunc
private:
complex c
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
pz=pz^2+pz*(1+2*pz+pz^2)*(pz^2-1)/(1+pz^3)^2+1i*(pz*(1-2*pz+pz^2)*(pz^2-1)/(1+pz^3)^2)+c
return pz
endfunc

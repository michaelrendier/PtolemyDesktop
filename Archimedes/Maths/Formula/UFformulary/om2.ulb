class OM_Hydra(common.ulb:DivergentFormula) {
;Thanks to Noel Giffin
public:
complex func Init(complex pz)
fpixel=pz
if @mj==0
pz=@sp
c=@pf(fpixel)
else
pz=@pf(pz)
c=@js
endif
return pz
endfunc
private:
complex c
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
k=pz
pz=pz^@pow+c
c=@p1*@fn1(k)
return pz
endfunc

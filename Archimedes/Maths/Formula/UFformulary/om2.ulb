p=(1+@apa*1i)*((real(x)+flip(y))^3-cos(real(x)+flip(y)))+@apa2*1i
elseif @af==22
ap=(1+@apa*1i)*(exp(real(ax)+flip(ay))^3+flip(real(ax)+flip(ay)))+@apa2*1i
bp=(1+@apa*1i)*(exp(real(bx)+flip(by))^3+flip(real(bx)+flip(by)))+@apa2*1i

i=2
else
pz=(2*pz^4-3*pz^3+2*pz^2-2*pz)/(pz^3-2*pz^2+2*pz-@p2)
i=0
endif
elseif @av==1
if i==0
pz=(2*pz^4-2*pz^3+2*pz^2-pz)/(2*pz^3-2*pz^2+3*pz-@p1)
i=1
elseif i==1
pz=(2*pz^4-3*pz^3+2*pz^2-2*pz)/(pz^3-2*pz^2+2*pz-@p2)
i=2
else
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
endif
pz=pz+@app*@pf(fpixel)
i=0
endif
elseif @av==2
if i==0
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
endif
pz=pz+@app*@pf(fpixel)
i=1
elseif i==1
pz=(2*pz^4-3*pz^3+2*pz^2-2*pz)/(pz^3-2*pz^2+2*pz-@p2)
i=2
else
pz=(2*pz^4-2*pz^3+2*pz^2-pz)/(2*pz^3-2*pz^2+3*pz-@p1)
i=0
endif
elseif @av==3
if i==0
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
endif
pz=pz+@app*@pf(fpixel)
i=1
elseif i==1
pz=(2*pz^4-2*pz^3+2*pz^2-pz)/(2*pz^3-2*pz^2+3*pz-@p1)
i=2
else
pz=(2*pz^4-3*pz^3+2*pz^2-2*pz)/(pz^3-2*pz^2+2*pz-@p2)
i=0
endif
elseif @av==4
if i==0
pz=(2*pz^4-3*pz^3+2*pz^2-2*pz)/(pz^3-2*pz^2+2*pz-@p2)
i=1
elseif i==1
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
endif
pz=pz+@app*@pf(fpixel)
i=2
else
pz=(2*pz^4-2*pz^3+2*pz^2-pz)/(2*pz^3-2*pz^2+3*pz-@p1)
i=0
endif
else
if i==0
pz=(2*pz^4-3*pz^3+2*pz^2-2*pz)/(pz^3-2*pz^2+2*pz-@p2)
i=1
elseif i==1
pz=(2*pz^4-2*pz^3+2*pz^2-pz)/(2*pz^3-2*pz^2+3*pz-@p1)
i=2
else
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3

default=(-1.25,0)
visible=@mj==1
endparam
func pf
caption="Pixel Function"
default=ident()
endfunc
param zp1
caption="Z Parameter 1"
default=(0.5,0)
endparam
param zp2
caption="Z Parameter 2"
default=(0,0)
endparam
param p_power
visible=false
endparam
float param p_bailout
caption="Bailout"
default=40.0
exponential=true
endparam
}

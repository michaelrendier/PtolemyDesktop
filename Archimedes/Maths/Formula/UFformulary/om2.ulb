class OM_TalisandHermione(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
if @mj==3
pz=@pf(pz)
c=@js
else
pz=@sp
c=@pf(fpixel)
endif
i=0
return pz
endfunc
private:
complex c
int i
complex func Iterate(complex pz)
if @mj==1
pz=(@zp1+0.08)*pz+@zp2
else
pz=@zp1*pz+@zp2
endif
if @av==0
if i==0
pz=pz^2+c
c=c^2/(c+@p1)+pz
i=1
else
if @mj==0 || @mj==3
pz=@p2*pz^2*(pz-@p3*c)/(1-@p3*c*pz)
elseif @mj==1
pz=(@p2-1.75)*pz^2*(pz-(@p3-0.75))/(1-(@p3-0.75)*pz)+c
else
pz=@p2*c*pz^2*(pz-(@p3-4.5))/(1-(@p3-4.5)*pz)
endif
i=0
endif
else
if i==0
if @mj==0 || @mj==3
pz=@p2*pz^2*(pz-@p3*c)/(1-@p3*c*pz)
elseif @mj==1
pz=(@p2-1.75)*pz^2*(pz-(@p3-0.75))/(1-(@p3-0.75)*pz)+c
else
pz=@p2*c*pz^2*(pz-(@p3-4.5))/(1-(@p3-4.5)*pz)
endif
i=1
else
pz=pz^2+c
c=c^2/(c+@p1)+pz
i=0
endif
endif
return pz
endfunc
default:
title="Talis and Hermione"
param version
caption="Version"
default=100
visible=@version<100
endparam
param mj
caption="M/J"
enum="M1""M2""M3""J"
endparam
param av
caption="Alt Variant"
enum="1""2"
endparam
param sp
caption="Start Parameter"
default=(0.5,0)
visible=@mj!=3
endparam
param js
caption="Julia Seed"
default=(-1.25,0)
visible=@mj==3
endparam
param p1
caption="Talis Parameter"
default=(-3,0)
endparam
param p2
caption="Hermione Parameter 1"
default=(1,0)
endparam
param p3
caption="Hermione Parameter 2"
default=(1,0)
endparam
func pf
caption="Pixel Function"
default=ident()
endfunc

class OM_FelixandJulia10(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
ang=2*pi/3
if @ff==0
c1=(1+@fp*1i)*(exp((0,0)*ang))+@fp2*1i
c2=(1+@fp*1i)*(exp((0,1)*ang))+@fp2*1i
c3=(1+@fp*1i)*(exp((0,2)*ang))+@fp2*1i
elseif @ff==1
c1=(1+@fp*1i)*flip(exp((0,0)*ang))+(@fp2+0.582)*1i
c2=(1+@fp*1i)*flip(exp((0,1)*ang))+(@fp2+0.582)*1i
c3=(1+@fp*1i)*flip(exp((0,2)*ang))+(@fp2+0.582)*1i
elseif @ff==2
c1=(1+@fp*1i)*cabs(exp((0,0)*ang))+(@fp2+0.05)*1i
c2=(1+@fp*1i)*cabs(exp((0,1)*ang))+(@fp2+0.05)*1i
c3=(1+@fp*1i)*cabs(exp((0,2)*ang))+(@fp2+0.05)*1i
elseif @ff==3
c1=(1+@fp*1i)*log(exp((0,0)*ang))+(@fp2+0.55)*1i
c2=(1+@fp*1i)*log(exp((0,1)*ang))+(@fp2+0.55)*1i
c3=(1+@fp*1i)*log(exp((0,2)*ang))+(@fp2+0.55)*1i
elseif @ff==4
c1=(1+@fp*1i)*sin(exp((0,0)*ang))+(@fp2-0.464)*1i
c2=(1+@fp*1i)*sin(exp((0,1)*ang))+(@fp2-0.464)*1i
c3=(1+@fp*1i)*sin(exp((0,2)*ang))+(@fp2-0.464)*1i
elseif @ff==5
c1=(1+@fp*1i)*sinh(exp((0,0)*ang))+(@fp2-0.44)*1i
c2=(1+@fp*1i)*sinh(exp((0,1)*ang))+(@fp2-0.44)*1i
c3=(1+@fp*1i)*sinh(exp((0,2)*ang))+(@fp2-0.44)*1i
elseif @ff==6
c1=(1+@fp*1i)*flip(cabs(exp((0,0)*ang)))+(@fp2-0.3915)*1i
c2=(1+@fp*1i)*flip(cabs(exp((0,1)*ang)))+(@fp2-0.3915)*1i
c3=(1+@fp*1i)*flip(cabs(exp((0,2)*ang)))+(@fp2-0.3915)*1i
elseif @ff==7
c1=(1+@fp*1i)*flip(log(exp((0,0)*ang)))+(@fp2-0.561)*1i
c2=(1+@fp*1i)*flip(log(exp((0,1)*ang)))+(@fp2-0.561)*1i
c3=(1+@fp*1i)*flip(log(exp((0,2)*ang)))+(@fp2-0.561)*1i
elseif @ff==8
c1=(1+@fp*1i)*flip(sin(exp((0,0)*ang)))+(@fp2+0.25)*1i
c2=(1+@fp*1i)*flip(sin(exp((0,1)*ang)))+(@fp2+0.25)*1i
c3=(1+@fp*1i)*flip(sin(exp((0,2)*ang)))+(@fp2+0.25)*1i
elseif @ff==9
c1=(1+@fp*1i)*flip(sinh(exp((0,0)*ang)))+(@fp2+1.075)*1i
c2=(1+@fp*1i)*flip(sinh(exp((0,1)*ang)))+(@fp2+1.075)*1i
c3=(1+@fp*1i)*flip(sinh(exp((0,2)*ang)))+(@fp2+1.075)*1i
elseif @ff==10
c1=(1+@fp*1i)*cabs(log(exp((0,0)*ang)))+(@fp2-0.615)*1i
c2=(1+@fp*1i)*cabs(log(exp((0,1)*ang)))+(@fp2-0.615)*1i
c3=(1+@fp*1i)*cabs(log(exp((0,2)*ang)))+(@fp2-0.615)*1i
elseif @ff==11
c1=(1+@fp*1i)*log(flip(exp((0,0)*ang)))+@fp2*1i
c2=(1+@fp*1i)*log(flip(exp((0,1)*ang)))+@fp2*1i
c3=(1+@fp*1i)*log(flip(exp((0,2)*ang)))+@fp2*1i
elseif @ff==12
c1=(1+@fp*1i)*log(cabs(exp((0,0)*ang)))+(@fp2-0.5822)*1i
c2=(1+@fp*1i)*log(cabs(exp((0,1)*ang)))+(@fp2-0.5822)*1i
c3=(1+@fp*1i)*log(cabs(exp((0,2)*ang)))+(@fp2-0.5822)*1i
elseif @ff==13
c1=(1+@fp*1i)*log(log(exp((0,0)*ang)))+(@fp2+1.005)*1i
c2=(1+@fp*1i)*log(log(exp((0,1)*ang)))+(@fp2+1.005)*1i
c3=(1+@fp*1i)*log(log(exp((0,2)*ang)))+(@fp2+1.005)*1i
elseif @ff==14
c1=(1+@fp*1i)*log(sin(exp((0,0)*ang)))+(@fp2+1.61)*1i
c2=(1+@fp*1i)*log(sin(exp((0,1)*ang)))+(@fp2+1.61)*1i

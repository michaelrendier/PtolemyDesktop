elseif @af==23
ap=(1+@apa*1i)*(cos(real(ax)+flip(ay))^3+sqr(real(ax)+flip(ay)))+@apa2*1i
bp=(1+@apa*1i)*(cos(real(bx)+flip(by))^3+sqr(real(bx)+flip(by)))+@apa2*1i
cp=(1+@apa*1i)*(cos(real(cx)+flip(cy))^3+sqr(real(cx)+flip(cy)))+@apa2*1i
p=(1+@apa*1i)*(cos(real(x)+flip(y))^3+sqr(real(x)+flip(y)))+@apa2*1i
elseif @af==24

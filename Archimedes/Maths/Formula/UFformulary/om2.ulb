complex a2
complex a3
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if @av==0
if i==0
pz=pz^@pow-(pz^a3-1)/(a3*pz^(-2))+c
a3=a1+a2
a1=a2
a2=a3
i=1
else

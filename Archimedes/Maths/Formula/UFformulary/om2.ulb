class OM_PrefacetotheLostGrimoiresofDoctorJohnDee(common.ulb:DivergentFormula) {
; Thanks to Mark Hammond
public:
complex func Init(complex pz)
fpixel=pz
i=0
k1=0.0
complex k2=(0,0)
while i<#maxiter
k2=k2^2+@p1
k3[i]=k2*@p2
k4=cabs(k3[i])
if k4>k1
k1=k4
endif
i=i+1
endwhile
i2=0
i3=0
if @mj==0
pz=@sp
c1=@pp1*@pf(fpixel)
c2=@pp2*@pf(fpixel)
else
pz=@pf(pz)
c1=@js1
c2=@js2
endif
i4=0
return pz
endfunc
private:
float k1
complex k3[#maxiter]
float k4
int i
int i2
int i3
int i4
complex c1
complex c2
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if i4==0
i3=i2
i3=#maxiter-1-i2
k5=k3[i3]
pz=pz^@pow1+c1+k5
i2=i2+1
i4=1
else
i3=i2
i3=#maxiter-1-i2
k5=k3[i3]
pz=pz^@pow2+c2-k5
i2=i2+1
i4=0
endif
return pz
endfunc

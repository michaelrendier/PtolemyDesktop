class OM_KleinPRIJulia(common.ulb:DivergentFormula) {
;Thanks to Felix Klein, Morgan L. Owens and Gaston Julia
public:
complex func Init(complex pz)
fpixel=pz
ang=pi/3
if @kv==0
c1=((0,0))+@fp2*1i
c2=((1,0))+@fp2*1i
c3=(exp((0,1)*ang))+@fp2*1i
c4=(exp((0,2)*ang))+@fp2*1i
c5=(exp((0,3)*ang))+@fp2*1i
c6=(exp((0,4)*ang))+@fp2*1i
c7=(exp((0,5)*ang))+@fp2*1i
elseif @kv==1
c1=flip((0,0))+(@fp2+0.77)*1i
c2=flip((1,0))+(@fp2+0.77)*1i
c3=flip(exp((0,1)*ang))+(@fp2+0.77)*1i
c4=flip(exp((0,2)*ang))+(@fp2+0.77)*1i
c5=flip(exp((0,3)*ang))+(@fp2+0.77)*1i
c6=flip(exp((0,4)*ang))+(@fp2+0.77)*1i
c7=flip(exp((0,5)*ang))+(@fp2+0.77)*1i
else
c1=acos((0,0))+(@fp2+0.0845)*1i
c2=acos((1,0))+(@fp2+0.0845)*1i
c3=acos(exp((0,1)*ang))+(@fp2+0.0845)*1i
c4=acos(exp((0,2)*ang))+(@fp2+0.0845)*1i
c5=acos(exp((0,3)*ang))+(@fp2+0.0845)*1i
c6=acos(exp((0,4)*ang))+(@fp2+0.0845)*1i
c7=acos(exp((0,5)*ang))+(@fp2+0.0845)*1i
endif
r=0.5
pz=@pf(pz)
c=@js
i=0
i2=0
return pz
endfunc
private:
complex c1
complex c2
complex c3
complex c4
complex c5
complex c6
complex c7
float r
int i
int i2
complex c
complex fpixel
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if @av==0
if i==0
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
elseif |pz-c4|<r^2
pz=r*conj(r/(pz-c4))+c4
elseif |pz-c5|<r^2
pz=r*conj(r/(pz-c5))+c5
elseif |pz-c6|<r^2
pz=r*conj(r/(pz-c6))+c6
elseif |pz-c7|<r^2
pz=r*conj(r/(pz-c7))+c7
endif
pz=pz+@app*@pf(fpixel)
i=1
else
if i2==0
pz=((((pz^@pow+c)^@pow+c)^@pow+c)^@pow+c)^@pow+c
i2=1
elseif i2==1
pz=(((pz^@pow+c)^@pow+c)^@pow+c)^@pow+c
i2=2
elseif i2==2
pz=((pz^@pow+c)^@pow+c)^@pow+c
i2=3
elseif i2==3
pz=(pz^@pow+c)^@pow+c
i2=4
elseif i2==4
pz=pz^@pow+c
i2=0
endif
i=0
endif
else
if i==0
if i2==0
pz=((((pz^@pow+c)^@pow+c)^@pow+c)^@pow+c)^@pow+c
i2=1
elseif i2==1
pz=(((pz^@pow+c)^@pow+c)^@pow+c)^@pow+c
i2=2
elseif i2==2
pz=((pz^@pow+c)^@pow+c)^@pow+c
i2=3
elseif i2==3
pz=(pz^@pow+c)^@pow+c
i2=4
elseif i2==4
pz=pz^@pow+c
i2=0
endif
i=1
else
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
elseif |pz-c4|<r^2
pz=r*conj(r/(pz-c4))+c4
elseif |pz-c5|<r^2
pz=r*conj(r/(pz-c5))+c5
elseif |pz-c6|<r^2
pz=r*conj(r/(pz-c6))+c6
elseif |pz-c7|<r^2
pz=r*conj(r/(pz-c7))+c7
endif
pz=pz+@app*@pf(fpixel)
i=0
endif
endif
return pz
endfunc

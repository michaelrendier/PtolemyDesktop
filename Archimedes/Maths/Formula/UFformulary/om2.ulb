class OM_FelixandJulia7(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
ang=2*pi/3
c1=(1+@fp*1i)*@fn1(exp((0,0)*ang))+@fp3*1i
c2=(1+@fp*1i)*@fn1(exp((0,1)*ang))+@fp3*1i
c3=(1+@fp*1i)*@fn1(exp((0,2)*ang))+@fp3*1i
r=sqrt(3)/2
a=pi/3
c1c=(1+@fp2*1i)*@fn2((0,2))+@fp4*1i
c2c=(1+@fp2*1i)*@fn2(2*(sin(a)+flip(cos(a))))+@fp4*1i
c3c=(1+@fp2*1i)*@fn2(2*(sin(2*a)+flip(cos(2*a))))+@fp4*1i
c4c=(1+@fp2*1i)*@fn2((0,-2))+@fp4*1i
c5c=(1+@fp2*1i)*@fn2(2*(sin(4*a)+flip(cos(4*a))))+@fp4*1i
c6c=(1+@fp2*1i)*@fn2(2*(sin(5*a)+flip(cos(5*a))))+@fp4*1i
pz=@pf(pz)
c=@js
i=0
return pz
endfunc

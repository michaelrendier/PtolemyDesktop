elseif @af==18
ap=(1+@apa*1i)*(flip(real(ax)+flip(ay))-cos(real(ax)+flip(ay)))+@apa2*1i
bp=(1+@apa*1i)*(flip(real(bx)+flip(by))-cos(real(bx)+flip(by)))+@apa2*1i
cp=(1+@apa*1i)*(flip(real(cx)+flip(cy))-cos(real(cx)+flip(cy)))+@apa2*1i
p=(1+@apa*1i)*(flip(real(x)+flip(y))-cos(real(x)+flip(y)))+@apa2*1i
elseif @af==19
ap=(1+@apa*1i)*(cos(real(ax)+flip(ay))-exp(real(ax)+flip(ay)))+@apa2*1i
bp=(1+@apa*1i)*(cos(real(bx)+flip(by))-exp(real(bx)+flip(by)))+@apa2*1i
cp=(1+@apa*1i)*(cos(real(cx)+flip(cy))-exp(real(cx)+flip(cy)))+@apa2*1i
p=(1+@apa*1i)*(cos(real(x)+flip(y))-exp(real(x)+flip(y)))+@apa2*1i
elseif @af==20
ap=(1+@apa*1i)*((real(ax)+flip(ay))-cos(real(ax)+flip(ay)))+@apa2*1i
bp=(1+@apa*1i)*((real(bx)+flip(by))-cos(real(bx)+flip(by)))+@apa2*1i
cp=(1+@apa*1i)*((real(cx)+flip(cy))-cos(real(cx)+flip(cy)))+@apa2*1i
p=(1+@apa*1i)*((real(x)+flip(y))-cos(real(x)+flip(y)))+@apa2*1i
elseif @af==21
ap=(1+@apa*1i)*((real(ax)+flip(ay))^3-cos(real(ax)+flip(ay)))+@apa2*1i
bp=(1+@apa*1i)*((real(bx)+flip(by))^3-cos(real(bx)+flip(by)))+@apa2*1i
cp=(1+@apa*1i)*((real(cx)+flip(cy))^3-cos(real(cx)+flip(cy)))+@apa2*1i

class OM_FelixandJulia8(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
ang=2*pi/3
if @fv==0
c1=(1+@fp*1i)*(exp((0,0)*ang))+@fp2*1i
c2=(1+@fp*1i)*(exp((0,1)*ang))+@fp2*1i
c3=(1+@fp*1i)*(exp((0,2)*ang))+@fp2*1i
elseif @fv==1
c1=(1+(@fp+0.35)*1i)*flip(exp((0,0)*ang))+@fp2*1i
c2=(1+(@fp+0.35)*1i)*flip(exp((0,1)*ang))+@fp2*1i
c3=(1+(@fp+0.35)*1i)*flip(exp((0,2)*ang))+@fp2*1i
elseif @fv==2
c1=(1+@fp*1i)*cabs(exp((0,0)*ang))+@fp2*1i
c2=(1+@fp*1i)*cabs(exp((0,1)*ang))+@fp2*1i
c3=(1+@fp*1i)*cabs(exp((0,2)*ang))+@fp2*1i
elseif @fv==3
c1=(1+@fp*1i)*log(exp((0,0)*ang))+(@fp2-0.7)*1i
c2=(1+@fp*1i)*log(exp((0,1)*ang))+(@fp2-0.7)*1i
c3=(1+@fp*1i)*log(exp((0,2)*ang))+(@fp2-0.7)*1i
elseif @fv==4
c1=(1+@fp*1i)*sin(exp((0,0)*ang))+(@fp2+1.2)*1i
c2=(1+@fp*1i)*sin(exp((0,1)*ang))+(@fp2+1.2)*1i
c3=(1+@fp*1i)*sin(exp((0,2)*ang))+(@fp2+1.2)*1i
elseif @fv==5
c1=(1+@fp*1i)*sinh(exp((0,0)*ang))+@fp2*1i
c2=(1+@fp*1i)*sinh(exp((0,1)*ang))+@fp2*1i
c3=(1+@fp*1i)*sinh(exp((0,2)*ang))+@fp2*1i
elseif @fv==6
c1=(1+@fp*1i)*flip(cabs(exp((0,0)*ang)))+(@fp2-0.3)*1i
c2=(1+@fp*1i)*flip(cabs(exp((0,1)*ang)))+(@fp2-0.3)*1i
c3=(1+@fp*1i)*flip(cabs(exp((0,2)*ang)))+(@fp2-0.3)*1i
elseif @fv==7
c1=(1+@fp*1i)*flip(log(exp((0,0)*ang)))+(@fp2+(0.67, 0.2))*1i
c2=(1+@fp*1i)*flip(log(exp((0,1)*ang)))+(@fp2+(0.67, 0.2))*1i
c3=(1+@fp*1i)*flip(log(exp((0,2)*ang)))+(@fp2+(0.67, 0.2))*1i
elseif @fv==8
c1=(1+@fp*1i)*flip(sin(exp((0,0)*ang)))+@fp2*1i
c2=(1+@fp*1i)*flip(sin(exp((0,1)*ang)))+@fp2*1i
c3=(1+@fp*1i)*flip(sin(exp((0,2)*ang)))+@fp2*1i
elseif @fv==9
c1=(1+(@fp+0.45)*1i)*flip(sinh(exp((0,0)*ang)))+(@fp2-1.67)*1i
c2=(1+(@fp+0.45)*1i)*flip(sinh(exp((0,1)*ang)))+(@fp2-1.67)*1i
c3=(1+(@fp+0.45)*1i)*flip(Sinh(exp((0,2)*ang)))+(@fp2-1.67)*1i
elseif @fv==10
c1=(1+@fp*1i)*cabs(sin(exp((0,0)*ang)))+(@fp2+0.65)*1i
c2=(1+@fp*1i)*cabs(sin(exp((0,1)*ang)))+(@fp2+0.65)*1i
c3=(1+@fp*1i)*cabs(sin(exp((0,2)*ang)))+(@fp2+0.65)*1i
elseif @fv==11
c1=(1+@fp*1i)*log(flip(exp((0,0)*ang)))+(@fp2+(1.94,-0.185))*1i
c2=(1+@fp*1i)*log(flip(exp((0,1)*ang)))+(@fp2+(1.94,-0.185))*1i
c3=(1+@fp*1i)*log(flip(exp((0,2)*ang)))+(@fp2+(1.94,-0.185))*1i
elseif @fv==12
c1=(1+@fp*1i)*log(log(exp((0,0)*ang)))+(@fp2+(0.8485,0.534))*1i
c2=(1+@fp*1i)*log(log(exp((0,1)*ang)))+(@fp2+(0.8485,0.534))*1i
c3=(1+@fp*1i)*log(log(exp((0,2)*ang)))+(@fp2+(0.8485,0.534))*1i
elseif @fv==13
c1=(1+@fp*1i)*log(sin(exp((0,0)*ang)))+(@fp2+0.75)*1i
c2=(1+@fp*1i)*log(sin(exp((0,1)*ang)))+(@fp2+0.75)*1i
c3=(1+@fp*1i)*log(sin(exp((0,2)*ang)))+(@fp2+0.75)*1i
elseif @fv==14
c1=(1+@fp*1i)*log(sinh(exp((0,0)*ang)))+(@fp2+(0,0.85))*1i
c2=(1+@fp*1i)*log(sinh(exp((0,1)*ang)))+(@fp2+(0,0.85))*1i
c3=(1+@fp*1i)*log(sinh(exp((0,2)*ang)))+(@fp2+(0,0.85))*1i
elseif @fv==15
c1=(1+@fp*1i)*sqr(flip(exp((0,0)*ang)))+@fp2*1i
c2=(1+@fp*1i)*sqr(flip(exp((0,1)*ang)))+@fp2*1i
c3=(1+@fp*1i)*sqr(flip(exp((0,2)*ang)))+@fp2*1i
elseif @fv==16
c1=(1+@fp*1i)*sqr(sin(exp((0,0)*ang)))+(@fp2+(-1,0.33))*1i
c2=(1+@fp*1i)*sqr(sin(exp((0,1)*ang)))+(@fp2+(-1,0.33))*1i
c3=(1+@fp*1i)*sqr(sin(exp((0,2)*ang)))+(@fp2+(-1,0.33))*1i
elseif @fv==17
c1=(1+(@fp+0.5)*1i)*sin(flip(exp((0,0)*ang)))+@fp2*1i
c2=(1+(@fp+0.5)*1i)*sin(flip(exp((0,1)*ang)))+@fp2*1i
c3=(1+(@fp+0.5)*1i)*sin(flip(exp((0,2)*ang)))+@fp2*1i
elseif @fv==18
c1=(1+@fp*1i)*sinh(sinh(exp((0,0)*ang)))+@fp2*1i
c2=(1+@fp*1i)*sinh(sinh(exp((0,1)*ang)))+@fp2*1i
c3=(1+@fp*1i)*sinh(sinh(exp((0,2)*ang)))+@fp2*1i
elseif @fv==19
c1=(1+@fp*1i)*sinh(cabs(exp((0,0)*ang)))+@fp2*1i
c2=(1+@fp*1i)*sinh(cabs(exp((0,1)*ang)))+@fp2*1i
c3=(1+@fp*1i)*sinh(cabs(exp((0,2)*ang)))+@fp2*1i
endif
r=sqrt(3)/2
pz=@pf(pz)
inte=0
i3=0
t=false
return pz
endfunc
private:
complex c1
complex c2
complex c3
float r
int inte
int i3
bool t
complex fpixel
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if @av==0
if inte==0
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
endif
pz=pz+@d*@pf(fpixel)
inte=1
else
t=!t
if t
if i3==0
pz=pz^2+@seed2
i3=1
else
pz=pz^3+@seed2
i3=0
endif
else
if i3==0
pz=pz^3+@seed1
i3=1
else
pz=pz^2+@seed1
i3=0
endif
endif
inte=0
endif
else
if inte==0
t=!t
if t
if i3==0
pz=pz^2+@seed2
i3=1
else
pz=pz^3+@seed2
i3=0
endif
else
if i3==0
pz=pz^3+@seed1
i3=1
else
pz=pz^2+@seed1
i3=0
endif
endif
inte=1
else
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
endif
pz=pz+@d*@pf(fpixel)
inte=0
endif
endif
return pz
endfunc
default:
title="Felix and Julia 8"
param version
caption="Version"
default=100
visible=@version<100
endparam
param av
caption="Alt Variant"
enum="1""2"
endparam
param fv
caption="Felix Function"
enum="ident""flip""cabs""log""sin""sinh""flipcabs"\
"fliplog""flipsin""flipsinh""cabssin""logflip""loglog"\
"logsin""logsinh""sqrflip""sqrsin""sinflip""sinhsinh""sinhcabs"
endparam
param fp
caption="Felix Parameter 1"
default=0.0
endparam
param fp2
caption="Felix Parameter 2"
default=(0,0)
endparam
param seed1
caption="Julia Seed 1"
default=(0.5,0)
endparam
param seed2
caption="Julia Seed 2"
default=(-0.31,0)
endparam
func pf
caption="Pixel Function"
default=ident()
endfunc
param zp1
caption="Z Parameter 1"
default=(1,0)
endparam
param zp2
caption="Z Parameter 2"
default=(0,0)
endparam
param d
caption="Distortion"
default=(0,0)
endparam
param p_power
visible=false
endparam
float param p_bailout
caption="Bailout"
default=40.0
exponential=true
endparam
}

class OM_KleinX17(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
ang=2*pi/3
c1=(1+@fp*1i)*@fn1(exp((0,0)*ang))+@fp3*1i
c2=(1+@fp*1i)*@fn1(exp((0,1)*ang))+@fp3*1i
c3=(1+@fp*1i)*@fn1(exp((0,2)*ang))+@fp3*1i
r=sqrt(3)/2
a=pi/3
c1c=(1+@fp2*1i)*@fn2((0,2))+@fp4*1i
c2c=(1+@fp2*1i)*@fn2(2*(sin(a)+flip(cos(a))))+@fp4*1i
c3c=(1+@fp2*1i)*@fn2(2*(sin(2*a)+flip(cos(2*a))))+@fp4*1i
c4c=(1+@fp2*1i)*@fn2((0,-2))+@fp4*1i
c5c=(1+@fp2*1i)*@fn2(2*(sin(4*a)+flip(cos(4*a))))+@fp4*1i
c6c=(1+@fp2*1i)*@fn2(2*(sin(5*a)+flip(cos(5*a))))+@fp4*1i
pz=@pf(pz)
i=0
return pz
endfunc
private:
complex c1
complex c2
complex c3
float r
complex c1c
complex c2c
complex c3c
complex c4c
complex c5c
complex c6c
complex fpixel
int i
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if @av==0
if i==0
pz=pz^2+@p2/(pz+exp(pz)/(@p1*pz))
i=1
elseif i==1
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
endif
pz=pz+@app*@pf(fpixel)
i=2
else
if cabs(pz-c1c)<1
pz=conj(1/(pz-c1c))+c1c
elseif cabs(pz-c2c)<1
pz=conj(1/(pz-c2c))+c2c
elseif cabs(pz-c3c)<1
pz=conj(1/(pz-c3c))+c3c
elseif cabs(pz-c4c)<1
pz=conj(1/(pz-c4c))+c4c
elseif cabs(pz-c5c)<1
pz=conj(1/(pz-c5c))+c5c
elseif cabs(pz-c6c)<1
pz=conj(1/(pz-c6c))+c6c
endif
i=0
endif
elseif @av==1
if i==0
pz=pz^2+@p2/(pz+exp(pz)/(@p1*pz))
i=1
elseif i==1
if cabs(pz-c1c)<1
pz=conj(1/(pz-c1c))+c1c
elseif cabs(pz-c2c)<1
pz=conj(1/(pz-c2c))+c2c
elseif cabs(pz-c3c)<1
pz=conj(1/(pz-c3c))+c3c
elseif cabs(pz-c4c)<1
pz=conj(1/(pz-c4c))+c4c
elseif cabs(pz-c5c)<1
pz=conj(1/(pz-c5c))+c5c
elseif cabs(pz-c6c)<1
pz=conj(1/(pz-c6c))+c6c
endif
i=2
else
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
endif
pz=pz+@app*@pf(fpixel)

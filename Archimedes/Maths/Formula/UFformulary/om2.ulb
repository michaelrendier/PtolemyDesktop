private:
complex c
int i
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if @av==0
if i==0
pz=pz^2+c
c=c^2/(c+@p1)+pz
i=1
else
k=(1-pz^@pow)^@pow
pz=pz*@fn1((1-k)/(1+k))+c
i=0
endif
else
if i==0
k=(1-pz^@pow)^@pow
pz=pz*@fn1((1-k)/(1+k))+c
i=1
else
pz=pz^2+c
c=c^2/(c+@p1)+pz
i=0
endif
endif
return pz
endfunc

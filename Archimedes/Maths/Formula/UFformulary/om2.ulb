class OM_Hydrajuliman(common.ulb:DivergentFormula) {
;Thanks to Noel Giffin, Gaston Julia and Benoit Mandelbrot
public:
complex func Init(complex pz)
fpixel=pz
if @mj==0
pz=@sp
c=@pf(fpixel)
else
pz=@pf(pz)
c=@js
endif
i=0
return pz
endfunc
private:
complex c
int i
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if @av==0
if i==0
k=pz
pz=pz^@pow+c
c=@p1*@fn1(k)
i=1
else
pz=pz^@pow+c
i=0
endif
else
if i==0
pz=pz^@pow+c
i=1
else
k=pz
pz=pz^@pow+c
c=@p1*@fn1(k)
i=0
endif
endif
return pz
endfunc

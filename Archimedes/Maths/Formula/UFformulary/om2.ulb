class OM_ApollonandJuliette3(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
ax=7
ay=7
ar=1
bx=-1
by=0
br=1
cx=1
cy=0
cr=1
h=sqr(ax)+ay^2-ar^2
a=2*(ar-br)
b=2*(ax-bx)
c=2*(ay-by)
d=h-(bx^2+by^2-br^2)
ee=2*(ar-cr)
f=2*(ax-cx)
g=2*(ay-cy)
h=h-(cx^2+cy^2-cr^2)
l=(b*g-c*f)
i=(d*g-c*h)/l
j=(a*g-c*ee)/l
k=(b*h-d*f)/l
l=(b*ee-a*f)/l
m=2*(1-2*l^2)
n=2*(cr+(i-cx)*j+(k-cy)*l)
o=2*(cr^2-(i-cx)^2-(k-cy)^2)
r=sqrt(sqr(n)-m*o)
r1=(-n-r)/m
r2=(-n+r)/m
if r1>0
r=r1
else
r=r2
endif
x=i-j*r
y=k-l*r
ap=(1+@ap*1i)*(real(ax)+flip(ay))+@ap2*1i
bp=(1+@ap*1i)*(real(bx)+flip(by))+@ap2*1i
cp=(1+@ap*1i)*(real(cx)+flip(cy))+@ap2*1i
p=(1+@ap*1i)*(real(x)+flip(y))+@ap2*1i
pz=@pf(pz)
inte=0
return pz
endfunc
private:
float ax
float ay
float ar
float bx
float by
float br
float cx
float cy
float cr
float h
float a
float b
float c
float d
float ee
float f
float g
float l
float i
float j
float k
float m
float n
float o
float r
float r1
float r2
float x
float y
complex ap
complex bp
complex cp
complex p
int inte
complex func Iterate(complex pz)
if @jv==1
pz=(@zp1-0.3)*pz+@zp2
elseif @jv==4
pz=(@zp1-0.25)*pz+@zp2
else
pz=@zp1*pz+@zp2
endif
if @av==0
if inte==0
if |pz-ap|<ar^2
pz=ar*conj(ar/(pz-ap))+ap
elseif |pz-bp|<br^2
pz=br*conj(br/(pz-bp))+bp
elseif |pz-cp|<cr^2
pz=cr*conj(cr/(pz-cp))+cp
elseif |pz-p|<r^2
pz=r*conj(r/(pz-p))+p
endif
inte=1
else
tmp=pz
int inte2=0
if @jv==2
pz=pz+(@js+1.1)
elseif @jv==3
pz=pz+(@js+0.3)
elseif @jv==5
pz=pz+(@js-1.45)
else
pz=pz+@js
endif
while inte2<1
tmp=sqr(tmp)
if @jv==0
pz=pz+tmp
elseif @jv==1
pz=pz+tmp-exp(pz)
elseif @jv==2
pz=pz+tmp-sinh(pz)
elseif @jv==3
pz=pz+tmp-cosh(pz)
elseif @jv==4
pz=pz+tmp-recip(pz)
else
pz=pz+tmp-sin(pz)
endif
inte2=inte2+1
endwhile
inte=0
endif
else
if inte==0
tmp=pz
int inte2=0
if @jv==2
pz=pz+(@js+1.1)
elseif @jv==3
pz=pz+(@js+0.3)
elseif @jv==5
pz=pz+(@js-1.45)
else
pz=pz+@js
endif
while inte2<1
tmp=sqr(tmp)
if @jv==0
pz=pz+tmp
elseif @jv==1
pz=pz+tmp-exp(pz)
elseif @jv==2
pz=pz+tmp-sinh(pz)
elseif @jv==3
pz=pz+tmp-cosh(pz)
elseif @jv==4
pz=pz+tmp-recip(pz)
else
pz=pz+tmp-sin(pz)
endif
inte2=inte2+1
endwhile
inte=1
else
if |pz-ap|<ar^2
pz=ar*conj(ar/(pz-ap))+ap
elseif |pz-bp|<br^2
pz=br*conj(br/(pz-bp))+bp
elseif |pz-cp|<cr^2
pz=cr*conj(cr/(pz-cp))+cp
elseif |pz-p|<r^2
pz=r*conj(r/(pz-p))+p
endif
inte=0
endif
endif
return pz
endfunc

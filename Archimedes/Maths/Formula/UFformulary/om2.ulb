elseif cabs(pz-c2c)<1
pz=conj(1/(pz-c2c))+c2c
elseif cabs(pz-c3c)<1
pz=conj(1/(pz-c3c))+c3c
elseif cabs(pz-c4c)<1
pz=conj(1/(pz-c4c))+c4c
elseif cabs(pz-c5c)<1
pz=conj(1/(pz-c5c))+c5c
elseif cabs(pz-c6c)<1
pz=conj(1/(pz-c6c))+c6c
endif
i=2
else
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
endif
pz=pz+@app*@pf(fpixel)
i=0
endif
elseif @av==2
if i==0
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
endif
pz=pz+@app*@pf(fpixel)
i=1
elseif i==1

class OM_numma2(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
if @mj==0
pz=@sp
c1=@pp1*@pf(fpixel)
c2=@pp2*@pf(fpixel)
else
pz=@pf(pz)
c1=@js1
c2=@js2
endif
inte=0
i=0
i2=1
i3=1
return pz
endfunc
private:
complex c1
complex c2
int inte
int i
int i2
int i3
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if inte==0
i=i+1
if i!=i3
pz=pz^@pow1+c1
else
i2=i2+1
i3=i2*i2
pz=pz^@pow2+c2
endif
inte=1
else
i=i+1
if i!=i3
pz=pz^@pow2+c2
else
i2=i2+1
i3=i2*i2
pz=pz^@pow1+c1
endif
inte=0
endif
return pz
endfunc

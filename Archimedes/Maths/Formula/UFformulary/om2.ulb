^@pow1+c*((pz^@pow1+c*pz^@pow2+@p1*a)^@pow1+c*(pz^@pow1+c*pz^@pow2+@p1*a)^@pow2+@p1*a)^@pow2+@p1*a)^@pow2+@p1*a)^@pow2+@p1*a)

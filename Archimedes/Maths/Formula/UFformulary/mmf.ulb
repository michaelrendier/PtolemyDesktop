  float param xco
    caption = "Fraction Across Screen"
    default = 0.5
    min = 0.0
    max = 1.0
    hint = "Use 0.0 for the far left, use 1.0 for the far right."
  endparam
  float param yco
    caption = "Fraction Down Screen"
    default = 0.5
    min = 0.0
    max = 1.0
    hint = "Use 0.0 for the top, use 1.0 for the bottom."

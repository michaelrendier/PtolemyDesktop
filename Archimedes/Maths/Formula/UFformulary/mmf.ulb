class MMF_ThreeKeyColours(MMF_KeyColourBase) {
  import "common.ulb"
  func MMF_ThreeKeyColours(Generic pparent)
    m_Parent = pparent
    cols = indexes = 0
  endfunc
  int func GetNumCols()
    cols = indexes = 0
    return 3
  endfunc
  color func GetNextColour()
    if cols==0
      cols = 1
      return @colour0
    elseif cols==1
      cols = 2
      return @colour1
    endif
    cols = 0
    return @colour2
  endfunc
  float func GetNextIndex()
    if indexes==0
      indexes = 1
      return 0.0025*@index0
    elseif indexes==1
      indexes = 2
      return 0.0025*@index1
    endif
    indexes = 0
    return 0.0025*@index2
  endfunc
private:
  int cols
  int indexes
default:
  title = "Three Key Colours"
	int param v_mmfthreekeycolours
		caption = "Version (MMF_ThreeKeyColours)"

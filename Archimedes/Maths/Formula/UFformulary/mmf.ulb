    merge = new @merge(this)
    DLAStimulus[0] = new @DLAStimulus1(this)
		if @numstimuli>0
		  DLAStimulus[1] = new @DLAStimulus2(this)
		  if @numstimuli>1
		    DLAStimulus[2] = new @DLAStimulus3(this)

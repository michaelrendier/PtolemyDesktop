  endfunc
  ; @param x the x pixel position of a stimulus
  ; @param y the y pixel position of a stimulus
  ; @return the square of the pixel distance
  float func DeadDistance(float x,float y)
    return 1e200
  endfunc
default:
  title = "No Dead Point DLA Seeding"

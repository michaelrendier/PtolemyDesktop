    o = 0
		DLASeed[0] = new @DLASeed1(this)
		if @numplants>0
		  o = 1
		  DLASeed[1] = new @DLASeed2(this)
		  if @numplants>1
		    o = 2
		    DLASeed[2] = new @DLASeed3(this)
		    if @numplants>2
		      o = 3
		      DLASeed[3] = new @DLASeed4(this)
		      if @numplants>3
		        o = 4

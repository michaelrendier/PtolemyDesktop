    ct = c2*82/119 + k, z = 0
  ELSEIF (iter==l3)
    ct = c3*82/119 + k, z = 0
  ELSEIF (iter==l4)
    ct = c4*82/119 + k, z = 0
  ENDIF
  z = .2*z^3 + z^2 + ct
  iter=iter+1
bailout:
  real(z)<=bailout

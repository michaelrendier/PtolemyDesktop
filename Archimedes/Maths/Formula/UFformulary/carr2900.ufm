Carr2938 {; Updated for UF2 by Erik Reckase, Feb 2000
          ; Modified Sylvie Gallet frm. 
init:
  b4=pixel-conj(.1/pixel-cabs(.1/pixel))
  b5=pixel^5-conj(.1/pixel-flip(.01/pixel))
  IF (@p3==1)
    c = conj(b4), z = sqr(b5)
  ELSEIF (@p3==0)
    c = -sqr(b4), z = -conj(b5)
  ELSE
    IF (whitesq)
      c = conj(b4), z = sqr(b5)
    ELSE
      c = -sqr(b4), z = -conj(b5)
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = (-.7456,-.132)
  ct = 1.1*c + k
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:

    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr2998 {; Updated for UF2 by Erik Reckase, Feb 2000
          ; Modified Sylvie Gallet frm. 
init:
  z=pixel-conj(.01/pixel)
  c=pixel-flip(.01/pixel)-conj(.001/pixel)
  IF (@p3==0)
    c = -c, z = -z
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -c, z = -z
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = (-.7456,-.132)
  ct = flip(conj(c/10)) + k
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter == l1)
    z = 0, ct = flip(conj(c1/10)) + k
  ELSEIF (iter == l2)
    z = 0, ct = flip(conj(c2/10)) + k
  ELSEIF (iter == l3)
    z = 0, ct = flip(conj(c3/10)) + k
  ELSEIF (iter == l4)
    z = 0, ct = flip(conj(c4/10)) + k
  ENDIF
  z = z^2 + ct
  iter = iter + 1
bailout:
  z <= bailout
default:
  title = "Carr 2998"
  periodicity = 0
  maxiter = 700
  magn = 1.3
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr2999 {; Updated for UF2 by Erik Reckase, Feb 2000
          ; Modified Sylvie Gallet frm. 
init:
  c=pixel-conj(.01/pixel)
  z=pixel-flip(.01/pixel)-conj(.001/pixel)-conj(.001/c)-.12
  IF (@p3==0)
    c = -c, z = -z
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -c, z = -z
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = (-.7156,-.132)
  ct = flip(conj(c/10)) + k
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter == l1)
    z = 0, ct = flip(conj(c1/10)) + k
  ELSEIF (iter == l2)
    z = 0, ct = flip(conj(c2/10)) + k
  ELSEIF (iter == l3)
    z = 0, ct = flip(conj(c3/10)) + k
  ELSEIF (iter == l4)
    z = 0, ct = flip(conj(c4/10)) + k
  ENDIF
  z = z^2 + ct
  iter=iter+1
bailout:
  real(z)<=bailout
default:
  title = "Carr 2999"

Carr2912 {; Updated for UF2 by Erik Reckase, Feb 2000
          ; Modified Sylvie Gallet frm. 
init:
  b5=conj(pixel^7)*conj(.33-pixel)^2
  b4=cabs(.25-pixel^5)-conj(.01/pixel)
  IF (@p3==1)
    c = b4^3, z = b5^.5
  ELSEIF (@p3==0)
    c = -b4^.5, z = -b5^3
  ELSE
    IF (whitesq)
      c = b4^3, z = b5^.5
    ELSE
      c = -b4^.5, z = -b5^3
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:

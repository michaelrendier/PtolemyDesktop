Carr2923 {; Updated for UF2 by Erik Reckase, Feb 2000
          ; Modified Sylvie Gallet frm. 
init:
  b4=conj(pixel^3)-conj(.1/pixel)-flip(.01/pixel)
  b5=real(b4)-flip(imag(b4/2))-imag(flip(.1/pixel))
  IF (@p3==1)
    c = sqr(b4), z = sqr(b5)
  ELSEIF (@p3==0)
    c = -conj(b4), z = -flip(b5)
  ELSE
    IF (whitesq)
      c = sqr(b4), z = sqr(b5)
    ELSE
      c = -conj(b4), z = -flip(b5)
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = (-.7296,.2132)
  ct = c/10 + k
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    ct = c1/10 + k, z = 0
  ELSEIF (iter==l2)
    ct = c2/10 + k, z = 0
  ELSEIF (iter==l3)
    ct = c3/10 + k, z = 0
  ELSEIF (iter==l4)
    ct = c4/10 + k, z = 0
  ENDIF
  z = z^2 + ct
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 2923"
  periodicity = 0
  maxiter = 700
  magn = 1
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}


}

Carr2906 {; Updated for UF2 by Erik Reckase, Feb 2000
          ; Modified Sylvie Gallet frm. 
init:
  c=pixel-conj(.1/pixel-exp(.001/pixel))
  z=(pixel-.0224)*conj(c-.25)/2
  IF (@p3==0)
    c = -c, z = -z
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -c, z = -z
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = c1, z = 0
  ELSEIF (iter==l2)
    c = c2, z = 0
  ELSEIF (iter==l3)
    c = c3, z = 0
  ELSEIF (iter==l4)
    c = c4, z = 0
  ENDIF
  z = z*z + c
  c = z + c/2.125 - .0325
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 2906"
  periodicity = 0
  maxiter = 700
  magn = .8
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr2907 (XYAXIS) {; Updated for UF2 by Erik Reckase, Feb 2000
                   ; Halley PHC
init:
  z=1/pixel
  IF (@p2==0)
    z = z^2
  ELSEIF (@p2==2)
    IF (whitesq)
      z = z^2
    ENDIF
  ENDIF
loop:
  z=z-p1*(z^7-z)/(14*z^6-2-84*z^5*(z^7-z)/(28*z^6-4))
bailout:
  |z^7-z|>=.0001
default:
  title = "Carr 2907"
  periodicity = 0
  maxiter = 700
  magn = 1
  center = (0,0)
  method = multipass
  param p1
    caption = "Parameter 1"
    default = (.5,-.5)
  endparam
  param p2
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr2908 (XYAXIS) {; Updated for UF2 by Erik Reckase, Feb 2000
                   ; Halley PHC
init:
  z=pixel
  IF (@p2==1)
    z = 2*z^2
  ELSEIF (@p2==2)
    IF (whitesq)
      z = 2*z^2
    ENDIF
  ENDIF
loop:
  z=(z-p1*((z^7-z)/((7*z^6-1)-(42*z^5)*(z^7-z)/(14*z^6-2))))
bailout:
  |z^7-z|>=.0001
default:
  title = "Carr 2908"
  periodicity = 0
  maxiter = 700
  magn = 1.2
  center = (0,0)
  method = multipass
  param p1
    caption = "Parameter 1"
    default = (.5,-.5)
  endparam
  param p2
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr2909 {; Updated for UF2 by Erik Reckase, Feb 2000
          ; Modified Sylvie Gallet frm. 
init:
  z=conj(pixel^7)*abs(pixel-.2)^2
  c=cabs(pixel)-conj(.01/pixel)
  IF (@p3==0)
    c = -fn2(c), z = -fn2(z)
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -fn2(c), z = -fn2(z)
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = (-.7456,-.132)
  ck = .0035/21
  ct = c/10 - ck/c + k
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    ct = c1/10 - ck/c1 + k, z = 0
  ELSEIF (iter==l2)
    ct = c2/10 - ck/c2 + k, z = 0
  ELSEIF (iter==l3)
    ct = c3/10 - ck/c3 + k, z = 0
  ELSEIF (iter==l4)
    ct = c4/10 - ck/c4 + k, z = 0
  ENDIF
  z = z*z + ct
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 2909"
  periodicity = 0
  maxiter = 700
  magn = 1.1
  center = (0.01,0.01)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
  func fn2
    caption = "Whitesq Fcn"
    default = sqr()
    hint = "This function is applied to the values of c and z \
            for the second layer of the PHC."
  endfunc
}

Carr2910 {; Updated for UF2 by Erik Reckase, Feb 2000
          ; Modified Sylvie Gallet frm. 
init:
  z=conj(pixel^7)*sin(pixel-.2)^2
  c=cabs(pixel^5)-conj(.01/pixel)
  IF (@p3==0)
    c = -fn2(c), z = -fn2(z)
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -fn2(c), z = -fn2(z)
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = (-.7456,-.132)
  ck = .0035/21
  ct = c/10 - ck/c + k
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    ct = c1/10 - ck/c1 + k, z = 0
  ELSEIF (iter==l2)
    ct = c2/10 - ck/c2 + k, z = 0
  ELSEIF (iter==l3)
    ct = c3/10 - ck/c3 + k, z = 0
  ELSEIF (iter==l4)
    ct = c4/10 - ck/c4 + k, z = 0
  ENDIF
  z = z*z + ct
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 2910"
  periodicity = 0
  maxiter = 700
  magn = 1.4
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
  func fn2
    caption = "Whitesq Fcn"
    default = sqr()
    hint = "This function is applied to the values of c and z \
            for the second layer of the PHC."
  endfunc
}

Carr2911 {; Updated for UF2 by Erik Reckase, Feb 2000
          ; Modified Sylvie Gallet frm. 
init:
  b5=conj(pixel^7)*sin(pixel-.2)^2
  b4=cabs(.25-pixel^5)-conj(.01/pixel)
  IF (@p3==1)
    c = b4^3, z = b5^.5
  ELSEIF (@p3==0)
    c = -b4^.5, z = -b5^3
  ELSE
    IF (whitesq)
      c = b4^3, z = b5^.5
    ELSE
      c = -b4^.5, z = -b5^3
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = c1, z = 0
  ELSEIF (iter==l2)
    c = c2, z = 0
  ELSEIF (iter==l3)
    c = c3, z = 0
  ELSEIF (iter==l4)
    c = c4, z = 0
  ENDIF
  z = z*z + c
  c = z + c/2.125 - .0325
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 2911"
  periodicity = 0
  maxiter = 700
  magn = 1.5
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2

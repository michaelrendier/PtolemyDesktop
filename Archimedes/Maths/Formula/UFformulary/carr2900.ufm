Carr2929 {; Updated for UF2 by Erik Reckase, Feb 2000
          ; Modified OK-42
          ; Continuous Potential recommended
init:
  b5=1/pixel
  p1x=real(p1)+1, p1y=imag(p1)+1
  p2x=real(p2)+1, p2y=imag(p2)+1
  IF (@p3==1)
    z = sqr(b5)
  ELSEIF (@p3==0)
    z = -conj(b5)
  ELSE
    IF (whitesq)
      z = sqr(b5)
    ELSE
      z = -conj(b5)
    ENDIF
  ENDIF
loop:
  zx=real(z), zy=imag(z)
  x=fn1(zx*p1x-zy*p1y)+fn2(zx*p2x-zy*p2y)
  y=fn3(zx*p1y+zy*p1x)+fn4(zx*p2y+zy*p2x)
  z=x+flip(y)
bailout:
  |z|<=20
default:
  title = "Carr 2929"
  periodicity = 0
  maxiter = 700
  magn = 1.2
  center = (0,0)
  method = multipass
  param p1
    caption = "Param 1, X/Y"
    default = (0,0)
  endparam
  param p2
    caption = "Param 2, X/Y"
    default = (0,0)
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
  func fn1
    caption = "X-Func 1"
    default = tan()
  endfunc
  func fn2
    caption = "X-Func 2"
    default = ident()
  endfunc
  func fn3
    caption = "Y-Func 1"
    default = tan()
  endfunc
  func fn4
    caption = "Y-Func 2"
    default = ident()
  endfunc
}


  endparam
}

Carr2966 {; Updated for UF2 by Erik Reckase, Feb 2000
          ; Modified Sylvie Gallet frm. 
init:
  b5=cotan(|1-pixel/2|)^3.5*pixel^8-(.5/log(.1/pixel+1))^12
  b4=exp((-.7456,-.132))-conj(.1/pixel)
  IF (@p3==1)
    c = conj(b4), z = sqr(b5)
  ELSEIF (@p3==0)
    c = -sqr(b4), z = -cabs(b5)
  ELSE
    IF (whitesq)
      c = conj(b4), z = sqr(b5)
    ELSE
      c = -sqr(b4), z = -cabs(b5)
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = c1, z = 0
  ELSEIF (iter==l2)
    c = c2, z = 0
  ELSEIF (iter==l3)
    c = c3, z = 0
  ELSEIF (iter==l4)
    c = c4, z = 0
  ENDIF
  z = z^2 + (-.7456,-.132) + c/10
  c = z + c/2.125 - .0325
  iter=iter+1
bailout:
  real(z^6)<=bailout
default:
  title = "Carr 2966"
  periodicity = 0
  maxiter = 700
  magn = 7
  center = (-.05,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}


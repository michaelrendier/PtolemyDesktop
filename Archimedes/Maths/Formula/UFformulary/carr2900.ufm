Carr2981 {; Updated for UF2 by Erik Reckase, Feb 2000
          ; Modified Sylvie Gallet frm. 
init:
  z=pixel/2-conj(.1/pixel-flip(.01/pixel))+.4
  b4=pixel^2-flip(.01/pixel)-conj(.1/pixel)
  IF (@p3==1)
    c = sqr(b4)
  ELSEIF (@p3==0)
    c = -b4, z = -sqr(z)
  ELSE
    IF (whitesq)
      c = sqr(b4)
    ELSE
      c = -b4, z = -sqr(z)
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = (-.8056,-.132)
  ct = c/7 + k
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter == l1)
    z = 0, ct = c1/7 + k
  ELSEIF (iter == l2)
    z = 0, ct = c2/7 + k
  ELSEIF (iter == l3)
    z = 0, ct = c3/7 + k
  ELSEIF (iter == l4)
    z = 0, ct = c4/7 + k
  ENDIF
  IF |z|>=0,
    z = z^2 + ct + 0.125
  ELSE
    z = z^2 + ct
  ENDIF
  iter=iter+1
bailout:
  real(z)<=bailout

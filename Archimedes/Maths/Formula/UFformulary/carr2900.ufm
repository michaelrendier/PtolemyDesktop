    c = c1, z = 0
  ELSEIF (iter==l2)
    c = c2, z = 0
  ELSEIF (iter==l3)
    c = c3, z = 0
  ELSEIF (iter==l4)
    c = c4, z = 0
  ENDIF
  z = z*z + c
  c = z + c/2.125 - .0425
  iter=iter+1
bailout:
  |z|<=bailout

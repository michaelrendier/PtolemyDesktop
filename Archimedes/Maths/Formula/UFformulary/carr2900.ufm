Carr2965 {; Updated for UF2 by Erik Reckase, Feb 2000
          ; Modified Sylvie Gallet frm. 
init:
  b5=pixel^4*(pixel-.2)-.1/pixel-cos(.01/pixel) \
     +conj(.1/pixel)+.5
  b4=conj(pixel^3)*pixel-flip(asin(.01/pixel)) \
     +conj(asin(.1/pixel))
  IF (@p3==1)
    c = sqr(b4), z = sqr(b5)
  ELSEIF (@p3==0)
    c = -sqr(b4), z = -conj(b5)
  ELSE
    IF (whitesq)
      c = sqr(b4), z = sqr(b5)
    ELSE
      c = -sqr(b4), z = -conj(b5)
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = (-.7456,-.132)
  ct = c/10 + k
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter == l1)
    z = 0, ct = c1/10 + k
  ELSEIF (iter == l2)
    z = 0, ct = c2/10 + k
  ELSEIF (iter == l3)
    z = 0, ct = c3/10 + k
  ELSEIF (iter == l4)
    z = 0, ct = c4/10 + k
  ENDIF
  z = z^2 + ct
  iter=iter+1
bailout:
  real(z)<=bailout
default:
  title = "Carr 2965"
  periodicity = 0
  maxiter = 700
  magn = 1.3
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2

Carr2944 {; Updated for UF2 by Erik Reckase, Feb 2000
          ; Modified Sylvie Gallet frm. 
init:
  b4=conj(pixel)^5-flip(.01/pixel)-conj(.1/pixel)
  b5=b4-.0625-conj(.1/pixel)
  IF (@p3==1)
    c = conj(b4), z = sqr(b5)
  ELSEIF (@p3==0)
    c = -sqr(b4), z = -conj(b5)
  ELSE
    IF (whitesq)
      c = conj(b4), z = sqr(b5)
    ELSE
      c = -sqr(b4), z = -conj(b5)
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = (-.7456,-.102)
  ct = c/10 + k
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    ct = c1/10 + k, z = 0
  ELSEIF (iter==l2)
    ct = c2/10 + k, z = 0
  ELSEIF (iter==l3)
    ct = c3/10 + k, z = 0
  ELSEIF (iter==l4)
    ct = c4/10 + k, z = 0
  ENDIF
  z = z^2 + ct
  iter=iter+1
bailout:
  real(z)<=bailout
default:
  title = "Carr 2944"
  periodicity = 0
  maxiter = 700
  magn = 1.3
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)

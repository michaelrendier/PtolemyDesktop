Carr2992 {; Updated for UF2 by Erik Reckase, Feb 2000
          ; Modified Sylvie Gallet frm. 
          ; Further optimization with next UF release
init:
  b5=cabs(pixel)^5+.2
  b4=pixel-flip(.01/pixel)-conj(.1/pixel)-cabs(.1/b5)
  IF (@p3==1)
    c = conj(b4), z = sqr(b5)
  ELSEIF (@p3==0)
    c = -sqr(b4), z = -conj(|b5|)
  ELSE
    IF (whitesq)
      c = conj(b4), z = sqr(b5)
    ELSE
      c = -sqr(b4), z = -conj(|b5|)
    ENDIF
  ENDIF
  c = c + flip(.1/b5)
  z = z + flip(.1/b4)
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = (-.7456,-.132)
  ct = 2*c^2 + k
  l1=real(p1), l2=imag(p1), l3=real(p2), l4=imag(p2)
  bailout = 16, iter=0, float zro = 0
loop:
  IF (iter==l1)
    ct = 2*c1^2 + k, z = z*zro
  ELSEIF (iter==l2)
    ct = 2*c2^2 + k, z = z*zro
  ELSEIF (itEr==l3)
    ct = 2*c3^2 + k, z = z*zro
  ELSEIF (iter==l4)
    ct = 2*c4^2 + k, z = z*zro
  ENDIF
  z = .2*z^3 + z^2 + ct
  iter=iter+1
bailout:
  real(z)<=bailout
default:
  title = "Carr 2992"
  periodicity = 0
  maxiter = 700
  magn = 1
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"

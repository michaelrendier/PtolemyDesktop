Carr2918 {; Updated for UF2 by Erik Reckase, Feb 2000
          ; Modified Sylvie Gallet frm. 
init:
  b5=pixel^5-conj(.1/pixel)-flip(.1/pixel)
  b4=pixel^5-b5-conj(sqr(b5*pixel))
  IF (@p3==1)
    c = sqr(b4), z = sqr(b5)
  ELSEIF (@p3==0)
    c = -conj(b4), z = -b5
  ELSE
    IF (whitesq)
      c = sqr(b4), z = sqr(b5)
    ELSE
      c = -conj(b4), z = -b5
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  ck = .0035/21
  k = (-.7456,-.132)
  ct = c/10 - ck/c + k
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    ct = c1/10 - ck/c1 + k, z = 0
  ELSEIF (iter==l2)
    ct = c2/10 - ck/c2 + k, z = 0
  ELSEIF (iter==l3)
    ct = c3/10 - ck/c3 + k, z = 0
  ELSEIF (iter==l4)
    ct = c4/10 - ck/c4 + k, z = 0
  ENDIF
  z=z*z + ct
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 2918"
  periodicity = 0
  maxiter = 700
  magn = 1.3
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"

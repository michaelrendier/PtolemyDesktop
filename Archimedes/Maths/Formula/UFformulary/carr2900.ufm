    ct = 1.1*c2 + k, z = 0
  ELSEIF (iter==l3)
    ct = 1.1*c3 + k, z = 0
  ELSEIF (iter==l4)
    ct = 1.1*c4 + k, z = 0
  ENDIF
  z = 0.2*z^3 + z^2 + ct
  iter=iter+1
bailout:
  real(z)<=bailout

Carr2958 {; Updated for UF2 by Erik Reckase, Feb 2000
          ; Modified Sylvie Gallet frm. 
init:
  b5=b4=abs(sinh(.5+pixel/2))^3-conj(.1/pixel)-flip(.1/pixel)+.5
  IF (@p3==1)
    c = conj(b4), z = sqr(b5)
  ELSEIF (@p3==0)
    c = -sqr(b4), z = - conj(b5)
  ELSE
    IF (whitesq)
      c = conj(b4), z = sqr(b5)
    ELSE
      c = -sqr(b4), z = - conj(b5)
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = (-.7456,-.132)
  ct = c/10 + k
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter == l1)
    z = 0, ct = c1/10 + k
  ELSEIF (iter == l2)
    z = 0, ct = c2/10 + k
  ELSEIF (iter == l3)
    z = 0, ct = c3/10 + k
  ELSEIF (iter == l4)
    z = 0, ct = c4/10 + k
  ENDIF
  z = z*z + ct
  iter = iter + 1
bailout:
  real(z) <= bailout
default:

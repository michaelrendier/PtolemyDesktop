  default = (0.77, 0.69)
endparam
param kq
  caption = "Quadratic Coefficient"
  default = (-1.22,0.26)
endparam
param kc
  caption = "Cubic Coefficient"
  default = (0.36,-0.13)
endparam
func  lf

  float op1 = |o1 - c|
  complex o2 = ( @d2 * x + @k2 ) / @al2 + flip(( @a2 * y + @l2 ) / @al2 )
  float op2 = |o2 - c|
  if ((op0 < op1) && (op0 < op2))
    #z = o0

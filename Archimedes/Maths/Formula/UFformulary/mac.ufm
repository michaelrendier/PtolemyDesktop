    caption = "Bailout"
    hint = "Select your bailout value."
    default = 8.0
    min = 1
  endparam
  func fn1
    caption = "First function"
    default = ident()
  endfunc
  func fn2
    caption = "Second function"
    default = ident()
  endfunc
switch:

Mac018j {
; Translated by Mac from Fractint mac018, mac019, mac020, mac021, mac018a,
; mac019a, mac020a, mac021a, macm18, macm19, macm18a, macm19a
; macxxxa and macmxx means mutation of original formula
; Caracas, 15 de Marzo de 1999
init:
    if (@modini==0)
      #z = #pixel
    elseif (@modini==1)
      #z = #pixel * #pixel
    elseif (@modini==2)
      #z = exp(#pixel)
    elseif (@modini==3)
      #z = exp(#pixel)/#pixel
    elseif (@modini==4)
      #z = (1.0,0.0)/#pixel
    endif
  complex c = @c
loop:
  complex x = real(#z)
  complex y = imag(#z)
  if (@formula==0)
    #z = @w1 * @fn1( x * x ) - @w2 * @fn2( 2 * x * y ) + c
  elseif (@formula==1)

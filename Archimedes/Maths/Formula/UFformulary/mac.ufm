bailout:
    ((@bto == 0 ) && (|#z| < @bail)) || ((@bto == 1 ) && (|#z - #pixel| < @bail)) || \
       ((@bto == 2 ) && (|#z + #pixel| < @bail))
default:
  title = "mac403 Mandel set"
  param modini
    caption = "Init method"
    default = 0

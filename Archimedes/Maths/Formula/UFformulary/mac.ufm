}

fern_J{ 
; created by Marcelo Anelli using IfsInv
init:
  #z = #pixel
  complex c = @c
loop:
  float x = real( #z )
  float y = imag( #z )
  complex o0 = ( @d0 * x ) / @al0 + flip(( @a0 * y ) / @al0 )
  float op0 = |o0 - c|
  complex o1 = ( @d1 * x - @b1 * y + @k1 ) / @al1 + flip(( -@c1 * x + @a1 * y + @l1 ) / @al1 )
  float op1 = |o1 - c|
  complex o2 = ( @d2 * x - @b2 * y + @k2 ) / @al2 + flip(( -@c2 * x + @a2 * y + @l2 ) / @al2 )
  float op2 = |o2 - c|
  complex o3 = ( @d3 * x - @b3 * y + @k3 ) / @al3 + flip(( -@c3 * x + @a3 * y + @l3 ) / @al3 )
  float op3= |o3 - c|
  if (( op0 < op1 ) && ( op0 < op2 ) && ( op0 < op3 ))
    #z = o0
  elseif (( op1 < op0 ) && ( op1 < op2 )  && ( op1 < op3 ))
    #z = o1
  elseif (( op2 < op1 ) && ( op2 < op0 ) && ( op2 < op3 ))
    #z = o2
  elseif (( op3 < op0 ) && ( op3 < op1 ) && ( op3 < op2 ))
    #z = o3
  endif
bailout:
  |#z| < @bail
default:
  title = "IFS Fern Julia set"
  center = (0.5, 5.0)
  magn = 0.25
  param bail
    caption = "Bailout"
    hint = "Select your bailout value."
    default = 128.0
    min = 1
  endparam
  param c

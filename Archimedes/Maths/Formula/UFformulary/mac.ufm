mac401j {
; Written by Mac
; Caracas, 31 de Marzo de 1999
init:
    if (@modini==0)
      #z = #pixel
    elseif (@modini==1)
      #z = #pixel * #pixel
    elseif (@modini==2)
      #z = exp(#pixel)
    elseif (@modini==3)
      #z = exp(#pixel)/#pixel
    elseif (@modini==4)
      #z = (1.0,0.0)/#pixel
    endif
  if @appfn1
    #z = @fn1(#z)
  endif
  complex c = @c
  float rx = 0.0
  float ry = 0.0
  float dx = 0.0
  float dy = 0.0
loop:
  if (@forma == 0 )
    rx = real( #z )
    ry = imag( #z )
  elseif (@forma == 1 )
    rx = real( #z ) / imag( #z )
    ry = imag( #z ) / real( #z )
  elseif (@forma == 2 )
    rx = real( #z ) * real( #z ) / imag( #z )
    ry = imag( #z ) * imag( #z ) / real( #z )
  elseif (@forma == 3 )
    rx = real( #z ) / ( imag( #z ) * real( #z ) )
    ry = imag( #z ) / ( imag( #z ) * real( #z ) )
  endif
  if (@calc == 0 )
    if (rx < @eps)
      dx = dx * @fac1 + ( 1.0 - rx / @eps )
    endif
    if (ry < @eps)
      dy = dy * @fac1 + ( 1.0 - ry / @eps )
    endif
  elseif (@calc == 1 )
    dx = @fac1 * ( 1.0 - rx / @eps )
    dy = @fac1 * ( 1.0 - ry / @eps )
  elseif (@calc == 2 )
    if (rx < @eps)
      dx = dx * @fac1 + ( 1.0 - rx / @eps ) * ( 1.0 - rx / @eps )
    endif
    if (ry < @eps)
      dy = dy * @fac1 + ( 1.0 - ry / @eps ) * ( 1.0 - ry / @eps )
    endif
  endif
  #z = @fn2( dx + flip( dy ) ) + c
bailout:
    ((@bto == 0 ) && (|#z| < @bail)) || ((@bto == 1 ) && (|#z - #pixel| < @bail)) || \
       ((@bto == 2 ) && (|#z + #pixel| < @bail))
default:

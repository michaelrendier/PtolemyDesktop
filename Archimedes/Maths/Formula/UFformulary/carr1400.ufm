Carr1496 { ; Updated for UF2 by Erik Reckase, Feb 2000
           ; Julia
init:
  z=1/(pixel+pixel)/(tan(sqr(1/pixel*4/pixel)))
  c=z*1/(pixel+pixel)/((sqr(pixel*z-1.55)*pixel)/(6/pixel))
loop:
  z=z*z+c
  c=((1+flip(imag(sqrt(sin(c)))))*real(sqrt(tan(c)))/9+z)

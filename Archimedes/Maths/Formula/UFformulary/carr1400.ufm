Carr1437 { ; Updated for UF2 by Erik Reckase, Feb 2000
           ; What-ja-macallit ?
init:
  z=pixel
  c=(0.5/pixel)-(-0.7456,0.2)
loop:
  z=sqr(z)+(c-1.2)
  z=z+c/2
bailout:
  |z| <=4
default:
  title = "Carr 1437"
  periodicity = 0
  maxiter = 500
  magn = 1.2
  center = (0,0)
  method = multipass
}

Carr1438 { ; Updated for UF2 by Erik Reckase, Feb 2000
           ; Seems to make spiders, julias & mandels.
init:
  z=pixel
  c=(0.3/pixel)-(0.342,1.97)
loop:
  z=sqr(z)+1/log(c)
  z=z+c/2
bailout:
  |z| <=4
default:
  title = "Carr 1438"
  periodicity = 0
  maxiter = 500
  magn = 1.2
  center = (0,0)
  method = multipass
}

Carr1439 { ; Updated for UF2 by Erik Reckase, Feb 2000

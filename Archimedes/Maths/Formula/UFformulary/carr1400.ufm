  method = multipass
}

Carr1442 { ; Updated for UF2 by Erik Reckase, Feb 2000
           ; Fractal Fender C Modified.
           ; Edited for Fracint v. 20 by George Martin, 10/98
init:
  z=0.224, x=|z|, c=(-0.7456,0.2)
loop:
  IF (x>1)
    z=cosh(z)+c
  ENDIF
  z=sqr(z)+pixel
  x=|z|
bailout:
  |z|<=4
default:
  title = "Carr 1442"
  periodicity = 0
  maxiter = 500
  magn = .8
  center = (0,0)
  method = multipass
}


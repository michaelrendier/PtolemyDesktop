}

Carr1428 { ; Updated for UF2 by Erik Reckase, Feb 2000
           ; Julia,Modified BUILTN.FRM Julia
init:
  z=pixel 
  c=1/pixel
  IF (real(1/pixel)<=0)
    k1 = 4
  ELSE
    k1 = 0
  ENDIF
  IF (1/pixel > 0)
    k2 = 1
  ELSE
    k2 = 0
  ENDIF
  t=k1+real(pixel)*k2
loop:
  z=sqr(z)+c
  c=(1+flip(imag(sqrt(c))))*real(sqrt(c))/9+z 
bailout:
  |z|<=t
default:
  title = "Carr 1428"
  periodicity = 0
  maxiter = 500
  magn = 3.8
  center = (-.85,0)
  method = multipass
}


     "-Round-Ceil""-Round*Ceil""+Round*Ceil""-Round-Trunc" \
     "-Round*Trunc""+Round*Trunc""-Trunc-Floor""-Trunc*Floor" \
     "+Trunc*Floor""-Trunc-Ceil""-Trunc*Ceil""+Trunc*Ceil" \
     "-Ceil-Floor""-Ceil*Floor""+Ceil*Floor"
    visible = @usemandras && @showmandras &&  @advt && @advpg
  endparam


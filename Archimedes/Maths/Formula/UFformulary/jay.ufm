endparam

bool param ztweak18
caption = "((@pztweak1  - 1) * z^@pztweak1  + @pztweak2 ) / (@pztweak1  * z ^ (@pztweak1  - 1))"
hint ="((@pztweak1  - 1) * z^@pztweak1  + @pztweak2 ) / (@pztweak1  * z ^ (@pztweak1  - 1))"
default = false

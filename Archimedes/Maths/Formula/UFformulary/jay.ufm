hint = "Z initializer"
enum = "z / z - @init1 / (z * @init1 * #pixel )+ (@finit1 ( #pixel ))" "@init1 ^ @finit1 ( z - z * z - z )" "(@finit1 ( z - @finit2 ( @finit1 ( #pixel ))))" "z / z * ((#pixel + @init1) ^ (0.5+ #random) )" "(z + z - z + @init1 )/ (z ^ @finit1 ( #pixel ))" "z - @init2 ^ @finit1 ( @init1 / @init2 )^ @init2 " "(z - (@init1 + #pixel) + (@init2 / (@finit1 ( @init2 )- z )))" "z * z + @finit1 ( @init1 + #pixel )" "@init1" "#pixel" 
default = 9
endparam

param zfunc

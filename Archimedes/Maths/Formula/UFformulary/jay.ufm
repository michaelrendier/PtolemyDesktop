IF (@bailoutchoice == 0 || @bailoutchoice == 1 || @bailoutchoice == 7 || @bailoutchoice == 8 || @bailoutchoice == 9)

IF (@addatan2left)
leftietest = atan2(Leftside)
   ENDIF

   IF (@Leftsidebailoutvalue == 0)
float leftietest = |Leftside|
   ELSEIF (@Leftsidebailoutvalue == 1)

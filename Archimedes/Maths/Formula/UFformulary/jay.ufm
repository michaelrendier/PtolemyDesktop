ELSEIF @zbailoper == 4
IF zbailleft < zbailright
stop = 1
ELSE
stop = 0
ENDIF
ELSEIF @zbailoper == 5
IF zbailleft != zbailright
stop = 1
ELSE
stop = 0
ENDIF
ENDIF
ENDIF


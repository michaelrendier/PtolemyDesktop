z = z * p1 + (fn3 ( p3 )+ fn3 ( p3 - (fn2 ( p4 )/ (fn2 ( #pixel )* (fn3 ( z )^ (fn4 ( p4 )/ fn2 ( p4 )- fn3 ( p4 )+ fn2 ( p4 )^ fn1 ( p1 )- fn1 ( p1 )^ fn1 ( #pixel )^ (fn1 ( p3 )+ fn1 ( p2 )* fn4 ( z )- fn2 ( z )^ fn3 ( p4 )/ fn2 ( p3 )- fn3 ( p2 )/ fn1 ( #pixel )/ fn4 ( p2 )- fn2 ( p3 )+ fn4 ( #pixel )+ fn1 ( p4 )* fn3 ( p1 )- fn4 ( p4 )+ fn3 ( p3 )/ fn4 ( p1 )^ fn3 ( p1 )* fn1 ( z ))))))))
    
bailout:
 
 |z| <= @bailout
  

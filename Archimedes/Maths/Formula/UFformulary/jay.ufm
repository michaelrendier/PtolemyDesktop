ELSEIF @zAfunc==10
complex zA= z  = (@Fracfn1( (@Fracfn2( (@Fracfn3( z + 3 ^ z + (@Fracfn2( (@Fracfn1( z * @Fracfn4( #pixel )))))))))))
ELSEIF @zAfunc==11

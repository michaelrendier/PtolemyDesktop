ELSEIF @ztoper1 == 3
z = z * tztweak
ELSEIF @ztoper1 == 4
z = z / tztweak
ELSEIF @ztoper1 == 5
z = z ^ tztweak
ELSEIF @ztoper1 == 6
z = tztweak - z
ELSEIF @ztoper1 == 7
z = tztweak / z
ELSEIF @ztoper1 == 8
z = tztweak ^ z

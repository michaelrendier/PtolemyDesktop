    z1morph = (real(z1morphq) % real(z1morphp)) + flip ((real(z1morphq) % real(z1morphp)))
  endif

elseif @change == "12"
    if @mmode3 == "#z+|#z|"
    z1morphq = @nufunc3(oo+hh)^@exp2
    elseif @mmode3 == "#z-|#z|"
    z1morphq = @nufunc3(oo-hh)^@exp2
    elseif @mmode3 == "|#z|-#z"
    z1morphq = @nufunc6(jj^@exp6-pp)^@exp2
    elseif @mmode3 == "#z*|#z|"
    z1morphq = @nufunc3(oo*hh)^@exp2
    elseif @mmode3 == "#z/|#z|"
    z1morphq = @nufunc3(oo/hh)^@exp2
    elseif @mmode3 == "|#z|/#z"
    z1morphq = @nufunc6(jj^@exp6/pp)^@exp2
    elseif @mmode3 == "#z^|#z|"
    z1morphq = @nufunc3(oo^hh)^@exp2
    elseif @mmode3 == "|#z|^#z"
    z1morphq = @nufunc6(jj^@exp6^pp)^@exp2

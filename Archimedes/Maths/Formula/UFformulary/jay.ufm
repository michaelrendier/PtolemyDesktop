hint ="z * z + @pztweak1"
default = false
endparam

bool param ztweak20
caption = "z * z + #pixel"
hint ="z * z + #pixel"
default = true
endparam

heading
caption = "Bailout"
endheading

param zbail
caption = "Custom Bailout"
hint = "Custom Bailouts"
enum = "z <= @bailout" "z >= @bailout" "z  <= @bailout + #e * (z * (@bailfunc (z)))" "z <= (@bailfunc ( z * @bailout )* z)+ (@bailfunc ( z ))" "z >= @bailout)/ (@bailout + (#pixel ^ (z )))" 
endparam


            @gnarl_amt != 0)
  default = 2
  endparam

  param TextureApply
    caption = "¤ Texture Apply"
        hint = "this will change how the tweak is applied to the main variable (#z)"
        enum    = "Directly" \
              "Add" "Add Inv+Tmp" \
              "Indirectly+" "Indirectly-" \
              "Indir+" "Indir-" \
              "Diff Inv" \
              "Replace by Min" "Replace by Max" \
              "Add when Min" "Add when Max" \
              "MaxDiff" "MinDiff" "AbsDiff"
    default = 1
    visible = @usemandras && @showmandras && @advt &&  (@rnd2 != 0 || @fbmtxt != 0 || @decamt != 0 || \
            @gnarl_amt != 0)
  endparam ; apply.ipl


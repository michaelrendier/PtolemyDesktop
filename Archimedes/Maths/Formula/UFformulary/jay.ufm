    min = 0
    max = 256
  endparam
  
param p3
default = (10,10)
endparam
  
  
 }
 
random3 {
;My 3rd Randomly-generated Formula
global:
  
init:
  z = #pixel
    
  loop:
  
   z = z ^ fn3 ( #pixel )^ flip ( 4 * p3 ^ fn3 ( p2 )/ tanh ( p4 )) 
    
bailout:
 
 |z| <= @bailout
  
default:
  title = "random 3"
  periodicity = 0
  
 float param bailout
    caption = "Bail-out value"
    hint = "This is the bail-out value"
    default = 1.0
    min = 0
    max = 256
  endparam

func fn3
default = cotan()
endfunc
  
param p2
default = (0,0)
endparam

param p3
default = (.5,.5)
endparam

param p4
default = (.5,.5)
endparam  
  
  
 }
 
 random4 {
 ;My 4th Randomly-generated Formula

global:
  
init:
  z = #pixel
    
  loop:
  
z = z - z * fn1 ( z / sqrt ( 2 - asinh ( z * cosh ( p1 ))))
    
bailout:
 
 |z| <= @bailout
  
default:
  title = "random 4"
  
 float param bailout
    caption = "Bail-out value"
    hint = "This is the bail-out value"
    default = 1.0
    min = 0
    max = 256
  endparam
  
 }
 
 
  random5 {

        tmpX = real(tmpZ)
        tmpY = imag(tmpZ)
      endif



      if (@disturb1_turbulence != 0 || @disturb2_turbulence != 0)
        tmpX = tmpX * (1 + @disturb1_turbulence * sin(231*iter + #pi/31) + @disturb2_turbulence * cos(123*log(iter+2) - #pi/7) )
        tmpY = tmpY * (1 + @disturb1_turbulence * cos(321*iter + #pi/17) + @disturb2_turbulence * sin(117*log(iter+7) - #pi/5) )
      endif ; disturb_turbulence != 0




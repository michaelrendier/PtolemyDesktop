IF @oper1 == 0
z = z
ELSEIF @oper1 == 1
z = z + zA
ELSEIF @oper1 == 2
z = z - zA
ELSEIF @oper1 == 3
z = z * zA
ELSEIF @oper1 == 4
z = z / zA
ELSEIF @oper1 == 5
z = z ^ zA
ELSEIF @oper1 == 6
z = zA - z
ELSEIF @oper1 == 7
z = zA / z
ELSEIF @oper1 == 8
z = zA ^ z
ENDIF

IF @oper2 == 0
z = z
ELSEIF @oper2 == 1
z = z + zB
ELSEIF @oper2 == 2
z = z - zB
ELSEIF @oper2 == 3
z = z * zB
ELSEIF @oper2 == 4
z = z / zB
ELSEIF @oper2 == 5
z = z ^ zB
ELSEIF @oper2 == 6
z = zB - z
ELSEIF @oper2 == 7
z = zB / z
ELSEIF @oper2 == 8
z = zB ^ z
ENDIF

IF @oper3 == 0
z = z
ELSEIF @oper3 == 1
z = z + zC
ELSEIF @oper3 == 2
z = z - zC
ELSEIF @oper3 == 3
z = z * zC
ELSEIF @oper3 == 4
z = z / zC
ELSEIF @oper3 == 5
z = z ^ zC
ELSEIF @oper3 == 6
z = zC - z
ELSEIF @oper3 == 7
z = zC / z
ELSEIF @oper3 == 8
z = zC ^ z

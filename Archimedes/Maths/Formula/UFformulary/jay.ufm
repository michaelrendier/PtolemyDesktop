IF @ztoper3 == 0
z = z
ELSEIF @ztoper3 == 1
z = z + tztweak
ELSEIF @ztoper3 == 2
z = z - tztweak
ELSEIF @ztoper3 == 3
z = z * tztweak
ELSEIF @ztoper3 == 4
z = z / tztweak
ELSEIF @ztoper3 == 5
z = z ^ tztweak
ELSEIF @ztoper3 == 6
z = tztweak - z
ELSEIF @ztoper3 == 7
z = tztweak / z
ELSEIF @ztoper3 == 8
z = tztweak ^ z
ENDIF

ENDIF
ENDIF

loop:

IF |z| < @bignumber

IF @once == false
IF @ztweak1 == true
tztweak = #pixel
IF @ztoper1 == 0
z = z
ELSEIF @ztoper1 == 1
z = z + tztweak
ELSEIF @ztoper1 == 2
z = z - tztweak
ELSEIF @ztoper1 == 3
z = z * tztweak

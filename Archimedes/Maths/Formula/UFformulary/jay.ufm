  if (@mirror_x != 0)
    float x = real(#z), float mirrorVal = 0, float mirrorLim = 0

    if (@mirror_x_disturb_val != 0)
      float r = 0
      if (@mirror_x_disturb_val_mode == 0) ; disturb outval with iter
        r=19 * iter
      elseif (@mirror_x_disturb_val_mode == 1) ; disturb outval with X
        r=x
      elseif (@mirror_x_disturb_val_mode == 2) ; disturb outval with Y
        r=imag(#z)
      elseif (@mirror_x_disturb_val_mode == 3) ; disturb outval with Y
        r = cabs(#z)
      endif
      mirrorVal = mirrorVal + @mirror_x_disturb_val * sin (@mirror_x_disturb_val_freq*r + #pi/19)
    endif

    if (@mirror_x_disturb_lim != 0)
      float r = 0
      if (@mirror_x_disturb_lim_mode == 0) ; disturb lim with iter

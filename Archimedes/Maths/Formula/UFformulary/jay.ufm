      endif
      mirrorLim = mirrorLim + @mirror_x_disturb_lim * sin (@mirror_x_disturb_lim_freq*r + #pi/19)
    endif

    if ( (@mirror_x == 1 && x<@mirror_xconst+mirrorLim) || (@mirror_x == 2 && x>@mirror_xconst+mirrorLim) )
      #z = #z - 2*(x - @mirror_xconst) + mirrorVal
    endif
  endif


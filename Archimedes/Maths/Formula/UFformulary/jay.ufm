;My Super Randomly-Generated Fractal Formula
global:

init:

stop = 0

complex tztweak = 0

complex zbailleft = 0

complex zbailright = 0

IF @xmode1 == true && @switchhold != 0 && @usenewmode == true
@p1 = @switchhold
ENDIF


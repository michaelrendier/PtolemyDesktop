 random10 {
;My 10th Randomly Generated Fractal Formula

global:
  
init:
 
     z = #pixel
       
  
   
loop:
z  = p4 / (fn1 ( z * (atan ( p6 )^ #y )/ z / p5 )^ z - p2 )/ z + asinh ( 0.20188146729749584 + z ^ fn1 ( z + p3 )- sqrt ( 4.3173688893786775 / z * p1 )+ p2 )+ (p2 )
    
bailout:
 
 |z| <= @bailout
  

ELSEIF @ztoper2 == 2
z = z - tztweak
ELSEIF @ztoper2 == 3
z = z * tztweak
ELSEIF @ztoper2 == 4
z = z / tztweak
ELSEIF @ztoper2 == 5
z = z ^ tztweak
ELSEIF @ztoper2 == 6
z = tztweak - z
ELSEIF @ztoper2 == 7
z = tztweak / z
ELSEIF @ztoper2 == 8
z = tztweak ^ z
ENDIF

ENDIF
IF @ztweak3 == true
tztweak = #random
IF @ztoper3 == 0
z = z
ELSEIF @ztoper3 == 1
z = z + tztweak
ELSEIF @ztoper3 == 2
z = z - tztweak
ELSEIF @ztoper3 == 3
z = z * tztweak
ELSEIF @ztoper3 == 4
z = z / tztweak
ELSEIF @ztoper3 == 5
z = z ^ tztweak
ELSEIF @ztoper3 == 6
z = tztweak - z
ELSEIF @ztoper3 == 7
z = tztweak / z
ELSEIF @ztoper3 == 8
z = tztweak ^ z
ENDIF

ENDIF
ENDIF

IF @zfunc==0
complex z= z * z + #pixel
ELSEIF @zfunc==1
complex z= z * #pixel + z
ELSEIF @zfunc==2
complex z= z + fn1(z * z + #pixel)
ENDIF

IF @zAfunc==0
complex zA= z * z + #pixel
ELSEIF @zAfunc==1
complex zA= z * #pixel + z
ELSEIF @zAfunc==2
complex zA= z + fn1(z * z + #pixel)
ENDIF

IF @zBfunc==0

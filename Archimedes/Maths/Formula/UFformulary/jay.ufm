  endparam 

bool param ztweak17
caption = "  (p3 )/ (fn1 ( z ))"
    default = false
  endparam 

bool param ztweak18
caption = "  (z ^ p4 - e ^ z )"
    default = false
  endparam 

bool param ztweak19
caption = "  (z ^ p6 )* #pixel ^ 1 / z + (z*#pi/(z^#pi) )"

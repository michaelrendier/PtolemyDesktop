    caption = "¤¤ Apply Strength"
    default = 1.0
    visible = @usemandras && @showmandras&& @advt&& (@TextureApply > 0) &&  (@rnd2 != 0 || @fbmtxt != 0 || @decamt != 0 || \
            @gnarl_amt != 0)
  endparam ; apply.ipl

  float param TextureApply_Keep
    caption = "¤¤ Apply Keep"
    default = 1.0
    visible = @usemandras && @showmandras&& @advt&& (@TextureApply > 0) &&  (@rnd2 != 0 || @fbmtxt != 0 || @decamt != 0 || \
            @gnarl_amt != 0)
  endparam ; apply.ipl

  float param TextureApply_Smooth
    caption = "¤¤ Apply Smooth"
    default = 0.01
    visible = @usemandras && @showmandras&& @advt&& (@TextureApply > 2) &&  (@rnd2 != 0 || @fbmtxt != 0 || @decamt != 0 || \
            @gnarl_amt != 0)

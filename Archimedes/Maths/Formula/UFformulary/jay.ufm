if @oper1 == 0
   z = z
  endif
  if @oper1 == 1
z = z + ra
  endif
  if @oper1 == 2
z = z - ra
  endif
  if @oper1 == 3
z = z /ra
  endif   
  if @oper1 == 4
z = z * ra
  endif
  if @oper1 == 5
z = z ^ ra
   endif

if @oper2 == 0
   z = z
  endif
  if @oper2 == 1
z = z + ga
  endif
  if @oper2 == 2
z = z - ga
  endif
  if @oper2 == 3
z = z / ga
  endif   
  if @oper2 == 4
z = z * ga
  endif
  if @oper2 == 5
z = z ^ ga
   endif

if @oper3 == 0
   z = z
  endif
  if @oper3 == 1
z = z + ba
  endif
  if @oper3 == 2
z = z - ba
  endif

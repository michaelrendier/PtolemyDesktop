superrandom12{
;My 1st 2nd Gen Super Randomly-Generated Fractal Formula
global:

init:

stop = 0
z = 0
complex tztweak = 0

complex zbailleft = 0

complex zbailright = 0

IF @xmode1 == true && @switchhold != 0 && @usenewmode == true
@p1 = @switchhold
ENDIF

IF @xmode2 == true && @switchhold != 0 && @usenewmode == true
@p2 = @switchhold
ENDIF

IF @xmode3 == true && @switchhold != 0 && @usenewmode == true
@p3 = @switchhold
ENDIF


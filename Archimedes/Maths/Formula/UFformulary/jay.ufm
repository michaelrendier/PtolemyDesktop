   caption = "Current mode"
   default = 1
   enum = "Mandelbrot" "Julia"
   hint = "Shows the current mode for the formula."
 endparam

func fn1
default = sin()
endfunc

func fn2
default = tanh()
endfunc

func fn3
default = cotanh()
endfunc

param p1
default = (.5,.5)
endparam

param p3
default = (.5,.5)

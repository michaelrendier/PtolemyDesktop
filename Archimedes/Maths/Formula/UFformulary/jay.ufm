        tmpL = tmpL + 1
        if (@turbulence_exp_freq), frqL=sqrt(tmpL), endif
        tmpD = tmpD + yTurbulence/tmpL * (sin(frqL*distX*tmpY + (xTurbulence/tmpL * sin(frqL*distY*tmpX) )))^tmpL
        tmpD = real(@turbulenceitx(tmpD))
      endwhile


 }

random11{
;My 11th Randomly Generated Fractal Formula

global:
  
init:
  z = #pixel
  loop:

z  = exp ( p3 ^ #y - z + p3 / #pixel )^ recip ( 4 ^ z * fn3 ( cotanh ( z * z / 1 )^ tan ( p2 )- z ))    
bailout:
 

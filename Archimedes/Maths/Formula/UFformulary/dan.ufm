  Elseif fin == 9
    bt = |z - zold|
  Elseif fin == 10
    bt = |zold - z|
  Elseif fin == 11
    bt = |z + zold|
  Elseif fin == 12
    bt = |@bail_func(z)|
  Elseif fin == 13
    bt = |@bail_func(z+zold)|
  Elseif fin == 14
    bt = |@bail_func(z-zold)|
  Elseif fin == 15
    bt = |@bail_func(zold-z)|
  Endif

bailout:
  
  bt < @bailo


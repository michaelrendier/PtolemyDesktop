loop:
  z = (z-a/z)/@func1(z)*@func2(b/z+c) + #pixel
  
  If (@t_b == 0)
    bz = |z|
  Elseif (@t_b == 1)
    bz = real(z)
  Elseif (@t_b == 2)
    bz = |real(z)|
  Elseif (@t_b == 3)
    bz = imag(z)
  Elseif (@t_b == 4)
    bz = |imag(z)|
  Elseif (@t_b == 5)
    bz = real(z)*imag(z)
  Elseif (@t_b == 6)
    bz = |real(z)*imag(z)|
  Elseif (@t_b == 7)
    bz = real(z)/imag(z)
  Elseif (@t_b == 8)
    bz = |real(z)/imag(z)|
  Elseif (@t_b == 9)
    bz = imag(z)/real(z)
   Elseif (@t_b == 10)
     bz = |imag(z)/real(z)|
   Endif
   
bailout:
  bz < bailout
default:
  title = "Gorg"
  
  Param para
    Caption = "a"
    Default = (1.0,0.0)
  Endparam
  
  Param parb
    Caption = "b"
    Default = (1.0,0.0)
  Endparam
  
  Param parc

Gorg_Julia {

;You can explore this formula with the
;Gorg switching.

global:
  
  complex a = @para
  complex b = @parb
  complex c = @parc
  float bailout = @b
  
init:
  z = #pixel
  float bz = 0.0
loop:
  z = (z-a/z)/@func1(z)*@func2(b/z+c) + @seed
  
  If (@t_b == 0)
    bz = |z|
  Elseif (@t_b == 1)
    bz = real(z)
  Elseif (@t_b == 2)
    bz = |real(z)|
  Elseif (@t_b == 3)
    bz = imag(z)
  Elseif (@t_b == 4)
    bz = |imag(z)|
  Elseif (@t_b == 5)
    bz = real(z)*imag(z)
  Elseif (@t_b == 6)
    bz = |real(z)*imag(z)|
  Elseif (@t_b == 7)
    bz = real(z)/imag(z)
  Elseif (@t_b == 8)
    bz = |real(z)/imag(z)|
  Elseif (@t_b == 9)
    bz = imag(z)/real(z)
   Elseif (@t_b == 10)
     bz = |imag(z)/real(z)|
   Endif
   
bailout:
  bz < bailout
default:
  title = "Gorg Julia"
  
  Param seed
    Caption = "Seed"
    Default = (-0.875,0.0)
  Endparam
  
  Param para
    Caption = "a"
    Default = (1.0,0.0)
  Endparam
  
  Param parb

    Caption = "b"

    Default = (1.0,0.0)
  Endparam
  
  Param parc
    Caption = "c"
    Default = (1.0,0.0)

  Endparam
  
  Param t_b
    Caption = "Type Bailout"
    Enum = "|z|" "real" "|real|" "imag" "|imag|" "real*imag" "|real*imag|" "real/imag" \
                "|real/imag|" "imag/real" "|imag/real|"
    Default = 0
  Endparam
  
  Param b
    Caption = "bailout"
    Default = 4.0
  Endparam
  
  
  Func func1
    Caption = "f1"
    Default = conj()
  Endfunc
  
  Func func2
    Caption = "f2"
    Default = sinh()
  endfunc
    
switch:

  Type = "Gorg_Mand"
  para = para
  parb = parb
  parc = parc
  b = b
  t_b = t_b
  func1 = func1
  func2 = func2
}



loop:
  
  If @scelta == 0
    c = @parc
  Elseif @scelta == 1
    c = #pixel
  Else
    c = z
  Endif

  z = a * @Func1 (@seed) / @Func2 (z) + b * @Func3(z) / @Func4 (@seed) + c
  
  If @bail1 == 0
    If |z| < |bail|
      stop = 0

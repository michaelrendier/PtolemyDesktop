class JLB_UT_OneOrTwoUT(common.ulb:UserTransform) {   ; 240904
; New 240904
; Make a UserTransform our of two UserTransforms
; It's the same as JLB_UT_OneOrTwoFunc except for using transforms instead of functions
; 250111 added z powers, got rid of Add/Replace, steps, step size
public:

  ; @param pparent the parent, generally "this" for the parent, or zero
	func JLB_UT_OneOrTwoUT(Generic pparent)
    UserTransform(pparent)
    if @exch && @howmany == "2"
      m1 = new @UT2(this)
      m2 = new @UT1(this)
    else
      m1 = new @uT1(this)
      if @howmany == "2"
        m2 = new @UT2(this)
      endif
    endif
    if @version >= 250111
      pp = @p, qq = @q
      add = false, ns = 1, hh = 1
    else
      pp = qq = 1
      add = @addrep == "Add"
      ns = @nsteps, hh = @h
    endif
	endfunc

;   complex func Init(complex pz)
;     UserTransform.Init(pz)
;     m1.Init(pz)
;     m2.Init(pz)
;     return pz
;   endfunc

	complex func Iterate(complex pz)
    complex t
    int n = 0
    while n < ns
      if @howmany == "1"
        t = T1(pz)
      elseif @how == "T1+T2"
        t = T1(pz) + T2(pz)
      elseif @how == "T1-T2"
        t = T1(pz) - T2(pz)
      elseif @how == "T1*T2"
        t = T1(pz) * T2(pz)
      elseif @how == "T1/T2"
        t = T1(pz) / T2(pz)
      elseif @how == "T1^T2"
        t = T1(pz) ^ T2(pz)
      else;if @how == "T1(T2)"
        t = T1(T2(pz))
      endif
      t = hh*t
      if add, pz = pz + t, else, pz = t, endif
      n = n + 1
    endwhile
    return pz
	endfunc

  complex func T1(complex z)
    return m1.Iterate(@a*z^pp)
  endfunc
  complex func T2(complex z)
    return m2.Iterate(@b*z^qq)
  endfunc

protected:
  UserTransform m1
  UserTransform m2
  float pp
  float qq
  bool add
  int ns
  float hh

default:
  rating = Recommended
  title = "1 or 2 Transforms"
  int param version
    caption = "Version"
     default = 250111
     visible = @version < 250111
	endparam
  heading
    text = "(Current is 250111.}"
		visible = @version < 250111
  endheading

  param addrep
    caption = "Add or Replace?"
    enum = "Add" "Replace"
    default = 1
    visible = @version < 250111
  endparam

  int param nsteps
    caption = "    # of steps"
    default = 1
    min = 1
    visible = @version < 250111
  endparam
  float param h
    caption = "    Step size"
    default = 1
    visible = @version < 250111
  endparam
  heading
    visible = @version < 250111
  endheading

  param howmany
    caption = "1 or 2 transforms?"
    enum = "1" "2"
    default = 1
  endparam
  param how
    caption = "Combine"
    default = 5
    enum = "T1+T2" "T1-T2" "T1*T2" "T1/T2" "T1^T2" "T1(T2)"
    visible =  @howmany == "2"
  endparam

  bool param exch
    caption = "Switch T1 and T2?"
    default = false
    visible = @howmany == "2" && @how != 0 && @how != 2
  endparam

  heading
    caption = "First transform"
    visible = @howmany == 1
  endheading
  UserTransform param UT1
    caption = "T1(a*z^p)"
    default = JLB_UT_Linear
  endparam
  complex param a
    caption = "a"
    default = (1,0)
  endparam
  float param p
    caption = "p"
    default = 2
    visible = @version >= 250111
  endparam

  heading
    caption = "Second transform"
    visible = @howmany == 1
  endheading
  UserTransform param UT2
    caption = "T2(b*z)^q"
    default = JLB_FTransform
    visible =  @howmany == "2"
  endparam
  complex param b
    caption = "b"
    default = (1,0)
    visible =  @howmany == "2"
  endparam
  float param q
    caption = "q"
    default = 2
    visible = @version >= 250111 && @howmany == "2"
  endparam
}


class JLB_39trunc*(FT) {
public:
  complex func Iterate(complex pz)
    float x = real(pz)
    if x >= 0, x = ceil(x), else, x = floor(x), endif
    float y = imag(pz)
    if y >= 0, y = ceil(y), else, y = floor(y), endif
    return x + flip(y)
  endfunc
default:
  title = "39 trunc*"
}

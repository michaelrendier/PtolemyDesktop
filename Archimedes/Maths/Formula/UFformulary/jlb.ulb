}
class JLB_CD202(CD2) {
public:
  float func Iterate(complex zz)
    float d = (y2-x2)*(x-a)*(2*x-3*a) - b*(c2-2*x)^2
    if m_scale, d = d/c4, endif
    return d
  endfunc
default:
  title = "CD202 Ampersand"
}
class JLB_CD203(CD2) {
public:

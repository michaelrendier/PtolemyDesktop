	func Distance(Generic pparent)
		Generic.Generic(pparent)
	endfunc

  func Init(complex zz)
    m_mode = 0
    m_abs_value = false
  endfunc

  func SetParams(int m, bool a)
    m_mode = m
    m_abs_value = a
  endfunc

  func SetIter(int k)
    m_iter = k
  endfunc
  int func GetIter( )
    return m_iter
  endfunc

	float func Iterate(complex zz)
		return cabs(zz)
	endfunc

protected:
  int  m_mode
  bool m_abs_value
  int m_iter

default:
	int param v_Distance
		caption = "Version (Distance)"
		default = 211019
		visible = false
	endparam
}


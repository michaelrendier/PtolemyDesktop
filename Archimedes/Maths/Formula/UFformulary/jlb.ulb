class JLB_DChopperPlus(Distance) {
; this is a re-writing and expansion of Chopper in om.ucl
; for use as a plug-in for Color by Distance
; 250606 added general UT to possibilities
; 250907 added "ident", backward compatible
public:
  import "common.ulb"
  import "Standard.ulb"

  func JLB_DChopperPlus(Generic pparent)
    Distance(pparent)
    if @type == "Function"
      m_f = new @f_UT(this)
    else
      m_f = new @g_UT(this)
    endif
    m_s = new @s_UT(this)
  endfunc

  float func Iterate(complex zz)

    complex v = m_f.Iterate(zz)
    v = m_s.Iterate(v)
    if @how == "round"
      zz = round(zz)
    elseif @how == "ceil"
      zz = ceil(zz)
    elseif @how == "floor"
      zz = floor(zz)
    elseif @how == "trunc"
      zz = trunc(zz)
    elseif @how == "trunc*"
      float x = real(zz)
      if x >= 0, x = ceil(x), else, x = floor(x), endif
      float y = imag(zz)
      if y >= 0, y = ceil(y), else, y = floor(y), endif
      zz = x + flip(y)
    ;else
    ;  zz = zz
    endif
    float d = cabs(v - zz)
    return d
  endfunc

private:
  UserTransform m_f
  UserTransform m_s

default:
  title = "Chopper +/-"
  rating = Recommended

	int param version
		caption = "Version"
		default = 240918
		visible = @version < 240918
	endparam
  heading
    text = "(current is 240918.}"
		visible = @version < 240918
  endheading

  param type
    caption = "Type?"
    enum = "Function" "Transform"
    default = 0
  endparam

  UserTransform param f_UT
    caption = "Function"
    default = JLB_UT_OneFunction
    selectable = false
    visible = @type == "Function"
  endparam
  UserTransform param g_UT
    caption = "Transform"
    default = Standard_Inverse
    visible = @type == "Transform"
  endparam

  heading
  endheading
  UserTransform param s_UT
    caption = "Signs?"
    default = JLB_UT_XY_Signs
    selectable = false
  endparam
  heading
  endheading
  param how
    caption = "How?"
    enum = "round" "ceil" "floor" "trunc" "trunc*" "ident"
    default = 0
  endparam
  heading
  endheading
}

class JLB_UT_PowerPlusFunc(common.ulb:UserTransform) { ; 241016
; New 241016
; Make a UserTransform out of a power and a function
; simplified version of "1 or 2 functions"
 public:
   func JLB_UT_PowerPlusFunc(Generic pparent)
    UserTransform(pparent)
    menu = @version < 250921 && @which == "Menu"
    if menu
      m_fm = new @fm(this)
    else
      m_fp = new @fp(this)
    endif
  endfunc

  complex func Iterate(complex pz)
    if menu
      return pz^@p + @a * m_fm.Iterate(@b*pz)
    else
      return pz^@p + @a * m_fp.Iterate(@b*pz)
    endif
  endfunc

private:
  UserTransform m_fm
  FT m_fp
  bool menu

default:
  rating = Recommended
  title = "Power + Function"
  int param version
     caption = "Version"
     default = 250921
    visible = @version < 250921
  endparam
   heading
     text = "(Current is 250921.)"
     visible = @version < 250921
   endheading

  heading
    text = "    z_new = z^p + a*f(b*z)"
  endheading

  complex param p
    caption = "p"
    default = 2
  endparam
  param which
    caption = "Choose f from"
    enum = "Menu" "Plug-in"
    default = 0
     visible = @version < 250921
  endparam
;   heading
;   endheading

  complex param a
    caption = "a"
    default = (1,0)
  endparam
  UserTransform param fm      ; caption doesn't show
    default = JLB_FTransform
    selectable = false
    visible = @version < 250921 && @which == "Menu"
  endparam
  FT param fp
    caption = "f"
    default = JLB_01sin
    visible = @version >= 250921 || @which == "Plug-in"
  endparam
  complex param b
    caption = "b"
    default = (1,0)
  endparam
}


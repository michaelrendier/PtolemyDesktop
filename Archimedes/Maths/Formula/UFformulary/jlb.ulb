class JLB_UT_TriFunc(common.ulb:UserTransform) {
; a plug-in transform version of Trifunctional in mt.ucl
; new 250810
public:

	func JLB_UT_TriFunc(Generic pparent)
    UserTransform(pparent)
    m_ff = new @ff(this)
    m_fx = new @fx(this)
    m_fy = new @fy(this)
	endfunc

  complex func Iterate(complex pz)
    float xx = real(pz), float yy = imag(pz)
    if @option == 2 || @option == 3, xx = -xx, endif
    if @option == 1 || @option == 3, yy = -yy, endif
    if @switch
      float t = xx, xx = yy, yy = t
    endif
    complex z1 = @a*m_fx.Iterate(xx)
    complex z2 = @b*m_fy.Iterate(yy)
    complex Zt = m_ff.Iterate(z1 + flip(z2))
    return Zt
  endfunc

private:
  FT m_ff
  FT m_fx
  FT m_fy

default:
  title = "Trifunctional +/-"
  rating = Recommended

	int param version
		caption = "Version"
		default = 250810
		visible = @version < 250810
	endparam
  heading
    text = "(current is 250810.}"
		visible = @version < 250810
  endheading

;   heading
;     caption = "Main function"
;   endheading
;   UserTransform param ff
;     default = JLB_FTransform
;     selectable = false
;   endparam
  FT param ff
    caption = "Main function"
    default = JLB_00ident
  endparam

  param option
    caption = "Option"
    enum = " x  y" " x -y" "-x  y" "-x -y"
    default = 0
  endparam
  bool param switch
    caption = "Switch x, y?"
    default = false
  endparam
;   heading
;     caption = "X function"
;   endheading
;   UserTransform param fx
;     default = JLB_FTransform
;     selectable = false
;   endparam
  FT param fx
    caption = "X function"
    default = JLB_44logit
  endparam
  complex param a
    caption = "Multiplier"
    default = 1
  endparam
;   heading
;     caption = "Y function"
;   endheading
;   UserTransform param fy
;     default = JLB_FTransform
;     selectable = false
;   endparam
  FT param fy
    caption = "Y function"
    default = JLB_44logit
  endparam
  heading
  endheading
  complex param b
    caption = "Multiplier"
    default = 1
  endparam
}

class JLB_UT_Harlequin(common.ulb:UserTransform) {
; a plug-in transform adapted from Harlequin in mt.ucl
; new 250810
; 250913 cleaned up
; 250921 functions via plug-ins
public:
  import "common.ulb"

	func JLB_UT_Harlequin(Generic pparent)
    UserTransform(pparent)
    m_f = new @f1(this)
	endfunc

  complex func Iterate(complex pz)
    complex a = atan2(pz)     ; -pi..pi with a cut
    a = @mul * a*a + @p1      ; squaring removes the cut
    complex b
          if @opt1 == 0, b = @p2 - a*a
      elseif @opt1 == 1, b = @p2 + a*a
      elseif @opt1 == 2, b = @p2 - a
      else             , b = @p2 + a
      endif
    complex Z1 = m_f.Iterate(b)
    ; the next is now in Coloring
       ; skip first, second, larger, smaller
    ;Z1 = Combine2C.Go(pz, Z1, @opt2+4)
    return Z1
  endfunc

private:
  FT m_f

default:
  title = "Harlequin +/-"
  rating = Recommended

	int param version
		caption = "Version"
		default = 250921
		visible = @version < 250921
	endparam
  heading
    text = "(current is 250921.}"
		visible = @version < 250921
  endheading

  complex param mul
    caption = "Angle multiplier"
    default = 2
  endparam
;   heading
;     caption = "Function"
;   endheading
  complex param p1
    caption = "p1"
    default = 0
  endparam
  param opt1
    caption = "Option 1"
    enum = "1" "2" "3" "4"
    default = 0
  endparam
  FT param f1
    default = JLB_01sin
  endparam
  complex param p2
    caption = "p2"
    default = 1
  endparam
  param opt2
    caption = "Combination"
    enum = "Sum" "Difference" "Product" "Geometric Average" \
         "Harmonic Average" "Hypotenuse"
    default = 1
  endparam
}


class JLB_DBeads(Distance) {
; a plug-in version of Beads in mt.ucl
; new 250806
public:
  import "common.ulb"

	func JLB_DBeads(Generic pparent)
    Distance(pparent)
    m_f1 = new @f1(this)
    m_f2 = new @f2(this)
	endfunc

  func Init(complex zz)
  endfunc

  float func Iterate(complex zz)
    float x = real(zz), float y = imag(zz)

    float d1 = abs(real(m_f1.Iterate(y))) - @p1*abs(x)
    float d2 = abs(real(m_f2.Iterate(x))) - @p2*abs(y)

    if d1 > 0 && d2 > 0
      return Combine2F.Go(d1, d2, @type)
    elseif d1 > 0
      return d1
    elseif d2 > 0
      return d2
    else
      return -1
    endif
  endfunc


private:
  UserTransform m_f1
  UserTransform m_f2

default:
  title = "Beads +/-"
  rating = Recommended

	int param version
		caption = "Version"
		default = 250806
		visible = @version < 250806
	endparam
  heading
    text = "(current is 250806.)"
		visible = @version < 250806
  endheading

  heading
    caption = "Calculate two distances"
  endheading
  heading
    caption = "First"
  endheading

    UserTransform param f1
    default = JLB_FTransform
    selectable = false
  endparam
  float param p1
    caption = "p1"
    default = 1
  endparam

  heading
    caption = "Second"
  endheading
  UserTransform param f2
    default = JLB_FTransform
    selectable = false
  endparam
  float param p2
    caption = "p2"
    default = 1
  endparam

  heading
    caption = "If both distances are positive"
  endheading
;   param type
;     caption = "Use option"
;     enum = "1" "2" "3" "4" "5" "6" "7" "8" "9"
;     default = 0
;   endparam
  param type
    caption = "Use option"
    enum = "First" "Second" "Larger" "Smaller" \
         "Sum" "Difference" "Product" "Geometric Average" \
         "Harmonic Average" "Hypotenuse"
    default = 3
  endparam
}

class JLB_UT_Sine(common.ulb:UserTransform) {
; a plug-in transform version of sine in mt.ucl
; new 250810
; 250921 functions via plug-ins
public:

	func JLB_UT_Sine(Generic pparent)
    UserTransform(pparent)
    m_f1 = new @f1(this)
    m_f2 = new @f2(this)
    m_f3 = new @f3(this)
	endfunc

  complex func Iterate(complex pz)
    ; cartesian
    float x = @ha * real(m_f3.Iterate(@ht * imag(m_f1.Iterate(pz))))
    float y = @va * real(m_f3.Iterate(@vt * real(m_f2.Iterate(pz))))
    complex Z1 = x + flip(y)
    ; polar
    float r0 = cabs(m_f1.Iterate(pz))
    float theta = MyMath.atan2a(m_f2.Iterate(pz))  ; 0..2*pi
    float r =  r0 + @ha * sin(@ht * theta)
    theta = theta + @va * cos(@vt * r0)
    complex Z2 = r*exp(flip(theta))
    ; combine
    Z2 = Combine2C.Go(Z1, Z2, @opt)
    return Z2
  endfunc

private:
  FT m_f1
  FT m_f2
  FT m_f3

default:
  title = "Sine +/-"
  rating = Recommended

	int param version
		caption = "Version"
		default = 250810
		visible = @version < 250810
	endparam
  heading
    text = "(current is 250810.)"
		visible = @version < 250810
  endheading

  heading
    caption = "Functions"
  endheading
;   heading
;     caption = "First"
;   endheading
;   UserTransform param f1
;     default = JLB_FTransform
;     selectable = false
;   endparam
  FT param f1
    caption = "First function"
    default = JLB_01sin
  endparam
;   heading
;     caption = "Second"
;   endheading
;   UserTransform param f2
;     default = JLB_FTransform
;     selectable = false
;   endparam
  FT param f2
    caption = "Second function"
    default = JLB_01sin
  endparam
;   heading
;     caption = "Third"
;   endheading
;   UserTransform param f3
;     default = JLB_FTransform
;     selectable = false
;   endparam
  FT param f3
    caption = "Third function"
    default = JLB_01sin
  endparam

  heading
  endheading
  param ht
    caption = "Frequency #1"
    default = 10.0
  endparam
  param ha
    caption = "Amplitude #1"
    default = 0.5
  endparam
  param vt
    caption = "Frequency #2"
    default = 10.0
  endparam
  param va
    caption = "Amplitude #2"
    default = 0.5
  endparam

  param opt
    caption = "Combine type"
    enum = "First" "Second" "Larger" "Smaller" \
         "Sum" "Difference" "Product" "Geometric Average" \
         "Harmonic Average" "Hypotenuse"
    default = 0
  endparam
}

class JLB_UT_Martin(common.ulb:UserTransform) {
; a plug-in version adapted from mt-martin-trap in mt.ucl
; new 250810
; 250921 functions via plug-ins
public:

	func JLB_UT_Martin(Generic pparent)
    UserTransform(pparent)
    m_f1 = new @f1(this)
    m_f2 = new @f2(this)
    m_f3 = new @f3(this)
	endfunc

  complex func Iterate(complex pz)
    complex Z1 = m_f1.Iterate(pz) / @scale
    float x = real(Z1)
    float y = imag(Z1)
    int iter = 0
    while iter < @max_iter
      float xx = x
    ; x = y - sin(x)
      x = y - real(m_f2.Iterate(x))
      y = @p - xx
      iter = iter + 1
    endwhile
    Z1 = m_f3.Iterate(x + flip(y))
    return Z1
  endfunc

private:
  FT m_f1
  FT m_f2
  FT m_f3

default:
  title = "Martin +/-"
  rating = Recommended

	int param version
		caption = "Version"
		default = 250810
		visible = @version < 250810
	endparam
  heading
    text = "(current is 250810.)"
		visible = @version < 250810
  endheading

  heading
    caption = "Functions"
  endheading
  FT param f1
    caption = "First"
    default = JLB_00ident
  endparam
  FT param f2
    caption = "Second"
    default = JLB_01sin
  endparam
  FT param f3
    default = JLB_00ident
    caption = "Third"
  endparam

  heading
  endheading

  float param @scale
    caption = "Martin scale"
    default = 1.0
  endparam
  int param max_iter
    caption = "Martin iterations"
    default = 10
  endparam
  float param p
    caption = "Martin parameter"
    default = 3.141592653589793
  endparam
}

class JLB_UT_Vine(common.ulb:UserTransform) {
; a plug-in version of various trap colorings, especially vine in mt.ucl
; new 250814
; 250921 functions via plug-ins
public:

	func JLB_UT_Vine(Generic pparent)
    UserTransform(pparent)
    m_fi = new @fi(this)
    m_fp = new @fp(this)
    m_fs = new @fs(this)
    m_ff = new @ff(this)

    if @type < 4
      ax = ay = @a, sx = sy = 1 , bx = by = 1
      if @signsa == "- +" || @signsa == "- -", ax = -@a, endif
      if @signsa == "+ -" || @signsa == "- -", ay = -@a, endif
      if @signs2 == "- +" || @signs2 == "- -", sx = -1, endif
      if @signs2 == "+ -" || @signs2 == "- -", sy = -1, endif
      if @signsb == "- +" || @signsb == "- -", bx = -@b, endif
      if @signsb == "+ -" || @signsb == "- -", by = -@b, endif
    else
      az = @a, sz = 1, bz = @b
      if @sgna == "-", az = -@a, endif
      if @sgn2 == "-", sz = -1, endif
      if @sgnb == "-", bz = -@b, endif
    endif
	endfunc


  ;  1   x =          x + signsa * a * fp(y)
  ;  1   y =          y + signsa * a * fp(x)    and also for 1+, 2, 2+
  ;  1+  x =          x + signsa * a * fp(y + signsb * b * fs(y))
  ;  2   x = signs2 * y + signsa * a * fp(x)
  ;  2+  x = signs2 * y + signsa * a * fp(x + signsb * b * fs(x))

  ;  3   z =        z  + sgna * a * fp(zf)
  ;  3+  z =        z  + sgna * a * fp(zf + sgnb * b * fs(zf))
  ;  4   z = sgn2 * zf + sgna * a * fp(z )
  ;  4+  z = sgn2 * zf + sgna * a * fp(z  + sgnb * b * fs(z))

;$define debug
  complex func Iterate(complex pz)
    complex z = m_fi.Iterate(pz) * @scale
    float x = real(z)
    float y = imag(z)
if |#pixel-1|<1e-6
print(pz, z)
endif
    int iter = 0
    while iter < @max_iter
      float xarg, float yarg
      complex zf = flip(z)
      complex zarg

      if @type == "1" || @type == "1+"
        xarg = y, yarg = x
        if @type == "1+"
          xarg = xarg + bx * real(m_fs.Iterate(xarg))
          yarg = yarg + by * real(m_fs.Iterate(yarg))
        endif
        x =       x + ax * real(m_fp.Iterate(xarg))
        y =       y + ay * real(m_fp.Iterate(yarg))

      elseif @type == "2" || @type == "2+"
        xarg = x, yarg = y
        if @type == "2+"
          xarg = xarg + bx * real(m_fs.Iterate(xarg))
          yarg = yarg + by * real(m_fs.Iterate(yarg))
        endif
        float xx = x
        x = sx *  y + ax * real(m_fp.Iterate(xarg))
        y = sy * xx + ay * real(m_fp.Iterate(yarg))

      elseif @type == "3" || @type == "3+"
        zarg = zf
        if @type == "3+"
          zarg = zarg + bz * m_fs.Iterate(zarg)
        endif
        z = z + az * m_fp.Iterate(zarg)

      else;if @type == "4" || @type == "4+"
        zarg = z
        if @type == "4+"
          zarg = zarg + bz * m_fs.Iterate(zarg)
        endif
        z = sz * zf + az * m_fp.Iterate(zarg)
      endif
      iter = iter + 1
if |#pixel-1|<1e-6
print("x,y ",x," ", y)
endif
    endwhile
    if @type < 4, z = x + flip(y), endif
    z = m_ff.Iterate(z)
if |#pixel-1|<1e-6
print(z)
endif
    return z
  endfunc

private:
  FT m_fi
  FT m_fp
  FT m_fs
  FT m_ff
  float ax, float ay, float az
  float sx, float sy, float sz
  float bx, float by, float bz

default:
  title = "Vine +/-"
  rating = Recommended

	int param version
		caption = "Version"
		default = 250814
		visible = @version < 250814
	endparam
  heading
    text = "(current is 250814.)"
		visible = @version < 250814
  endheading

  param type
    caption = "Type"
    enum = "1" "1+" "2" "2+" "3" "3+" "4" "4+"
    default = 0
  endparam

  heading
    caption = "Functions"
  endheading
  FT param fi
    caption = "Initial"
    default = JLB_00ident
  endparam
  FT param fp
    caption = "Primary"
    default = JLB_09tan
  endparam
  FT param fs
    default = JLB_00ident
    caption = "Secondary"
    visible = @type == "1+" || @type == "2+"
  endparam
  FT param ff
    default = JLB_00ident
    caption = "Final"
  endparam

  heading
  endheading

  float param @scale
    caption = "Scale"
    default = 0.25
  endparam
  int param max_iter
    caption = "Iterations"
    default = 1
    min = 1
  endparam
  param signs2
    caption = "Signs"
    enum= "+ +" "+ -" "- +" "- -"
    default = 0
    visible = @type == "2" || @type == "2+"
  endparam
  param sgn2
    caption = "Signs"
    enum= "+" "-"
    default = 0
    visible = @type == "4" || @type == "4+"
  endparam
  float param a
    caption = "Parameter a"
    default = 1
  endparam
  param signsa
    caption = "Signs - a"
    enum= "+ +" "+ -" "- +" "- -"
    default = 0
    visible = @type < 4
  endparam
  param sgna
    caption = "Signs - a"
    enum= "+" "-"
    default = 0
    visible = @type >= 4
  endparam

  float param b
    caption = "Parameter b"
    default = 1
    visible = @type == "1+" || @type == "2+"
  endparam
  param signsb
    caption = "Signs - b"
    enum= "+ +" "+ -" "- +" "- -"
    default = 0
    visible = @type == "1+" || @type == "2+"
  endparam
  param sgnb
    caption = "Signs - b"
    enum= "+" "-"
    default = 0
    visible = @type == "3+" || @type == "4+"
  endparam
}


class JLB_DPointAxis(Distance) {
; a plug-in version of Point and Axis in mt.ucl
; new 250811
public:
  import "common.ulb"

	func JLB_DPointAxis(Generic pparent)
    Distance(pparent)
    m_f1 = new @f1(this)
    m_f2 = new @f2(this)
    c = cos(@axis * #pi/180)
    s = sin(@axis * #pi/180)
; ;$define debug
; complex v = (2,0)
; complex w = (1,1)
; complex z
; int i = 0
; while i <= 9
;   z = combine2c.go(v, w, i)
;   print(i, z)
;   i=i+1
; endwhile
	endfunc

  func Init(complex zz)
  endfunc

  float func Iterate(complex zz)
    float t = c * real(zz) + s * imag(zz)      ; dot product
    float da = abs(real(m_f1.Iterate(t)))
    float dp = cabs(m_f2.Iterate(zz - @pt))
    return Combine2F.Go(da, dp, @type)
  endfunc

private:
  UserTransform m_f1
  UserTransform m_f2
  float c
  float s

default:
  title = "Point and Axis"
  rating = Recommended

	int param version
		caption = "Version"
		default = 250811
		visible = @version < 250811
	endparam
  heading
    text = "(current is 250811.)"
		visible = @version < 250811
  endheading

  heading
    caption = "Calculate two distances"
  endheading
  heading
    caption = "Axis"
  endheading
  float param axis
    caption = "Axis (degrees)"
    default = 90
  endparam
  heading
    caption = "Axis function"
  endheading
  UserTransform param f1
  default = JLB_FTransform
  selectable = false
  endparam

  heading
    caption = "Point"
  endheading
  param pt
    caption = "Point"
    default = (1,0)
  endparam
  heading
    caption = "Point function"
  endheading
  UserTransform param f2
    default = JLB_FTransform
    selectable = false
  endparam

  heading
    caption = "Combine distances"
  endheading
;   param type
;     caption = "Use option"
;     enum = "1" "2" "3" "4" "5" "6" "7" "8" "9"
;     default = 0
;   endparam
  param type
    caption = "Use option"
    enum = "Point to z" "Axis to z" "Larger" "Smaller" \
         "Sum" "Difference" "Product" "Geometric Average" \
         "Harmonic Average" "Hypotenuse"
    default = 3
  endparam
}

class JLB_UT_PointLine(common.ulb:UserTransform) {
; a plug-in version inspired by Point and Axis in mt.ucl
; and Two Points, also in mt.ucl
; new 250819
; 250906 allowed PP and LL as well as PL
; 250911 added functions
; 250921 functions via plug-ins
public:
  import "common.ulb"

	func JLB_UT_Pointline(Generic pparent)
    UserTransform.UserTransform(pparent)
    theta1 = @angle1 * #pi/180
    theta2 = @angle2 * #pi/180
    m0 = new @f0(this)
    m1 = new @f1(this)
    m2 = new @f2(this)
	endfunc
                         ; maybe f(@p1) early
  complex func Iterate(complex pz)
    pz = m0.Iterate(pz)
    complex Z1
    if @which < 2
      Z1 = @p1 - pz
    else
      Z1 = Geometry.VectorPointToLine(pz, @p1, theta1)
    endif
    Z1 = m1.Iterate(Z1)     ; instead of here?
    complex Z2
    if @which == 0
      Z2 = @p2 - pz
    else
      Z2 = Geometry.VectorPointToLine(pz, @p2, theta2)
    endif
    Z2 = m2.Iterate(Z2)
    Z1 = Combine2C.Go(Z1, Z2, @type)
    return Z1
  endfunc

private:
  float theta1
  float theta2
  FT m0
  FT m1
  FT m2

default:
  title = "Point and Line"
  rating = Recommended

	int param version
		caption = "Version"
		default = 250905
		visible = @version < 250905
	endparam
  heading
    text = "(current is 250905.)"
		visible = @version < 250905
  endheading
;   heading
;     caption = "Z function"
;   endheading
;   UserTransform param f_UT
;     ;caption = "invisible"
;     default = JLB_FTransform
;     selectable = false
;   endparam
  FT param f0
    caption = "Initial function"
    default = JLB_00ident
  endparam

  param which
    caption = "Which?"
    enum = "Point + Point" "Point + Line" "Line + Line"
    default = 1
  endparam

  heading
    caption = "Point"
    visible = @which < 2
  endheading
  heading
    caption = "Line through point 1 at angle 1"
    visible = @which == 2
  endheading
  heading
    caption = "Z1"
  endheading
  param p1
    caption = "Point 1"
    default = (1,0)
  endparam
  float param angle1
    caption = "Angle 1 (degrees)"
    default = 45
    visible = @which == 2
  endparam
;   UserTransform param f1
;     ; caption doesn't show
;     default = JLB_FTransform
;     selectable = false
;   endparam
  FT param f1
    caption = "Function"
    default = JLB_05cos
  endparam

  heading
    caption = "Point"
    visible = @which == 0
  endheading
  heading
    caption = "Line through point 2 at angle 2"
    visible = @which > 0
  endheading
  heading
    caption = "Z2"
  endheading
  param p2
    caption = "Point 2"
    default = (-1,0)
  endparam
  float param angle2
    caption = "Angle 2 (degrees)"
    default = -45
    visible = @which > 0
  endparam
;   UserTransform param f2
;     ; caption doesn't show
;     default = JLB_FTransform
;     selectable = false
;   endparam
  FT param f2
    caption = "Function"
    default = JLB_01sin
  endparam

  heading
  endheading

  param type
    caption = "Combine method?"
    enum = "Z1" "Z2" "Larger" "Smaller" \
         "Sum" "Difference" "Product" "Geometric Average" \
         "Harmonic Average" "Hypotenuse"
    default = 3
  endparam
}


class JLB_UT_TwoUT(common.ulb:UserTransform) {
; New 250902
; Make a UserTransform out of two UserTransforms in succession
; Simplified version of JLB_UT_OneOrTwoUT
; 250906 allow combination of T1 and T2
public:
  ;import "dmj5.ulb"
	func JLB_UT_TwoUT(Generic pparent)
    UserTransform(pparent)
    if @exch
      m1 = new @UT2(this)
      m2 = new @UT1(this)
    else
      m1 = new @uT1(this)
      m2 = new @UT2(this)
    endif
	endfunc

	complex func Iterate(complex pz)
    complex Z1 = m1.Iterate(pz)
    if @how == "T1 then T2"
      return m2.Iterate(Z1)
    else
      complex Z2 = m2.Iterate(pz)
      return Combine2C.go(Z1, Z2, @opt)
    endif
	endfunc

protected:
  UserTransform m1
  UserTransform m2

default:
  rating = Recommended
  title = "Two Transforms"
  int param version
    caption = "Version"
     default = 250902
     visible = @version < 250902
	endparam
  heading
    text = "(Current is 250902.}"
		visible = @version < 250902
  endheading

  param how
    caption = "How?"
    enum = "T1 then T2" "Combine T1 and T2"
    default = 0
  endparam
  param opt
    caption = "Combine method"
    enum = "T1" "T2" "Larger" "Smaller" \
         "Sum" "Difference" "Product" "Geometric Average" \
         "Harmonic Average" "Hypotenuse"
    default = 3
    visible = @how == 1
  endparam
  heading
    visible = @how == 1
  endheading

  UserTransform param UT1
    caption = "T1"
    default = JLB_FTransform
  endparam
  heading
  endheading
  UserTransform param UT2
    caption = "T2"
    default = JLB_UT_Moebius
  endparam
  heading
  endheading
  bool param exch
    caption = "Switch T1 and T2?"
    default = false
  endparam
}

class JLB_UT_Null(common.ulb:UserTransform) {
; revived 250906
public:
  func JLB_UT_NULL(Generic pparent)
    UserTransform.UserTransform(pparent)
  endfunc
  complex func Iterate(complex pz)
    return pz
  endfunc
default:
  title = "None"
  rating = Recommended
}

class JLB_UT_Inverse(common.ulb:UserTransform) {
; generalized version of Inverse in Standard.ulb
; new 250905
 public:
  func JLB_UT_Inverse(Generic pparent)
		UserTransform.UserTransform(pparent)
    if @screen_center
      ctr = #center
    else
      ctr = @center
    endif
  endfunc

  complex func Iterate(complex pz)
    return ctr + (@radius / (pz - ctr)) ^ @p
  endfunc

private:
  complex ctr

default:
  rating = Recommended
  title = "Inverse"
  int param version
    caption = "Version"
     default = 250905
     visible = @version < 250905
	endparam
  heading
    text = "(Current is 250905.}"
		visible = @version < 250905
  endheading

  bool param screen_center
    caption = "Use screen center?"
    default = true
  endparam
  complex param center
    caption = "Center"
    default = (0,0)
    visible = !@screen_center
  endparam
  float param radius
    caption = "Radius"
    default = 1
    min = 0
  endparam
  complex param p
    caption = "power"
    default = 1
  endparam
}

class JLB_UT_Moebius(common.ulb:UserTransform) {
; 250918 revised, removed @ab parameter and
; allowed combining Z1 and Z2
 public:
  func JLB_UT_Moebius(Generic pparent)
		UserTransform.UserTransform(pparent)
    useT = (@version <  250918 && @fz > 0) || \
           (@version >= 250918 && @gz > 0)
    if useT
      m_t = new @fT(this)
    endif
    if @version < 250918, a = @ab, else, a = (1,0), endif
  endfunc

  complex func Iterate(complex pz)
    complex Z1 = pz
    if useT
      Z1 = m_t.Iterate(a*pz)
    endif
    complex Z2 = (@a0 + @a1*Z1) / (@b0 + @b1*Z1)
    if useT &&  @version >= 250918
      return Combine2C.Go(Z1, Z2, @opt)
    endif
    return Z2
  endfunc

private:
  UserTransform m_t
  complex a
  bool useT

default:
  rating = Recommended
  title = "Moebius"
  int param version
    caption = "Version"
     default = 250918
     visible = @version < 250918
	endparam
  heading
    text = "(Current is 250918.}"
		visible = @version < 250918
  endheading

  param fz
    caption = "Z1 = z or T(ab*z)?"
    enum = "z"  "T(ab*z)"
    default = 0
   visible = @version < 250918
  endparam
  param gz
    caption = "Z1 = z or T(z)?"
    enum = "z"  "T(z)"
    default = 0
   visible = @version >= 250918
  endparam
  UserTransform param fT
    caption = "Transform T"
    default = JLB_FTransform
     visible = (@version <  250918 && @fz > 0) || \
               (@version >= 250918 && @gz > 0)
  endparam
  complex param ab
    caption = "ab"
    default = (1,0)
   visible = @version < 250918 && @fz > 0
  endparam

;   heading
;     text = "Z1 = Z"
;      visible = (@version <  250918 && @fz == 0) || \
;                (@version >= 250918 && @gz == 0)
;   endheading

  heading
    caption = "Z2=(a0+a1*Z1)/(b0+b1*Z1)"
  endheading
  complex param a0
    caption = "a0"
    default = (1,0)
  endparam
  complex param a1
    caption = "a1"
    default = (1,0)
  endparam
  complex param b0
    caption = "b0"
    default = (1,0)
  endparam
  complex param b1
    caption = "b1"
    default = (-1,0)
  endparam
  param opt
    caption = "Combine"
    enum = "Z1" "Z2" "Larger" "Smaller"  \
    "Sum" "Difference" "Product" "Geometric Average" \
         "Harmonic Average" "Hypotenuse"
    default = 5
    visible = @version >= 250918 && @gz > 0
  endparam
}


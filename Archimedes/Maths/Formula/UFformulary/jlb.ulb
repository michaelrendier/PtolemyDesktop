    if m_scale, d = d/c4, endif
    return d
  endfunc
default:
  title = "CD143 Viviani's"
}
class JLB_CD144(CD1) {
public:
  float func Iterate(complex zz)
    float d = x2*x2-y2*y2 + a*x*y
    if m_scale, d = d/c4, endif
    return d
  endfunc
default:
  title = "CD144 Wavy Cross"
}
class JLB_CD145(CD1) {
public:

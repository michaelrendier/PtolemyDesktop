class JLB_UT_OneOrTwoFunc(common.ulb:UserTransform) { ; 240903
; New 240903
; Make a UserTransform out of two functions
; 250111 added  z powers, got rid of Add/Replace, steps, step size z powers, got rid of Add/Replace, steps, step size
; 250330 added final option reciprocal
 public:
   func JLB_UT_OneOrTwoFunc(Generic pparent)
    UserTransform(pparent)
    if @which == "Menu"
      if @exch && @howmany == "2"
        m_fm = new @gm(this)
        m_gm = new @fm(this)
      else
        m_fm = new @fm(this)
        if @howmany == "2"
          m_gm = new @gm(this)
        endif
      endif
    else;if @which == "Plug-in"
      if @exch && @howmany == "2"
        m_fp = new @gp(this)
        m_gp = new @fp(this)
      else
        m_fp = new @fp(this)
        if @howmany == "2"
          m_gp = new @gp(this)
        endif
      endif
    endif
    if @version >= 250111
      pp = @p, qq = @q
      add = false, ns = 1, hh = 1
      ffhow = @fhow, gghow = @ghow
    else
      pp = qq = 1
      add = @addrep == "Add"
      ns = @nsteps, hh = @h
      ffhow = gghow = 0
    endif
  endfunc

  complex func Iterate(complex pz)
    complex t
    int n = 0
    while n < ns
      if @howmany == "1"
        t = ffunc(pz)
      elseif @how == "f+g"
        t = ffunc(pz) + gfunc(pz)
      elseif @how == "f-g"
        t = ffunc(pz) - gfunc(pz)
      elseif @how == "f*g"
        t = ffunc(pz) * gfunc(pz)
      elseif @how == "f/g"
        t = ffunc(pz) / gfunc(pz)
      elseif @how == "f^g"
        t = ffunc(pz) ^ gfunc(pz)
      else;if @how == "f(g)"
        t = ffunc(gfunc(pz))
      endif
      if @version >= 250111
        if @version >= 250330 && @recip, t = 1/t, endif
        return t
      else
        t = hh*t
        if add, pz = pz + t, else, pz = t, endif
        n = n + 1
      endif
    endwhile
    return pz
  endfunc

  complex func ffunc(complex z)
    if @which == "Menu"
          if ffhow == 0
        return m_fm.Iterate(@a*z^pp)
      elseif ffhow == 1
        return m_fm.Iterate(@a*z)^pp
      elseif ffhow == 2
        return @a*m_fm.Iterate(z^pp)
      else;if ffhow == 3
        return @a*m_fm.Iterate(z)^pp
      endif
    else
          if ffhow == 0
        return m_fp.Iterate(@a*z^pp)
      elseif ffhow == 1
        return m_fp.Iterate(@a*z)^pp
      elseif ffhow == 2
        return @a*m_fp.Iterate(z^pp)
      else;if ffhow == 3
        return @a*m_fp.Iterate(z)^pp
      endif
    endif
  endfunc
  ; a copy of ffunc
  complex func gfunc(complex z)
    if @which == "Menu"
          if gghow == 0
        return m_gm.Iterate(@b*z^qq)
      elseif gghow == 1
        return m_gm.Iterate(@b*z)^qq
      elseif gghow == 2
        return @b*m_gm.Iterate(z^qq)
      else;if gghow == 3
        return @b*m_gm.Iterate(z)^qq
      endif
    else
          if gghow == 0
        return m_gp.Iterate(@b*z^qq)
      elseif gghow == 1
        return m_gp.Iterate(@b*z)^qq
      elseif gghow == 2
        return @b*m_gp.Iterate(z^qq)
      else;if gghow == 3
        return @b*m_gp.Iterate(z)^qq
      endif
    endif
  endfunc

  private:
  UserTransform m_fm
  UserTransform m_gm
  FT m_fp
  FT m_gp
  int ffhow
  int gghow
  float pp
  float qq
  bool add
  int ns
  float hh

default:
  rating = Recommended
  title = "1 or 2 Functions"
  int param version
     caption = "Version"
     default = 250330
    visible = @version < 250330;111
  endparam
   heading
     text = "(Current is 250330.)"
     visible = @version < 250330;111
   endheading


  param which
    caption = "Choose from"
    enum = "Menu" "Plug-in"
    default = 0
  endparam

  param addrep
    caption = "Add or Replace?"
    enum = "Add" "Replace"
    default = 1
    visible = @version < 250111
  endparam
  int param nsteps
    caption = "    # of steps"
    default = 1
    min = 1
    visible = @version < 250111
  endparam
  float param h
    caption = "    Step size"
    default = 1
    visible = @version < 250111
  endparam
  heading
    visible = @version < 250111
  endheading

  param howmany
    caption = "1 or 2 functions?"
    enum = "1" "2"
    default = 1
  endparam

  heading
  endheading

  param how
    caption = "Combine"
    enum = "f+g" "f-g" "f*g" "f/g" "f^g" "f(g)"
    default = 5
    visible = @howmany == "2"
  endparam
  bool param exch
    caption = "Switch f and g?"
    default = false
    visible = @howmany == "2" && @how != 0 && @how != 2
  endparam
;   heading
;   endheading

  param fhow
    caption = "f option"
    enum = "f(a*z^p)" "f(a*z)^p" "a*f(z^p)" "a*f(z)^p"
    default = 0
    visible = @version > 250330
  endparam
;   heading
;     text = "    f(a*z^p)"
;     visible = @which == "Menu"
;   endheading
  UserTransform param fm      ; caption doesn't show
    default = JLB_FTransform
    selectable = false
    visible = @which == "Menu"
  endparam
  FT param fp
    caption = " "
    default = JLB_02sinh
    visible = @which == "Plug-in"
  endparam
  complex param a
    caption = "a"
    default = (1,0)
  endparam
  float param p
    caption = "p"
    default = 2
    visible = @version >= 250111
  endparam
  heading
    visible = @howmany == "2"
  endheading
  param ghow
    caption = "g option"
    enum = "g(b*z^q)" "g(b*z)^q" "b*g(z^q)" "b*g(z)^q"
    default = 0
    visible = @howmany == "2" && @version > 250330
  endparam
;   heading
;     text = "    g(b*z^q)"
;     visible = @which == "Menu" && @howmany == "2"
;   endheading
  UserTransform param gm      ; caption doesn't show
    default = JLB_FTransform
    selectable = false
    visible = @which == "Menu" && @howmany == "2"
  endparam
  FT param gp
    caption = " "
    default = JLB_05cos
    visible = @which == "Plug-in" && @howmany == "2"
  endparam
  complex param b
    caption = "b"
    default = (1,0)
    visible = @howmany == "2"
  endparam
  float param q
    caption = "q"
    default = 2
    visible = @version >= 250111 && @howmany == "2"
  endparam

  bool param recip
    caption = "Use reciprocal?"
    default = false
    visible = @version >= 250330
  endparam
}

class JLB_UT_OneOrTwoFunc2(common.ulb:UserTransform) { ; 240903
; New 251120
 public:
   func JLB_UT_OneOrTwoFunc2(Generic pparent)
    UserTransform(pparent)
    if @which == "Menu"
      if @exch && @howmany == "2"
        m_fm = new @gm(this)
        m_gm = new @fm(this)
      else
        m_fm = new @fm(this)
        if @howmany == "2"
          m_gm = new @gm(this)
        endif
      endif
    else;if @which == "Plug-in"
      if @exch && @howmany == "2"
        m_fp = new @gp(this)
        m_gp = new @fp(this)
      else
        m_fp = new @fp(this)
        if @howmany == "2"
          m_gp = new @gp(this)
        endif
      endif
    endif
  endfunc

  complex func Iterate(complex pz)
    complex farg = args(pz, @fhow+1)
    complex zf = fgfunc(farg, true)
    if @howmany == "1"
      return zf
    endif
    complex garg = args(pz, @ghow+1)
    complex zg = fgfunc(garg, false)
    if @flip
      zg = flip(zg)
    endif
    if @how == "f+g"
      return zf + zg
    elseif @how == "f-g"
      return zf - zg
    elseif @how == "f*g"
      return zf * zg
    else;if @how == "f/g"
      return zf / zg
    endif
  endfunc

  complex func args(complex z, int i)
    float x = real(z), float y = imag(z)
    if i == 1
      return x + flip(y)
    elseif i == 2
      return x - flip(y)
    elseif i == 3
      return -x + flip(y)
    elseif i == 4
      return -x - flip(y)
    elseif i == 5
      return x+ y
    elseif i == 6
      return x - y
    elseif i == 7
      return -x + y
    else;if i == 8
      return -x - y
    endif
  endfunc

  complex func fgfunc(complex arg, bool f)
    if f
      if @which == "Menu"
        return m_fm.Iterate(arg)
      else
        return m_fp.Iterate(arg)
      endif
    else
      if @which == "Menu"
        return m_gm.Iterate(arg)
      else
        return m_gp.Iterate(arg)
      endif
    endif
  endfunc

  private:
  UserTransform m_fm
  UserTransform m_gm
  FT m_fp
  FT m_gp

default:
  rating = Recommended
  title = "1 or 2 Functions #2"
  int param version
     caption = "Version"
     default = 2511200
    visible = @version < 251120
  endparam
   heading
     text = "(Current is 21120.)"
     visible = @version < 251120
   endheading

  param which
    caption = "Choose from"
    enum = "Menu" "Plug-in"
    default = 0
  endparam

  param howmany
    caption = "1 or 2 functions?"
    enum = "1" "2"
    default = 1
  endparam

  heading
  endheading

  bool param flip
    caption = "Flip g?"
    default = true
    visible = @howmany == "2"
  endparam
  param how
    caption = "Combine"
    enum = "f+g" "f-g" "f*g" "f/g"
    default = 0
    visible = @howmany == "2"
  endparam
  bool param exch
    caption = "Switch f and g?"
    default = false
    visible = @howmany == "2"
  endparam
;   heading
;   endheading

  param fhow
    caption = "f option"
    enum = "1" "2" "3" "4" "5" "6" "7" "8"
    default = 0
  endparam
  UserTransform param fm      ; caption doesn't show
    default = JLB_FTransform
    selectable = false
    visible = @which == "Menu"
  endparam
  FT param fp
    caption = " "
    default = JLB_02sinh
    visible = @which == "Plug-in"
  endparam
  heading
    visible = @howmany == "2"
  endheading
  param ghow
    caption = "g option"
    enum = "1" "2" "3" "4" "5" "6" "7" "8"
    default = 0
    visible = @howmany == "2"
  endparam
  UserTransform param gm      ; caption doesn't show
    default = JLB_FTransform
    selectable = false
    visible = @which == "Menu" && @howmany == "2"
  endparam
  FT param gp
    caption = " "
    default = JLB_05cos
    visible = @which == "Plug-in" && @howmany == "2"
  endparam}



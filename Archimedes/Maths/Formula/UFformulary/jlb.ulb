}
class JLB_CD111(CD1) {
public:
  float func Iterate(complex zz)
    float d = 4*(c2-a*x)^3 - 27*a^2*c2^2
    if m_scale, d = d/c4/c2, endif
    return d
  endfunc
default:
  title = "CD111 Cayley's Sextic"
}
class JLB_CD112(CD1) {
public:

}
class JLB_C04(CT) {
public:
; 	func Accumulate(float d, float &dsum, float &dsumsq, int count)
; 	endfunc
  func Aux(float &dsum, float dmin, float dmax, int &count)
    dsum = dmax
    count = 1
  endfunc
	func FinalAverage(float &dsum, float dsumsq, int &count)
    count = 1
	endfunc
default:
  rating = Recommended
  title = "C04 Largest distance"
}
class JLB_C05(CT) {
public:
; 	func Accumulate(float d, float &dsum, float &dsumsq, int count)
; 	endfunc
  func Aux(float &dsum, float dmin, float dmax, int &count)
    dsum = dmax - dmin
    count = 1
  endfunc
	func FinalAverage(float &dsum, float dsumsq, int &count)
    count = 1
	endfunc
default:
  rating = Recommended
  title = "C05 Distance range"
}
class JLB_C06(CT) {
public:
; 	func Accumulate(float d, float &dsum, float &dsumsq, int count)
; 	endfunc
  func Aux(float &dsum, float dmin, float dmax, int &count)
    dsum = dmax / dmin             ; dmin guaranteed > 0
    count = 1
  endfunc
	func FinalAverage(float &dsum, float dsumsq, int &count)
    count = 1
	endfunc
default:
  rating = Recommended
  title = "C06 Distance ratio"
}
class JLB_C07(CT) {
; 250818 added log option; backward compatible
public:
; 	func Accumulate(float d, float &dsum, float &dsumsq, int count)
; 	endfunc
;   func Aux(float &dsum, float dmin, float dmax, int &count)
;   endfunc
	func FinalAverage(float &dsum, float dsumsq, int &count)
    if @how == "Scale"
      dsum = count / @scale
    else
      dsum = log(count)
    endif
    count = 1
	endfunc
default:
  rating = Recommended
  title = "C07 Iteration count"
  heading
    text = "(Ignores any distance method plug-in)"
  endheading
  param how
    caption = "how"
    enum = "Scale" "log"
    default = 0
  endparam
  float param scale
    caption = "Scale"
    default = 10         ; was 100
    min = 1
    visible = @how == "Scale"
  endparam
}
class JLB_C07a(CT) {
public:
	func Accumulate(float d, float &dsum, float &dsumsq, int count)
    dsum = dsum + d
	endfunc
  func Aux(float &dsum, float dmin, float dmax, int &count)
    count = 1           ; avoid averaging
  endfunc
; 	func FinalAverage(float &dsum, float dsumsq, int &count)
; 	endfunc
default:
  rating = Recommended
  title = "C07a Sum"
}
class JLB_C08(CT) {
public:
	func Accumulate(float d, float &dsum, float &dsumsq, int count)
    dsum = dsum + d
	endfunc
;   func Aux(float &dsum, float dmin, float dmax, int &count)
;   endfunc
; 	func FinalAverage(float &dsum, float dsumsq, int &count)
; 	endfunc
default:
  rating = Recommended
  title = "C08 Arithmetic average"
}
class JLB_C09(CT) {
; instead doing nth root of the product, average the logs and then exponentiate
public:
	func Accumulate(float d, float &dsum, float &dsumsq, int count)
    dsum = dsum + log(d)             ; d guaranteed > 0
	endfunc
;   func Aux(float &dsum, float dmin, float dmax, int &count)
;   endfunc
	func FinalAverage(float &dsum, float dsumsq, int &count)
    dsum = exp(dsum)
	endfunc
default:
  rating = Recommended
  title = "C09 Geometric average"
}
class JLB_C10(CT) {
public:
	func Accumulate(float d, float &dsum, float &dsumsq, int count)
    dsum = dsum + 1 / d             ; d guaranteed > 0
	endfunc
;   func Aux(float &dsum, float dmin, float dmax, int &count)
;   endfunc
	func FinalAverage(float &dsum, float dsumsq, int &count)
    dsum = 1 / dsum
	endfunc
default:
  rating = Recommended
  title = "C10 Harmonic average"
}


class JLB_C10a(CT) {
public:
	func Accumulate(float d, float &dsum, float &dsumsq, int count)
    if @p == 0
      dsum = dsum + log(d)             ; d guaranteed > 0
    else
      dsum = dsum + d^@p
    endif
	endfunc
;   func Aux(float &dsum, float dmin, float dmax, int &count)
;   endfunc
	func FinalAverage(float &dsum, float dsumsq, int &count)
    if @p == 0
      dsum = exp(dsum)
    else
      dsum = dsum ^ (1/@p)
    endif
	endfunc
default:
  rating = Recommended
  title = "C10a Power average"
  float param p
    caption = "Power"
    default  = 2
    hint = "p=+1, same as Arithmetic average; \
           p=-1, same as Harmonic average; \
           p near 0, similar to Geometric average"
  endparam
  heading
    text = "p=0, doing geometric average"
    visible = @p==0
  endheading
}
class JLB_C11(CT) {
    ; "Std. Deviation" ignoring -1
public:
	func Accumulate(float d, float &dsum, float &dsumsq, int count)
    dsum = dsum + d
    dsumsq = dsumsq + d * d
	endfunc
;   func Aux(float &dsum, float dmin, float dmax, int &count)
;   endfunc
	func FinalAverage(float &dsum, float dsumsq, int &count)
; when this is called, dsum is the mean value, and
; dsumsq is the mean of the squares of the values
    dsum = sqrt(dsumsq - sqr(dsum))
	endfunc
default:
  rating = Recommended
  title = "C11 Variation 1"
}
class JLB_C12(CT) {
    ; "Coefficient of Variation"
public:
	func Accumulate(float d, float &dsum, float &dsumsq, int count)
    dsum = dsum + d
    dsumsq = dsumsq + d * d
	endfunc
;   func Aux(float &dsum, float dmin, float dmax, int &count)
;   endfunc
	func FinalAverage(float &dsum, float dsumsq, int &count)
    dsum = sqrt(dsumsq - sqr(dsum)) / dsum
	endfunc
default:
  rating = Recommended
  title = "C12 Variation 2"
}
class JLB_C13(CT) {
    ; "Fractal Dimension" -- more or less
public:
	func Accumulate(float d, float &dsum, float &dsumsq, int count)
    dsum = dsum + d
    dsumsq = dsumsq + d * d
	endfunc
  func Aux(float &dsum, float dmin, float dmax, int &count)
    ddmin = dmin, ddmax = dmax
  endfunc
	func FinalAverage(float &dsum, float dsumsq, int &count)
    if ddmax == ddmin
      dsum = 0
    else
      dsum = sqrt(dsumsq - sqr(dsum)) / (ddmax - ddmin)
    endif
	endfunc
private:
  float ddmin
  float ddmax
default:
  rating = Recommended
  title = "C13 Variation 3"
}
class JLB_C14(CT) {
; something like the Lyapunov exponent
; d-dprev instead of derivative, but use abs
public:
	func Accumulate(float d, float &dsum, float &dsumsq, int count)
    if count == 1
      dprev = d
    else
      dsum = dsum + abs(log(abs(d-dprev)))    ; need d >= 0
      dprev = d
    endif
	endfunc
  func Aux(float &dsum, float dmin, float dmax, int &count)
    count = count - 1
  endfunc
; 	func FinalAverage(float &dsum, float dsumsq, int &count)
; 	endfunc
private:
  float dprev
default:
  rating = Recommended
  title = "C14 Variation 4"
}
class JLB_C15(CT) {
; something like the Lyapunov exponent
; d instead of derivative, but use abs
public:
	func Accumulate(float d, float &dsum, float &dsumsq, int count)
    dsum = dsum + abs(log(d))         ; d >= 0, UF sets log(0) to 0
	endfunc
;   func Aux(float &dsum, float dmin, float dmax, int &count)
;   endfunc
; 	func FinalAverage(float &dsum, float dsumsq, int &count)
; 	endfunc
default:
  rating = Recommended
  title = "C15 Variation 5"
}
; next group new 250901
class JLB_C16(CT) {
public:
; 	func Accumulate(float d, float &dsum, float &dsumsq, int count)
; 	endfunc
  func Aux(float &dsum, float dmin, float dmax, int &count)
    dsum = m_a1, count = 1
  endfunc
; 	func FinalAverage(float &dsum, float dsumsq, int &count)
; 	endfunc
default:
  rating = Recommended
  title = "C16 Angle at min d"
}
class JLB_C17(CT) {
public:
; 	func Accumulate(float d, float &dsum, float &dsumsq, int count)
; 	endfunc
  func Aux(float &dsum, float dmin, float dmax, int &count)
    dsum = m_a2, count = 1
  endfunc
; 	func FinalAverage(float &dsum, float dsumsq, int &count)
; 	endfunc
default:
  rating = Recommended
  title = "C17 Angle at max d"
}
; class JLB_C17a(CT) {
; public:
; ; 	func Accumulate(float d, float &dsum, float &dsumsq, int count)
; ; 	endfunc
;   func Aux(float &dsum, float dmin, float dmax, int &count)
;     dsum = m_x1, count = 1
;   endfunc
; ; 	func FinalAverage(float &dsum, float dsumsq, int &count)
; ; 	endfunc
; default:
;   rating = Recommended
;   title = "C17a Real at min d"
; }
class JLB_C18(CT) {
public:
; 	func Accumulate(float d, float &dsum, float &dsumsq, int count)
; 	endfunc
  func Aux(float &dsum, float dmin, float dmax, int &count)
    dsum = CombineFF.Go(m_x1, m_y1, @opt), count = 1
  endfunc
; 	func FinalAverage(float &dsum, float dsumsq, int &count)
; 	endfunc
default:
  rating = Recommended
  title = "C18 Value at min d"
  param opt
    caption = "Real,Imag,?"
    enum = "Real" "Imag" "Larger" "Smaller" \
         "Sum" "Difference" "Product"  \
         "Harmonic Average" "Cabs"
    default = 0
  endparam
}
class JLB_C19(CT) {
public:
; 	func Accumulate(float d, float &dsum, float &dsumsq, int count)
; 	endfunc
  func Aux(float &dsum, float dmin, float dmax, int &count)
    dsum = CombineFF.Go(m_x2, m_y2, @opt), count = 1
  endfunc
; 	func FinalAverage(float &dsum, float dsumsq, int &count)
;     ; dsum has been set to imag_min, count to 1
; 	endfunc
default:
  rating = Recommended
  title = "C19 Value at max d"
  param opt
    caption = "Real,Imag,?"
    enum = "Real" "Imag" "Larger" "Smaller" \
         "Sum" "Difference" "Product"  \
         "Harmonic Average" "Cabs"
    default = 0
  endparam
}
; class JLB_C18a(CT) {
; public:
; ; 	func Accumulate(float d, float &dsum, float &dsumsq, int count)
; ; 	endfunc
;   func Aux(float &dsum, float dmin, float dmax, int &count)
;     dsum = m_y1, count = 1
;   endfunc
; ; 	func FinalAverage(float &dsum, float dsumsq, int &count)
; ;     ; dsum has been set to imag_min, count to 1
; ; 	endfunc
; default:
;   rating = Recommended
;   title = "C18a Imag at min d"
; }

class JLB_DColoring(common.ulb:GradientColoring) {    ; 240917
; Accumulate a sum at each step, or at selected steps, of the orbit.
; Use the result to calculate a color index.
; 231203 added pathlength
; 240826 added partial smoothing; backwards compatible  REMOVED
; 240917 correction: changed za from float to complex; backwards compatible
; 250215 added dscale option; backwards compatible
; 250305 bug fix!
; 250330 simplify lastgasp stuff
public:

import "common.ulb"
  func JLB_DColoring(Generic pparent)
    GradientColoring(pparent)
    m_dist = new @fdist(this)         ; distance plug-in
    m_ct   = new @fct(this)           ; coloring plug-in
    if !@Basic && @d_zd > 0
      m_zdist = new @fzdist(this)
    endif
    rotation = 1
    min_d_use = 0, max_d_use = 1e38
    if (@version >= 240224 && @someDist == "Some")
      min_d_use = @ddmin, max_d_use = @ddmax
    endif
    z_off = (0,0)
    invert = @version >= 250330 && @reciprocate

    if !@Basic
      m_BP1 = new @fBP1(this)         ; distance adjustment plug-in
      m_BP2 = new @fBP2(this)         ; final adjustment plug-in
      m_ZZ = new @fZZ(this)           ; initial z plug-in
      if @fz > 0
        m_zT = new @fUT(this)         ; initial z transform plug-in
      endif
      rotation = cos(@angle * #pi/180.0) - flip(sin(@angle * #pi/180.0))
      if (@version <  240224 && @UseMinMax         )
        min_d_use = @ddmin, max_d_use = @ddmax
      endif
      z_off = @offset
    endif
  endfunc

  func Init(complex pz, complex ppixel)
    GradientColoring.Init(pz, ppixel)
    m_dist.init(pz)
    m_dist.SetParams(0, true)             ; iteration 0, absolute value distance
    if !@Basic && @d_zd > 9
      m_zdist.init(pz)
      m_zdist.SetParams(0, true)
    endif

    dsum  = dsum_prev = dsumsq = dmin = dmax = 0
    z_prev = pz
    iter = 0            ; iter updated each call to Iterate()
    iter1 = 1
    iter2 = 2000000000  ; largest int is 2147483647
    if !@Basic && @some_all > 0
      iter1 = @start
      iter2 = @start + @howmany - 1
    endif
    count = 0           ; count updates only for succesful distance calculation
  endfunc

  func Iterate(complex pz)
    GradientColoring.Iterate(pz)

    ; doing only certain iterations?
    iter = iter + 1
    bool okay = (iter >= iter1 && iter <= iter2)
    if !okay
      return
    endif

    ; initial changes to z
    complex zz = pz
    if !@Basic
      zz = m_ZZ.Go(pz, z_prev, #pixel)    ; z, z-zprev, etc.
    endif
    z_prev = pz
    dsum_prev = dsum

    zz = zz * rotation
    if !@Basic && @fz > 0
      zz = m_zT.Iterate(@a*zz)
    endif

    ; the iteration itself!
    m_dist.SetIter(iter)

    zz = zz - z_off
    float d = m_dist.Iterate(zz)    ; here it is!

    if @version >= 250305 && d < 0    ; why did I just find this bug?
      return
    endif

    ; doing only certain distance ranges?
;     if  !@Basic && @version >= 240224 && @someDist == "Some"
    if  @version >= 240224 && @someDist == "Some"
      if d < min_d_use || d > max_d_use
        return
      endif
      if @dscale ; scale d to [0,1]
        d = (d - min_d_use) / (max_d_use - min_d_use)
      endif
    endif

    if !@Basic && @d_zd > 0
      d = m_zdist.Iterate(@za * d * zz)
    endif

    if @version >= 250330
      if invert, d = 1/d, endif
    else
      ; per-iteration distance adjustment?
      if !@Basic && d != 0 && @version >= 250223
        float t = @b1
        if @fBP1 == JLB_BP99, t = @n1, endif
        d = m_BP1.Go(d, t, @p1)
      endif
    endif

    ; bookkeeping
    count = count + 1
    if count == 1
      dmin = dmax = d
    else
      if d < dmin, dmin = d, endif
      if d > dmax, dmax = d, endif
      dsum_prev = dsum
    endif

    ; accumulate based on coloring plug-in
    m_ct.Accumulate(d, dsum, dsumsq, count)

  endfunc              ; Iterate

  float func ResultIndex(complex pz)

    ; use the final iteration by default (UF doesn't call Iterate after bailout)
    if @Basic || (!@Basic && @dofinal)
      Iterate(pz)
    endif

    if @solid && count == 0
      m_solid = true      ; from base class
      return 0
    endif

    ; any cleaning up?
    m_ct.Aux(dsum, dmin, dmax, count)

    if count > 0
      dsum = dsum / count               ; average "d"
      dsumsq = dsumsq / count           ; average sqr(d)
    endif
    if count > 1
      dsum_prev = dsum_prev  / (count-1) ; only needed for TIA smoothing
    endif

    ; finish some types
    m_ct.FinalAverage(dsum, dsumsq, count)

    ; do Mandelbrot or TIA smoothing?
    if @final > 0 && count > 0            ; && !@Basic is possible
      FinalSmooth( )
    endif
    float d = dsum

    ; two old versions have been superceded.
        if @version < 240108 && !@Basic && @recip && d != 0
          d = 1/d
        endif
        if @version >= 240108 && !@Basic && @version < 240224 && d != 0
          if @lastgasp == "Reciprocal"
            d = 1/d
          elseif @lastgasp == "Power"
            d = d^@p_lastgasp
          endif
        endif
        if @version >= 240224 && !@Basic && d != 0
          float t = @b2
          if @fBP2 == JLB_BP99, t = @n2, endif
          d = m_BP2.Go(d, t, @p2)
        endif

    ; all done! d is the index value
    return d
  endfunc            ; ResultIndex

  func FinalSmooth( )
    if @final == 1
      float il = 1/log(@power)
      float lp = log(log(@bailout))
               ; 0.05 to agree with original Smooth (Mandelbrot)
;     dsum =  0.05 * (count - 1 + il*lp - il*log(log(abs(dsum))))
      float d =  0.05 * (iter + il*lp - il*log(log(dsum)))
      ;dsum = d*@full + dsum*(1-@full)
      dsum = d
    elseif @final == 2
      float il = 1/log(@power)     ; as in Triangle in Standard.ulb
      float lp = log(log(@bailout)/2.0)
      float fac = il * lp - il*log(log(cabs(#z)))
      ;dsum  = dsum * count / (count+1)              ; to agree with original
      ;dsum_prev = dsum_prev * (count-1) / count
      float d = cabs(dsum_prev + (dsum - dsum_prev) * (fac + 1))
      ;dsum = d*@full + dsum*(1-@full)
      dsum = d
    endif
  endfunc

private:
  complex rotation
  Distance m_dist
  Distance m_zdist
  CT m_ct
  ZZ m_ZZ
  BP m_BP1
  BP m_BP2
  UserTransform m_zT
  float dsum
  float dsum_prev          ; used by TIA smoothing
  float dsumsq             ; used by Variations 1, 2, 3
  float dmin, float dmax
  float min_d_use, float max_d_use
  complex z_off
  complex z_prev
  int count
  int iter, int iter1, int iter2
  bool invert

default:
  title = "Color by Distance"
  rating = Recommended

	int param version
		caption = "Version"
		default = 250330
		visible = @version < 250330
	endparam
  heading
    text = "(current is 250330.}"
		visible = @version < 250330
  endheading

  bool param solid
    caption = "Use solid background?"
    default = true
  endparam
  bool param Basic
    caption = "Basic version?"
    default = true
  endparam
  heading
    caption = "Accumulation phase"
  endheading

  Distance param fzdist
    caption = "d * z conversion"
    default = JLB_D_SD
    selectable = false
    visible = !@Basic && @d_zd > 0
  endparam

  bool param dofinal
    caption = "Use final distance?"
    default = true
    visible =!@Basic
  endparam
  ZZ param fZZ
    caption = "Use for zz "
    visible = !@Basic
  endparam
  float param angle
    caption = "Rotate zz by "
    default = 0
    visible = !@Basic
  endparam
  heading
    caption = "Use zz or T(a*zz)"
;     caption = "Use zz or T(zz)"
    visible = !@Basic
  endheading
  param fz
    caption = "Which?"
    enum = "zz"  "T(a*zz)"
;     enum = "zz"  "T(zz)"
    default = 0
    visible = !@Basic
  endparam
  complex param a
    caption = "a"
    default = 1
    visible = !@Basic && @fz > 0
  endparam
  UserTransform param fUT
    caption = "Transform"
    default = JLB_UT_OneFunction
    visible = !@Basic && @fz > 0
  endparam
  heading
    visible  = !@Basic && @fz == "T(a*zz)"
  endheading

  complex param offset
    caption = "ZZ Offset"
    default = (0,0)
    visible = !@Basic
  endparam

  heading
    visible = !@Basic
  endheading
  heading
    caption = "Distance plug-in"
  endheading
  Distance param fdist
    caption = "Plug-in"
    default = JLB_D_SD
    visible = @fct != JLB_C07
  endparam

  heading
    caption = "End of distance plug-in"
  endheading

  bool param reciprocate
    caption = "Use reciprocal?"
    default = false
    visible = @version >= 250330
  endparam

  param d_zd
    caption = "Color using"
    enum = "d = Distance" "a * d * z"
    default = 0
		visible = !@Basic && @version >= 240420
  endparam
  complex param za
    caption = "a"
    default = 1
		visible = @version >= 240420 && !@Basic && @d_zd > 0
  endparam

  ; this section not used starting 250330
  BP param fBP1
    caption = "Distance adjustment"
    visible = !@Basic && @version < 250330
    default = JLB_BP00
  endparam
  float param b1
    caption = "Factor b"
    default = 1
    min = 0
    visible = !@Basic && @fBP1 != JLB_BP00 && @fBP1 != JLB_BP99 && @version < 250330
  endparam
  float param p1
    caption = "Power p"
    default = 1
    visible = !@Basic && @fBP1 != JLB_BP00 && @fBP1 != JLB_BP99 && @version < 250330
  endparam
  int param n1
    caption = "Number of values"
    default = 4
    min = 2
    visible = !@Basic && @fBP1 == JLB_BP99 && @version < 250330
  endparam
  ; end of unused section

  heading
    visible = !@Basic
  endheading

  param someDist
    caption = "Use all / some distances?"
    enum = "All" "Some"
    default  = 0
    ;visible = !@Basic && @version >= 240224
    visible = @version >= 240224
  endparam
  bool param UseMinMax
    caption = "Min/max distances?"
    default = false
    visible = !@Basic && @version < 240224
  endparam
  float param ddmin
    caption = "Minimum distance"
    default = 0
    min = 0
;     visible = !@Basic && ( (@version <  240224 && @UseMinMax) || \
;                            (@version >= 240224 && @someDist == "Some") )
    visible = (!@Basic &&  (@version <  240224 && @UseMinMax)) || \
                           (@version >= 240224 && @someDist == "Some")
  endparam
  float param ddmax
    caption = "Maximum distance"
    default = 1
    min = 0
;     visible = !@Basic && ( (@version <  240224 && @UseMinMax) || \
;                            (@version >= 240224 && @someDist == "Some") )
    visible = (!@Basic &&  (@version <  240224 && @UseMinMax)) || \
                           (@version >= 240224 && @someDist == "Some")
  endparam
  bool param dscale
    caption = "Scale distance?"
    default = false
;     visible = !@Basic && @version >= 240224 && @someDist == "Some"
    visible = @version >= 240224 && @someDist == "Some"
  endparam
  heading
    visible = !@Basic
  endheading
  param some_all
    enum = " All" " Some" ;" Some + More"
    default = 0
    caption = "Use all / some iterations?"
    visible = !@Basic
  endparam
  int param start
    caption = "Starting with iteration?"
    default = 4
    min = 1
    visible = !@Basic && @some_all > 0
  endparam
  int param howmany
    caption = "How many to use?"
    default = 100
    min = 1
    visible =  !@Basic && @some_all > 0
  endparam
  heading
    caption = "Final phase of coloring"
  endheading
  CT param fct
    caption = "How to color"
    default = JLB_C05
  endparam

  heading
  endheading
  param final
    caption = "Final smooth"
    enum = "None" "Mandelbrot type" "TIA type"
    default = 0
    ; visible = !@Basic       ; possible
  endparam
  float param power
    caption = "Smoothing exponent"
    default = 2.0
    visible = @final  > 0   ; && !@Basic is possible
  endparam

  float param bailout
    caption = "Smoothing bailout"
    default = 100
    min = 1
    visible = @final  > 0  ; && !@Basic is possible
  endparam
;   float param full
;     caption = "Smoothing fullness"
;     default = 1
;     min = 0
;     max = 1
;   endparam

  heading
    visible = !@Basic
  endheading
  bool param recip
    caption = "Use reciprocal?"
    default = false
    ;hint = "Color based on, for example, 1/Mod(z) instead of Mod(z)."
    visible = @version < 240108 && !@Basic
  endparam
  param lastgasp
    caption = "Last gasp change"
    enum = "None" "Reciprocal" "Power"
    default = 0
    visible = @version >= 240108 && !@Basic && @version < 240224
  endparam
  float param p_lastgasp
    caption = "Power"
    default = 1
    visible = @version >= 240108 && !@Basic && @lastgasp == 2
  endparam
  BP param fBP2
    caption = "Final adjustment"
    visible = !@Basic && @version >= 240224
    default = JLB_BP00
  endparam
  float param b2
    caption = "Factor b"
    default = 1
    min = 0
    visible = !@Basic && @fBP2 != JLB_BP00 && @fBP2 != JLB_BP99
  endparam
  float param p2
    caption = "Power p"
    default = 2
    visible = !@Basic && @version >= 240224 && @fBP2 != JLB_BP00 && @fBP2 != JLB_BP99
  endparam
  int param n2
    caption = "Number of values"
    default = 4
    min = 2
    visible = !@Basic && @version >= 240224 && @fBP2 == JLB_BP99
  endparam
}


class JLB_DColoring2(common.ulb:GradientColoring) {
; A redoing of JLB_DColoring = "Color by Distance:
; new 250903 or so
; 250913 added "skip final" iteration
; 250913 changed someDist and someIter interface
; 250916 add Z averaging option
; 251216 added new method options for using only some distances
; 260219 added option to skip last (bailed-out) iteration
public:
import "common.ulb"

  func JLB_DColoring2(Generic pparent)
    GradientColoring(pparent)
    m_dist = new @fdist(this)         ; distance plug-in
    m_ct   = new @fct(this)           ; coloring plug-in
    if @version >= 251216 && @somedist
      m_d = new @fd(this)
    endif

    iter1 = 1
    iter2 = 2000000000  ; largest int is 2147483647
    if @someIter
      iter1 = @first
      iter2 = @last
    endif
    if @useT
      m_zT = new @fUT(this)    ; initial z transform plug-in
    endif
  endfunc

  func Init(complex pz, complex ppixel)
    GradientColoring.Init(pz, ppixel)
    m_dist.init(pz)
    m_dist.SetParams(0, true)             ; iteration 0, absolute value distance
    if @version >= 251216 && @somedist
      m_d.Init(pz)
    endif

    dsum  = dsum_prev = dsumsq = 0
    dmin = dmax = 0     ; to make compiler happy
    iter = 0            ; iter updated each call to Iterate()
    count = 0           ; count updates only for succesful distance calculation
    zsum = (0,0)
    wtsum = 0
  endfunc

  func Iterate(complex pz)
    GradientColoring.Iterate(pz)

    iter = iter + 1
    ; doing only certain iterations?
    if (iter < iter1 || iter > iter2)
      return
    endif

    ; where does this go?
    ; does it fit at all?
    if @avg
      float wt = 1 / iter ^ @pavg
      zsum  = zsum  + wt * pz
      wtsum = wtsum + wt
      pz = zsum / wtsum
    endif


    m_dist.SetIter(iter)             ; just in case
    dsum_prev = dsum
    float d
    if @useT
      complex Znew = m_zT.Iterate(pz)
      if @opt1 == "z1"
        d = m_dist.Iterate(Znew)
      elseif @opt1 == "Combine Z and z1"
        complex z2 = Combine2C.Go(pz, Znew, @opt2)
        d = m_dist.Iterate(z2)
      else
        float d1 = m_dist.Iterate(pz)
        float d2 = m_dist.Iterate(Znew)
        d = CombineFF.Go(d1, d2, @opt3)
      endif
    else
      d = m_dist.Iterate(pz)
    endif

    if  d < 0
      return
    endif

    ; doing only certain distance ranges?
    if @someDist
      bool okay
      if @version >= 251216
        okay = m_d.Iterate(pz, iter, d, @ddmin, @ddmax)
      else
        okay = @ddmin <= d && d <= @ddmax
      endif
      if !okay
        return
      endif
      if @dscale ; scale d to [0,1]
        d = (d - @ddmin) / (@ddmax - @ddmin)
      endif
    endif

    if @d_adj == "Reciprocal"
      if d != 0, d = 1/d, endif
    elseif @d_adj == "Power"
      d = d ^ @pwr
    elseif @d_adj == "Log"
      d = log(1 + d)      ; keep positive
      ; maybe divide by log(2)
    endif

    ; bookkeeping
    count = count + 1
    if count == 1
      dmin = dmax = d
      m_ct.SetMin(MyMath.atan2a(pz), abs(real(pz)), abs(imag(pz)))
      m_ct.SetMax(MyMath.atan2a(pz), abs(real(pz)), abs(imag(pz)))
    else
      if d < dmin,
        dmin = d
        m_ct.SetMin(MyMath.atan2a(pz), abs(real(pz)), abs(imag(pz)))
      endif
      if d > dmax
        dmax = d
        m_ct.SetMax(MyMath.atan2a(pz), abs(real(pz)), abs(imag(pz)))
      endif
      dsum_prev = dsum
    endif

    ; accumulate based on coloring plug-in
    m_ct.Accumulate(d, dsum, dsumsq, count)

  endfunc              ; Iterate

  float func ResultIndex(complex pz)

      ; use the final z?
      ; (UF doesn't call the coloring iteration after bailout)
      if @version < 260219 || @usefinal
        Iterate(pz)
      endif

    if @solid && count == 0
      m_solid = true      ; from base class
      return 0
    endif

    ; any cleaning up?
    m_ct.Aux(dsum, dmin, dmax, count)

    if count > 0
      dsum = dsum / count               ; average "d"
      dsumsq = dsumsq / count           ; average sqr(d)
    endif
    if count > 1
      dsum_prev = dsum_prev  / (count-1) ; only needed for TIA smoothing
    endif

    ; finish some types
    m_ct.FinalAverage(dsum, dsumsq, count)

    ; do Mandelbrot or TIA smoothing?
    if @final > 0 && count > 0
      FinalAdjust( )
    endif

    ; all done! dsum is the index value
    return dsum
  endfunc            ; ResultIndex

  func FinalAdjust( )
    if @final == "Power"
      dsum = dsum ^ @pwrf
    elseif @final == "Log"
      dsum = log(1 + dsum)          ; keep result positive
      ; maybe divide by log(2)
    elseif @final == "LogLog"
      dsum = log(1 + log(1 + dsum)) ; keep result positive
;     elseif @final == "Mod"
;       dsum = (dsum % @vmod) / @vmod  ; in [0..1)
    elseif @final == "Mandelbrot"
      float il = 1/log(@power)
      float lp = log(log(@bailout))
               ; 0.05 to agree with original Smooth (Mandelbrot)
               ; iter-1 because original doesn't count the last iteration
      dsum =  0.05 * (iter-1 + il*lp - il*log(log(dsum)))
    else;if @final == "TIA"
      float il = 1/log(@power)     ; similar to Triangle in Standard.ulb
      float lp = log(log(@bailout)/2.0)
      float fac = il * lp - il*log(log(cabs(#z)))
      dsum = cabs(dsum_prev + (dsum - dsum_prev) * (fac + 1))
;     else
;       plug in something else
    endif
  endfunc

private:
  Distance m_dist
  CT m_ct
  UserTransform m_zT
  IsOkay m_d
  float dsum
  float dsum_prev          ; used by TIA smoothing
  float dsumsq             ; used by Variations 1, 2, 3
  float dmin, float dmax
;   float min_d_use, float max_d_use
  ;float angle_min, float real_min, float imag_min
  int count
  int iter, int iter1, int iter2
  complex zsum
  float wtsum


default:
  title = "Coloring"
  rating = Recommended

	int param version
		caption = "Version"
		default = 260219
		visible = @version < 260219
	endparam
  heading
    text = "(current is 260219.}"
		visible = @version < 260219
  endheading

  bool param solid
    caption = "Use solid background?"
    default = true
  endparam

  heading
    caption = "Accumulation phase"
  endheading

;   heading
;     visible = @version >= 260219
;   endheading
  heading
    text = "Note: Ultra Fractal by default does not use the final Z for coloring."

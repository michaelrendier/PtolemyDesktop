class BP(common.ulb:Generic) {
; BP base class. No title, so only used for a base class.
; Given a positive float and two parameters, return a positive float.
; many possibilities!
public:
  import "common.ulb"

	func BP(Generic pparent)
		Generic.Generic(pparent)
	endfunc
	float func Go(float d, float b, float p)
		return d
	endfunc
}
class JLB_BP00(BP) {
public:
	float func Go(float d, float b, float p)
		return d
  endfunc
default:
  title = "BP00 no change"
}
class JLB_BP01(BP) {
public:
	float func Go(float d, float b, float p)
		return b * d^p
  endfunc
default:
  title = "BP01 power"
}
class JLB_BP02(BP) {
public:
	float func Go(float d, float b, float p)
		return (0.5*(1-cos(b*d*#pi)))^p
  endfunc
default:
  title = "BP02 haversine"
}
class JLB_BP03(BP) {
public:
	float func Go(float d, float b, float p)
		return (tanh(b*d))^p
  endfunc
default:
  title = "BP03 tanh"
}
class JLB_BP99(BP) {
public:
	float func Go(float d, float b, float p)
    int n = round(b)
		return round(n*d)/n
  endfunc
default:
  title = "BP99 discontinuous"
}

class JLB_UT_Formula(common.ulb:UserTransform) {
public:
  import "Standard.ulb"

  func JLB_UT_Formula(Generic pparent)
    UserTransform(pparent)
    if @hasC == "Yes"
       m_Formula  = new @f_Formula (this)
    else
       m_FormulaX = new @f_FormulaX(this)
    endif
  endfunc

  complex func Iterate(complex pz)
;     int n = 0
;     while n < @nsteps
      if @hasC == "Yes"
        pz = m_Formula.Iterate(pz)
      else
        pz = m_FormulaX.Iterate(pz)
      endif
;       n = n + 1
;     endwhile
    return pz
  endfunc

  protected:
    Formula  m_Formula
    FormulaX m_FormulaX

  default:
   title = "Formula Transform"
   rating = Recommended
   int param version
     caption = "Version"
		default = 240301
		visible = @version < 240301
	endparam
  heading
    text = "(Current is 240301.}"
		visible = @version < 240301
  endheading

  heading
    caption = "Does Formula define its own C?"
  endheading
  param hasC
    caption = " "
    enum = "Yes" "No"
    default = 1
  endparam
;   int param nsteps
;     caption = "Number of steps"
;     default = 1
;     min = 0
;   endparam
  Formula param f_Formula
    caption = "Formula"
    default = Standard_Mandelbrot
    visible = @hasC == 0
  endparam
  FormulaX param f_FormulaX
    caption = "FormulaX"
    default = JLB_FX_Mandelbrot
    visible = @hasC == 1
  endparam
}

class JLB_DShapes(Distance) {
; 241110 added optional final step to Two Shapes option; backward compatible
; 251018 fixed nested shapes bug
; 251021 added shape tweaking
public:

  func JLB_DShapes(Generic pparent)
    Distance(pparent)
    s1 = s2 = 1
    if @which == 0      ; one shape
      m_shap = new @dp_1(this)
    elseif @which == 1  ; nested
          if @nest == 0, m_shap = new @dp_CE(this)
      elseif @nest == 1, m_shap = new @dp_SR(this)
      else,              m_shap = new @dp_T(this)
      endif
      s1 = MyMath.fmin(@scale1, @scale2)
      s2 = MyMath.fmax(@scale1, @scale2)
    else;if @which == 2               ; two different shapes
      m_shap2a = new @dp_2a(this)
      m_shap2b = new @dp_2b(this)
    endif
  endfunc

  func Init(complex zz)
    if @version < 240607
      m_dist.Init(zz)
      m_dist.SetParams(0, m_abs_value)
    endif

    int i=0, int i1=0, int i2=0        ; make compiler happy

    ; ignore return values, just check in/out/etc.
    if @which == 0                   ; one shape
      m_shap.SetMult(1.0)
      ;m_shap.SetTweak(0.0, 0.0, 0.0)
      m_shap.Iterate(zz, i)
      oldval = i
    elseif @which == 1               ; nesting
      m_shap.SetMult(s1)
      m_shap.Iterate(zz, i1)
      m_shap.SetMult(s2)
      m_shap.Iterate(zz, i2)
      oldval = 2*i1 + i2
    else;if @which == 2               ; two shapes
      m_shap2a.SetMult(1.0)
      m_shap2b.SetMult(1.0)
      m_shap2a.Iterate(zz, i1)
      m_shap2b.Iterate(zz, i2)
      oldval = i1 + 10 * i2
    endif
  endfunc

  float func Iterate(complex zz)
    int newval
    int i=0, int i1=0, int i2=0           ; make compiler happy
    float r=0, float r2a=0, float r2b=0   ; make compiler happy
    bool okay = false, bool okaya = false, bool okayb = false

    ; just showing shapes
    if @show_shape
      if @which == "One shape"
        r = m_shap.Iterate(#pixel, i)
        okay = i==1
        r = 1      ; 0.01 * m_shap.GetIter( ) is reasonable
      elseif @which == "Two nested"
        m_shap.SetMult(s1)
        m_shap.Iterate(#pixel, i1)
        m_shap.SetMult(s2)
        m_shap.Iterate(#pixel, i2)
        i = 2*i1 + i2
        okay = i==1           ; the space between inner and outer
        r = 1                 ; only the shape matters
      else
        r2a = m_shap2a.Iterate(#pixel, i1)
        r2b = m_shap2b.Iterate(#pixel, i2)
        if @show_type != "#2 shape"
          okaya = i1 == 1
          if okaya, r = r2a, endif
        endif
        if @show_type != "#1 shape"
          okayb = i2 == 1
          if okayb, r = r2b, endif
        endif
        if @show_type == "Both" && okaya && okayb
          r = Mymath.fmin(r2a, r2b)
        endif
        okay = okaya || okayb
      endif
      if okay, return 1, else, return -1, endif
    endif     ; end of showing shapes

    ; start of regular iteration

; $define debug

    if @which == "One shape"
      int iter = GetIter( )       ; from distance class
      m_shap.SetIter(iter)        ; in case the shape depends on iter
      ;float mult = 1

      r = m_shap.Iterate(zz, i)

; if |#pixel-(1,0)|<1e-6
; print("zz ", zz, " mult ", mult, " r ", r)
; endif

    elseif @which == "Two nested"
      ;m_shap.SetIter(iter)        ; in case the shape depends on iter
      m_shap.SetMult(s1)
      r2a = m_shap.Iterate(zz, i1)
      m_shap.SetMult(s2)
      r2b = m_shap.Iterate(zz, i2)
      i = 2*i1 + i2
      if @dhow == "Min"
        r = Mymath.fmin(r2a, r2b)
      elseif @dhow == "Average"
        r = (r2a + r2b)/2
      elseif @dhow == "Max"
        r = Mymath.fmax(r2a, r2b)
      else;if @dhow == "Difference"
        r = abs(r2a - r2b)
      endif
; if |#pixel-(1,0)|<1e-6 || |#pixel-(0,1)|<1e-6
; print(MyMath.cround(zz,3), " ", MyMath.fround(r2a, 3), " ", i1, " ",\
;                                 MyMath.fround(r2b, 3), " ", i2, " ",\
;                                 MyMath.fround(r, 3))
; endif
    else;if @which == "Two different"
      r2a = abs(m_shap2a.Iterate(s1*zz, i1))
      r2b = abs(m_shap2b.Iterate(s2*zz, i2))
      i = i1 + 10 * i2
    endif
    newval = i

    if @which == "One shape"
      okay = test_1s(oldval, newval, @in_out, r)
    elseif @which == "Two nested"
      okay = test_ns(oldval, newval, @in_out1, r)
    else;if @which == "Two different"
      ; in_out2 values are the same as the first 5 of in_out
      int oldv = oldval % 10
      int newv = newval % 10
      okaya = test_1s(oldv, newv, @in_out2a, r2a)
      oldv = floor(oldval / 10)
      newv = floor(newval / 10)
      okayb = test_1s(oldv, newv, @in_out2b, r2b)
      if @dhow == "Min"
        r = Mymath.fmin(r2a, r2b)
      elseif @dhow == "Average"
        r = (r2a + r2b)/2
      elseif @dhow == "Max"
        r = Mymath.fmax(r2a, r2b)
      else;if @dhow == "Difference"
        r = abs(r2a - r2b)
      endif
      okay = okaya && okayb
    endif
    oldval = newval
    if !okay
      return -1
    endif
    if @version < 240607        ; this option now in Color by Distance
      return m_dist.Iterate(r * zz)
    endif
    return r
  endfunc

  ; testing for one whape
  bool func test_1s(int oldval, int newval, int v, float &r)
    bool okay = false
    if v == 0                   ; "Inside"
      okay = newval == 1
    elseif v == 1               ; "Outside"
      okay = newval != 1
    elseif v == 2               ; "Either"
      okay = true
    elseif v == 3               ; "Change"
      okay = oldval != newval
    elseif v == 4               ; "Same"
      okay = oldval == newval
    elseif v == 5               ; "In->In"
        okay = (oldval==1) && (newval==1)
    elseif v == 6               ; "In->Out"
      okay = (oldval==1) && (newval!=1)
    elseif v == 7               ; "Out->In"
      okay = (oldval!=1) && (newval==1)
    else;if v == 8               ; "Out->Out"
      okay = (oldval!=1) && (newval!=1)
    endif
    return okay
  endfunc

  ; testing for nested whapes
  bool func test_ns(int oldval, int newval, int v, float &r)
    bool okay = false
    if v == 0                   ; "Inner"
      okay = newval == 3
    elseif v == 1               ; "Middle"
      okay = newval == 1
    elseif v == 2               ; "Outside"
      okay = newval == 0
    elseif v == 3               ; "Any"
      okay = true
    elseif v == 4               ; "Change"
      okay = oldval != newval
    elseif v == 5               ; "Same"
      okay = oldval == newval
    elseif v == 6               ; "Inwards"
        okay = oldval < newval
    else;if v == 7               ; "Outwards"
      okay = oldval > newval
    endif
if |#pixel-1|<1e-6
print(" newval ", newval, " v ", v, " okay ", okay)
endif
    return okay
  endfunc


protected:
  Distance m_dist
  DistancePlus  m_shap
  DistancePlus2 m_shapns
  DistancePlus m_shap2a
  DistancePlus m_shap2b
  DistancePlus m_ns
  int oldval
  float s1, float s2

default:
  title = "Shapes"
  rating = Recommended

	int param version
		caption = "Version"
		default = 240805
		visible = @version < 240805
	endparam
  heading
    text = "(current is 240805.}"
		visible = @version < 240805
  endheading

  param which
    caption = "Which"
    enum = "One shape" "Two nested" "Two different"
    default = 0
  endparam
  param nest
    caption = "Nesting shape"
    enum = "Circle/Ellipse" "Square/Rectangle" "Triangle"
    default = 0
    visible = @which == "Two nested"
  endparam

  bool param show_shape
    caption = "Show shape(s)?"
    default = false
  endparam

  param in_out
    caption = "In/Out/etc."
    enum = "Inside" "Outside" "Either" "Change" "Same"   \
           "In->In" "In->Out" "Out->In" "Out->Out"; "Show shape"
    default = 2
    visible = @which == "One shape" && !@show_shape
  endparam
  param in_out1
    caption = "Inner/Outer/etc."
    enum = "Inner" "Middle" "Outside" "Any" "Change" "Same"   \
           "Inwards" "Outwards" ;"Show shape"
    default = 3
    visible = (@which == "Two nested") && !@show_shape
  endparam
  param show_type
    caption = "Show"
    enum = "#1 shape" "#2 shape" "Both"
    default = 2
    visible = @which == "Two different"  && @show_shape
  endparam

  param in_out2a
    caption = "#1 In/Out/etc."
    enum = "Inside" "Outside" "Either" "Change" "Same"
    default = 2
    visible = (@which == "Two different") && !@show_shape
  endparam
  param in_out2b
    caption = "#2 In/Out/etc."
    enum = "Inside" "Outside" "Either" "Change" "Same"
    default = 2
    visible = (@which == "Two different") && !@show_shape
  endparam
  param dhow
    caption = "Which distance?"
    enum = "Min" "Average" "Max" "Difference"
    default = 0
    visible = @which > 0 && !@show_shape
  endparam

  heading
  endheading
  DistancePlus param dp_1
    caption = "Shape"
    default = JLB_DP_CE
    visible = @which == 0
  endparam
  DistancePlus param dp_CE
    caption = "Shape"
    default = JLB_DP_CE
    visible = @which == 1 && @nest == 0
    selectable = false
  endparam
  DistancePlus param dp_SR
    caption = "Shape"
    default = JLB_DP_SR
    visible = @which == 1 && @nest == 1
    selectable = false
  endparam
  DistancePlus param dp_T
    caption = "Shape"
    default = JLB_DP_T
    visible = @which == 1 && @nest == 2
    selectable = false
  endparam

  float param scale1
    caption = "Inner scaling"
    default = 1
    min = 0
    visible = @which == 1
  endparam
  float param scale2
    caption = "Outer scaling"
    default = 2
    min = 0
    visible = @which == 1
  endparam
  heading
    text = "reversing scales"
    visible =  @which == 1 && @scale1 > @scale2
  endheading
  DistancePlus param dp_2a
    caption = "Shape #1"
    default = JLB_DP_CE
    visible = @which  == "Two different"
  endparam
  DistancePlus param dp_2b
    caption = "Shape #2"
    default = JLB_DP_SR
    visible = @which  == "Two different"
  endparam
  heading
  endheading
}


class JLB_DShapesT(Distance) {
; new 251105 after not being satisfied with adding shape tweaking to JLB_DShapes
public:

  func JLB_DShapesT(Generic pparent)
    Distance(pparent)
    m_shap = new @dp_T(this)
;         if @shape == 0, m_shap = new @dp_CE_T(this)
;     elseif @shape == 1, m_shap = new @dp_SR_T(this)
;     elseif @shape == 2, m_shap = new @dp_T(this)
;     else,               m_shap = new @dp_CD(this)
;     endif
    m_shap.SetMult(1.0)
  endfunc

  func Init(complex zz)
    ;m_shap.SetTweak(@twk1, @twk2, @twk3)
    ; ignore return values, just check initial in/out
    m_shap.Iterate(zz, oldval)
  endfunc

  float func Iterate(complex zz)
    int newval
    float r
    bool okay

    ; just showing shapes
    if @show_shape
      int i
      m_shap.SetIter(@s_iter)        ; the shape depends on iter
      ;m_shap.SetTweak(@twk1, @twk2, @twk3)
      r = m_shap.Iterate(#pixel, i)
      okay = i==1
      r = 1      ; 0.01 * m_shap.GetIter( ) is reasonable
      if okay, return 1, else, return -1, endif
    endif

    ; start of regular iteration

; $define debug

    int iter = GetIter( )       ; from distance class
    m_shap.SetIter(iter)        ; the shape depends on iter
    ;m_shap.SetTweak(@twk1, @twk2, @twk3)
    r = m_shap.Iterate(zz, newval)
    okay = test(oldval, newval, @in_out)
    oldval = newval
    if !okay
      return -1
    endif
    return r
  endfunc

  ; testing for one whape
  bool func test(int oldval, int newval, int v)
    bool okay = false
    if v == 0                   ; "Inside"
      okay = newval == 1
    elseif v == 1               ; "Outside"
      okay = newval != 1
    elseif v == 2               ; "Either"
      okay = true
    elseif v == 3               ; "Change"
      okay = oldval != newval
    elseif v == 4               ; "Same"
      okay = oldval == newval
    elseif v == 5               ; "In->In"
        okay = (oldval==1) && (newval==1)
    elseif v == 6               ; "In->Out"
      okay = (oldval==1) && (newval!=1)
    elseif v == 7               ; "Out->In"
      okay = (oldval!=1) && (newval==1)
    else;if v == 8               ; "Out->Out"
      okay = (oldval!=1) && (newval!=1)
    endif
    return okay
  endfunc

protected:
  Distance m_dist
  DistancePlusT m_shap
  int oldval

default:
  title = "Shapes (tweaked)"
  rating = Recommended

	int param version
		caption = "Version"
		default = 251105
		visible = @version < 251105
	endparam
  heading
    text = "(current is 251105.}"
		visible = @version < 251105
  endheading

;   param shape
;     caption = "Shape"
;     enum = "Circle/Ellipse" "Square/Rectangle" "Triangle" "Curve"
;     default = 0
;   endparam

  bool param show_shape
    caption = "Show shape?"
    default = false
  endparam
  int param s_iter
    caption = "Which iteration?"
    default = 2
    min = 1
    visible = @show_shape
  endparam

  param in_out
    caption = "In/Out/etc."
    enum = "Inside" "Outside" "Either" "Change" "Same"   \
           "In->In" "In->Out" "Out->In" "Out->Out"; "Show shape"
    default = 2
    visible = !@show_shape
  endparam

  heading
  endheading
  DistancePlusT param dp_T
    caption = "Shape"
    default = JLB_DP_CE_T
  endparam
  heading
  endheading
}

; Circle/Ellipse DP
class JLB_DP_CE(DistancePlus) {
public:

  func JLB_DP_CE(Generic pparent)
		Generic.Generic(pparent)
    if @screen_center, ctr = #center, else, ctr = @center, endif
    float ang = @angle*#pi/180
    rot = cos(ang) + flip(sin(ang))
    if @type == "Circle" || @standard
      px = py = pxy = @p
    else
      px = @qx, py = @qy, pxy = (px+py)/2   ; sqrt(px*py) ?
    endif
    if @type == "Circle"
      h0 = v0 = @r
    else;if @type == "Ellipse"
      h0 = abs(real(@hvE)), v0 = abs(imag(@hvE))
      ; h = @hE, v = @vE
    endif
    SetCenter(ctr)
    SetRotation(rot)
    SetMult(1)                   ; set m_mult = 1
  endfunc

  float func Iterate(complex zz, int &i)
    ScaleShape(m_mult)
    float r
    bool inside = IsInsideCE(rot*(zz-ctr), r)
    i = 0
    if inside, i = 1, endif
    return r
  endfunc
  bool func IsInsideCE(complex zz, float &r)
  ; calling function rotates and shifts zz
    float x = abs(real(zz)/h)
    float y = abs(imag(zz)/v)
    r= ( x^px + y^py ) ^ (1/pxy)
    bool val = r <= 1
    r = abs(1-r) * (h+v)/2       ; Simple Shapes didn't do this.
    return val
  endfunc

  func ScaleShape(float f)
    h = h0*f, v = v0*f  ;, scale = scale0*f
  endfunc
  func unScaleShape( )
    h = h0, v = v0
  endfunc

protected:
  complex ctr
  complex rot
  float h0, float v0, float h, float v
  float px, float py, float pxy

default:
  title = "Circle/Ellipse"
  rating = Recommended

	int param version
		caption = "Version"
		default = 240303
		visible = @version < 240303
	endparam
  heading
    text = "(Current is 240303.}"
		visible = @version < 240303
  endheading

  param type
    caption = "Shape type"
    enum = "Circle" "Ellipse"
    default = 0
  endparam

  bool param screen_center
    caption = "Use screen center for shape center?"
    default = true
  endparam
  param center
    caption = "Shape center"
    default = (0,0)
    visible = !@screen_center
  endparam
  float param angle
    caption = "Shape rotation angle"
    default = 0
  endparam

  bool param standard
    caption = "Standard?"
    default = true
    visible = @type == 1
  endparam
  float param p
    caption = "Shape power"
    default = 2
    min = 0.15
    visible = @type == 0 || (@type == 1 && @standard)
  endparam
  float param qx
    caption = "X shape power"
    default = 2
    min = 0.15
    visible = @type == 1 && !@standard
  endparam
  float param qy
    caption = "Y shape power"
    default = 2
    min = 0.15
    visible = @type == 1 && !@standard
  endparam
  float param r
    caption = "Radius"
    default = 1
    min = 0
    visible = @type == 0
  endparam
  complex param hvE
    caption = "Shape"
    default = (2,1)
    ;min = 0
    visible = @type == 1
  endparam
}

; Circle/Ellipse DP with tweaking
class JLB_DP_CE_T(DistancePlusT) {
; 251110 new
public:

  func JLB_DP_CE_T(Generic pparent)
		Generic.Generic(pparent)
    if @screen_center, ctr = #center, else, ctr = @center, endif
    float ang = @angle*#pi/180
    rot = cos(ang) + flip(sin(ang))
    if @type == "Circle" || @standard
      px = py = pxy = @p
    else
      px = @qx, py = @qy, pxy = (px+py)/2   ; sqrt(px*py) ?
    endif
    if @type == "Circle"
      h0 = v0 = @r
    else;if @type == "Ellipse"
      ;h0 = abs(real(@hvE)), v0 = abs(imag(@hvE))
      h0 = @hE, v0 = @vE
    endif
    SetCenter(ctr)
    SetRotation(rot)
    SetMult(1)
    tweaking = @twk

  endfunc

  float func Iterate(complex zz, int &i)
    ScaleShape(m_mult)
    if tweaking
      int iter = GetIter( )
      if iter > 1
        TweakShape(iter-1)
      endif
    endif
    float r
    bool inside = IsInsideCE(rot*(zz-ctr), r)
    i = 0
    if inside, i = 1, endif
    return r
  endfunc
  bool func IsInsideCE(complex zz, float &r)
  ; calling function rotates and shifts zz
    float x = abs(real(zz)/h)
    float y = abs(imag(zz)/v)
    r= ( x^px + y^py ) ^ (1/pxy)
    bool val = r <= 1
    r = abs(1-r) * (h+v)/2       ; Simple Shapes didn't do this.
    return val
  endfunc

  func ScaleShape(float f)
    h = h0*f, v = v0*f  ;, scale = scale0*f
  endfunc
  func unScaleShape( )
    h = h0, v = v0
  endfunc

  func TweakShape(int i)
    if @type == "Circle"
      h = v = abs(h0 + i*@t1c)
    else;if @type == "Ellipse"
      h = abs(h0 + i*@t1e)
      v = abs(v0 + i*@t2e)
    endif
    float ang = (@angle+i*@t3)*#pi/180
    rot = cos(ang) + flip(sin(ang))
  endfunc

protected:
  complex ctr
  complex rot
  float h0, float v0, float h, float v
  float px, float py, float pxy
  bool tweaking

default:
  title = "Circle/Ellipse"
  rating = Recommended

	int param version
		caption = "Version"
		default = 251110
		visible = @version < 251110
	endparam
  heading
    text = "(Current is 251110.}"
		visible = @version < 251110
  endheading

  param type
    caption = "Shape type"
    enum = "Circle" "Ellipse"
    default = 0
  endparam

  bool param screen_center
    caption = "Use screen center for shape center?"
    default = true
  endparam
  param center
    caption = "Shape center"
    default = (0,0)
    visible = !@screen_center
  endparam
  float param angle
    caption = "Shape angle"
    default = 0
  endparam

  bool param standard
    caption = "Standard?"
    default = true
    visible = @type == 1
  endparam
  float param p
    caption = "Shape power"
    default = 2
    min = 0.15
    visible = @type == 0 || (@type == 1 && @standard)
  endparam
  float param qx
    caption = "X shape power"
    default = 2
    min = 0.15
    visible = @type == 1 && !@standard
  endparam
  float param qy
    caption = "Y shape power"
    default = 2
    min = 0.15
    visible = @type == 1 && !@standard
  endparam
  float param r
    caption = "Radius"
    default = 1
    min = 0
    visible = @type == "Circle"
  endparam
  float param hE
    caption = "H size"
    default = 2
    min = 0
    visible = @type == 1
  endparam
  float param vE
    caption = "V size"
    default = 1
    min = 0
    visible = @type == 1
  endparam

  bool param twk
    caption = "Tweak parameters?"
    default = true
  endparam
  float param t1c
    caption = "Tweak radius"
    default = 0.1
    visible = @twk && @type == "Circle"
  endparam
  float param t1e
    caption = "Tweak H size"
    default = 0.1
    visible = @twk && @type == "Ellipse"
  endparam
  float param t2e
    caption = "Tweak V size"
    default = 0.1
    visible = @twk && @type == "Ellipse"
  endparam
  float param t3
    caption = "Tweak angle"
    default = 5
    visible = @twk && ( \
            (@type == "Circle" && @p != 2) || \
             @type == "Ellipse" )
  endparam
}

; Triangle DP
class JLB_DP_T(DistancePlus) {
  public:

  func JLB_DP_T(Generic pparent)
		Generic.Generic(pparent)
    if @equi
      if @screen_center, ctr = #center, else, ctr = @center, endif
      v1 = flip(2*@Tside/3)
      complex rrot = cos(#pi*2/3) + flip(sin(#pi*2/3))
      v2 = v1 * rrot
      v3 = v2 * rrot
      v1 = v1 + ctr, v2 = v2 + ctr, v3 = v3 + ctr
    else
      v1 = @vt1, v2 = @vt2, v3 = @vt3
      ctr = ( v1 + v2 + v3 ) / 3
    endif
    float ang = @angle*#pi/180
    rot = cos(ang) - flip(sin(ang))
    ScaleShape(1.0)
    SetCenter(ctr)
    SetRotation(rot)
    SetMult(1)
  endfunc

  float func Iterate(complex zz, int &i)
    ScaleShape(m_mult)
    float r
    bool inside = IsInsideT(zz, r)
    i = 0
    if inside, i = 1, endif
    return r
  endfunc
  bool func IsInsideT(complex zz, float &r)
    complex v = Geometry.ClosestPointToFigure(zz, 3, v1r, v2r, v3r, v3r)
    r = cabs(v)
    bool inside = Geometry.PointInTriangle(zz, v1r, v2r, v3r)
    return inside
  endfunc

  func ScaleShape(float f)
    v1r = ctr + f*rot*(v1-ctr)
    v2r = ctr + f*rot*(v2-ctr)
    v3r = ctr + f*rot*(v3-ctr)
  endfunc
  func unScaleShape( )
    v1r = v1, v2r = v2, v3r = v3
  endfunc

protected:
  complex ctr
  complex rot
  complex v1  , complex v2  , complex v3
  complex v1r , complex v2r , complex v3r

default:
  title = "Triangle"
  rating = Recommended

	int param version
		caption = "Version"
		default = 240303
		visible = @version < 240303
	endparam
  heading
    text = "(current is 240303.}"
		visible = @version < 240303
  endheading

  bool param equi
    caption = "Equilateral triangle?"
    default = true
  endparam
  float param Tside
    caption = "Side length"
    default = 2.0
    min = 0
    visible = @equi
  endparam
  bool param screen_center
    caption = "Use screen center for shape center?"
    default = true
    visible = @equi
  endparam
  param center
    caption = "Shape center"
    default = (0,0)
    visible = @equi && !@screen_center
  endparam

  ; non-equilateral stuff
  complex param vt1
    caption = "Vertex 1"
    default = (0,0)
    visible = !@equi
  endparam
  complex param vt2
    caption = "Vertex 2"
    default = (2,0)
    visible = !@equi
  endparam
  complex param vt3
    caption = "Vertex 3"
    default = (0,1)
    visible = !@equi
  endparam

  float param angle
    caption = "Shape rotation angle"
    default = 0
  endparam
}

; Triangle DP with tweaking
class JLB_DP_T_T(DistancePlusT) {
; 251110 new
  public:

  func JLB_DP_T_T(Generic pparent)
		Generic.Generic(pparent)
    if @equi
      if @screen_center, ctr = #center, else, ctr = @center, endif
      v1 = flip(2*@Tside/3)
      complex rrot = cos(#pi*2/3) + flip(sin(#pi*2/3))
      v2 = v1 * rrot
      v3 = v2 * rrot
      v1 = v1 + ctr, v2 = v2 + ctr, v3 = v3 + ctr
    else
      v1 = @vt1, v2 = @vt2, v3 = @vt3
      ctr = ( v1 + v2 + v3 ) / 3
    endif
    float ang = @angle*#pi/180
    rot = cos(ang) - flip(sin(ang))
    ScaleShape(1.0)
    SetCenter(ctr)
    SetRotation(rot)
    SetMult(1)
    tweaking = @twk
  endfunc

  float func Iterate(complex zz, int &i)
    ScaleShape(m_mult)
    if tweaking
      int iter = GetIter( )
      if iter > 1
        TweakShape(iter-1)
      endif
    endif
    float r
    bool inside = IsInsideT(zz, r)
    i = 0
    if inside, i = 1, endif
    return r
  endfunc
  bool func IsInsideT(complex zz, float &r)
    complex v = Geometry.ClosestPointToFigure(zz, 3, v1r, v2r, v3r, v3r)
    r = cabs(v)
    bool inside = Geometry.PointInTriangle(zz, v1r, v2r, v3r)
    return inside
  endfunc

  func ScaleShape(float f)
    v1r = ctr + f*rot*(v1-ctr)
    v2r = ctr + f*rot*(v2-ctr)
    v3r = ctr + f*rot*(v3-ctr)
  endfunc
  func unScaleShape( )
    v1r = v1, v2r = v2, v3r = v3
  endfunc

  func TweakShape(int i)
    float ang = (@angle+i*@t3)*#pi/180
    rot = cos(ang) - flip(sin(ang))
    float f = 1 + i * @t1
    ScaleShape(f)
  endfunc

protected:
  complex ctr
  complex rot
  complex v1  , complex v2  , complex v3
  complex v1r , complex v2r , complex v3r
  bool tweaking

default:
  title = "Triangle"
  rating = Recommended

	int param version
		caption = "Version"
		default = 251110
		visible = @version < 251110
	endparam
  heading
    text = "(current is 251110.}"
		visible = @version < 251110
  endheading

  bool param equi
    caption = "Equilateral triangle?"
    default = true
  endparam
  float param Tside
    caption = "Side length"
    default = 2.0
    min = 0
    visible = @equi
  endparam
  bool param screen_center
    caption = "Use screen center for shape center?"
    default = true
    visible = @equi
  endparam
  param center
    caption = "Shape center"
    default = (0,0)
    visible = @equi && !@screen_center
  endparam

  ; non-equilateral stuff
  complex param vt1
    caption = "Vertex 1"
    default = (0,0)
    visible = !@equi
  endparam
  complex param vt2
    caption = "Vertex 2"
    default = (2,0)
    visible = !@equi
  endparam
  complex param vt3
    caption = "Vertex 3"
    default = (0,1)
    visible = !@equi
  endparam

  float param angle
    caption = "Shape rotation angle"
    default = 0
  endparam

  bool param twk
    caption = "Tweak parameters?"
    default = true
  endparam
  float param t1
    caption = "Tweak size"
    default = 0.1
    visible = @twk
  endparam
  float param t3
    caption = "Tweak angle"
    default = 5
    visible = @twk
  endparam
}


; Square/Rectangle DP
class JLB_DP_SR(DistancePlus) {
  public:

  func JLB_DP_SR(Generic pparent)
		Generic.Generic(pparent)
    if @screen_center, ctr = #center, else, ctr = @center, endif
    if @type == "Square"
      h = v = 0.5 * @Sside
    else
      h = 0.5 * @hR, v = 0.5 * @vR
    endif
    v1 = ctr + h + flip(v)       ; upper right corner
    v2 = ctr + h - flip(v)       ; lower right corner
    v3 = ctr - h - flip(v)       ; lower left  corner
    v4 = ctr - h + flip(v)       ; upper left  corner
    float ang = @angle*#pi/180
    rot = cos(ang) - flip(sin(ang))
    ScaleShape(1.0)
    SetCenter(ctr)
    SetRotation(rot)
    SetMult(1)
  endfunc

  float func Iterate(complex zz, int &i)
    ScaleShape(m_mult)
    float r
    bool inside = IsInsideSR(zz, r)
    i = 0
    if inside, i = 1, endif
    return r
  endfunc
  bool func IsInsideSR(complex zz, float &r)
    complex p = Geometry.ClosestPointToFigure(zz, 4, v1r, v2r, v3r, v4r)
    r = cabs(p)
  ; check both triangles
    return Geometry.PointInTriangle(zz, v1r, v2r, v3r) || \
           Geometry.PointInTriangle(zz, v3r, v4r, v1r)
  endfunc

  func ScaleShape(float f)
    v1r = ctr + f*rot*(v1-ctr), v2r = ctr + f*rot*(v2-ctr)
    v3r = ctr + f*rot*(v3-ctr), v4r = ctr + f*rot*(v4-ctr)
  endfunc
  func unScaleShape( )
    v1r = v1, v2r = v2, v3r = v3, v4r = v4
  endfunc

protected:
  complex ctr
  complex rot
  float h, float v
  complex v1 , complex v2 , complex v3 , complex v4
  complex v1r, complex v2r, complex v3r, complex v4r

default:
  title = "Square/Rectangle"
  rating = Recommended

	int param version
		caption = "Version"
		default = 240303
		visible = @version < 240303
	endparam
  heading
    text = "(current is 240303.}"
		visible = @version < 240303
  endheading

  param type
    caption = "Shape type"
    enum = "Square" "Rectangle"
    default = 0
  endparam
  bool param screen_center
    caption = "Use screen center for shape center?"
    default = true
  endparam
  param center
    caption = "Shape center"
    default = (0,0)
    visible = !@screen_center
  endparam

  float param Sside
    caption = "Side length"
    default = 2.0
    min = 0
    visible = @type == 0
  endparam
  float param hR
    caption = "Rectangle X length"
    default = 2
    min = 0
    visible = @type == 1
  endparam
  float param vR
    caption = "Rectangle Y length"
    default = 1
    min = 0
    visible = @type == 1
  endparam

  float param angle
    caption = "Shape rotation angle"
    default = 0
  endparam
}


; Square/Rectangle DP with tweaking
class JLB_DP_SR_T(DistancePlusT){
; 251110 new
  public:

  func JLB_DP_SR_T(Generic pparent)
		Generic.Generic(pparent)
    if @screen_center, ctr = #center, else, ctr = @center, endif
    if @type == "Square"
      h0 = v0 = 0.5 * @Sside
    else
      h0 = 0.5 * @hR, v0 = 0.5 * @vR
    endif
    SetCenter(ctr)
    SetVertices(h0, v0, @angle)
    SetMult(1)                    ; set m_mult = 1
    tweaking = @twk
  endfunc

  func SetVertices(float h, float v, float angle)
    float ang = angle*#pi/180
    rot = cos(ang) + flip(sin(ang))
    complex v1 = ctr + h + flip(v)       ; upper right corner
    complex v2 = ctr + h - flip(v)       ; lower right corner
    complex v3 = ctr - h - flip(v)       ; lower left  corner
    complex v4 = ctr - h + flip(v)       ; upper left  corner
    v1r0 = ctr + conj(rot)*(v1-ctr)
    v2r0 = ctr + conj(rot)*(v2-ctr)
    v3r0 = ctr + conj(rot)*(v3-ctr)
    v4r0 = ctr + conj(rot)*(v4-ctr)
    SetRotation(rot)
  endfunc

  float func Iterate(complex zz, int &i)
    ScaleShape(m_mult)
    if tweaking
      int iter = GetIter( )
      if iter > 1
        TweakShape(iter-1)
      endif
    endif
    float r
    bool inside = IsInsideSR(zz, r)
    i = 0
    if inside, i = 1, endif
    return r
  endfunc
  bool func IsInsideSR(complex zz, float &r)
  ; check both triangles
    complex p = Geometry.ClosestPointToFigure(zz, 4, v1r, v2r, v3r, v4r)
    r = cabs(p)
    return Geometry.PointInTriangle(zz, v1r, v2r, v3r) || \
           Geometry.PointInTriangle(zz, v3r, v4r, v1r)
  endfunc

  func ScaleShape(float f)
    v1r = ctr + f*(v1r0-ctr), v2r = ctr + f*(v2r0-ctr)
    v3r = ctr + f*(v3r0-ctr), v4r = ctr + f*(v4r0-ctr)
  endfunc
  func unScaleShape( )
    v1r = v1r0, v2r = v2r0, v3r = v3r0, v4r = v4r0
  endfunc

  func TweakShape(int i)
    float h, float v
    if @type == "Square"
      h = v = abs(h0 + i*@t1s)
    else
      h = abs(h0 + i*@t1r)
      v = abs(v0 + i*@t2r)
    endif
    float ang = @angle+i*@t3
    SetVertices(h, v, ang)
  endfunc

protected:
  complex ctr
  complex rot
  float h0, float v0
  complex v1r , complex v2r , complex v3r , complex v4r
  complex v1r0, complex v2r0, complex v3r0, complex v4r0
  bool tweaking

default:
  title = "Square/Rectangle"
  rating = Recommended

	int param version
		caption = "Version"
		default = 251110
		visible = @version < 251110
	endparam
  heading
    text = "(current is 251110.}"
		visible = @version < 251110
  endheading

  param type
    caption = "Shape type"
    enum = "Square" "Rectangle"
    default = 0
  endparam
  bool param screen_center
    caption = "Use screen center for shape center?"
    default = true
  endparam
  param center
    caption = "Shape center"
    default = (0,0)
    visible = !@screen_center
  endparam
  float param angle
    caption = "Shape rotation angle"
    default = 0
  endparam

  float param Sside
    caption = "Side length"
    default = 2.0
    min = 0
    visible = @type == 0
  endparam
  float param hR
    caption = "Rectangle X length"
    default = 2
    min = 0
    visible = @type == 1
  endparam
  float param vR
    caption = "Rectangle Y length"
    default = 1
    min = 0
    visible = @type == 1
  endparam

  bool param twk
    caption = "Tweak parameters?"
    default = true
  endparam
  float param t1s
    caption = "Tweak sixe"
    default = 0.1
    visible = @twk && @type == "Square"
  endparam
  float param t1r
    caption = "Tweak H size"
    default = 0.1
    visible = @twk && @type == "Rectangle"
  endparam
  float param t2r
    caption = "Tweak V size"
    default = 0.1
    visible = @twk && @type == "Rectangle"
  endparam
  float param t3
    caption = "Tweak angle"
    default = 5
    visible = @twk
  endparam
}

; Angle DP
class JLB_DP_A(DistancePlus) {
  public:

  func JLB_DP_A(Generic pparent)
		Generic.Generic(pparent)
    if @screen_center, ctr = #center, else, ctr = @center, endif
    w = @width
  endfunc

  float func Iterate(complex zz, int &i)
    float r
    bool inside = IsInsideA(zz, r)
    i = 0
    if inside, i = 1, endif
    return r
  endfunc

  bool func IsInsideA(complex zz, float &r)
    float d = atan2(zz-ctr)*180/#pi     ; range -180 to +180
    if d < 0, d = d + 360, endif    ; range 0 to 360
    float spacing = 360/@mult
    float b = d - @ref_angle
    b = b - spacing * round(b/spacing)
    b = abs(b)
    b = MyMath.fmin(b, spacing-b)
    r = b / (0.5 * w)
    return r <= 1
  endfunc

  func ScaleShape(float f)
    wsave = w
    w = w*f
  endfunc
  func unScaleShape( )
    w = wsave
  endfunc
protected:
  complex ctr
  float w
  float wsave

default:
  title = "Angle"
  rating = Recommended

	int param version
		caption = "Version"
		default = 240607
		visible = @version < 240607
	endparam
  heading
    text = "(current is 240607.}"
		visible = @version < 240607
  endheading

  bool param screen_center
    caption = "Use screen center for shape center?"
    default = true
    ;visible = !(@type == 2 && !@equi)
  endparam
  param center
    caption = "Shape center"
    default = (0,0)
    visible = !@screen_center
  endparam

  heading
    text = "(All in degrees)"
  endheading
  float param ref_angle
    caption = "Reference angle"
    min = 0
    max = 360
    default = 0
  endparam
  int param mult
    caption = "Multiplicity"
    min = 1
    default = 3
  endparam
  float param width
    caption = "Width"
    min = 0
    max = 360
    default = 45
  endparam
}

; nested shapes
class JLB_DP2_NS(DistancePlus2) {
  public:

  func JLB_DP2_NS(Generic pparent)
		Generic.Generic(pparent)
		if @version < 240810          ; allow any shape
      m_shap = new @dp(this)
    else                          ; only the ones that can nest
      if @shape == 0
        m_shap = new JLB_DP_CE(this)
      elseif @shape == 1
        m_shap = new JLB_DP_SR(this)
      else
        m_shap = new JLB_DP_T(this)
      endif
    endif
    s1 = MyMath.fmin(@scale1, @scale2)
    s2 = MyMath.fmax(@scale1, @scale2)
  endfunc

  float func Iterate(complex zz, int &i)
    float r1 = 1e30, float r2
    int i1 = 0, int i2

    ; inner shape
    bool inside1 = false
    if s1 > 0
      m_shap.ScaleShape(s1)
      r1 = m_shap.Iterate(zz, i1)
      inside1 = (i1 == 1)
      m_shap.unScaleShape( )
    endif
    ; outer shape
    m_shap.ScaleShape(s2)
    r2 = m_shap.Iterate(zz, i2)
    bool inside2 = (i2 == 1)
    m_shap.unScaleShape( )

    i = 0
    if inside1                            ; inner
      i = 0
    elseif !inside1 && inside2            ; middle
      i = 1
    else;if !inside1 && !inside2          ; outer
      i = 2
    endif
    return MyMath.fmin(r1, r2)
  endfunc

protected:
  DistancePlus m_shap
  float s1, float s2

default:
  title = "Nested shapes"
  rating = Recommended

	int param version
		caption = "Version"
		default = 240810
		visible = @version < 240810
	endparam
  heading
    text = "(current is 240810.}"
		visible = @version < 240810
  endheading

  DistancePlus param dp
    caption = "Plug-in"
    default = JLB_DP_CE
		;visible = @version < 240810
  endparam
  param shape
    caption = "Nesting shape"
    enum = "Circle/Ellipse" "Square/Rectangle" "Triangle"
    default = 0
		visible = @version >= 240810
  endparam

  float param scale1
    caption = "Inner scaling"
    default = 1
    min = 0
  endparam
  float param scale2
    caption = "Outer scaling"
    default = 2
    min = 0
  endparam
  heading
    text = "reversing scales"
    visible = @scale1 > @scale2
  endheading
}

class JLB_DP_CD(DistancePlus){
 ; Color by Distance plug-in using Curves--CD10x, etc.
 ; slightly confusing names.
 ;    @scale means scale result to be O(1) (or don't)
 ;    ScaleShape means change a and b by factor
 ; 951021 implement ScaleShape correctly. backward compatible
public:
  func JLB_DP_CD(Generic pparent)
		Generic.Generic(pparent)
    ;DistancePlus(pparent)
    if @numpar == "1"
      m_CD1 = new @d_CD1(this)
      m_CD1.SetScale(@scale)
    else
      m_CD2 = new @d_CD2(this)
      m_CD2.SetScale(@scale)
    endif
    ScaleShape(1.0)
    if @screen_center, ctr = #center, else, ctr = @center, endif
    float ang = @angle*#pi/180
    rot = cos(ang) + flip(sin(ang))
    ;scale = 1
    SetCenter(ctr)
    SetRotation(rot)
    SetMult(1)
  endfunc

  float func Iterate(complex zz, int &i)
    ScaleShape(m_mult)
;     if m_tweak
;       int iter = GetIter( )
;       if iter > 1
;         TweakShape(iter-1)
;       endif
;     endif
    float r
    bool inside = IsInsideC(rot*(zz-ctr), r)
    i = 0
    if inside, i = 1, endif
    return r
  endfunc
  bool func IsInsideC(complex zz, float &r)
  ; calling function rotates and shifts zz
    if @numpar == "1"
      m_CD1.SetAll(zz, @exch)
      r = m_CD1.Iterate(zz)
    else
      m_CD2.SetAll(zz, @exch)
      r = m_CD2.Iterate(zz)
    endif
    bool val = r < @bdry
    r = abs(r)
    return val
  endfunc

  func ScaleShape(float f)
    if @numpar == "1"
      m_CD1.SetAB(@a*f, 1)
    else
      m_CD2.SetAB(@a*f, @b*f)
    endif
  endfunc
  func unScaleShape( )
    ScaleShape(1.0)
  endfunc

;   func TweakShape(int i)
;     float ang = (@angle+i*m_d)*#pi/180
;     rot = cos(ang) + flip(sin(ang))
;     if @numpar == "1"
;       m_CD1.SetAB(@a+i*m_a, 1)
;     else
;       m_CD2.SetAB(@a+i*m_a, @b+i*m_b)
;     endif
;   endfunc

protected:
  CD1 m_CD1
  CD2 m_CD2
  complex ctr
  complex rot
  ;float scale        ; for Nested Shapes

default:
  title = "Curve"
  rating = Recommended
	int param version
		caption = "Version"
		default = 240314
		visible = @version < 240314
	endparam
  heading
    text = "(Current is 240314.)"
		visible = @version < 240314
  endheading
;   heading
;     text = "Scaling is often useful, as is Mandelbrot smoothing."
;   endheading

  bool param screen_center
    caption = "Use screen center for shape center?"
    default = true
    ;visible = !(@type == 2 && !@equi)
  endparam
  param center
    caption = "Shape center"
    default = (0,0)
    visible = !@screen_center
  endparam
  float param angle
    caption = "Shape rotation angle"
    default = 0
  endparam
  float param bdry
    caption = "In/Out boundary"
    default = 0
  endparam

  param numpar
    caption = "# parameters"
    enum = "1" "2"
    default = 0
  endparam
  CD1 param d_CD1
    caption = "Curve"
    default = JLB_CD101
    visible = @numpar == "1"
  endparam
  CD2 param d_CD2
    caption = "Curve"
    default = JLB_CD201
    visible = @numpar == "2"
  endparam
  bool param exch
    caption = "Exchange x and y?"
    default = false
    visible = (@numpar == "1"               \
               && @d_CD1 != JLB_CD118       \
               && @d_CD1 != JLB_CD133       \
               && @d_CD1 != JLB_CD141 ) ||  \
               (@numpar == "2"              \
               && @d_CD2 != JLB_CD203a      \
               && @d_CD2 != JLB_CD205       \
               && @d_CD2 != JLB_CD232)
           ; Folium of Descartes, Quadrifolium, Trott
           ; Astroid, Beetle, Windmill
  endparam
  bool param scale
    caption = "Scale?"
    default = true
  endparam
  float param a
    caption = "Parameter a"
    default = 1.0
  endparam
  float param b
    caption = "Parameter b"
    default = 1.0
    visible = @numpar == "2"
  endparam
}

; curves with tweaking
class JLB_DP_CD_T(DistancePlusT){
 ; 951110 new
public:
  func JLB_DP_CD_T(Generic pparent)
		Generic.Generic(pparent)
    ;DistancePlus(pparent)
    if @numpar == "1"
      m_CD1 = new @d_CD1(this)
      m_CD1.SetScale(@scale)
    else
      m_CD2 = new @d_CD2(this)
      m_CD2.SetScale(@scale)
    endif
    ScaleShape(1.0)
    if @screen_center, ctr = #center, else, ctr = @center, endif
    float ang = @angle*#pi/180
    rot = cos(ang) + flip(sin(ang))
    ;scale = 1
    SetCenter(ctr)
    SetRotation(rot)
    SetMult(1)                   ; set m_mult = 1
    tweaking = @twk
  endfunc

  float func Iterate(complex zz, int &i)
    ScaleShape(m_mult)
    if tweaking
      int iter = GetIter( )
      if iter > 1
        TweakShape(iter-1)
      endif
    endif
    float r
    bool inside = IsInsideC(rot*(zz-ctr), r)
    i = 0
    if inside, i = 1, endif
    return r
  endfunc
  bool func IsInsideC(complex zz, float &r)
  ; calling function rotates and shifts zz
    if @numpar == "1"
      m_CD1.SetAll(zz, @exch)
      r = m_CD1.Iterate(zz)
    else
      m_CD2.SetAll(zz, @exch)
      r = m_CD2.Iterate(zz)
    endif
    bool val = r < @bdry
    r = abs(r)
    return val
  endfunc

  func ScaleShape(float f)
    if @numpar == "1"
      m_CD1.SetAB(@a*f, 1)
    else
      m_CD2.SetAB(@a*f, @b*f)
    endif
  endfunc
  func unScaleShape( )
    ScaleShape(1.0)
  endfunc

  func TweakShape(int i)
    float ang = (@angle+i*@t3)*#pi/180
    rot = cos(ang) + flip(sin(ang))
    if @numpar == "1"
      m_CD1.SetAB(@a*(1+i*@t1), 1)
    else
      m_CD2.SetAB(@a*(1+i*@t1), @b*(1+i*@t2))
    endif
  endfunc

protected:
  CD1 m_CD1
  CD2 m_CD2
  complex ctr
  complex rot
  bool tweaking

default:
  title = "Curve"
  rating = Recommended
	int param version
		caption = "Version"
		default = 251110
		visible = @version < 251110
	endparam
  heading
    text = "(Current is 251110.)"
		visible = @version < 251110
  endheading
;   heading
;     text = "Scaling is often useful, as is Mandelbrot smoothing."
;   endheading

  bool param screen_center
    caption = "Use screen center for shape center?"
    default = true
    ;visible = !(@type == 2 && !@equi)
  endparam
  param center
    caption = "Shape center"
    default = (0,0)
    visible = !@screen_center
  endparam
  float param angle
    caption = "Shape rotation angle"
    default = 0
  endparam
  float param bdry
    caption = "In/Out boundary"
    default = 0
  endparam

  param numpar
    caption = "# parameters"
    enum = "1" "2"
    default = 0
  endparam
  CD1 param d_CD1
    caption = "Curve"
    default = JLB_CD101
    visible = @numpar == "1"
  endparam
  CD2 param d_CD2
    caption = "Curve"
    default = JLB_CD201
    visible = @numpar == "2"
  endparam
  bool param exch
    caption = "Exchange x and y?"
    default = false
    visible = (@numpar == "1"               \
               && @d_CD1 != JLB_CD118       \
               && @d_CD1 != JLB_CD133       \
               && @d_CD1 != JLB_CD141 ) ||  \
               (@numpar == "2"              \
               && @d_CD2 != JLB_CD203a      \
               && @d_CD2 != JLB_CD205       \
               && @d_CD2 != JLB_CD232)
           ; Folium of Descartes, Quadrifolium, Trott
           ; Astroid, Beetle, Windmill
  endparam
  bool param scale
    caption = "Scale?"
    default = true
  endparam
  float param a
    caption = "Parameter a"
    default = 1.0
  endparam
  float param b
    caption = "Parameter b"
    default = 1.0
    visible = @numpar == "2"
  endparam

  bool param twk
    caption = "Tweak parameters?"
    default = true
  endparam
  float param t1
    caption = "Tweak a"
    default = 0.1
    visible = @twk
  endparam
  float param t2
    caption = "Tweak b"
    default = 0.1
    visible = @twk && @numpar == "2"
  endparam
  float param t3
    caption = "Tweak angle"
    default = 5
    visible = @twk
  endparam
}

class JLB_UT_Curves(common.ulb:UserTransform){
 ; UserTransform using Curves--CD10x, etc.
 ; new 250923
 ; first version: x and y use the same curve but switch x and y
public:
  func JLB_UT_Curves(Generic pparent)
    UserTransform(pparent)
    if @numpar == "1"
      m_CD1x = new @d_CD1x(this)
      m_CD1x.SetAB(@ax, 1)
      m_CD1x.SetScale(false)
      m_CD1y = new @d_CD1y(this)
      m_CD1y.SetAB(@ay, 1)
      m_CD1y.SetScale(false)
    else
      m_CD2x = new @d_CD2x(this)
      m_CD2x.SetAB(@ay, @by)
      m_CD2x.SetScale(false)
      m_CD2y = new @d_CD2y(this)
      m_CD2y.SetAB(@ay, @by)
      m_CD2y.SetScale(false)
    endif
  endfunc

  complex func Iterate(complex pz)
    float x, float y
    if @numpar == "1"
      m_CD1x.SetAll(pz, false)
      x = m_CD1x.Iterate(pz)
      m_CD1y.SetAll(pz, false)
      y = m_CD1y.Iterate(pz)
    else
      m_CD2x.SetAll(pz, false)
      x = m_CD2y.Iterate(pz)
      m_CD2y.SetAll(pz, true)
      y = m_CD2y.Iterate(pz)
    endif
    return x + flip(y)
  endfunc

protected:
  CD1 m_CD1x
  CD1 m_CD1y
  CD2 m_CD2x
  CD2 m_CD2y

default:
  title = "Two Curves"
  rating = Recommended
	int param version
		caption = "Version"
		default = 250923
		visible = @version < 250923
	endparam
  heading
    text = "(Current is 250923.)"
		visible = @version < 250923
  endheading

  param numpar
    caption = "Curve type"
    enum = "1" "2"
    default = 0
  endparam
  CD1 param d_CD1x
    caption = "X Curve"
    default = JLB_CD101
    visible = @numpar == "1"
  endparam
  CD2 param d_CD2x
    caption = "X Curve"
    default = JLB_CD201
    visible = @numpar == "2"
  endparam
  float param ax
    caption = "Parameter a"
    default = 1.0
  endparam
  float param bx
    caption = "Parameter b"
    default = 1.0
    visible = @numpar == "2"
  endparam
  CD1 param d_CD1y
    caption = "Y Curve"
    default = JLB_CD101
    visible = @numpar == "1"
  endparam
  CD2 param d_CD2y
    caption = "Y Curve"
    default = JLB_CD201
    visible = @numpar == "2"
  endparam
  float param ay
    caption = "Parameter a"
    default = 1.0
  endparam
  float param by
    caption = "Parameter b"
    default = 1.0
    visible = @numpar == "2"
  endparam
;   CD2 param d_CD2
;     caption = "Curve"
;     default = JLB_CD201
;     visible = @numpar == "2"
;   endparam
;   bool param exch
;     caption = "Exchange x and y?"
;     default = false
;     visible = (@numpar == "1"               \
;                && @d_CD1x != JLB_CD118       \
;                && @d_CD1x != JLB_CD133       \
;                && @d_CD1x != JLB_CD141 ) ||  \
;                (@numpar == "2"              \
;                && @d_CD2 != JLB_CD203a      \
;                && @d_CD2 != JLB_CD205       \
;                && @d_CD2 != JLB_CD232)
;            ; Folium of Descartes, Quadrifolium, Trott
;            ; Astroid, Beetle, Windmill
;   endparam
;   bool param scale
;     caption = "Scale?"
;     default = false
;   endparam
}

class JLB_DP_Trap(DistancePlus){
 ; a plug-in for Color by Distance using Trap plug-ins
public:
  import "common.ulb"
  import "standard.ulb"

  func JLB_DP_Trap(Generic pparent)
    ;DistancePlus(pparent)
		Generic.Generic(pparent)
    m_T = new @shape(this)
    if @screen_center, ctr = #center, else, ctr = @center, endif
    float ang = @angle*#pi/180
    rot = cos(ang) + flip(sin(ang))
    scale = 1
    SetCenter(ctr)
    SetRotation(rot)
    SetMult(1)
  endfunc

  float func Iterate(complex zz, int &i)
    ;scale = GetScale( )
    zz = scale * zz
    float r
    bool inside = IsInsideC(rot*(zz-ctr), r)
    i = 0
    if inside, i = 1, endif
    return r
  endfunc
  bool func IsInsideC(complex zz, float &r)
  ; calling function rotates and shifts zz
    if @exch, zz = flip(zz), endif
    r = m_T.Iterate(zz)
    bool val = r < @bdry
    r = abs(r)
    return val
  endfunc

  func ScaleShape(float f)
    scale = f
  endfunc
  func unScaleShape( )
    scale = 1
  endfunc

protected:
  TrapShape m_T
  complex ctr
  complex rot
  float scale        ; for Nested Shapes

default:
  title = "Trap"
  rating = Recommended
	int param version
		caption = "Version"
		default = 240804
		visible = @version < 240804
	endparam
  heading
    text = "(Current is 240804.)"
		visible = @version < 240804
  endheading

  bool param screen_center
    caption = "Use screen center for shape center?"
    default = true
  endparam
  param center
    caption = "Shape center"
    default = (0,0)
    visible = !@screen_center
  endparam
  float param angle
    caption = "Shape rotation angle"
    default = 0
  endparam
  float param bdry
    caption = "Boundary"
    default = 0
  endparam
  TrapShape param shape
    caption = "Trap Shape"
    default = Standard_TrapShapeHeart
  endparam

  bool param exch
    caption = "Exchange x and y?"
    default = false
  endparam
}

class JLB_DCiliaPlus(Distance){
; A generalized version of dmj-cilia in dmj.ucl
; 250607 some minor bug fixes
; 250703 added possibilities for Distance, Grid, and Concentric
;        added switch possibility (backward compatibile)
public:
  func JLB_DCiliaPlus(Generic pparent)
    Distance(pparent)
    if @t1 == "Distance"
      m_SD1 = new @d_SD1(this)
      m_SD1.SetScale(true)
    elseif @t1 == "Grid"
      m_D1 = new @fd1(this)
    elseif @t1 == "Concentric"
      m_D1 = new @gd1(this)
    endif
    if @t2 == "Distance"
      m_SD2 = new @d_SD2(this)
      m_SD2.SetScale(true)
    elseif @t2 == "Grid"
      m_D2 = new @fd2(this)
    elseif @t2 == "Concentric"
      m_D2 = new @gd2(this)
    endif
  endfunc

  func Init(complex zz)
    if @t1 == "Distance"
      if (@d_SD1 == JLB_D00 || @d_SD1 == JLB_D01)
        m_SD1.SetFactor(@divisor1)
      endif
      m_SD1.SD_Set(0, 0)        ; initial path length = 0 - no path yet
      m_SD1.SetScale(true)
    endif
    if @t2 == "Distance"
      if (@d_SD2 == JLB_D00 || @d_SD2 == JLB_D01)
        m_SD2.SetFactor(@divisor2)
      endif
      m_SD2.SD_Set(0, 0)        ; initial path length = 0 - no path yet
      m_SD2.SetScale(true)
    endif
    if @t1 == 0 || @t2 == 0
      il = real(1/log(@pow))
      lp = log(log(@Top))
    endif
  endfunc

  float func Iterate(complex zz)
    complex z0 = zz
    float d, float f         ; names d and f are left over from dmj-cilia
    if @version >= 250703
      if @switch
        d = Go(zz, z0, @t2, 2)
        f = Go(zz, z0, @t1, 1)
      else
        d = Go(zz, z0, @t1, 1)
        f = Go(zz, z0, @t2, 2)
      endif
    else
      d = Go(zz, z0, @t1, 1)
      f = Go(zz, z0, @t2, 2)
    endif

    if d < 0         ; negative only if log used and cabs(z) > @Top
      d = fixup(d)
    endif
    if f < 0
      f = fixup(f)
    endif
    if d < 0 || f < 0
      return -1
    endif
    ; apply skew
    d = d + @skew*f         ; dmj suggests half-integers
    d = d - floor(d)        ; keep in 0..1

    ; All these take two numbers, d and f, each in 0..1, and produces
    ; an index also in 0..1
    ; At end, with d in 0..1, can use d, 1-d, abs(1-2*d), or 1-abs(1-2*d)
    ; (these are V0 through V3, respectively)

    float d1, float d2
    if (@ciliatype == 0)			; sawtooth
      if (d < 0.5)
        d = d * (f+1)                   ; 0..1
      else
        d = (d-0.5) * (f+1) - f/2 + 0.5
        ;d = d * (f+1) - f               ; 0..1
      endif
      d = Xform(d, @V)

    elseif (@ciliatype == 1)		; interpolated
      d1 = Xform(d, @V1)
      d = @fac*d
      d = d - floor(d)
      d2 = Xform(d, @V2)
      d = d1 + f*(d2-d1)       ; = d1*(1-f) + d2*f
      d = Xform(d, @V)

    elseif (@ciliatype == 2)		; sine waves
      float a1 = 2 * #pi * d
      float a2 = 2 * #pi * d * @fac
      if @type == "cos cos" || @type == "cos sin"
        d1 = (1 + cos(a1)) / 2
      else
        d1 = (1 + sin(a1)) / 2
      endif
      if @type == "cos cos" || @type == "sin cos"
        d2 = (1 + cos(a2)) / 2
      else
        d2 = (1 + sin(a2)) / 2
      endif
      d = d1 + f*(d2-d1)       ; = d1*(1-f) + d2*f
      d = Xform(d, @V)

    elseif (@ciliatype == 3)		; cells
      d = ((0.25-sqr(d-0.5)) * (0.25-sqr(f-0.5))) * 16
      d = Xform(d, @V)

    elseif (@ciliatype == 4)		; bricks
      d1 = Xform(d, @V)
      d2 = Xform(f, @V)
      if @version >= 250703
        d = combine2(d, f, @b_type)
      else
        if @Use == 0
          d = MyMath.Fmin(d1, d2)
        else
          d = MyMath.Fmax(d1, d2)
        endif
      endif

    elseif (@ciliatype == 5)		; diamonds
      d = 0.5 - abs(d - 0.5)  ; 0..0.5   hat shape
      float v = @vv   ; original v = 2/3
      if (f < v)
        d = d + f/(2*v)        ; 0..1
        ;d = abs(1-2*d)        ; optional, but smoother for one case
      else
        if (d < f/(2*v)-0.5)
          d = f*(2/v)-2-4*d
        else
          d = 1-(0.5-d)/(1-f/(2*v))
        endif
      endif
      d = Xform(d, @V)

    elseif (@ciliatype == 6)		; Simple
      if @version >= 250703
        d = combine2(d, f, @s_type2)
      else
        if @s_type == "d#1"
          ;
        elseif @s_type == "d#2"
          d = f
        elseif @s_type == "Arithmetic Average"
          d = (d + f) / 2
        elseif @s_type == "Geometric Average"
          d = sqrt(d * f)
        elseif @s_type == "Harmonic Average"
          d = 2 * d * f / (d + f)
        elseif @s_type == "Max"
          d = MyMath.fmax(d, f)
        elseif @s_type == "Min"
          d = MyMath.fmin(d, f)
        elseif @s_type == "Difference"
          d = abs(d - f)
        elseif @s_type == "Product"
          d = d * f
        endif
      endif
      d = Xform(d, @V)
    endif
    return d
  endfunc

  ; combine 2 floats, each in 0..1, keep answer in 0..1
  float func combine2(float d, float f, int type)
    if type == 0          ; "First"
      return d
    elseif type == 1      ; "Second"
      return f
    elseif type == 2      ; "Arithmetic Average"
      return (d + f) / 2
    elseif type == 3      ; "Geometric Average"
      return sqrt(d * f)
    elseif type == 4      ; "Harmonic Average"
      return 2 * d * f / (d + f)
    elseif type == 5      ; "Larger"
      return MyMath.fmax(d, f)
    elseif type == 6      ; "Smaller"
      return MyMath.fmin(d, f)
    elseif type == 7      ; "Sum"
      return MyMath.fmin(d+f, 1.0)
    elseif type == 8      ; "Difference"
      return abs(d - f)
    elseif type == 9     ; "Product"
      return d * f
    else;if type == 10   ; "Hypotenuse"
      return sqrt( (d*d+f*f)/2 )
    endif
  endfunc

  float func fixup(float d)
    if @bigZ == "No"
      return -1
    elseif @bigZ == "Floor"
      return d - floor(d)
    else
      return abs(d) - floor(abs(d))
    endif
  endfunc

  float func Xform(float d, int v)
    if v == 1
      d = 1 - d
    elseif v == 2
      d = abs(1-2*d)
    elseif v == 3
      d = 1 - abs(1-2*d)
    endif
    return d
  endfunc

  ; Go returns a value in 0..1
  float func Go(complex zz, complex z0, int t, int i)
    ; zz is the latest, z0 could be a previous one,
    ; but for now they are the same
    ; t is the type, i is 1 or 2
    float v = -1
    if t == 0                     ; "LogLog"
      v = real(il*(lp - log(log(cabs(zz)))))	; fractional iteration
    elseif t == 1                 ; "Log"
      v = log(@Top/cabs(zz))
    elseif t == 2                ; "Angle"
      v = atan2(zz)/(2*#pi)
      if (v <= 0)
        v = v + 1
      endif        ; v in 0..1
    elseif t == 3                ; "Distance"
      if i == 1
        v =  m_SD1.Iterate(zz)
      else
        v =  m_SD2.Iterate(zz)
      endif
    else                         ; "Grid" or "Concentric"
      if i == 1
        v = m_D1.Iterate(zz)
      else
        v = m_D2.Iterate(zz)
      endif
    endif
    if v == 0, v = 1, endif      ; 0 not allowed
    return v
  endfunc


protected:
  float il
  float lp
  ; complex z1, complex z2, complex z3
  SD m_SD1
  SD m_SD2
  Distance m_D1
  Distance m_D2

default:
  title = "Cilia +/-"
  rating = Recommended
	int param version
		caption = "Version"
		default = 250703
		visible = @version < 250703
	endparam
  heading
    text = "(current is 250703.}"
		visible = @version < 250703
  endheading

  float param pow
    caption = "Exponent"
    default = 2
    ;min = 1.01
    visible = @t1 == 0 || @t2 == 0
  endparam
  float param Top
    caption = "Top"
    default = 100
    min = 1
    visible = @t1 <= 1 || @t2 <= 1
  endparam
  param bigz
    caption = "Use cabs(z)>Top?"
    enum = "No" "Floor" "Ceiling"
    default = 0
    visible = @t1 <= 1 || @t2 <= 1
  endparam

  bool param switch
    caption = "Switch first and second?"
    default = false
    visible = @version >= 250703
  endparam
  param t1
    caption = "First"
    enum = "LogLog" "Log" "Angle" "Distance" "Grid" "Concentric"
    default = 0
  endparam
  SD param d_SD1
    caption = "First"
    default = JLB_D02
    visible = @t1 == 3
  endparam
  Distance param fd1
    ;caption = "First"
    default = JLB_DGridS
    visible = @t1 == 4
    selectable = false
  endparam
  Distance param gd1
    ;caption = "First"
    default = JLB_DConcentric
    visible = @t1 == 5
    selectable = false
  endparam
  param t2
    caption = "Second"
    enum = "LogLog" "Log" "Angle" "Distance" "Grid" "Concentric"
    default = 2
  endparam
  SD param d_SD2
    caption = "Second"
    default = JLB_D03
    visible = @t2 == 3
  endparam
  Distance param fd2
    caption = "Second"
    default = JLB_DGridS
    visible = @t2 == 4
    selectable = false
  endparam
  Distance param gd2
    ;caption = "Second"
    default = JLB_DConcentric
    visible = @t2 == 5
    selectable = false
  endparam

  float param divisor1
    caption = "Divisor 1"
    default = 1
    min = 1e-6
    visible = @t1 == 3 && (@d_SD1 == JLB_D00 || @d_SD1 == JLB_D01)
  endparam
  float param divisor2
    caption = "Divisor 2"
    default = 1
    min = 1e-6
    visible = @t1 == 3 && (@d_SD2 == JLB_D00 || @d_SD2 == JLB_D01)
  endparam

  param ciliatype
    caption = "Cilia Type"
    default = 4
    enum = "Sawtooth" "Interpolated" "Sine waves" "Cells"  \
           "Bricks" "Diamonds" "Simple"
    hint = "This is the function used to generate the \
            cilia pieces.  Each has a different 'flavor'."
  endparam

  ; Interpolated
  param V1
    caption = "First"
    enum = "V 0" "V 1" "V 2" "V 3"
    default = 2
    visible = @ciliatype == 1
  endparam
  param V2
    caption = "Second"
    enum = "V 0" "V 1" "V 2" "V 3"
    default = 2
    visible = @ciliatype == 1
  endparam
  ; Interpolated or Sine waves
  float param fac            ; fac = 2 is sometimes smoother
    caption = "Multiplier"
    default = 2
    ;min = 1
    visible = @ciliatype == 1 || @ciliatype == 2
  endparam
  ; Sine waves
  param type
    caption = "Cos or Sin"
    enum = "cos cos" "cos sin" "sin cos" "sin sin"
    default = 0
    visible = @ciliatype == 2
  endparam
  ; Bricks
  param Use
    caption = "Use"
    default = 0
    enum = "Smaller d" "Larger d"
    visible = @ciliatype == 4 && @version < 250703
  endparam
  param b_type
    caption = "Combine"
    default = 7
    enum = "First d" "Second d" \
           "Larger" "Smaller" "Sum" "Difference" "Product" \
           "Arithmetic Average" "Geometric Average" "Harmonic Average"
    visible = @ciliatype == 4 && @version >= 250703
  endparam

  ; Diamonds
  float param vv
    caption = "Parameter"
    default = 1
    min = 0
    max = 1
    visible = @ciliatype == 5
  endparam
  ; Simple
  param s_type
    caption = "Combine"
    enum = "d#1" "d#2" "Arithmetic Average" "Geometric Average" \
           "Harmonic Average" "Max" "Min" \
           "Difference" "Product"
    default = 2
    visible = @ciliatype == 6 && @version < 250703
  endparam
  param s_type2
    caption = "Combine"
    enum = "First d" "Second d" \
           "Arithmetic Average" "Geometric Average" "Harmonic Average" \
           "Larger" "Smaller" "Sum" "Difference" "Product"
    default = 2
    visible = @ciliatype == 6 && @version >= 250703
  endparam

  float param skew
    caption = "Cilia Skew"
    default = 0.0
  endparam

  param V
    caption = "Final"
    enum = "V 0" "V 1" "V 2" "V 3"
    default = 0
  endparam
}

class JLB_DfBM(Distance) {                            ; 240915
; this is a re-writing of, and a combination of,
; the versions in dmj.ucl and in mt.ucl
; New 240715; 240915 changed FT plug-in to UserTransform plug-in
public:
  import "common.ulb"

  func JLB_DfBM(Generic pparent)
    Distance(pparent)
    rot  = (0,1) ^ (@angle / 90.0)
    drot = (0,1) ^ (@astep / 90.0)
    ; half ranges from 4 (2^2) to 8192 (2^13)
    half  = round(2.0 ^ (2 + 0.11 * @spread))
    whole = 2 * half
    if @version < 240915
      m = new @T(this)
    elseif @useT
      m_t = new @f_UT(this)
    endif
    if @screen_center, ctr = #center, else, ctr = @center, endif
  endfunc

  func Init(complex zz)
    sum = 0
  endfunc

  float func Iterate(complex zz)

    float decay = exp(-|zz|/sqr(@fade))
    complex v = zz - ctr
    if @version < 240915
      v =   m.Iterate(v)
    elseif @useT
      v = m_t.Iterate(v)
    endif
    v = v * @scale * rot
    float freq = 1.0
    int i = @octaves
    while (i > 0)
      float d = fbm(v)
      sum = sum + d * freq * decay
      freq = freq * @step
      v = v * drot / @step
      i = i - 1
    endwhile
    return abs(sum)       ; abs not in dmj, but needed
  endfunc

  float func fbm(complex v)
    ; determine integer coordinate for corners of square
    ; surrounding v
    float bx0 = floor(real(v)) % half
    float by0 = floor(imag(v)) % half
    if (bx0 < 0), bx0 = bx0 + half, endif
    if (by0 < 0), by0 = by0 + half, endif
    float bx1 = (bx0 + 1) % half
    float by1 = (by0 + 1) % half

    float rx0 = real(v) - floor(real(v))
    float ry0 = imag(v) - floor(imag(v))
    float rx1 = rx0 - 1
    float ry1 = ry0 - 1

    ; create a "random" index for each corner
    ; Notes from dmj
    ; (this is where Intel's version differs from Perlin's;
    ; I used Intel's version because it doesn't require a
    ; pre-computed random table, which is difficult to manage
    ; in UF.)
    if @type == "dmj"
      float b00 = (bx0^@p % 65536 + by0)^@p % 65536
      float b10 = (bx1^@p % 65536 + by0)^@p % 65536
      float b01 = (bx0^@p % 65536 + by1)^@p % 65536
      float b11 = (bx1^@p % 65536 + by1)^@p % 65536

      ; produce a "random" vector for each corner
      float g_b00_0 = (b00  )^@p*0.25 % whole - half
      float g_b10_0 = (b10  )^@p*0.25 % whole - half
      float g_b01_0 = (b01  )^@p*0.25 % whole - half
      float g_b11_0 = (b11  )^@p*0.25 % whole - half
      float g_b00_1 = (b00+1)^@p*0.25 % whole - half
      float g_b10_1 = (b10+1)^@p*0.25 % whole - half
      float g_b01_1 = (b01+1)^@p*0.25 % whole - half
      float g_b11_1 = (b11+1)^@p*0.25 % whole - half
    else    ; mt's version
      float b00 = (bx0^@p * 2473 % 65536 + by0)^@p % 65536
      float b01 = (bx0^@p * 2473 % 65536 + by1)^@p % 65536
      float b10 = (bx1^@p * 2473 % 65536 + by0)^@p % 65536
      float b11 = (bx1^@p * 2473 % 65536 + by1)^@p % 65536

      float g_b00_0 = b00^@p * 5381 % 65536 / 4 % whole - half
      float g_b01_0 = b01^@p * 5381 % 65536 / 4 % whole - half
      float g_b10_0 = b10^@p * 5381 % 65536 / 4 % whole - half
      float g_b11_0 = b11^@p * 5381 % 65536 / 4 % whole - half
      float g_b00_1 = (b00 + 1)^@p * 79997 % 65536 / 4 % whole - half
      float g_b01_1 = (b01 + 1)^@p * 79997 % 65536 / 4 % whole - half
      float g_b10_1 = (b10 + 1)^@p * 79997 % 65536 / 4 % whole - half
      float g_b11_1 = (b11 + 1)^@p * 79997 % 65536 / 4 % whole - half
    endif

    ; normalize each vector
    float d
    d = 1 / sqrt(sqr(g_b00_0) + sqr(g_b00_1))
    g_b00_0 = g_b00_0 * d
    g_b00_1 = g_b00_1 * d
    d = 1 / sqrt(sqr(g_b10_0) + sqr(g_b10_1))
    g_b10_0 = g_b10_0 * d
    g_b10_1 = g_b10_1 * d
    d = 1 / sqrt(sqr(g_b01_0) + sqr(g_b01_1))
    g_b01_0 = g_b01_0 * d
    g_b01_1 = g_b01_1 * d
    d = 1 / sqrt(sqr(g_b11_0) + sqr(g_b11_1))
    g_b11_0 = g_b11_0 * d
    g_b11_1 = g_b11_1 * d

    ; produce colors for each corner
    float u1 = rx0 * g_b00_0 + ry0 * g_b00_1
    float v1 = rx1 * g_b10_0 + ry0 * g_b10_1
    float u2 = rx0 * g_b01_0 + ry1 * g_b01_1
    float v2 = rx1 * g_b11_0 + ry1 * g_b11_1

    ; interpolate between corners using bilinear filtering
    float sx = sqr(rx0) * (3 - rx0*2)
    float sy = sqr(ry0) * (3 - ry0*2)
    float a = u1 + sx*(v1-u1)
    float b = u2 + sx*(v2-u2)
    return a + sy*(b-a)
  endfunc

private:
  complex rot
  complex drot
  float sum
  int half
  int whole
  FT m
  UserTransform m_t
  complex ctr

default:
  title = "Fractional Brownian Motion"
  rating = Recommended

	int param version
		caption = "Version"
		default = 240915
		visible = @version < 240915
	endparam
  heading
    text = "(current is 240915.}"
		visible = @version < 240915
  endheading

  FT param T
    caption = "Function"
    default = JLB_00ident
    visible = @version < 240915
  endparam
  bool param useT
    caption = "Use transform?"
    default = false
    visible = @version >= 240915
  endparam
  UserTransform param f_UT
    caption = "Transform f"
    default = JLB_UT_OneFunction
    visible = @version >= 240915 && @useT
  endparam

  bool param screen_center
    caption = "Use screen center?"
    default = true
  endparam
  complex param center
    caption = "Center"
    default = (0,0)
    visible = !@screen_center
  endparam
  float param scale
    caption = "Scale"
    default = 1.0
  endparam
  float param angle
    caption = "Rotation"
    default = 0.0
  endparam
  heading
  endheading

  param type
    caption = "Noise type"
    enum = "dmj" "mt"
    default = 0
  endparam
  float param spread
    caption = "Spread (0..100)"
    min = 0
    max = 100
    default = 50
  endparam
  float param p
    caption = "Noise power"
    default = 2.0
  endparam
  float param fade
    caption = "Fade radius"
    default = 16.0
  endparam
;   heading
;   endheading

  int param octaves
    caption = "# of steps"
    default = 1
    min = 1
  endparam

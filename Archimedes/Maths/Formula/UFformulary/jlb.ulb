class JLB_CD113(CD1) {
public:
  float func Iterate(complex zz)
    float d = c2^3 + a*(3*x^4 - 6*x2*y2 - 5*y^4) + 8*a^2*y2 - 4*a^3
    if m_scale, d = d/c4/c2, endif
    return d
  endfunc
default:

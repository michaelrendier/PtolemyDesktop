cubic1 { ; jam 010522

  init:
  if ( @plottype == 0 )
    z = @perturbation, jc = #pixel
  else
    z = #pixel, jc = @jconstant
  endif

  loop:
  complex z2 = z*z
  z = ( @coeff3 * z2*z ) + ( @coeff2 * (z2) ) + ( @coeff1 * z ) + ( @coeff0 ) + jc

  bailout:
  |z| < @bail

  default:
  title = "GenCubic 1"
  center = (0,0)
  maxiter = 200
  method = multipass
  periodicity = 0


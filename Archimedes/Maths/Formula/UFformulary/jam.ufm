  elseif  @formula1 == 51
    zf1 = 1 / ( z * z * z )
  elseif  @formula1 == 52
    zf1 = atan( 1 / z )
  elseif  @formula1 == 53
    zf1 = acos( 1 / z )
  elseif  @formula1 == 54
    zf1 = asin( 1 / z )
  elseif  @formula1 == 55
    zf1 = tan( z ) / z
  elseif  @formula1 == 56

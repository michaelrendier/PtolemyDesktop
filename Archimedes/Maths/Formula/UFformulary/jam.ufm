      elseif  @formula2 == 84
        #z = sinh(1/#z)
      elseif  @formula2 == 85
        #z = cosh(1/#z)
      elseif  @formula2 == 86
        #z = tanh(1/#z)
      elseif  @formula2 == 87
        #z = cotanh(1/#z)
      elseif  @formula2 == 88
        #z = (1,0)/cosh(1/#z)
      elseif  @formula2 == 89
        #z = (1,0)/sinh(1/#z)
      else ;  @formula2 == 90
        #z = sin( #z ) * tan(#z)
      endif ; formula2-2
    else ; 90 < @formula2 <= 120
      if  @formula2 == 91
        #z = sinh(#z) * tanh(#z)
      elseif  @formula2 == 92
        #z = sinh(#z) * cosh(#z)
      elseif  @formula2 == 93
        temp2 = sinh(#z), zextra = cosh(#z)
        #z = temp2*temp2*zextra*zextra
      elseif  @formula2 == 94
        temp2 = sin(#z), zextra = cos(#z)
        #z = temp2*temp2*zextra*zextra
      elseif  @formula2 == 95
        zextra = 1/#z
        #z = sin(zextra)*cos(zextra)

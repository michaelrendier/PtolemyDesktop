Bessel0 { ; Order 0 Bessell function of the 1st kind, J0(z)
  ; jam 010612

  global:
  complex c4 = 1/64, complex c6 = -1/2304, complex c8 = 1/147456
  complex c10 = -1/14745600, complex c12 = 1/2123366400
  complex c14 = -1/4.16179814400E11, complex c16 = 1/1.06542032486400E14

  init:
  if ( @plottype == 0 )
    z = @perturbation, jc = #pixel
  else
    z = #pixel, jc = @jconstant
  endif
  complex zblend = (0,0)

  loop:
  zblend = z
  complex z2 = z*z, complex z4 = z2*z2, complex z6 = z4*z2, complex z8 = z6*z2
  complex z10 = z8*z2, complex z12 = z10*z2, complex z14 = z12*z2, complex z16 = z14*z2
  z = 1 - 0.25*z2 + c4*z4 + c6*z6 + c8*z8 + c10*z10 + c12*z12 + c14*z14 + c16*z16
  if @blend
    z = @weightzfn * z + @weightzpwr * zblend^@zpower
  endif ; @blend
  z = z + jc

  bailout:
  |z| < @bail

  default:
  title = "Bessell 0 Order"
  center = (0,0)
  maxiter = 200
  method = multipass
  periodicity = 0
  magn = 0.5

  param blend
    caption = "Blend Z^Power?"
    default = FALSE
    hint = "If enabled, the iterated function can be blended into a normal \
          z^power Mandelbrot function; set parameter 'Z Power' to fix exponent, \
          and 'Z Weight' and 'Function Weight' to fix blend proportions"
  endparam
  param weightzfn
    caption = "Function Weight"
    default = -0.1
    hint = "If 'Blend Z^Power' is enabled, then this is the fraction of the \
          function that is blended in with the normal z^power Mandelbrot"
    visible = @blend == TRUE
  endparam
  param weightzpwr
    caption = "Z^Power Weight"
    default = 1.0
    hint = "If 'Blend Z^Power' is enabled, then this is the fraction of the \
          normal z^power Mandelbrot that is blended in with the function"
    visible = @blend == TRUE
  endparam

        elseif  @formula1 == 17
          #z = cosh( #z )
        elseif  @formula1 == 18
          #z = tanh( #z )
        elseif  @formula1 == 19
          #z = asinh( #z )
        elseif @formula1 == 20
          #z = acosh( #z )
        elseif  @formula1 == 21
          #z = atanh( #z )
        elseif  @formula1 == 22
          #z = log( 1/#z )
        elseif  @formula1 == 23
          #z = log( log( #z ))
        elseif  @formula1 == 24
          #z = exp( -#z )
        elseif  @formula1 == 25
          #z = exp( 1/#z )
        elseif  @formula1 == 26
          #z = #z^(-#z)
        elseif  @formula1 == 27
          zextra = sin( #z )
          #z = zextra * zextra
        elseif  @formula1 == 28
          zextra = cos( #z )
          #z = zextra * zextra
        elseif  @formula1 == 29
          zextra = tan( #z )
          #z = zextra * zextra
        else ;  @formula1 == 30

    endif ; @pixelformula = 1
  endif ; @pixelformula != 0

  loop:
  if @pmode != 0
    z = z + jc
  endif ; pmode

  zblend = z

  iterations = iterations + 1

  if @formula1 == 0
    zf1 = z * z
  elseif  @formula1 == 1
    zf1 = z * z * z
  elseif  @formula1 == 2

  loop:
  iter = iter + 1
  if iter > @skipped
    ; Center z at the graph offset, and rotate if appropriate
    ztemp = (z - center) * exp( flip( rotation))

    ; Find point on exp(-x) graph trapped by ztemp
    tempx = scale * real( ztemp ), tempy = exp( -tempx )
    ztemp = tempx + flip( tempy )

    ; Now combine z according to mode with trapped point on graph, and iterate

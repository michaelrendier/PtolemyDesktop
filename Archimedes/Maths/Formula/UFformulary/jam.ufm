cubic3 { ; jam 010522

  init:
  if ( @plottype == 0 )
    z = @perturbation, jc = #pixel
  else
    z = #pixel, jc = @jconstant
  endif

  loop:
  complex zsum = z+jc, complex zsumsq = zsum*zsum
  z = ( @coeff3 * zsumsq*zsum ) + ( @coeff2 * zsumsq ) + ( @coeff1 * zsum ) + ( @coeff0 ) + jc

  bailout:
  |z| < @bail

  default:

z2sinmanX5power+-J { ; simple sine function Mandelbrot study
  ; jam 010525

  init:
  if ( @plottype == 0 )
    z = @perturbation, jc = #pixel
  else
    z = #pixel, jc = @jconstant
  endif

  loop:
  complex z2 = z*z, complex z3 = z2*z, complex z4 = z3*z, complex z5 = z4*z
  z = z2*sin(z+jc)*sin(2*(z2+jc))*sin(3*(z3+jc))*sin(4*(z4+jc))*sin(5*(z5+jc)) + jc

  bailout:
  |z| < @bail

  default:
  title = "zSinmanX5Power+ Julia"
  center = (0,0)
  maxiter = 200
  method = multipass
  periodicity = 0

  param plottype
    caption = "Plotting Method"
    enum = "Mandelbrot" "Julia"
    default = 1
    hint = "Select type of initialization for z, c"
  endparam
  param perturbation
    caption = "Initial Perturbation"
    default = (0,0)
    hint = "Iteration starting value"
  endparam
  param jconstant
    caption = "Julia Constant"
    default = (0,0)
    hint = "Iteration constant"
  endparam
  param bail
    caption = "Bailout Value"
    default = 64.0
    hint = "Value needed to 'escape' to infinity"
  endparam

  switch:
  type = "z2sinmanX5power+"
  perturbation = #pixel
  bail = bail
}


m4m4m4m2m2 { ; Aternates 3 rounds quartic with 2 quadratic Mandelbrot iterations.
  ; jam 010507

  init:
  if ( @plottype == 0 )
    z = @perturbation, jc = #pixel
  else
    z = #pixel, jc = @jconstant
  endif
  int iterations = 0

  loop:
  iterations = iterations + 1
  int remainder = iterations % 5
  if ( remainder == 0 ) || ( remainder == 4 )
    z = z*z + jc
  else
    z = z*z*z*z + jc
  endif

  bailout:
  |z| < @bail

  default:
  title = "Alt Quartic3/Quadratic2 Mandelbrot"
  center = (0,0)
  maxiter = 500
  method = multipass
  periodicity = 0

  param plottype
    caption = "Plotting Method"
    enum = "Mandelbrot" "Julia"
    default = 0

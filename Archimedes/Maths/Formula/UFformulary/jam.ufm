m2m4m4m4tanh { ; jam 010520

  init:
  if ( @plottype == 0 )
    z = @perturbation, jc = #pixel
  else
    z = #pixel, jc = @jconstant
  endif
  int iterations = 0

  loop:
  z2 = z*z
  iterations = iterations + 1
  int remainder = iterations % 5
  if ( remainder == 1 )
    z = z2 + jc
  elseif ( remainder == 0 )
    z = z2*tanh( z2 + jc ) + jc
  else
    z = z2*z2 + jc
  endif

  bailout:
  |z| < @bail

  default:
  title = "Alt Quad/Quart/Tanh Mandelbrot"
  center = (0,0)

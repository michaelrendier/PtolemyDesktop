      elseif  @formula1 == 88
        #z = (1,0)/cosh(1/#z)
      elseif  @formula1 == 89
        #z = (1,0)/sinh(1/#z)
      else ;  @formula1 == 90
        #z = sin( #z ) * tan(#z)
      endif ; formula1-2
    else ; 90 < @formula1 <= 120
      if  @formula1 == 91
        #z = sinh(#z) * tanh(#z)
      elseif  @formula1 == 92
        #z = sinh(#z) * cosh(#z)
      elseif  @formula1 == 93
        temp2 = sinh(#z), zextra = cosh(#z)

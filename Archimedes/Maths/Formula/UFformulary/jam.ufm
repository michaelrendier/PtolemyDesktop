    caption = "Julia Constant"
    default = (0,0)
    hint = "Iteration constant"
  endparam
  param bail
    caption = "Bailout Value"
    default = 100.0
    hint = "Value needed to 'escape' to infinity"
  endparam
  param plottype
    caption = "Plotting Method"
    enum = "Mandelbrot" "Julia"
    default = 1
    hint = "Select type of initialization for z, c"
  endparam

  switch:
  type = "Laguerre7"
  perturbation = #pixel
  bail = bail
  blend = blend
  weightzfn = weightzfn
  weightzpwr = weightzpwr
  zpower = zpower
}

Laguerre8 { ; 8th order Laguerre polynomial
  ; jam 010707

  global:
  complex coeff = 1/40320

  init:
  if ( @plottype == 0 )
    z = @perturbation, jc = #pixel
  else
    z = #pixel, jc = @jconstant
  endif
  complex zblend = (0,0)

  loop:
  zblend = z
  z = coeff * ( z* (z* (z* (z* (z* (z* (z* (z - 64 ) + 1568 ) - 18816 ) + 117600 ) - 376320 ) + 564480 ) - 322560 ) + 40320 )
  if @blend
    z = @weightzfn * z + @weightzpwr * zblend^@zpower
  endif ; @blend
  z = z + jc


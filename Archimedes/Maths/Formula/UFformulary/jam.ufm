  ; jam 010507

  init:
  if ( @plottype == 0 )
    z = @perturbation, jc = #pixel
  else
    z = #pixel, jc = @jconstant
  endif
  int iterations = 0

  loop:
  iterations = iterations + 1
  int remainder = iterations % 3
  if ( remainder == 1 )
    z = z*z*z*z + jc
  elseif ( remainder == 2 )
    z = z*z + jc
  else
    z = sin(z) + jc

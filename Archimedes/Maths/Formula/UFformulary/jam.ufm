altXm2m3m1/3 { ; jam 010520

  init:
  if ( @plottype == 0 )
    z = @perturbation, jc = #pixel
  else
    z = #pixel, jc = @jconstant
  endif
  int iterations = 0
  float power = 1/3

  loop:
  iterations = iterations + 1
  int remainder1 = iterations % 3
  int remainder2 = iterations % 6
  if ( remainder2 == 0 )
    z = z*z*z + jc
  else
    z = z*z + jc
  endif
  if ( remainder1 == 0 )
    complex z = z^power + jc
  endif

  bailout:
  |z| < @bail

  default:
  title = "SpecialAltX Z2Z3Z1/3 Mandelbrot"

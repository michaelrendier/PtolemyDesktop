jam-bernoulli2 { ; jam 010706
  ; second order Bernoulli polynomial

  global:
  float sixth = 1/6

  init:
  if ( @plottype == 0 )
    z = @perturbation, jc = #pixel
  else
    z = #pixel, jc = @jconstant
  endif
  complex zblend = (0,0)

  loop:
  zblend = z
  z = sixth - z + z*z
  if @blend
    z = @weightzfn * z + @weightzpwr * zblend^@zpower
  endif ; @blend
  z = z + jc

  bailout:
  |z| < @bail


      endif ; formula1-2
    else ; 90 < @formula1 <= 120
      if  @formula1 == 91
        #z = sinh(#z) * tanh(#z)
      elseif  @formula1 == 92
        #z = sinh(#z) * cosh(#z)
      elseif  @formula1 == 93
        temp2 = sinh(#z), zextra = cosh(#z)

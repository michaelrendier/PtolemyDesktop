  if ( @plottype == 0 )
    z = @perturbation, jc = #pixel
  else
    z = #pixel, jc = @jconstant
  endif

  loop:
  complex zsum = z+jc, complex zsumsq = zsum*zsum, complex zsum3 = zsum*zsumsq
  complex zsum4 = zsum*zsum3, complex zsum5 = zsum4*zsum
  z = ( @coeff6 * (zsum5*zsum) ) + ( @coeff5 * zsum5 ) + ( @coeff4 * zsum4 ) + ( @coeff3 * zsum3 ) + ( @coeff2 * zsumsq ) + ( @coeff1 * zsum ) + ( @coeff0 ) + jc


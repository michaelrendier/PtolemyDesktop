  loop:
  complex z2 = z*z
  complex z3 = z*z2
  complex z5 = z2*z3
  complex z6 = z3*z3
  iterations = iterations + 1
  int remainder1 = iterations % 3
  int remainder2 = iterations % 5
  int remainder3 = iterations % 6
  complex zr0 = z2 + jc
  if ( remainder1 == 0 )
    complex zr1 = z3 + jc
  else
    complex zr1 = 1
  endif
  if ( remainder2 == 0 )
    complex zr2 = z5 + jc
  else
    complex zr2 = 1
  endif
  if ( remainder3 == 0 )
    complex zr3 = z6 + jc
  else
    complex zr3 = 1
  endif

  z = zr0*zr1*zr2*zr3 + jc

  bailout:
  |z| < @bail


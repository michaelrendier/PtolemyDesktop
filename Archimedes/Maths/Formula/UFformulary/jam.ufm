        #z = @coeff1a * #z^@exponent1a + @coeff1b * #z^@exponent1b + @coeff1c * #z^@exponent1c
      elseif  @formula1 == 78
        zextra = sinh(#z)
        #z = zextra * zextra
      elseif  @formula1 == 79
        zextra = cosh( #z )

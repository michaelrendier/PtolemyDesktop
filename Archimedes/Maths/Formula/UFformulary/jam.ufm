sextic2 { ; jam 010524

  init:
  if ( @plottype == 0 )
    z = @perturbation, jc = #pixel
  else
    z = #pixel, jc = @jconstant
  endif

  loop:
  complex z2 = z*z, complex z3 = z2*z, complex z4 = z3*z, complex z5 = z4*z
  z = ( @coeff6 * (z5*z+jc) ) + ( @coeff5 * (z5+jc) ) + ( @coeff4 * (z4 + jc) ) + ( @coeff3 * (z3 + jc) ) + ( @coeff2 * (z2 + jc) ) + ( @coeff1 * (z+jc) ) + ( @coeff0 ) + jc

  bailout:

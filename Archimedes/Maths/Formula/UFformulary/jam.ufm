jam-bernoulli7-J { ; jam 010706
  ; seventh order Bernoulli polynomial

  global:
  float sixth = 1/6, float sevensixths = -7*sixth

  init:
  if ( @plottype == 0 )
    z = @perturbation, jc = #pixel
  else

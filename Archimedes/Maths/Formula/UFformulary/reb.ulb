		int elements = sqr(count)
		setLength(m_Offsets, elements)
		setLength(m_Weights, elements)
		m_Multiplier = 0.0

		int j = -@p_samples
		int k = 0
		int l = 0
		while (j <= @p_samples)
			k = -@p_samples
			while (k <= @p_samples)
				m_Offsets[l] = (@p_radius*j/@p_samples + flip(@p_radius*k/@p_samples))/100
        m_Weights[l] = 0
				l = l + 1
				k = k + 1
			endwhile
			j = j + 1
		endwhile
		m_Multiplier = 1
	endfunc
	
default:
	title = "Conservative Smoothing Filter"

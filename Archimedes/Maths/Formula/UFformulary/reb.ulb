    default = 30
  endparam
	float param scale2
	  caption = "Prescale"
	  default = 0.5
	endparam
	float param scale
	  caption = "Scale"
	  default = 0.2
	endparam
  float param T
    caption = "Bow thickness"
    default = 1
  endparam

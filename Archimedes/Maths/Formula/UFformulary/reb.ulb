 	    t = real(pz) * imag(pz)
 	  elseif @partype == "angle"
 	    t = atan2(pz)
 	  endif
 	  t = t*@scale
 	  float x = 5*@a*cos(t)*(8+5*cos(2*t)+3*cos(6*t))/(13+3*cos(4*t))
 	  float y = 20*@a*sin(t)^3*(7+6*cos(2*t)+3*cos(4*t))/(13+3*cos(4*t))
 	  m_LastZ = x + flip(y)

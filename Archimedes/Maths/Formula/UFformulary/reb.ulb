 	  if @partype == "cabs(z)"
 	    tz = cabs(pz)+rotangle
 	  elseif @partype == "real(z)"
 	    tz = real(pz)+rotangle
 	  elseif @partype == "imag(z)"
 	    tz = imag(pz)+rotangle
 	  elseif @partype == "real(z) + imag(z)"

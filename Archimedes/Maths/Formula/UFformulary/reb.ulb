 	  float rr = 0
     theta = atan2(pz)
    int sgn = 1
    if @sgn
      sgn = -1
    endif
     rr = 0.3*@a*tan(theta)/(cos(theta)*(1+tan(theta)^3))
     if !@ptraps
       if @absval
         d = abs(cabs(pz) - cabs(rr*cos(theta)+ sgn*flip(rr*sin(theta))))
       else

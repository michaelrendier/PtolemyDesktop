	  caption = "Precale"
	  default = 1.0
	endparam
	float param scale
	  caption = "Scale"
	  default = 0.2
	endparam
  float param ba
    caption = "param a"
    default = 0.5
  endparam
  float param bb
    caption = "param b"
    default = 1.5
  endparam

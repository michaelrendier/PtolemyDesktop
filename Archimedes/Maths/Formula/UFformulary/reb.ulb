	  enum = "Original" "Positive Z" "Cosine" "Rucker" "Reversed" "Reversed +Z"\
	         "Msltoe" "IQ" "Negative IQ" "XpYp3" "XpZp2" "XpYn1" "XnYp1" "XpYn3"\
                 "XnYp3" "XnYn3" "YpXp3" "YpXn2" "YnXp2" "YpXn3" "YnXp3" "YnXn3"\
                 "ZpXp3" "ZpXn2" "ZnXp2" "ZpXn3" "ZnXp3" "ZnXn3" "XpZn1" "XnZp1"\
                 "XpZn2" "XnZp2" "XnZn2" "YpZp2" "YpZn1" "YnZp1" "YpZn2" "YnZp2"\
                 "YnZn2" "ZnYp1" "ZnYn1" "ZnYp3" "Tad 20" "Tad 28" "Tad 29" "Tad 34"\
                 "Tad 50" "Tad 61" "Tad 84" "Tad 85" "Tad 86" "Tad 87" "Tad 52"\
                 "Tad 53" "Tad 93" "Tad 95" "Tad 98" "Tad 114" "Tad 116" "Tad 117"\

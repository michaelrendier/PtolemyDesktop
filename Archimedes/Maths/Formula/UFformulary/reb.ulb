Class REB_EmbossAtzemaSpiral(REB_EmbossFormula) {

public:
  import "common.ulb"

  ; constructor
  func REB_EmbossAtzemaSpiral(Generic pparent)
  endfunc

  complex func Init(complex pz)
    REB_EmbossFormula.Init(pz)
    return pz
  endfunc

  float func Iterate(complex pz,float &tz)
    tz=atan2(pz)+rotangle
    while tz <= 0
      tz = tz + 2*#pi
    endwhile
    float af1 = 0.5*@a*(sin(tz)/tz-2*cos(tz)-tz*sin(tz))
    float af2 = 0.05*@b*(cos(tz)/tz-2*sin(tz)+tz*cos(tz))
    complex as = (af1 + flip(af2))
    rz = cabs(as)
    return rz
  endfunc

default:
  title = "Atzema Spiral"
	int param v_AtzemaSpiral
		caption = "Version (Atzema Spiral)"

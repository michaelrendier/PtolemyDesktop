 		  ;

 		  t[20]=(pzs-v[16])/(v[11]-v[16])
 		  x=real(t[20])
 		  y=imag(t[20])
 		  if y > 0
 		    out = false
 		  endif
 		  if(x<0.0)
 		    r[20]=sqr(x)+sqr(y)
 		  elseif(x>1.0)
 		    r[20]=sqr(x-1.0)+sqr(y)
 		  else

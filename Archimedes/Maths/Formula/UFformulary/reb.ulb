}


Class REB_EmbossCurtateCycloid(REB_EmbossFormula) {

public:
  import "common.ulb"

  ; constructor
  func REB_EmbossCurtateCycloid(Generic pparent)
  endfunc

  complex func Init(complex pz)
    REB_EmbossFormula.Init(pz)
    return pz
  endfunc

  float func Iterate(complex pz,float &tz)
    tz=atan2(pz)+rotangle
    while tz <= 0
      tz = tz + 2*#pi
    endwhile
    complex af1 = @a*tz - 0.1*@b*@afn2(tz)
    complex af2 = @a - 0.1*@b*@afn1(tz)
    complex as = (af1 + flip(af2))
    rz = cabs(as)
    return rz
  endfunc


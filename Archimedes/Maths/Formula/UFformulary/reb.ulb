Class REB_EmbossInfiniteQuadrifolium(REB_EmbossFormula) {

public:
  import "common.ulb"

  ; constructor
  func REB_EmbossInfiniteQuadrifolium(Generic pparent)
  endfunc

  float func Iterate(complex pz,float &tz)
 	  if @partype == "cabs(z)"
 	    tz = cabs(pz)+rotangle
 	  elseif @partype == "real(z)"
 	    tz = real(pz)+rotangle
 	  elseif @partype == "imag(z)"
 	    tz = imag(pz)+rotangle
 	  elseif @partype == "real(z) + imag(z)"
 	    tz = real(pz) + imag(pz)+rotangle
 	  elseif @partype == "real(z) * imag(z)"
 	    tz = real(pz) * imag(pz)+rotangle
 	  elseif @partype == "angle"
 	    tz =  atan2(pz)+rotangle
      while tz <= 0
        tz = tz + 2*#pi
      endwhile
 	  endif
 	  tz = tz*@scale*6.28
 	  float x = 2*@a*(tz^3-tz)*(tz-1)/(tz^3+1)^2
 	  float y = 2*@a*(tz^3-tz)*(tz+1)/(tz^3+1)^2
 	  rz = cabs(x + flip(y))
    return rz
  endfunc

default:
  title = "Infinite Quadrifolium"
	int param v_InfiniteQuadrifolium

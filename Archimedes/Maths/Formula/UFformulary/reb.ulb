          y.m_elements[k] = (cos(2*#pi*(u-v/3+2/3))*cos(2*#pi*(-u-v/3+2/3))*cos(2*#pi*(-u-v+1)))*scale
          z.m_elements[k] = (cos(2*#pi*(u-v/3-2/3))*cos(2*#pi*(-u-v/3-2/3))*cos(2*#pi*(-u+v+1)))*scale

  ;
  ; Y axis rotation
  ;
          temp = x.m_elements[k] + flip(z.m_elements[k])

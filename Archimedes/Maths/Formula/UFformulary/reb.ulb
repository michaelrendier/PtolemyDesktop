          x.m_elements[k] = (@da*cos(u)*sin(v))*scale
          y.m_elements[k] = (@da*sin(u)*sin(v))*scale
          z.m_elements[k] = (@da*(cos(v)+log(tan((v/2))))+@db*u)*scale

  ;
  ; Y axis rotation
  ;
          temp = x.m_elements[k] + flip(z.m_elements[k])
          temp = temp*yrot
          x.m_elements[k] = real(temp)
          z.m_elements[k] = imag(temp)
  ;
  ; X axis rotation
  ;
          temp = y.m_elements[k] + flip(z.m_elements[k])
          temp = temp*xrot
          y.m_elements[k] = real(temp)
          z.m_elements[k] = imag(temp)

          if z.m_elements[k] < zmin
            zmin = z.m_elements[k]
          endif
          if z.m_elements[k] > zmax
            zmax = z.m_elements[k]
          endif
          k = k + 1
          j = j + 1
        endwhile
        i = i + 1
        j = 0
      endwhile
        l = l + 1
        i = 0
        j = 0
    endwhile
 	endfunc


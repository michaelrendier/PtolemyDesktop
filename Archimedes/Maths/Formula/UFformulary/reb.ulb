  endparam
  float param power
    caption = "Ikenaga Mandel Power"
    default = 8
  endparam
	param flagtype
	  caption = "Bulb types"
	  enum = "Original" "Positive Z" "Cosine" "Rucker" "Reversed" "Reversed +Z"\
	         "Msltoe" "IQ" "Negative IQ" "XpYp3" "XpZp2" "XpYn1" "XnYp1" "XpYn3"\
                 "XnYp3" "XnYn3" "YpXp3" "YpXn2" "YnXp2" "YpXn3" "YnXp3" "YnXn3"\

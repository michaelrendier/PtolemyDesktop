			 elseif @tz == "angle pz"
			   d = sqrt((real(pz)-x)^2 + (imag(pz)-y)^2 +(@sz*atan2(pz)-z)^2)*@scale
			 endif
     endif
     m_lastZ = x + flip(y)
     return d
 	endfunc


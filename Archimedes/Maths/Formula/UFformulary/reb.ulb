public:
  import "common.ulb"

  ; constructor
  func REB_EmbossCardioidInvolute(Generic pparent)
  endfunc

  float func Iterate(complex pz,float &tz)
 	  if @partype == "cabs(z)"
 	    tz = cabs(pz)+rotangle
 	  elseif @partype == "real(z)"
 	    tz = real(pz)+rotangle
 	  elseif @partype == "imag(z)"
 	    tz = imag(pz)+rotangle
 	  elseif @partype == "real(z) + imag(z)"
 	    tz = real(pz) + imag(pz)+rotangle
 	  elseif @partype == "real(z) * imag(z)"
 	    tz = real(pz) * imag(pz)+rotangle
 	  elseif @partype == "angle"
 	    tz =  atan2(pz)+rotangle
      while tz <= 0
        tz = tz + 2*#pi

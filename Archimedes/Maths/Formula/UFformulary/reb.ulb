     endif
     endif
    if @v_ducksswitch <= 101
      pz = @fn2((log(pz^m_power)+m_c)^@pow)
    else
     if @fna2 == "sin"
       pz = sin((log(pz^m_power)+m_c)^@pow)
     elseif @fna2 == "cosec"
       pz = 1/sin((log(pz^m_power)+m_c)^@pow)
     elseif @fna2 == "sinc"
       if cabs((log(pz^m_power)+m_c)^@pow) != 0
         pz = sin((log(pz^m_power)+m_c)^@pow)/(log(pz^m_power)+m_c)^@pow
       else
         pz = (log(1)+m_c)^@pow
       endif
     elseif @fna2 == "haversin"
       pz = (1-cos((log(pz^m_power)+m_c)^@pow))/2
     elseif @fna2 == "versin"
       pz = 1-cos((log(pz^m_power)+m_c)^@pow)
     elseif @fna2 == "sinh"
       pz = sinh((log(pz^m_power)+m_c)^@pow)

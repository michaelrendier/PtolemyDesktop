          x.m_elements[k] = cos(u)* sin(2*v)*scale
          y.m_elements[k] = sin(u)* sin(2*v)*scale
          z.m_elements[k] = sin(v)*scale

  ;
  ; Y axis rotation
  ;
          temp = x.m_elements[k] + flip(z.m_elements[k])
          temp = temp*yrot
          x.m_elements[k] = real(temp)
          z.m_elements[k] = imag(temp)
  ;

    CtoV(zrid,zjkd,ind)
    MD.Sexp(in, out)
    MD.Smult(@quadcor,@altel,cin,out,in,@pfactor,@flagtype)
    MD.Smult(@quadcor,@altel,in,ind,out,@pfactor,@flagtype)

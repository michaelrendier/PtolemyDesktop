               zjk = flip(ucamj) + ck2
             elseif fourth2 == 1
               zri = ucamj + flip(ck2)
               zjk = ucamr + flip(ucami)
             elseif fourth2 == 0
               zri = flip(ucamj) + ck2
               zjk = ucamr + flip(ucami)

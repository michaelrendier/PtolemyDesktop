    caption = "j-k plane"
    default = (0.0,0.0)
  endparam
  param fourth
    caption = "4th Dimension"
    default = 3
    enum = "zr" "zi" "zj" "zk"
  endparam
  float param ck
    caption = "4th Dimension Value"
    default = 0.0
  endparam
}



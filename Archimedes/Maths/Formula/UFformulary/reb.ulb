  endfunc

  complex func Init(complex pz)
    REB_EmbossFormula.Init(pz)
    return pz
  endfunc

  float func Iterate(complex pz,float &tz)
    tz=atan2(pz)+rotangle
    while tz <= 0
      tz = tz + 2*#pi
    endwhile
    float x = 0
    float y = 0
    if @altformula
      pz = pz/@scale
      pz = pz*(cos(rotangle)+flip(sin(rotangle)))
      x = real(@fn1(pz))
      y = imag(@fn2(pz))
      if @ref == "pz"
        rz = y^2*(@aa^2-x^2)-(x^2+2*@aa*y-@aa^2)^2+cabs(pz)*@offset
      else
        rz = y^2*(@aa^2-x^2)-(x^2+2*@aa*y-@aa^2)^2+@offset
      endif
      if abs(rz) < @width
        rz =abs(rz)
      else
        rz = 1e20

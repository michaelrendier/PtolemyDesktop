  func InvertDodecahedron(Generic pparent)
    InvertSphere.InvertSphere(0)
    p = (1+sqrt(5))/2, ip = 1/p, fscle = (3+sqrt(3)*(p-1))/(p+1), fbaserad = fscle*2*sqrt(3)/3

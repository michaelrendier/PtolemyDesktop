    l = 0
    while i < asize
      use.m_elements[i] = true
      i = i + 1
    endwhile
    i = 0
    xlimit = trunc((@xmax-@xmin)/@xstep)
    ylimit = trunc((@ymax-@ymin)/@ystep)
    umin = @xmin
    vmin = @ymin
    ustep = @xstep
    vstep = @ystep
    scale = @fscale
    complex xrot = (0,1)^(@xang/90)
    complex yrot = (0,1)^(@yang/90)
    complex temp = 0
;
; Generate the points for the lines for a full mesh grid
;
    while l < 2
      if l == 0
        outlimit = xlimit
        inlimit = ylimit
      else
        outlimit = ylimit
        inlimit = xlimit
      endif
      while i <= outlimit
        if l == 0
          u = umin + i*ustep
        else

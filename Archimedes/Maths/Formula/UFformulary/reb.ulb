	  default = 0.2
    visible = @altformula
	endparam
	float param width
	  caption = "width"
	  default = 1
    visible = @altformula
	endparam
   float param aa
     caption = "Besace parameter"
     default = 2
    visible = @altformula
   endparam
	param ref
	  caption = "offset reference"
	  default = 0
	  enum  = "zero" "pz"
    visible = @altformula
	endparam
  float param offset
    caption = "Offset"
    default = 0.0
    hint = "Trap offset"
    visible = @altformula
  endparam
  func fn1
    caption = "Function 1"
    default = ident()
    visible = @altformula
  endfunc
  func fn2
    caption = "Function 2"
    default = ident()
    visible = @altformula
  endfunc
 	
   float param a
     caption = "Polar parameter"
     default = 0.2
     hint = "Affects spread and scale of trap"
    visible = !@altformula
   endparam
   float param b
     caption = "Besace parameter"

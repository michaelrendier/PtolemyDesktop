}


Class REB_EmbossDeltoidCatacaustic(REB_EmbossFormula) {

public:
  import "common.ulb"

  ; constructor
  func REB_EmbossDeltoidCatacaustic(Generic pparent)
  endfunc

  complex func Init(complex pz)
    REB_EmbossFormula.Init(pz)
    return pz
  endfunc

  float func Iterate(complex pz,float &tz)
    tz=atan2(pz)+rotangle
    while tz <= 0
      tz = tz + 2*#pi
    endwhile
    complex af1 = 3*@afn1(tz) + @afn1(3*tz+#pi/2*@b) - @afn1(#pi/2*@b)
    complex af2 = 3*@afn2(tz) + @afn2(3*tz+#pi/2*@b) - @afn2(#pi/2*@b)
    complex as = 0.25*@a*(af1 + flip(af2))
    rz = cabs(as)
    return rz
  endfunc


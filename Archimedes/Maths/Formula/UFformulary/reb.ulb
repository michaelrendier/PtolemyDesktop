	endparam
	float param scale
	  caption = "scale"
	  default = 1
    visible = @altformula
	endparam
	float param width
	  caption = "width"
	  default = 1
    visible = @altformula
	endparam
   float param aa
     caption = "parameter a"
     default = 1.5
     hint = "Affects spread and scale of trap"
    visible = @altformula
   endparam
   float param ab
     caption = "parameter b"
     default = 3
     hint = "Affects spread and scale of trap"
    visible = @altformula
   endparam
	param ref
	  caption = "offset reference"
	  default = 0
	  enum  = "zero" "pz"
    visible = @altformula
	endparam
  float param offset
    caption = "Offset"
    default = 0.0

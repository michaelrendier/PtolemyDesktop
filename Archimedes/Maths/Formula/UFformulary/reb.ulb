 		  r[22]=sqrt(r[22])*cabs(v[15]-v[10])
 		  ;
 		  ; 16,17,12,7,11
 		  ;
 		  t[23]=(pzs-v[17])/(v[12]-v[17])
 		  x=real(t[23])

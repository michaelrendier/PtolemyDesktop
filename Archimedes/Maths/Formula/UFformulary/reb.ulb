     hint = "Affects spread and scale of trap"
   endparam
   float param scale
     caption = "Scale"
     default = 1.0
     hint = "Affects spread and scale of trap"
   endparam
   param partype
     caption = "Param Type"
     default = 5
     enum = "cabs(z)" "real(z)" "imag(z)" "real(z) + imag(z)"  "real(z) * imag(z)" \
            "angle"
   endparam
}


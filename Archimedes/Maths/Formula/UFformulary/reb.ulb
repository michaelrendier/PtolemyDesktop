public:
  import "common.ulb"

  ; constructor
  func REB_EmbossCycloidCatacaustic(Generic pparent)
  endfunc

  float func Iterate(complex pz,float &tz)
 	  if @partype == "cabs(z)"
 	    tz = cabs(pz)+rotangle
 	  elseif @partype == "real(z)"

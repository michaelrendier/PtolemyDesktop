  func fn2
    caption = "Function 2"
    default = ident()
  endfunc
 }


class REB_TrapShapeWattsCurve(common.ulb:TrapShape) {
 ; This shape uses the Watts Curve function.<br>
 ; <p>
 ; This variant of the function has a signed and absolute value

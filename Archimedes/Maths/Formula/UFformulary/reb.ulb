    caption = "Polar Parameter"
    default = 0.5
    hint = "Affects spread and scale of trap"
  endparam
  func afn1
    caption = "Function #1"
    default = cos()
  endfunc
  func afn2
    caption = "Function #2"
    default = sin()
  endfunc
}



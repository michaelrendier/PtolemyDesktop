class REB_TrapShapeCycloidCatacaustic(common.ulb:TrapShape) {
 ; This shape uses the Cycloid Catacaustic function.<br>
 public:
 	import "common.ulb"

; Constructor
 	func REB_TrapShapeCycloidCatacaustic(Generic pparent)
 		TrapShape.TrapShape(pparent)
 	endfunc
 	
  ; Call this for each iteration being trapped.
 	float func Iterate(complex pz)
    TrapShape.Iterate(pz)
 	  float d =  0
 	  float t = 0
 	  if @partype == "cabs(z)"
 	    t = cabs(pz)
 	  elseif @partype == "real(z)"
 	    t = real(pz)
 	  elseif @partype == "imag(z)"
 	    t = imag(pz)
 	  elseif @partype == "real(z) + imag(z)"
 	    t = real(pz) + imag(pz)
 	  elseif @partype == "real(z) * imag(z)"
 	    t = real(pz) * imag(pz)
 	  elseif @partype == "angle"
 	    t = atan2(pz)
 	  endif
 	  t = t*@scale
 	  float x = @a*2.5*(0.5*t-sin(0.5*t))
 	  float y = @a*2.5*(1-cos(0.5*t))
 	  m_LastZ = x + flip(y)
 	  d = cabs(pz-m_LastZ)
     return d
 	endfunc
 	

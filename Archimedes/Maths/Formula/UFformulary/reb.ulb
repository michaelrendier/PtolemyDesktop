            use.m_elements[k] = false
          endif
          x.m_elements[k] = (0.655866*cos(1.03002+u)*(2+cos(v)))*scale
          y.m_elements[k] = (0.754878*cos(1.40772-u)*(2+0.868837*cos(2.43773+v)))*scale
          z.m_elements[k] = (0.868837*cos(2.43773+u)*(2+0.495098*cos(0.377696-v)))*scale

  ;
  ; Y axis rotation
  ;
          temp = x.m_elements[k] + flip(z.m_elements[k])
          temp = temp*yrot
          x.m_elements[k] = real(temp)
          z.m_elements[k] = imag(temp)
  ;
  ; X axis rotation
  ;
          temp = y.m_elements[k] + flip(z.m_elements[k])
          temp = temp*xrot
          y.m_elements[k] = real(temp)
          z.m_elements[k] = imag(temp)

          if z.m_elements[k] < zmin
            zmin = z.m_elements[k]
          endif
          if z.m_elements[k] > zmax
            zmax = z.m_elements[k]
          endif
          k = k + 1
          j = j + 1
        endwhile
        i = i + 1
        j = 0
      endwhile
        l = l + 1
        i = 0
        j = 0
    endwhile
 	endfunc


  param adv
    caption = "Advanced Options"
    hint = "Additional shaping parameters and functions."
    default = false
  endparam
  float param distort
    caption = "Fission"
    hint = "Generally stretches and splits the elements"
    default = 0
    visible = @adv
  endparam

  float param shapeAdjust1
    caption = "Shape Adj. I"

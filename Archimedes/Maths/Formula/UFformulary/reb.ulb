Class REB_EmbossFishCurve(REB_EmbossFormula) {

public:
  import "common.ulb"

  ; constructor
  func REB_EmbossFishCurve(Generic pparent)
  endfunc

  complex func Init(complex pz)
    REB_EmbossFormula.Init(pz)
    return pz
  endfunc

  float func Iterate(complex pz,float &tz)
    tz=atan2(pz)+rotangle
    while tz <= 0
      tz = tz + 2*#pi
    endwhile
    tz = 5*@a*tz
 	  float x = @b*(cos(tz) - sin(tz)^2/sqrt(2))

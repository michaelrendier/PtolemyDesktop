class REB_DirectColorHelper(common.ulb:Generic) {
; Provides colors to use with some Direct Coloring classes <br>
public:
  import "common.ulb"
  
  ; constructor
  func REB_DirectColorHelper(Generic pparent)
    Generic.generic(pparent)
    int i = 0
    while i < 8
      direct[i] = rgba(0,0,0,0)
      i = i + 1
    endwhile
  endfunc

  func Init()
  endfunc
  
  color direct[8]


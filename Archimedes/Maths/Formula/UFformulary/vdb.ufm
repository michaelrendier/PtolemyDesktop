Curfew_Variation {; by D.H. Van den Berghe 2010
;formula adapted from Fractal Explorer 2.02
init:
  if @mode == "Mandelbrot"
   z = @seed
   c = #pixel
  elseif @mode == "Julia"
   z = #pixel
   c = @seed
  endif
loop:
  z = z + c + @p1
  z = z * @fn1((1/c)/(1/z))
bailout:
  |z| < @bailout
default:
  title = "Curfew_Variation"
  magn = 1
  center = (0,0)
  param mode
    caption = "Current Mode"
    enum = "Mandelbrot""Julia"
    default = 0

Moscova {; by D.H. Van den Berghe 2010
init:
  z = @start
  oldz = z
loop:
  temp = z
  z = z * @seed^(oldz^(1/@power)) + #pixel
  oldz = temp
bailout:
  |z| < @bailout
default:
  title = "Moscova"
  magn = 0.25
  angle= 90
  center= (0,0)
  param start
    default = (1,0)
  endparam
  param bailout
    default = 40.0
  endparam
  param seed
    default = (0.5,0)
  endparam
  param power
    default = (0.3,0)
  endparam
switch:
  type = "Moscova2"
  bailout = bailout
  start = #pixel
  seed = seed
  power = power
}


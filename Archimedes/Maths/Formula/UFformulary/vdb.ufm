}

Magpie4 { ; by D.H. Van den Berghe 2010
init:
  z = #pixel
loop:
  zold = z
  z = (log(z * @seed^z)) - (z^2) + @start
bailout:
  |z - zold| >= @bailout
default:
  title = "Magpie4"
  angle = 0
  magn = 0.5
  center = (2,0)
  param start
    default = (1.5,0)
  endparam
  param bailout
    default = 0.1
  endparam
  param seed
    default = (2.3,0)
  endparam
switch:
  type = "Magpie3"
  start = #pixel
  bailout = bailout
  seed = seed
}


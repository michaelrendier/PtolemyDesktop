JT109_Pop_Art {; by D.H. Van den Berghe 2010
;based on Joseph Trotsky formula adapted for UF
;http://www.wack.ch/fame/tips/kodtips_fedb.html
init:
  if @mode == "Mandelbrot"
   z = @seed
   c = #pixel
  elseif @mode == "Julia"
   z = #pixel
   c = @seed
  endif
loop:
  z = @fn1(z)
  z = @fn2(z*z^sin(@p1*z)) + z*(z + @p2) + c
  z = z*z + c
bailout:
  |z| < @bailout
default:
  title = "JT109_Pop_Art"
  magn = 1
  center = (0,0)
  param mode
    caption = "Current Mode"
    enum = "Mandelbrot""Julia"
    default = 0
  endparam
  param switchto
    caption = "Switch To"
    enum = "Mandelbrot""Julia"
    default = 1
    visible = 0
  endparam
  param seed
    default = (0.5,0.5)
  endparam
  param bailout
    default = 9.0
  endparam
  param p1
    default = (0.5,0.5)
  endparam
  param p2
    default = (0.5,0.5)
  endparam
  func fn1
    default = ident()
  endfunc
  func fn2
    default = ident()
  endfunc
switch:
  type = "JT109_Pop_Art"
  mode = switchto
  switchto = mode
  seed = #pixel
  bailout = bailout
  p1 = p1
  p2 = p2
  fn1 = fn1
  fn2 = fn2
}

JT110_India {; by D.H. Van den Berghe 2010
;based on Joseph Trotsky formula adapted for UF
;http://www.wack.ch/fame/tips/kodtips_fedb.html
init:
  if @mode == "Mandelbrot"
   z = @seed
   c = #pixel
  elseif @mode == "Julia"
   z = #pixel
   c = @seed
  endif
loop:
  z = @fn1(z)
  z = @p1*c/z - z*z^@fn2(z*@p2) + c
bailout:

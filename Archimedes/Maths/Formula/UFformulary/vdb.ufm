JT113_Wood {; by D.H. Van den Berghe 2010
;based on Joseph Trotsky formula adapted for UF
;http://www.wack.ch/fame/tips/kodtips_fedb.html
init:
  if @mode == "Mandelbrot"
   z = @seed
   c = #pixel
  elseif @mode == "Julia"
   z = #pixel
   c = @seed
  endif
loop:
  z = @p1 + z*z*@fn1(z*@p2) + @fn2(z*@p3)*c + c
bailout:
  |z| < @bailout

Haiku {; by D.H. Van den Berghe 1999
init:
  z = @start
  oldz = z
loop:
  temp = z
  z = @seed^oldz /z + #pixel
  oldz = temp
bailout:
  |z| < @bailout
default:
  title = "Haiku"
  magn = 0.5
  angle= 90
  param start
    default = (1.5,0)
  endparam
  param bailout
    default = 20.0
  endparam
  param seed
    default = (0.5,0)
  endparam
switch:
  type = "Haiku2"

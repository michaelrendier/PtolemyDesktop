Desert {; by D.H. Van den Berghe 1999
init:
  z = @start
loop:
  z = z * @seed^z + z^2 + #pixel
bailout:
  |z| < @bailout
default:
  title = "Desert"
  magn = 1.4
  param start
    default = (1,0)
  endparam
  param bailout
    default = 10.0
  endparam
  param seed
    default = (-0.5,0)
  endparam
switch:
  type = "Desert2"
  bailout = bailout
  start = #pixel
  seed = seed
}


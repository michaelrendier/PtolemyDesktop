  param bailout
    default = 9.0
  endparam
  float param factor
    default = 10
  endparam
  param p1
    default = (0.5,0.5)
  endparam
  func fn1
    default = ident()
  endfunc
  func fn2
    default = ident()
  endfunc
switch:
  type = "JT5_Tower_of_Hanoi"
  mode = switchto
  switchto = mode
  seed = #pixel
  bailout = bailout
  p1 = p1
  factor = factor
  fn1 = fn1
  fn2 = fn2
}


  z = abs(z)
  z = @p*(z^@power)*@fn1((z+(@fn2(z)/@factor))+(@factor2*(fn4(#pixel)))) + (@warp*c) + (@move*z) + (@distortion*(fn3(#pixel))) + @distortion2

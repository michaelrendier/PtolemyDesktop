Ishan {; by D.H. Van den Berghe 1999
init:
  z = @start
  oldz = z
loop:
  temp = z
  z = oldz * @seed^z + #pixel
  oldz = temp
bailout:
  |z| < @bailout
default:
  title = "Ishan"
  magn = 0.5
  angle= 90
  param start
    default = (2,0)
  endparam
  param bailout
    default = 40.0
  endparam
  param seed
    default = (0.65,0)
  endparam
switch:
  type = "Ishan2"
  bailout = bailout
  start = #pixel
  seed = seed
}


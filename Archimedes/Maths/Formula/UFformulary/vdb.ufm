Talis3 {; by D.H. Van den Berghe 2010
;formula adapted from Fractal Explorer 2.02
init:
  if @mode == "Mandelbrot"
   z = @seed
   c = #pixel
  elseif @mode == "Julia"
   z = #pixel
   c = @seed
  endif
loop:
  z = @fn1(z)
  z = (z*z*z*z+@p1)/(z*z-@fn1(z)+@p2)+c

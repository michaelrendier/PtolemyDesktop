Carr2341 (YAXIS) {; Updated for UF by Erik Reckase, March 2000
                  ; Modified Sylvie Gallet frm.
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  z=c=(1+1.5/pixel2)/conj(cos(2/pixel2-.25))
  d1=-.0008056/pixel2+flip(.0001/pixel2)
  int iter = 0, int nextzoom = round(p1)
  int iterspace = nextzoom
loop:

    c = z2, z=0
  ELSEIF (iter==l3)
    c = z3, z=0
  ELSEIF (iter==l4)
    c = z4, z=0
  ENDIF
  c = c + d4
  z = (z+d4)^2 + c
  iter=iter+1
bailout:

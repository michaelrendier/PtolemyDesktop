    c = z2, z=0
  ELSEIF (iter==l3)
    c = z3, z=0
  ELSEIF (iter==l4)
    c = z4, z=0
  ENDIF
  c = c + d4
  z = (z+d4)^2 + c
  iter=iter+1
bailout:
  |real(z)| <= bailout
default:
  title = "Carr 2309"
  periodicity = 0
  maxiter = 500
  magn = 1.6
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150) 
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"

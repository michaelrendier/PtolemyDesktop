  z1=1.5*z+d1, z2=2.25*z+d1, z3=3.375*z+d1, z4=5.0625*z+d1
  l1=round(real(p1)), l2=round(imag(p1))
  l3=round(real(p2)), l4=round(imag(p2))
  float bailout = 16, int iter = 0 
loop:
  IF (iter==l1)
    c = z1, z=0
  ELSEIF (iter==l2)
    c = z2, z=0
  ELSEIF (iter==l3)
    c = z3, z=0
  ELSEIF (iter==l4)
    c = z4, z=0
  ENDIF
  c = c + d4
  z = (z+d4)^2 + c
  iter=iter+1
bailout:
  |real(z)| <= bailout
default:
  title = "Carr 2306"
  periodicity = 0
  maxiter = 500
  magn = 1.4
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150) 
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \

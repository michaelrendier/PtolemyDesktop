  ELSEIF (iter==l2)
    z=c=z2
  ELSEIF (iter==l3)
    z=c=z3
  ELSEIF (iter==l4)
    z=c=z4
  ELSEIF (iter==l5)
    c=c+z5, z=z+z5
  ENDIF
  z = z + d3, c = c + d5
  z = z^2 + c
  iter=iter+1
bailout:
  |real(z)| <= bailout
default:
  title = "Carr 2329"
  periodicity = 0
  maxiter = 500
  magn = 3
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150) 
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <  300 \

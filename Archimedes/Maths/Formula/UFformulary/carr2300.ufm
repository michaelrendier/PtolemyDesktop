Carr2397 {; Updated for UF by Erik Reckase, March 2000
          ; Modified Brian Jones frm. mans-galore-012
init:
  z=c=conj(flip(2*pixel))
  int iter=0, x=real(z), y=imag(z)
  int nextzoom=round(real(p1)), float magnification=imag(p1)
  int iterspace = nextzoom
  x1=x-p2*fn1(y+p3*fn2(y))
  y1=y-p2*fn1(x+p3*fn2(x))
  k = x1 + flip(y1)
loop:
  IF (iter==nextzoom)
    nextzoom=nextzoom + iterspace
    z=0, c=magnification*c
  ENDIF  
  z=z + k
  z=z^2 + c
  iter=iter + 1
bailout:
  |z| <= 16
default:
  title="Carr 2397"
  periodicity=0
  maxiter=500
  magn=4
  center=(0,-.1)
  method = multipass
  param p1
    caption = "Nextzoom/Mag"
    default = (25,1.33)
    hint = "The real part of this parameter is the number of \
            iteration steps between value resets.  The imag \
            part is the magnification factor."
  endparam
  param p2
    caption = "Outer Fn Mult"
    default = (.05,0)
    hint = "This value scales the result of the coordinate \
            transform's Outer Function."
  endparam
  param p3
    caption = "Inner Fn Mult"
    default = (50,0)
    hint = "This value scales the result of the coordinate \
            transform's Inner Function."
  endparam
  func fn1
    caption = "Outer Function"
    default = tan()
    hint = "Operates on the sum of the z-coordinates and the \
            scaled result of the Inner Function"
  endfunc
  func fn2
    caption = "Inner Function"
    default = asin()
    hint = "Operates on raw z-coordinates"
  endfunc
}


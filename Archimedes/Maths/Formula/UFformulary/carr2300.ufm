comment {
  Carr2300.ufm Version 1.1
  Ultra Fractal conversions of Robert Carr's formulas Carr2300 - Carr2399
  by Erik Reckase / Lale Erguner, 12 December 2002

  History:  Version 1.2 - Fixes for UF3 compatibility by
                          Lale Erguner

            Version 1.1 - Major optimization effort, hints, cleanup

            Version 1.0 - Initial Release
                          Original formulas pulled from _rc2.frm
                          Carr2300-2331,2333-2391,
                              2394-2399              : pixel fix
                          Carr2341,2370              : cosxx fix
                          Carr2389-2399              : statements out of order
                          Carr2392                   : bad assignment
}

Carr2300 (YAXIS) {; Updated for UF by Erik Reckase, March 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  z=c=flip(.8*pixel2)-5*((.3,.6)+pixel2)*pixel2
  d1=real(.0009055/pixel2),d4=4*d1
  z1=1.5*z+d1, z2=2.25*z+d1, z3=3.375*z+d1, z4=5.0625*z+d1
  l1=round(real(p1)), l2=round(imag(p1))
  l3=round(real(p2)), l4=round(imag(p2))
  float bailout = 16, int iter = 0 
loop:
  IF (iter==l1)
    c = z1, z=0
  ELSEIF (iter==l2)
    c = z2, z=0
  ELSEIF (iter==l3)
    c = z3, z=0
  ELSEIF (iter==l4)
    c = z4, z=0
  ENDIF
  c = c + d4
  z = (z+d4)^2 + c
  iter=iter+1
bailout:
  |real(z)| <= bailout
default:
  title = "Carr 2300"
  periodicity = 0
  maxiter = 500
  magn = 2.8
  center = (0,-.4)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150) 
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (200,250)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
}

Carr2301 (YAXIS) {; Updated for UF by Erik Reckase, March 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  z=c=flip(.65*pixel2)-5*((.3,.6)+pixel2)*pixel2+conj(.065/pixel2)
  d1=real(.0009055/pixel2), d4=4*d1
  z1=1.5*z+d1, z2=2.25*z+d1, z3=3.375*z+d1, z4=5.0625*z+d1
  l1=round(real(p1)), l2=round(imag(p1))
  l3=round(real(p2)), l4=round(imag(p2))
  float bailout = 16, int iter = 0 
loop:
  IF (iter==l1)
    c = z1, z=0
  ELSEIF (iter==l2)
    c = z2, z=0
  ELSEIF (iter==l3)
    c = z3, z=0
  ELSEIF (iter==l4)
    c = z4, z=0
  ENDIF
  c = c + d4
  z = (z+d4)^2 + c
  iter=iter+1
bailout:
  |real(z)| <= bailout
default:
  title = "Carr 2301"
  periodicity = 0
  maxiter = 500
  magn = 2.8
  center = (0,-.36)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150) 
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (200,250)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
}

Carr2302 (YAXIS) {; Updated for UF by Erik Reckase, March 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  z=pixel2^3-conj(.01/pixel2)-flip(.015/pixel2)
  c=(-.6256,-.09), q=pixel2/4.375
  d1=.0007155/pixel2, d4=4*d1
  z1=1.5*z+d1, z2=2.25*z+d1, z3=3.375*z+d1, z4=5.0625*z+d1
  l1=round(real(p1)), l2=round(imag(p1))
  l3=round(real(p2)), l4=round(imag(p2))
  float bailout = 16, int iter = 0 
loop:
  IF (iter==l1)
    c = z1, z=0
  ELSEIF (iter==l2)
    c = z2, z=0
  ELSEIF (iter==l3)
    c = z3, z=0
  ELSEIF (iter==l4)
    c = z4, z=0
  ENDIF
  c = c + d4
  z = (z+d4)^2.3 + c - q
  iter=iter+1
bailout:
  |real(z)| <= bailout
default:
  title = "Carr 2302"
  periodicity = 0
  maxiter = 500
  magn = 1.6
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150) 
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (200,250)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
}

Carr2303 (YAXIS) {; Updated for UF by Erik Reckase, March 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  z=pixel2+pixel2^2.18+conj(.13/pixel2)+flip(.02/pixel2) \
    +tanh(.01/pixel2)
  c=(-.6256,-.49), d1=.0003055/pixel2, d7=7*d1
  z1=1.5*z+d1, z2=2.25*z+d1, z3=3.375*z+d1, z4=5.0625*z+d1
  l1=round(real(p1)), l2=round(imag(p1))
  l3=round(real(p2)), l4=round(imag(p2))
  float bailout = 16, int iter = 0 
loop:
  IF (iter==l1)
    c = z1, z=0
  ELSEIF (iter==l2)
    c = z2, z=0
  ELSEIF (iter==l3)
    c = z3, z=0
  ELSEIF (iter==l4)
    c = z4, z=0
  ENDIF
  c = c + d7
  z = (z+d7)^2.3 + c
  iter=iter+1
bailout:
  |real(z)| <= bailout
default:
  title = "Carr 2303"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150) 
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (200,250)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
}

Carr2304 (YAXIS) {; Updated for UF by Erik Reckase, March 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  z=conj(pixel2)^4-conj(.05/pixel2)-flip(.029/pixel2)
  c=flip(pixel2)^4-conj(.02/pixel2)-flip(.02/pixel2)
  d1=-tanh(.0014095/pixel2), d4=4*d1
  z1=1.5*z+d1, z2=2.25*z+d1, z3=3.375*z+d1, z4=5.0625*z+d1
  l1=round(real(p1)), l2=round(imag(p1))
  l3=round(real(p2)), l4=round(imag(p2))
  float bailout = 16, int iter = 0 
loop:
  IF (iter==l1)
    c = z1, z=0
  ELSEIF (iter==l2)
    c = z2, z=0
  ELSEIF (iter==l3)
    c = z3, z=0
  ELSEIF (iter==l4)
    c = z4, z=0
  ENDIF
  c = c + d4
  z = (z+d4)^2 + c
  iter=iter+1
bailout:
  |real(z)| <= bailout
default:
  title = "Carr 2304"
  periodicity = 0
  maxiter = 500
  magn = 1.5
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150) 
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (200,250)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
}


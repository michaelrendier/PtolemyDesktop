Carr2389 (YAXIS) {; Updated for UF by Erik Reckase, March 2000
                  ; Modified Brian Jones frm.
init:
  z=pixel2=-abs(real(pixel))+flip(imag(pixel)), c=(-.7456,-.112)
  x=real(z), y=imag(z)
  x1=x-p2*fn1(y*y+p3*fn2(y))
  y1=y-p2*fn1(x*x+p3*fn2(x))
  coracao=x1+flip(y1)
  z1=c1=1.5*z, z2=c2=fn3(coracao*pixel2)
  l1=round(real(p1)), l2=round(imag(p1))
  float bailout=16, int iter=0
loop:
  IF (iter==l1)
    z=z1, c=c1
  ELSEIF (iter==l2)
    z=z2, c=c2
  ENDIF
  z=z^2 + c
  iter=iter + 1
bailout:
  |z| <= bailout
default:
  title="Carr 2389"
  periodicity=0
  maxiter=1000
  magn=1.3
  center=(0,0)
  method = multipass
  param p1
    caption="Iter. Limits 1/2"
    default=(25,50)
    hint="0 < Re(P1) < Im(P1) < maxiter for best results"
  endparam
  param p2
    caption = "Outer Fn Mult"
    default=(-12,.5)
    hint = "This value scales the result of the coordinate \
            transform's Outer Function."
  endparam
  param p3
    caption = "Inner Fn Mult"
    default=(21,.6)
    hint = "This value scales the result of the coordinate \
            transform's Inner Function."
  endparam
  func fn1
    caption = "Outer Function"
    default=tan()
    hint = "Operates on the sum of the squared z-coordinates \
            and the scaled result of the Inner Function"
  endfunc
  func fn2
    caption = "Inner Function"
    default=sin()
    hint = "Operates on raw z-coordinates"
  endfunc
  func fn3
    caption = "Coracao Function"
    default=tan()
  endfunc
}


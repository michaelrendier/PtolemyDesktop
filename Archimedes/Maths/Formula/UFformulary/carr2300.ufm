Carr2326 (YAXIS) {; Updated for UF by Erik Reckase, March 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  c=(.1*pixel2/conj(.009*pixel2-cos(1/pixel2)-conj(1/pixel2)))^2 \
    -.15
  z=sin(43*pixel2/60)/(sin(1.5/pixel2)-conj(.1/pixel2))-.55
  d1=-.00149917/pixel2+flip(.0001/pixel2), d5=5*d1
  z1=1.5*z+d1, z2=2.25*z+d1, z3=3.375*z+d1
  z4=5.0625*z+d1, z5 = 7.59375*z+d1
  l1=round(real(p1)), l2=round(imag(p1))
  l3=round(real(p2)), l4=round(imag(p2)), int l5=300
  float bailout = 16, int iter = 0 
loop:
  IF (iter==l1)
    z=c=z1
  ELSEIF (iter==l2)
    z=c=z2
  ELSEIF (iter==l3)
    z=c=z3
  ELSEIF (iter==l4)
    z=c=z4
  ELSEIF (iter==l5)
    c=c+z5, z=z+z5
  ENDIF
  z = z + d5, c = c + d5
  z = z^2.2 + c + sinh(z/4)
  iter=iter+1
bailout:
  |real(z)| <= bailout
default:
  title = "Carr 2326"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150) 
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <  300 \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (200,250)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <  300 \
            for best results"
  endparam
}

Carr2327 (YAXIS) {; Updated for UF by Erik Reckase, March 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  c=(.1*pixel2/conj(.009*pixel2-cos(1/pixel2)-conj(1/pixel2)))^2 \
    -.35
  z=abs(pixel2*8) \
    /(sqr(2*pixel2)-flip(5/pixel2)+1/pixel2+conj(1/pixel2))-.15
  d1=-.00499917/pixel2+flip(.0001/pixel2), d5=5*d1
  z1=z+d1, z2=1.5*z+d1, z3=2.25*z+d1 
  z4=3.375*z+d1, z5=5.0625*z+d1
  l1=round(real(p1)), l2=round(imag(p1))
  l3=round(real(p2)), l4=round(imag(p2)), int l5=300
  float bailout = 16, int iter = 0 
loop:
  IF (iter==l1)
    z = c = z1
  ELSEIF (iter==l2)
    z = c = z2
  ELSEIF (iter==l3)
    z = c = z3
  ELSEIF (iter==l4)
    z = c = z4
  ELSEIF (iter==l5)
    c=c+z5, z=z+z5
  ENDIF
  z = z + d5, c = c + d5
  z = z^2 + c + sinh(z/4)
  iter=iter+1
bailout:
  |real(z)| <= bailout
default:
  title = "Carr 2327"
  periodicity = 0
  maxiter = 500
  magn = .12
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150) 
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <  300 \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (200,250)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <  300 \
            for best results"
  endparam
}

Carr2328 (YAXIS) {; Updated for UF by Erik Reckase, March 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel)), th1=tanh(1)
  z=pixel2-flip(.01/pixel2)-conj(.1/pixel2)+.285
  c=conj(flip((pixel2-conj(0.15/pixel2))^4))
  d1=-.0013899/pixel2+flip(.0001/pixel2), d5=5*d1, d3=3*d1
  z1=z+d1, z2=1.5*z+d1, z3=2.25*z+d1 
  z4=3.375*z+d1, z5=5.0625*z+d1
  l1=round(real(p1)), l2=round(imag(p1))
  l3=round(real(p2)), l4=round(imag(p2)), int l5=300
  float bailout = 16, int iter = 0 
loop:
  IF (iter==l1)
    z=c=z1
  ELSEIF (iter==l2)
    z=c=z2
  ELSEIF (iter==l3)
    z=c=z3
  ELSEIF (iter==l4)
    z=c=z4
  ELSEIF (iter==l5)
    c=c+z5, z=z*th1+c
  ELSE
    z=z*th1
  ENDIF
  z = z + d3, c = c + d5
  z = z^2 + c + sinh(z/4)
  iter=iter+1
bailout:
  |real(z)| <= bailout
default:
  title = "Carr 2328"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150) 
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <  300 \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (200,250)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <  300 \
            for best results"
  endparam
}

Carr2329 (YAXIS) {; Updated for UF by Erik Reckase, March 2000

Carr2392 {; Updated for UF by Erik Reckase, March 2000
          ; Modified Brian Jones frm.
init:
  z=pixel-conj(.1/pixel-flip(.01/pixel)), c=pixel
  x=real(z), y=imag(z)
  x1=x-p2*fn1(y*y+p3*fn2(y))
  y1=y-p2*fn1(x*x+p3*fn2(x))
  coracao=x1+flip(y1)
  z1=c1=1.5*z, z2=c2=fn3(coracao*pixel)
  l1=round(real(p1)), l2=round(imag(p1))
  float bailout=16, int iter=0
loop:
  IF (iter==l1)
    z=z1, c=c1
  ELSEIF (iter==l2)
    z=z2, c=c2
  ENDIF
  z=z^2 + c
  iter=iter + 1
bailout:
  |z| <= bailout

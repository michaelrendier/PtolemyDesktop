    visible=((@dissecttype!=0)&&(@ssq15type=="square")\
      &&(@nsubq>14))
  endparam
;
;   square sub-shape 16
;
  heading
    caption="sub-shape 16"
    visible=((@dissecttype!=0)&&(@nsubq>15))
  endheading
  param ssq16type
    caption="type"
    default=0
    enum="triangle" "square"
    visible=((@dissecttype!=0)&&(@nsubq>15))

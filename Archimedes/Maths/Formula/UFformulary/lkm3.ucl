        sinphase=\
           1*gt5*omgt0*@sinphase_a1+\
           5*gt4*omgt1*@sinphase_c4+\
          10*gt3*omgt2*@sinphase_c3+\
          10*gt2*omgt3*@sinphase_c2+\
           5*gt1*omgt4*@sinphase_c1+\

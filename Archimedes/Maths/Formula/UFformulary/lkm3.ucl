  endparam
  complex param ssq16c4
    caption="corner 4"
    default=(0,0)
    visible=((@dissecttype!=0)&&(@ssq16type=="square")\
      &&(@nsubq>15))
  endparam
;
;   square sub-shape 17
;
  heading
    caption="sub-shape 17"
    visible=((@dissecttype!=0)&&(@nsubq>16))
  endheading
  param ssq17type
    caption="type"
    default=0
    enum="triangle" "square"

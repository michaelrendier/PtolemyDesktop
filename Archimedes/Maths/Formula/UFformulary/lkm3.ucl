          1*gt3*omgt0*@sinphase_a1*@sinphase_wa1+\
          3*gt2*omgt1*@sinphase_c2*@sinphase_wc2+\
          3*gt1*omgt2*@sinphase_c1*@sinphase_wc1+\
          1*gt0*omgt3*@sinphase_a0*@sinphase_wa0)/(\
          1*gt3*omgt0*@sinphase_wa1+\
          3*gt2*omgt1*@sinphase_wc2+\
          3*gt1*omgt2*@sinphase_wc1+\
          1*gt0*omgt3*@sinphase_wa0)
      endif
    elseif(@nsinphase==5)
      if(@sinphase_interp=="Lagrange")
        sinphase=\
          @sinphase_l1*(gt-@sinphase_lt2)*(gt-@sinphase_lt3)*(gt-@sinphase_lt4)*\
                   (gt-@sinphase_lt5)/(\
          (@sinphase_lt1-@sinphase_lt2)*(@sinphase_lt1-@sinphase_lt3)*(@sinphase_lt1-@sinphase_lt4)*\
          (@sinphase_lt1-@sinphase_lt5))+\
          @sinphase_l2*(gt-@sinphase_lt1)*(gt-@sinphase_lt3)*(gt-@sinphase_lt4)*\
                   (gt-@sinphase_lt5)/(\
          (@sinphase_lt2-@sinphase_lt1)*(@sinphase_lt2-@sinphase_lt3)*(@sinphase_lt2-@sinphase_lt4)*\
          (@sinphase_lt2-@sinphase_lt5))+\
          @sinphase_l3*(gt-@sinphase_lt1)*(gt-@sinphase_lt2)*(gt-@sinphase_lt4)*\
                   (gt-@sinphase_lt5)/(\

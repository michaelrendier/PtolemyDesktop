  endparam
  complex param ssq17c2
    caption="corner 2"
    default=(0,0)
    visible=((@dissecttype!=0)&&(@nsubq>16))
  endparam
  complex param ssq17c3
    caption="corner 3"
    default=(0,0)
    visible=((@dissecttype!=0)&&(@nsubq>16))
  endparam

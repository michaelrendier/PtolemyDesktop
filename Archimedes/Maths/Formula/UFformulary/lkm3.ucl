;
; compute orbit
;
  gi=0
  while(gi<gn)
    gi=gi+1
    gj=0
  while(gj<gn)
    gj=gj+1
    xold=real(zorbit)
    yold=imag(zorbit)
    if(@mode=="de Jong")
      if(@trig_mode=="standard")
        cosin=@xcosfreq*xold

    caption="corner 4"
    default=(0,0)
    visible=((@dissecttype!=2)&&(@sst10type=="square")\
      &&(@nsubt>9))
  endparam
;
;   triangle sub-shape 11
;
  heading
    caption="sub-shape 11"
    visible=((@dissecttype!=2)&&(@nsubt>10))
  endheading
  param sst11type
    caption="type"
    default=0
    enum="triangle" "square"
    visible=((@dissecttype!=2)&&(@nsubt>10))
  endparam
  complex param sst11c1
    caption="corner 1"
    default=(0,0)
    visible=((@dissecttype!=2)&&(@nsubt>10))
  endparam
  complex param sst11c2
    caption="corner 2"
    default=(0,0)
    visible=((@dissecttype!=2)&&(@nsubt>10))
  endparam
  complex param sst11c3

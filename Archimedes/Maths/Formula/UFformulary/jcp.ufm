  z =(z/tan(z))^@power +#pixel*c
  c=p1*@function(z)+p2*@function1(z)
  
bailout:
  |z| < @bailout
default:
  title = "Trigomandelbrot4"
  center = (0,0)
  magn=1
  param start
   caption = "Starting point"
   default = (-1,0)
   endparam
  
  param power
    caption = "Power"
    default = (2,0)

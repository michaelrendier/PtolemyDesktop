Mandelbrotseptem {
;
; Generic Mandelbrot set modified for z=z-log(z).
;
init:
  z = @start, c=0
loop:
  z =z-log(z) + #pixel*c*@function(z)
  c=cos(z)
  bailout:
  |z| > @bailout
default:
  title = "Mandelbrotseptem"
  center = (0,0)
  maxiter=1000
  magn=0.5
   param start
   hint= "c= sin(z)is valid too and the sqr of both"
  caption = "Starting point"
   hint="change starting point for some functions"
   default = (1e7,0)
   endparam
  
   param function
    caption = "Function"
    endparam 

         
  float param bailout
    caption = "Bailout value"
    default =.0000001
    min = 10e-8
    endparam
  
   switch:
  type = "Juliabiso3"
  seed = #pixel
  power = power
  function=function
  bailout = bailout
}


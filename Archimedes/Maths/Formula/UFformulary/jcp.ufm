Juliaclim3 {
;
; Generic Julia set.
;
init:
  z = #pixel
loop:
  z = z^@power +@function4(z)*(@seed*((@function(z)*@function1(z))))/(@function2(z)+p1*@function3(z))
bailout:
  |z| > @bailout
default:
  title = "Juliaclim3"
  center=(0,0)  
  maxiter=1000
  param seed
    caption = "Julia seed"
    default = (-1, 0)
   endparam
  param power
    caption = "Power"
    hint="change power"
    default = (2,0)
   endparam 
    param bailout
    caption = "Bailout value"
    default = 1e-7
    endparam
switch:
  type = "Clim3"
  function=function
  function1=function1
  function2=function2
  function3=function3
  function4=function4
  p1=p1
  power = power
  bailout = bailout
  @start=#pixel
}


comment{
 Update: 08.2011
 Several examples added that show the possibilities
 of my classes in thm.ulb
 
 You may use this parameter for your purposes.
 You must not sell the pictures without altering
 this parameters. Altering the colors only is not
 enough. Please create a stunning artwork;-)

 Copyright © 2009 by Thomas Michels
 Meet me at http://stimpykatz.deviantart.com
}

A115Nova {
fractal:
  title="interlace5" width=640 height=480 layers=1
  credits="Thomas;10/8/2010"
layer:
  caption="Background" opacity=100
mapping:
  center=0.00666445246216917265/-1.0047690678577425e-9 magn=27506731
formula:
  maxiter=500 percheck=off filename="thm.ufm"
  entry="ThmGenericSwitch" p_modeM=Mandel p_modeJ=Julia
  p_seed=1.175/0.4625 p_formulaClass="thm.ulb:THMSwitchFuncInterlace"
  p_formulaClass.v_generic=100 p_formulaClass.v_formula=100
  p_formulaClass.p_power=2/0 p_formulaClass.p_bailout=1
  p_formulaClass.bailoutbase="thm.ulb:THMBailoutA115"
  p_formulaClass.bailoutbase.v_generic=100
  p_formulaClass.bailoutbase.p_bailout=50
  p_formulaClass.classplugin1="thm.ulb:THMSwitchA115"
  p_formulaClass.classplugin1.v_generic=100
  p_formulaClass.classplugin1.v_formula=100
  p_formulaClass.classplugin1.p_power=2/0
  p_formulaClass.classplugin1.p_bailout=50
  f_formulaClass.classplugin1.fn1=cos
  f_formulaClass.classplugin1.fn2=cos
  f_formulaClass.classplugin1.fn3=asinh
  f_formulaClass.classplugin1.fn4=sqr
  p_formulaClass.classplugin1.p1=5.3114
  p_formulaClass.classplugin1.p2=1 p_formulaClass.classplugin1.p3=1
  p_formulaClass.classplugin1.p4=1
  p_formulaClass.classinterplugin="Standard.ulb:Standard_NovaMandel"
  p_formulaClass.classinterplugin.v_generic=100
  p_formulaClass.classinterplugin.v_formula=100
  p_formulaClass.classinterplugin.v_convergentformula=100
  p_formulaClass.classinterplugin.start=1/0
  p_formulaClass.classinterplugin.p_power=3/0
  p_formulaClass.classinterplugin.p_bailout=0
  p_formulaClass.classinterplugin.relax=1/0
inside:
  transfer=none
outside:
  transfer=sqrt filename="Standard.ucl" entry="ExponentialSmoothing"
  p_diverge=yes p_converge=yes p_divergescale=1.0
gradient:
  smooth=yes rotation=-812 index=-741 color=16574564 index=-689
  color=6562816 index=-664 color=12606560 index=-639 color=16579836
  index=-614 color=23804 index=-589 color=2960747 index=-567
  color=8672312 index=-453 color=16579832 index=-805 color=11299650
opacity:
  smooth=no index=0 opacity=255
}


Brella {
; You can put this image in your
; site, if you want.
; I haven't a copiryght, and i want only
; to now the URL, (to visit it!!!)
; and my name for the author.
; You can put it tweaked, too.
fractal:
  title="Brella" width=640 height=480 author="Daniele Lupo"
  created="April 21, 2002" numlayers=6
layer:
  method=multipass caption="Raggiera" opacity=23 visible=yes alpha=no
  mergemode=multiply
mapping:
  center=0/0 magn=2.85714285714285728 angle=6
formula:
  filename="enr-convert.ufm" entry="Gallet-4-10" maxiter=500 percheck=off
  p_p1=0.4/0.5 p_p2=0/0 p_p3=0/0 p_p4="Original"
inside:
  transfer=none repeat=yes
outside:
  filename="sam.ucl" entry="String-ArtColoring" transfer=linear repeat=yes
  p_shape="Old" p_power=1 p_order1=5 p_w1=1 p_order2=3 p_w2=0 p_phi=90
  p_obound=2 p_ibound=0.4 p_thick=1

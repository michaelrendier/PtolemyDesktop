    default = rgb(17/255,168/255,0/255)
    hint = "Specifies the color at the low end of Range #2."
    visible = (@colormode == 1) 
  endparam
color param colorMax3
    caption = "Color Range 3 High"
    default = rgb(255/255,255/255,230/255)

default:
  title = "Backdrops"
  param d
    caption = "Grid size"
    default = .1
  endparam
  param var
    caption = "Variation"
    enum= "Trellice" "Circles" "Weave" "Weave2""Weave3""Weave4""Frames" "Interlocked"

    default = 0
  endparam
  

  param dikte
   Caption = "Line thickness"
   Default = 0.25
  endparam
 
  param n

 IF   abs(test2)< dikte/2
 c=clr[cnt+1]+(dikte-test2)/dikte+-.5
 endif
pt1=5/8, pt2=5/8+i
test1 = (zz-pt1)/(pt2-pt1)
 test2 =  imag(test1)*sqrt(|pt1-pt2|)

Carr2418 (YAXIS) {; Updated for UF by Erik Reckase, March 2000
                  ; Modified Brian Jones frm. mans-galore-012
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  r=cabs(pixel2), j=4.5*pixel2
  z=tanh(pixel2)-1/sqrt(j+.555/j-conj(.03/pixel2) \
    -flip(.055/pixel2)+2/r)
  c=2*pixel2+(-.099,-.2249)
  int iter=0, x=real(z), y=imag(z)
  int iterspace = round(real(p1)), int nextzoom = iterspace
  float magnification = imag(p1)  
  x1=x-p2*cotan(fn1(y+p3*fn2(y)))
  y1=y-p2*cotan(fn1(x+p3*fn2(x)))
  k = x1 + flip(y1)
loop:
  IF (iter==nextzoom)
    nextzoom = nextzoom + iterspace
    z = 0, c = magnification*c
  ENDIF
  z = (z+k)^2 + c
  iter = iter + 1
bailout:
  |z| <= 16
default:
  title = "Carr 2418"
  periodicity = 0
  maxiter = 500
  magn = 3.5
  center = (0,.07)
  method = multipass
  param p1
    caption = "Nextzoom/Mag"
    default = (25,1.33)
    hint = "The real part of this parameter is the number of \
            iteration steps between value resets.  The imag \
            part is the magnification factor."
  endparam
  param p2
    caption = "Outer Fn Mult"
    default = (.05,0)
    hint = "This value scales the result of the coordinate \
            transform's Outer Function."
  endparam
  param p3
    caption = "Inner Fn Mult"
    default = (50,0)
    hint = "This value scales the result of the coordinate \
            transform's Inner Function."
  endparam
  func fn1
    caption = "Outer Function"
    default = tan()
    hint = "Operates on the cotan of the sum of the \
            z-coordinates and the scaled result of the \
            Inner Function"
  endfunc
  func fn2
    caption = "Inner Function"
    default = asin()
    hint = "Operates on raw z-coordinates"
  endfunc
}


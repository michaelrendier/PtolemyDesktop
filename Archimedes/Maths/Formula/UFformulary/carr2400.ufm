Carr2425 {; Updated for UF by Erik Reckase, March 2000
          ; Modified Brian Jones frm. mans-galore-012
init:
  m=cabs(pixel/4+pixel/3)-conj(0.1275/pixel)
  z=2*pixel^4-m-sin(.8*pixel-flip(.01/pixel))
  c=4*pixel^4-m-sin(pixel-flip(.01/pixel))
  int iter=0, x=real(z), y=imag(z)
  int iterspace = round(real(p1)), int nextzoom = iterspace
  float magnification = imag(p1)  
  x1=x-p2*fn1(y+p3*fn2(y))
  y1=y-p2*fn1(x+p3*fn2(x))
  k = x1 + flip(y1)
loop:
  IF (iter==nextzoom)
    nextzoom = nextzoom + iterspace
    z = 0, c = magnification*c
  ENDIF
  z = (z+k)^2 + c
  iter = iter + 1
bailout:
  |z| <= 16
default:

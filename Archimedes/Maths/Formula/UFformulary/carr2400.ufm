  z = (pm1*z^p1+1)/p1/z^pm1
bailout:
  |z-oldz|>=.001
default:
  title = "Carr 2459"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = multipass
  param p1
    caption = "Scalar/Exponent"
    default = (5,-1)
  endparam
}


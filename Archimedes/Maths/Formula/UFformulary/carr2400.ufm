Carr2430 (YAXIS) {; Updated for UF by Erik Reckase, March 2000
                  ; Sylvie Gallet [101324,3444], Mod. BEJ
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  z=c=.55*(2*pixel2-flip(.01/pixel2)-conj(.1/pixel2))
  limit=p1, float b1=16, float b2=.0001, float iter=1
loop:
  IF (iter<limit)
    z = z^2 + c
    float zfinal = |z|
    float bfinal = b1
  ELSE
    z1 = (z^5-1)/4/z^4
    z = z - z1
    float bfinal = |z1|
    float zfinal = b2
  ENDIF
  iter = iter + 1.099
bailout:
  zfinal <= bfinal
default:
  title = "Carr 2430"
  periodicity = 0
  maxiter = 1000
  magn = 1.3
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter. Limit"
    default = 25
    hint = "Number of iterations before z iteration procedure \
            changes"
  endparam
}


init:
  z=pixel/3-conj(.1/pixel), c=conj(pixel^3)-conj(.1/pixel)
  x=real(z), y=imag(z)
  x1=x-p2*fn1(y+p3*fn2(y))
  y1=y-p2*fn1(x+p3*fn2(x)), int iter=1 
  rad=fn1(3.1*fn3(x1+flip(y1))), center=(1,.1) 
  pix=fn2(10*pixel+(5.,-3.4))*(-.1,-.95)
  zn=center+fn4(rad)/(pix-center)
  int limit=p1, float b1=16, float b2=.0001
loop:
  IF (iter==limit)

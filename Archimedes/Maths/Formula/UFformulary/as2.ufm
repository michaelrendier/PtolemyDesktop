  ua2=@fike(ua2+@ike6)^@ike1+(appcua2-@ike4)*@fike1(ua2-@ike3)+@fike2(appcua2*@ike5)^@ike2
  ua3=@fike(ua3+@ike6)^@ike1+(appcua3-@ike4)*@fike1(ua3-@ike3)+@fike2(appcua3*@ike5)^@ike2


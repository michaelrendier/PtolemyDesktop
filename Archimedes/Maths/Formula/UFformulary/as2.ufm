 elseif (method1==1)

   yaa11=(ya11)*@pgz11
   yaa12=(ya12)*@pgz11
   yaa13=(ya13)*@pgz11
   ybb11=(yb11)*@pgz11
   ybb12=(yb12)*@pgz11
   ybb13=(yb13)*@pgz11


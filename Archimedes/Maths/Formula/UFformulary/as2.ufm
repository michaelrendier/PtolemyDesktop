 yb102=b2*b2*b2*b2*b2*b2*b2*b2*b2*b2
 yb103=b3*b3*b3*b3*b3*b3*b3*b3*b3*b3

;---------------Loop the distortion sequence method-----------------------------

  if (method1==0)

   yaa11=(ya11)*@pgz1
   yaa12=(ya12)*@pgz1
   yaa13=(ya13)*@pgz1
   ybb11=(yb11)*@pgz1

  dist4=@dist4
  pho1=@pho1
  pho2=@pho2
  pho3=@pho3
  fnznew=@fnznew
  fnz=@fnz
  fnc=@fnc
  fnha=@fnha
  fnhb=@fnhb
  fnph1=@fnph1
  juliadim=@juliadim
  mode=@switchmode
  switchmode=@mode
  version=@version
  slope=@slope
  offset=@offset
  zmode=@zmode

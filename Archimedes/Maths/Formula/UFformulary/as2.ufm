    enum="Mandelbrot Newton 1""Mandelbrot Newton 2""Mandelbrot Newton 3""Mandelbrot Newton 4""Mandelbrot Newton 5"\
         "Mandelbrot Newton 6""Mandelbrot Newton 7""Mandelbrot Newton 8""Mandelbrot Newton 9""Mandelbrot Newton 10"
    default=0
   endparam
  bool param showGlobal
    caption="Global Param. a/b"

       "13 Funny : z*sqr(z)+c*(1+z-sqr(z))""14 FGZ : a=z*z+c ; z=(0.5*a*a)/( a+0.5)+c""15 Funny : z^2*c+c+z""16 N9 : 2/sinh(1/(z*c))+c" \

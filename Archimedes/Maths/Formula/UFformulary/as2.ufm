   zpub2=@mphy7+@fn1hy1(@mphy1+tempub2^@mphy8)*@mphy5
   zpub3=@mphy7+@fn1hy1(@mphy1+tempub3^@mphy8)*@mphy5

   ;-----------------------------------------------------

   oldza1=@od3+@fnod2(@od4+tempa1^@od5)*@od6
   oldza2=@od3+@fnod2(@od4+tempa2^@od5)*@od6

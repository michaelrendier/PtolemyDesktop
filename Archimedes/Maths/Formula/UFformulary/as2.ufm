    default=ident()
   endfunc

Heading
 caption="Parameters"
Endheading
   param select1
    caption="Op. C"
    enum="+""*""/""^"
    default=0
   endparam
   param select2
    caption="Add. Z"
    enum="Normal""+Z""*Z""/Z""^Z"
    default=0

;-----------------------Define the degrees of the distortion--------------------

 ya11=a1
 ya12=a2
 ya13=a3
 yb11=b1
 yb12=b2
 yb13=b3

 ya21=a1*a1
 ya22=a2*a2
 ya23=a3*a3

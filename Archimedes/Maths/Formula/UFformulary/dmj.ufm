  f2z = @coeff1*@power1*(@power1-1)*z^(@power1-2) + @coeff2*@power2*(@power2-1)*z^(@power2-2)
  z = z - @relax * (2*fz*f1z) / (2*f1z^2 - fz*f2z) + @seed + @induct*y
  

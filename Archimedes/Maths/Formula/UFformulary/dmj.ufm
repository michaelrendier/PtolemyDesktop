loop:
  IF (@power == (3,0)); special optimized routine for power 3
    zsquared = sqr(z)
    zcubed = zsquared * z
    zold = z
    z = z - @relax * (zcubed-1) / (3*zsquared) + #pixel
  ELSE
    zold = z
    z = z - @relax * (z^@power-1) / (@power * z^(@power-1)) + #pixel

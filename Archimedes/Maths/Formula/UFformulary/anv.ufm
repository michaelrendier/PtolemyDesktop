   if(@switch9==true)
      complex sw9=0   
      sw9=(z*z*(sin(z)))^tan(z)+#pixel
         if(@tfuncdisplay1==false)
            A9=sw9+@zsw9zet1
         elseif(@tfuncdisplay1==true)
            A9=fn1(sw9)+@zsw9zet1

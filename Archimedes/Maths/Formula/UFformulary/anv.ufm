         b = @tvalor2*tan(@tvalor3*a)
         c = @tvalor2*@tvalor3/sqr(cos(@tvalor3*a))
            if(@tchoice==0)
               zsw7 = abs(((z)-(b)+((z)-(a)/c)*abs(c))+A7)

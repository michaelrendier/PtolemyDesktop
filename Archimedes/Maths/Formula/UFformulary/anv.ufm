            elseif(@tchoice==5)
               zsw5 = fn2(A5)              
            endif
      endif 
   elseif(@switch5==false)
   endif                               
;****************************************************************
   if(@switch6==true)
      complex sw6 = 0   
      sw6=z*#pixel-#pixel/(z*z+#pixel)
         if(@tfuncdisplay1==false)
            A6=sw6+@zsw6zet1
         elseif(@tfuncdisplay1==true)
            A6=fn1(sw6)+@zsw6zet1

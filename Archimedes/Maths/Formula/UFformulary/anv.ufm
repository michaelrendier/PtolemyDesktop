      elseif(@tfuncdisplay2==true)
            iterations = iterations + 1
         a = iterations-(#pi*2/@tvalor1)
         b = @tvalor2*tan(@tvalor3*a)
         c = @tvalor2*@tvalor3/sqr(cos(@tvalor3*a))
            if(@tchoice==0)
               zsw9 = fn2(abs(((z)-(b)+((z)-(a)/c)*abs(c))+A9))
            elseif(@tchoice==1)
               zsw9 = fn2(abs(((z)-(b)-(c)*((z)-(a)))+A9))
            elseif(@tchoice==2)
               zsw9 = fn2(abs(((z)+(b)-(a)*((z)-(c)))+A9))
            elseif(@tchoice==3)

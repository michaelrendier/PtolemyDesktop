          repeat                    
            temp=1/(z1^@kwadzet-real(zh)^@kwad+imag(zh)^@kwad2-2*flip(real(zh)*imag(zh))+cri)
        zh=@zeth*(real(z1)*real(zh)-imag(z1)*imag(zh)+flip(real(z1)*imag(zh)+imag(z1)*real(zh)))+cjk
            z1=temp
            length=|z1|+|zh|
            m=m+1
          until m>=#maxiter || length>@bailout
          count2=count2+1
        until length>=@bailout
        if count0==0

            elseif(@tchoice==5)
               zsw9 = fn2(A9)              
            endif
      endif 
   elseif(@switch9==false)
   endif                               
  if(@zetswitch==0)
      z = zsw1+zsw2+zsw3+zsw4+zsw5+zsw6+zsw7+zsw8+zsw9
  elseif(@zetswitch==1)
      z = zsw1-zsw2-zsw3-zsw4-zsw5-zsw6-zsw7-zsw8-zsw9 
  elseif(@zetswitch==2)
      z = 1/(zsw1+zsw2+zsw3+zsw4+zsw5+zsw6+zsw7+zsw8+zsw9)
  elseif(@zetswitch==3)
      z = 1/(zsw1-zsw2-zsw3-zsw4-zsw5-zsw6-zsw7-zsw8-zsw9)     
  endif       

Platelet {
; Copyright 2002, Sharon S. Schultz
init:
  Z = #pixel
  C = #pixel
loop:
  Z = Z^3*((Z^3*c)/2*(COS(Z)+C/Z^5*C))
bailout:
  |Z| < 5

default:
  title = "Platelet"
  angle = 30
  center = (0,0)
  method = multipass
  periodicity = 0

param Start
  default = (1,0)
endparam

param Bailout
  caption = "Bailout"
  default = (4,4)
endparam

func fn1
  caption = "Function 1"
  default = cos()
endfunc

func fn2
  caption = "Function 2"
  default = ident()
endfunc

func fn3
  caption = "Function 3"
  default = sin()
endfunc
}


Shapes1 {
; Copyright 2002, Sharon S. Schultz
init:
  Z = #pixel
  C = p1*Z
  x = z^4+real(c)
loop:
  Z = Z^3*((|z|*Z^3*c)/2*fn1(real(Z)+C/Z^3*C))+X
bailout:
  |Z| < (Z+C/X)

default:
  title = "Shapes 1"
  angle = 90
  center = (0,0)
  method = multipass
  periodicity = 0

param Start
  default = (3,0)
endparam


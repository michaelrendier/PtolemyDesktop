Shapes2 {
; Copyright 2002, Sharon S. Schultz
init:
  Z = #pixel
  C = p1/Z
  x = z^4+real(c)
loop:
  Z = Z^3*((|z|*Z^3*c)/2*fn1(real(Z)+C/Z^3*C))+X

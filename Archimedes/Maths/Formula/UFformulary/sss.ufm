Alien1 {
; Copyright 2002, Sharon S. Schultz
init:
  Z = #pixel
  C = #pixel
  x = z^2+c
loop:
  Z = fn1(Z^3*fn2((|z|*Z^3*c)/2*fn3(COS(Z)+C/Z^5*C))+X)
bailout:
  |Z| < (3*Z^3+C)

default:
  title = "Alien 1"
  angle = 90
  center = (0,0)
  method = multipass
  periodicity = 0

param Start
  default = (3,0)
endparam

param Bailout
  caption = "Bailout"
  default = (4,8)
endparam


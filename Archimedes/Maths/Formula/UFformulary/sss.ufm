SeaLife {
; Copyright 2002, Sharon S. Schultz
init:
  z = #pixel
  c = p1+p2*p3
loop:
  z = fn1(z^5*cotanh(c)-1)+(tan(c)^3*3+1)+(cos(z)+2.29354)/fn2((c*z*real(z))+1)
bailout:
  z<12
default:
  title = "Sea Life"
  angle = 0
  center = (0,0)
  method = multipass
  periodicity = 0
  

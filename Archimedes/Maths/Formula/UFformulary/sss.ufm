ComplexShape3 {
; Copyright 2002, Sharon S. Schultz
init:
  z = #pixel
  c = p1
  d = p1+p2
  x = p1+p2+p3
loop:
  z = fn1(z^4*cotanh(x)-1)+(tan(c)*3+1)*(cos(D)+2)/fn1((c*d*x)+1)
bailout:
  z < @bailout+1.97531

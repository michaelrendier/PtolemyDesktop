        elseif @thistype2 == 323
          tempc = (imag(thist[@trapmixmatch4,@traphisindex2]) - real(thist[@trapmixmatch3,9])) - flip((real(thist[@trapmixmatch4,@traphisindex2]) - imag(thist[@trapmixmatch3,9])))
        elseif @thistype2 == 324

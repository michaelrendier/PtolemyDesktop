    caption = "Martin Z Iterations"
    default = 2
    min = 1
    hint = "This parameter determines the number of Martin attractor iterations of #z"
    visible = @zattractor && @zattractmartin
  endparam
  param zmartinparam
    caption = "Martin Z Parameter"
    default = 3.1415926535897932384626433832795
    hint = "This parameter modulates the #z Martin attractor"
    visible = @zattractor && @zattractmartin
  endparam
  param zmartinscale
    caption = "Martin x,y Scale (z)"
    default = (5.0, 5.0)
     hint = "This parameter scales #z before the Martin iterations"
     visible = @zattractor && @zattractmartin
   endparam
  param blendzmartin
    caption = "Blend Z Martin?"
    default = FALSE
    hint = "If enabled, than the Martin attractor perturbation is only partially mixed into \

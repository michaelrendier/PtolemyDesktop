	folioidconstA[1] = @folioidconstA2
	folioidconstB[1] = @folioidconstB2
endif ; @traptype2

	; shaping variables for 'parametric functions' traps
if @traptype == "parametric functions"
	hyponumer[0] = @hyponumerator1
	hypodenom[0] = @hypodenom1
	companC1[0] = @companC11
	companC2[0] = @companC21
	companfreq[0] = @companfreq1
	cycampA[0] = @cycampA1
	cycampB[0] = @cycampB1
	cycxscale[0] = @cycxscale1
	cycyoffset[0] = @cycyoffset1
	cycsinfreq[0] = @cycsinfreq1

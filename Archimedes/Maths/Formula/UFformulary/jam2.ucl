	visible = @showprimaries && @traptype == "parametric functions" && \
		@parashape1 == "companion of cycloid"
endparam
param companC21
	caption = "Companion Y-offset"
	default = 1.0
	hint = "If 'Trap Shape' is set to 'companion of cycloid', then this setting \

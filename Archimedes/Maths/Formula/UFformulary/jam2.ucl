          "(e^(x^2))/x" "(e^(1/(x^2))/x" "x*e^(x^2)" "x*e^(1/(x^2))" \
          "e^(-x^2)"  "e^(-1/(x^2))" "(e^(-x^2))/x" "(e^(-1/(x^2))/x" \
          "x*e^(-x^2)" "x*e^(-1/(x^2))"
    default = 0
    hint = "This is the second of up to four texture functions.  Texture functions may be turned \
            off by setting them to 'x'"
    visible = @showtex && @texture
  endparam
  param tex2power2
    caption = "Tex Fn2 Power"
    default = 4.0
    hint = "This is the exponent if 'Texture Func 2' is \
            set to 'x^power'"
    visible = @showtex && @texfunc2 == "x^power" && @texture
  endparam
  param texf2offset
    caption = "Tex Fn2 Offset"
    default = (0, 0)
    hint = "This constant is added to the result of 'Texture Func 2'"
    visible = @showtex && @texture
  endparam

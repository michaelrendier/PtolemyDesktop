	conchoidA[0] = @conchoidA1
	conchoidB[0] = @conchoidB1
	conchoidC[0] = @conchoidC1
	conchoidA[0] = @conchoidA1
	conchoidB[0] = @conchoidB1
	conchoidC[0] = @conchoidC1
	cubicpA[0] = @cubicpA1
	cubicpB[0] = @cubicpB1
	cubicpC[0] = @cubicpC1
	majaxis[0] = @majaxis1
	minaxis[0] = @minaxis1

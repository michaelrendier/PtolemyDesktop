	cycangle[1] = @cycangle2
	epicycAN[1] = @epicycAN2
	epicycAD[1] = @epicycAD2
	epicycB[1] = @epicycB2
	epicycC[1]= @epicycC2
	nephsinfreq[1] = @nephsinfreq2
	nephcosfreq[1] = @nephcosfreq2
	nephconstA[1] = @nephconstA2
	nephconstB[1] = @nephconstB2
	parafreqA[1] = @parafreqA2
	parafreqB[1] = @parafreqB2
	paraconstA[1] = @paraconstA2
	paraconstB[1] = @paraconstB2
	wavysinfreq[1] = @wavysinfreq2

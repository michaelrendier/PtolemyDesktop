	tanfreq[0] = @tanfreq1
	fosinfreq[0] = @fosinfreq1
	focosfreq[0] = @focosfreq1
	sinfreq2[0] = @sinfreq21
	hyperbolic[0] = @hyperbolic1
	kampfreq[0] = @kampfreq1
	kamppower[0] = @kamppower1
	nodalfreq[0] = @nodalfreq1
	lemfreq[0] = @lemfreq1
	lempower[0] = @lempower1
	limfreq[0] = @limfreq1
	limamp[0] = @limamp1
	limoffset[0] = @limoffset1
	litpower[0] = @litpower1
	logspiA[0] = @logspiA1
	logspiB[0] = 0.2 * @logspiB1
	parafreq[0] = @parafreq1
	paraamp[0] = @paraamp1

          ((@coordtype == "Parametric") && (@traptype == "oscillators") && ((@osc31amp != 0.0) || (@osc41amp != 0.0))) || \
          ((@coordtype == "Parametric") && ((@traptype == "mixed 1") || (@traptype == "mixed 2"))) || \
          @coordtype == "Mixed") && @altcombo

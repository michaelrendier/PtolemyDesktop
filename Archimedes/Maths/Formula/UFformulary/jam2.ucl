	caption = "Folioid 1 Const A"
	default = 1.5
	hint = "If 'Trap 1 Type' is set to 'polar functions' and 'Trap Shape' \
		is 'folioid', then this parameter is the first of two shaping terms."
	visible = @showprimaries && (@traptype == "polar functions" && @polarshape1 == "folioid" \
		&& @polarmode1 == "implicit")
endparam
param folioidconstB1

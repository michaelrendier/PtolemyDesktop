      elseif ( @transmogrify == 34 )
        tempc = tempc^(tempc)
        tempc = 1/( tempc^tempc )
      elseif ( @transmogrify == 35 )
        tempc = log(-tempc)
      elseif ( @transmogrify == 36 )
        tempc = 1/log( tempc )
      elseif ( @transmogrify == 37 )
        tempc = tempc * log( tempc )

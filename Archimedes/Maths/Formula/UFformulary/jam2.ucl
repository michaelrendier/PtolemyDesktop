	hint = "If 'Trap 1 Type' is set to 'polar functions' and 'Trap Shape' \
		is 'folioid', then this parameter fixes the denominator of the frequency of the cosine term."
	visible = @showprimaries && (@traptype == "polar functions" && @polarshape1 == "folioid")
endparam

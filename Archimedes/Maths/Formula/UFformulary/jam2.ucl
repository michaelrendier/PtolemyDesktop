;      endif; @fbmblendmode1
;    elseif @fbminit == "blend9"
;      if @fbmblendmode2 == "normal"
;        ztemp = zantepenult
;      elseif @fbmblendmode2 == "negate"
;        ztemp = -zantepenult
;      elseif @fbmblendmode2 == "flip"
;        ztemp = flip(zantepenult)
;      elseif @fbmblendmode2 == "conj"
;        ztemp = conj(zantepenult)
;      elseif @fbmblendmode2 == "flip-conj"
;        ztemp = flip(conj(zantepenult))
;      endif; @fbmblendmode2
;      if @fbmblendmode1 == "*"
;        zfBm = (sum+flip(sum2))*ztemp
;      elseif @fbmblendmode1 == "+"
;        zfBm = (sum+flip(sum2))+ztemp
;      elseif @fbmblendmode1 == "-"
;        zfBm = (sum+flip(sum2))-ztemp
;      elseif @fbmblendmode1 == "/"
;        zfBm = (sum+flip(sum2))/ztemp
;      elseif @fbmblendmode1 == "^"

	cycangle[0] = @cycangle1
	epicycAN[0] = @epicycAN1
	epicycAD[0] = @epicycAD1
	epicycB[0] = @epicycB1
	epicycC[0]= @epicycC1
	nephsinfreq[0] = @nephsinfreq1
	nephcosfreq[0] = @nephcosfreq1
	nephconstA[0] = @nephconstA1
	nephconstB[0] = @nephconstB1
	parafreqA[0] = @parafreqA1
	parafreqB[0] = @parafreqB1
	paraconstA[0] = @paraconstA1
	paraconstB[0] = @paraconstB1

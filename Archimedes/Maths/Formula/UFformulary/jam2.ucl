	hint = "If parameter 'Trap Shape' is set to 'strophoid', \
		then this setting is the frequency of the 1st (numerator) cosine term.  \
		2.0 corresponds to the strophoid."
	visible = (@traptype == "polar functions") && (@polarshape1 == "strophoid") && @showprimaries

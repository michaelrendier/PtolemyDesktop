	parayaxis[0] = @parayaxis1	
	epiradiusA[0] = @epiradiusA1
	epiradiusB[0] = @epiradiusB1
	epiradiusC[0] = @epiradiusC1
endif ; @traptype

if @traptype2 == "parametric functions"
	hyponumer[1] = @hyponumerator2
	hypodenom[1] = @hypodenom2
	companC1[1] = @companC12
	companC2[1] = @companC22
	companfreq[1] = @companfreq2
	cycampA[1] = @cycampA2
	cycampB[1] = @cycampB2
	cycxscale[1] = @cycxscale2
	cycyoffset[1] = @cycyoffset2
	cycsinfreq[1] = @cycsinfreq2

    default = 3.0
    min = 0.0
    hint = "This is the const value used in 4 of the 'Range 8 Mapping' \
        options; unused otherwise. Positive values only"
  endparam
  param r8color
    caption = "Range 8 Color"
    default = 0.0
    min = 0.0
    max = 400.0
    hint = "Gradient position index that will be assigned to Range 8 pixels \
        if 'Range 8 Mapping' is set to 'Range 8 Color' (0-400)"

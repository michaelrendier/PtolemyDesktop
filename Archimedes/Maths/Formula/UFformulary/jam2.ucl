;      if @fbmblendmode1 == "*"
;        zfBm = zmin*ztemp
;      elseif @fbmblendmode1 == "+"
;        zfBm = zmin+ztemp
;      elseif @fbmblendmode1 == "-"
;        zfBm = zmin-ztemp
;      elseif @fbmblendmode1 == "/"

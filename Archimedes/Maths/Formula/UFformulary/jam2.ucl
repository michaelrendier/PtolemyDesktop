param folioidamp1
	caption = "Folioid 1 Amplitude"
	default = 2.2
	hint = "If 'Trap 1 Type' is set to 'polar functions' and 'Trap Shape' \
		is 'folioid', then this parameter fixes the amplitude of the cosine term."
	visible = @showprimaries && (@traptype == "polar functions" && @polarshape1 == "folioid" \
		&& @polarmode1 == "normal")
endparam
param folioidfreqN1
	caption = "Folioid 1 Numerator"
	default = 3.0
	hint = "If 'Trap 1 Type' is set to 'polar functions' and 'Trap Shape' \
		is 'folioid', then this parameter fixes the numerator of the frequency of the cosine term."
	visible = @showprimaries && (@traptype == "polar functions" && @polarshape1 == "folioid")
endparam

        tempc = 1/cos( tempc )
        tempc = tempc * tempc
      elseif ( @transmogrify == 32 )
        tempc = 1/sin( tempc )
        tempc = tempc * tempc
      elseif ( @transmogrify == 33 )
        tempc = tempc^(tempc)

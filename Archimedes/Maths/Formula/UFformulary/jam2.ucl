;        ztemp = flip(conj(zfirst))
;      endif; @fbmblendmode2
;      if @fbmblendmode1 == "*"
;        zfBm = zmin*ztemp
;      elseif @fbmblendmode1 == "+"
;        zfBm = zmin+ztemp
;      elseif @fbmblendmode1 == "-"
;        zfBm = zmin-ztemp
;      elseif @fbmblendmode1 == "/"
;        zfBm = zmin/ztemp
;      elseif @fbmblendmode1 == "^"
;        zfBm = zmin^ztemp

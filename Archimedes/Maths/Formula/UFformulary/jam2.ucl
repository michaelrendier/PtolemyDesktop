    elseif ( @realfront == 46 )
      tempx = ftemp * exp( -1/ftemp )
    elseif ( @realfront == 47 )
      tempx = ftemp * ftemp * ftemp
    elseif ( @realfront == 48 )
      tempx = 1 / ( ftemp * ftemp * ftemp )
    elseif ( @realfront == 49 )

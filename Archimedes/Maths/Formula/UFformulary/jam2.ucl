  param funcy2
    caption = "Func Y2 Sin?"
    default = FALSE
    hint = "If enabled, the sine function is used for oscillator Y2; \
        cosine is the default"
    visible = @ampy2 != 0.0
  endparam
  param ampy3
    caption = "Y Amplitude 3"
    default = 0.0
    hint = "The trap is defined by the parametric equations x = cx1 * \

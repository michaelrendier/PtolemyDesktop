          "log(x)^2" "sin(x)sin(2x)" "e^2x" "e^-2x" "sinh(1/x)cosh(1/x)" \
          "sinh(1/x)^2" "sinh(x)cosh(1/x)" "sinh(x)sinh(1/x)" "sin(x)sinh(x)" \
          "sin(x)cosh(x)" "sin(x)^2*sinh(x)^2" "sin(x)e^x" "cos(x)e^x" \
          "sinh(x)e^x" "cosh(x)e^x" "sin(x)log(x)" "cos(x)log(x)" "sinh(x)log(x)" \
          "cosh(x)log(x)" \
          "e^(x^2)"  "e^(1/(x^2))"  "abs(x)"  "round(x)" "trunc(x)" \
          "ceil(x)"  "floor(x)" "x/log(x)" "log(x)/x" "(e^x)/x" "(e^(1/x))/x" \
          "(e^(x^2))/x" "(e^(1/(x^2))/x" "x*e^(x^2)" "x*e^(1/(x^2))" \
          "e^(-x^2)"  "e^(-1/(x^2))" "(e^(-x^2))/x" "(e^(-1/(x^2))/x" \
          "x*e^(-x^2)" "x*e^(-1/(x^2))"
    default = 0
    hint = "This is the second of up to four texture functions.  Texture functions may be turned \
            off by setting them to 'x'"
    visible = @showtex && @texture
  endparam
  param tex2power2
    caption = "Tex Fn2 Power"
    default = 4.0
    hint = "This is the exponent if 'Texture Func 2' is \
            set to 'x^power'"
    visible = @showtex && @texfunc2 == "x^power" && @texture
  endparam
  param texf2offset
    caption = "Tex Fn2 Offset"
    default = (0, 0)
    hint = "This constant is added to the result of 'Texture Func 2'"
    visible = @showtex && @texture
  endparam

  z2=4*z^3-1.68*z
  z=z-z1/z2
bailout:
  |real(z)| <=100
default:
  title = "Carr 1383"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = multipass
}


  z4=conj(sqr(pixel))/conj(cos(sqr(pixel)))
loop:
  z=((z*1/c)+z4)/(pixel-z*z+c)
  z4=(1/z*z+z4)/(pixel-z*z+c)
bailout:
  |real(z)| <=100
default:
  title = "Carr 1345"

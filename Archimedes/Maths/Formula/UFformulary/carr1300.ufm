}

Carr1353 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=1/pixel*0.91/pixel
  c1=(1.099,0)
  c=z*sqr(c1)
loop:
  z=conj(cos(z))+c+sin(z/c1)+conj(cos(1/pixel))
bailout:
  |real(z)| <=100
default:
  title = "Carr 1353"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = multipass
}

Carr1354 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=1/pixel*0.91/pixel

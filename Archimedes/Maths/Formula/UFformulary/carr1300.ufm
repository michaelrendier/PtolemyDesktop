Carr1382 { ; Updated for UF2 by Erik Reckase, Feb 2000
           ; SpNewton modified
init:
  z=sqr(sqr(pixel))
loop:
  z1=(z*z-1)*(z*z+0.16)
  z2=4*z^3-1.68*z
  z=z-z1/z2
bailout:
  |real(z)| <=100
default:
  title = "Carr 1382"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = multipass
}

Carr1383 { ; Updated for UF2 by Erik Reckase, Feb 2000

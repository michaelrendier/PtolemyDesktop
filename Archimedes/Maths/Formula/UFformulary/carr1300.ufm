Carr1344 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=conj(cos(1/pixel)), z2=flip(real(z)), z3=conj(imag(z))
  c=cotanh(1/pixel), z4=conj(sqr(pixel))/conj(cos(sqr(pixel)))
loop:
  z=(z*1/c)+z4
  z2=conj(z2^z3)/z
  z3=conj(z3^z4)/z
  z4=(1/z*z+z4)/(pixel-z*z+c)
bailout:
  |real(z)| <=100
default:
  title = "Carr 1344"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = multipass
}

Carr1345 { ; Updated for UF2 by Erik Reckase, Feb 2000

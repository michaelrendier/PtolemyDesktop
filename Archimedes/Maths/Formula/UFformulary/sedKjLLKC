          endif ; bailiter
        elseif @type3 == 2 ; two-tone
          if ( bailiter[0] == bailiter[1] ) && ( bailiter[1] == bailiter[2] ) ; all equal
            z = (0.9,1e30)
          else
            z = (0.1,1e30)
          endif ; bailiter
        endif ; @type3
      endif ; @testpoints
    else ; all test points haven't bailed yet
      z = (0.05,0.05)
    endif ; bailcount
  else
    if @pixelmode
      z = #pixel + @pixelblend*zvalues[0]
    else

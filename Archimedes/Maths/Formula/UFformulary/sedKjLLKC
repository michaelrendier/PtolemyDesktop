      elseif  @formula2 == 88
        tempform2 = (1,0)/cosh(1/#z)
      elseif  @formula2 == 89
        tempform2 = (1,0)/sinh(1/#z)
      else ;  @formula2 == 90
        tempform2 = sin( #z ) * tan(#z)
      endif ; formula2-2
    else ; 90 < @formula2 <= 120
      if  @formula2 == 91
        tempform2 = sinh(#z) * tanh(#z)
      elseif  @formula2 == 92
        tempform2 = sinh(#z) * cosh(#z)
      elseif  @formula2 == 93

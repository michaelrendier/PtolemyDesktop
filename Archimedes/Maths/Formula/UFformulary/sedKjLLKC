          else
            z = (0.5,1e30)
          endif ; bailiter
        elseif @type2 == 1 ; two-tone
          if bailiter[0] == bailiter[1]
            z = (0.1,1e30)
          else
            z = (0.9,1e30)
          endif ; bailiter
        endif ; @type2
      elseif @testpoints == 3

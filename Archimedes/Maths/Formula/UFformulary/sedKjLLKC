        tempform2 = zextra * zextra
      elseif  @formula2 == 84
        tempform2 = sinh(1/#z)
      elseif  @formula2 == 85
        tempform2 = cosh(1/#z)
      elseif  @formula2 == 86
        tempform2 = tanh(1/#z)
      elseif  @formula2 == 87

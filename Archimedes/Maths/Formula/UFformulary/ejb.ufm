Gnarlathotep3reversedver4 {
; Orig formula ottomagus
; Modified Evan Bayliss April 2022
; order of formulae groups reversed
; The "variant" section is alternately iterated with the garlic variations.
; Five gnarlic variations were chosen from the original thirty or so
; Any combination of five these can be selected
; The result of the first choice is the basis for the calculation of the second
; ... and so on

init:
float x= real(@fn1(pixel)/@r)
float y= imag(@fn1(pixel)/@r)
float a=0.0
int i=0
Count = -1
Count1 = 0
loop:
while i<@iter
  i=i+1
  a=x

  count = -count


 If @iterchoice == 0
 ; varying order of iterations variant first

   if count == 1

     ; Variant choice
     if @V1=="ident"
     z=(fn2(x+flip(y)))^@pow+p4
     elseif @V1=="exp"
     z=exp(fn2(x+flip(y)))^@pow+p4
     elseif @V1=="sqr"
     z=sqr(fn2(x+flip(y)))^@pow+p4
     elseif @V1=="cotan"
     z=cotan(fn2(x+flip(y)))^@pow+p4
     elseif @V1=="tan"

elseif @V2=="log cabs"
z=log(cabs(fn2(x+flip(y))))^@pow+p5
elseif @V2=="log abs"
z=log(abs(fn2(x+flip(y))))^@pow+p5
elseif @V2=="log cotan"
z=log(cotan(fn2(x+flip(y))))^@pow+p5
elseif @V2=="exp abs"
z=exp(abs(fn2(x+flip(y))))^@pow+p5
elseif @V2=="exp exp"
z=exp(exp(fn2(x+flip(y))))^@pow+p5
elseif @V2=="log log"
z=log(log(fn2(x+flip(y))))^@pow+p5
elseif @V2=="acos acos"
z=acos(acos(fn2(x+flip(y))))^@pow+p5
elseif @V2=="sqr sqr"

MandelbrotwithJuliacalcs8 {
; Evan Bayliss
; derived from Generic Mandelbrot set.
; This one uses alternating Mandel and Julia iterations
init:
  zm = zj = @start, juliacount = 0, mandelcount = 0, loopcount =0
loop:
 if @reverse == 0

 zj = zj^@power + @seed
 zj =zj + zm
  zm = zm^@power + #pixel
 zm = zm +zj

  zx = (zm * zj)/2


 elseif @reverse == 1

  zm = zm + zj
 zm = zm^@power + @seed

 zj = zj +zm
 zj = zj^@power + #pixel

 zx = (zm * zj)/2

 endif

bailout:
  |zx| <= @bailout
default:

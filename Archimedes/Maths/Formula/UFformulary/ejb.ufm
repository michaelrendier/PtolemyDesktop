endif
elseif @var1 =="6"
if i2==0
x=x-p4*real(tanh(y+sin(p2*(y+sin(p3*y)))))/10
y=y+p4*real(tanh(a+sin(p2*(a+sin(p3*a)))))/10
i2=i2+1
else

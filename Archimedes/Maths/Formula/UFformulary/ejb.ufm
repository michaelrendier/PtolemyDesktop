mt-halleygnarlEB1 {
; original gnarl Mark Townsend, 31 Dec 1999 version
;
; Evan Bayliss adjustments January 2025
;
; Halley formula incorporated, different bailout options
;
 init:
  z = 0
  p = #pixel / @scale
  float x = real(p)
  float y = imag(p)
  float xx = 0
  int iter = 0
loop:
  ; gnarl component
  iter = iter + 1
  xx = x
  x = x - @h * real(@fn1(y + @fn2(@a * (y + @fn3(@b * y)))))
  y = y + @h * real(@fn1(xx + @fn2(@a * (xx + @fn3(@b * xx)))))

  ; choice of flip options
  if @choice == 0
    z = x + flip(y)
  elseif @choice == 1
    if a == 0
    z = x + flip(y)
    a=1
    else
    z= flip(x) + y
    a= 0
    endif
  elseif @choice == 2
    if a == 0
    z = flip(x) + y
    a=1
    else
    z= x + flip(y)
    a= 0
    endif
  endif
; halley component
        if @halchoice == 1
        z5=z*z*z*z*z;
        z6=z*z5;
        z7=z*z6;
        z=z-p1*((z7-z)/ ((7.0*z6-1)-(42.0*z5)*(z7-z)/(14.0*z6-2)))
        endif
bailout:
  (@bchoice == 0 && iter < #maxiter) || (@bchoice == 1 && @bail <= |z7-z|) || @bchoice == 2 && ( iter < #maxiter || @bail <= |z7-z|)
default:
  title = "Halley Gnarl EB ver 1"
  maxiter = 20
  magn = 0.15
  param h
    caption = "Gnarl step size"
    default = 0.1
  endparam
  func fn1
    caption = "First Gnarl Function"
    default = sin()
  endfunc
  func fn2
    caption = "Second Gnarl  Function"
    default = sin()
  endfunc
  func fn3
    caption = "Third Gnarl Function"
    default = sin()
  endfunc
    param scale
    caption = "Halley Scale"
    default = 1.0
  endparam

  param a
    caption = "Alpha"
    default = 2.7
  endparam
  param b
    caption = "Beta"
    default = 2.7
  endparam


  int param choice
  caption = "Flip options"
  enum = "x + flip(y) only" "x + flip(y) alt with Flip(x) +y" "flip(x) + y alt with x + flip(y)"
  default = 0
  endparam
  int param halchoice
  caption = "Halley option"
  enum = "N" "Y"
  default = 0
  endparam
  complex param p1
        caption = "Halley constant p1"
        default = (-0.016889,-0.11822)
        visible = @halchoice == 1
  endparam

  float param bail
        caption = "Halley bailout value"
        default = 0.0001
        visible = @halchoice == 1
        endparam
  int param bchoice
  caption = "Bailout options"
  enum = "iter < #maxiter" "@bail <= |z7-z|" "iter < #maxiter || @bail <= |z7-z|"
  default = 0
  endparam
}

mt-halleygnarlEB3 {
; original gnarl Mark Townsend, 31 Dec 1999 version
;
; Evan Bayliss adjustments January 2025, Halley formula incorporated
;
; Either Halley or Gnarl are used as bailout for other formula
; Use "inside " colouring from outset

 init:
  ; for halley
  z = #pixel
  z1 = z
  ;for gnarl
  zg = 0
  p = #pixel / @scale
  float x = real(p)
  float y = imag(p)
  float xx = 0
  int iter = 0


loop:
  iter = iter + 1
  ; halley component
        z5=z1*z1*z1*z1*z1;
        z6=z1*z5;
        z7=z1*z6;
        zh=z1-p1*((z7-z1)/ ((7.0*z6-1)-(42.0*z5)*(z7-z1)/(14.0*z6-2)))

       ; gnarl component
        xx = x
        x = x - @h * real(@fn1(y + @fn2(@a * (y + @fn3(@b * y)))))
        y = y + @h * real(@fn1(xx + @fn2(@a * (xx + @fn3(@b * xx)))))


    ; choice of flip options
  if @choice == 0
    zg = x + flip(y)
  elseif @choice == 1
    if a == 0
    zg = x + flip(y)
    a=1
    else
    zg= flip(x) + y
    a= 0
    endif
  elseif @choice == 2
    if a == 0
    zg = flip(x) + y
    a=1
    else
    zg= x + flip(y)
    a= 0
    endif
  endif
  if @bchoice == 0 || @bchoice == 1
    ; halley gives bailout value
    if @halchoice == 0
    bail = |zh|
    else
    bail = |zh - z1|
    endif
    z = zg
  elseif @bchoice == 2 || @bchoice == 3
    ; gnarl give bailout value
    bail = |zg|
    z = zh
  endif

bailout:
  ((@bchoice == 0 || @bchoice == 2) && bail <= |z|) || ((@bchoice == 1 || @bchoice == 3) && bail > |z|)
default:
  title = "Halley Gnarl EB ver 3"
  maxiter = 20
  magn = 0.15
  param a
    caption = "Alpha"
    default = 2.7
  endparam
  param b
    caption = "Beta"
    default = 2.7
  endparam
  param h
    caption = "Step size"
    default = 0.1
  endparam
  param scale
    caption = "Scale"
    default = 1.0
  endparam
  func fn1
    caption = "First Function"
    default = sin()
  endfunc
  func fn2
    caption = "Second Function"
    default = sin()
  endfunc
  func fn3
    caption = "Third Function"
    default = sin()
  endfunc

  int param choice
  caption = "Flip options"
  enum = "x + flip(y) only" "x + flip(y) alt with Flip(x) +y" "flip(x) + y alt with x + flip(y)"
  default = 0
  endparam
  complex param p1
        caption = "Halley constant p1"
        default = (-0.016889,-0.11822)

  endparam

  int param halchoice
  caption = "halley bailout "
  enum = "Ver 1" "Ver 2"
  default = 0
  visible = @bchoice == 0 || @bchoice == 1
  endparam
  int param bchoice
  caption = "Bailout options"
  enum = "gnarl <= halley" "gnarl > halley" "halley <= gnarl" "halley > gnarl"
  default = 0
  endparam
}

mt-halleygnarlEB2 {
; original gnarl Mark Townsend, 31 Dec 1999 version
;
; Evan Bayliss adjustments January 2025
;
; Halley formula incorporated, different bailout options
; Here Halley comes here first

 init:
  if @halchoice == 1
  z = #pixel
  endif

  if @halchoice == 0
     ; if no halley formula, initialise for gnarl
     z = 0
     p = #pixel / @scale
     float x = real(p)
     float y = imag(p)
     float xx = 0
  endif
  int iter = 0
  float xx = 0
loop:
  iter = iter + 1
  ; halley component
        if @halchoice == 1
        z5=z*z*z*z*z;
        z6=z*z5;
        z7=z*z6;
        z=z-p1*((z7-z)/ ((7.0*z6-1)-(42.0*z5)*(z7-z)/(14.0*z6-2)))
        endif
  ; gnarl component
  if @halchoice == 1
  p = z / @scale
  float x = real(p)
  float y = imag(p)
  endif
  xx = x
  x = x - @h * real(@fn1(y + @fn2(@a * (y + @fn3(@b * y)))))
  y = y + @h * real(@fn1(xx + @fn2(@a * (xx + @fn3(@b * xx)))))

  ; choice of flip options
  if @choice == 0
    z = x + flip(y)
  elseif @choice == 1
    if a == 0
    z = x + flip(y)
    a=1
    else
    z= flip(x) + y
    a= 0
    endif
  elseif @choice == 2
    if a == 0
    z = flip(x) + y
    a=1
    else
    z= x + flip(y)
    a= 0
    endif
  endif

bailout:
  (@bchoice == 0 && iter < #maxiter) || (@bchoice == 1 && @bail <= |z7-z|) || @bchoice == 2 && ( iter < #maxiter || @bail <= |z7-z|)
default:
  title = "Halley Gnarl EB ver 2"
  maxiter = 20
  magn = 0.15
  param a
    caption = "Alpha"
    default = 2.7
  endparam
  param b
    caption = "Beta"
    default = 2.7
  endparam
  param scale
    caption = "Halley scale"
    default = 1.0
  endparam
  param h
    caption = "Gnarl step size"
    default = 0.1
  endparam

  func fn1
    caption = "First Gnarl Function"
    default = sin()
  endfunc
  func fn2
    caption = "Second Gnarl Function"
    default = sin()
  endfunc
  func fn3
    caption = "Third Gnarl Function"
    default = sin()
  endfunc

  int param choice
  caption = "Flip options"
  enum = "x + flip(y) only" "x + flip(y) alt with Flip(x) +y" "flip(x) + y alt with x + flip(y)"
  default = 0
  endparam
  int param halchoice
  caption = "Halley option"
  enum = "N" "Y"
  default = 0
  endparam
  complex param p1
        caption = "Halley constant p1"
        default = (-0.016889,-0.11822)
        visible = @halchoice == 1
  endparam

  float param bail
        caption = "Halley bailout value"
        default = 0.0001
        visible = @halchoice == 1
        endparam
  int param bchoice
  caption = "Bailout options"
  enum = "iter < #maxiter" "@bail <= |z7-z|" "iter < #maxiter || @bail <= |z7-z|"
  default = 0
  endparam
}

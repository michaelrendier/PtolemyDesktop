endparam

func fn2
caption="Post Function 2"
default=ident()
endfunc
param p5
caption="Post Function Parameter"
default=(0,0)
endparam
param pow
caption="Post Function Exponent"
default=(1,0)
endparam
param iter
caption="Iterations"
default=50
endparam

param w
caption = "Multiplier for final z"
default =51.0
endparam

param finalchoice

AltGnarlaMandelthotep2ver2 {
; The original altgnarlathotep formula is from Otto Magus - om2.ufm
; Evan Bayliss May 2021
; This version either concurrently iterates two formula and combines the results or -
; feeds the result of the the first formula into the second
; A Mandelbrot iteration can be selected or bypassed
; The pow variable is for the post function exponent, while power is for the Mandelbrot z power exponent
; Try iterations = 500 for interesting results

init:
float x=real(fn1(pixel))
float y=imag(fn1(pixel))
float a=0
int i=0
int i2=0
num = -1

loop:
  num = -num
  if num == 1
while i<@iter
i=i+1
float b=x^2+y^2
x=x/b*p6+real(p1/10)
y=y/b*p6+imag(p1/10)
x2=x
y2=y
a=x

if @vf1=="1"
if i2==0
x=x-p4*real(sin(y+sin(p2*(y+sin(p3*y)))))/10
y=y+p4*real(sin(a+sin(p2*(a+sin(p3*a)))))/10
i2=i2+1

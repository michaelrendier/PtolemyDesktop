MandelbrotAveraging4 {
;
; Evan Bayliss
; Mandelbrot set seeing what happens if z values are "averaged" .
;
init:
  z = initstart = @start, complex zlow = (0,0), complex zhigh = (0,0), float yy = 0
loop:
  z = z^@power + #pixel
  if z < zlow
   zlow = z
  elseif z > zhigh
   zhigh = z
  endif

  if @zchoice == 0
   yy = (|zhigh| + |zlow|)/2
  elseif @zchoice == 1
   yy = (|zhigh + zlow|)/2
  endif
bailout:
    yy <= @bailout

default:
  title = "MandelbrotAveraging4"
  center = (-0.5, 0)
  helpfile = "Uf*.chm"
  helptopic = "Html\formulas\standard\mandelbrot.html"

AltGnarlaMandelthotep2 {
; The original altgnarlathotep formula is from Otto Magus - om2.ufm
; Modified Evan Bayliss
; This have been combined with Mandelbrot formula - a gnarlic iteration is alternated with a Mandelbrot iteration
; The pow variable is for the post function exponent, while power is for the Mandelbrot z power exponent
; Try iterations = 500 for intersting results

init:
float x=real(fn1(pixel))
float y=imag(fn1(pixel))
float a=0
int i=0
int i2=0
num = -1

loop:
  num = -num
  if num == 1
while i<@iter
i=i+1

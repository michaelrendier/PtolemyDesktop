   z = z^@power +pix1+(pix2+pix3+pix4+pix5+pix6)
  z = z^@power +z1 -(z2+z3+z4+z5+z6)

   elseif @choice == 3
   z = z^@power + pix1-(pix2+pix3+pix4+pix5+pix6)
   z = z^@power +z1+z2+z3+z4+z5+z6

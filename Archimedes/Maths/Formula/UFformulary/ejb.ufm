endif
; First post function
if @pf1a=="ident"
za=(fn2(x+flip(y)))^@pow+p5
elseif @pf1a=="exp"
za=exp(fn2(x+flip(y)))^@pow+p5
elseif @pf1a=="sqr"
za=sqr(fn2(x+flip(y)))^@pow+p5
elseif @pf1a=="cotan"

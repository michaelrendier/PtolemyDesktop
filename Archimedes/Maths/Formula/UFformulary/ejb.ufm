MandelbrotwithJuliacalcs4 {
;
; Evan Bayliss
;Another group of mixed Mandelbrot and Julia formulae
init:
  z = zz = @start, count = 1
loop:
 if @choice == 0
 	  z = z^@power + #pixel/count
 	  z = z^@power + @sfunc(@seed*count)
 	  count = count + 1
 elseif @choice == 1 
   	  zz = zz^@power + @seed
	  z = z^@power + zz + #pixel
 elseif @choice == 2
 	  z = z^@power + zz + #pixel
       zz = zz^@power + @seed
 endif

bailout:
  |z| <= @bailout

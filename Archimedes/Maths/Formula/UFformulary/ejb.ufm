zb=exp(exp(fn2(x+flip(y))))^@pow+p5
elseif @pf1b=="log log"
zb=log(log(fn2(x+flip(y))))^@pow+p5
elseif @pf1b=="acos acos"
zb=acos(acos(fn2(x+flip(y))))^@pow+p5
elseif @pf1b=="sqr sqr"
zb=sqr(sqr(fn2(x+flip(y))))^@pow+p5
elseif @pf1b=="tan sin"
zb=tan(sin(fn2(x+flip(y))))^@pow+p5
elseif @pf1b=="ceil round"
zb=ceil(round(fn2(x+flip(y))))^@pow+p5
elseif @pf1b=="log cos"
zb=log(cos(fn2(x+flip(y))))^@pow+p5
endif

if @pf1c=="ident"
zc=(fn2(x+flip(y)))^@pow+p5
elseif @pf1c=="exp"
zc=exp(fn2(x+flip(y)))^@pow+p5
elseif @pf1c=="sqr"
zc=sqr(fn2(x+flip(y)))^@pow+p5
elseif @pf1c=="cotan"
zc=cotan(fn2(x+flip(y)))^@pow+p5
elseif @pf1c=="tan"
zc=tan(fn2(x+flip(y)))^@pow+p5
elseif @pf1c=="acos"
zc=acos(fn2(x+flip(y)))^@pow+p5
elseif @pf1c=="log cabs"
zc=log(cabs(fn2(x+flip(y))))^@pow+p5
elseif @pf1c=="log abs"
zc=log(abs(fn2(x+flip(y))))^@pow+p5
elseif @pf1c=="log cotan"
zc=log(cotan(fn2(x+flip(y))))^@pow+p5
elseif @pf1c=="exp abs"
zc=exp(abs(fn2(x+flip(y))))^@pow+p5
elseif @pf1c=="exp exp"

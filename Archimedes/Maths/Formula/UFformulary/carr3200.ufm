  d=sqrt(1/pixel2-conj(cos(1/pixel2)))
  b3=cabs(pixel2)-conj(cos(pixel2^4))-conj(.1/pixel2^3)
  z=abs(pixel2^10)-conj(.1/b3-flip(.0075/b3)) \
     -conj(.065/pixel2-flip(.01/pixel2))-.3
  b4=cabs(z/2.5)-conj(.1/pixel2-flip(.01/pixel2))
  IF (@p3==1)

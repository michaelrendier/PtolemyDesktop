Carr3228 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  d=sqrt(1/pixel2-conj(cos(1/pixel2)))
  z=conj(pixel2)*abs(pixel2)*flip(pixel2^4) \
    -conj(.01/pixel2-flip(.001/pixel2))+.15
  b4=conj(sinh(cabs(z/2.5)))-conj(.1/pixel2-flip(.01/pixel2))
  IF (@p3==1)
    c = conj(b4)
  ELSEIF (@p3==0)
    c = -conj(b4)^3, z = -z
  ELSE
    IF (whitesq)
      c = conj(b4)
    ELSE
      c = -conj(b4)^3, z = -z
    ENDIF
  ENDIF
  dterm = flip(abs(d/70*pixel2))
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = c1, z = 0
  ELSEIF (iter==l2)
    c = c2, z = 0
  ELSEIF (iter==l3)
    c = c3, z = 0
  ELSEIF (iter==l4)
    c = c4, z = 0
  ENDIF
  z=(c*(z*z*(z*z-3.5)+2+c))-dterm
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3228"
  periodicity = 0
  maxiter = 700
  magn = 1.3
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"

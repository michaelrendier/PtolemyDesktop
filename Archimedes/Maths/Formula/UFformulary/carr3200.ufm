Carr3234 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  d=sqrt(1/pixel2-conj(cos(1/pixel2)))
  z=cabs(pixel2^6)-pixel2*((.3,.6)+pixel2)-conj(.09/pixel2)-.3
  c=cabs(z/2.5)-conj(.1/pixel2-flip(.01/pixel2))-.075
  IF (@p3==0)
    c = -c, z = -(z^2)
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -c, z = -(z^2)
    ENDIF
  ENDIF
  zmult = 3/(c+2)
  cp = conj(.1/pixel2)
  dterm = flip(|d/70*pixel2|)
  zmod = (cp+1)/(c+2)
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    zmult=3/(c1+2), zmod=(cp+1)/(c1+2), z=0
  ELSEIF (iter==l2)
    zmult=3/(c2+2), zmod=(cp+1)/(c2+2), z=0
  ELSEIF (iter==l3)
    zmult=3/(c3+2), zmod=(cp+1)/(c3+2), z=0
  ELSEIF (iter==l4)
    zmult=3/(c4+2), zmod=(cp+1)/(c4+2), z=0
  ENDIF
  z = zmult*z^2 - zmod + dterm
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3234"
  periodicity = 0
  maxiter = 700
  magn = 1.5
  center = (0,-.1)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}


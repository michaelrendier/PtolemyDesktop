Carr3242 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  b1=cosh(cos(pixel2))
  b2=conj(cos(cosh(pixel2)))
  b6=(cabs(pixel2)*conj(flip(pixel2))+.15)/b2
  z=pixel2^6-conj(.001/b1-flip(.001/b2-conj(.001/b6)))-.35
  c=pixel2/2-conj(.01/b1-flip(.01/b2-conj(.01/b6)))+.1
  IF (@p3==0)
    c = -c, z = -z
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -c, z = -z
    ENDIF
  ENDIF
  con = (-.7456,-.132)+sqr(.1/pixel2)
  cterm = conj(c/8) + con
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = c1, z = 0, cterm = conj(c1/8) + con
  ELSEIF (iter==l2)
    c = c2, z = 0, cterm = conj(c2/8) + con
  ELSEIF (iter==l3)
    c = c3, z = 0, cterm = conj(c3/8) + con
  ELSEIF (iter==l4)
    c = c4, z = 0, cterm = conj(c4/8) + con
  ENDIF
  z=(c*z*z)/(conj(z+c))+cterm
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3242"
  periodicity = 0
  maxiter = 700
  magn = 1
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}


    c = c2, cterm = 2+imag(c), cterm2 = .001/c, z = 0
  ELSEIF (iter==l3)
    c = c3, cterm = 2+imag(c), cterm2 = .001/c, z = 0
  ELSEIF (iter==l4)
    c = c4, cterm = 2+imag(c), cterm2 = .001/c, z = 0
  ENDIF
  z=(c*(z*z*(z*z-3.5)+cterm))-dterm-cterm2
  iter=iter+1
bailout:
  |z|<=bailout
default:

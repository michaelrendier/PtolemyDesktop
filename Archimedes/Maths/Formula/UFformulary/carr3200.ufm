  d=sqrt(1/pixel2-conj(cos(1/pixel2)))
  c=abs(pixel2^2)*conj(flip(pixel2^3))
  b5=pixel2^3*cabs(pixel2^4)-flip(.01/pixel2)-conj(.01/pixel2)-.2
  IF (@p3==1)
    z = (b5)^.75
  ELSEIF (@p3==0)
    c = -c, z = -(b5)
  ELSE
    IF (whitesq)
      z = (b5)^.75
    ELSE
      c = -c, z = -(b5)
    ENDIF
  ENDIF
  dterm = flip(|d/70*pixel2|)
  cmod = c + dterm
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    cmod = c1 + dterm, z = 0
  ELSEIF (iter==l2)
    cmod = c2 + dterm, z = 0
  ELSEIF (iter==l3)
    cmod = c3 + dterm, z = 0
  ELSEIF (iter==l4)
    cmod = c4 + dterm, z = 0
  ENDIF
  z=z^2+cmod
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3250"
  periodicity = 0
  maxiter = 700
  magn = 1.4
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}


Carr3210 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  d=sqrt(1/pixel2-conj(cos(1/pixel2)))
  b4=pixel2^4/tanh(.3/pixel2)+flip(.1/pixel2)
  b5=conj(b4^6)-conj(.1/pixel2-flip(.01/pixel2))-.25
  IF (@p3==1)
    c = cabs(b4), z = sqr(b5)
  ELSEIF (@p3==0)
    c = -sqr(b4), z = -conj(b5)
  ELSE
    IF (whitesq)
      c = cabs(b4), z = sqr(b5)
    ELSE
      c = -sqr(b4), z = -conj(b5)
    ENDIF
  ENDIF
  zmod = |.1/pixel2|
  dterm = -flip(|.01/pixel2|) + flip(|d/80*pixel2|)
  cmod = c + dterm
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    cmod = c1 + dterm, z = 0
  ELSEIF (iter==l2)
    cmod = c2 + dterm, z = 0
  ELSEIF (iter==l3)
    cmod = c3 + dterm, z = 0
  ELSEIF (iter==l4)
    cmod = c4 + dterm, z = 0
  ENDIF
  z = (z+zmod)^2 + cmod
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3210"
  periodicity = 0
  maxiter = 700
  magn = 1.8
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \

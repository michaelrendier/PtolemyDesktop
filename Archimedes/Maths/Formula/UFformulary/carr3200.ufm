Carr3273 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  d=sqrt(1/pixel2-conj(cos(1/pixel2)))
  c=conj(pixel2^4-sinh(.007/pixel2))
  m4=conj(.005/pixel2)-sqr(flip(.09/pixel2))
  z=conj(1/acos(1-pixel2))*pixel2^4-m4-conj(.008/pixel2)-.1
  IF (@p3==0)
    c = -c, z = -z
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -c, z = -z
    ENDIF
  ENDIF
  dterm = flip(abs(d/30*pixel2))
  conterm = .09 + .025/pixel2
  cterm = .875*c + conterm - dterm
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    z = 0, cterm = .875*c1 + conterm - dterm
  ELSEIF (iter==l2)
    z = 0, cterm = .875*c2 + conterm - dterm
  ELSEIF (iter==l3)
    z = 0, cterm = .875*c3 + conterm - dterm
  ELSEIF (iter==l4)
    z = 0, cterm = .875*c4 + conterm - dterm
  ENDIF
  z=(|z/6|)+z*z+cterm
  iter=iter+1
bailout:
  |z|<=bailout
default:

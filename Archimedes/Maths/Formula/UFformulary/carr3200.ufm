Carr3260 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  d=sqrt(1/pixel2-conj(cos(1/pixel2)))
  c=abs(pixel2^2)*conj(flip(pixel2^3))
  b5=pixel2^3*cabs(pixel2^4)-flip(.01/pixel2) \
     -conj(.01/pixel2)-|.0175/pixel2|-.2
  IF (@p3==1)
    z = (b5)^.75
  ELSEIF (@p3==0)
    c = -c, z = -(b5)
  ELSE
    IF (whitesq)
      z = (b5)^.75
    ELSE
      c = -c, z = -(b5)
    ENDIF
  ENDIF
  dterm = (-.7456,-.132)+flip(|d/80*pixel2|)
  cterm = |c/12| + dterm
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    cterm = |c1/12| + dterm, z = 0
  ELSEIF (iter==l2)
    cterm = |c2/12| + dterm, z = 0
  ELSEIF (iter==l3)
    cterm = |c3/12| + dterm, z = 0
  ELSEIF (iter==l4)
    cterm = |c4/12| + dterm, z = 0
  ENDIF
  z=z^2+cterm
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3260"
  periodicity = 0
  maxiter = 700
  magn = 1.4
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)

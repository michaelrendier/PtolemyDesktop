    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr3298 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  b10=flip(pixel2^3)*pixel2^4/sinh(.3/pixel2)
  c=abs(pixel2^2)*conj(flip(pixel2^3))-.01/pixel2
  b5=pixel2^2*flip(c/pi)*conj(b10)^3-conj(.0155/pixel2) \
     -flip(.025/pixel2)+.005/pixel2-.17
  IF (@p3==1)
    z = (b5)^.75
  ELSEIF (@p3==0)
    c = -c, z = -(b5)/2
  ELSE
    IF (whitesq)
      z = (b5)^.75
    ELSE
      c = -c, z = -(b5)/2
    ENDIF
  ENDIF
  c = (c-.24)*13/12
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = c1*13/12, z = 0
  ELSEIF (iter==l2)
    c = c2*13/12, z = 0
  ELSEIF (iter==l3)
    c = c3*13/12, z = 0
  ELSEIF (iter==l4)
    c = c4*13/12, z = 0
  ENDIF
  z=z*z+c
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3298"
  periodicity = 0
  maxiter = 700
  magn = 1.5
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr3299 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  b6=conj(.015/pixel2), b7=flip(.025/pixel2)
  b8=sin(.002/pixel2-flip(.002/pixel2))
  b10=pixel2^10-conj(.01/pixel2-flip(.15/pixel2))
  c=abs(pixel2^2)*b10-.01/pixel2
  b5=pixel2^2*abs(b10)^2*conj(cos(.1-c))-b8-b6-b7-.002/pixel2-.19
  IF (@p3==1)
    z = (b5)^.745
  ELSEIF (@p3==0)
    c = -c, z = -(b5)/2
  ELSE
    IF (whitesq)
      z = (b5)^.745
    ELSE
      c = -c, z = -(b5)/2
    ENDIF
  ENDIF
  dterm = .015 + (b7*b6)^3/1.5
  c = c - .24 - dterm
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = c1 - dterm, z = 0
  ELSEIF (iter==l2)
    c = c2 - dterm, z = 0
  ELSEIF (iter==l3)
    c = c3 - dterm, z = 0
  ELSEIF (iter==l4)
    c = c4 - dterm, z = 0
  ENDIF
  z=z*z+c
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3299"
  periodicity = 0
  maxiter = 700
  magn = 1.4
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

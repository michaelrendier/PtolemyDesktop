  ELSEIF (iter==l3)
    c = c3, z = 0
  ELSEIF (iter==l4)
    c = c4, z = 0
  ENDIF
  z=(c*(z*z*(z*z-3.5)+2+c))-dterm
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3232"
  periodicity = 0
  maxiter = 500
  magn = 1.5
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"

comment {
  Carr3200.ufm Version 1.4
  Ultra Fractal conversions of Robert Carr's formulas Carr3200 - Carr3299
  by Erik Reckase, February 28, 2000

  History:  Version 1.4 - Minor optimization tweaks + cleanup

            Version 1.3 - Major optimization overhaul
            
            Version 1.2 - Modified whitesq code to eliminate warnings

            Version 1.1 - fixed exact Fractint functionality in order
                          and variable fixes below

            Version 1.0 - Initial Release
                          Original formulas pulled from 43cCarr.frm
                                                        43dCarr.frm
                                                        43eCarr.frm
                          Carr3200-3299            : pixel fix
                          Carr3265-3269,3296-3297  : |z| fix
                          Carr3281,3285,3292,3293  : statements out of order
                          Carr3282                 : Undefined variable
                          Carr3214,3284            : missing parentheses
}

Carr3200 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  d=log(1/pixel2-conj(cos(1/pixel2)))
  c=pixel2^3-1/(atan(.1/pixel2)-cabs(acos(.2/pixel2)))
  z=conj(c)-.54, zmod = (-.7456,-.132)+ flip(|d/80*pixel2|)
  cmod = |c/7.5| + zmod
  c1=1.5*z^1.2,c2=2.25*conj(z)
  c3=3.375*flip(z),c4=5.0625*flip(z)
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    cmod = |c1/7.5| + zmod, z = 0
  ELSEIF (iter==l2)
    cmod = |c2/7.5| + zmod, z = 0
  ELSEIF (iter==l3)
    cmod = |c3/7.5| + zmod, z = 0
  ELSEIF (iter==l4)
    cmod = |c4/7.5| + zmod, z = 0
  ENDIF
  z = z^2 + cmod
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3200"
  periodicity = 0
  maxiter = 700
  magn = 1.4
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
}

Carr3201 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  d=log(1/pixel2-conj(cos(1/pixel2)))
  c=pixel2-conj(.1/pixel2-flip(.01/pixel2))
  z=conj(abs(pixel2))^5-.5/(conj(atan(0.1/pixel2)) \
     -cabs(acos(.2/pixel2)))+.35
  zmod = (-.7456,-.132) + flip(|d/80*pixel2|)
  cmod = |c/7.5| + zmod
  c1=1.5*z^1.2,c2=2.25*conj(z)
  c3=3.375*flip(z),c4=5.0625*flip(z)
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    cmod = |c1/7.5| + zmod, z = 0
  ELSEIF (iter==l2)
    cmod = |c2/7.5| + zmod, z = 0
  ELSEIF (iter==l3)
    cmod = |c3/7.5| + zmod, z = 0
  ELSEIF (iter==l4)
    cmod = |c4/7.5| + zmod, z = 0
  ENDIF
  z = z^2 + cmod
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3201"
  periodicity = 0
  maxiter = 700
  magn = 1.4
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
}

Carr3202 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  d=log(1/pixel2-conj(cos(1/pixel2)))
  c=pixel2^3-conj(.1/pixel2-flip(.01/pixel2))
  z=abs(pixel2^12)-flip(.01/pixel2)-conj(.1/pixel2)+.3
  zmod = (-.7456,-.132) + flip(|d/80*pixel2|)
  cmod = |c/7.5| + zmod
  c1=1.5*z^1.2,c2=2.25*conj(z)
  c3=3.375*flip(z),c4=5.0625*flip(z)
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    cmod = |c1/7.5| + zmod, z = 0
  ELSEIF (iter==l2)
    cmod = |c2/7.5| + zmod, z = 0
  ELSEIF (iter==l3)
    cmod = |c3/7.5| + zmod, z = 0
  ELSEIF (iter==l4)
    cmod = |c4/7.5| + zmod, z = 0
  ENDIF
  z = z^2 + cmod
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3202"
  periodicity = 0
  maxiter = 700
  magn = 1.4
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
}

Carr3203 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  d=sqrt(1/pixel2-conj(cos(1/pixel2)))
  b3=conj(.1/pixel2-flip(.01/pixel2))
  b4=conj(conj(pixel2/2)*sin(abs(pixel2/3)))*flip(pixel2^6) \
     -conj(.1/pixel2+b3)+.15
  z=conj(conj(pixel2/2)*sin(abs(pixel2/3)))*conj(pixel2^6)-b3+.13
  IF (@p3==1)
    c = (b4^2)
  ELSEIF (@p3==0)
    c = -(b4), z = -z
  ELSE
    IF (whitesq)
      c = (b4^2)
    ELSE
      c = -(b4), z = -z
    ENDIF
  ENDIF
  zmod = flip(abs(d/70*pixel2))
  cmod = 2*c + c^2 - zmod
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = c1, cmod = 2*c + c^2 - zmod, z = 0
  ELSEIF (iter==l2)
    c = c2, cmod = 2*c + c^2 - zmod, z = 0
  ELSEIF (iter==l3)
    c = c3, cmod = 2*c + c^2 - zmod, z = 0
  ELSEIF (iter==l4)
    c = c4, cmod = 2*c + c^2 - zmod, z = 0
  ENDIF
  z = z^2*(z^2-3.5)*c + cmod
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3203"
  periodicity = 0
  maxiter = 500
  magn = 1.2
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (200,250)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr3204 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  d=sqrt(1/pixel2-conj(cos(1/pixel2)))
  b3=conj(.1/pixel2-flip(.01/pixel2))
  z=conj(conj(pixel2/2)*sin(abs(pixel2/3)))*conj(pixel2^8) \
    -b3+.1+conj(.01/pixel2)
  b6=z/2.5-conj(.01/pixel2)
  b4=b6-0.2*(conj(flip(pixel2/2)*sin(abs(pixel2/3))) \
     *flip(pixel2^6)-conj(.1/pixel2+b3)+.2)
  IF (@p3==1)
    c = (b4^2)
  ELSEIF (@p3==0)
    c = -conj(b4), z = -z
  ELSE
    IF (whitesq)
      c = (b4^2)
    ELSE
      c = -conj(b4), z = -z
    ENDIF
  ENDIF
  zmod = flip(abs(d/70*pixel2))
  cmod = 2*c + c^2 - zmod
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = c1, cmod = 2*c + c^2 - zmod, z = 0
  ELSEIF (iter==l2)
    c = c2, cmod = 2*c + c^2 - zmod, z = 0
  ELSEIF (iter==l3)
    c = c3, cmod = 2*c + c^2 - zmod, z = 0
  ELSEIF (iter==l4)
    c = c4, cmod = 2*c + c^2 - zmod, z = 0
  ENDIF
  z = z^2*(z^2-3.5)*c + cmod
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3204"
  periodicity = 0
  maxiter = 500
  magn = 1.2
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (200,250)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr3205 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  d=sqrt(1/pixel2-conj(cos(1/pixel2)))
  b3=conj(.1/pixel2-flip(.01/pixel2))
  z=conj(abs(pixel2/2)*sin(abs(pixel2/3)))*conj(pixel2^4) \
    -b3+conj(.01/pixel2)-0.125
  b6=pixel2^3-b3
  c=b6-.2*(conj(flip(pixel2/2)*sin(abs(pixel2/3))) \
    *flip(pixel2^6)-conj(.1/pixel2+b3)-.15)
  zmod = (-.7456,-.132) + flip(|d/80*pixel2|)
  cmod = |c/7.5| + zmod
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    cmod = |c1/7.5| + zmod, z = 0
  ELSEIF (iter==l2)
    cmod = |c2/7.5| + zmod, z = 0
  ELSEIF (iter==l3)
    cmod = |c3/7.5| + zmod, z = 0
  ELSEIF (iter==l4)
    cmod = |c4/7.5| + zmod, z = 0
  ENDIF
  z = z^2 + cmod
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3205"
  periodicity = 0
  maxiter = 700
  magn = 1
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
}

Carr3206 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  d=sqrt(1/pixel2-conj(cos(1/pixel2)))
  c=pixel2/2-conj(.01/pixel2-flip(.001/pixel2))
  z=conj(conj(abs(pixel2))^5-.5/(conj(atan(.01/pixel2)) \
     -cabs(acos(.02/pixel2))))-.235
  IF (@p3==0)
    c = -(c^2), z = -z
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -(c^2), z = -z
    ENDIF
  ENDIF
  zmod = flip(abs(d/70*pixel2))
  cmod = 2*c + c^2 - zmod
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = c1, cmod = 2*c + c^2 - zmod, z = 0
  ELSEIF (iter==l2)
    c = c2, cmod = 2*c + c^2 - zmod, z = 0
  ELSEIF (iter==l3)
    c = c3, cmod = 2*c + c^2 - zmod, z = 0
  ELSEIF (iter==l4)
    c = c4, cmod = 2*c + c^2 - zmod, z = 0
  ENDIF
  z = z^2*(z^2-3.5)*c + cmod
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3206"
  periodicity = 0
  maxiter = 700
  magn = 1.5
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr3207 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  d=sqrt(1/pixel2-conj(cos(1/pixel2)))
  c=(.37,-.3101)-flip(.1/pixel2)
  z=cabs(cabs(pixel2/2)*tan(cabs(pixel2/3))) \
    *conj(abs(pixel2^3))-conj(.1/pixel2)
  IF (@p3==0)
    c = -c, z = -z
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -c, z = -z
    ENDIF
  ENDIF
  zmod = |.1/pixel2|
  dterm = -flip(.1/pixel2) + flip(|d/80*pixel2|)
  cmod = c + dterm
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    cmod = c1 + dterm, z = 0
  ELSEIF (iter==l2)
    cmod = c2 + dterm, z = 0
  ELSEIF (iter==l3)
    cmod = c3 + dterm, z = 0
  ELSEIF (iter==l4)
    cmod = c4 + dterm, z = 0
  ENDIF
  z = (z+zmod)^2 + cmod
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3207"
  periodicity = 0
  maxiter = 700
  magn = 1
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr3208 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  d=sqrt(1/pixel2-conj(cos(1/pixel2)))
  b4=pixel2^4/tanh(.3/pixel2)+.1/pixel2
  b5=conj(b4^6)-conj(.1/pixel2-flip(.01/pixel2))-.25
  IF (@p3==1)
    c = cabs(b4), z = sqr(b5)
  ELSEIF (@p3==0)
    c = -sqr(b4), z = -conj(b5)
  ELSE
    IF (whitesq)
      c = cabs(b4), z = sqr(b5)
    ELSE
      c = -sqr(b4), z = -conj(b5)
    ENDIF
  ENDIF
  zmod = |.1/pixel2|
  dterm = -flip(|.01/pixel2|) + flip(|d/80*pixel2|)
  cmod = c + dterm
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    cmod = c1 + dterm, z = 0
  ELSEIF (iter==l2)
    cmod = c2 + dterm, z = 0
  ELSEIF (iter==l3)
    cmod = c3 + dterm, z = 0
  ELSEIF (iter==l4)
    cmod = c4 + dterm, z = 0
  ENDIF
  z = (z+zmod)^2 + cmod
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3208"
  periodicity = 0
  maxiter = 700
  magn = 1.8
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr3209 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  d=sqrt(1/pixel2-conj(cos(1/pixel2)))
  b4=pixel2^3/tanh(.3/pixel2)+.1/pixel2
  b5=cabs(b4^6)-conj(.1/pixel2-flip(.01/pixel2))^.75-.25
  IF (@p3==1)
    c = cabs(b4), z = sqr(b5)
  ELSEIF (@p3==0)
    c = -sqr(b4), z = -conj(b5)
  ELSE
    IF (whitesq)
      c = cabs(b4), z = sqr(b5)
    ELSE
      c = -sqr(b4), z = -conj(b5)
    ENDIF
  ENDIF
  zmod = |.1/pixel2|
  dterm = -flip(|.01/pixel2|) + flip(|d/80*pixel2|)
  cmod = c + dterm
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    cmod = c1 + dterm, z = 0
  ELSEIF (iter==l2)
    cmod = c2 + dterm, z = 0
  ELSEIF (iter==l3)
    cmod = c3 + dterm, z = 0
  ELSEIF (iter==l4)
    cmod = c4 + dterm, z = 0
  ENDIF
  z = (z+zmod)^2 + cmod
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3209"
  periodicity = 0
  maxiter = 500
  magn = 1.8
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam

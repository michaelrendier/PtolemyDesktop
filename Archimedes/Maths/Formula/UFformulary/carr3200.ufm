  ELSEIF (iter==l3)
    cterm = .875*c3 + conterm, z = 0
  ELSEIF (iter==l4)
    cterm = .875*c4 + conterm, z = 0
  ENDIF
  z = |z/6| + z^2 + cterm
  iter=iter+1
bailout:
  |z|<=bailout
default:

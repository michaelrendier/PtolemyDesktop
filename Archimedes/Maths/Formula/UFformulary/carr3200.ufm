Carr3214 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  z=conj(pixel2^5)*abs(pixel2)*pixel2-conj(.1/pixel2) \
    -flip(.0051/pixel2)^4-.3
  c=conj(z-flip(.1/pixel2))
  IF (@p3==0)
    c = -(c), z = -sqr(z)
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -(c), z = -sqr(z)
    ENDIF
  ENDIF
  zterm = 3/(c+2)
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    zterm = 3/(c1+2), z = 0
  ELSEIF (iter==l2)
    zterm = 3/(c2+2), z = 0
  ELSEIF (iter==l3)
    zterm = 3/(c3+2), z = 0
  ELSEIF (iter==l4)
    zterm = 3/(c4+2), z = 0
  ENDIF
  z = zterm*(z^2-.5)
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3214"
  periodicity = 0
  maxiter = 700
  magn = 1.4
  center = (0,.07)
  method = multipass
  param p1

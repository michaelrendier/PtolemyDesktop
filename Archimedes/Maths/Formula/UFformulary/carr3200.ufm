Carr3220 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel)), op = .1/pixel2
  d=sqrt(1/pixel2-conj(cos(1/pixel2))), z=pixel2^6+.15
  c=1.2*|pixel2/.75|^5+conj(op+flip(.01/pixel2))
  IF (@p3==0)
    c = -c, z = -conj(abs(z-conj(op)))
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -c, z = -conj(abs(z-conj(op)))
    ENDIF
  ENDIF
  zterm = 3.5 + flip(op)
  dterm = flip(|d/80*pixel2|)
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = c1, z = 0
  ELSEIF (iter==l2)
    c = c2, z = 0
  ELSEIF (iter==l3)
    c = c3, z = 0
  ELSEIF (iter==l4)
    c = c4, z = 0
  ENDIF
  z=(c*(z*z*(z*z-zterm)+2))+dterm
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3220"
  periodicity = 0
  maxiter = 700
  magn = 2
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"

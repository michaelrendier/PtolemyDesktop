Carr3274 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  d=sqrt(1/pixel2-conj(cos(1/pixel2)))
  b3=exp(.0045/pixel2)/conj(cos(.1-pixel2))-conj(.01/pixel2)
  c=abs(pixel2^2)*conj(flip(pixel2^3))
  b5=pixel2^3*cabs(pixel2^4)-flip(.01/pixel2) \
     -conj(.01/pixel2)+conj(.0095/b3)-.2
  IF (@p3==1)
    z = (b5)^.75
  ELSEIF (@p3==0)
    c = -c, z = -(b5)
  ELSE
    IF (whitesq)
      z = (b5)^.75
    ELSE
      c = -c, z = -(b5)
    ENDIF
  ENDIF
  dterm = flip(|d/70*pixel2|) + .125
  c = c + dterm
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = c1 + dterm, z = 0
  ELSEIF (iter==l2)
    c = c2 + dterm, z = 0
  ELSEIF (iter==l3)
    c = c3 + dterm, z = 0
  ELSEIF (iter==l4)
    c = c4 + dterm, z = 0
  ENDIF
  z=z*z+c
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3274"
  periodicity = 0
  maxiter = 700
  magn = 1.4
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"

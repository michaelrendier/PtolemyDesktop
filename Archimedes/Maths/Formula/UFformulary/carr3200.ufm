Carr3255 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  d=sqrt(1/pixel2-conj(cos(1/pixel2)))
  c=abs(pixel2^2)*conj(flip(pixel2^3))-cabs(0.04/pixel2)
  z=pixel2^3*cabs(pixel2^4)-flip(.01/pixel2)-conj(.01/pixel2)-.2
  IF (@p3==0)
    c = -conj(c), z = -z
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -conj(c), z = -z
    ENDIF
  ENDIF
  cterm = 2+imag(c)
  cterm2 = .001/c
  dterm = flip(abs(d/30*pixel2))
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = c1, cterm = 2+imag(c), cterm2 = .001/c, z = 0
  ELSEIF (iter==l2)
    c = c2, cterm = 2+imag(c), cterm2 = .001/c, z = 0
  ELSEIF (iter==l3)
    c = c3, cterm = 2+imag(c), cterm2 = .001/c, z = 0
  ELSEIF (iter==l4)
    c = c4, cterm = 2+imag(c), cterm2 = .001/c, z = 0
  ENDIF
  z=(c*(z*z*(z*z-3.5)+cterm))-dterm-cterm2
  iter=iter+1
bailout:
  |z|<=bailout
default:

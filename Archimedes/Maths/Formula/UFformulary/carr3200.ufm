Carr3241 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  d=sqrt(1/pixel2-conj(cos(1/pixel2)))
  b1=cosh(cos(pixel2))
  b2=conj(cos(cosh(pixel2)))
  b6=(cabs(pixel2)*conj(flip(pixel2))+.15)/b2
  b8=conj(.01/b1-flip(.01/b2-conj(.01/b6)))
  z=pixel2^6-b8+.25, c=pixel2/2-b8
  IF (@p3==0)
    c = -c, z = -z
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -c, z = -z
    ENDIF
  ENDIF
  cterm = 2+imag(c)
  dterm = flip(abs(d/70*pixel2))
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = c1, cterm = 2+imag(c), z = 0
  ELSEIF (iter==l2)
    c = c2, cterm = 2+imag(c), z = 0
  ELSEIF (iter==l3)
    c = c3, cterm = 2+imag(c), z = 0
  ELSEIF (iter==l4)
    c = c4, cterm = 2+imag(c), z = 0
  ENDIF
  z=(c*(z*z*(z*z-3.5)+cterm))-dterm
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3241"
  periodicity = 0
  maxiter = 700
  magn = 1.6
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)

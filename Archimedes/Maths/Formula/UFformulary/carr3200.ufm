}

Carr3231 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  d=sqrt(1/pixel2-conj(cos(1/pixel2)))
  b3=cabs(pixel2/2)-pixel2*((.3,.6)+pixel2)-conj(.1/pixel2)
  z=pixel2^5-conj(.1/b3-flip(.01/b3)) \
    -conj(.1/pixel2-flip(.01/pixel2))-.25
  c=z+.25
  dterm = (-.7456,-.132) + flip(|d/80*pixel2|)
  cterm = |c/7.5| + dterm
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    cterm = |c1/7.5| + dterm, z = 0
  ELSEIF (iter==l2)
    cterm = |c2/7.5| + dterm, z = 0
  ELSEIF (iter==l3)
    cterm = |c3/7.5| + dterm, z = 0
  ELSEIF (iter==l4)
    cterm = |c4/7.5| + dterm, z = 0
  ENDIF
  z=z^2+cterm
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3231"
  periodicity = 0
  maxiter = 700
  magn = 1.4
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
}


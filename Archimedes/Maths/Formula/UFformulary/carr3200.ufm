  c=abs(pixel2^2)*conj(flip(pixel2^3))-cabs(.045/pixel2)+.075
  z=pixel2^3*flip(conj(sinh(pixel2^4)))-flip(.01/pixel2) \
     -conj(.01/pixel2)-.2

  c=pixel2^4/tanh(.3/pixel2)+.1/pixel2
  b9=conj(.0033/c*b8^2-flip(.0033/c*b8)), b10=cos(c+b9)
  b5=(c+pixel2)*(flip(pixel2-b9^2)^2*conj(pixel2^2) \

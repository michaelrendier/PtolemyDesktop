  IF (@p3==1)
    z = b5^0.75
  ELSEIF (@p3==0)
    c = -c, z = 0-conj(b5-0.025/b5*pixel2^4)^2
  ELSE
    IF (whitesq)
      z = b5^0.75
    ELSE
      c = -c, z = 0-conj(b5-0.025/b5*pixel2^4)^2
    ENDIF
  ENDIF
  conterm = .08 + .03/pixel2
  cterm = .95*c + conterm
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    cterm = .95*c1 + conterm, z = 0
  ELSEIF (iter==l2)
    cterm = .95*c2 + conterm, z = 0
  ELSEIF (iter==l3)
    cterm = .95*c3 + conterm, z = 0
  ELSEIF (iter==l4)
    cterm = .95*c4 + conterm, z = 0
  ENDIF
  z=(|z|/4)+z*z+cterm
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3269"
  periodicity = 0
  maxiter = 700
  magn = 1.4
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr3270 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  c=pixel2^4-conj(.075/pixel2)+sinh(.001/pixel2)
  z=tan(tan(pixel2^4)-.075/c)-tanh(.1/pixel2) \
    -conj(.001/pixel2)-.24
  IF (@p3==0)
    c = -c, z = -z
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -c, z = -z
    ENDIF
  ENDIF
  conterm = .09 + .025/pixel2
  cterm = .875*c + conterm
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))

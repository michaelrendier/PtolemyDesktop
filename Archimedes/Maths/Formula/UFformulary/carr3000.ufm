  ct = c/8 + k
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = c1, ct = c/8 + k, z = 0
  ELSEIF (iter==l2)
    c = c2, ct = c/8 + k, z = 0
  ELSEIF (iter==l3)
    c = c3, ct = c/8 + k, z = 0
  ELSEIF (iter==l4)
    c = c4, ct = c/8 + k, z = 0
  ENDIF
  z = c*z^2/conj(z+c) + ct
  iter=iter+1
bailout:

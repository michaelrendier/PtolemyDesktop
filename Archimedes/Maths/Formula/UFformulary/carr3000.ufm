  c=(-.6256,-.09)/1.5
  IF (@p3==1)
    z = conj(b5)
  ELSEIF (@p3==0)
    c = -conj(c), z = -sqr(b5)
  ELSE
    IF (whitesq)
      z = conj(b5)
    ELSE
      c = -conj(c), z = -sqr(b5)
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = (-.7456,-.132)
  ct = c*82/119 + k
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16, int iter=0
loop:
  IF (iter==l1)
    ct = c1*82/119 + k, z = 0
  ELSEIF (iter==l2)
    ct = c2*82/119 + k, z = 0
  ELSEIF (iter==l3)
    ct = c3*82/119 + k, z = 0
  ELSEIF (iter==l4)
    ct = c4*82/119 + k, z = 0
  ENDIF
  z = 0.2*z^3 + z^2 + ct
  iter=iter+1
bailout:
  real(z)<=bailout

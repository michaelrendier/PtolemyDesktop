Carr3028 {; Updated for UF2 by Erik Reckase, February 2000
          ; Modified Sylvie Gallet frm. [101324,3444],1996
init:
  z=c=pixel
  IF (@p3==0)
    c = -c, z = -z
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -c, z = -z
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  int iter=0, float zro=0
loop:
  IF (iter==l1)
    c = c1, z = z*zro
  ELSEIF (iter==l2)
    c = c2, z = z*zro
  ELSEIF (iter==l3)
    c = c3, z = z*zro
  ELSEIF (iter==l4)
    c = c4, z = z*zro
  ENDIF
  z = z^2 + c
  iter=iter+1
bailout:
  (imag(z)-2*abs(real(z)))^3<=(16-sqr(real(z)+sin(imag(z))))
default:
  title = "Carr 3028"
  periodicity = 0
  maxiter = 700
  magn = 1.2
  center = (0,.001)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"

Carr3094 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  z=pixel2^exp(.2)+.2*exp(.2-pixel2^-.025)
  c=cabs(z)^3-conj(.1/pixel2-flip(.01/z))^3
  IF (@p3==0)

default:
  title = "Carr 3094"
  periodicity = 0
  maxiter = 700
  magn = 1.7
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \

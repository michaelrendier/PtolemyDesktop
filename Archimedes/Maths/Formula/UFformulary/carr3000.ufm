}

Carr3095 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm.
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  b3=conj(.13/pixel2)+flip(.1/pixel2), c=(-.7456,.2)
  z=flip(cabs(pixel2))*cabs(pixel2^2)+tanh(.1/pixel2) \
     -sinh(.1/pixel2)-b3
  IF (@p3==0)
    c = -c, z = -z
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -c, z = -z
    ENDIF
  ENDIF
  c1=1.5*z,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  k = (-.7456,-.132)
  ct1 = |c/12|^2 + k
  ct2 = c*2/3 + k
  ct = ct1 - .0025*ct2
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16, int iter=0
loop:
  IF (iter==l1)
    ct1=|c1/12|^2+k,ct2=c1*2/3+k,ct=ct1-.0025*ct2,z=0
  ELSEIF (iter==l2)
    ct1=|c2/12|^2+k,ct2=c2*2/3+k,ct=ct1-.0025*ct2,z=0
  ELSEIF (iter==l3)
    ct1=|c3/12|^2+k,ct2=c3*2/3+k,ct=ct1-.0025*ct2,z=0
  ELSEIF (iter==l4)
    ct1=|c4/12|^2+k,ct2=c4*2/3+k,ct=ct1-.0025*ct2,z=0
  ENDIF
  z = .9975*z^2 - .0005*z^3 + ct
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3095"
  periodicity = 0
  maxiter = 700
  magn = 1.5
  center = (0,.1)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr3096 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  b3=conj(.13/pixel2)+flip(.1/pixel2), c=(-.7456,.2)
  b5=flip(cabs(pixel2))*cabs(pixel2^2)+tanh(.1/pixel2)\
      -sinh(.1/pixel2)-flip(b3)-.05
  IF (@p3==1)
    z = conj(b5)
  ELSEIF (@p3==0)
    c = -c, z = -conj(b5)
  ELSE
    IF (whitesq)
      z = conj(b5)
    ELSE
      c = -c, z = -conj(b5)
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = (-.7456,-.132)
  ct1 = |c/12|^2 + k
  ct2 = c*2/3 + k
  ct = ct1 - .0025*ct2
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16, int iter=0
loop:
  IF (iter==l1)
    ct1=|c1/12|^2+k,ct2=c1*2/3+k,ct=ct1-.0025*ct2,z=0
  ELSEIF (iter==l2)
    ct1=|c2/12|^2+k,ct2=c2*2/3+k,ct=ct1-.0025*ct2,z=0
  ELSEIF (iter==l3)
    ct1=|c3/12|^2+k,ct2=c3*2/3+k,ct=ct1-.0025*ct2,z=0
  ELSEIF (iter==l4)
    ct1=|c4/12|^2+k,ct2=c4*2/3+k,ct=ct1-.0025*ct2,z=0
  ENDIF
  z = .9975*z^2 - .0005*z^3 + ct
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3096"
  periodicity = 0
  maxiter = 700
  magn = 1.6
  center = (0,-.05)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr3097 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  b3=abs(.13/pixel2)+flip(pixel2/3)
  c=(.3,.6)+flip(.01/pixel2)+1/b3
  z=flip(cabs(pixel2^3))*pixel2^2-tanh(.1/pixel2) \
    +sinh(.1/pixel2)-flip(b3)-.185
  IF (@p3==0)
    c = -(c + conj(.1/pixel2)), z = -z
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -(c + conj(.1/pixel2)), z = -z
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = (-.7456,-.132)
  ct1 = |c/12|^2 + k
  ct2 = c*2/3 + k
  ct = ct1 - .0025*ct2
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16, int iter=0
loop:
  IF (iter==l1)
    ct1=|c1/12|^2+k,ct2=c1*2/3+k,ct=ct1-.0025*ct2,z=0
  ELSEIF (iter==l2)
    ct1=|c2/12|^2+k,ct2=c2*2/3+k,ct=ct1-.0025*ct2,z=0
  ELSEIF (iter==l3)
    ct1=|c3/12|^2+k,ct2=c3*2/3+k,ct=ct1-.0025*ct2,z=0
  ELSEIF (iter==l4)
    ct1=|c4/12|^2+k,ct2=c4*2/3+k,ct=ct1-.0025*ct2,z=0
  ENDIF
  z = .9975*z^2 - .0005*z^3 + ct
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3097"
  periodicity = 0
  maxiter = 700
  magn = 1.5
  center = (0,-.05)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}


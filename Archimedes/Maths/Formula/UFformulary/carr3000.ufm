Carr3062 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  b4=flip(conj(abs(pixel2^.5))) 
  b5=flip(imag(pixel2))-conj(asin(pixel2*3+.32))\
     -flip(.01/b4-conj(.1/b4))
  IF (@p3==1)
    c = conj(b4), z = conj(b5)
  ELSEIF (@p3==0)
    c = -sqr(b4), z = -(b5)^2
  ELSE
    IF (whitesq)
      c = conj(b4), z = conj(b5)
    ELSE
      c = -sqr(b4), z = -(b5)^2
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = (-.7456,-.132)
  ct = |c/10| + k
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16, int iter=0
loop:
  IF (iter==l1)
    ct = |c1/10| + k, z = 0
  ELSEIF (iter==l2)
    ct = |c2/10| + k, z = 0
  ELSEIF (iter==l3)
    ct = |c3/10| + k, z = 0
  ELSEIF (iter==l4)
    ct = |c4/10| + k, z = 0
  ENDIF
  z = z^2 + ct
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3062"
  periodicity = 0
  maxiter = 700
  magn = 4.3
  center = (0,.035)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"

  endparam
}

Carr3090 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  z=flip(.5+pixel2)^9-conj(.1/pixel2-flip(.01/pixel2))+.435
  c=flip(z)*z^2/exp(pixel2)-conj(.1/pixel2-flip(.01/pixel2))
  IF (@p3==0)
    c = -|c|, z = -z
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -|c|, z = -z
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = (-.7356,-.132)
  ct = c/6 + k
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16, int iter=0
loop:
  IF (iter==l1)
    ct = c1/6 + k, z = 0
  ELSEIF (iter==l2)
    ct = c2/6 + k, z = 0
  ELSEIF (iter==l3)
    ct = c3/6 + k, z = 0
  ELSEIF (iter==l4)
    ct = c4/6 + k, z = 0
  ENDIF
  z = z^2 + ct
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3090"
  periodicity = 0
  maxiter = 700
  magn = 1.2
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr3091 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  c=.5-pixel2*cabs(1.65*pixel2-flip(.01/pixel2)-conj(.1/pixel2))
  z=pixel2^3-1/log(pixel2-.25/cos(conj(sinh(.1/pixel2))))^5
  IF (@p3==0)
    c = -|c|, z = -z
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -|c|, z = -z
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = (-.7456,-.132)
  ct = |c/12| + k
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16, int iter=0
loop:
  IF (iter==l1)
    ct = |c1/12| + k, z = 0
  ELSEIF (iter==l2)
    ct = |c2/12| + k, z = 0
  ELSEIF (iter==l3)
    ct = |c3/12| + k, z = 0
  ELSEIF (iter==l4)
    ct = |c4/12| + k, z = 0
  ENDIF
  z = z^2 + ct
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3091"
  periodicity = 0
  maxiter = 700
  magn = 1.4
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr3092 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  c=pixel2^7-.2*exp(.2-pixel2^-.025)
  z=cabs(c)^5-conj(.1/pixel2-flip(.01/c))-.45
  IF (@p3==0)
    c = -c, z = -z
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -c, z = -z
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = .75 + conj(.05/pixel2)
  ct1 = c - k
  ct2 = c^3
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16, int iter=0
loop:
  IF (iter==l1)
    ct1 = c1 - k, ct2 = c1^3, z = 0
  ELSEIF (iter==l2)
    ct1 = c2 - k, ct2 = c2^3, z = 0
  ELSEIF (iter==l3)
    ct1 = c3 - k, ct2 = c3^3, z = 0
  ELSEIF (iter==l4)
    ct1 = c4 - k, ct2 = c4^3, z = 0
  ENDIF
  z = z^3 + ct1*z - ct2
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3092"
  periodicity = 0
  maxiter = 700
  magn = 1.4
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}


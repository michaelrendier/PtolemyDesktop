  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = c1, ct = conj(c/4) + k, z = 0
  ELSEIF (iter==l2)
    c = c2, ct = conj(c/4) + k, z = 0
  ELSEIF (iter==l3)
    c = c3, ct = conj(c/4) + k, z = 0
  ELSEIF (iter==l4)
    c = c4, ct = conj(c/4) + k, z = 0
  ENDIF
  z = zm*c*z^2/conj(z+c) + ct
  iter=iter+1
bailout:
  real(z-pixel)<=bailout
default:
  title = "Carr 3020"
  periodicity = 0
  maxiter = 700
  magn = .4
  center = (.8,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"

Carr3052 {; Updated for UF2 by Erik Reckase, February 2000
          ; Modified Sylvie Gallet frm. [101324,3444],1996
init:
  b4=-flip(imag(pixel))*pixel^2-conj(.01/pixel-flip(.001/pixel))
  b5=pixel/tanh(.3/pixel)+.3
  IF (@p3==1)
    c = abs(b4), z = flip(b5)
  ELSEIF (@p3==0)
    c = -conj(b4), z = -(|b5|)
  ELSE
    IF (whitesq)
      c = abs(b4), z = flip(b5)
    ELSE
      c = -conj(b4), z = -(|b5|)
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = (-.7056,-.132)
  ct = conj(c/8) + k
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16, int iter=0
loop:
  IF (iter==l1)
    ct = conj(c1/8) + k, z = 0
  ELSEIF (iter==l2)
    ct = conj(c2/8) + k, z = 0
  ELSEIF (iter==l3)
    ct = conj(c3/8) + k, z = 0
  ELSEIF (iter==l4)
    ct = conj(c4/8) + k, z = 0
  ENDIF
  z = z^2 + ct
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3052"
  periodicity = 0
  maxiter = 700
  magn = 2.1
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}


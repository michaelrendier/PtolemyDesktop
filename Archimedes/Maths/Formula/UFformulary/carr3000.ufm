comment {
  Carr3000.ufm Version 1.7
  Ultra Fractal conversions of Robert Carr's formulas Carr3000 - Carr3099
  by Erik Reckase, February 29, 2000

  History:  Version 1.7 - minor optimization tweaks, cleanup

            Version 1.6 - z=z*t workaround in Carr3015-3017,3028-3030

            Version 1.5 - major optimization overhaul
                          fixed bugs in two formulae
 
            Version 1.4 - fixed typos in 3039,3083,3084,3085

            Version 1.3 - Modified whitesq code to eliminate warnings

            Version 1.2 - Fixed bug in Carr3095

            Version 1.1 - Fixed errors in last 3 formulas
                          Respaced whitesq lines

            Version 1.0 - Initial Release
                          Original formulas pulled from _rc3.frm
                          Carr3005,3009,3010,3012,
                              3014,3036,3054-3086,
                              3088-3099            : pixel fix
                          Carr3037,3065,3067,3084  : cosxx fix
}

Carr3000 {; Updated for UF2 by Erik Reckase, February 2000
          ; Modified Sylvie Gallet frm. [101324,3444],1996
init:
  c=pixel-conj(.01/pixel-flip(.001/pixel))
  z=conj(pixel)-flip(.01/pixel)-conj(.001/pixel)-conj(.001/c)-.1
  IF (@p3==0)
    c = -c, z = -z
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -c, z = -z
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = (.3,.525)
  ct = flip(conj(c/10)) - k
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    ct = flip(conj(c1/10)) - k, z = 0
  ELSEIF (iter==l2)
    ct = flip(conj(c2/10)) - k, z = 0
  ELSEIF (iter==l3)
    ct = flip(conj(c3/10)) - k, z = 0
  ELSEIF (iter==l4)
    ct = flip(conj(c4/10)) - k, z = 0
  ENDIF
  z = z^2 + ct
  iter=iter+1
bailout:
  real(z)<=bailout
default:
  title = "Carr 3000"
  periodicity = 0
  maxiter = 700
  magn = 1.3
  center = (.1,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr3001 {; Updated for UF2 by Erik Reckase, February 2000
          ; Modified Sylvie Gallet frm. [101324,3444],1996
init:
  b5=conj(pixel)-conj(.1/pixel-flip(.001/pixel))-.45
  b4=flip(2*pixel)-flip(.01/pixel)-conj(.001/pixel)-conj(.001/b5)
  IF (@p3==1)
    c = flip(b4), z = sqr(b5)
  ELSEIF (@p3==0)
    c = -sqr(b4), z = -flip(b5)
  ELSE
    IF (whitesq)
      c = flip(b4), z = sqr(b5)
    ELSE
      c = -sqr(b4), z = -flip(b5)
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = (-.7496,-.132)
  ct = flip(|c/12|) + k
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    ct = flip(|c1/10|) + k, z = 0
  ELSEIF (iter==l2)
    ct = flip(|c2/10|) + k, z = 0
  ELSEIF (iter==l3)
    ct = flip(|c3/10|) + k, z = 0
  ELSEIF (iter==l4)
    ct = flip(|c4/10|) + k, z = 0
  ENDIF
  z = z^2 + ct
  iter=iter+1
bailout:
  real(z-pixel)<=bailout
default:
  title = "Carr 3001"
  periodicity = 0
  maxiter = 700
  magn = 0.9
  center = (.4,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr3002 {; Updated for UF2 by Erik Reckase, February 2000
          ; Modified Sylvie Gallet frm. [101324,3444],1996
init:
  b5=conj(pixel)-conj(.1/pixel-flip(.0019/pixel))
  b4=conj(pixel)-flip(.01/pixel)-conj(.001/pixel)
  IF (@p3==1)
    c = conj(b4), z = sqr(b5)
  ELSEIF (@p3==0)
    c = -sqr(b4), z = -conj(b5)
  ELSE
    IF (whitesq)
      c = conj(b4), z = sqr(b5)
    ELSE
      c = -sqr(b4), z = -conj(b5)
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = (-.7156,-.132) + .01
  ct = c/6 + k
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    ct = c1/6 + k, z = 0
  ELSEIF (iter==l2)
    ct = c2/6 + k, z = 0
  ELSEIF (iter==l3)
    ct = c3/6 + k, z = 0
  ELSEIF (iter==l4)
    ct = c4/6 + k, z = 0
  ENDIF
  z = z^2 + ct
  iter=iter+1
bailout:
  real(z-pixel)<=bailout
default:
  title = "Carr 3002"
  periodicity = 0
  maxiter = 700
  magn = 1.2
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr3003 {; Updated for UF2 by Erik Reckase, February 2000
          ; Modified Sylvie Gallet frm. [101324,3444],1996
init:
  b5=conj(pixel)-conj(.1/pixel-flip(.0019/pixel))+.2
  b4=conj(pixel)-flip(.01/pixel)-conj(.001/pixel)
  IF (@p3==1)
    c = conj(b4), z = sqr(b5)
  ELSEIF (@p3==0)
    c = -sqr(b4), z = -sqr(b5)
  ELSE
    IF (whitesq)
      c = conj(b4), z = sqr(b5)
    ELSE
      c = -sqr(b4), z = -sqr(b5)
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = (-.7956,-.132)
  ct = c/10 + k
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = c1, ct = c/10 + k, z = 0
  ELSEIF (iter==l2)
    c = c2, ct = c/10 + k, z = 0
  ELSEIF (iter==l3)
    c = c3, ct = c/10 + k, z = 0
  ELSEIF (iter==l4)
    c = c4, ct = c/10 + k, z = 0
  ENDIF
  z = c*z^2/(z+c) + ct
  iter=iter+1
bailout:
  real(z-pixel)<=bailout
default:
  title = "Carr 3003"
  periodicity = 0
  maxiter = 700
  magn = .9
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr3004 {; Updated for UF2 by Erik Reckase, February 2000
          ; Modified Sylvie Gallet frm. [101324,3444],1996
init:
  b5=conj(pixel)-conj(.1/pixel-flip(.0019/pixel))+.2
  b4=conj(pixel)-flip(.01/pixel)-conj(.001/pixel)
  IF (@p3==1)
    c = conj(b4), z = sqr(b5)
  ELSEIF (@p3==0)
    c = -sqr(b4), z = -sqr(b5)
  ELSE
    IF (whitesq)
      c = conj(b4), z = sqr(b5)
    ELSE
      c = -sqr(b4), z = -sqr(b5)
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = (-.7956,-.132)
  ct = c/10 + k
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = c1, ct = c/10 + k, z = 0
  ELSEIF (iter==l2)
    c = c2, ct = c/10 + k, z = 0
  ELSEIF (iter==l3)
    c = c3, ct = c/10 + k, z = 0
  ELSEIF (iter==l4)
    c = c4, ct = c/10 + k, z = 0
  ENDIF
  z = c*z^2/conj(z+c) + ct
  iter=iter+1
bailout:
  real(z-pixel)<=bailout
default:
  title = "Carr 3004"
  periodicity = 0
  maxiter = 700
  magn = 1.1
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr3005 {; Updated for UF2 by Erik Reckase, February 2000
          ; Modified Sylvie Gallet frm. [101324,3444],1996
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  b4=conj(pixel2^3)-conj(.1/pixel2-flip(.01/pixel2))+.4
  z=flip(conj(1.25*pixel2))-flip(.01/pixel2) \
    -conj(.001/pixel2)+.4
  IF (@p3==1)
    c = conj(b4)
  ELSEIF (@p3==0)
    c = -sqr(b4), z = -sqr(z)
  ELSE
    IF (whitesq)
      c = conj(b4)
    ELSE
      c = -sqr(b4), z = -sqr(z)
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = (-.7956,-.132)
  ct = c/10 + k
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = c1, ct = c/10 + k, z = 0
  ELSEIF (iter==l2)
    c = c2, ct = c/10 + k, z = 0
  ELSEIF (iter==l3)
    c = c3, ct = c/10 + k, z = 0
  ELSEIF (iter==l4)
    c = c4, ct = c/10 + k, z = 0
  ENDIF
  z = c*z^2/conj(z+c) + ct
  iter=iter+1
bailout:
  real(z-pixel2)<=bailout
default:
  title = "Carr 3005"
  periodicity = 0
  maxiter = 700
  magn = 1.2
  center = (0,.1)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr3006 {; Updated for UF2 by Erik Reckase, February 2000
          ; Modified Sylvie Gallet frm. [101324,3444],1996
init:
  z=pixel-conj(.1/pixel)
  c=pixel-flip(.1/pixel)-conj(.001/pixel)
  IF (@p3==0)
    c = -c, z = -z
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -c, z = -z
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = (-.7956,-.132)
  ct = c/10 + k
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = c1, ct = c/10 + k, z = 0
  ELSEIF (iter==l2)
    c = c2, ct = c/10 + k, z = 0
  ELSEIF (iter==l3)
    c = c3, ct = c/10 + k, z = 0
  ELSEIF (iter==l4)
    c = c4, ct = c/10 + k, z = 0
  ENDIF
  z = c*z^2/conj(z+c) + ct
  iter=iter+1
bailout:
  real(z-pixel)<=bailout
default:
  title = "Carr 3006"
  periodicity = 0
  maxiter = 700
  magn = .9
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr3007 {; Updated for UF2 by Erik Reckase, February 2000
          ; Modified Sylvie Gallet frm. [101324,3444],1996
init:
  c=(-.7456,-.132)
  z=abs(2*pixel^12)-flip(.1/pixel)-conj(.1/pixel)+.35
  IF (@p3==0)
    c = -c, z = -z
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -c, z = -z
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = (-.7956,-.132)
  ct = c/8 + k
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = c1, ct = c/8 + k, z = 0
  ELSEIF (iter==l2)
    c = c2, ct = c/8 + k, z = 0
  ELSEIF (iter==l3)
    c = c3, ct = c/8 + k, z = 0
  ELSEIF (iter==l4)
    c = c4, ct = c/8 + k, z = 0
  ENDIF
  z = c*z^2/conj(z+c) + ct
  iter=iter+1
bailout:
  real(z-pixel)<=bailout
default:
  title = "Carr 3007"
  periodicity = 0
  maxiter = 700
  magn = 1.2
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr3008 {; Updated for UF2 by Erik Reckase, February 2000
          ; Modified Sylvie Gallet frm. [101324,3444],1996
init:
  c=pixel-conj(.01/pixel-flip(.001/pixel))
  z=1-abs(imag(c)-real(c))+flip(1-abs(1-real(c)-imag(c)))
  IF (@p3==0)
    c = -c, z = -sqr(z)
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -c, z = -sqr(z)
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = (-.132,-.6956)
  ct = c/8 + k
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = c1, ct = c/8 + k, z = 0
  ELSEIF (iter==l2)
    c = c2, ct = c/8 + k, z = 0
  ELSEIF (iter==l3)
    c = c3, ct = c/8 + k, z = 0
  ELSEIF (iter==l4)
    c = c4, ct = c/8 + k, z = 0
  ENDIF
  z = c*z^2/conj(z+c) + ct
  iter=iter+1
bailout:
  real(z-pixel)<=bailout
default:
  title = "Carr 3008"
  periodicity = 0
  maxiter = 700
  magn = .8
  center = (.3,.3)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}


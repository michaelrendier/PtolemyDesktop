            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr3029 {; Updated for UF2 by Erik Reckase, February 2000
          ; Modified Sylvie Gallet frm. [101324,3444],1996
          ; Black lines not present in Fractint version
init:
  z=abs(conj(pixel)*flip(pixel))+.4
  c=z-conj(.01/pixel-flip(.0015/pixel-flip(.01/z)))
  IF (@p3==0)
    c = -c, z = -sqr(z)
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -c, z = -sqr(z)
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  int iter=0, float zro=0
loop:
  IF (iter==l1)
    c = c1, z = z*zro
  ELSEIF (iter==l2)
    c = c2, z = z*zro
  ELSEIF (iter==l3)
    c = c3, z = z*zro
  ELSEIF (iter==l4)
    c = c4, z = z*zro
  ENDIF
  z = z^3 + (c-1)*(z-c)
  iter=iter+1
bailout:
  (imag(z)-2*abs(real(z)))^3<=32-sqr(real(z)+sin(imag(z)))
default:
  title = "Carr 3029"
  periodicity = 0
  maxiter = 700
  magn = 1.6
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr3030 {; Updated for UF2 by Erik Reckase, February 2000
          ; Modified Sylvie Gallet frm. [101324,3444],1996
init:
  b5=abs(conj(pixel^2))*flip(abs(pixel))
  b4=b5-conj(.01/pixel-flip(.0015/pixel-flip(.01/b5)))
  IF (@p3==1)
    c = conj(b4), z = sqr(b5)
  ELSEIF (@p3==0)
    c = -sqr(b4), z = -conj(b5)
  ELSE
    IF (whitesq)
      c = conj(b4), z = sqr(b5)
    ELSE
      c = -sqr(b4), z = -conj(b5)
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  int iter=0, float zro=0
loop:
  IF (iter==l1)
    c = c1, z = z*zro
  ELSEIF (iter==l2)
    c = c2, z = z*zro
  ELSEIF (iter==l3)
    c = c3, z = z*zro
  ELSEIF (iter==l4)
    c = c4, z = z*zro
  ENDIF
  z = z^3 + (c-1)*(z-c/8)
  iter=iter+1
bailout:
  (imag(z)-2*abs(real(z)))^3<=32-sqr(real(z)+sin(imag(z)))
default:
  title = "Carr 3030"
  periodicity = 0
  maxiter = 700
  magn = 1.2
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"

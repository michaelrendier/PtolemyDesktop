default:
  title = "Carr 3009"
  periodicity = 0
  maxiter = 700
  magn = .8
  center = (0,.25)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr3010 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. [101324,3444],1996
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  b4=pixel2-conj(.01/pixel2-flip(.001/pixel2))
  z=1-abs(imag(b4)-real(b4/2)) \
     +flip(1-abs(1-real(b4)-flip(imag(b4))))
  IF (@p3==1)
    c = conj(b4)
  ELSEIF (@p3==0)
    c = -(b4), z = -sqr(z)
  ELSE
    IF (whitesq)
      c = conj(b4)
    ELSE
      c = -(b4), z = -sqr(z)
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = (-.132,-.6956)
  ct = c/8 + k
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = c1, ct = c/8 + k, z = 0
  ELSEIF (iter==l2)
    c = c2, ct = c/8 + k, z = 0
  ELSEIF (iter==l3)
    c = c3, ct = c/8 + k, z = 0
  ELSEIF (iter==l4)
    c = c4, ct = c/8 + k, z = 0
  ENDIF
  z = c*z^2/conj(z+c) + ct
  iter=iter+1
bailout:
  real(z-pixel2)<=bailout
default:
  title = "Carr 3010"
  periodicity = 0
  maxiter = 700
  magn = 1
  center = (0,.1)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}


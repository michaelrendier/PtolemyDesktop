Carr3086 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  z=flip(.66-pixel2)^3+.2, c=abs(.33-pixel2)
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = (-.745,-.13)
  ct = |c/12| + k
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16, int iter=0
loop:
  IF (iter==l1)
    ct = |c1/12| + k, z = 0
  ELSEIF (iter==l2)
    ct = |c2/12| + k, z = 0
  ELSEIF (iter==l3)
    ct = |c3/12| + k, z = 0
  ELSEIF (iter==l4)
    ct = |c4/12| + k, z = 0
  ENDIF
  z = z^2 + ct
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3086"
  periodicity = 0
  maxiter = 700
  magn = 2.2
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
}

Carr3087 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  z=pixel^3-conj(.1/pixel)-flip(.01/pixel)^2+.1/pixel
  c=z^3/exp(pixel)-conj(.1/pixel-flip(.01/pixel))
  IF (@p3==0)
    c = -c, z = -z
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -c, z = -z
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16, int iter=0
loop:
  IF (iter==l1)
    c = c1, z = 0
  ELSEIF (iter==l2)
    c = c2, z = 0
  ELSEIF (iter==l3)
    c = c3, z = 0
  ELSEIF (iter==l4)
    c = c4, z = 0
  ENDIF
  z = z^2 + c
  iter=iter+1
bailout:
  real(2-z)<=bailout
default:
  title = "Carr 3087"
  periodicity = 0
  maxiter = 700
  magn = 1.5
  center = (0,.001)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr3088 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  c=pixel2^3-conj(.1/pixel2)-flip(.01/pixel2)^2+.1/pixel2+.4
  z=c^3/exp(pixel2)-conj(.1/pixel2-flip(.01/pixel2))
  IF (@p3==0)
    c = -c, z = -z
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -c, z = -z
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16, int iter=0
loop:
  IF (iter==l1)
    c = c1, z = 0
  ELSEIF (iter==l2)
    c = c2, z = 0
  ELSEIF (iter==l3)
    c = c3, z = 0
  ELSEIF (iter==l4)
    c = c4, z = 0
  ENDIF
  z = z^2 + c
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3088"
  periodicity = 0
  maxiter = 700
  magn = 1.6
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr3089 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  c=flip(.5+pixel2)
  z=c^5/exp(pixel2)-conj(.1/pixel2-flip(.01/pixel2))-.45
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = (-.7456,-.132)
  ct = |c/12| + k
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16, int iter=0
loop:
  IF (iter==l1)
    ct = |c1/12| + k, z = 0
  ELSEIF (iter==l2)
    ct = |c2/12| + k, z = 0
  ELSEIF (iter==l3)
    ct = |c3/12| + k, z = 0
  ELSEIF (iter==l4)
    ct = |c4/12| + k, z = 0
  ENDIF
  z = z^2 + ct
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3089"
  periodicity = 0
  maxiter = 700
  magn = 1.4
  center = (0,.05)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \

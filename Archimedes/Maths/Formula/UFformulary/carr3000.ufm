Carr3031 {; Updated for UF2 by Erik Reckase, February 2000
          ; Modified Sylvie Gallet frm. [101324,3444],1996
init:
  z=sin(pixel)/tanh(.3/pixel)
  b4=pixel-asin(.33-pixel^3)
  IF (@p3==1)
    c = |b4|
  ELSEIF (@p3==0)
    c = -b4, z = -|z|
  ELSE
    IF (whitesq)
      c = |b4|
    ELSE
      c = -b4, z = -|z|
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = (-.7956,-.132)
  ct = conj(c/8) + k
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16, int iter=0
loop:
  IF (iter==l1)
    ct = conj(c1/8) + k, z = 0
  ELSEIF (iter==l2)
    ct = conj(c2/8) + k, z = 0
  ELSEIF (iter==l3)
    ct = conj(c3/8) + k, z = 0
  ELSEIF (iter==l4)
    ct = conj(c4/8) + k, z = 0
  ENDIF
  z = z^2 + ct
  iter=iter+1
bailout:
  real(z)<=bailout
default:
  title = "Carr 3031"
  periodicity = 0
  maxiter = 700
  magn = 2.1
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"

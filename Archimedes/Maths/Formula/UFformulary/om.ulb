pz=0.18*recip(pz)
elseif @kxv==16
pz=-1.5*flip(pz)
elseif @kxv==17
pz=0.125*recip(pz)
endif
i=1
else
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2

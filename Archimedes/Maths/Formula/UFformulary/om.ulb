elseif @v=="20"
z=x+sin(y)+flip(y+x+@p1*sin(y))
elseif @v=="21"
z=-sin(y)*(1-0.35)+flip(sin(x)*(1+0.35))+x+0.35*(@p1-1.5+0.2i)*sin(2*pi*y)\

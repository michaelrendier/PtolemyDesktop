class OM_MandelbrotExpPixtet(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fPixel=pz
return @sf1(sqr(@sf2(pz)))
endfunc
private:
complex fPixel
complex func Iterate(complex pz)
pz=@pzp1*flip(conj(pz))+@pzp2
pz=pz^2+@pf2(@pf1(exp(fPixel))^@pf1(exp(fPixel)))+@mp
pz=pz+@arp/@arf(pz)
return pz
endfunc

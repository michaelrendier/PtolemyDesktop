complex fpixel
complex func Iterate(complex pz)
pw=@wp1*pw+@wp2
pk=@kp1*pk+@kp2
if@mj==0
pz=@zp1*pz+@zp2
else
pz=@zp1*pz+@zp2-0.5
endif
pq=@qp1*pq+@qp2
a=pw
b=pk
c=pz
if @mj==0
if @v==0
pw=exp(log(pw^3/pk)+log(pz^3/pq))+@p1*@pf(fpixel)
pk=(pk^2/pz+pq^2/a)^2+@p2*@pf(fpixel)
pz=pz^2+pq^2+a^2+b^2+@p3*@pf(fpixel)/pz^2
pq=(pq^2/a)^2+(c^2/b)^2+@p4*@pf(fpixel)
elseif @v==1
pw=pw^3/pk+pz^3/pq+@p1*@pf(fpixel)
pk=(exp(log(pk^2/pz)+log(pq^2/a)))^2+@p2*@pf(fpixel)
pz=pz^2+pq^2+a^2+b^2+(@p3+0.05)*@pf(fpixel)/pz^2
pq=(pq^2/a)^2+(c^2/b)^2+@p4*@pf(fpixel)
else
pw=pw^3/pk+pz^3/pq+@p1*@pf(fpixel)
pk=(pk^2/pz+pq^2/a)^2+@p2*@pf(fpixel)
pz=pz^2+pq^2+a^2+b^2+@p3*@pf(fpixel)/pz^2
pq=exp(log((pq^2/a)^2)+log((c^2/b)^2))+@p4*@pf(fpixel)
endif
else
if @v==0
pw=exp(log(pw^3/pk)+log(pz^3/pq))+@p1
pk=(pk^2/pz+pq^2/a)^2+@p2
pz=pz^2+pq^2+a^2+b^2+@p3/pz^2
pq=(pq^2/a)^2+(c^2/b)^2+@p4
elseif @v==1
pw=pw^3/pk+pz^3/pq+@p1
pk=(exp(log(pk^2/pz)+log(pq^2/a)))^2+@p2
pz=pz^2+pq^2+a^2+b^2+(@p3+0.05)/pz^2
pq=(pq^2/a)^2+(c^2/b)^2+@p4
else
pw=pw^3/pk+pz^3/pq+@p1
pk=(pk^2/pz+pq^2/a)^2+@p2
pz=pz^2+pq^2+a^2+b^2+@p3/pz^2
pq=exp(log((pq^2/a)^2)+log((c^2/b)^2))+@p4
endif
endif
return pz
return pw
return pk
return pq
endfunc

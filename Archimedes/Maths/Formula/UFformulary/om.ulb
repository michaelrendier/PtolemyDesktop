y=y+@p6*(cos(1+k+cos((1,-0.25)+pi*y))-1.85*sin(k+tan(1i*k)))
elseif @v=="40"
x=x+@p1*(cos((-3.8,-0.35)+y+cos(0.5i+pi*x))+sin(y+tan(1i*y)))
y=y+@p6*(cos(1+k+cos(0.25i+pi*y))-2*sin(k+tan(1i*k)))
endif
f=(d1*x+d2)*x+(d3*y+d4)*y
g=(d5*x+d6)*x+(d7*y+d8)*y
b=cabs(f)+cabs(g)
if b<c
c=b
endif
endfunc
float func ResultIndex(complex pz)
index=@tp*cabs(@tf(c))
return index
endfunc
private:
float a
float b
float c
float d1
float d2
float d3
float d4
float d5
float d6
float d7
float d8
float index
default:
title="Brujo"

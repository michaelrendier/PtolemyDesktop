&& @v!="Coriolis' Catenary" && @v!="Cornoid" && @v!="Deltoid 1" && @v!="Deltoid 2" \
&& @v!="Dipole" && @v!="Double U" && @v!="Duplicatrix Cubic" \
&& @v!="Egg of Granville 2" && @v!="Egg of Kepler" && @v!="Eight" \
&& @v!="Fish" && @v!="Folium of Descartes" && @v!="Folium of Durer" && @v!="Gudermannian" && @v!="Heat Capacity" \
&& @v!="Hoerl" && @v!="Humbert's Cubic" && @v!="Hyperbolic Spiral" && @v!="Kappa" && @v!="Kiepert" \
&& @v!="Kiss" && @v!="Kulp Quartic" && @v!="Lemniscate of Bernoulli" && @v!="Lemniscatrix of Ökinghaus" \
&& @v!="Limacon of Pascal 1" && @v!="Lissajous 1" && @v!="Lissajous 2" \
&& @v!="Logarithmic Lemniscate"&& @v!="Logarithmic Sinusoid" \
&& @v!="Logistic Growth" && @v!="Loriga" && @v!="Maltese Cross" && @v!="Neile's Semi-Cubical Parabola" \
&& @v!="Nephroid" && @v!="Nephroid of Freeth" && @v!="Parabolic Trifolium" && @v!="Planck Radiation" \
&& @v!="Pursuit 1" && @v!="Pursuit 2" && @v!="Quadratix of Hippias" && @v!="Quadrifolium" \
&& @v!="Regular Trifolium" && @v!="Richards" && @v!="Right Strophoid" && @v!="Scyphoid" && @v!="Semi-Trident" \
&& @v!="Sinus Chain" && @v!="Szego" && @v!="Teardrop" && @v!="Torpedo" && @v!="Tractrix" && @v!="Trident 1" \
&& @v!="Trisectrix of Delange" && @v!="Trisectrix of Maclaurin" && @v!="Tschirnhaus' Cubic" && @v!="Visiera" \
&& @v!="Viviani's" && @v!="Witch of Agnesi") && @version==100
endparam
param cp3
caption="Curve Parameter 3"
default=(1,0)
visible=(@v=="Beetle" || @v=="Cartesian Oval" || @v=="Chasles Cubic" \
|| @v=="Circular Cubic" || @v=="Cissoid of Zahradnik" || @v=="Clinoid" \
|| @v=="Conchoid of a Circle" || @v=="Cubic of Apollonius" \
|| @v=="Egg of Granville 1" || @v=="Elongated Cissoid" || @v=="Hyperbolic" || @v=="Kieroid" || @v=="Klein Quartic" \
|| @v=="Newton's Diverging Parabolas 1" || @v=="Oblique Pancappa" || @v=="Oblique Conchoid" || @v=="Oval of Münger" \
|| @v=="Parabola 1" || @v=="Parabola 2" || @v=="Parabola 3" || @v=="Pearls of Sluze" || @v=="Rosillo" \
|| @v=="Spiric" || @v=="Spiric of Perseus" || @v=="Spiric Sections" || @v=="Superellipse 1" || @v=="Superellipse 2" \
|| @v=="Trident 2" || @v=="Trifolium 1" || @v=="Watt's") && @version==100
endparam
param cp4
caption="Curve Parameter 4"
default=(1,0)
visible=(@v=="Cartesian Oval" || @v=="Chasles Cubic" || @v=="Circular Cubic" \
|| @v=="Cissoid of Zahradnik" || @v=="Oval of Münger" || @v=="Pearls of Sluze" \
|| @v=="Spiric" || @v=="Superellipse 2" || @v=="Trident 2") && @version==100
endparam
param cp5
caption="Curve Parameter 5"
default=(1,0)
visible=(@v=="Circular Cubic" || @v=="Cissoid of Zahradnik" || @v=="Oval of Münger" || @v=="Pearls of Sluze") && @version==100
endparam
param cp1b
caption="Curve Parameter"
default=(1,0)
visible=(@v2!="Biquartic" && @v2!="Butterfly Curve" &&  @v2!="Heart Curve" && @v2!="Heart of Eugene Beutel" \
&& @v2!="Logarithmic Sinusoid" \
&& @v2!="Szego Curve") && @version==101
endparam
param cp2b
caption="Curve Parameter 2"
default=(1,0)
visible=(@v2!="Antiversiera" && @v2!="Astroid" && @v2!="Bean Curve 1" && @v2!="Bean Curve 2" && @v2!="Besace" && @v2!="Biaxial Eight Reverse" && @v2!="Bicorn"  \
&& @v2!="Bicuspid" && @v2!="Biquartic" && @v2!="Blade's Cubic" && @v2!="Bow Curve" && @v2!="Butterfly Curve" && @v2!="Cardioid" \
&& @v2!="Catenary" && @v2!="Cayley's Sextic" && @v2!="Ceva's Trisectrix" && @v2!="Circle" && @v2!="Cissoid of Diocles 1" \
&& @v2!="Cissoid of Diocles 2" && @v2!="Conic Sections" \
&& @v2!="Coriolis' Catenary" && @v2!="Cornoid" && @v2!="Deltoid 1" && @v2!="Deltoid 2" \
&& @v2!="Dipole Curve" && @v2!="Double Egg" && @v2!="Duplicatrix Cubic" \
&& @v2!="Egg of Kepler" && @v2!="Eight Curve" \
&& @v2!="Fish Curve" && @v2!="Folium of Descartes" && @v2!="Folium of Durer" && @v2!="Heart Curve" \
&& @v2!="Heart of Eugene Beutel" && @v2!="Heat Capacity Curve" \
&& @v2!="Hoerl Curve" && @v2!="Inverse Nephroid" && @v2!="Kappa Curve" && @v2!="Kiepert Curve" \
&& @v2!="Kiss Curve" && @v2!="Kulp Quartic" && @v2!="Lemniscate of Bernoulli" \
&& @v2!="Limacon of Pascal 1" && @v2!="Lissajous Curve 1" && @v2!="Lissajous Curve 2" \
&& @v2!="Logarithmic Lemniscate"&& @v2!="Logarithmic Sinusoid" \
&& @v2!="Neile's Semi-Cubical Parabola" \
&& @v2!="Nephroid" && @v2!="Nephroid of Freeth" && @v2!="Parabolic Trifolium" && @v2!="Pearl of the Fourth Order 1" && @v2!="Pearl of the Fourth Order 2" \
&& @v2!="Pseudoversiera" && @v2!="Pursuit Curve 1" && @v2!="Pursuit Curve 2" && @v2!="Quadratix of Hippias" && @v2!="Quadrifolium" \
&& @v2!="Regular Trifolium" && @v2!="Right Strophoid" && @v2!="Scyphoid" && @v2!="Semi-Trident" \
&& @v2!="Szego Curve" && @v2!="Teardrop Curve" && @v2!="Torpedo Curve" && @v2!="Tractrix" \
&& @v2!="Trisectrix of Delange" && @v2!="Trisectrix of Maclaurin" && @v2!="Tschirnhaus' Cubic" && @v2!="Visiera" \
&& @v2!="Viviani's Curve" && @v2!="Wassenaar Curve" && @v2!="Windmill Curve") && @version==101
endparam
param cp3b
caption="Curve Parameter 3"
default=(1,0)
visible=(@v2=="Apollonian Cubic" || @v2=="Bicircular Quartic" || @v2=="Beetle" || @v2=="Cartesian Oval" || @v2=="Chasles Cubic" \
|| @v2=="Circular Cubic" || @v2=="Cissoid of Zahradnik" || @v2=="Clinoid" \
|| @v2=="Conchoid of a Circle" || @v2=="Cubic of Apollonius" \
|| @v2=="Egg of Granville" || @v2=="Elongated Cissoid" || @v2=="Holditch Curve 1" || @v2=="Kieroid" || @v2=="Klein Quartic" \
|| @v2=="Newton's Diverging Parabolas 1" || @v2=="Oblique Pancappa" || @v2=="Oblique Conchoid" || @v2=="Oval of Münger" \
|| @v2=="Parabola 1" || @v2=="Parabola 2" || @v2=="Parabola 3" || @v2=="Pearls of Sluze" || @v2=="Curve of Rosillo" || @v2=="Salmon Quartic 2" \
|| @v2=="Spiric Curve" || @v2=="Spiric of Perseus" || @v2=="Spiric Sections" || @v2=="Superellipse 1" || @v2=="Superellipse 2" || @v2=="Toric Section" \
|| @v2=="Trident" || @v2=="Trifolium 1" || @v2=="Virtual Parabola" || @v2=="Watt's Curve") && @version==101
endparam
param cp4b
caption="Curve Parameter 4"
default=(1,0)
visible=(@v2=="Bicircular Quartic" || @v2=="Cartesian Oval" || @v2=="Chasles Cubic" || @v2=="Circular Cubic" \
|| @v2=="Cissoid of Zahradnik" || @v2=="Oval of Münger" || @v2=="Pearls of Sluze" \
|| @v2=="Spiric Curve" || @v2=="Superellipse 2" || @v2=="Toric Section" || @v2=="Trident" || @v2=="Virtual Parabola") && @version==101
endparam
param cp5b
caption="Curve Parameter 5"
default=(1,0)
visible=(@v2=="Bicircular Quartic" || @v2=="Circular Cubic" || @v2=="Cissoid of Zahradnik" || @v2=="Oval of Münger" || @v2=="Pearls of Sluze" || @v2=="Toric Section") && @version==101
endparam
param adj
caption="Adjustment"
default=-0.05
visible=@version==100
endparam
param zp1
caption="Z Parameter 1"
default=(1,0)
endparam
param zp2
caption="Z Parameter 2"
default=(0,0)
endparam
func zf
caption="Z Function"
default=ident()
endfunc
param solid
caption="Solid Color"
default=false
endparam
param sca
caption="Solid Color Adjustment"
default=1.725
visible=@solid==true
endparam
param invert
caption="Invert Solid Color"
default=false
visible=@solid==true
endparam
}

class OM_SmescitResu(common.ulb:GradientColoring) {
public:
func Init(complex pz, complex ppixel)
GradientColoring.Init(pz, ppixel)
if @version==100
a=0.0
else
a=3.0
endif
fpixel=pz
endfunc
func Iterate(complex pz)
GradientColoring.Iterate(pz)
pz=@zp1*@zf(pz)+@zp2
if @version==100
if @v==0
pz=pz
elseif @v==1
pz=pz+cosh(pz)
elseif @v==2
pz=pz+1/cabs(pz)
elseif @v==3
pz=pz+1/abs(pz)
elseif @v==4
pz=pz+1/sqrt(pz)
elseif @v==5
pz=pz+fpixel
elseif @v==6
pz=pz+flip(fpixel)
elseif @v==7
pz=pz-cosh(pz)
elseif @v==8
pz=pz-recip(pz)
elseif @v==9
pz=pz-1/cabs(pz)
elseif @v==10
pz=pz+(pz-1i)/(pz+1i)
elseif @v==11
pz=pz+recip(pz)
elseif @v==12
pz=pz+log((pz-1i)/(pz+1i))
elseif @v==13
pz=pz+sqr((pz-1i)/(pz+1i))
elseif @v==14
pz=pz-(pz-1i)/(pz+1i)
elseif @v==15
pz=pz-abs((pz-1i)/(pz+1i))
elseif @v==16
pz=pz+flip((pz-fpixel)/(pz+fpixel))
elseif @v==17
pz=pz+conj((pz-fpixel)/(pz+fpixel))
elseif @v==18
pz=pz+abs((pz-2)/(1-2*pz))
elseif @v==19
pz=pz+exp((pz-2)/(1-2*pz))
elseif @v==20
pz=pz-conj((pz-2)/(1-2*pz))
elseif @v==21
pz=pz-cabs((pz-2)/(1-2*pz))
elseif @v==22
pz=pz-exp((pz-2)/(1-2*pz))
elseif @v==23
pz=pz+((pz-(fpixel))/(1-(fpixel)*pz))
elseif @v==24
pz=pz+((pz-recip(fpixel))/(1-recip(fpixel)*pz))
elseif @v==25
pz=pz-((pz-recip(fpixel))/(1-recip(fpixel)*pz))
elseif @v==26
pz=pz^3+pz^2+pz+1
elseif @v==27
pz=pz^3+2*pz^2+2*pz+2
elseif @v==28
pz=0.5*pz^3+pz-1
elseif @v==29
pz=pz^3+0.5*pz^2-pz+0.8
elseif @v==30
pz=pz^3+pz^2+pz+fpixel
elseif @v==31
pz=0.5*pz^4+0.5*pz^3-pz^2+0.1*pz+1
elseif @v==32
pz=-0.5*pz^4+pz^3-pz^2-pz+1
elseif @v==33
pz=exp(-((pz-2)/4)^2)*cos(pz*2*pi/4)
elseif @v==34
pz=1.25*exp(-((pz-2)/4)^2)*cos(pz*2*pi/8)
elseif @v==35
pz=-0.25*pz^3*exp(-pz)-1.3*pz
elseif @v==36
pz=-3.75*pz/(1+pz^2)+1.5*pz
elseif @v==37
pz=pz+1-(0.01/(2*pi))*sin(2*pi*pz)
elseif @v==38
pz=pz+1.33-(-0.1/(2*pi))*sin(2*pi*pz)
elseif @v==39
pz=recip(1+exp(1.75*pz))
elseif @v==40
pz=pz-(pz^3-1)/(3*pz^2)
elseif @v==41
pz=pz-(pz^3-2)/(3*pz^2)+1
elseif @v==42
pz=pz-(pz^3+2)/(3*pz^2)
elseif @v==43
pz=pz-(pz^3-fpixel)/(3*pz^2)-0.6
elseif @v==44
pz=pz-(pz^3-cosh(fpixel))/(3*pz^2)
elseif @v==45
pz=pz-(pz^3-exp(fpixel))/(3*pz^2)
elseif @v==46
pz=pz-(pz^3-1)/(3*pz^2)+cabs(fpixel)
elseif @v==47
pz=pz-(pz^3-1)/(3*pz^2)+abs(fpixel)
elseif @v==48
pz=pz-0.75*(pz^3-2.75)/(3*pz^2)+conj(fpixel)
endif
a=a+exp(@adj*log(log(cabs(pz))))
elseif @version==101
if @v==0
float b=|2*pz+flip(fpixel)-1i|
elseif @v==1
float b=|pz+cosh(pz)+fpixel+1i|
elseif @v==2
float b=|pz+1/abs(pz)+flip(fpixel)+1i|
elseif @v==3
float b=|pz+1/abs(pz)+fpixel|
elseif @v==4
float b=|pz+conj(fpixel)-1i|
elseif @v==5
float b=|pz+1/pz+1/fpixel+1i|
elseif @v==6
float b=|2*pz+flip(fpixel)+pz*(pz-1i)/(pz+1i)|
elseif @v==7
float b=|pz+flip(fpixel)+flip(pz)+2*pz*(pz-1i)/(pz+1i)|
elseif @v==8
float b=|pz+flip(fpixel)+conj(pz)+2*abs(pz)*(pz-1i)/(pz+1i)|
elseif @v==9
float b=|pz+flip(fpixel)+conj(pz)+2*conj(pz)*(pz-1i)/(pz+1i)|
elseif @v==10
float b=|pz+(pz-1i)/(pz+1i)+flip(fpixel)|
elseif @v==11
float b=|pz+flip(fpixel)+sqr(pz)+pz*(pz-1i)/(pz+1i)|
elseif @v==12
float b=|pz+log((pz-1i)/(pz+1i))+flip(fpixel)|
elseif @v==13
float b=|pz+sqr((pz-1i)/(pz+1i))+flip(fpixel)|
elseif @v==14
float b=|pz-(pz-1i)/(pz+1i)+flip(fpixel)|
elseif @v==15
float b=|pz-abs((pz-1i)/(pz+1i))+flip(fpixel)|
elseif @v==16
float b=|pz+flip((pz-fpixel)/(pz+fpixel))|
elseif @v==17
float b=|pz++sqr(pz)+abs(conj((pz-fpixel)/(pz+fpixel)))|
elseif @v==18
float b=|pz+conj(pz)+flip(conj((pz-fpixel)/(pz+fpixel)))+1.25i|
elseif @v==19
float b=|pz+flip((pz-2i)/(1-2i*pz))+flip(fpixel)|
elseif @v==20
float b=|pz+flip((pz-2i)/(1-2i*pz))+conj(fpixel)|
elseif @v==21
float b=|pz+conj((pz-2i)/(1-2i*pz))+conj(fpixel)|
elseif @v==22
float b=|pz-abs((pz-2i*fpixel)/(1-2i*pz))+abs(fpixel)|
elseif @v==23
float b=|pz-conj((pz-2i*fpixel)/(1-2i*pz))+abs(fpixel)|
elseif @v==24
float b=|pz+flip((pz-recip(fpixel))/(1-recip(fpixel)*pz))|
elseif @v==25
float b=|pz+flip((pz-recip(fpixel))/(1-recip(fpixel)*pz))+(pz-1i)/(pz+1i)|
elseif @v==26
float b=|pz+abs((pz-recip(fpixel))/(1-recip(fpixel)*pz))|
elseif @v==27
float b=|pz+abs((pz-recip(fpixel))/(1-recip(fpixel)*pz))-(pz-1i)/(pz+1i)|
elseif @v==28
float b=|pz^3+flip(pz)-1+fpixel|
elseif @v==29
float b=|-pz^3+flip(pz)-1+conj(fpixel)|
elseif @v==30
float b=|-pz^3+abs(pz)+1+conj(fpixel)|
elseif @v==31
float b=|0.5*pz^3*1i-pz^2+pz+flip(fpixel)|
elseif @v==32
float b=|0.5*pz^3*1i-pz^2+flip(pz)+flip(fpixel)|
elseif @v==33
float b=|pz^4+0.5*pz^3*1i-pz^2+flip(pz)+conj(flip(fpixel))|
elseif @v==34
float b=|pz^4-pz^3*1i-pz^2+abs(pz)+conj(flip(fpixel))|
elseif @v==35
float b=|-pz^4+pz^3*1i-pz^2+abs(pz)+fpixel|
elseif @v==36
float b=|flip(pz/(1i+pz^2))+0.5*pz+conj(fpixel)|
elseif @v==37
float b=|abs(pz/(1i+pz^2))+pz+flip(fpixel)|
elseif @v==38
float b=|abs(pz/(1i+pz^2))-2*pz+flip(fpixel)|
elseif @v==39
float b=|abs(pz/(1i+pz^2))-2*pz+conj(fpixel)|
elseif @v==40
float b=|-2*conj(pz/(1i+pz^2))-2*pz+conj(fpixel)|
elseif @v==41
float b=|-0.5*flip(pz/(1i+pz^2))+2*pz+flip(fpixel)|
elseif @v==42
float b=|1i*pz-flip((pz^3+2)/(3*pz^2))+fpixel+1|
elseif @v==43
float b=|1i*pz-flip((pz^3+2)/(3*pz^2))+conj(fpixel+1)|
elseif @v==44
float b=|1i*pz-abs((pz^3+2)/(3*pz^2))+conj(fpixel+1)|
elseif @v==45
float b=|1i*pz+abs((pz^3+2)/(3*pz^2))+flip(fpixel+1)|
elseif @v==46
float b=|1i*pz+abs((pz^3+2)/(3*pz^2))+conj(fpixel+1)|
elseif @v==47
float b=|1i*pz+0.5*abs((pz^3+2)/(3*pz^2))+abs(fpixel+0.5)|
else
float b=|1i*pz+conj(fpixel+0.5)|
endif
if b<a
a=b
endif
else
if @v2==0
float b=|2*pz+flip(pixel)-1i|
elseif @v2==1
float b=|pz+cosh(pz)+pixel+1i|
elseif @v2==2
float b=|pz+recip(1/flip(pz)+pixel+1i)|
elseif @v2==3
float b=|pz+1/abs(pz)+pixel|
elseif @v2==4
float b=|pz+abs(pixel*pz^2+0.5i)|
elseif @v2==5
float b=|pz^2*(pixel-1i)/(pixel+1i)+abs(pixel)-pz^2*(pz-conj(pixel))/(1-conj(pixel)*pz)|
elseif @v2==6
float b=|2*pz+flip(pixel)+pz*(pz-1i)/(pz+1i)|
elseif @v2==7
float b=|2*pz+pixel+2*pz*(pz-1i)/(pz+1i)|
elseif @v2==8
float b=|pz+flip(pixel)+conj(pz)+2*abs(pz)*(pz-1i)/(pz+1i)|
elseif @v2==9
float b=|pz+flip(pixel)+conj(pz)+2*conj(pz)*(pz-1i)/(pz+1i)|
elseif @v2==10
float b=|pz+(pz-1i)/(pz+1i)+exp(pixel)|
elseif @v2==11
float b=|pz+flip(pixel)+sqr(pz)+pz*(pz-1i)/(pz+1i)|
elseif @v2==12
float b=|pz+abs((pz-1i)/(pz+1i))+pixel-0.7i|
elseif @v2==13
float b=|pz+abs((pz-1i)/(pz+1i))+pixel-1i|
elseif @v2==14
float b=|pz^2-(pz-1i)/(pz+1i)+flip(pz)+pixel+1i|
elseif @v2==15
float b=|pz-flip((pz-1i*pz)/(pz+1i))+abs(pz)^2+pixel+0.15i|
elseif @v2==16
float b=|pz+flip((pz-pixel)/(pz+pixel))|
elseif @v2==17
float b=|pz++sqr(pz)+abs(conj((pz-pixel)/(pz+pixel)))|
elseif @v2==18
float b=|2i*pz+conj(pixel)-pz^2*(pz-flip(pixel))/(1-flip(pixel)*pz)|
elseif @v2==19
float b=|pz+abs((pz-2i)/(1-2i*pz))+pixel-0.85i|
elseif @v2==20
float b=|2i*pz+conj(pixel)-pz^2*(pz-abs(pixel))/(1-abs(pixel)*pz)|
elseif @v2==21
float b=|pz+conj((pz-2i)/(1-2i*pz))+conj(fpixel)|
elseif @v2==22
float b=|pz-abs((pz-2i*pixel)/(1-2i*pz))+pixel+1i|
elseif @v2==23
float b=|abs(pz)-flip(pz^2*(pz-2i*pixel)/(1-2i*pz))+pixel-1.15i|
elseif @v2==24
float b=|2i*pz+conj(pixel)-pz^2*(pz-abs(pixel))/(1-abs(pixel)*pz)|
elseif @v2==25
float b=|0.5i*pz+conj(pixel)-pz^2*(pz-abs(pixel))/(1-abs(pixel)*pz)|
elseif @v2==26
float b=|1i*pz+sqr(pixel)-pz^2*conj((pz-pixel)/(1-pixel*pz))+1i|
elseif @v2==27
float b=|abs(pz^3)+1i*pz+pixel+1i|
elseif @v2==28
float b=|pz^3+flip(pz)-1+pixel|
elseif @v2==29
float b=|-pz^3+flip(pz)-1+conj(pixel)|
elseif @v2==30
float b=|-pz^3+abs(pz)+1+conj(pixel)|
elseif @v2==31
float b=|0.5*pz^3*1i-pz^2+pz+flip(pixel)|
elseif @v2==32
float b=|0.5*pz^3*1i-pz^2+flip(pz)+flip(pixel)|
elseif @v2==33
float b=|pz^4+0.5*pz^3*1i-pz^2+flip(pz)+conj(flip(pixel))|
elseif @v2==34
float b=|pz^4-pz^3*1i-pz^2+abs(pz)+conj(flip(pixel))|
elseif @v2==35
float b=|-pz^4+pz^3*1i-pz^2+abs(pz)+pixel|
elseif @v2==36
float b=|flip(pz/(1i+pz^2))+0.5*pz+conj(pixel)|
elseif @v2==37
float b=|flip(pz/(1i+pz^2))+pz+abs(pixel+1i*pz*pixel)|
elseif @v2==38
float b=|abs(pz/(1i+pz^2))-2*pz+flip(pixel)|
elseif @v2==39
float b=|-2*abs(pz/(1i+pz^2))-0.9i*sqr(pz)+pz*pixel|
elseif @v2==40
float b=|-2*conj(pz/(1i+pz^2))-2*pz+conj(pixel)|
elseif @v2==41
float b=|-0.5*flip(pz/(1i+pz^2))+2*pz+flip(pixel)|
elseif @v2==42
float b=|1i*pz-flip((pz^3+2)/(3*pz^2))+pixel+1|
elseif @v2==43
float b=|1i*pz+abs((pz^3+1i*pz)/(3*pz^2))+pixel+1|
elseif @v2==44
float b=|1i*pz-abs((pz^3+2)/(3*pz^2-3.5i*pz))+sqr(pixel+1)|
elseif @v2==45
float b=|1i*pz+abs((pz^3+2)/(3*pz^2))+sqr(pixel+0.5)*pz|
elseif @v2==46
float b=|pz^2+flip(cotan(pz))+pixel+1i|
elseif @v2==47
float b=|conj(pz)-abs(pz^2*(pz-2i*pixel)/(1-2i*pz))+pixel|
elseif @v2==48

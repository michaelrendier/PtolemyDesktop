fpixel=pz
a=(0,0)
b=(0,0)
if @mj==1
pz=@pf(pz)
else
pz=@sp
endif
c1=@js1
c2=@js2
c=@pf(fpixel)
i=0
return pz
endfunc
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if @mj==1
if i==0
b=pz^@pow1+c1/(pz-@dmp1)^@pow2+@mp1*a
a=pz
pz=b
i=i+1
else
b=pz^@pow3+c2/(pz-@dmp2)^@pow4+@mp2*a
a=pz
pz=b
i=0
endif
else
if i==0
b=pz^@pow1+@pp1*c/(pz-@dmp1)^@pow2+@mp1*a
a=pz
pz=b
i=i+1
else
b=pz^@pow3+@pp2*c/(pz-@dmp2)^@pow4+@mp2*a
a=pz
pz=b
i=0
endif
endif
return pz
endfunc

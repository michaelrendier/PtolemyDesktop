class OM_Memzon(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fPixel=pz
if @mj==0
if @st==0
pz=@sf(pz)
else
pz=@sp
endif
else
pz=@sf(pz)
endif
i=0
return pz
endfunc
private:
complex fPixel
int i
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if @v==0
if @mj==0
if i<@mtp
pz=pz^2+@mtf2(pz)+@pp1*@pf(fpixel)
i=i+1
else
pz=@mtf1(pz)^2+@mtf2(pz)+@pp2*@pf(fpixel)
i=0
endif
else
if i<@mtp
pz=pz^2+@mtf2(pz)+@c1
i=i+1
else
pz=@mtf1(pz)^2+@mtf2(pz)+@c2
i=0
endif
endif
elseif @v==1
if @mj==0
if i<@mtp
pz=pz^2+@mtf2(pz)+@pp1*@pf(fpixel)
i=i+1
else
pz=@mtf1(pz)^2-@mtf2(pz)+@pp2*@pf(fpixel)
i=0
endif
else
if i<@mtp
pz=pz^2+@mtf2(pz)+@c1+0.3
i=i+1
else
pz=@mtf1(pz)^2-@mtf2(pz)+@c2+0.75
i=0
endif
endif
else
if @mj==0
if i<@mtp
pz=pz^2-@mtf2(pz)+@pp1*@pf(fpixel)
i=i+1
else
pz=@mtf1(pz)^2+@mtf2(pz)+@pp2*@pf(fpixel)
i=0
endif
else
if i<@mtp
pz=pz^2-@mtf2(pz)+@c1+2
i=i+1
else
pz=@mtf1(pz)^2+@mtf2(pz)+@c2
i=0
endif
endif
endif
return pz
endfunc

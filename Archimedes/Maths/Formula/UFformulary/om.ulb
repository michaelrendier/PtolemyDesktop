class OM_TetravarX14(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
a=(0,0)
b=(0,0)
if @mj==0
pk=@sp
pq=@sp
pz=@sp
pw=@sp
else
pz=@pf(pz)
pk=pz
pq=pz
pw=pz
endif
return pz
return pq
return pk
return pw
endfunc
private:
complex pk
complex pw
complex pq
complex a
complex b
complex fpixel
complex func Iterate(complex pz)
pw=@wp1*pw+@wp2
pk=@kp1*pk+@kp2
pz=@zp1*pz+@zp2
pq=@qp1*pq+@qp2
a=pw
b=pk
if @mj==0
if @v==0
pw=pw^2+@p1*@pf(fpixel)+pk/pz
pk=pk^2+@p2*@pf(fpixel)+pz/pq
pz=pz^2+pq^2+a^2+b^2+@p3*@pf(fpixel)
pq=pq^2+@p4*@pf(fpixel)+a/b
elseif @v==1
pw=pw^2+@p1*@pf(fpixel)+sqr(pk)/pz
pk=pk^2+@p2*@pf(fpixel)+pz/pq
pz=pz^2+pq^2+a^2+b^2+@p3*@pf(fpixel)
pq=pq^2+@p4*@pf(fpixel)+a/b
elseif @v==2
pw=pw^2+@p1*@pf(fpixel)+sqr(pk)/pz
pk=pk^2+@p2*@pf(fpixel)+pz/pq
pz=pz^2+pq^2+a^2+b^2+@p3*@pf(fpixel)
pq=pq^2+@p4*@pf(fpixel)+sqr(a)/b
elseif @v==3
pw=pw^2+@p1*@pf(fpixel)+pk/pz
pk=pk^2+@p2*@pf(fpixel)+pz/pq
pz=pz^2+pq^2+a^2+b^2+@p3*@pf(fpixel)
pq=pq^2+@p4*@pf(fpixel)+sqr(a)/b
elseif @v==4
pw=pw^2+@p1*@pf(fpixel)+pk/pz
pk=pk^2+@p2*@pf(fpixel)+sqr(pz)/pq
pz=pz^2+pq^2+a^2+b^2+@p3*@pf(fpixel)
pq=pq^2+@p4*@pf(fpixel)+sqr(a)/b
else
pw=pw^2+@p1*@pf(fpixel)+sqr(pk)/pz
pk=pk^2+@p2*@pf(fpixel)+sqr(pz)/pq
pz=pz^2+pq^2+a^2+b^2+@p3*@pf(fpixel)
pq=pq^2+@p4*@pf(fpixel)+sqr(a)/b
endif
else
if @v==0
pw=pw^2+@p1+pk/pz
pk=pk^2+@p2+pz/pq
pz=pz^2+pq^2+a^2+b^2+@p3
pq=pq^2+@p4+a/b
elseif @v==1
pw=pw^2+@p1+sqr(pk)/pz
pk=pk^2+@p2+pz/pq
pz=pz^2+pq^2+a^2+b^2+@p3
pq=pq^2+@p4+a/b
elseif @v==2
pw=pw^2+@p1+sqr(pk)/pz
pk=pk^2+@p2+pz/pq
pz=pz^2+pq^2+a^2+b^2+@p3
pq=pq^2+@p4+sqr(a)/b
elseif @v==3
pw=pw^2+@p1+pk/pz
pk=pk^2+@p2+pz/pq
pz=pz^2+pq^2+a^2+b^2+@p3
pq=pq^2+@p4+sqr(a)/b
elseif @v==4
pw=pw^2+@p1+pk/pz
pk=pk^2+@p2+sqr(pz)/pq
pz=pz^2+pq^2+a^2+b^2+@p3
pq=pq^2+@p4+sqr(a)/b
else
pw=pw^2+@p1+sqr(pk)/pz
pk=pk^2+@p2+sqr(pz)/pq
pz=pz^2+pq^2+a^2+b^2+@p3
pq=pq^2+@p4+sqr(a)/b
endif
endif
return pz
return pw
return pk
return pq
endfunc

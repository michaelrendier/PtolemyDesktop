pk=@sp
pq=@sp
pz=@sp
pw=@sp
else
pz=@pf(pz)
pk=pz
pq=pz
pw=pz
endif
return pz
return pq
return pk
return pw
endfunc
private:
complex pk
complex pw
complex pq
complex a
complex b
complex c
complex fpixel
complex func Iterate(complex pz)
pw=@wp1*pw+@wp2
pk=@kp1*pk+@kp2
pz=@zp1*pz+@zp2
pq=@qp1*pq+@qp2
a=pw
b=pk
c=pz
if @mj==0
if @v==0
pw=pw^2+@pf(fpixel)+@p1*pk*pz*pq
pk=pk^2+@pf(fpixel)+@p2*(a+pz+pq)
pz=pz^2+@pf(fpixel)+@p3*(a*b*pq)^2
pq=pq^2+@pf(fpixel)+@p4*(a+b+c)^2
elseif @v==1
pw=pw^2+@pf(fpixel)+@p1*pk*pz*pq*pw
pk=pk^2+@pf(fpixel)+@p2*(a+pz+pq)
pz=pz^2+@pf(fpixel)+@p3*(a*b*pq*pz)^2
pq=pq^2+@pf(fpixel)+@p4*(a+b+c)^2
elseif @v==2
pw=pw^2+@pf(fpixel)+@p1*pk*pz*pq
pk=pk^2+@pf(fpixel)+(@p2+0.45)*(a+pz+pq+pk)
pz=pz^2+@pf(fpixel)+@p3*(a*b*pq)^2
pq=pq^2+@pf(fpixel)+@p4*(a+b+c+pq)^2
else
pw=pw^2+@pf(fpixel)+@p1*pk*pz*pq*pw
pk=pk^2+@pf(fpixel)+(@p2+0.35)*(a+pz+pq+pk)
pz=pz^2+@pf(fpixel)+@p3*(a*b*pq*pz)^2
pq=pq^2+@pf(fpixel)+@p4*(a+b+c+pq)^2
endif
else
if @v==0
pw=pw^2+@p1*pk*pz*pq
pk=pk^2+@p2*(a+pz+pq)
pz=pz^2+@p3*(a*b*pq)^2
pq=pq^2+@p4*(a+b+c)^2
elseif @v==1
pw=pw^2+@p1*pk*pz*pq*pw
pk=pk^2+(@p2-0.11)*(a+pz+pq)
pz=pz^2+@p3*(a*b*pq*pz)^2
pq=pq^2+@p4*(a+b+c)^2
elseif @v==2
pw=pw^2+@p1*pk*pz*pq
pk=pk^2+(@p2+0.56)*(a+pz+pq+pk)
pz=pz^2+@p3*(a*b*pq)^2
pq=pq^2+@p4*(a+b+c+pq)^2
else
pw=pw^2+@p1*pk*pz*pq*pw
pk=pk^2+(@p2+0.48)*(a+pz+pq+pk)
pz=pz^2+@p3*(a*b*pq*pz)^2
pq=pq^2+@p4*(a+b+c+pq)^2
endif
endif
pz=pz+pw+pk+pq
return pz
return pw
return pk
return pq
endfunc

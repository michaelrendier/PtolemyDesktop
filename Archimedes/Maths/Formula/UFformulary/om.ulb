class OM_ModFelixMandelbrot(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
ang=2*pi/3
c1=((0,0)*ang)
c2=((0,1)*ang)
c3=((0,2)*ang)
r=sqrt(3)/2
pz=@pf(pz)
c=@pf(fpixel)
return pz
endfunc
private:
complex c1
complex c2
complex c3
float r
complex c
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if @v==6
pz=pz^2-0.4*recip(pz)+@pp*c
elseif @v==7
pz=pz^2-0.5*pz+@pp*c
elseif @v==8
pz=pz^2+0.3i*exp(pz)+@pp*c
elseif @v==9
pz=pz^2+0.5i*cotan(pz)+@pp*c
elseif @v==10
pz=pz^2-0.5i*cotan(pz)+@pp*c
elseif @v==11
pz=pz^2+0.5i*cotanh(pz)+@pp*c
elseif @v==12
pz=pz^2-0.5i*cotanh(pz)+@pp*c
elseif @v==13
pz=pz^2+(-0.25,0.25)*cos(pz)+@pp*c
elseif @v==14
pz=pz^2+(-0.25,0.25)*cosh(pz)+@pp*c
else
pz=pz^2+@pp*c
endif
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
endif
if @v==1
pz=abs(pz)
elseif @v==2
pz=flip(pz)
elseif @v==3
pz=1.06*conj(pz)
elseif @v==4
pz=flip(conj(pz))
elseif @v==5
pz=log(exp(pz))
endif
return pz
endfunc

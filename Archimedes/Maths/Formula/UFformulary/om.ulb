class OM_Koatrone(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fPixel=pz
z1=@p3
z2=@p8
c=fn2(fpixel)
i=0
return pz
return z1
return z2
endfunc
private:
complex c
complex z1
complex z2
int i
complex func Iterate(complex pz)
i=i+1
z1=@p10*z1+@p11
z2=@p12*z2+@p13
z1=z1+@p5*sqr(z1)
z2=z2+@p5*sqr(z2)
z1=z1+@p6/z1
z2=z2+@p6/z2
if @v==0
a=3*sqr(z1^i+z2^i)
b=z1^2+@p1*(z2*z1-c)/a
z2=z2^2+@p2*fn3(z2*z1+c)/a
elseif @v==1
a=3*sqr(z1^i+z2^i)
b=z1^2+@p1*(z2*z1-c)^2/a
z2=z2^2+@p2*fn3(z2*z1+c^2)^2/a
elseif @v==2
a=3*sqr(z1^i+z2^i)
b=z1^2-@p1*(z2*z1-c)^2/a
z2=z2^2+@p2*fn3(z2*z1+c)/a
elseif @v==3
a=3*sqr(z1^i+z2^i)
b=z1^2-@p1*(z2*z1-c)^2/a
z2=z2^2+@p2*fn3(z2*z1+c^2)^2/a
elseif @v==4
a=3*sqr(z1^i+z2^i)
b=z1^2-@p1*(z2*z1+c)^2/a
z2=z2^2+@p2*fn3(z2*z1+c)/a
elseif @v==5
a=3*sqr(log(z1^i+z2^i))
b=z1^2+@p1*(z2*z1-c)/a
z2=z2^2+@p2*fn3(z2*z1+c)/a
elseif @v==6
a=3*sqr(log(z1^i+z2^i))
b=z1^2+@p1*(z2*z1-c)^2/a
z2=z2^2+@p2*fn3(z2*z1+c^2)^2/a
elseif @v==7
a=3*sqr(log(z1^i+z2^i))
b=z1^2-@p1*(z2*z1-c)^2/a
z2=z2^2+@p2*fn3(z2*z1+c)/a
elseif @v==8
a=3*sqr(log(z1^i+z2^i))
b=z1^2-@p1*(z2*z1-c)^2/a
z2=z2^2+@p2*fn3(z2*z1+c^2)^2/a
elseif @v==9
a=3*sqr(log(z1^i+z2^i))
b=z1^2-@p1*(z2*z1+c)^2/a
z2=z2^2+@p2*fn3(z2*z1+c)/a
elseif @v==10
a=3*log(z1^i+z2^1)^3
b=z1^2+@p1*(z2*z1-c)/a
z2=z2^2+@p2*fn3(z2*z1+c)/a
elseif @v==11
a=3*log(z1^i+z2^i)^3
b=z1^2+@p1*(z2*z1-c)^2/a
z2=z2^2+@p2*fn3(z2*z1+c^2)^2/a
elseif @v==12
a=3*log(z1^i+z2^i)^3
b=z1^2-@p1*(z2*z1-c)^2/a
z2=z2^2+@p2*fn3(z2*z1+c)/a
elseif @v==13
a=3*log(z1^i+z2^i)^3
b=z1^2-@p1*(z2*z1-c)^2/a
z2=z2^2+@p2*fn3(z2*z1+c^2)^2/a
else
a=3*log(z1^i+z2^i)^3
b=z1^2-@p1*(z2*z1+c)^2/a
z2=z2^2+@p2*fn3(z2*z1+c)/a
endif
z1=@p7*fn4(b)+@p4
pz=z1^2+z2^2
return pz
return z1
return z2
endfunc
bool func IsBailedOut(complex pz)
bool bail=false
bail=(|(pz+z1+z2)/3|>@p_bailout)
return bail
endfunc

d=@p3*fn2(pz^2-pz)+@p4
elseif @v=="3"
d=@p3*fn2(pz^3-1.5*pz^2+0.25)+@p4
elseif @v=="4"
d=@p3*fn2(pz^4-2*pz^3+pz)+@p4
elseif @v=="5"
d=@p3*fn2(pz^5-2.5*pz^4+2.5*pz^2-0.5)+@p4
elseif @v=="6"
d=@p3*fn2(pz^6-3*pz^5+5*pz^3-3*pz)+@p4
elseif @v=="7"
d=@p3*fn2(pz^7-3.5*pz^6+8.75*pz^4-10.5*pz^2+2.125)+@p4
else
d=@p3*fn2(pz^8-4*pz^7+14*pz^5-28 *pz^3+17*pz)+@p4
endif
a=cabs(fn3(d)-fn3(fpixel))
b=cabs(fn4(d)-@fn5(fpixel))
if f && @adj1<b && b<@adj2
f=false
c=a
endif
endfunc
float func ResultIndex(complex pz)
if @solid
if @invert
if c<@p7
index=c
else
m_Solid=true
endif
else
if c>=@p7
index=c
else
m_Solid=true
endif
endif
else
index=c
endif
return index
endfunc
private:
float a
float b
float c
complex d
bool f
complex fpixel
float index
default:
title="Euler Polynomial Traps"
int param version
caption="Version"
default=100
visible=@version<100

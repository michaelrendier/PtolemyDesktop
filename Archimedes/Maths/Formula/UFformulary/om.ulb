+x0-0.7*real(@p2)*sin(2*pi*y0)+flip(y0-(-0.7/real(@p2))*sin(2*pi*(x0-0.7*real(@p2)*sin(2*pi*y0))))\
+sin(real(@p3-6.3)*y0)+sqr(sin(real(@p3-6.3)*x0))+flip(sin(real(@p4)*x0)+sqr(sin(real(@p4)*y0)))
endif
z=z+@app*@apf(pixel)
x1=real(a)
y1=imag(a)
x2=real(z)
y2=imag(z)
if @v2=="1"
b=abs(y1-y2)
c=abs(x1-x2)
if b<c
h=b
else
h=c
endif
elseif @v2=="2"
b=y1-y2
c=x1-x2
if b<c
h=b
else
h=c
endif
elseif @v2=="3"
h=abs(y1-y2)
else
b=y1-y2
c=x1-x2
h=b+c
endif
if i%50==0
if h>f
f=h
endif
else
if h>g
g=h
endif
endif
a=pz
i=i+1
endfunc
float func ResultIndex(complex pz)
if f==0.0
index=@tp*real(@tf(g))
elseif g==0.0
index=@tp*real(@tf(f))
else
if f<g
index=@tp*real(@tf((f/g)))
else
index=@tp*real(@tf(g/f))
endif
endif
return index
endfunc

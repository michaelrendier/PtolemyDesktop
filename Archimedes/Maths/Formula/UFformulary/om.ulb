complex func Init(complex pz)
ConvergentDivergentFormula.Init(pz)
pz=@sf(pz)
return pz
endfunc
complex func Iterate(complex pz)
ConvergentDivergentFormula.Iterate(pz)
pz=@zp1*pz+@zp2
pz=pz+@ar/pz
u=@p1*(sqr((pz^2+@mp1-1)/(2*pz+@mp1-2)))+@p2*pz
v=@p3*(sqr((u^2+@mp2-1)/(2*u+@mp2-2)))+@p4*pz
pz=@p3*pz+(1-@p3)*v
return pz
endfunc
default:

pq=pq/d+@p4*c
c=@p5*c/2+@p6*(pz+pw+pk+pq)
elseif @v==4
pw=pw/pz+(@p1-1.9)*c
pk=pk/pz+@p2*c
pz=a^2+b^2+pz^2+pq^2+@p3*c

pz=pz^2+exp(log(pz)^2+@xp1/log(pz)+1/log(c1+0.3))+exp(log(-pz)^2+@xp1/log(-pz)+1/log(c1+0.3))+a^2+exp(log(a)^2+@xp1/log(a)+1/log(c2))+exp(log(-a)^2+@xp1/log(-a)+1/log(c2))

class OM_EnaridulaJulia2(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
a0=(0,0)
a=fn1(pz)
b=fn1(pz)
pz=fn1(pz)
return pz
return a
return b
endfunc
private:
complex a0
complex a
complex b
complex func Iterate(complex pz)
a=@p3*fn2(a)+@p4
b=@p3*fn2(b)+@p5
a0=a
if @v==0
a=-a^3+b^3+@p1
b=1/(-a0*b*(a+b)+@p2)
elseif @v==1
a=-a^3+b^3+@p1
b=1/(-a0*b*(a0+b)+@p2)
elseif @v==2
a=-a^3+b^3+@p1
b=1/(-a*b*(a0+b)+@p2)
else
a=-a^3+b^3+@p1
b=1/(-a*b*(a+b)+@p2)
endif
pz=a+b
return pz
return a
return b
endfunc

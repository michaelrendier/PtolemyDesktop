pz=(pz-(@ap-1.3)*@af(values[i2]))^@pow1+(1+(@ap-1.3)*@af(values[i2]))/(pz+(@ap-1.3)*@af(values[i2])-(@p1-0.3))^@pow2+(@ap-1.3)*@af(values[i2])+c
elseif @av==28
pz=@zp1*(pz-@ap*@af(values[i2]))+@zp2
pz=(pz-@ap*@af(values[i2]))^@pow1+(1+@ap*@af(values[i2]))/(pz-@ap*@af(values[i2])-(@p1+0.4))^@pow2+@ap*@af(values[i2])+c
endif
if @dv==3
pz=pz+1/(pz+c)
elseif @dv==4
pz=pz+c/(pz+c)
elseif @dv==5
pz=pz+1i/(pz+c)
elseif @dv==6
pz=pz+1i*c/(pz+c)
endif
i2=i2+1
return pz
endfunc

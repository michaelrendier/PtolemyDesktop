endif
else
if i<1
b=pk
pk=@bp3*@bf(pk/pz)+@bp4
pz=pz^2+b^2+@c2*@pf(fpixel)
i=i+1
else
a=pz
pz=pz^2+@bp1*pk+@c1*@pf(fpixel)
pk=pk^2+@bp2*a+@c1*@pf(fpixel)
i=0
endif
endif
return pz
return pk
endfunc
default:

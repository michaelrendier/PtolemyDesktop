}

class OM_AleatorNewtoniMod(common.ulb:ConvergentFormula) {
public:
complex func Init(complex pz)
ConvergentFormula.Init(pz)
i=0
seed=@seed
while i<100
seed=random(seed)
values[i]=seed/#randomrange
i=i+1
endwhile
pz=@sf(pz)
pz=pz+@sp*@sf2(pz)
i2=0
return pz
endfunc
private:
float values[#maxiter]
int i
int seed
int i2
complex func Iterate(complex pz)
ConvergentFormula.Iterate(pz)
if @v==0
pz=@zp1*pz+@zp2+@ap*@af(values[i2])
pz=pz-0.1*sqr(pz)
f=pz^i2-1
f1=3*pz^(i2-1)
pz=pz-@np1*f/f1+@np2
elseif @v==1
pz=@zp1*pz+@zp2
pz=pz-0.1*sqr(pz)
f=pz^i2-1+@ap*@af(values[i2])
f1=3*pz^(i2-1)
pz=pz-@np1*f/f1+@np2

class OM_Lod(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
pz=@sf(pz)
c=@js
i=0
return pz
endfunc
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
pz=pz+@ar/pz
pz=pz+@ac*(pz-1i)/(pz+1i)
if i==0
pz=@p3*pz^2*(@p1*pz^2+@p2)/(pz^2+@p1)+@p4+@ap1*@sf(pixel)
else
pz=pz^2+c+@ap2*@sf(pixel)
endif
i=i+1
return pz
endfunc

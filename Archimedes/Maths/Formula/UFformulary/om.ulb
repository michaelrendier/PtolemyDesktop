else
pz=@start
endif
return pz
endfunc
complex func Iterate(complex pz)
ConvergentFormula.Iterate(pz)
pz=@zp1*pz+@zp2
if @v==0
f=pz^@pow-@c
f1=@pow*pz^(@pow-1)
a=pz-(2*@sp/(@sp+2))*(f/f1)
f1a=@pow*a^(@pow-1)
elseif @v==1
f=pz^@pow-pz^(@pow-1)-pz^(@pow-2)-@c
f1=@pow*pz^(@pow-1)-(@pow-1)*pz^(@pow-2)-(@pow-2)*pz^(@pow-3)
a=pz-(2*@sp/(@sp+2))*(f/f1)
f1a=@pow*a^(@pow-1)-(@pow-1)*a^(@pow-2)-(@pow-2)*a^(@pow-3)
elseif @v==2
f=pz^@pow+pz^(@pow-1)+pz^(@pow-2)-@c
f1=@pow*pz^(@pow-1)+(@pow-1)*pz^(@pow-2)+(@pow-2)*pz^(@pow-3)
a=pz-(2*@sp/(@sp+2))*(f/f1)
f1a=@pow*a^(@pow-1)+(@pow-1)*a^(@pow-2)+(@pow-2)*a^(@pow-3)
elseif @v==3
f=pz^@pow+1/pz^@pow-@c
f1=@pow*pz^(@pow-1)-@pow*pz^(-@pow-1)
a=pz-(2*@sp/(@sp+2))*(f/f1)
f1a=@pow*a^(@pow-1)-@pow*a^(-@pow-1)
else
f=pz^@pow-1/pz^@pow-@c
f1=@pow*pz^(@pow-1)+@pow*pz^(-@pow-1)
a=pz-(2*@sp/(@sp+2))*(f/f1)
f1a=@pow*a^(@pow-1)+@pow*a^(-@pow-1)
endif
k1=@sp^3-4*@sp+8
k2=(@sp+2)*(@sp/(@sp+2))^@sp
if @st==0
pz=pz-@sp2*(@sp/8)*(k1*f/f1-(@sp-2)*k2*((@sp-1)-k2*f1/f1a)*(f/f1a))+@np*@nf(fpixel)
else
pz=pz-@sp2*(@sp/8)*(k1*f/f1-(@sp-2)*k2*((@sp-1)-k2*f1/f1a)*(f/f1a))+@nf(fpixel)
endif
return pz
endfunc

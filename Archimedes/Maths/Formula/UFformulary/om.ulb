else
z2=@sf(pz)
pz=@sf(pz)
c=@js
if @v==0
c=@js-0.175
endif
endif
return pz
return z2
endfunc
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
z2=@z2p1*z2+@z2p2
pz=pz+@ar/pz
z2=z2+@ar/z2
pz=pz+@ac*(pz-1i)/(pz+1i)
z2=z2+@ac*(z2-1i)/(z2+1i)
if @v==0
pz=(pz^2/(pz-@p1))^2+c
z2=(z2^2/(z2-@p1))^2+c
a=z2
z2=@bp1*c*@bf(z2/pz)+@bp2
pz=@bp3*(pz+a)+c
elseif @v==1
pz=(pz^2/(pz-@p1))^2+c
z2=(z2^2/(z2-@p1))^2+c
a=z2
z2=@bp1*c*@bf(z2/pz)+@bp2+pz
pz=@bp3*(pz+a)+a+c
else
pz=(pz^2/(pz-@p1))^2+c
z2=(z2^2/(z2-@p1))^2+c
a=z2
z2=@bp1*c*@bf(z2/pz)+@bp2-pz
pz=@bp3*(pz+a)+a+c
endif
return pz
return z2
endfunc

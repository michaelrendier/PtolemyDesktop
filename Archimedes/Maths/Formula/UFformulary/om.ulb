class OM_AltNewtonMidpoint(common.ulb:ConvergentFormula) {
public:
complex func Init(complex pz)
ConvergentFormula.Init(pz)
pz=@sf(pz)
i=0
return pz
endfunc
complex func Iterate(complex pz)
ConvergentFormula.Iterate(pz)
m_ZOld=pz
pz=@p6*pz+@p7
if @version==100
if @av==0
if i==0
pz=pz-@np*(pz^@pow-@c)/(3*pz^(@pow-1))
i=i+1
else
pz=pz-@mp*((pz^@pow-@c)/((3*pz^(@pow-1))*(pz-((pz^@pow-@c)/(3*pz^(@pow-1)))/2)))
i=0
endif
else
if i==0
pz=pz-@mp*((pz^@pow-@c)/((3*pz^(@pow-1))*(pz-((pz^@pow-@c)/(3*pz^(@pow-1)))/2)))
i=i+1
else
pz=pz-@np*(pz^@pow-@c)/(3*pz^(@pow-1))
i=0
endif
endif
else
if @av==0
if i==0
pz=pz-@np*(pz^@pow-@c)/(@pow*pz^(@pow-1))
i=i+1
else
pz=pz-@mp*((pz^@pow-@c)/((@pow*pz^(@pow-1))*(pz-((pz^@pow-@c)/(@pow*pz^(@pow-1)))/2)))
i=0
endif
else
if i==0
pz=pz-@mp*((pz^@pow-@c)/((@pow*pz^(@pow-1))*(pz-((pz^@pow-@c)/(@pow*pz^(@pow-1)))/2)))
i=i+1
else
pz=pz-@np*(pz^@pow-@c)/(@pow*pz^(@pow-1))
i=0
endif
endif
endif
return pz
endfunc

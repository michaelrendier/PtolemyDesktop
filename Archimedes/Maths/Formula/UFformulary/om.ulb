complex func Iterate(complex pz)
pw=@wp1*pw+@wp2
pk=@kp1*pk+@kp2
pz=@zp1*pz+@zp2
pq=@qp1*pq+@qp2
a=pw
b=pk
d=pz
if @mj==0
if @v==0
pw=pw/pz+c
pk=pk/pz+c
pz=a^2*(a-@p1)/(1-@p1*a)+b^2*(b-@p2)/(1-@p2*b)+pz^2*(pz-@p3)/(1-@p3*pz)+pq^2*(pq-@p4)/(1-@p4*pq)+c
pq=pq/d+c
c=@p5*c/2+@p6*pz
elseif @v==1
pw=pw/pz+c
pk=pk/pz+c
pz=a^2*(a-@p1)/(1-@p1*a)+b^2*(b-@p2)/(1-@p2*b)+pz^2*(pz-@p3)/(1-@p3*pz)+pq^2*(pq-@p4)/(1-@p4*pq)+c
pq=pq/d+c
c=(@p5-0.5)*c/2+@p6*(pz+pw)
elseif @v==2
pw=pw/pz+c
pk=pk/pz+c
pz=a^2*(a-@p1)/(1-@p1*a)+b^2*(b-@p2)/(1-@p2*b)+pz^2*(pz-@p3)/(1-@p3*pz)+pq^2*(pq-@p4)/(1-@p4*pq)+c
pq=pq/d+c
c=(@p5-1)*c/2+@p6*(pz+pw+pk)
else
pw=pw/pz+c
pk=pk/pz+c
pz=a^2*(a-@p1)/(1-@p1*a)+b^2*(b-@p2)/(1-@p2*b)+pz^2*(pz-@p3)/(1-@p3*pz)+pq^2*(pq-@p4)/(1-@p4*pq)+c
pq=pq/d+c
c=(@p5-1.5)*c/2+@p6*(pz+pw+pk+pq)
endif
else
if @v==0
pw=pw/pz+c
pk=pk/pz+c
pz=a^2*(a-@p1)/(1-@p1*a)+b^2*(b-@p2)/(1-@p2*b)+pz^2*(pz-@p3)/(1-@p3*pz)+pq^2*(pq-@p4)/(1-@p4*pq)+c
pq=pq/d+c
c=@p5*c/2+@p6*pz
elseif @v==1
pw=pw/pz+c
pk=pk/pz+c
pz=a^2*(a-@p1)/(1-@p1*a)+b^2*(b-@p2)/(1-@p2*b)+pz^2*(pz-@p3)/(1-@p3*pz)+pq^2*(pq-@p4)/(1-@p4*pq)+c
pq=pq/d+c
c=(@p5-0.5)*c/2+@p6*(pz+pw)
elseif @v==2
pw=pw/pz+c
pk=pk/pz+c
pz=a^2*(a-@p1)/(1-@p1*a)+b^2*(b-@p2)/(1-@p2*b)+pz^2*(pz-@p3)/(1-@p3*pz)+pq^2*(pq-@p4)/(1-@p4*pq)+c
pq=pq/d+c
c=(@p5-1)*c/2+@p6*(pz+pw+pk)
else
pw=pw/pz+c
pk=pk/pz+c
pz=a^2*(a-@p1)/(1-@p1*a)+b^2*(b-@p2)/(1-@p2*b)+pz^2*(pz-@p3)/(1-@p3*pz)+pq^2*(pq-@p4)/(1-@p4*pq)+c
pq=pq/d+c
c=(@p5-1.5)*c/2+@p6*(pz+pw+pk+pq)
endif
endif
return pz
return pw
return pk
return pq
endfunc

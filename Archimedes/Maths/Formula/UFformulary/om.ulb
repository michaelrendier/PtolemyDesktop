}

class OM_Traub-Ostrowski(common.ulb:ConvergentFormula) {
; Traub-Ostrowski root finding method
public:
complex func Init(complex pz)
ConvergentFormula.Init(pz)
fPixel = pz
return fn1(pz)
endfunc
private:
complex fPixel
complex func Iterate(complex pz)
ConvergentFormula.Iterate(pz)
m_ZOld=pz
pz=@p4*fn2(pz)+@p5
if @JM=="J"
if @Va=="none"
pz=pz
elseif @Va=="1"
pz=pz+1.21/sin(pz)
elseif @Va=="2"
pz=pz+0.3/pz
elseif @Va=="3"

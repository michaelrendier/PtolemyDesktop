caption="Start Function"
default=ident()
visible=@st==0
endfunc
param mtp
caption="Memzon Parameter"
default=5
min=1
endparam
func pf
caption="Pixel Function"
default=ident()
endfunc
param mp1
caption="Munster Parameter 1"
default=0.0
endparam
param mp2
caption="Munster Parameter 2"
default=(2,0)
endparam

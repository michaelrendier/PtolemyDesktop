elseif @v==14
pz=pz^2+exp(log(pz)^2+log(exp(log(pz)^2+(@xp1+1)*log(pz)+log(-c1))))+exp(log(-pz)^2+(@xp1+1)*log(pz+1)+log(-c1))^2+a^2+exp(log(a)^2+log(exp(log(a)^2+(@xp1+1)*log(a)+log(c2))))+exp(log(-a)^2+(@xp1+1)*log(a+1)+log(c2))^2
elseif @v==15

float func ResultIndex(complex pz)
if @version==100
if @solid
if @invert
if c<=@sca
index=(log(c)+1)*0.5
else
m_Solid=true
endif
else
if c>@sca
index=(log(c)+1)*0.5
else
m_Solid=true
endif
endif
else
index=(log(c)+1)*0.5
endif
return index
else
if @solid
if @invert
if c<=@sca
index=(log(c)+1)*0.5+@adj2
else
m_Solid=true
endif
else
if c>@sca
index=(log(c)+1)*0.5+@adj2
else
m_Solid=true
endif
endif
else
index=(log(c)+1)*0.5+@adj2
endif
return index
endif
endfunc

z3=@p1*z3^2*(z2-@p2)/(1-(2*@p2-3)*z1/(@p2-2))+@p3*c
elseif @v==8
z1=@p1*z1^2*(z1-@p2)/(1-(2*@p2-3)*z3/(@p2-2))+@p3*c
z2=@p1*z2^2*(z2-@p2)/(1-(2*@p2-3)*z1/(@p2-2))+@p3*c
z3=@p1*z3^2*(z3-@p2)/(1-(2*@p2-3)*z2/(@p2-2))+@p3*c
elseif @v==9

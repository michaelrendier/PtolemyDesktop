class OM_TrivarJulia3(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
if @sv==0
pz=@sf(pz)
pk=pz
pw=pz
elseif @sv==1
pz=@sf(pz)
pk=@sp
pw=pz
elseif @sv==2
pz=@sf(pz)
pk=pz
pw=@sp
else
pz=@sf(pz)
pk=@sp
pw=@sp
endif
return pz
return pk
return pw
endfunc
private:
complex pk
complex pw
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
pk=@kp1*pk+@kp2
pw=@wp1*pw+@wp2
if @v==0
pw=pw^2-pk^2-pz^2+@p1
pk=2*pw*pk+@p2
pz=2*pw*pz+@p3
else
pw=pw^2-pk^2+pz^2+@p1
pk=2*pw*pk+@p2
pz=2*pw*pz+@p3
endif
return pz
return pk
return pw
endfunc

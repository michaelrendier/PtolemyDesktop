class OM_Steffensen2(common.ulb:ConvergentFormula) {
;Steffensen's method for z+1/z=c
;https://en.wikipedia.org/wiki/Steffensen%27s_method
public:
complex func Init(complex pz)
ConvergentFormula.Init(pz)
return @sf(pz)
endfunc
complex func Iterate(complex pz)
m_ZOld=pz
pz=@zp1*pz+@zp2
if @v==0
f=pz^@pow-@c
fa=(pz+f)^@pow-@c
elseif @v==1
f=pz^@pow-pz^(@pow-1)-pz^(@pow-2)-@c
fa=(pz+f)^@pow-(pz+f)^(@pow-1)-(pz+f)^(@pow-2)-@c
else
f=pz^@pow+pz^(@pow-1)+pz^(@pow-2)-@c
fa=(pz+f)^@pow+(pz+f)^(@pow-1)+(pz+f)^(@pow-2)-@c
endif
pz=pz-@sp*f^2/(fa-f)
return pz
endfunc

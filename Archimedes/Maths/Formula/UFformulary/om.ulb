class OM_BivarXPlog6(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fPixel=pz
if @mj==1
pk=@sf(pz)
pz=@sf(pz)
if @v==7 || @v==9 || @v==11
c=-@js
elseif @v==10
c=@js+1.35
else
c=@js
endif
else
if @v==1
pk=-@sp1
pz=@sp2
elseif @v==2
pk=@sp1+2.85
pz=-@sp2
elseif @v==10
pk=@sp1+1.3
pz=@sp2
else
pk=@sp1
pz=@sp2
endif
c=@sf(fpixel)
endif
return pz
return pk
endfunc
private:
complex c
complex pk
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
pk=@kp1*pk+@kp2
a=pk
pk=@bp1*pk/pz+@bp2
if @v==0
pz=pz^2+@xp1*exp(log(pz)^2)+a^2+@xp1*exp(log(a)^2)+c
elseif @v==1
if @mj==1
pz=pz^2+@xp1*exp(log(-pz)^2)+a^2+@xp1*exp(log(-a)^2)+c
else
pz=pz^2-@xp1*exp(log(-pz)^2)+a^2-@xp1*exp(log(-a)^2)+c
endif
elseif @v==2
if @mj==1
pz=pz^3+@xp1*exp(log(-pz)^2)+a^3+@xp1*exp(log(-a)^2)+c
else
pz=pz^3+(@xp1-0.7)*exp(log(-pz)^2)+a^3+(@xp1-0.7)*exp(log(-a)^2)+c
endif
elseif @v==3
if @mj==1
pz=pz^4+@xp1*exp(log(pz)^2)+a^4+@xp1*exp(log(a)^2)+c
else
pz=pz^4+(@xp1-0.7)*exp(log(pz)^2)+a^4+(@xp1-0.7)*exp(log(a)^2)+c
endif
elseif @v==4
if @mj==1
pz=pz^4+@xp1*exp(log(-pz)^2)+a^4+@xp1*exp(log(-a)^2)+c
else
pz=pz^4+(@xp1-0.7)*exp(log(-pz)^2)+a^4+(@xp1-0.7)*exp(log(-a)^2)+c
endif
elseif @v==5
if @mj==1
pz=pz^2-(@xp1-1.25)*(exp(log(pz)^2)+exp(log(-pz)^2))+a^2-(@xp1-1.25)*(exp(log(a)^2)+exp(log(-a)^2))+c
else
pz=pz^2-(@xp1-0.7)*(exp(log(pz)^2)+exp(log(-pz)^2))+a^2-(@xp1-0.7)*(exp(log(a)^2)+exp(log(-a)^2))+c
endif
elseif @v==6
if @mj==1
pz=pz^2-(@xp1-1.25)*(exp(log(pz)^2)-exp(log(-pz)^2))+a^2-(@xp1-1.25)*(exp(log(a)^2)-exp(log(-a)^2))+c
else
pz=pz^2-(@xp1-0.7)*(exp(log(pz)^2)-exp(log(-pz)^2))+a^2-(@xp1-0.7)*(exp(log(a)^2)-exp(log(-a)^2))+c
endif
elseif @v==7
pz=pz^2-@xp1*(exp(log(pz^2+pz)^2))+a^2-@xp1*(exp(log(a^2+a)^2))+c
elseif @v==8
if @mj==1
pz=pz^2+@xp1*(exp(log(pz^2-pz)^2))+a^2+@xp1*(exp(log(a^2-a)^2))+c
else
pz=pz^2+(@xp1-0.7)*(exp(log(pz^2-pz)^2))+a^2+(@xp1-0.7)*(exp(log(a^2-a)^2))+c
endif
elseif @v==9
if @mj==1
pz=pz^2+@xp1*(exp(log(pz)^2+log(c)/log(pz)^2))+a^2+@xp1*(exp(log(a)^2+log(c)/log(a)^2))
else
pz=pz^2+(@xp1-0.7)*(exp(log(pz)^2+log(c)/log(pz)^2))+a^2+(@xp1-0.7)*(exp(log(a)^2+log(c)/log(a)^2))
endif
elseif @v==10
pz=(pz*(pz-1)/(pz+1))^2+exp(log(pz*(pz-1)/(pz+1))^2+@xp1*log(pz*(pz-1)/(pz+1)))+(a*(a-1)/(a+1))^2+exp(log(a*(a-1)/(a+1))^2+@xp1*log(a*(a-1)/(a+1)))+c
else
if @mj==1
pz=(pz*(pz-1)/(pz+1))^2+exp(log(pz*(pz-1)/(pz+1))^2-@xp1*log(pz*(pz-1)/(pz+1))+log(c))+(a*(a-1)/(a+1))^2+exp(log(a*(a-1)/(a+1))^2-@xp1*log(a*(a-1)/(a+1))+log(c))
else
pz=(pz*(pz-1)/(pz+1))^2+exp(log(pz*(pz-1)/(pz+1))^2+@xp1*log(pz*(pz-1)/(pz+1))+log(c))+(a*(a-1)/(a+1))^2+exp(log(a*(a-1)/(a+1))^2+@xp1*log(a*(a-1)/(a+1))+log(c))
endif
endif
return pz
return pk
endfunc
bool func IsBailedOut(complex pz)
bool bail=false
bail=(|(pz+pk)/2|>@p_bailout)
return bail
endfunc

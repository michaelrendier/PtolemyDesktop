caption="Bivar Parameter 2"
default=(-1,0)
endparam
func pf
caption="Pixel Function"
default=ident()
endfunc
param pzp1
caption="Z Parameter 1"
default=(1,0)
endparam
param pzp2
caption="Z Parameter 2"
default=(0,0)
endparam
param pkp1
caption="K Parameter 1"
default=(1,0)
endparam
param pkp2
caption="K Parameter 2"
default=(0,0)
endparam
param p_power
visible=false
endparam

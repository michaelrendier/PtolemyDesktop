z1=@p5*z1^2*(z2-@p1*c)/(1-@p1*c*z3)
else
z1=@p5*z1^2*(z2-@p1*c)/(1-@p1*c*z3)
z2=@p6*z2^2*(a-@p2)/(1-@p2*z3)+@p3*c
z3=@p7*z3^2*(a-@p4*c)/(1-@p4*c*b)+@p4*c
endif
pz=z1+z2+z3
return pz

if cabs(pz-c1)<1
pz=conj(1/(pz-c1))+c1
elseif cabs(pz-c2)<1
pz=conj(1/(pz-c2))+c2
elseif cabs(pz-c3)<1
pz=conj(1/(pz-c3))+c3
elseif cabs(pz-c4)<1
pz=conj(1/(pz-c4))+c4
elseif cabs(pz-c5)<1
pz=conj(1/(pz-c5))+c5
elseif cabs(pz-c6)<1
pz=conj(1/(pz-c6))+c6
endif
pz=@fn2(pz)
pz=(pz^2+@p1)/(pz^2-1)
i=1
else
pz=(pz^2+@p1)/(pz^2-1)
i=0
endif
endif
return pz
endfunc

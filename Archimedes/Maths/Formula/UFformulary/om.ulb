class OM_Semaberence(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
if @jm==0
pz=@pf(pz)
c=@js
else
pz=@sp
c=@pf(fpixel)
endif
a=(0,0)
b=(0,0)
i=0
return pz
endfunc
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if i==0
b=(pz^@pow1+c)*(@xp1-pz^2)/(@xp1+pz^2)+@xp3*a
a=pz
pz=b
i=i+1
else
b=(pz^@pow2+c)*(@xp2-pz^2)/(@xp2+pz^2)+@xp4*a
a=pz
pz=b
i=0
endif
return pz
endfunc
private:
complex c
complex a
complex b
int i
default:
title="Semaberence"

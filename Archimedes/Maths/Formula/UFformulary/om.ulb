elseif @v==7
pz=pz^2+exp(log(-pz)^2+@xp1*log(-pz+1)+log(c))
elseif @v==8
pz=pz^2+exp(log(pz)^2+@xp1*log(-pz+1)+log(c))
elseif @v==9
pz=pz^2+exp(log(pz)^2+@xp1*log(pz^2+c)+log(c))^2+c
elseif @v==10
pz=pz^2+exp(log(pz)^2+@xp1*log(pz)+log(c))+c*exp(log(pz)^2+@xp1*log(pz)+log(c))
elseif @v==11
if @jm==0
pz=pz^2+exp(log(pz)^2+@xp1*log(pz)+log(c))+log(exp(pz)^2+@xp1*exp(pz)+exp(c))
else

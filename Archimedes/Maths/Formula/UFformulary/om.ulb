class OM_Phovanaga(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
a=(0,0)
b=(0,0)
if @mj==1
pz=@pf(pz)
c=@js
else
pz=@sp
c=@pf(fpixel)
endif
return pz
endfunc
complex func Iterate(complex pz)
if @v==6 || @v==11
pz=(@zp1-0.05)*pz+@zp2
elseif @v==10
pz=(@zp1-0.1)*pz+@zp2
else
pz=@zp1*pz+@zp2
endif
if @v==0
if @mj==0
b=pz^3+c/((@dmp1*c-a)*pz)-@dmp2*c-@php*a
else
b=pz^3+c/((-@dmp1*c-a)*pz)-@dmp2*c-@php*a
endif
elseif @v==1
b=pz^3+c/((-@dmp1*c+a)*pz)-@dmp2*c+@php*a
elseif @v==2
if @mj==0
b=pz^3+c/((@dmp1*c-a)*pz)-@dmp2*c*a-@php*a
else
b=pz^3+(c+0.7)/((@dmp1*(c+0.7)-a)*pz)-@dmp2*(c+0.7)*a-@php*a
endif
elseif @v==3
if @mj==0
b=pz^3+c/((-@dmp1*c+a)*pz)-@dmp2*c*a+@php*a
else
b=pz^3-c/((@dmp1*c+a)*pz)+@dmp2*c*a+@php*a
endif
elseif @v==4
if @mj==0
b=pz^3+a*c/((@dmp1*c-a)*pz)-@dmp2*c+@php*a
else
b=pz^3-a*c/((-@dmp1*c-a)*pz)+@dmp2*c+@php*a
endif
elseif @v==5
if @mj==0
b=pz^3+a*c/((-@dmp1*c+a)*pz)+@dmp2*c+@php*a
else
b=pz^3+a*(c-0.2)/((-@dmp1*(c-0.2)+a)*pz)+@dmp2*(c-0.2)+@php*a
endif
elseif @v==6
b=pz^3+(c+a)/((-@dmp1*c-a)*pz)-(@dmp2-2.5)*c+(@php-1.95)*a
elseif @v==7
b=pz^3+(c+a)/(((@dmp1+0.5)*c+a)*pz)-@dmp2*c+(@php-1.5)*a
elseif @v==8
b=pz^3+(c-a)/(((@dmp1+0.5)*c-a)*pz)-@dmp2*c+@php*a
elseif @v==9
b=pz^3+(c-a)/((-@dmp1*c+a)*pz)-@dmp2*c+(@php-1.85)*a
elseif @v==10
b=a*pz^3+c/((-@dmp1*c-a)*pz)-@dmp2*c+@php*a
elseif @v==11
if @mj==0
b=a*pz^3+c/((-@dmp1*c+a)*pz)-@dmp2*c+(@php-2.35)*a
else
b=a*pz^3+(c+1.55)/((-@dmp1*(c+1.55)+a)*pz)-@dmp2*(c+1.55)+(@php-2.35)*a
endif
elseif @v==12
if @mj==0
b=(pz+a)^3+c/((-@dmp1*c-a)*pz)-@dmp2*c+@php*a
else
b=(pz+a)^3+(c+0.35)/((-@dmp1*(c+0.35)-a)*pz)-@dmp2*(c+0.35)+@php*a
endif
elseif @v==13
if @mj==0
b=(pz+a)^3+c/(((@dmp1+4)*c+a)*pz)-@dmp2*c+@php*a
else
b=(pz+a)^3+(c+0.775)/(((@dmp1+4)*(c+0.775)+a)*pz)-@dmp2*(c+0.775)+@php*a
endif
elseif @v==14
if @mj==0
pz=pz+c
b=pz^3+(c+a)/(((@dmp1+0.5)*c+a)*pz)-@dmp2*c+(@php-1.5)*a
else
pz=pz+(c+0.25)
b=pz^3+((c+0.25)+a)/(((@dmp1+0.5)*(c+0.25)+a)*pz)-@dmp2*(c+0.25)+(@php-1.5)*a
endif
elseif @v==15
pz=pz+c
b=pz^3+(c-a)/(((@dmp1+0.5)*c-a)*pz)-@dmp2*c+@php*a
elseif @v==16
pz=pz+c
b=pz^3+(c-a)/((-@dmp1*c+a)*pz)-@dmp2*c+(@php-1.85)*a
elseif @v==17
pz=pz-c
b=pz^3+(c+a)/((-@dmp1*c-a)*pz)-(@dmp2-2.5)*c+(@php-1.95)*a
endif
a=pz
pz=b
return pz
endfunc

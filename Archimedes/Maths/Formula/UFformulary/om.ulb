elseif @V=="41"
pz=@p3*(pz*tan(pz)/conj(pz))
elseif @V=="42"
pz=@p3*(pz*tan(pz)/cabs(pz))
elseif @V=="43"
pz=@p3*(pz*tan(pz)/tanh(pz))
elseif @V=="44"
pz=@p3*(pz*flip(pz)/atan(pz))
elseif @V=="45"
pz=@p3*(pz*flip(pz)/tanh(pz))
elseif @V=="46"
pz=@p3*(pz*flip(pz)/tan(pz))
elseif @V=="47"

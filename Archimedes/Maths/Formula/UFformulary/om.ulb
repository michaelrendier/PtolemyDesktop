class OM_TetrationCapruq(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
if @jm==1
pz=@sp
c=@pf(fpixel)
else
pz=@pf(pz)
c=@js
endif
return pz
endfunc
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if @v==0
pz=(pz^2+sqr(pz^pz+@xp1*c*pz)+pz^pz+@xp2*c*sqr(pz))/@xp3
elseif @v==1
pz=(pz^2+sqr(pz^pz+@xp1*c*pz)+pz^(pz-1)+@xp2*c*sqr(pz))/@xp3
elseif @v==2
pz=(pz^2+sqr(pz^pz+@xp1*c*pz)+pz^(pz-2)+@xp2*c*sqr(pz))/@xp3
elseif @v==3
pz=(pz^2+sqr(pz^pz+@xp1*c*pz)+pz^(pz-3)+@xp2*c*sqr(pz))/@xp3
else
pz=(pz^2+sqr(pz^pz+@xp1*c*pz)+pz^(pz-4)+@xp2*c*sqr(pz))/@xp3
endif
return pz
endfunc

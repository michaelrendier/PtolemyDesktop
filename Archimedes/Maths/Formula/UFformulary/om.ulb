endif
pz=pz*@fn9(atan(@p8))+@p11
if @p5<=a
pz=atanh(sqrt(1i)*pz+@p17)*fn2(conj(@p1))+@p3
endif
elseif @V=="9"
if a<@p4
pz=flip(sqrt(1i)*pz+1.75+@p17)*fn2(flip(@p1))+@p2
endif
pz=pz*@fn9(atan(@p8))+@p11
if @p5<=a
pz=(sqrt(1i)*pz+@p17)*fn2(conj(@p1))+@p3
endif
elseif @V=="10"
if a<@p4
pz=conj(sqrt(1i)*pz+2.85+@p17)*fn2(flip(@p1))+@p2
endif
pz=pz*@fn9(atan(@p8))+@p11
if @p5<=a

class OM_TetravarX2(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
a=(0,0)
b=(0,0)
d=(0,0)
if @jm==0
pz=@sf(pz)
pq=pz
pk=pz
pw=pz
else
pk=@sp
pq=@sp
pz=@sp
pw=@sp
endif
return pz
return pq
return pk
return pw
endfunc
private:
complex pk
complex pw
complex pq
complex a
complex b
complex d
complex fpixel
complex func Iterate(complex pz)
pw=@wp1*pw+@wp2
pk=@kp1*pk+@kp2
pz=@zp1*pz+@zp2
pq=@qp1*pq+@qp2
if @jm==0
if @v==0
pw=-0.15*(pk-pw)+pk*pz*pq
pk=0.855*(pw+pk)-pw*pz*pq
pz=-pz+pw*pk*pq
pq=-1.05*pq+pw*pk*pz+@c
else
a=pw
b=pk
d=pz
pw=-0.15*(pk-pw)+pk*pz*pq
pk=0.855*(a+pk)-a*pz*pq
pz=-pz+a*b*pq
pq=-1.05*pq+a*b*d+@c
endif
else
if @v==0
pw=-0.15*(pk-pw)+pk*pz*pq
pk=0.855*(pw+pk)-pw*pz*pq
pz=-pz+pw*pk*pq
pq=-1.05*pq+pw*pk*pz+@pf(fpixel)
else
a=pw
b=pk
d=pz
pw=-0.15*(pk-pw)+pk*pz*pq
pk=0.855*(a+pk)-a*pz*pq
pz=-pz+a*b*pq
pq=-1.05*pq+a*b*d+@pf(fpixel)
endif
endif
return pz
return pw
return pk
return pq
endfunc

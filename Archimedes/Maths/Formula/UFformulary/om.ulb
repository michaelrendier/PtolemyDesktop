elseif @v2=="Lissajous Quadratic"
pz=@p1b^4*y^4-4*@p1b^3*@p2b*x*y^3+2*@p1b^2*@p2b*y^3 \
+6*@p1b^2*@p2b^2*x^2*y^2-4*@p1b*@p2b^2*x*y^2-2*@p1b^3*x*y^2 \
-2*@p1b^2*@p2b^2*y^2+@p2b^2*y^2+@p1b^2*y^2 \
-4*@p1b*@p2b^3*x^3*y+2*@p2b^3*x^2*y+4*@p1b^2*@p2b*x^2*y+4*@p1b*@p2b^3*x*y \
-2*@p2b^3*y-4*@p1b^2*@p2b*y+@p2b^4*x^4-2*@p1b*@p2b^2*x^3-2*@p2b^4*x^2 \
+@p2b^2*x^2+@p1b^2*x^2+2*@p1b*@p2b^2*x-@p1b^2-@p2b^2+@p2b^4
elseif @v2=="Mascheroni’s Curve"
pz=(x^2+y^2)*x^2-((@p1b+1.85-0.55i)*x+(@p2b-2.35+0.45i)*y)^2
elseif @v2=="Neile's Semi-Cubical Parabola"
pz=y^3-(@p1b+2-0.55i)*x^2
elseif @v2=="Nephroid"
pz=(x^2+y^2-4*(@p1b-1+0.5i)^2)^3-108*(@p1b-1+0.5i)^4*y^2
elseif @v2=="Nephroid of Freeth"
pz=(x^2+y^2)*(x*2+y^2-(@p1b+1)^2)^2-4*(@p1b+1)^2*(x^2+y^2-(@p1b+1)*x)^2
elseif @v2=="Newton's Diverging Parabolas"
pz=(@p1b-0.5+0.25i)*y^2-x*(x^2-2*(@p2b+0.25-1.5i)*x+(@p3b+1.4))
elseif @v2=="Oblique Astroid"
pz=((x^2+y^2+2*x*y*cos(@p1b)-@p2b^2)^3+27*@p2b^2*x^2*y^2*sin(@p1b)^2)*sin(@p1b)^2\
-@p2b^2*cos(@p1b)*((x^2+y^2+2*x*y*cos(@p1b)-@p2b^2)^2*cos(@p1b)-\
2*x*y*(9*(x^2+y^2+2*x*y*cos(@p1b)-@p2b^2)*sin(@p1b)^2-8*@p2b^2*cos(@p1b)^2))
elseif @v2=="Oblique Bifolium"
pz=(x^2+y^2)^2-x^2*((@p1b+7)*x+(@p2b+11.5)*y)
elseif @v2=="Oblique Cappa"
pz=(x^2+y^2)*y^2-(@p1b-6.5)^2*(x*sin(@p2b)+y*cos(@p2b))^2
elseif @v2=="Oblique Cissoid"
pz=(x^2+y^2)*(x*cos(@p2b+0.5+0.2i)+y*sin(@p2b+0.5+0.2i))-2*@p1b*y^2
elseif @v2=="Oblique Conchoid"
pz=(x*y*cos(@p1b-1.65-0.4i)-(y^2+@p2b*y-@p3b^2)*sin(@p1b-1.65-0.4i))^2-(x*sin(@p1b-1.65-0.4i)\
+y*cos(@p1b-1.65-0.4i)+@p2b*cos(@p1b-1.65-0.4i))^2*(@p3b^2-y^2)
elseif @v2=="Oblique Pancappa"
pz=(y-@p1b)^2*(x^2+y^2)-((@p2b-5.5-0.5i)*x+(@p3b-2.35)*y)^2
elseif @v2=="Oblique Parabolic Bifolium"
pz=x^3-@p1b*(x^2-y^2)-(@p2b+1.45)*x*y
elseif @v2=="Oblique Strophoid"
pz=y*(x^2+y^2)-(@p1b+1)*(x^2-y^2)-2*(@p2b-0.5+0.5i)*x*y
elseif @v2=="Oblique Trifolium"
pz=(x^2+y^2)^2/(2*@p1b)-x*(x^2+y^2)-(x^2-3*y^2)*(x*cos(2*(@p2b-1.7-0.1i))+y*sin(@p2b-1.7-0.1i))
elseif @v2=="Oblique Versiera"
pz=(x^2+y^2)*(x*cos(@p1b)+y*sin(@p1b)-4*cos(@p1b)^2)+2*@p2b*y^2
elseif @v2=="Ophiuride"
pz=x*(x^2+y^2)-(@p2b+3)*x*y-(@p1b-1.55-0.1i)*y^2
elseif @v2=="Orthoconchoid"
pz=(y^2+(@p1b+1i)*y-(@p2b-1.8+0.9i)^2)^2-x^2*((@p2b-1.8+0.9i)^2-y^2)
elseif @v2=="Oval of Munger"
pz=(x^2+y^2)^(2*(@p1b-0.85)+1)-2*@p2b*x^(2*(@p1b-0.85)+1)*(x^2+y^2)^(@p1b-0.85)+(@p2b^2-@p3b^2)*x^(4*(@p1b-0.85))*@p4b\
-2*@p2b*@p4b*cos(@p5b)^(2*(@p1b-0.85)+1)+(@p2b^2-@p3b^2)*cos(@p5b)^(4*(@p1b-0.85))
elseif @v2=="Panestrofoide"
pz=x*(x^2+y^2)+(@p1b-0.6+0.43i)*(x^2-y^2)+(@p2b+0.2-1.85i)*(x+(@p1b-0.6+0.43i))
elseif @v2=="Parabola"
pz=y-@p1b*x^2-(@p2b-3)*x-@p3b
elseif @v2=="Parabolic Trifolium"
pz=x^2*(x^2+y^2)-(@p1b-8)*y*(x^2-y^2)
elseif @v2=="Pear-Shaped Quartic"
pz=@p2b^2*y^2-x^3*((@p1b+1)-x)
elseif @v2=="Pearl of the Fourth Order"
pz=(@p1b+1)*y^3-y^4-(@p1b+1)^2*x^2
elseif @v2=="Pearls of Sluze"
pz=y^@p1b-@p2b*x^(@p3b+1)*((@p4b+1+0.5i)-x)^@p5b
elseif @v2=="Polyod of Circle"
pz=(x^2+y^2)*((x^2+y^2)/(2*(@p1b+0.65+1.55i))-x)^2+4*(@p2b+0.1+0.2i)^4\
-4*(@p2b+0.1+0.2i)^2*(x^2+y^2)+2*(@p2b+0.1+0.2i)*x*(x^2+y^2)/(@p1b+0.65+1.55i)
elseif @v2=="Polyod of Straight Line Parallel to Polar Axis"
pz=y^2*(x^2+y^2-(@p1b-0.75+0.5i)^2)-(x^2+y^2-(@p1b-0.75+0.5i)*x-2*(@p2b-2.25)^2)^2
elseif @v2=="Pursuit Curve"
pz=y-(@p1b-1.5)*x^2+log(x)^2
elseif @v2=="Quadratix of Hippias"
pz=x-y*cotan(y/(@p1b+1.6-0.4i))
elseif @v2=="Quadrifolium"
pz=(x^2+y^2)^3-4*@p1b^2*x^2*y^2
elseif @v2=="Quartic of Bernoulli"
pz=x^2*y^2-((((@p1b+2)+(@p2b+0.25))/2)^2-y^2)*(y^2-(((@p1b+2)-(@p2b+0.25))/2)^2)
elseif @v2=="Right Strophoid"
pz=y^2-x^2*(@p1b-x)/(@p1b+x)
elseif @v2=="Salmon Quartic"
pz=(x^2-(@p1b+0.35)^2)^2+(y^2-@p2b^2)^2-@p3b^4
elseif @v2=="Sand Clock"
pz=(@p1b+1)^2*(y^2-(@p2b+0.25i)^2)^2-4*(@p2b+0.25i)^2*x^2*(y^2+(@p2b+0.25i)^2)
elseif @v2=="Scarab"
pz=(x^2+y^2)*(x^2+y^2+(@p1b-3+0.2i)*x)^2-@p2b^2*(x^2-y^2)^2
elseif @v2=="Serpentine Curve"
pz=x^2*y+@p1b^2*y-@p1b*(@p2b-4.9)*x
elseif @v2=="Spiric Curve"
pz=(x^2+y^2)^2+(@p1b-5.5+0.5i)*x^2+@p2b*y^2+2*(@p3b-2.75-0.5i)*x+@p4b
elseif @v2=="Spiric of Perseus"
pz=(x^2+y^2)^2-2*(@p1b+0.5)*x^2-2*(@p2b+1)*y^2+(@p3b-1.5)
elseif @v2=="Spiric Section"
pz=(x^2+y^2-(@p1b-0.25)^2+(@p3b-0.05)^2+(@p2b-1+0.5i)^2)^2-4*(@p3b-0.05)^2*(x^2+(@p2b-1+0.5i)^2)
elseif @v2=="Superellipse"
pz=cabs(x/(@p1b-0.35))^(@p3b+3.7+3i)+cabs(y/(@p2b+1.15))^(@p3b+3.7+3i)-1
elseif @v2=="Syntractrix"
pz=x+sqrt(@p2b^2-y^2)-@p1b*log((@p2b+sqrt(@p2b^2-y^2))/y)
elseif @v2=="Toric Section"
pz=(x^2+y^2)^2+@p1b*x^2+(@p2b-1.5)*y^2+@p3b*x+(@p4b+2.5-0.5i)*y+@p5b
elseif @v2=="Torpedo Curve"
pz=(x^2+y^2)^2-(@p1b+6)*x*(x^2-y^2)
elseif @v2=="Tractrix"
pz=x-log(((@p1b-1+0.5i)-sqrt((@p1b-1+0.5i)^2-y^2))/y)-sqrt((@p1b-1+0.5i)^2-y^2)
elseif @v2=="Trident Curve"
pz=@p1b*x^3+(@p2b+0.5i)*x^2+(@p3b-7.55)*x-(@p4b-4)+x*y
elseif @v2=="Trifolium"
pz=(x^2+y^2)*(y^2+x*(x+(@p1b-2.4)))-4*(@p1b-2.4)*x*y^2
elseif @v2=="Trisectrix of Maclaurin"
pz=y^2*((@p1b-0.5)+x)-x^2*(3*(@p1b-0.5)-x)
elseif @v2=="Tschirnhaus’s Cubic"
pz=3*(@p1b-3.75)*y^2-x*(x-(@p1b-3.75))^2
elseif @v2=="Virtual Parabola"
pz=y-((@p1b-2.3+0.7i)*x+@p2b)^(1/2)-((@p3b+0.4-1i)*x+@p4b)^(1/2)
elseif @v2=="Visiera"
pz=x*(x^2+y^2)-@p1b*(x^2+2*y^2)
elseif @v2=="Viviani's Curve"
pz=y^2-x^2*((@p1b+1)^2-x^2)
elseif @v2=="Wassenaar Curve"
pz=1-@p1b*x^2-(y-x)^2
elseif @v2=="Watt's Curve"
pz=(x^2+y^2)*(x^2+y^2-(@p3b-0.9+0.1i)^2)^2+4*@p1b^2*y^2*(x^2+y^2-(@p2b+4)^2)
elseif @v2=="Weibull Curve"
pz=y-exp(-(x/(@p1b+2+2i))^(@p2b-0.8-0.1i))
elseif @v2=="Witch of Agnesi"
pz=y*(x^2+4*(@p1b-0.35)^2)-8*(@p1b-0.35)^3
elseif @v2=="Borrelli"
pz=x-y-@p1b*x*(x^2+y^2)+(@p2b-0.5-0.2i)+flip(x+y-@p3b*y*(x^2+y^2)+(@p4b-1.25+1.2i))
elseif @v2=="Buckling Column Model"
pz=y+flip(-((@p1b-1.1)*x^3+@p2b*x+@p3b*y)/(@p4b-1+0.7i))
elseif @v2=="Business Cycle"
pz=x+y+flip(@p1b*y-(@p1b+1)*y^3-@p2b*x)
elseif @v2=="Cathala"
pz=(1-2*@p1b)*x+y+flip(2*@p1b*(@p2b+1.5)*x+(@p3b-2-0.75i)*y-2*@p1b*x^3)
elseif @v2=="Chip"
pz=y-(x/cabs(x))*cos(sqr(log(abs((@p2b-1+1i)*x-(@p3b-1+1i)))))*atan(sqr(log(abs((@p3b-1+1i)*x-(@p2b-1+1i)))))+flip((@p1b+1)-x)
elseif @v2=="Clifford"
pz=sin((@p1b-2.6-0.55i)*y)+@p3b*cos((@p1b-2.6-0.55i)*x)+flip(sin(@p2b*x)+@p4b*cos(@p2b*y))
elseif @v2=="Coupled Logistic"
pz=(1-(@p1b-1i))*@p2b*x*(1-x)+(@p1b-1i)*@p2b*y*(1-y)+flip((1-(@p1b-1i))*@p2b*y*(1-y)+(@p1b-1i)*@p2b*x*(1-x))
elseif @v2=="Cremona"
pz=x*cos(@p1b-17-0.5i)-(y-x^2)*sin(@p1b-17-0.5i)+flip(x*sin(@p1b-17-0.5i)-(y-x^2)*cos(@p1b-17-0.5i))
elseif @v2=="de Jong"
pz=sin(@p1b*y)-cos((@p2b-1.93-1.05i)*x)+flip(sin(@p3b*x)-cos((@p4b-0.83+1.3i)*y))

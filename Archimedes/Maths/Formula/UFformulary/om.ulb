complex func Iterate(complex pz)
pz=@p6*pz+@p7
x=cos(@p26)*real(pz)-sin(@p26)*imag(pz)
y=sin(@p26)*real(pz)+cos(@p26)*imag(pz)
pz=x+flip(y)
float a=1/real(fn3(round(trunc(pz))))
if a<@p4
pz=pz*recip(@p1)+@p2
endif
if @p5<=a
pz=pz*ceil(@p25)+@p3
endif
if a<@p8
pz=pz*tan(@p25)+@p9
endif
if @p10<=a
pz=pz*recip(@p1)+@p11
endif
return pz
endfunc

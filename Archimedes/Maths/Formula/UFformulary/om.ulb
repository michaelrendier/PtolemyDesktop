z3=-z1
else
z2=-z1
z3=-cos(z1)
endif
return pz
return z1
return z2
return z3
endfunc
private:
complex z1
complex z2
complex z3
complex func Iterate(complex pz)
ConvergentFormula.Iterate(pz)
;m_ZOld=pz
z3=@p7*fn4(z3)+@p8
z1=z1+@p5*sqr(z1)
z2=z2+@p5*sqr(z2)
z1=z1+@p6/z1
z2=z2+@p6/z2
if @v==0
a=(z1*z2*z3-1)/z2
b=a^3
d=z2^2
elseif @v==1
a=(z1*z2*z3-z1)/z2
b=a^3
d=z2^2+1
elseif @v==2
a=(z1*z2*z3-z3)/z2
b=a^3
d=z2^2
elseif @v==3
a=(z1*z3-z1)/z2
b=a^3
d=z2^2+1
elseif @v==4

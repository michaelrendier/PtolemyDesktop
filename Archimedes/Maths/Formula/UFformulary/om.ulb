}

class OM_ModifiedAleatorFloorPhoenixM(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
i=0
seed=@seed
while i<100
seed=random(seed)
values[i]=seed/#randomrange
i=i+1
endwhile
pz=fn1(pz)
z2=(0,0)
z1=fn2(pz)
c=fn1(fpixel)
i2=0
return pz
return z1
return z2
endfunc
private:
float values[#maxiter]
int i
int seed
complex z1
complex z2
complex c
int i2
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if @v==0
pz=pz^2+@pp1*pz+@pp2*z2+@ap*fn3(floor(values[i2]))+@c*c+@mp1*@c*c/pz^2
elseif @v==1
pz=pz^2+@pp1*pz+@pp2*z2+@ap*fn3(floor(values[i2]))+@c*c*pz+@mp1*@c*c/pz^2
else
pz=pz^2+@pp1*pz+@pp2*z2+@ap*fn3(floor(values[i2]))+@c*c*pz^2+@mp1*@c*c/pz^2
endif
z2=z1
i2=i2+1
return pz
return z1
return z2
endfunc

"Tschirnhaus' Cubic""Visiera""Viviani's""Watt's""Weibull""Witch of Agnesi"
visible=@version==100
endparam
param v2
caption="Curve"
enum="Alain Curve""Antiversiera""Apollonian Cubic""Astroid""Bean Curve 1""Bean Curve 2""Beetle""Besace""Biaxial Eight Reverse"\

class OM_LabsTemorof(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fPixel=pz
pz=fn1(pz)
if @S=="1"
pz=pz+(@sp-1)*(pz-1)/(pz+1)
elseif @S=="2"
pz=pz^2*(pz-@sp)/(1-@sp*pz)
elseif @S=="3"
pz=pz^2*(pz-@sp)/(1i-@sp*pz)
elseif @S=="4"
pz=pz+pz^2*(pz-@sp)/(1-@sp*pz)
elseif @S=="5"
pz=pz+pz^2*(pz-@sp)/(1i-@sp*pz)
elseif @S=="6"
pz=pz+(@sp+1)*(pz-1i)/(pz+1i)
elseif @S=="7"
pz=pz+(@sp+1)*recip(pz)
elseif @S=="8"
pz=pz+(@sp+1)*((pz^2-1)/(2*pz-2))^2
elseif @S=="9"
pz=pz+(@sp+1)*((pz^2-1i)/(2*pz-2i))^2
elseif @S=="10"
pz=pz+(pz-(@sp-1)*1i)/(pz+(@sp-1)*1i)
elseif @S=="11"
pz=pz+(pz-(@sp+1))/(pz+(@sp+1))
elseif @S=="12"
pz=pz+(@sp+1)*(pz-1i)/(pz+1i)/(pz-1i)
elseif @S=="13"
pz=pz+(@sp-1)*(pz-1)/(pz+1)/(pz-1)
endif
i=0
return pz
endfunc
complex func Iterate(complex pz)
while i<@iter
i=i+1
pz=@p4*fn2((pz))+@p5
pz=(pz-@p6)/(1-@p6*pz)
pz=pz/(@p7*pz+1)
pz=pz+@p8*sqr(pz)
pz=pz+@p9/pz
if @Va=="None"
pz=pz
elseif @Va=="1"
if |pz|<1
pz=pz/|pz|
endif
elseif @Va=="2"
if |pz|>1
pz=pz/|pz|
endif
elseif @Va=="3"
x=real(pz)
y=imag(pz)
x=x/|pz|
y=y/|pz|
pz=x+flip(y)
elseif @Va=="4"
if real(pz)<imag(pz)
pz=flip(pz)
endif
elseif @Va=="5"
if real(pz)>imag(pz)
pz=flip(pz)
endif
endif
pz=@p1*(pz-real(pz)/cabs(real(pz)))^2
pz=@p2*fn3(log(abs(pz)))+@p3*fn4(fpixel)

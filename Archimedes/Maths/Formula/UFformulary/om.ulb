title="Ahtanu"
int param version
caption="Version"
default=100
visible=@version<100
endparam
param v
caption="Variant"
enum="1""2""3""4"
endparam
param sp
caption="Start Parameter"
default=(0,0)
endparam
param p1
caption="Ahtanu Parameter 1"
default=(1,0)
endparam
param p3
caption="Ahtanu Parameter 2"
default=0.0
endparam
param p2
caption="Z Parameter"
default=1.9
endparam

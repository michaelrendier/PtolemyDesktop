elseif @v==1
z1=@p1*z1^2*(z3-@p2)/(1-(2*@p2-3)*z2/(@p2-2))+@p3
z2=@p1*z2^2*(z1-@p2)/(1-(2*@p2-3)*z3/(@p2-2))+@p3
z3=@p1*z3^2*(z2-@p2)/(1-(2*@p2-3)*z1/(@p2-2))+@p3
elseif @v==2
z1=@p1*z1^2*(z1-@p2)/(1-(2*@p2-3)*z3/(@p2-2))+@p3
z2=@p1*z2^2*(z2-@p2)/(1-(2*@p2-3)*z1/(@p2-2))+@p3
z3=@p1*z3^2*(z3-@p2)/(1-(2*@p2-3)*z2/(@p2-2))+@p3
elseif @v==3
z1=@p1*z1^2*(z3-@p2)/(1-(2*@p2-3)*z3/(@p2-2))+@p3
z2=@p1*z2^2*(z1-@p2)/(1-(2*@p2-3)*z1/(@p2-2))+@p3
z3=@p1*z3^2*(z2-@p2)/(1-(2*@p2-3)*z2/(@p2-2))+@p3
elseif @v==4
z1=(@p1-0.5)*z1^2*(z2-@p2)/(1-(2*@p2-3)*z1/(@p2-2))+@p3
z2=(@p1-0.5)*z2^2*(z3-@p2)/(1-(2*@p2-3)*z2/(@p2-2))+@p3
z3=(@p1-0.5)*z3^2*(z1-@p2)/(1-(2*@p2-3)*z3/(@p2-2))+@p3
elseif @v==5
z1=(@p1-1)*z1^2*(z3-@p2)/(1-(2*@p2-3)*z1/(@p2-2))+@p3
z2=(@p1-1)*z2^2*(z1-@p2)/(1-(2*@p2-3)*z2/(@p2-2))+@p3
z3=(@p1-1)*z3^2*(z2-@p2)/(1-(2*@p2-3)*z3/(@p2-2))+@p3
elseif @v==6

pz=pz+0.3*cosh(pz)/sin(pz)
elseif @Va=="16"
pz=pz+0.5*sqr(pz)/cos(pz)
elseif @Va=="17"
pz=abs(pz-2/(tan(cotanh(pz))))
elseif @Va=="18"
pz=pz-0.5*cotanh(tanh(pz))
elseif @Va=="19"
pz=pz+0.55*exp(pz)/cotan(pz)
elseif @Va=="20"

y=y+@p9*real(sin(a+sin(@p7*(a+sin(@p8*a)))))/10
i2=0
endif
elseif @v101=="44"
if i2==0
x=x-(@p4+0.15)*real(sin(y+sqr((@p2-3.2)*(y+sin(@p3*y)))))/10
y=y+(@p4+0.15)*real(sin(a+abs((@p2-3.2)*(a+sin(@p3*a)))))/10
i2=i2+1
else
x=x-@p9*real(sqrt(y+sin(@p7*(y+sin((@p8-0.8)*y)))))/10
y=y+@p9*real(sin(a+sin(@p7*(a+sin((@p8-0.8)*a)))))/10
i2=0
endif
elseif @v101=="45"

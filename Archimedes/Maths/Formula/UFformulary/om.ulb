elseif @alp==6
pz=@zp1*pz+@zp2
u=(1-@p1)*pz+@p1*((pz^2+(@p3+0.6)*c/pz))
pz=(1-@p2)*pz+@p2*((u^2+@p4*c/u))+@ap*@af(values[i2])
elseif @alp==7
pz=@zp1*pz+@zp2-@ap*@af(values[i2])
u=(1-@p1)*pz+@p1*((pz^2+@p3*c/pz))+@ap*@af(values[i2])

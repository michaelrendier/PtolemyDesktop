b=fn1(pz)
pz=fn1(pz)
else
a=@sp
b=@sp
pz=@sp
endif
return pz
return a
return b
endfunc
private:
complex a0
complex a
complex b
complex fpixel
complex func Iterate(complex pz)
a=@p3*fn2(a)/2+@p4*fn3(fpixel)
b=@p3*fn2(b)/2+@p5*fn3(fpixel)
a0=a
if @V=="1"
a=-a^2+b^3+@p1
b=1/(-a0*b*(a+b)+@p2)
elseif @v=="2"
a=-a^2+b^3+@p1*fn3(fpixel)
b=1/(-a0*b*(a0+b)+@p2)
elseif @v=="3"
a=-a^2+b^3+@p1*fn3(fpixel)
b=1/(-a0*b*(a+b)+@p2)
else
a=-a^2+b^3+@p1
b=1/(-a0*b*(a0+b)+@p2)
endif
pz=a+b
return pz
return a
return b
endfunc

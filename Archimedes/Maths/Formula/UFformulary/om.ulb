if @v==1 || @v==2 || @v==4 || @v==5
pz=flip(pz)
elseif @v==3
pz=abs(pz)
endif
i=1
else
f=@mp1*pz^2*(pz-@mp2)/(1-@mp2*pz)
pz=1/(@mp3+1/(@mp4+f))
if @v==4
pz=conj(pz)
elseif @v==5

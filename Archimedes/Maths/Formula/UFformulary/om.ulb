default=(0,0)
endparam
param php1
caption="Phoenix Parameter 1"
default=(0.6,0)
endparam
param php2
caption="Phoenix Parameter 2"
default=(-0.5,0)
endparam
param zp1
caption="Z Parameter 1"
default=(0.5,0)
endparam
param zp2
caption="Z Parameter 2"
default=(0,0)
endparam
param z2p1
caption="Z2 Parameter 1"
default=(0.5,0)
endparam
param z2p2
caption="Z2 Parameter 2"
default=(0,0)
endparam

fpixel=pz
if @mj==0
pz=@sp
z2=@sp
c=@sf(fpixel)
else
z2=@sf(pz)
pz=@sf(pz)
c=@js
endif
return pz
return z2
endfunc
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
z2=@z2p1*z2+@z2p2
pz=pz+@ar/pz
z2=z2+@ar/z2
pz=pz+@ac*(pz-1i)/(pz+1i)
z2=z2+@ac*(z2-1i)/(z2+1i)
a=z2
if @mj==0
z2=@bp1*c*@bf(z2/pz)+@bp2*pz

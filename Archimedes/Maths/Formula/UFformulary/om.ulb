pz=@zp1*pz+@zp2
pz=exp(@p1*1i)*((pz-1/@p2)/(1-pz/@p2))^3*(pz-@p2^2*exp(-@p1*1i))/(1-@p2^2*exp(@p1*1i)*pz)
return pz
endfunc

elseif @v==10
z1=@p1*z1^2*(z2-@p2)/(1-(2*@p2-3)*z1/(@p2-2))+(@p3+2)*c
z2=@p1*z2^2*(z3-@p2)/(1-(2*@p2-3)*z2/(@p2-2))+(@p3+2)*c

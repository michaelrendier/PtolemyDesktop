class OM_AltBivarX2(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
if @mj=="M"
fPixel=pz
if @sv=="1"
If @v==1
pz=@sp1+0.55
else
pz=@sp1
endif
pk=@sp2
elseif @sv=="2"
pk=@pf(pz)
if @v==1
pz=@sp1+1
else
pz=@sp1+0.5
endif
elseif @sv=="3"
pz=@pf(pz)
pk=@sp1
elseif @sv=="4"
pk=@pf(pz)
pz=@pf(pz)
endif
c=@pf2(exp(@pf(fpixel)))
else
if @svj=="1"
pk=@pf(pz)
pz=@pf(pz)
elseif @svj=="2"
pk=@pf(pz)
pz=@sp1+0.5
else
pk=@sp1+0.5
pz=@pf(pz)
endif
c=@js
endif
i=0
return pz
return pk
endfunc
private:
complex c
complex pk
int i
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
pk=@kp1*pk+@kp2
a=pk
pk=@bp1*@bf(pk/pz)+@bp2
if @v=="1"
if i==0
pz=pz^2+a^2+@p1*c
i=1
else
pz=c*(pz^2+a^2)
i=0
endif
else
if i==0
pz=c*(pz^2+a^2)
i=1
else
pz=pz^2+a^2+@p1*c
i=0
endif
endif
return pz
return pk
endfunc
bool func IsBailedOut(complex pz)
bool bail=false
bail=(|(pz+pk)/2|>@p_bailout)
return bail
endfunc

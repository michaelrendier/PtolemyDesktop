elseif |pz-c6|<r^2
pz=r*conj(r/(pz-c6))+c6
elseif |pz-c7|<r^2
pz=r*conj(r/(pz-c7))+c7
endif
if @v==1 || @v==2 || @v==4 || @v==5
pz=flip(pz)
elseif @v==3
pz=abs(pz)
endif
i=0
endif
else
if i==0

class OM_SiegelMunster(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
return @sf(pz)
endfunc
complex func Iterate(complex pz)
pz=exp(@p1*1i)*pz+pz^2
return exp(@p2*1i)*pz^2*(pz-@p3)/(1-@p3*pz)
endfunc

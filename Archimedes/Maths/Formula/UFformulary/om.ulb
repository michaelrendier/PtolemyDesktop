class OM_TetravarX20(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
a=(0,0)
b=(0,0)
d=(0,0)
if @mj==0
pk=@sp
pq=@sp
pz=@sp
pw=@sp
c=@pf(fpixel)
else
pz=@pf(pz)
pk=pz
pq=pz
pw=pz
if @v==0
c=@js
else
c=@js+0.3
endif
endif
return pz
return pq
return pk
return pw
endfunc
private:
complex pk
complex pw
complex pq
complex a
complex b
complex c
complex d
complex fpixel
complex func Iterate(complex pz)
pw=@wp1*pw+@wp2
pk=@kp1*pk+@kp2
pz=@zp1*pz+@zp2
pq=@qp1*pq+@qp2
a=pw
b=pk
d=pz
pw=pw/pz+@p1*c
pk=pk/pz+@p2*c
pz=a^2+b^2+pz^2+pq^2+@p3*c
pq=pq/d+@p4*c
if @v==0
c=c
elseif @v==1
c=@p5*c/2+@p6*d
else
c=@p5*c/2+@p6*pz
endif
return pz
return pw
return pk
return pq
endfunc

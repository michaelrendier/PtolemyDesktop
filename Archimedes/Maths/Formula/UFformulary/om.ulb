default=(-1.65,0)
visible=@mj==1
endparam
param p1
caption="Stohminy Parameter 1"
default=(4,0)
endparam
param p2
caption="Stohminy Parameter 2"
default=(1,0)
endparam
param zp1
caption="Z Parameter 1"
default=(1,0)
endparam

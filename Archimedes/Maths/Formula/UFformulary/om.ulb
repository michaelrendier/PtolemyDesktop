-3*y^2+(1.75,0.15)*sqrt((x-(0.15,0.65))^2+y^2)+sqrt((x+(0.15,0.65))^2+y^2)-@p1
elseif @v=="39"
z=((-0.95,1.45)*x^2+2*(-2,-0.55)*x*y+(1,-1)*y^2)*x-(2*@p1+(-0.95,1.45)*(-0.75,-0.95))*x^2-2*(-2,-0.55)*x*y-(2*(@p1+1.5+0.75i)+(1,-1)*(-0.75,-0.95))*y^2
elseif @v=="40"

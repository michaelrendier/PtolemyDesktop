f1=@pow*pz^(@pow-1)
a=f/f1
if @JM=="J"
pz=pz-@p1*a*(((pz-a)^@pow-@p3)-f)/((2*((pz-a)^@pow-@p3))-f)+@p2
else
pz=pz-@p1*a*(((pz-a)^@pow-@p3)-f)/((2*((pz-a)^@pow-@p3))-f)+@p2+fn3(fpixel)
endif
return pz
endfunc

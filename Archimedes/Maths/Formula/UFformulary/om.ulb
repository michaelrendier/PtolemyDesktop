default=100.0
exponential=true
endparam
}

class OM_IFB34(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
pz=fn1(pz)
return pz
endfunc
complex func Iterate(complex pz)
pz=@p6*pz+@p7
x=cos(@p26)*real(pz)-sin(@p26)*imag(pz)
y=sin(@p26)*real(pz)+cos(@p26)*imag(pz)
pz=x+flip(y)
float a=real(fn3(flip(pz)))-real(fn3(cotan(pz)))
if a<@p4
pz=pz*flip(@p1)+@p2
endif
if @p5<=a
pz=pz*atan(@p25)+@p3
endif
if a<@p8
pz=pz*sinh(@p25)+@p9
endif
if @p10<=a
pz=pz*conj(@p1)+@p11
endif
return pz
endfunc

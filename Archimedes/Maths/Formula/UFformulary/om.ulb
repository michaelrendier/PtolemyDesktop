class OM_Nedzhibov2(common.ulb:ConvergentFormula) {
;Root finding method attributed to Nedzhibov et al
;https://file.scirp.org/pdf/AM20100300002_25669189.pdf
public:
complex func Init(complex pz)
ConvergentFormula.Init(pz)
return @sf(pz)
endfunc
complex func Iterate(complex pz)
m_ZOld=pz
pz=@zp1*pz+@zp2
f=pz^@pow-@c
f1=@pow*pz^(@pow-1)
a=pz-@np3*f/f1
fa=a^@pow-@c
pz=a-@np2*f*fa/(f1*(f-@np1*fa))
return pz
endfunc

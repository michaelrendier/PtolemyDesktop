f=pz^i2-1
f1=3*pz^(i2-1)+@ap*@af(values[i2])
pz=pz-@np1*f/f1+@np2-0.4
elseif @v==3
pz=@zp1*pz+@zp2
pz=pz-0.1*sqr(pz)

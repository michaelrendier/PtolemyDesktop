complex func Iterate(complex pz)
ConvergentFormula.Iterate(pz)
return pz-@wp1*(((pz^@pow-@wp2)/(@pow*pz^(@pow-1)))/2)*(2-((pz^@pow-@wp2)*((@pow-1)*@pow*pz^(@pow-2))/sqr(@pow*pz^(@pow-1))))+@c

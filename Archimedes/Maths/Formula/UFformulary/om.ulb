b=a^3
d=z2^2+1
elseif @v==6
a=(z1^2*z3-1)/z2
b=a^3
d=z2^2
else
a=(z1^2*z3-z1)/z2
b=a^3
d=z2^2+1
endif
z1=@p1*fn2(z1-a/3+a/(3*b))+@p2
z2=@p3*fn3(z2+z3*a*d/3+z3*a*d/(3*b))+@p4
pz=z1+z2
return pz
return z1
return z2
return z3
endfunc

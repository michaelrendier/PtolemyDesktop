class OM_TrivarJulia4(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
u=@sf(pz)
v=@sf(pz)
pz=@sf(pz)
c=@js
return pz
return u
return v
endfunc
private:
complex c
complex u
complex v
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
u=@up1*u+@up2
v=@vp1*v+@vp2
pz=pz+@ar/pz
u=u+@ar/u
v=v+@ar/v
a=pz
pz=(1-@p1)*pz+@p1*(u^@pow+c)
u=(1-@p2)*a+@p2*(v^@pow+c)
v=(1-@p3)*a+@p3*(a^@pow+c)
return pz
return u
return v
endfunc
bool func IsBailedOut(complex pz)
bool bail=false
bail=(|(pz+u+v)/3|>@p_bailout)
return bail
endfunc

class OM_TetravarX6(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
a=(0,0)
b=(0,0)
pk=@sp
pq=@sp
pz=@sp
pw=@sp
return pz
return pq
return pk
return pw
endfunc
private:
complex pk
complex pw
complex pq
complex a
complex b
complex fpixel
complex func Iterate(complex pz)
pw=@wp1*pw+@wp2
pk=0.5*pk
pz=0.5*pz
pq=@qp1*pq+@qp2
if @v==0
pw=@p1*(pk-pw^2)+@p2*pq
pk=pw*(1-pz)-pk^2
pz=pw*pk-pz^2
pq=-pw-@p1*pq^2+@pf(fpixel)/pq^2
else
a=pw
b=pk
pw=@p1*(pk-pw^2)+@p2*pq
pk=a*(1-pz)-pk^2
pz=a*b-pz^2
pq=-a-@p1*pq^2+@pf(fpixel)/pq^2
endif
return pz
return pw
return pk
return pq
endfunc

class OM_BivarNewton(common.ulb:ConvergentFormula) {
public:
complex func Init(complex pz)
ConvergentFormula.Init(pz)
pk=@sf(pz)
pz=@sf(pz)
return pz
return pk
endfunc
private:
complex pk
complex func Iterate(complex pz)
ConvergentFormula.Iterate(pz)
;m_ZOld=pz
pz=@zp1*pz+@zp2
pk=@kp1*pk+@kp2
if @version==100
pk=@bp1*@bf(pk/pz)+@bp2
pz=pz+pk-@np1*(pz^@zpow-@np2)/(@zpow*pz^(@zpow-1))-@np3*(pk^@kpow-@np4)/(@kpow*pk^(@kpow-1))
else
if @bv==0
a=pk
pk=@bp1*@bf(pk/pz)+@bp2
pz=pz+a-@np1*(pz^@zpow-@np2)/(@zpow*pz^(@zpow-1))-@np3*(a^@kpow-@np4)/(@kpow*a^(@kpow-1))
else
pk=(@bp1+0.5)*@bf(pk/pz)+@bp2
pz=pz+pk-@np1*(pz^@zpow-@np2)/(@zpow*pz^(@zpow-1))-@np3*(pk^@kpow-@np4)/(@kpow*pk^(@kpow-1))
endif
endif
return pz
return pk
endfunc

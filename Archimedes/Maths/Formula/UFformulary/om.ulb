class OM_BivarGeneralisedAgarwalMandelhrot2(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fPixel=pz
c=@sf(fpixel)
pz=@sp
z2=@sp
return pz
return z2
endfunc
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
z2=@z2p1*z2+@z2p2
pz=pz+@ar/pz
z2=z2+@ar/z2
a=pz
b=z2
u=(1-@p1)*pz+@p1*(pz^@pow1+@pp1*c)
pz=(1-@p2)*(pz^@pow2+@pp2*c)+@p2*(u^@pow3+@pp3*c)
u2=(1-@p1)*z2+@p1*(z2^@pow1+@pp1*c)
z2=(1-@p2)*(z2^@pow2+@pp2*c)+@p2*(u2^@pow3+@pp3*c)
d=z2
z2=@bp1*@bf(b/a)+@bp2
pz=pz+@bp3*d
return pz
return z2
endfunc
bool func IsBailedOut(complex pz)
bool bail=false
bail=(|(pz+z2)/2|>@p_bailout)
return bail
endfunc

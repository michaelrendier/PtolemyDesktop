caption="Bailout"
default=1.0e-15
exponential=true
endparam
}

class OM_Jarratt(common.ulb:ConvergentFormula) {
public:
complex func Init(complex pz)
ConvergentFormula.Init(pz)
return @sf(pz)
endfunc
complex func Iterate(complex pz)
ConvergentFormula.Iterate(pz)
pz=@zp1*pz+@zp2
f=pz^@pow-@c
f1=@pow*pz^(@pow-1)

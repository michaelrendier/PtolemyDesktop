class OM_ModifiedXPlogPhoenix(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
a=(0,0)
b=(0,0)
if @jm==0
pz=@pf(pz)
c=@js
else
if @jm==2
pz=@sp
else
pz=@sp+2.775
endif
c=@pf(fpixel)
endif
return pz
endfunc
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if @jm==0 || @jm==1
b=pz^@pow1+pz^@pow2*c+@pp*a
b=b^2+exp(log(b)^2+@xp1*log(b)+log(c))+@mp1/b
else
b=pz^@pow1+pz^@pow2*c+@pp*a
b=b^2+exp(log(b)^2+@xp1*log(b)+log(c))-@mp1*c/b
endif
a=pz
pz=b
return pz
endfunc
private:
complex a
complex b
complex c
default:

+flip(-x+(-@p2b)*(y+(@p1b-1.2)*(1-0.05*y^2)+(-@p2b)*x+2*(1-(-@p2b))*x^2/(1+x^2))\
+2*(1-(-@p2b))*(y+(@p1b-1.2)*(1-0.05*y^2)+(-@p2b)*x+2*(1-(-@p2b))*x^2/(1+x^2))\
^2/(1+(y+(@p1b-1.2)*(1-0.05*y^2)+(-@p2b)*x+2*(1-(-@p2b))*x^2/(1+x^2))^2))
elseif @v2=="Hamilton"
pz=x+(@p1b-0.8-0.2i)*@p2b*sin(2*pi*y)+flip(y-((@p1b-0.8-0.2i)/@p2b)*sin(2*pi*(x+(@p1b-0.8-0.2i)*@p2b*sin(2*pi*y))))
elseif @v2=="Henon"
pz=1-@p1b*x^2+y+flip(@p2b*x)
elseif @v2=="Henon-Heiles"
pz=-@p1b*x-@p2b*x*y+flip(-@p3b*y-@p4b*x^2+@p5b*y^2)
elseif @v2=="Horsthemke-Lefever"
pz=(@p1b-1.5)*x*(1-x/@p3b)-@p2b*x*y+flip(-@p2b*x*y+@p4b*(@p5b-y))
elseif @v2=="Ikeda"
pz=@p1b+@p2b*(x*cos((@p3b+0.5)-(@p4b-5.5-1i)/(x^2+y^2+1))-y*sin((@p3b+0.5)-(@p4b-5.5-1i)/(x^2+y^2+1))) \
+flip(@p2b*(x*sin((@p3b+0.5)-(@p4b-5.5-1i)/(x^2+y^2+1))+y*cos((@p3b+0.5)-(@p4b-5.5-1i)/(x^2+y^2+1))))
elseif @v2=="Ilhem-Amel"
pz=x^3+@p1b*x+(@p2b-2.25+0.55i)+y+flip(@p3b*x)
elseif @v2=="Kam Torus"
pz=x*cos(@p1b-1+0.5i)+(x^2-y)*sin(@p1b-1+0.5i)+flip(x*sin(@p1b-1+0.5i)-(x^2-y)*cos(@p1b-1+0.5i))
elseif @v2=="Khovanov-Luchinsky"
pz=y+flip(-(@p1b-2.45+1.25i)*x+(@p2b-3+1.45i)*y-y^3+@p3b)
elseif @v2=="Kolmogorov-Volterra"
pz=(x*((@p1b-2.05-1.6i)-x^2)-@p2b*x*y)/(1+x^2)+flip((@p3b*x^2-1)*y/(1+x^2))
elseif @v2=="Latoocarfian"
pz=sin((@p1b+5.45-1.4i)*y)+(@p2b-1+0.15i)*sin((@p1b+5.45-1.4i)*x)+flip(sin(@p3b*x)+@p4b*sin(@p3b*y))
elseif @v2=="Limit Cycle"
pz=x-y-@p1b*x*(x^2+y^2)+@p3b+flip(x+y-@p2b*y*(x^2+y^2)+@p4b)
elseif @v2=="Lozi"
pz=1-(@p1b-2.7)*cabs(x)+y+flip(@p2b*x)
elseif @v2=="MacMillan"
pz=y+flip(-x-2*(@p1b-1+0.5i)*y/(1-y^2)+(@p2b-0.75-1.5i)*y)
elseif @v2=="Marotto-Lorenz"
pz=(1-@p1b*x-@p2b*y)*(@p1b*x+@p2b*y)+flip(x)
elseif @v2=="Martin"
pz=y+sin(x)+flip(@p1b-x)
elseif @v2=="Maynard Smith"
pz=y+flip(-@p1b*y+(@p2b+1)-x^2)
elseif @v2=="Mira"
pz=x^2-y^2+(@p1b-1.87+0.52i)*x+(@p2b-1.25+0.95i)+flip(2*x*y-5*(@p1b-1.87+0.52i)*y/2+@p3b)
elseif @v2=="Modified Lozi"
pz=1+@p1b*(cabs(x)-y^2)+y+flip(@p2b*x)
elseif @v2=="Multifold Henon"
pz=1-(@p1b+0.5+1.35i)*sin(x)+@p2b*y+flip(x)
elseif @v2=="Pharaoh"
pz=-y+@p1b*cos(x)*sin(1-real(pz)^2-y^2)+@p3b+flip(x+@p2b*cos(y)*sin(1-x^2-y^2)+@p4b)
elseif @v2=="Popcorn"
pz=x-(@p1b-2.5)*sin(y+tan((@p2b-1+1i)*y))+flip(y-(@p1b-2.5)*sin(x+tan((@p2b-1+1i)*x)))
elseif @v2=="Quadruptwo"
pz=y-(x/cabs(x))*sin(log(abs((@p2b+0.2+0.85i)*x-@p3b)))*atan(sqr(log(abs(@p3b*x-(@p2b+0.2+0.85i)))))+flip(@p1b-x)
elseif @v2=="Provenzale-Balmforth"
pz=((@p1b-0.35+4.55i)*y+@p2b)*x*(1-x)+flip(4*y*(1-y))
elseif @v2=="Rayleigh"
pz=y+flip(-(x+(@p2b-1+0.35i)*y^3-@p1b*y)/(@p3b-0.75+0.25i))
elseif @v2=="Rulkov"
pz=(@p1b-3-1i)/(1+x^2)+y+flip(y-@p2b*x-@p3b)
elseif @v2=="Sprott"
pz=(1+(@p1b-1+3.25i)*(@p2b-1+1i))*x-(@p2b-1+1i)*x*y+flip((1-(@p2b-1+1i))*y+(@p2b-1+1i)*x^2)
elseif @v2=="Sprott-Elhadj"
pz=@p1b*x/(1+y^2)+flip(x+(@p2b+1.15+1.15i)*y)
elseif @v2=="Standard Map"
pz=x+@p1b*sin(y)+flip(y+x+@p1b*sin(y))
elseif @v2=="Stommel Thermohaline"
pz=(@p1b+0.2+0.35i)-x-x*(x-y)+flip(@p2b-(@p3b-1.75-2.25i)*y-y*(x-y))
elseif @v2=="Strelkova-Anishchenko"
pz=1-@p1b*x^2+(@p2b-1.7-0.25i)*(y-x)+flip(1-@p1b*y^2+(@p2b-1.7-0.25i)*(x-y))
elseif @v2=="Threeply"
pz=y-(x/cabs(x))*(abs(sin(x)*cos(@p2b)+@p3b-x*sin((@p1b-3.7-1.7i)+@p2b+@p3b)))+flip((@p1b-3.7-1.7i)-x)
elseif @v2=="Tinkerbell"
pz=x^2-y^2+(@p1b-2+0.1i)*x+(@p2b-0.85-0.65i)*y+flip(2*x*y-@p3b*x+@p4b*y)
elseif @v2=="Ushiki"
pz=((@p1b+1i)-x-@p2b*y)*x+flip((@p3b-y-@p4b*x)*y)
elseif @v2=="Van der Pol"
pz=(@p1b+3-1.5i)*(x-x^3/3-y)+flip(x/(@p1b+3-1.5i))
elseif @v2=="Volterra-Lotka"
pz=(@p1b+0.6-0.9i)*x-@p2b*x*y+flip(-@p3b*y+@p4b*x*y)
elseif @v2=="Zaslavsky"
pz=(x+(@p1b-3.5-2i)*sin(y))*cos(2*pi/@p2b)+y*sin(2*pi/@p2b)+flip(-(x+(@p1b-3.5-2i)*sin(y))*sin(2*pi/@p2b)+y*cos(2*pi/@p2b))
elseif @v2=="OM1"
pz=(x^2-y^2)*(x^2+y^2)^2-2*(@p1b-7.15-1.45i)*x*y*(x-@p2b^2)
elseif @v2=="OM2"
pz=(@p1b-2.2+0.25i)*(x+y^2)+@p2b*sin(x)*(x^2-y)+flip(-2*(@p1b-2.2+0.25i)*x*y*((@p1b-2.2+0.25i)^2-@p2b^2))
elseif @v2=="OM3"
pz=y/(@p2b+4.25-2.75i)+flip(x/@p3b-(@p1b+0.6+0.85i))
elseif @v2=="OM4"
pz=((@p1b*@p2b-x)^2+(@p1b-y)^2)/@p3b^2-1
elseif @v2=="OM5"
pz=@p1b*y-@p2b*x^2+flip(x*y-(@p3b-0.3-2.2i))
elseif @v2=="OM6"
pz=((@p1b*(@p2b-2+0.55i)-x*y)^3+(@p1b*@p3b-(X^2+y^2)^2))
elseif @v2=="OM7"
pz=y^2+x^2-((x+(@p3b*(x-@p2b))/sqrt((x-@p1b)^2+(y-@p3b)^2))-(y+(@p2b*(y-@p1b))/sqrt((x-@p3b)^2+(y-@p2b)^2)))
elseif @v2=="OM8"
pz=x^2-4*(@p1b-1.2)*y*(x^2+y^2)+flip(y^3*(@p2b-1.2-0.2i)^2*(x^2-y^2)^4)
elseif @v2=="OM9"
pz=y-x*(x^4-(@p1b-3.8-0.3i))*(x^2+y^2)^2
elseif @v2=="OM10"
pz=x+y+(@p1b-3.5-1.25i)*sin(x)+flip(x-y+(@p2b+1.15)*sin(x)-x)
elseif @v2=="OM11"
pz=x-y-cotan(x)*(@p1b*x^2+@p2b*y^2)+flip(x+y-cotan(y)*(@p3b*x^2+@p4b*y^2))
elseif @v2=="OM12"
pz=x+(@p1b-1.85)*@p2b*abs(y)+flip(y-((@p1b-1.85)+@p2b)*abs(x+(@p1b-1.85)*@p2b*2*pi*y))
elseif @v2=="OM13"
pz=x-(@p1b-0.25-1.4i)*y+flip(x^4-(@p1b-0.25-1.4i)^2*y+(@p2b-2-1i)-x^2)
elseif @v2=="OM14"
pz=x+@p2b*y+@p1b*sin(x)+flip(y+@p3b*sin(x))
elseif @v2=="OM15"
pz=(@p1b-2.3-1.65i)*x/(1+y^2)+(1+(@p1b-2.3-1.65i)*@p2b)*x-@p2b*x*y+flip(x+@p2b*y+(1-@p2b)*y+@p2b*x^2)
elseif @v2=="OM16"
pz=y+(@p1b+1.3-0.7i)*x*(2-x)+flip(@p2b*x*sin(y)+@p2b/2+x^2)
elseif @v2=="OM17"
pz=(x^2+y^2)*((x^2+y^2)/(2*@p1b)-x)^2+4*(@p2b-1.75-0.05i)^4\
-4*(@p2b-1.75-0.05i)^2*(x^2+y^2)+2*(@p2b-1.75-0.05i)*x*(x^2+y^2)/@p1b\
+(x^2+y^2)*(x^2+@p1b^2-(@p2b-1.75-0.05i)^2)^2-4*@p1b^2*x^4
elseif @v2=="OM18"
pz=x*(x^2+y^2)+(@p1b-2)*(x^2-y^2)+(@p2b-4.5+1.35i)*(x+@p3b)+(x-(@p1b-2))*(x^2+y^2)+(@p2b-4.5+1.35i)*x+@p3b*y
elseif @v2=="OM19"
pz=((@p1b-2.85+1i)*y+(@p2b-1.6-2i))*x*(1-x)+1+(@p1b-2.85+1i)*(cabs(x)-y^2)+y+flip((@p2b-1.6-2i)*x+4*y*(1-y))
elseif @v2=="OM20"
pz=x-y-@p1b*x*(x^2+y^2)+@p3b-@p1b*x*(x-@p2b)*(1-x)-y+@p3b+flip(x+y-@p2b*y*(x^2+y^2)+(@p4b-3.5-2i)*(1+x-y))
elseif @v2=="OM21"
pz=(x-2*@p1b)*(x^2+y^2)+(@p2b+0.15+0.1i)^2*(cos(2*@p3b*x)+sin(2*@p3b*y))+(x^2+y^2)*(x^2+@p1b^2-(@p2b+0.15+0.1i)^2)^2-4*@p1b^2*x^4
elseif @v2=="OM22"
pz=(x^2+y^2)*(x^2+(@p1b+0.05-0.5i)^2-@p2b^2)^2-4*(@p1b+0.05-0.5i)^2*x^4\
+@p2b*y+(@p1b+0.05-0.5i)*x+2*(1-(@p1b+0.05-0.5i))*x^2/(1+x^2)\
+flip(-x+(@p1b+0.05-0.5i)*(@p2b*y+(@p1b+0.05-0.5i)*x+2*(1-(@p1b+0.05-0.5i))*x^2/(1+x^2))\
+2*(1-(@p1b+0.05-0.5i))*(@p2b*y+(@p1b+0.05-0.5i)*x+2*(1-(@p1b+0.05-0.5i))*x^2/(1+(@p2b*y\
+(@p1b+0.05-0.5i)*x+2*(1-(@p1b+0.05-0.5i))*x^2/(1+x^2))^2))^2/(1+x^2))
elseif @v2=="OM23"
pz=(y^2-x^2)*(x-1)*(2*x-3)-4*(x^2+y^2-2*x)^2-(@p1b-4.25-0.35i)+(@p1b-4.25-0.35i)*x+y+flip((@p2b-1.45-3.75i)+x^2)
elseif @v2=="OM24"
pz=x^2*(3*x^2-y^2)^2-y^2*(x^2+y^2)-(@p1b-4.25-0.35i)+(@p1b-4.25-0.35i)*x+y+flip((@p2b-1.45-3.75i)+x^2)
elseif @v2=="OM25"
pz=1-(@p1b-6.5-0.25i)*x^2+(@p2b-0.55-0.5i)*(y-x)+(@p1b-6.5-0.25i)*(1-x)-(@p2b-0.55-0.5i)*x*cabs(y-@p3b*x)\
+flip(2-(@p1b-6.5-0.25i)*y^2+(@p2b-0.55-0.5i)*(x-y)-y-(@p2b-0.55-0.5i)*y*cabs(y-@p3b*x))
elseif @v2=="OM26"
pz=x^@p1b+(x^2+y^2)^@p2b-@p1b*(x-y)^(@p3b-0.2-0.8i)
elseif @v2=="OM27"
pz=(@p1b-0.65-0.2i)^2*y^2+(@p2b+0.2+0.45i)^2*x^(@p1b-0.65-0.2i)-x^2*y^(@p2b+0.2+0.45i)
elseif @v2=="OM28"
pz=y^2/(2*@p1b)+@p1b*(@p2b-0.4)^2/(2*(y^2+@p1b))-x+(x+@p1b*sin(y))*cos(2*pi/(@p2b-0.4))\
+y*sin(2*pi/(@p2b-0.4))+flip(-(x+@p1b*sin(y))*sin(2*pi/(@p2b-0.4))+y*cos(2*pi/(@p2b-0.4)))
elseif @v2=="OM29"
pz=x^2+(@p5b-0.5)*y^2-e^(2*x-2)+(x^2+y^2)^@p1b-2*@p2b*x^(2*@p1b)*(x^2+y^2)^@p1b+(@p2b-@p3b)*x^(4*@p1b)*@p4b\
-2*@p2b*@p4b*cos(@p5b-0.5)^(2*@p1b)+(@p2b-@p3b)*cos(@p5b-0.5)^(4*@p1b)
elseif @v2=="OM30"
pz=(x^2+y^2)*(x^2+y^2-@p1b*x-@p2b*y)-@p3b^2*x^2*y^2+@p1b^2*y^2-x^2*(y^2-x^2)+x^3+y^3-@p3b^3+(@p1b^2-x^2)*(@p2b^2+y^2)-@p1b^2*@p2b^2
endif
pz=pz+@app*@apf(pixel)
a=a+exp(-cabs(pz))
endif
endfunc
float func ResultIndex(complex pz)
if@solid
if @invert
if a<@sca
index=@adj*a
else
m_Solid=true
endif
else
if a>=@sca
index=@adj*a
else
m_Solid=true
endif
endif
else
index=@adj*a
endif
return index
endfunc

class OM_FelixCL(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
ang=2*pi/3
c1=(1+@fp*1i)*@fn1(exp((0,0)*ang))
c2=(1+@fp*1i)*@fn1(exp((0,1)*ang))
c3=(1+@fp*1i)*@fn1(exp((0,2)*ang))
r=sqrt(3)/2
pz=@pf(pz)
i=0
i2=0
i3=0
return pz
endfunc
private:
complex c1
complex c2
complex c3
float r
int i
int i2
int i3
complex func Iterate(complex pz)
if @v==1
pz=@zp1*flip(pz)+@zp2
elseif @v==6
pz=@zp1*recip(pz)+@zp2
elseif @v==7
pz=@zp1*flip(pz)+@zp2
elseif @v==8
pz=@zp1*flip(pz)+@zp2
elseif @v==9
pz=@zp1*abs(pz)+@zp2
elseif @v==10
pz=@zp1*flip(pz)+@zp2
else
pz=@zp1*pz+@zp2
endif
if @av==0
if i==0
if i2<i3
pz=pz^@pow1+@clp2
i2=i2+1
else
pz=pz^@pow1+@clp1*pz^@pow2+@clp2
i2=0
endif
i=1
else
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
endif
if @v==2
pz=flip(pz)
elseif @v==3
pz=conj(pz)
elseif @v==4
pz=abs(pz)
elseif @v==5
pz=sqr(pz)
elseif @v==6
pz=sqr(pz)
elseif @v==7
pz=flip(pz)
elseif @v==8
pz=conj(pz)
elseif @v==9
pz=flip(pz)
elseif @v==10
pz=abs(pz)
endif
i=0
endif
else
if i==0
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
endif
if @v==2
pz=flip(pz)
elseif @v==3
pz=conj(pz)
elseif @v==4
pz=abs(pz)
elseif @v==5
pz=sqr(pz)
elseif @v==6
pz=sqr(pz)
elseif @v==7
pz=flip(pz)
elseif @v==8
pz=conj(pz)
elseif @v==9
pz=flip(pz)
elseif @v==10
pz=abs(pz)
endif
i=1
else
if i2<i3
pz=pz^@pow1+@clp2
i2=i2+1
else
pz=pz^@pow1+@clp1*pz^@pow2+@clp2
i2=0
endif
i=0
endif
endif
return pz
endfunc

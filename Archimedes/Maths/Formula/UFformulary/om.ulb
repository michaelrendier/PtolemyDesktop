class OM_ModifiedDasDebataLogXP(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fPixel=pz
if @jm==0
pz=@sf(pz)
if @v==0
c=@js+1.85
else
c=@js
endif
else
pz=@sp
c=@sf(fpixel)
endif
return pz
endfunc
private:
complex c
complex func Iterate(complex pz)
if @v==0 && @jm==1
pz=(@zp1+0.05)*pz+@zp2
else
pz=@zp1*pz+@zp2
endif
if @v==0
fz=pz^2+(@xp2-1.5)*log(1/(exp(1/pz)^2+@xp1*exp(1/pz)+exp(1/c)))^2+c+@mp1/pz
u=(1-@ddp1)*pz+@ddp1*fz
fu=u^2+(@xp4-1.5)*log(1/(exp(1/u)^2+@xp3*exp(1/u)+exp(1/c)))^2+c+@mp2/u
pz=(1-@ddp2)*pz+@ddp2*fu
elseif @v==1
fz=pz^2+(@xp2-1.75)*log(1/(exp(1/pz)^2+@xp1*exp(1/pz)+exp(1/c)))^2+@mp1/pz
u=(1-@ddp1)*pz+@ddp1*fz
fu=u^2+(@xp4-1.75)*log(1/(exp(1/u)^2+@xp3*exp(1/u)+exp(1/c)))^2+@mp2/u
pz=(1-@ddp2)*pz+@ddp2*fu
else
fz=pz^2+(@xp2-0.5)*log(1/(exp(1/pz)^2+@xp1*exp(1/pz)))^2+c+@mp1/pz
u=(1-@ddp1)*pz+@ddp1*fz
fu=u^2+(@xp4-0.5)*log(1/(exp(1/u)^2+@xp3*exp(1/u)))^2+c+@mp2/u
pz=(1-@ddp2)*pz+@ddp2*fu
endif
return pz
endfunc

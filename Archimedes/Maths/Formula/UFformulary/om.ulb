class OM_InversefreeJarratt(common.ulb:ConvergentFormula) {
public:
complex func Init(complex pz)
ConvergentFormula.Init(pz)
return @sf(pz)
endfunc
complex func Iterate(complex pz)
ConvergentFormula.Iterate(pz)
pz=@zp1*pz+@zp2
f=pz^@pow-@c
f1=@pow*pz^(@pow-1)
u=f/f1
h=(@pow*(pz-2*u/3)^(@pow-1)-f1)/f1
pz=pz-@jp*(u-3*u*h*(1-3*h/2)/4)
return pz
endfunc

class OM_Stirling(common.ulb:ConvergentFormula) {
public:
complex func Init(complex pz)
ConvergentFormula.Init(pz)
return @sf(pz)
endfunc
complex func Iterate(complex pz)
ConvergentFormula.Iterate(pz)
pz=@zp1*pz+@zp2
f=pz^@pow-@c
ff1=@pow^2*pz^(@pow-1)*(pz^@pow-@c)^(@pow-1)
pz=pz-@sp*(pz-f)/(1-ff1)
return pz
endfunc

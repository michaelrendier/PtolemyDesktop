endif
elseif @V=="6"
if a<@p4
pz=(sqrt(1i)*pz+0.5+@p17)*fn2(flip(@p1))+@p2
endif
pz=pz*@fn9(atan(@p8))+@p11
if @p5<=a
pz=log(sqrt(1i)*pz+0.5+@p17)*fn2(conj(@p1))+@p3
endif
elseif @V=="7"
if a<@p4
pz=(sqrt(1i)*pz+0.3+@p17)*fn2(flip(@p1))+@p2
endif
pz=pz*@fn9(atan(@p8))+@p11
if @p5<=a
pz=cotan(sqrt(1i)*pz+0.3+@p17)*fn2(conj(@p1))+@p3
endif
elseif @V=="8"
if a<@p4
pz=(sqrt(1i)*pz+@p17)*fn2(flip(@p1))+@p2
endif
pz=pz*@fn9(atan(@p8))+@p11
if @p5<=a

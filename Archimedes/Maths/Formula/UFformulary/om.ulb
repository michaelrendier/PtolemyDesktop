caption="Z Parameter 2"
default=(0,0)
endparam
param z2p1
caption="Z2 Parameter 1"
default=(1,0)
endparam
param z2p2
caption="Z2 Parameter 2"
default=(0,0)
endparam
func sf
caption="Pixel Function"
default=ident()
endfunc
func bf
caption="Bivar Function"
default=ident()
endfunc
param ar
caption="Add recip Parameter"
default=(0,0)
endparam
param p_power
visible=false
endparam

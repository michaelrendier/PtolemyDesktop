class OM_IFB83(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
i=0
return fn1(pz)
endfunc
private:
int i
complex func Iterate(complex pz)
i=i+1
pz=@p6*pz+@p7
pz=pz+@p8*sqrt(pz)
pz=pz+@p9*atanh(pz)
pz=pz+@p10*atan(pz)
pz=pz+@p11*asinh(pz)
pz=pz+@p12*asin(pz)
pz=pz+@p13*ceil(pz)
float a=real(pz)
if a<@p4
pz=(pz+i)*@p1+@p2
endif
if @p5<=a
pz=(pz-i)*conj(fn2(@p1))+@p2
endif
return pz
endfunc

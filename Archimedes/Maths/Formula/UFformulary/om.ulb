class OM_AltX14(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
if @mj==0
fpixel=pz
c=@pf(fpixel)
pz=@sp
else
pz=@pf(pz)
c=@js
endif
i=0
return pz
endfunc
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if i==0
a=pz^@pow1+@xp3*c
b=pz^@pow2+@xp4*c
pz=a+b+@xp1/(a+b)
i=1
else
a=pz^@pow3+@xp5*c
b=pz^@pow4+@xp6*c
pz=a+b+@xp2/(a+b)
i=0
endif
return pz
endfunc
private:
complex c
int i
default:
title="Alt X 14"
int param version
caption="Version"
default=100
visible=@version<100
endparam
param mj
caption="M/J"
enum="M""J"
endparam
param sp
caption="Start Parameter"
default=(0,0)
visible=@mj==0
endparam
param js

class OM_LabsX14(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fPixel=pz
i=0
pz=fn1(pz)
if @S=="1"
pz=pz^2+@sp*(2*pz-1i)/(pz+2i)/(pz-1)
elseif @S=="2"
pz=pz+(pz-@sp*1i)/(pz+@sp*1i)
elseif @S=="3"
pz=(pz+@sp*1i)/(pz-@sp*1i)
elseif @S=="4"
pz=pz^2*(pz-@sp)/(1-@sp*pz)
elseif @S=="5"
pz=(cotanh(pz)-@sp*1i)/(pz+cotanh(@sp))
elseif @S=="6"
pz=pz+((pz^2+@sp-1)/(2*pz+@sp-2))^2
elseif @S=="7"
pz=pz^2*((pz-(@sp-0.5))/(1-(@sp-0.5)*pz))
elseif @S=="8"
pz=(pz+@sp*1i)/(pz-@sp*1i)
elseif @S=="9"
pz=@sp*(pz+1i)*(pz-1)/(pz+1)
elseif @S=="10"
pz=@sp*(pz+1i)*(pz-1)/(pz-1i)
elseif @S=="11"
pz=pz+pz^2*cosh((pz-@sp)/(1-@sp*pz))
elseif @S=="12"
pz=pz+@sp*pz^3
elseif @S=="13"
pz=@sp*(pz-0.5)/(1-0.5*pz)/(pz-1i)
elseif @S=="14"
pz=@sp*(pz-0.5)/(1i-0.5*pz)/(pz-1)
elseif @S=="15"
pz=(sqr(pz)-@sp*1i)/(pz+sqr(@sp))
elseif @S=="16"
pz=pz+pz^2*cos((pz-@sp)/(1-@sp*pz))
elseif @S=="17"
pz=pz^2*sqr((pz-(@sp-0.5))/(1-(@sp-0.5)*pz))
elseif @S=="18"
pz=pz^2*exp((pz-(@sp-0.5))/(1-(@sp-0.5)*pz))
endif
return pz
endfunc
complex func Iterate(complex pz)
while i<@iter
i=i+1
pz=@p12*fn2(pz)+@p13
pz=(pz-@p6)/(1-@p6*pz)
pz=pz/(@p7*pz+1)
pz=pz+@p8*sqr(pz)
pz=pz+@p9/pz
if @Va=="None"
pz=pz
elseif @Va=="1"
pz=pz-1/sqr(pz)
elseif @Va=="2"
pz=pz+(pz+1i)/(pz-1i)
elseif @Va=="3"
if real(pz)<imag(pz)
pz=flip(pz)
endif
pz=0.67*conj(pz)
elseif @Va=="4"
pz=pz-cotanh(pz)
elseif @Va=="5"
if real(pz)>imag(pz)
pz=flip(pz)
endif
pz=0.5*pz
elseif @Va=="6"
pz=pz+(sqr(pz)+1)/(sqr(pz)-1)
elseif @Va=="7"
if |pz|<1
pz=pz/|pz|
endif
pz=0.75*pz
elseif @Va=="8"
pz=pz+(pz+1)/(pz-1)
elseif @Va=="9"
pz=pz+cotan(pz)
elseif @Va=="10"
if real(pz)>imag(pz)
pz=flip(pz)
endif
pz=0.54*conj(pz)
elseif @Va=="11"
pz=pz+(pz-1)/(pz+1)
elseif @Va=="12"
if real(pz)<imag(pz)
pz=flip(pz)
endif
pz=-0.67*pz
elseif @Va=="13"
pz=pz+1/cosh(pz)
elseif @Va=="14"
pz=pz-tan(pz)
elseif @Va=="15"
pz=pz+cotanh((pz-1i)/(pz+1i))
elseif @Va=="16"
pz=pz+(exp(pz)-1)/(exp(pz)+1)
elseif @Va=="17"
if real(pz)<imag(pz)
pz=flip(pz)
endif
pz=-0.67*conj(pz)
elseif @Va=="18"
pz=pz+(exp(pz)+1)/(exp(pz)-1)
elseif @Va=="19"
pz=((pz^2-0.8)/(2*pz-1.8))^2
elseif @Va=="20"
pz=pz+1/sin(pz)
elseif @Va=="21"
pz=conj((pz-0.155)/(1-0.155*pz))
elseif @Va=="22"
pz=pz+tanh(pz)
elseif @Va=="23"
pz=cotan(-1/(pz-1))+1
elseif @Va=="24"
pz=conj((pz-0.258)/(1-0.258*pz))
elseif @Va=="25"
pz=flip((pz+0.177)/(1+0.177*pz))
elseif @Va=="26"
pz=pz-tanh(pz)
elseif @Va=="27"
if real(pz)<imag(pz)
pz=flip(pz)
endif
pz=-abs(pz)
elseif @Va=="28"
pz=pz+(sinh(pz)-1)/(sinh(pz)+1)
elseif @Va=="29"
pz=cotanh(-1/(pz-1))+1
elseif @Va=="30"
pz=pz+(pz-1i)/(pz+1i)
elseif @Va=="31"
pz=pz+1i*tan(1i*pz)
elseif @Va=="32"
pz=pz+tan(pz)
elseif @Va=="33"
pz=pz+(sqr(pz)-1)/(sqr(pz)+1)
elseif @Va=="34"
pz=pz+cotanh(pz)
elseif @Va=="35"
pz=pz+(recip(pz)+1)/(recip(pz)-1)
elseif @Va=="36"
pz=pz+(sinh(pz)+1)/(sinh(pz)-1)
endif
if real(pz)>imag(pz)
pz=flip(pz)
endif
pz=(@p1-1.45)*abs(pz)+@p2
pz=((pz^2-0.8)/(2*pz-1.8))^2
pz=(pz^2/(2*pz-1))^2
f=pz+1/pz
f1=1-1/pz^2
pz=pz-@p3*f/f1
if @JM=="J"
pz=@p10*fn4(log(abs(pz)))+@p11
else
pz=@p10*fn4(log(abs(pz)))+@pp*@fn5(fpixel)
endif
endwhile
pz=pz*51/50
return pz
endfunc
private:
complex fpixel
int i
default:
title="Labs X 14"
int param version
caption="Version"
default=100
visible=@version<100
endparam
param JM
caption="J/M"
enum="J""M"

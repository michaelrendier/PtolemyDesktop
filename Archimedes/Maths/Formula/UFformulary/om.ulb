c2=(h2*((@p1b+3.3+3.4i)-h2^2)-(@p2b+0.5+2.5i)*h2*j2)/(1+h2^2)+flip((@p3b-4.85+2.55i)*j2/(1+h2^2))
elseif @v3=="Latoocarfian Attractor"
c2=sin((@p1b-2.4+0.6i)*j2)+(@p2b-3.1-0.5i)*sin((@p1b-2.4+0.6i)*h2)+flip(sin(@p3b*h2)+@p4b*sin(@p3b*j2))
elseif @v3=="Lemniscate of Bernoulli"
c2=(h2^2+j2^2)^2-(@p1b-0.7-1.55i)^2*(h2^2-j2^2)
elseif @v3=="Lemniscate of Booth"
c2=(h2^2+j2^2)^2-(2*(@p1b-0.85+0.95i)^2+@p2b)*h2^2+(2*(@p1b-0.85+0.95i)^2-@p2b)*j2^2
elseif @v3=="Lemniscate of Montferrier"
c2=@p2b^2*j2^2-h2^2*((@p1b-2.8+0.35i)^2-h2^2)
elseif @v3=="Limit Cycle"
c2=h2-j2-@p1b*h2*(h2^2+j2^2)+@p3b+flip(h2+j2-@p2b*j2*(h2^2+j2^2)+@p4b)
elseif @v3=="Lissajous Curve"
c2=2*(2*h2^2-(@p1b-1.9-0.1i)^2)^2-(@p1b-1.9-0.1i)*(2*j2-(@p1b-1.9-0.1i))^2*(j2+(@p1b-1.9-0.1i))
elseif @v3=="Lissajous Quadratic"
c2=(@p1b-0.6)^4*j2^4-4*(@p1b-0.6)^3*(@p2b-1-0.6i)*h2*j2^3+2*(@p1b-0.6)^2*(@p2b-1-0.6i)*j2^3 \
+6*(@p1b-0.6)^2*(@p2b-1-0.6i)^2*h2^2*j2^2-4*(@p1b-0.6)*(@p2b-1-0.6i)^2*h2*j2^2-2*(@p1b-0.6)^3*h2*j2^2 \
-2*(@p1b-0.6)^2*(@p2b-1-0.6i)^2*j2^2+(@p2b-1-0.6i)^2*j2^2+(@p1b-0.6)^2*j2^2 \
-4*(@p1b-0.6)*(@p2b-1-0.6i)^3*h2^3*j2+2*(@p2b-1-0.6i)^3*h2^2*j2+4*(@p1b-0.6)^2*(@p2b-1-0.6i)*h2^2*j2+4*(@p1b-0.6)*(@p2b-1-0.6i)^3*h2*j2 \
-2*(@p2b-1-0.6i)^3*j2-4*(@p1b-0.6)^2*(@p2b-1-0.6i)*j2+(@p2b-1-0.6i)^4*h2^4-2*(@p1b-0.6)*(@p2b-1-0.6i)^2*h2^3-2*(@p2b-1-0.6i)^4*h2^2 \
+(@p2b-1-0.6i)^2*h2^2+(@p1b-0.6)^2*h2^2+2*(@p1b-0.6)*(@p2b-1-0.6i)^2*h2-(@p1b-0.6)^2-(@p2b-1-0.6i)^2+(@p2b-1-0.6i)^4
elseif @v3=="Logarithmic Lemniscate"
c2=j2^2-h2^2*log((@p1b+1.5+1i)^2/h2^2)
elseif @v3=="Martin Attractor"
c2=j2+sin(h2)+flip(@p1b-h2)
elseif @v3=="Modified Lozi Attractor"
c2=1-@p1b*(cabs(h2)-j2^2)+j2+flip((@p2b-1.55-0.35i)*h2)
elseif @v3=="Neile's Semi-Cubical Parabola"
c2=j2^3-(@p1b-0.8+0.15i)*h2^2
elseif @v3=="Nephroid"
c2=(h2^2+j2^2-4*(@p1b-1.4+0.4i)^2)^3-108*(@p1b-1.4+0.4i)^4*h2^2
elseif @v3=="Newton's Diverging Parabolas 1"
c2=(@p1b+0.55+2i)*j2^2-h2*(h2^2-2*(@p2b-2.45-0.2i)*h2+@p3b)
elseif @v3=="Newton's Diverging Parabolas 2"
c2=j2^2-h2*(h2^2+2*(@p1b-0.85-0.25i)*h2+(@p2b-1.85-0.2i))
elseif @v3=="Oblique Astroid"
c2=((h2^2+j2^2+2*h2*j2*cos(@p1b+1.1-0.55i)-@p2b^2)^3+27*@p2b^2*h2^2*j2^2*sin(@p1b+1.1-0.55i)^2)*sin(@p1b+1.1-0.55i)^2\
-@p2b^2*cos(@p1b+1.1-0.55i)*((h2^2+j2^2+2*h2*j2*cos(@p1b+1.1-0.55i)-@p2b^2)^2*cos(@p1b+1.1-0.55i)-\
2*h2*j2*(9*(h2^2+j2^2+2*h2*j2*cos(@p1b+1.1-0.55i)-@p2b^2)*sin(@p1b+1.1-0.55i)^2-8*@p2b^2*cos(@p1b+1.1-0.55i)^2))
elseif @v3=="Oblique Bifolium"
c2=(h2^2+j2^2)^2-h2^2*((@p1b-2.45+0.1i)*h2+@p2b*j2)
elseif @v3=="Oblique Cappa"
c2=(h2^2+j2^2)*j2^2-(@p1b+0.75-0.6i)^2*(h2*sin(@p2b)+j2*cos(@p2b))^2
elseif @v3=="Oblique Cissoid"
c2=(h2^2+j2^2)*(h2*cos(@p2b)+j2*sin(@p2b))-2*(@p1b+0.45-1.35i)*j2^2
elseif @v3=="Oblique Conchoid"
c2=(h2*j2*cos(@p1b+0.75+0.8i)-(j2^2+@p2b*j2-(@p3b+0.2+0.75i)^2)*sin(@p1b+0.75+0.8i))^2\
-(h2*sin(@p1b+0.75+0.8i)+j2*cos(@p1b+0.75+0.8i)+@p2b*cos(@p1b+0.75+0.8i))^2*((@p3b+0.2+0.75i)^2-j2^2)
elseif @v3=="Oblique Estrofoide"
c2=h2*(h2^2+j2^2)-(@p1b-4.25+0.9i)*((h2^2-j2^2)*sin(@p2b)+2*h2*j2*cos(@p2b))
elseif @v3=="Oblique Pancappa"
c2=(j2-(@p1b+1.3-0.2i))^2*(h2^2+j2^2)-((@p2b+1.7-0.65i)*h2+@p3b*j2)^2
elseif @v3=="Oblique Parabolic Bifolium"
c2=h2^3-(@p1b-2.55+2.4i)*(h2^2-j2^2)-(@p2b-2.7)*h2*j2
elseif @v3=="Oblique Strophoid"
c2=j2*(h2^2+j2^2)-(@p1b-2.5-1.25i)*(h2^2-j2^2)-2*(@p2b-2)*h2*j2
elseif @v3=="Orthoconchoid"
c2=(j2^2+(@p1b+0.5+1i)*j2-(@p2b-0.5+0.5i)^2)^2-h2^2*((@p2b-0.5+0.5i)^2-j2^2)
elseif @v3=="Oval of Munger"
c2=(h2^2+j2^2)^(2*(@p1b-1.22+0.08i)+1)-2*@p2b*h2^(2*(@p1b-1.22+0.08i)+1)*(h2^2+j2^2)^(@p1b-1.22+0.08i)\
+(@p2b^2-@p3b^2)*h2^(4*(@p1b-1.22+0.08i))*@p4b\
-2*@p2b*@p4b*cos(@p5b)^(2*(@p1b-1.22+0.08i)+1)+(@p2b^2-@p3b^2)*cos(@p5b)^(4*(@p1b-1.22+0.08i))
elseif @v3=="Parabola"
c2=h2-(@p1b-1.1-0.2i)*(j2-@p2b)^2-@p3b
elseif @v3=="Parabolic Trifolium"
c2=h2^2*(h2^2+j2^2)-(@p1b+3.5-2.7i)*j2*(h2^2-j2^2)
elseif @v3=="Pear-Shaped Quartic"
c2=@p2b^2*j2^2-h2^3*((@p1b-2.9-0.1i)-h2)
elseif @v3=="Pearl of the Fourth Order"
c2=(@p1b-1.4-0.55i)*j2^3-j2^4-(@p1b-1.4-0.55i)^2*h2^2
elseif @v3=="Pearl of the Fourth Order 2"
c2=(@p1b-0.5+2.5i)*j2^3-j2^4-h2^4
elseif @v3=="Pearls of Sluze"
c2=j2^(@p2b+1.85-0.15i)-(@p3b-4.3+3.5i)*(@p1b-h2)^@p4b*h2^@p5b
elseif @v3=="Polyod of Circle"
c2=(h2^2+j2^2)*((h2^2+j2^2)/(2*(@p1b+0.35+2.4i))-h2)^2+4*@p2b^4\
-4*@p2b^2*(h2^2+j2^2)+2*@p2b*h2*(h2^2+j2^2)/(@p1b+0.35+2.4i)
elseif @v3=="Polyod of Straight Line Parallel to Polar Axis"
c2=j2^2*(h2^2+j2^2-(@p1b-2.35+0.45i)^2)-(h2^2+j2^2-(@p1b-2.35+0.45i)*h2-2*(@p2b-0.75+0.45i)^2)^2
elseif @v3=="Polyod of Straight Line Parallel to Polar Axis 2"
c2=(h2^2+j2^2)*(((@p1b-1.8-0.35i)-j2)^2-4*@p2b^2)\
+4*(@p1b-1.8-0.35i)*@p2b^2*j2+4*@p2b^2
elseif @v3=="Popcorn"
c2=h2-@p1b*sin(j2+tan((@p2b-1+1i)*j2))+flip(j2-@p1b*sin(h2+tan((@p2b-1+1i)*h2)))
elseif @v3=="Quadrifolium"
c2=(h2^2+j2^2)^3-4*(@p1b+0.8-0.15i)^2*h2^2*j2^2
elseif @v3=="Regular Trifolium"
c2=(h2^2+j2^2)^2-(@p1b+0.7+0.5i)*h2*(h2^2-3*j2^2)
elseif @v3=="Right Strophoid"
c2=j2^2-h2^2*((@p1b-1.45-0.2i)-h2)/((@p1b-1.45-0.2i)+h2)
elseif @v3=="Salmon Quartic"
c2=(h2^2-(@p1b-0.55)^2)+(j2^2-(@p1b-0.55)^2)-(@p2b+0.1+0.1i)^4
elseif @v3=="Salmon Quartic 2"
c2=(h2^2-(@p1b+0.3)^2)^2+(j2^2-(@p2b-0.35i)^2)^2-@p3b^4
elseif @v3=="Sand Clock"
c2=@p1b^2*(j2^2-(@p2b-0.55-0.1i)^2)^2-4*(@p2b-0.55-0.1i)^2*h2^2*(j2^2+(@p2b-0.55-0.1i)^2)
elseif @v3=="Scarab"
c2=(h2^2+j2^2)*(h2^2+j2^2+(@p1b+1.45+0.25i)*h2)^2-(@p2b-2.2)^2*(h2^2-j2^2)^2
elseif @v3=="Serpentine Curve"
c2=h2^2*j2+(@p1b-0.3+1.5i)^2*j2-(@p1b-0.3+1.5i)*@p2b*h2
elseif @v3=="Spiric Curve"
c2=(h2^2+j2^2)^2+@p1b*h2^2+(@p2b-2.15-0.85i)*j2^2+2*@p3b*h2+(@p4b-2)
elseif @v3=="Spiric of Perseus"
c2=(h2^2+j2^2)^2-2*@p1b*h2^2-2*(@p2b+0.7-0.15i)*j2^2+(@p3b+0.1+0.7i)
elseif @v3=="Spiric Sections"
c2=(@p3b^2-@p1b^2+(@p2b-0.8+0.15i)^2+h2^2+j2^2)^2-4*@p3b^2*(h2^2+(@p2b-0.8+0.15i)^2)
elseif @v3=="Sprott-Elhadj Attractor"
c2=(@p1b+3.8-1.1i)*h2/(1+j2^2)+flip(h2+(@p2b+0.8-0.95i)*j2)
elseif @v3=="Stommel Thermohaline Attractor"
c2=@p1b-h2-h2*(h2-j2)+flip((@p2b-1.7-0.45i)-(@p3b-1.85+0.9i)*j2-j2*(h2-j2))
elseif @v3=="Stommel Thermohaline Attractor 2"
c2=(@p1b+0.85+0.5i)*(1-h2)-@p2b*h2*cabs(j2-@p3b*h2)+flip(1-j2-@p2b*j2*cabs(j2-@p3b*h2))
elseif @v3=="Tetracuspid"
c2=(@p1b+1.55+0.55i)^@p2b*(cabs(h2)^@p2b+cabs(j2)^@p2b)-(h2^2+j2^2)^@p2b
elseif @v3=="Toric Section"
c2=(h2^2+j2^2)^2+(@p1b-3.5-0.5i)*h2^2+@p2b*j2^2+@p3b*h2+@p4b*j2+(@p5b-1)
elseif @v3=="Torpedo Curve"
c2=(h2^2+j2^2)^2-(@p1b-2.6-0.35i)*h2*(h2^2-j2^2)
elseif @v3=="Trisectrix of Delange"
c2=(h2^2+j2^2-2*(@p1b+0.2-0.235i)^2)^2-h2^2*(h2^2+j2^2)
elseif @v3=="Trisectrix of Maclaurin"
c2=j2^2*((@p1b+0.5i)+h2)-h2^2*(3*(@p1b+0.5i)-h2)
elseif @v3=="Tschirnhaus' Cubic"
c2=3*(@p1b-4.25+0.35i)*j2^2-h2*(h2-(@p1b-4.25+0.35i))^2
elseif @v3=="Van der Pol Attractor"
c2=(@p1b-1.9+0.5i)*(h2-h2^3/3-j2)+flip(h2/@p1b)
elseif @v3=="Van der Pol Attractor 2"
c2=j2+flip((@p1b-1.6+0.2i)*(1-h2^2)*j2-h2)
elseif @v3=="Virtual Parabola"
c2=j2-((@p1b+1)*h2+@p2b)^(1/2)-((@p3b-1.85-2.9i)*h2+@p4b)^(1/2)
elseif @v3=="Viviani's Curve"
c2=j2^2-h2^2*((@p1b-2.7-3.25i)^2-h2^2)
elseif @v3=="Volterra-Lotka Attractor"
c2=@p1b*h2-(@p2b-1.45+0.6i)*h2*j2+flip(-(@p3b-1.4+0.35i)*j2+@p4b*h2*j2)
elseif @v3=="Volterra-Lotka Attractor 2"
c2=@p1b*h2*(1-h2-(@p2b-0.8)*j2)+flip(@p3b*j2*(1-j2-@p4b*h2))
elseif @v3=="Wassenaar Curve"
c2=1-(@p1b-1+1i)*h2^2-(j2-h2)^2
elseif @v3=="Zaslavsky Attractor"
c2=(h2+(@p1b+1.08-1.65i)*sin(j2))*cos(2*pi/(@p2b+3.6-1.4i))+j2*sin(2*pi/(@p2b+3.6-1.4i))\
+flip(-(h2+(@p1b+1.08-1.65i)*sin(j2))*sin(2*pi/(@p2b+3.6-1.4i))+j2*cos(2*pi/(@p2b+3.6-1.4i)))
endif
c2=c2+@app*@apf(pixel)
if @v2b=="1"
d2=sqr(real(c2))+sqr(imag(c2))
elseif @v2b=="2"
d2=sqr(abs(real(c2))+abs(imag(c2)))
elseif @v2b=="3"
d2=sqrt((real(c2))^4+(imag(c2))^4)
endif
float t=1/(d2+1)
float q=2*real(c2)*t
float r=2*imag(c2)*t
float s=(d2-1)*t
if isInf(d2) || isNaN(d2)
q=0.0
r=0.0
s=1.0
endif
if i2>0
b2=(q-k2)^2+(r-m)^2+(s-n)^2
a2=a2+b2
endif
i2=i2+1
k2=q
m=r
n=s
if @hb==true
if b2>p
p=b2
endif
endif
endif
endfunc
float func ResultIndex(complex pz)
if @version==100
if @solid
if @invert
if a<=@sca
index=@adj*a/(i-1)
else
m_Solid=true
endif
else
if a>@sca
index=@adj*a/(i-1)
else
m_Solid=true
endif
endif
else
index=@adj*a/(i-1)
endif
return index
else
if @hb==true
a2=4*a2/(1+p)
endif
a2=asinh(a2)
index2=a2
return index2
endif
endfunc

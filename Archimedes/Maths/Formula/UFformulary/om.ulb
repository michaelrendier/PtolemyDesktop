private:
complex pk
complex pzold
complex pkold
complex func Iterate(complex pz)
ConvergentFormula.Iterate(pz)
pzold=pz
pkold=pk
pz=@zp1*pz+@zp2
pk=@kp1*pk+@kp2
a=pk
pk=@bp1*pk^2*pz+@bp2
if @bv==0
pz=pz-@sp1*(pz^@pow1-@sp2)/(@pow1*pz^(@pow1-1))+pk-@sp3*(a^@pow2-@sp4)/(@pow2*a^(@pow2-1))

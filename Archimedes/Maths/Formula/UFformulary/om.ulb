}

class OM_AttraktorTraps3(common.ulb:GradientColoring) {
public:
func Init(complex pz, complex ppixel)
GradientColoring.Init(pz, ppixel)
a=0.0
i=0
b=0.0
b2=0.0
endfunc
func Iterate(complex pz)
GradientColoring.Iterate(pz)
i=i+1
if @S==true
if i>=0 && i<=1E20
pz=(abs(fn2(fn1(pz)))-@center)/@p5
float x=sqrt(@p6)*real(pz)
float y=1/sqrt(@p6)*imag(pz)
if @V=="Bedhead"
b=log(cabs(sin(x*y/(2*@p2))*y+cos(@p1*x-y)+flip(x+sin(y)/(2*@p2))))
elseif @V=="Bogdanov"
if @version==100
b=log(cabs(flip(y+@p1*y+@p2*x*(x-1)+@p3*x*y)+x+y+@p1*y+@p2*x*(x-1)+@p3*x*y))
else
b=log(cabs(flip(y+@p1*y-@p2*x*(x-1)-@p3*x*y)+x+y+@p1*y-@p2*x*(x-1)-@p3*x*y))
endif
elseif @V=="Bogdanov-Takens"
b=log(cabs(y+flip(@p1+@p2*x+x^2-x*y)))
elseif @V=="Borrelli"
b=log(cabs(real(pz)-imag(pz)-@p1*real(pz)*(real(pz)^2+imag(pz)^2)+@p2+flip(real(pz)+imag(pz)-(-@p3)*imag(pz)*(real(pz)^2+imag(pz)^2)+@p4)))
elseif @V=="Brusselator"
b=log(cabs((1-(@p1+1)*x+y*x^2)/@p2+flip((@p1*x-y*x^2)/@p3)))
elseif @V=="Buckling Column Model"
b=log(cabs(y+flip(-(@p1*x^3+@p2*x+@p3*y)/@p4)))
elseif @V=="Burgers"
b=log(cabs(@p1*x-y^2+flip(@p2*y+x*y)))
elseif @V=="Business Cycle"
b=log(cabs(x+y+flip(@p1*y-(@p1+1)*y^3-@p2*x)))
elseif @V=="Cao-Lai"
b=log(cabs(@p1*x*(1-x)+flip(@p2*x*sin(2*pi*y)/(2*pi))))
elseif @V=="Cat"
b=log(cabs((2*x+y)%1+flip((x+y)%1)))
elseif @V=="Cathala"
b=log(cabs(@p1*x+y+flip(@p2/2+x^2)))
elseif @V=="Cathala 2"
b=log(cabs((1-2*@p1)*x+y+flip(2*@p1*@p2*x+@p3*y-2*@p1*x^3)))
elseif @V=="Chip"
if @version==100
b=log(cabs(y-(x/cabs(x))*cos(sqr(log(abs(@p2*x-@p3))))*atan(sqr(log(abs(@p3*x-@p2))))+flip(@p1-x)))
else
b=log(cabs(y-(x/cabs(x))*cos(sqr(log(abs(@p2*x-(@p3-1+0.75i)))))*atan(sqr(log(abs((@p3-1+0.75i)*x-@p2))))+flip(@p1-x)))
endif
elseif @V=="Chirikov Mod"
if @version==100
b=log(cabs(x+y+((@p1-0.75-0.2i)/2*pi)*sin(2*pi*x)+flip(y+(@p1/2*pi)*sin(2*pi*x))))
else
b=log(cabs(x+y+(@p1/2*pi)*sin(2*pi*x)+flip(y+((@p1-0.75-0.2i)/2*pi)*sin(2*pi*x))))
endif
elseif @V=="Coupled Logistic"
b=log(cabs((1-@p1)*@p2*x*(1-x)+@p1*@p2*y*(1-y)+flip((1-@p1)*@p2*y*(1-y)+@p1*@p2*x*(1-x))))
elseif @V=="Cross Chaotic"
b=log(cabs(1-(@p1+1i)*y^2+flip(cos(@p2*acos(x)))))
elseif @V=="Damped Pendulum"
b=log(cabs(y+flip(-@p1*sin(x)-@p2*y)))
elseif @V=="de Jong"
if @version==100
b=log(cabs(sin(@p1*y)-cos(@p2*x)+flip(sin(@p3*x)-cos(@p4*y))))
else
b=log(cabs(sin((@p1-1+1i)*y)-cos(@p2*x)+flip(sin((@p3-1+1i)*x)-cos(@p4*y))))
endif
elseif @V=="Duffing"
b=log(cabs(y+flip(-@p2*x+@p1*y-y^3)))
elseif @V=="Duffing 2"
b=log(cabs(y+flip(-@p1*y+(1+@p2*(@p3*cos(@p4)+cos(@p7)))*x-x^3+@p9)))
elseif @V=="Duffing 3"
b=log(cabs(y+flip(-@p1*x-@p2*x^3+@p3)))
elseif @V=="Duffing 4"
b=log(cabs(imag(pz)+flip(-@p1*x-((@p2-@p1)/2)*(cabs(x+1)-cabs(x-1))-@p3*y+@p4)))
elseif @V=="Duffing Parametric"
b=log(cabs(y+flip(-x-x^3+(@p1+@p2*x^2+@p3*@p4*x)*y+@p4*@p7)))
elseif @v=="Duffing Quintic 1"
b=log(cabs(y+flip(@p1*x-@p2*x^3-@p3*x^5+(@p4-1+1i))))
elseif @v=="Duffing Quintic 2"
b=log(cabs(y+flip(-@p1*x-@p2*x^3-@p3*x^5+(@p4-1+1i)*(@p7*(1-x^2)*y-@p9))))
elseif @v=="Duffing Septic"
b=log(cabs(y+flip(-@p1*x+@p2*x^3-@p3*x^5-@p4*x^7-@p7)))
elseif @V=="Fitzhugh-Nagumo 1"
b=log(cabs(-@p1*x*(x-@p2)*(1-x)-y+@p3+flip(@p4*(x-y))))
elseif @V=="Fitzhugh-Nagumo 2"
b=log(cabs(x-x^3/3-y-@p1+flip(@p2*(x-@p3*y-@p4))))
elseif @V=="Garrote-Mira"
b=log(cabs(y+@p1*(1-0.05*y^2)+@p2*x+2*(1-@p2)*x^2/(1+x^2)\
+flip(-x+@p2*(y+@p1*(1-0.05*y^2)+@p2*x+2*(1-@p2)*x^2/(1+x^2))\
+2*(1-@p2)*(y+@p1*(1-0.05*y^2)+@p2*x+2*(1-@p2)*x^2/(1+x^2))\
^2/(1+(y+@p1*(1-0.05*y^2)+@p2*x+2*(1-@p2)*x^2/(1+x^2))^2))))
elseif @V=="Ghost"
if @version==100
b=log(cabs(sin(@p1*y)-@p2*x+flip(@p3*x-cos(@p4*y))))
else
b=log(cabs(sin(@p1*y)-@p2*x+flip(@p3*x-cos((@p4-1+1i)*y))))
endif
elseif @V=="Gingerbread"
b=log(cabs(1-y+cabs(x)+flip(x)))
elseif @V=="Gumowski-Mira"
if @version==100
b=log(cabs(y+@p1*x+2*(1-@p1)*x^2/(1+x^2)+@p2*(1-@p3*y^2)*y+ \
flip(-x+@p1*(y+@p1*x+2*(1-@p1)*x^2/(1+x^2)+@p2*(1-@p3*y^2)*y) \
+2*(1-@p1)*(y+@p1*x+2*(1-@p1)*x^2/(1+x^2)+ \
@p2*(1-@p3*y^2)*y)^2/(1+(y+@p1*x+2*(1-@p1)*x^2/(1+x^2)+@p2*(1-@p3*y^2)*y)^2))))
else
b=log(cabs(y+@p1*x+2*(1-@p1)*x^2/(1+x^2)-@p2*(1-@p3*y^2)*y+ \
flip(-x+@p1*(y+@p1*x+2*(1-@p1)*x^2/(1+x^2)-@p2*(1-@p3*y^2)*y) \
+2*(1-@p1)*(y+@p1*x+2*(1-@p1)*x^2/(1+x^2)+ \
@p2*(1-@p3*y^2)*y)^2/(1+(y+@p1*x+2*(1-@p1)*x^2/(1+x^2)-@p2*(1-@p3*y^2)*y)^2))))
endif
elseif @V=="Gumowski-Mira 2"
if @version==100
b=log(cabs(y+@p1*(1-@p2*y^2)*y+@p3*x+2*(1-@p3)*x^2/(1+x^2)+flip \
(-x+@p3*(y+@p1*(1-@p2*y^2)*y+@p3*x+2*(1-@p3)*x^2/(1+x^2)) \
+2*(1-@p3)*(y+ @p1*(1-@p2*y^2)*y+@p3*x+2*(1-@p3)*x^2/(1+x^2))^2 \
/(1+(y+@p1*(1-@p2*y^2)*y+@p3*x+2*(1-@p3)*x^2/(1+x^2))^2))))
else
b=log(cabs(y-@p1*(1+@p2*y^2)*y+@p3*x+2*(1-@p3)*x^2/(1+x^2)+flip \
(-x+@p3*(y-@p1*(1+@p2*y^2)*y+@p3*x+2*(1-@p3)*x^2/(1+x^2)) \
+2*(1-@p3)*(y-@p1*(1+@p2*y^2)*y+@p3*x+2*(1-@p3)*x^2/(1+x^2))^2 \
/(1+(y-@p1*(1+@p2*y^2)*y+@p3*x+2*(1-@p3)*x^2/(1+x^2))^2))))
endif
elseif @V=="Gumowski-Mira 3"
k=y+(@p1-0.5+1i)*x+2*(1-(@p1-0.5+1i))*x^2*exp((1-x^2)/4)
b=log(cabs(y+(@p1-0.5+1i)*x+2*(1-(@p1-0.5+1i))*x^2*exp((1-x^2)/4)+flip(-k+(@p1-0.5+1i)*x+2*(1-(@p1-0.5+1i))*x^2*exp((1-x^2)/4))))
elseif @V=="Gumowski-Mira 4"
k=y+(@p2-1.5-3i)*y*(1-(@p2-1.5-3i)*y^2)+(@p1+1.5+0.25i)*x+2*(1-(@p1+1.5+0.25i))*x^2/(1-x^2)
b=log(cabs(y+(@p2-1.5-3i)*y*(1-(@p2-1.5-3i)*y^2)+(@p1+1.5+0.25i)*x+2*(1-(@p1+1.5+0.25i))*x^2/(1-x^2)+flip(-k+(@p1+1.5+0.25i)*x+2*(1-(@p1+1.5+0.25i))*x^2/(1-x^2))))
elseif @V=="Gumowski-Mira 5"
k=y+(@p2-1.4+0.15i)*y*(1-(@p2-1.4+0.15i)*y^2)+(@p1-1+1i)*x+2*(1-(@p1-1+1i))*x^2*exp((1-x^2)/4)
b=log(cabs(y+(@p2-1.4+0.15i)*y*(1-(@p2-1.4+0.15i)*y^2)+(@p1-1+1i)*x+2*(1-(@p1-1+1i))*x^2*exp((1-x^2)/4)+flip(-k+(@p1-1+1i)*x+2*(1-(@p1-1+1i))*x^2*exp((1-x^2)/4))))
elseif @V=="Gumowski-Mira 6"
b=log(cabs(@p1*(x*cos(@p2)-y*sin(@p2))+x*y+flip(@p1*(x*sin(@p2)+y*cos(@p2))+x^2+y^3)))
elseif @V=="Gumowski-Mira Mod"
b=log(cabs((1-@p1)*x+y+flip(y+@p2*x+2*(1-@p2)*x^2*(1+x^2)^(-2))))
elseif @V=="Gumowski-Mira Mod 2"
b=log(cabs((@p2-0.4+1.7i)*y+(@p1-0.05+0.4i)*x+2*(1-(@p1-0.05+0.4i))*x^2/(1+x^2)\
+flip(-x+(@p1-0.05+0.4i)*((@p2-0.4+1.7i)*y+(@p1-0.05+0.4i)*x+2*(1-(@p1-0.05+0.4i))*x^2/(1+x^2))\
+2*(1-(@p1-0.05+0.4i))*((@p2-0.4+1.7i)*y+(@p1-0.05+0.4i)*x+2*(1-(@p1-0.05+0.4i))*x^2/(1+((@p2-0.4+1.7i)*y\
+(@p1-0.05+0.4i)*x+2*(1-(@p1-0.05+0.4i))*x^2/(1+x^2))^2))^2/(1+x^2))))
elseif @V=="Hamilton"
if @version==100
b=log(cabs(x+@p1*@p2*sin(2*pi*y)+flip(y-(@p1/@p2)*sin(2*pi*(x+@p1*@p2*sin(2*pi*y))))))
else
b=log(cabs(x+(@p1-0.75-0.1i)*@p2*sin(2*pi*y)+flip(y-((@p1-0.75-0.1i)/@p2)*sin(2*pi*(x+(@p1-0.75-0.1i)*@p2*sin(2*pi*y))))))
endif
elseif @V=="Hamilton Torus"
b=log(cabs(-sin(imag(pz))*(2-@p1)+flip(sin(real(pz))*@p1)))
elseif @V=="HCA"
if @version==100
b=log(cabs(1-@p1*x^2+@p2*(y^2-x^2)+flip(1-@p1*y^2+@p2*(x^2-y^2))))
else
b=log(cabs(1-@p1*x^2+(@p2-1+1i)*(y^2-x^2)+flip(1-@p1*y^2+(@p2-1+1i)*(x^2-y^2))))
endif
elseif @V=="Henon"
b=log(cabs(1-@p1*x^2+y+flip(@p2*x)))
elseif @V=="Henon 2"
b=log(cabs(-(y-real(pz)^2)*sin(2*pi/(@p1+(0,0.1)))+x*cos(2*pi/(@p1+(0,0.1)))+flip((y-real(pz)^2)*cos(2*pi/(@p1+(0,0.1)))+x*sin(2*pi/(@p1+(0,0.1))))))
elseif @V=="Henon 3"
b=log(cabs(y+flip(-@p2^(-1)*(1-@p1*y^2-@p2*x))))
elseif @V=="Henon 4"
b=log(cabs(exp(-@p1*@p2/2)*(x*cos(@p2*@p3)+(1/@p3)*(y-(@p4+x^2)+@p1*x/2)*sin(@p2*@p3))+flip(exp(-@p1*@p2/2)*(-@p3*x*sin(@p2*@p3)+(y-(@p4+x^2)+@p1*x/2)*cos(@p2*@p3))-@p1*x/2)))
elseif @V=="Henon 5"
b=log(cabs(y+(@p1+1)*cos(pi*x/2)-1+flip((@p2-0.5)*x)))
elseif @v=="Henon Dual"
b=log(cabs((@p1-1+1i)*x-@p2*y+@p3*x^3+flip(x)))
elseif @V=="Henon-Heiles 1"
b=log(cabs(-@p1*x-@p2*x*y+flip(-@p3*y-@p4*x^2+@p7*y^2)))
elseif @V=="Henon-Heiles 2"
b=log(cabs(y+flip(-@p1*x-@p2*x^2+@p3)))
elseif @V=="Hopalong"
b=log(cabs(y-(x/cabs(x))*sqrt(cabs(@p2*x-@p3))+flip(@p1-x)))
elseif @V=="Horsthemke-Lefever"
b=log(cabs(@p1*x*(1-x/@p3)-@p2*x*y+flip(-@p2*x*y+@p4*(@p7-y))))
elseif @V=="Ikeda"
b=log(cabs(@p1+@p2*(x*cos(@p3-@p4/(x^2+y^2+1))-y*sin(@p3-@p4/(x^2+y^2+1))) \
+flip(@p2*(x*sin(@p3-@p4/(x^2+y^2+1))+y*cos(@p3-@p4/(x^2+y^2+1))))))
elseif @V=="Ilhem-Amel"
b=log(cabs(x^3+@p1*x+@p2+y+flip(@p3*x)))
elseif @V=="Ilhem-Amel 2"
b=log(cabs((@p4-0.5)*x^3+@p1*x+@p2/2+@p7*y+flip(@p3*x+@p9*y)))
elseif @v=="Jiang"
b=log(cabs(y+flip(x+@p1*x^2+@p2*y^2-@p3*x*y-@p4)))
elseif @v=="Jiang-Liu-Wei-Zhang"
b=log(cabs(y+flip(@p1*x+@p2*y+@p3*x^2+@p4*y^2+@p7*x*y+@p9)))
elseif @V=="Kam Torus"
b=log(cabs(x*cos(@p1)+(x^2-y)*sin(@p1)+flip(x*sin(@p1)-(x^2-y)*cos(@p1))))
elseif @V=="Kaplan-Yorke"
b=log(cabs(real(@p1)*x%1+flip(-@p2*y+cos(2*pi*x))))
elseif @V=="Khovanov-Luchinsky"
b=log(cabs(y+flip(-@p1*x+@p2*y-y^3+@p3)))
elseif @v=="Knot"
b=log(cabs(-y+flip(x^4-y)))
elseif @V=="Kolmogorov-Volterra"
b=log(cabs((x*(@p1-x^2)-@p2*x*y)/(1+x^2)+flip((@p3*x^2-1)*y/(1+x^2))))
elseif @V=="Latoocarfian"
if @version==100
b=log(cabs(sin(@p1*y)+@p2*sin(@p1*x)+flip(sin(@p3*x)+@p4*sin(@p3*y))))
else
b=log(cabs(sin(@p1*y)+@p2*sin(@p1*x)+flip(sin((@p3-1+1i)*x)+(@p4-1+1i)*sin((@p3-1+1i)*y))))
endif
elseif @V=="Limit Cycle"
b=log(cabs(x-y-@p1*x*(x^2+y^2)+(@p3-1.25)+flip(x+y-@p2*y*(x^2+y^2)+@p4)))
elseif @V=="Lozi"
b=log(cabs(1+y-@p1*cabs(x)+flip(@p2*x)))
elseif @V=="MacMillan"
b=log(cabs(y+flip(-x-2*@p1*y/(1-y^2)+@p2*y)))
elseif @V=="Marotto-Lorenz"
b=log(cabs((1-@p1*x-@p2*y)*(@p1*x+@p2*y)+flip(x)))
elseif @V=="Martin"
b=log(cabs(y+sin(x)+flip(@p1-x)))
elseif @V=="Maynard Smith"
b=log(cabs(y+flip(-@p1*y+@p2-x^2)))
elseif @V=="Mira"
b=log(cabs(@p2*y+@p1*x+2*(1-@p1)*x^2/(1+x^2)\
+flip(-x+@p1*(@p2*y+@p1*x+2*(1-@p1)*x^2/(1+x^2))\
+2*(1-@p1)*(@p2*y+@p1*x+2*(1-@p1)*x^2/(1+(@p2*y\
+@p1*x+2*(1-@p1)*x^2/(1+x^2))^2))^2/(1+x^2))))
elseif @V=="Mira 2"
b=log(cabs(x^2-y^2+@p1*x+@p2+flip(2*x*y-5*@p1*y/2)))
elseif @V=="Mira 3"
b=log(cabs((1-@p1)*x+y+flip(@p1*@p2*x+@p3*y-@p1*x^3)))
elseif @V=="Mira 4"
b=log(cabs((@p1-1+1i)*x+y+flip((@p2-1+1i)+x^2)))
elseif @V=="Modified Lozi"
b=log(cabs(1+@p1*(cabs(x)-y^2)+y+flip(@p2*x)))
elseif @V=="Nowicki-Swirszcz"
if @version==100
b=log(cabs(3*x*((x-y)^2-@p1)/((3*x-y)^2-@p2)+flip(y*(y^2+2*x*y-3*x^2-@p3)/((3*x-y)^2-@p4))))
else
b=log(cabs(3*x*((x-y)^2+@p1)/((3*x-y)^2-@p2)+flip(y*(y^2+2*x*y-3*x^2-@p3)/((3*x-y)^2-@p4))))
endif
elseif @V=="Multifold Henon"
b=log(cabs(1-@p1*sin(x)+@p2*y+flip(x)))
elseif @V=="Oscillating Chemical Reaction"
b=log(cabs((@p1-x-4*x*y)/(1+x^2)+flip(@p2*x*(1-y)/(1+x^2))))
elseif @V=="Pendulum"
b=log(cabs(y+flip(-sin(x)+(@p1+1i))))
elseif @V=="Pendulum Morozov"
b=log(cabs(y+flip(-sin(x)+y*((@p1-1-1i)+@p2*cos(@p3*x))*(-@p4))))
elseif @V=="Pharaoh"
b=log(cabs(-y-@p1*cos(x)*sin(1-x^2-y^2)+(@p3-1+0.5i)+flip(x+(@p2-1+0.5i)*cos(y)*sin(1-x^2-y^2)+@p4)))
elseif @V=="Pickover 1"
if @version==100
b=log(cabs(sin(@p1*y)+@p3*cos(@p1*x)+flip(sin(@p2*x)+@p4*cos(@p2*y))))
else
b=log(cabs(sin(@p1*y)+@p3*cos(@p1*x)+flip(sin((@p2-1+1i)*x)+(@p4-1+1i)*cos((@p2-1+1i)*y))))
endif
elseif @V=="Pickover 2"
if @version==100
b=log(cabs(sin(@p1*y)+(sin(@p1*x))^2+(sin(@p1*x))^3+flip(sin(@p2*x)+(sin(@p2*y))^2+(sin(@p3*y))^3)))
else
b=log(cabs(sin((@p1-1+1i)*y)+(sin((@p1-1+1i)*x))^2+(sin((@p1-1+1i)*x))^3+flip(sin(@p2*x)+(sin(@p2*y))^2+(sin(@p3*y))^3)))
endif
elseif @V=="Pickover 3"
if @version==100
b=log(cabs(sin(@p1*y)+(sin(@p1*x))^2+flip(sin(@p2*x)+(sin(@p2*y))^2)))
else
b=log(cabs(sin(@p1*y)+(sin(@p1*x))^2+flip(sin((@p2-1+1i)*x)+(sin((@p2-1+1i)*y))^2)))
endif
elseif @V=="Pickover 4"
if @version==100
b=log(cabs(cabs(sin(@p1*y))+(sin(@p1*x))^2+flip(cabs(sin(@p2*x))+(sin(@p2*y))^2)))
else
b=log(cabs(cabs(sin(@p1*y))+(sin(@p1*x))^2+flip(cabs(sin((@p2-1+1i)*x))+(sin((@p2-1+1i)*y))^2)))
endif
elseif @V=="Polyharmonic Pendulum"
b=log(cabs(y+flip(-@p1*sin(x)-@p2*sin(3*x)+@p3*sin(@p4))))
elseif @V=="Popcorn"
if @version==100
b=log(cabs(@p1*sin(y+tan(@p2*y))+flip(@p1*sin(x+tan(@p2*x)))))
else
b=log(cabs(@p1*sin(y+tan((@p2-1+1i)*y))+flip(@p1*sin(x+tan((@p2-1+1i)*x)))))
endif
elseif @V=="Popcorn 2"
if @version==100
b=log(cabs(x-@p1*sin(y+tan(@p2*y))+flip(y-@p1*sin(x+tan(@p2*x)))))
else
b=log(cabs(x-@p1*sin(y+tan((@p2-1+1i)*y))+flip(y-@p1*sin(x+tan((@p2-1+1i)*x)))))
endif
elseif @V=="Provenzale-Balmforth"
b=log(cabs((@p1*y+(@p2-1+1i))*x*(1-x)+flip(4*y*(1-y))))
elseif @V=="Quadruptwo"
if @version==100
b=log(cabs(y-(x/cabs(x))*sin(log(abs(@p2*x-@p3)))*atan(sqr(log(abs(@p3*x-@p2))))+flip(@p1-x)))
else
b=log(cabs(y-(x/cabs(x))*sin(log(abs(@p2*x-(@p3-1+1i))))*atan(sqr(log(abs((@p3-1+1i)*x-@p2))))+flip((@p1-1+1i)-x)))
endif
elseif @V=="Rayleigh"
b=log(cabs(y+flip(-(x+@p2*y^3-@p1*y)/@p3)))
elseif @v=="Rulkov"
b=log(cabs(@p1/(1+x^2)+y+flip(y-@p2*x-@p3)))
elseif @V=="Sine"
b=log(cabs(y+flip(@p1*sin(x)+@p2*y)))
elseif @V=="Sine-Sine"
b=log(cabs(sin(x)-sin(2*y)+flip(x)))
elseif @V=="Sprott"
b=log(cabs((1+@p1*@p2)*x-@p2*x*y+flip((1-@p2)*y+@p2*x^2)))
elseif @V=="Sprott-Elhadj"
b=log(cabs(@p1*x/(1+y^2)+flip(x+@p2*y)))
elseif @V=="Standard Map"
b=log(cabs(x+@p1*sin(y)+flip(y+x+@p1*sin(y))))
elseif @V=="Stommel Thermohaline 1"
b=log(cabs((@p1-1i)-x-x*(x-y)+flip(@p2-(@p3-1+1i)*y-y*(x-y))))
elseif @V=="Stommel Thermohaline 2"
b=log(cabs((@p1-1i)*(1-x)-@p2*x*cabs(y-@p3*x)+flip(1-y-@p2*y*cabs(y-@p3*x))))
elseif @V=="Strelkova-Anishchenko"
b=log(cabs(1-@p1*x^2+@p2*(y-x)+flip(1-@p1*y^2+@p2*(x-y))))
elseif @V=="Svensson"
if @version==100
b=log(cabs(@p4*sin(@p1*x)-sin(@p2*y)+flip(@p3*cos(@p1*x)+cos(@p2*y))))
else
b=log(cabs((@p4-1+0.5i)*sin(@p1*x)-sin(@p2*y)+flip((@p3+1.25)*cos(@p1*x)+cos(@p2*y))))
endif
elseif @V=="Tartan"
b=log(cabs(-(@p1-0.65-0.5i)*y-(@p2-0.25)+flip(@p3-x^2)))
elseif @V=="Threeply"
if @version==100
b=log(cabs(y-(x/cabs(x))*(abs(sin(x)*cos(@p2)+@p3-x*sin(@p1+@p2+@p3)))+flip(@p1-x)))
else
b=log(cabs(y-(x/cabs(x))*(abs(sin(x)*cos(@p2)+(@p3-1+1i)-x*sin((@p1-1+1i)+@p2+(@p3-1+1i))))+flip((@p1-1+1i)-x)))
endif

fpixel=pz
a=(0,0)
if @jm==0
pz=@sf(pz)
pk=pz
else
pz=@sp
pk=pz
endif
return pz
return pk
endfunc
private:
complex fpixel
complex a
complex pk
complex func Iterate(complex pz)
a=pk
pk=@bp1*@bf(pk/pz)+@bp2
if @v==0
if @jm==0
pz=(@p2*(pz^3-@p3*@p1*pz^2))/(pz+@p1/@p3)+(@p2*(a^3-@p3*@p1*a^2))/(a+@p1/@p3)+@c
else
pz=(@p2*(pz^3-@p3*@p1*pz^2))/(pz+@p1/@p3)+(@p2*(a^3-@p3*@p1*a^2))/(a+@p1/@p3)+@pf(fpixel)
endif
else
if @jm==0
pz=(@p2*(pz^3-@p3*@p1*pz^2))/(pz+@p1/@p3)+(@p2*(pk^3-@p3*@p1*pk^2))/(pk+@p1/@p3)+@c
else
pz=(@p2*(pz^3-(@p3-1.15)*@p1*pz^2))/(pz+@p1/(@p3-1.15))+(@p2*(pk^3-(@p3-1.15)*@p1*pk^2))/(pk+@p1/(@p3-1.15))+@pf(fpixel)
endif
endif
return pz
return pk
endfunc

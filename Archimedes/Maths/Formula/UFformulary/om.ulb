elseif @jm==1
pz=exp(@p1*1i)*c*((pz^2-1)/pz)^2*(pz-@p2)/(1-@p2*pz)
else
pz=exp(@p1*1i)*((pz^2-1)/pz)^2*(pz-@p2)/(1-@p2*pz)+c
endif

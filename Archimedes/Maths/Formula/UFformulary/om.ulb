pz=recip(pz)
elseif @m==13
pz=pz^2*(pz-5)/(1-5*pz)
pz=flip(conj(pz))
else
pz=pz^2*(pz+3)/(1+3*pz)
pz=flip(recip(pz))
endif
pz=@zp1*pz+@zp2
if i<1
pz=exp(@mp4*1i)*pz^2*(pz-@mp1)/(1-@mp1*pz)
elseif i>0 && i<@mem
pz=exp(@mp5*1i)*pz^2*(pz-@mp2)/(1-@mp2*pz)
else
pz=exp(@mp6*1i)*pz^2*(pz-@mp3)/(1-@mp3*pz)
endif
i=i+1
return pz
endfunc

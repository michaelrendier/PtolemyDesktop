class OM_TrivarX13(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
a=(0,0)
fpixel=pz
c=@sf(fpixel)
pw=@sf(pz)
pz=@sp
pk=@sp
return pz
return pk
return pw
endfunc
private:
complex a
complex pk
complex pw
complex c
complex func Iterate(complex pz)
a=pw
if @jm==0
if @v==0
pw=@p1*pw+@p4*sin(pk)+@c
pk=@p2*pk+@p5*sin(pz)
pz=@p3*pz+@p6*sin(pw)
elseif @v==1
pw=@p1*pw+@p4*sin(pk)+@c
pk=@p2*pk+@p5*sin(pz)
pz=@p3*pz+@p6*sin(a)
elseif @v==2
pw=@p1*pw+@p4*cos(pk)+@c+1
pk=@p2*pk+@p5*cos(pz)
pz=@p3*pz+@p6*cos(pw)
else
pw=@p1*pw+@p4*cos(pk)+@c
pk=@p2*pk+@p5*cos(pz)
pz=@p3*pz+@p6*cos(a)
endif
else
if @v==0
pw=@p1*pw+@p4*sin(pk)+c
pk=@p2*pk+@p5*sin(pz)
pz=@p3*pz+@p6*sin(pw)
elseif @v==1
pw=@p1*pw+@p4*sin(pk)+c
pk=@p2*pk+@p5*sin(pz)
pz=@p3*pz+@p6*sin(a)
elseif @v==2
pw=@p1*pw+@p4*cos(pk)+c
pk=@p2*pk+@p5*cos(pz)
pz=@p3*pz+@p6*cos(pw)
else
pw=@p1*pw+@p4*cos(pk)+c
pk=@p2*pk+@p5*cos(pz)
pz=@p3*pz+@p6*cos(a)
endif
endif
return pz
return pk
return pw
endfunc
bool func IsBailedOut(complex pz)
bool bail=false
bail=(|(pz+pk+pw)/3|>@p_bailout)
return bail
endfunc

elseif @v==5
a=(z1*z2*z3-1)^i
b=z2^i
d=(b-a)*(z1*z2-1)/(3*a)
elseif @v==6
a=(z1*z2*z3-1)^i
b=z2^i
d=(a-b)*(z1*z2*z3-1)/(3*a)
else
a=(z1*z2*z3-1)^i
b=z2^i
d=(b-a)*(z1*z2*z3-1)/(3*a)
endif
z1=@p1*fn2(z1+d/z2)+@p2
z2=@p3*fn3(z2+z3*d*z2)+@p4
pz=z1+z2
return pz

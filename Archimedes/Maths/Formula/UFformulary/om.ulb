class OM_KleinGopalsamy(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
ang=pi/3
c1=(1+@fp*1i)*@fn1((0,0))
c2=(1+@fp*1i)*@fn1((1,0))
c3=(1+@fp*1i)*@fn1(exp((0,1)*ang))
c4=(1+@fp*1i)*@fn1(exp((0,2)*ang))
c5=(1+@fp*1i)*@fn1(exp((0,3)*ang))
c6=(1+@fp*1i)*@fn1(exp((0,4)*ang))
c7=(1+@fp*1i)*@fn1(exp((0,5)*ang))
r=0.5
pz=@pf(pz)
i=0
c=@js
return pz
endfunc
private:
complex c1
complex c2
complex c3
complex c4
complex c5
complex c6
complex c7
float r
int i
complex c
complex func Iterate(complex pz)
if @kgv==1
pz=@zp1*flip(pz)+@zp2
elseif @kgv==6
pz=@zp1*flip(pz)+@zp2
elseif @kgv==7
pz=@zp1*conj(pz)+@zp2
else
pz=@zp1*pz+@zp2
endif
if @v=="1"
if i==0
pz=-1i*conj(pz)^@pow+c
if @kgv==5
pz=flip(pz)
elseif @kgv==8
pz=flip(pz)
elseif @kgv==9
pz=flip(pz)
elseif @kgv==10
pz=conj(pz)
endif
i=1
else
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
elseif |pz-c4|<r^2
pz=r*conj(r/(pz-c4))+c4
elseif |pz-c5|<r^2
pz=r*conj(r/(pz-c5))+c5
elseif |pz-c6|<r^2
pz=r*conj(r/(pz-c6))+c6
elseif |pz-c7|<r^2
pz=r*conj(r/(pz-c7))+c7
endif
if @kgv==2
pz=flip(pz)
elseif @kgv==3
pz=conj(pz)
elseif @kgv==4
pz=sqr(pz)
elseif @kgv==6
pz=conj(pz)
elseif @kgv==7
pz=flip(pz)
elseif @kgv==8
pz=conj(pz)
elseif @kgv==9
pz=sqr(pz)
elseif @kgv==10
pz=sqr(pz)
endif
i=0
endif
else
if i==0
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
elseif |pz-c4|<r^2
pz=r*conj(r/(pz-c4))+c4
elseif |pz-c5|<r^2
pz=r*conj(r/(pz-c5))+c5
elseif |pz-c6|<r^2
pz=r*conj(r/(pz-c6))+c6
elseif |pz-c7|<r^2
pz=r*conj(r/(pz-c7))+c7
endif
if @kgv==2
pz=flip(pz)
elseif @kgv==3
pz=conj(pz)
elseif @kgv==4
pz=sqr(pz)
elseif @kgv==6
pz=conj(pz)
elseif @kgv==7
pz=flip(pz)
elseif @kgv==8
pz=conj(pz)
elseif @kgv==9
pz=sqr(pz)
elseif @kgv==10
pz=sqr(pz)
endif
i=1
else
pz=-1i*conj(pz)^@pow+c
if @kgv==5
pz=flip(pz)
elseif @kgv==8
pz=flip(pz)
elseif @kgv==9
pz=flip(pz)
elseif @kgv==10
pz=conj(pz)
endif
i=0
endif
endif

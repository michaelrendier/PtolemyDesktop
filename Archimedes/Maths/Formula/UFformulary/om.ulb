class OM_TrivarX5(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
if @sv==0
pz=@sf(pz)
pk=pz
pw=pz
elseif @sv==1
pz=@sf(pz)
pk=pz
pw=@sp
elseif @sv==2
pk=@sf(pz)
pw=@sf(pz)
pz=@sp
elseif @sv==3
pz=@sf(pz)
pk=@sp
pw=pz
elseif @sv==4
pz=@sf(pz)
pk=@sp
pw=@sp
elseif @sv==5
pk=@sf(pz)
pz=@sp
pw=@sp
else
pw=@sf(pz)
pz=@sp
pk=@sp
endif
return pz
return pk
return pw
endfunc
private:
complex pk
complex pw
complex func Iterate(complex pz)
pw=(pz-@p1)*pw-@p2*pk
pk=@p2*pw+(pz-@p1)*pk
pz=@p3+@p4*pz-pz^3/3-(pw^2+pk^2)*(1+@p5*pz)+@p6*pz*pw^3
return pz
return pk
return pw
endfunc

}

class OM_GeneralisedAgarwalDevaney(common.ulb:DivergentFormula) {
;generalised Agarwal iteration from
;https://www.ncbi.nlm.nih.gov/pmc/articles/PMC7517277/
;(21) {
public:
complex func Init(complex pz)
fpixel=pz
c=@sf(fpixel)
if @jm==0
pz=@sf(pz)
else
pz=@sp
endif
return pz
endfunc
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
pz=pz+@as*sqr(pz)
pz=pz+@ar/pz
if @jm==0
u=(1-@p1)*pz+@p1*(pz^@pow1a+@jsa/(pz-@mpa)^@pow2a)
pz=(1-@p2)*(pz^@pow1b+@jsb/(pz-@mpb)^@pow2b)+@p2*(u^@pow1c+@jsc/(u-@mpc)^@pow2c)
else
u=(1-@p1)*pz+@p1*(pz^@pow1a+@ppa*c/(pz-@mpa)^@pow2a)
pz=(1-@p2)*(pz^@pow1b+@ppb*c/(pz-@mpb)^@pow2b)+@p2*(u^@pow1c+@ppc*c/(u-@mpc)^@pow2c)
endif
return pz
endfunc

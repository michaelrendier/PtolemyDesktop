elseif @F1=="atan"
float b=|atan(pz)|
elseif @F1=="atanh"
float b=|atanh(pz)|
elseif @F1=="cotan"
float b=|cotan(pz)|
elseif @F1=="cotanh"
float b=|cotanh(pz)|
elseif @F1=="acotan"
float b=|atan(1/(pz))|
elseif @F1=="acotanh"
float b=|atanh(1/(pz))|
elseif @F1=="sec"
float b=|1/cos(pz)|
elseif @F1=="sech"
float b=|1/cosh(pz)|
elseif @F1=="asec"
float b=|acos(1/pz)|

class OM_Rootmod(common.ulb:ConvergentFormula) {
public:
complex func Init(complex pz)
ConvergentFormula.Init(pz)
return @sf(pz)
endfunc
complex func Iterate(complex pz)
ConvergentFormula.Iterate(pz)
m_ZOld=pz
pz=@pzp1*fn2(pz)+@pzp2
f=pz^(-2)-@p2
f1=-2*pz^(-3)
f2=6*pz^(-4)
a=f1^2
b=f1-f*f2
return pz-@p1*(f/(f1*b))*(a+b)+@c
endfunc

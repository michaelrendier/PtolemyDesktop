default=(-1.25,0)
endparam
param p_power
visible=false
endparam
float param p_bailout
caption="Bailout"
default=0.00000001
exponential=true
endparam
}

class OM_BivarX56(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
c=@sf(fpixel)
if @sv==0
pz=@sf(pz)
pk=pz
elseif @sv==1
pz=@sf(pz)
pk=@sp
else
pz=@sp
pk=@sp
endif
return pz
return pk
endfunc
private:
complex pk
complex c
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
pk=@kp1*pk+@kp2
pz=pz+@asp*pz^2
pk=pk+@asp*pk^2
pk=@p1*@bf(pz*pk)+@p2
pz=pk^2/pz+pz^3/pk+c
return pz
return pk
endfunc
bool func IsBailedOut(complex pz)
bool bail=false
bail=(|(pz+pk)/2|>@p_bailout)
return bail
endfunc

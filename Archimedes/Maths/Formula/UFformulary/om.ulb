pz=@sf(pz)
else
pz=@sp
endif
c=@sf(fpixel)
endif
i=0
return pz
endfunc
complex func Iterate(complex pz)
ConvergentFormula.Iterate(pz)
pz=@zp1*pz+@zp2
if @av==0
if i==0
pz=(pz-pz/3*(@xp1-(c/pz)^3))+@xp2
i=i+1
else
pz=(pz-(pz^3-1)/(3*pz^2))^3*c+@xp3
i=0
endif
else
if i==0
pz=(pz-(pz^3-1)/(3*pz^2))^3*c+@xp3
i=i+1
else
pz=(pz-pz/3*(@xp1-(c/pz)^3))+@xp2
i=0
endif
endif
return pz
endfunc

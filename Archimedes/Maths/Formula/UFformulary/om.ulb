func Init(complex pz, complex ppixel)
GradientColoring.Init(pz, ppixel)
a=1e20
i=0
b=0.0
c=0.0
endfunc
func Iterate(complex pz)
GradientColoring.Iterate(pz)
i=i+1
if i>@p7
z=@zp1*@zf(pz)+@zp2
x=real(z)
y=imag(z)
if @v=="1"
z=-(@p1-0.9+0.15i)*x-x*y+flip(-y-x^2+y^2)
elseif @v=="2"
z=(y+@p1*x^2)^2-x^2+x^4+(1-2*(0,0.25))*x+y+flip(2*(0,0.25)*@p1*x+(-0.5,0) *y-2*(0,0.25)*x^3)
elseif @v=="3"

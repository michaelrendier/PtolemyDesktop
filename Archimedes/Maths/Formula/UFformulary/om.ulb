ConvergentFormula.Iterate(pz)
;m_ZOld=pz
z1=@p4*z1+@p7
z2=@p8*z2+@p9
z1=z1+@p5*sqr(z1)
z2=z2+@p5*sqr(z2)
z1=z1+@p6/z1
z2=z2+@p6/z2
if @v==0
a=(z1-z2)^3
z1=(z1)+@p2*(@p1*z1^2-a*z1-@p1*z1*z2-2*a*z2)/(@p1*z1+a+@p1*z2)
z2=@p3*(z1*z2)+@p1
elseif @v==1
a=(z1+z2)^3
z1=(z1)+@p2*(@p1*z1^2-a*z1-@p1*z1*z2-2*a*z2)/(@p1*z1+a+@p1*z2)
z2=@p3*(z1*z2)+@p1

class OM_Phorlis(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
if @st==0
pz=@sp
else
pz=@pf(pz)
endif
c=@pf(fpixel)
return pz
endfunc
private:
complex c
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
pz=@p1*pz*(1-(1+1/c)*pz/2+(1/c)*pz^2/3)
return pz
endfunc

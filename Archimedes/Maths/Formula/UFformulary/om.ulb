elseif @v=="4"
z=y^2*((@p1-0.5-0.4i)^2-x^2)-(x^2+2*(@p1-0.5-0.4i)*y-(@p1-0.5-0.4i)^2)^2
elseif @v=="5"
z=x*(x^2+y^2)-((@p1-1-0.25i)+2)*x^2+5*x*y-(@p1-1-0.25i)*y^2
elseif @v=="6"
z=sin((@p1-0.15-0.7i)*y)+sqr(sin((@p1-0.15-0.7i)*x))\
+flip(sin(-2.5*@p1*x)+sqr(sin(-2.5*@p1*y)))
elseif @v=="7"
z=sin((@p1-0.2-0.15i)*y)+(sin((@p1-0.2-0.15i)*x))^2+(sin((@p1-0.2-0.15i)*x))^3\
+flip(sin((0.55,-0.65)*x)+(sin((0.55,-0.65)*y))^2+(sin(1.75*y))^3)
elseif @v=="8"
z=(x-2*(@p1-2.15-0.25i))*(x^2+y^2)+(1.5,0.5)^2*(cos(1.8*x)+sin(1.8*y))
elseif @v=="9"
z=((-1,1)*x^2+2*(1,1)*x*y+@p1*y^2)*x-(-2+(-1,1)*@p1)*x^2-2*(1,1)*x*y-(2*@p1+@p1^2)*y^2
elseif @v=="10"
z=(x^2+y^2)*(x*cos(-2.1+0.7i)+y*sin(-2.1+0.7i))-2*y^2+x\
-@p1*sin(y+tan(1i*y))+flip(y+sin(x+tan(1i*x)))
elseif @v=="11"
z=(-1,-2.7i)*x+y+flip((@p1-0.25+1i)+x^2)
elseif @v=="12"
z=4*(0.35,0.4)*(x-(-0.25,0.1))-(y-(@p1-1.5+0.5i))^2
elseif @v=="13"
z=@p1*x*y+(0.5,1.35)*x-(0,0.25)*y^3+x^3+(@p1-1)*x^2
elseif @v=="14"

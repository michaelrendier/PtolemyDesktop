endif
if @JM=="J" || @JM=="M1"
pz=@p3*fn3(log(abs(pz)))^@pow+@p4
else
pz=@p3*fn3(log(abs(pz)))^@pow+@p4+fn4(fpixel)
endif
endwhile
pz=@adj*pz/100
return pz
endfunc

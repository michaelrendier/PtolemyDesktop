y=y+@p9*real(sqrt(a+(@p7*(a+sin(@p8*a)))))/10
i2=0
endif
elseif @v101=="38"
if i2==0
x=x-@p4*real(sin(y+(@p2*(y+asinh(@p3*y)))))/10
y=y+@p4*real(sin(a+(@p2*(a+asinh(@p3*a)))))/10
i2=i2+1
else
x=x-@p9*real(sqrt(y+cos(@p7*(y+sin(@p8*y)))))/10
y=y+@p9*real(sqrt(a+cos(@p7*(a+sin(@p8*a)))))/10
i2=0
endif
elseif @v101=="39"
if i2==0
x=x-@p4*real(sqrt(y+sin(@p2*(y+cos(@p3*y)))))/10
y=y+@p4*real(sqrt(a+sin(@p2*(a+cos(@p3*a)))))/10
i2=i2+1
else
x=x-@p9*real(sin(y+cos(@p7*(y+exp(@p8*y)))))/10
y=y+@p9*real(sin(a+cos(@p7*(a+exp(@p8*a)))))/10
i2=0
endif
elseif @v101=="40"
if i2==0
x=x-@p4*real((y+sin(@p2*(y+(@p3*y)))))/10
y=y+@p4*real((a+sin(@p2*(a+(@p3*a)))))/10
i2=i2+1
else

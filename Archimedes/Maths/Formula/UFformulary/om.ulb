class OM_TetravarNewtonJ(common.ulb:ConvergentFormula) {
public:
complex func Init(complex pz)
ConvergentFormula.Init(pz)
pw=@sf(pz)
pk=@sf(pz)
pq=@sf(pz)
pz=@sf(pz)
pzold=(0,0)
pkold=(0,0)
pwold=(0,0)
pqold=(0,0)
return pz
return pk
return pw
return pq
endfunc
private:
complex pk
complex pw
complex pq
complex pzold
complex pkold
complex pwold
complex pqold
complex func Iterate(complex pz)
ConvergentFormula.Iterate(pz)
pzold=pz
pkold=pk
pwold=pw
pqold=pq
pz=@zp1*pz+@zp2
pk=@kp1*pk+@kp2
pw=@wp1*pw+@wp2
pq=@qp1*pq+@qp2
a=pw
b=pk
c=pq
pw=@tp1*pw/pz+@tp2
pk=@tp3*pk/pz+@tp4
pq=@tp5*pq/pz+@tp6
pz=pz-@np5*(pz^3-@np1)/(3*pz^2)+a-@np6*(a^3-@np2)/(3*a^2)+b-@np7*(b^3-@np3)/(3*b^2)+c-@np8*(c^3-@np4)/(3*c^2)
return pz
return pk
return pw
return pq
endfunc
bool func IsBailedOut(complex pz)
bool bail=false
bail=(|(pz-pzold+pk-pkold+pw-pwold+pq-pqold)/4|<@p_bailout)
return bail
endfunc

a=pz-@p1*f/f1
fa=a^@pow-(a+1)^2*(a-1)^(@pow-2)-@c
b=pz-@p2*(fa/f1)*(1/(1-fa/f)^2)
fb=b^@pow-(b+1)^2*(b-1)^(@pow-2)-@c
elseif @v==3
f=pz^@pow-(pz+1)^2*(pz-1)^(@pow-2)-pz^@pow*(pz-1.5)/(1-1.5*pz)-@c
f1=@pow*pz^(@pow-1)-(pz+1)*(@pow*pz+@pow-4)*(pz-1)^(@pow-3)-pz^(@pow-1)*(@pow*(-2*pz^2/3+13*pz/9-2/3)-5*pz/9)/(2/3-pz)^2
a=pz-@p1*f/f1
fa=a^@pow-(a+1)^2*(a-1)^(@pow-2)-a^@pow*(a-1.5)/(1-1.5*a)-@c
b=pz-@p2*(fa/f1)*(1/(1-fa/f)^2)
fb=b^@pow-(b+1)^2*(b-1)^(@pow-2)-b^@pow*(b-1.5)/(1-1.5*b)-@c
elseif @v==4
f=(pz+2)^2*(pz-2)^(@pow-2)-@c
f1=(pz+2)*(@pow*(pz+2)-8)*(pz-2)^(@pow-3)
a=pz-@p1*f/f1
fa=(a+2)^2*(a-2)^(@pow-2)-@c
b=pz-@p2*(fa/f1)*(1/(1-fa/f)^2)
fb=(b+2)^2*(b-2)^(@pow-2)-@c
elseif @v==5

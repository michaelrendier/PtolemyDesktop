class OM_Mogotrevo(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
return @sf(pz)
endfunc
complex func Iterate(complex pz)
pz=@zp1*@zf(pz)+@zp2
if real(pz)<imag(pz)
return @p1*(pz^@pow+@c)
else
return fn1(@p1)*(pz^@pow-@c)
endif
endfunc

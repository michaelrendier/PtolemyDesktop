+flip(abs(sin(@p2*x))+(sin((@p1-2.6)*y))^2)+sin(((@p1-2.6)-1+2i)*y)\
+sqr(sin(((@p1-2.6)-1+2i)*x))+flip(sin((@p2-2.25-1.25i)*x)+sqr(sin((@p2-2.25-1.25i)*y)))
elseif @V=="22"

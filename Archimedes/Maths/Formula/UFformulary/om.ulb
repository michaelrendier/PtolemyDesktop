class OM_TetravarX12(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
a=(0,0)
b=(0,0)
c=(0,0)
if @mj==0
pk=@sp
pq=@sp
pz=@sp
pw=@sp
else
pz=@pf(pz)
pk=pz
pq=pz
pw=pz
endif
return pz
return pq
return pk
return pw
endfunc
private:
complex pk
complex pw
complex pq
complex a
complex b
complex c
complex fpixel
complex func Iterate(complex pz)
pw=@wp1*pw+@wp2
pk=@kp1*pk+@kp2
pz=@zp1*pz+@zp2
pq=@qp1*pq+@qp2
a=pw
b=pk
c=pz
if @mj==0
if @v==0
pw=pw^2*@p1*@pf(fpixel)*pk+pq^2*(pq-@p5)/(1-@p5*pq)
pk=pk^2+@p2*@pf(fpixel)+pz+pw^2*(pw-@p5)/(1-@p5*pw)
pz=pz^2*@p3*@pf(fpixel)/pq+pk^2*(pk-@p5)/(1-@p5*pk)
pq=pq^2+@p4*@pf(fpixel)-a+pz^2*(pz-@p5)/(1-@p5*pz)
elseif @v==1
pw=pw^2*@p1*@pf(fpixel)*pz+pq^2*(pq-@p5)/(1-@p5*pq)
pk=pk^2+(@p2-0.35)*@pf(fpixel)+pq+pw^2*(pw-@p5)/(1-@p5*pw)
pz=pz^2*(@p3+0.6)*@pf(fpixel)/a+pk^2*(pk-@p5)/(1-@p5*pk)
pq=pq^2+(@p4+1.7)*@pf(fpixel)-b+pz^2*(pz-@p5)/(1-@p5*pz)
elseif @v==2
pw=pw^2*@p1*@pf(fpixel)*pq+pq^2*(pq-@p5)/(1-@p5*pq)
pk=pk^2+(@p2+1.25)*@pf(fpixel)+a+pw^2*(pw-@p5)/(1-@p5*pw)
pz=pz^2*@p3*@pf(fpixel)/b+pk^2*(pk-@p5)/(1-@p5*pk)
pq=pq^2+@p4*@pf(fpixel)-c+pz^2*(pz-@p5)/(1-@p5*pz)
else
pw=pw^2*@p1*@pf(fpixel)*pw+pq^2*(pq-@p5)/(1-@p5*pq)
pk=pk^2+(@p2+0.6)*@pf(fpixel)+pk+pw^2*(pw-@p5)/(1-@p5*pw)
pz=pz^2*@p3*@pf(fpixel)/pz+pk^2*(pk-@p5)/(1-@p5*pk)
pq=pq^2+@p4*@pf(fpixel)-pq+pz^2*(pz-@p5)/(1-@p5*pz)
endif
else
if @v==0
pw=pw^2*@p1*pk+pq^2*(pq-@p5)/(1-@p5*pq)
pk=pk^2+@p2+pz+pw^2*(pw-@p5)/(1-@p5*pw)
pz=pz^2*@p3/pq+pk^2*(pk-@p5)/(1-@p5*pk)
pq=pq^2+@p4-a+pz^2*(pz-@p5)/(1-@p5*pz)
elseif @v==1
pw=pw^2*@p1*pz+pq^2*(pq-@p5)/(1-@p5*pq)
pk=pk^2+(@p2-0.25)+pq+pw^2*(pw-@p5)/(1-@p5*pw)
pz=pz^2*@p3/pq+a^2*(pk-@p5)/(1-@p5*pk)
pq=pq^2+@p4-b+pz^2*(pz-@p5)/(1-@p5*pz)
elseif @v==2
pw=pw^2*@p1*pq+pq^2*(pq-@p5)/(1-@p5*pq)
pk=pk^2+(@p2-3.45)+a+pw^2*(pw-@p5)/(1-@p5*pw)
pz=pz^2*@p3/b+a^2*(pk-@p5)/(1-@p5*pk)
pq=pq^2+@p4-c+pz^2*(pz-@p5)/(1-@p5*pz)
else
pw=pw^2*@p1*pw+pq^2*(pq-@p5)/(1-@p5*pq)
pk=pk^2+(@p2-1.45)+pk+pw^2*(pw-@p5)/(1-@p5*pw)
pz=pz^2*@p3/pz+a^2*(pk-@p5)/(1-@p5*pk)
pq=pq^2+@p4-pq+pz^2*(pz-@p5)/(1-@p5*pz)
endif
endif
pz=pz+pk+pw+pq
return pz
return pw
return pk
return pq
endfunc

c2=(1+@fp*1i)*@fn1(2*(sin(a)+flip(cos(a))))
c3=(1+@fp*1i)*@fn1(2*(sin(2*a)+flip(cos(2*a))))
c4=(1+@fp*1i)*@fn1((0,-2))
c5=(1+@fp*1i)*@fn1(2*(sin(4*a)+flip(cos(4*a))))
c6=(1+@fp*1i)*@fn1(2*(sin(5*a)+flip(cos(5*a))))
pz=@pf(pz)
i=0
return pz
endfunc

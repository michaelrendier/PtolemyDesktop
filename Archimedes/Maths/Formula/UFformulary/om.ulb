i=i+1
else
x=x-@p3b*real(conj(y+cos(@p1b*(y+abs(@p2b*y)))))/10
y=y+@p3b*real(conj(k+cos(@p1b*(k+abs(@p2b*k)))))/10
i=0
endif
elseif @v==99
if i==0
x=x-@p3a*real(conj(y+cos(@p1a*(y+conj(@p2a*y)))))/10
y=y+@p3a*real(conj(k+cos(@p1a*(k+conj(@p2a*k)))))/10
i=i+1
else
x=x-@p3b*real(conj(y+cos(@p1b*(y+conj(@p2b*y)))))/10
y=y+@p3b*real(conj(k+cos(@p1b*(k+conj(@p2b*k)))))/10
i=0
endif
else
if i==0
x=x-@p3a*real(sin(y+sin(@p1a*(y+sin(@p2a*y)))))/10
y=y+@p3a*real(sin(k+sin(@p1a*(k+sin(@p2a*k)))))/10
i=i+1
else
x=x-@p3b*real(sin(y+cos(@p1b*(y+sin(@p2b*y)))))/10
y=y+@p3b*real(sin(k+cos(@p1b*(k+sin(@p2b*k)))))/10
i=0
endif
endif
pz=x+flip(y)
return pz
endfunc

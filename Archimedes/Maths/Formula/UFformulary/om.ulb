i2=i2+1
else
x=x-(@p9-0.6)*real(cos(y+sin(@p7*(y+sin(@p8*y)))))/10
y=y+(@p9-0.6)*real(acosh(a+sin(@p7*(a+sin(@p8*a)))))/10
i2=0
endif
elseif @v101=="46"
if i2==0
x=x-@p4*real(flip(y+cos(@p2*(y+cos(@p3*y)))))/10
y=y+@p4*real((a+cos(@p2*(a+cos(@p3*a)))))/10
i2=i2+1
else
x=x-@p9*real(cos(y+(@p7*(y+(@p8*y)))))/10
y=y+@p9*real(cos(a+(@p7*(a+(@p8*a)))))/10
i2=0
endif
elseif @v101=="47"
if i2==0
x=x-@p4*real(flip(y+cos(@p2*(y+cos(@p3*y)))))/10
y=y+@p4*real(flip(a+cos(@p2*(a+cos(@p3*a)))))/10
i2=i2+1
else
x=x-@p9*real(cos(y+(@p7*(y+(@p8*y)))))/10
y=y+@p9*real(cos(a+(@p7*(a+(@p8*a)))))/10
i2=0
endif
elseif @v101=="48"
if i2==0
x=x-@p4*real(flip(y+cos(@p2*(y+cos(@p3*y)))))/10
y=y+@p4*real(sqrt(a+cos(@p2*(a+cos(@p3*a)))))/10
i2=i2+1
else
x=x-@p9*real(cos(y+(@p7*(y+(@p8*y)))))/10
y=y+@p9*real(cos(a+(@p7*(a+(@p8*a)))))/10
i2=0
endif
elseif @v101=="49"
if i2==0
x=x-@p4*real(abs(y+cos(@p2*(y+cos(@p3*y)))))/10
y=y+@p4*real(cos(a+cos(@p2*(a+cos(@p3*a)))))/10
i2=i2+1
else
x=x-@p9*real(cos(y+(@p7*(y+(@p8*y)))))/10
y=y+@p9*real(cos(a+(@p7*(a+(@p8*a)))))/10
i2=0
endif
elseif @v101=="50"
if i2==0
x=x-@p4*real(abs(y+cos(@p2*(y+cos((@p3-1.15)*y)))))/10
y=y+@p4*real(cos(a+cos(@p2*(a+cos((@p3-1.15)*a)))))/10
i2=i2+1
else
x=x-@p9*real(cos(y+(@p7*(y+sqr((@p8-1)*y)))))/10
y=y+@p9*real(cos(a+(@p7*(a+exp((@p8-1)*a)))))/10
i2=0
endif
elseif @v101=="51"
if i2==0
x=x-@p4*real((y+cos(@p2*(y+cos((@p3-1.15)*y)))))/10
y=y+@p4*real((a+cos(@p2*(a+cos((@p3-1.15)*a)))))/10
i2=i2+1
else

class OM_ModifiedAleatorFloorPhoenixJ(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
i=0
seed=@seed
while i<100
seed=random(seed)
values[i]=seed/#randomrange
i=i+1
endwhile

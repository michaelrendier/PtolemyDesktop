elseif @v=="136"
z=@p1*z+flip(z+@p2)*flip(@p3*z+@p4)+@p5
elseif @v=="137"
z=@p1*z+flip(z+@p2)*conj(@p3*z+@p4)+@p5
elseif @v=="138"

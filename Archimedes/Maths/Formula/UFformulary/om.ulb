class OM_TetravarX5(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
c=@sf(fpixel)
pk=@sf(pz)
pq=@sf(pz)
pz=@sp
pw=@sp
return pz
return pq
return pk
return pw
endfunc
private:
complex pk
complex pw
complex pq
complex c
complex func Iterate(complex pz)
pw=@wp1*pw+@wp2
if @jm==0
pk=@kp1*pk+@kp2
else
pk=(@kp1+0.13)*pk+@kp2
endif
pz=@zp1*pz+@zp2
pq=@qp1*pq+@qp2
a=pw
b=pk
if @jm==0
pw=pq*(-pk-@p1)+(1-pq)*(pz+@p1)+@mp1/pw
pk=pq*(a+@p2-1)+pk*(1-pq)*(pz+@p1)/(a+@p3-1)+@mp2/pk
pz=pq*pz*(-b-@p1)/(a-@p3)+(1-pq)*(@p2-a)+@mp3/pz
pq=@p4*(pq*(1-pq)*(pq-1+a)-@p5*(pq-0.5))+@c+@mp4/pq
else
pw=pq*(-pk-@p1)+(1-pq)*(pz+@p1)+@mp1*c/pw
pk=pq*(a+@p2-1)+pk*(1-pq)*(pz+@p1)/(a+@p3-1)+@mp2*c/pk
pz=pq*pz*(-b-@p1)/(a-@p3)+(1-pq)*(@p2-a)+@mp3*c/pz
pq=@p4*(pq*(1-pq)*(pq-1+a)-@p5*(pq-0.5))+c+@mp4*c/pq
endif
return pz
return pw
return pk
return pq
endfunc
bool func IsBailedOut(complex pz)
bool bail=false
bail=(|(pz+pk+pw+pq)/4|>@p_bailout)
return bail
endfunc

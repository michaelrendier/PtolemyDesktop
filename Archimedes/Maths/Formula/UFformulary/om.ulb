elseif |pz-c5|<r^2
pz=r*conj(r/(pz-c5))+c5
elseif |pz-c6|<r^2
pz=r*conj(r/(pz-c6))+c6
elseif |pz-c7|<r^2
pz=r*conj(r/(pz-c7))+c7
endif
if @kxv==3

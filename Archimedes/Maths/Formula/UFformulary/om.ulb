caption="Z Parameter 2"
default=(0,0)
endparam
func sf
caption="Pixel Function"
default=ident()
endfunc
param as
caption="Add Sqr Parameter"
default=(0,0)
endparam
param ar
caption="Add recip Parameter"
default=(0,0)
endparam
param p_power
visible=false
endparam
float param p_bailout
caption="Bailout"
default=10000.0
exponential=true
endparam
}

class OM_DasDebataMagnetJ(common.ulb:ConvergentDivergentFormula) {
;Das-Debata iteration from
;https://link.springer.com/article/10.1007/s11071-017-3813-6
;(21)
public:
complex func Init(complex pz)
ConvergentDivergentFormula.Init(pz)
pz=@sf(pz)
return pz
endfunc
complex func Iterate(complex pz)
ConvergentDivergentFormula.Iterate(pz)
pz=@zp1*pz+@zp2
pz=pz+@as*sqr(pz)
pz=pz+@ar/pz
u=(1-@p1)*pz+@p1*(sqr((pz^2+@mp1-1)/(2*pz+@mp1-2)))
pz=(1-@p2)*pz+@p2*(sqr((u^2+@mp2-1)/(2*u+@mp2-2)))
return pz
endfunc

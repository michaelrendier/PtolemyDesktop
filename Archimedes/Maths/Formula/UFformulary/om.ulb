pz=-0.75*flip(pz)
elseif @kxv==17
pz=-0.1*sqr(pz)
endif
i=1
else
a=pz^@pow1+@p1
b=pz^@pow2-@p2
c=a/b
d=@p3+(@p4/(pz^@pow3-@p3))
pz=(c/d)*pz
if @kxv==4

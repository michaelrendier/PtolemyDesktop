"cube""cuberoot""colog""logit""expit""gauss""softplus"\
"primecount""sqr+""cube+""sin+""cos+""tan+""cotan+""sec+""cosec+""sin*""cos*""tan*""cotan*""sec*"\
"cosec*""loglog""sinsin""coscos""+pixel""-pixel"\
"*pixel""/pixel""(sqr-pixel)/(+pixel)""(sqr+pixel)/(-pixel)""(sqr-pixel)/(+pixel)+pixel"\
"(sqr+pixel)/(-pixel)+pixel""(sqr-pixel)/(+pixel)-pixel""(sqr+pixel)/(-pixel)-pixel"\
"+pixel+sqr(pixel)""+pixel-sqr(pixel)""-pixel+sqr(pixel)""-pixel-sqr(pixel)""ceil""floor""trunc""round"
default=22

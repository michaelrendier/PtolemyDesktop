int param version
caption="Version"
default=100
visible=@version<100
endparam
param jm
caption="J/M"
enum="J""M"
endparam
param sp
caption="Start Parameter"
default=(-0.5,0)
visible=@jm==1
endparam
param c
caption="Julia Seed"
default=(0,0)
visible=@jm==0
endparam
param p1
caption="FB Parameter"
default=(-0.5,0)
endparam
param zp1
caption="Z Parameter 1"
default=(1,0)
endparam
param zp2
caption="Z Parameter 2"
default=(0,0)
endparam
func sf
caption="Start Function"
default=ident()
visible=@jm==0
endfunc
func pf
caption="Pixel Function"
default=ident()
visible=@jm==1
endfunc
param p_power
visible=false
endparam
float param p_bailout
caption="Bailout"
default=100.0
exponential=true
endparam
}


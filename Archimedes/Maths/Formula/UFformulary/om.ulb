fpixel=pz
a=(0,0)
b=(0,0)
d=(0,0)
if @mj==0
pk=@sp
pq=@sp
pz=@sp
pw=@sp
c=@pf(fpixel)
else
pz=@pf(pz)
pk=pz
pq=pz
pw=pz
c=@js
endif
return pz
return pq
return pk
return pw
endfunc
private:
complex pk
complex pw
complex pq
complex a
complex b
complex c
complex d
complex fpixel
complex func Iterate(complex pz)
pw=@wp1*pw+@wp2
pk=@kp1*pk+@kp2
pz=@zp1*pz+@zp2
pq=@qp1*pq+@qp2
a=pw
b=pk
d=pz
if @mj==0
pw=pw/pz+@p1*c
pk=pk/pz+@p2*c
pz=pz*(pz^2+1/((pz-1/pz)*(pz^2+1/pz+@p8)+@p7/pz))\
+a*(a^2+1/((a-1/a)*(a^2+1/a+@p8)+@p7/a))\
+b*(b^2+1/((b-1/b)*(b^2+1/b+@p8)+@p7/b))\
+pq*(pq^2+1/((pq-1/pq)*(pq^2+1/pq+@p8)+@p7/pq))+@p3*c
pq=pq/d+@p4*c
else
pw=pw/pz+@p1*c
pk=pk/pz+@p2*c
pz=pz*(pz^2+1/((pz-1/pz)*(pz^2+1/pz+@p8)+@p7/pz))\
+a*(a^2+1/((a-1/a)*(a^2+1/a+@p8)+@p7/a))\
+b*(b^2+1/((b-1/b)*(b^2+1/b+@p8)+@p7/b))\
+pq*(pq^2+1/((pq-1/pq)*(pq^2+1/pq+@p8)+@p7/pq))+(@p3-4.5)*c
pq=pq/d+@p4*c
endif
return pz
return pw
return pk
return pq
endfunc

caption="Bailout"
default=0.000000001
exponential=true
endparam
}

class OM_MidpointMethod(common.ulb:ConvergentFormula) {
public:
complex func Init(complex pz)
ConvergentFormula.Init(pz)
return @sf(pz)
endfunc
complex func Iterate(complex pz)
ConvergentFormula.Iterate(pz)
pz=@pzp1*@pzf(pz)+@pzp2
f=pz^@pow+pz^(@pow-1)+pz^(@pow-2)-@p2
f1=@pow*pz^(@pow-1)+(@pow-1)*pz^(@pow-2)+(@pow-2)*pz^(@pow-3)
return @p3*pz-@p1*(f/(f1*(pz-(f/f1)/2)))+@c
endfunc

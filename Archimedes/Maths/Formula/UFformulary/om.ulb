class OM_AleatorDevix(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
i=0
seed=@seed
while i<100
seed=random(seed)
values[i]=seed/#randomrange
i=i+1
endwhile
fpixel=pz
a=(0,0)
b=(0,0)
if @mj==1
pz=@pf(pz)
c=@js
else
pz=@sp
c=@pf(fpixel)
endif
i2=0
return pz
endfunc
complex func Iterate(complex pz)
if @av==0
pz=@zp1*pz+@zp2
b=pz^@pow1+c/(pz-@dmp)^@pow2+(@php+1)*a+@ap*@af(values[i2])
elseif @av==1
pz=@zp1*pz+@zp2+@ap*@af(values[i2])
b=pz^@pow1+c/(pz-@dmp)^@pow2+@php*a
elseif @av==2
pz=@zp1*pz+@zp2
b=pz^@pow1+(c+(@ap-0.4)*@af(values[i2]))/(pz-@dmp)^@pow2+(@php+1)*(a+(@ap-0.4)*@af(values[i2]))
elseif @av==3
pz=@zp1*pz+@zp2
b=(pz+(@ap-1.4)*@af(values[i2]))^@pow1+c/(pz-@dmp)^@pow2+@php*a
elseif @av==4
pz=@zp1*pz+@zp2
b=pz^@pow1+c/(pz+@ap*@af(values[i2])-@dmp)^@pow2+(@php+1)*a
elseif @av==5
pz=@zp1*pz+@zp2+(@ap-1.3)*@af(values[i2])
b=(pz+(@ap-1.3)*@af(values[i2]))^@pow1+c/(pz-(@dmp+0.2))^@pow2+@php*a
elseif @av==6
pz=@zp1*pz+@zp2
b=pz^@pow1+(c+@ap*@af(values[i2]))/(pz+@ap*@af(values[i2])-@dmp)^@pow2+(@php+1)*a
elseif @av==7
pz=@zp1*pz+@zp2+@ap*@af(values[i2])
b=pz^@pow1+c/(pz+@ap*@af(values[i2])-(@dmp-1))^@pow2+(@php+1)*a
elseif @av==8
pz=@zp1*pz+@zp2
b=pz^@pow1+c/(pz+@ap*@af(values[i2])-@dmp)^@pow2+@php*a+@ap*@af(values[i2])
elseif @av==9
pz=@zp1*pz+@zp2
b=pz^@pow1+c/(pz-@dmp)^@pow2+@php*(a+@ap*@af(values[i2]))
elseif @av==10
pz=@zp1*pz+@zp2+(@ap-0.15)*@af(values[i2])
b=pz^@pow1+(c+(@ap-0.15)*@af(values[i2]))/(pz-@dmp)^@pow2+(@php+1)*a
elseif @av==11
pz=@zp1*pz+@zp2
b=(pz+@ap*@af(values[i2]))^@pow1+c/(pz-@dmp)^@pow2+(@php+1)*(a+@ap*@af(values[i2]))
elseif @av==12
pz=@zp1*pz+@zp2
b=pz^@pow1+c/(pz+@ap*@af(values[i2])-(@dmp-0.7))^@pow2+@php*(a+@ap*@af(values[i2]))
elseif @av==13
pz=@zp1*pz+@zp2+(@ap-0.4)*@af(values[i2])
b=pz^@pow1+c/(pz-(@ap-0.4)*@af(values[i2])-@dmp)^@pow2+(@php+1)*a
elseif @av==14
pz=@zp1*pz+@zp2+@ap*@af(values[i2])
b=pz^@pow1+c/(pz-@dmp)^@pow2+@php*(a-@ap*@af(values[i2]))
elseif @av==15
pz=@zp1*pz+@zp2
b=(pz-(@ap-0.4)*@af(values[i2]))^@pow1+c/(pz-@dmp)^@pow2+(@php+1)*a+(@ap-0.4)*@af(values[i2])
elseif @av==16
pz=@zp1*pz+@zp2
b=pz^@pow1+c/(pz-(@ap-1.3)*@af(values[i2])-@dmp)^@pow2+@php*(a+(@ap-1.3)*@af(values[i2]))
elseif @av==17
pz=@zp1*pz+@zp2
b=pz^@pow1+c/(pz-@dmp)^@pow2+(@php+1)*(a+(@ap-1.5)*@af(values[i2]))-(@ap-1.5)*@af(values[i2])
elseif @av==18
pz=@zp1*pz+@zp2+(@ap-1.3)*@af(values[i2])
b=(pz-(@ap-1.3)*@af(values[i2]))^@pow1+c/(pz-@dmp)^@pow2+(@php+1)*a
elseif @av==19
pz=@zp1*pz+@zp2
b=(pz+(@ap-0.4)*@af(values[i2]))^@pow1+c/(pz-(@dmp-0.2))^@pow2+@php*(a-(@ap-0.4)*@af(values[i2]))
elseif @av==20
pz=@zp1*pz+@zp2
b=pz^@pow1+c/(pz-@dmp)^@pow2+@php*(a+@ap*@af(values[i2]))+@ap*@af(values[i2])
elseif @av==21
pz=@zp1*pz+@zp2
b=pz^@pow1+c/(pz-(@ap-0.5)*@af(values[i2])-@dmp)^@pow2+@php*a+(@ap-0.5)*@af(values[i2])
elseif @av==22
pz=@zp1*pz+@zp2
b=pz^@pow1+(c+(@ap-1.4)*@af(values[i2]))/(pz-@dmp)^@pow2+(@php+1)*a
elseif @av==23
pz=@zp1*pz+@zp2+@ap*@af(values[i2])
b=pz^@pow1+c/(pz-@dmp)^@pow2+@php*(a+@ap*@af(values[i2]))
elseif @av==24
pz=@zp1*pz+@zp2
b=(pz+(@ap-1.35)*@af(values[i2]))^@pow1+(c+(@ap-1.35)*@af(values[i2]))/(pz-@dmp)^@pow2+(@php+1)*a
elseif @av==25
pz=@zp1*pz+@zp2
b=(pz+@ap*@af(values[i2]))^@pow1+c/(pz-@dmp)^@pow2+@php*a+@ap*@af(values[i2])
elseif @av==26
pz=@zp1*pz+@zp2
b=pz^@pow1+(c+@ap*@af(values[i2]))/(pz-@dmp)^@pow2+@php*a+@ap*@af(values[i2])
elseif @av==27
pz=@zp1*pz+@zp2+@ap*@af(values[i2])
b=pz^@pow1+c/(pz-(@dmp-0.65))^@pow2+@php*a+@ap*@af(values[i2])

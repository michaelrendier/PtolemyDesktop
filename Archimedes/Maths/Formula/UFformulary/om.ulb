if @sv==0
pz=@zp1*pz+@zp2
else
pz=(@zp1+0.2)*pz+@zp2
endif
a=pk
pk=@bp1*@bf(pk/pz)+@bp2
pz=((pz*@pf(fpixel)-@p2)^2-@p2)^2+((a*@pf(fpixel)-@p2)^2-@p2)^2-2*@p2
return pz
return pk
endfunc

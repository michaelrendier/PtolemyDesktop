if @V=="1"
if real(fn3(pz))>@p6
pz=(pz-@p1)*fn1(cotanh(@p5))
else
pz=(pz+@p2)*fn2(cabs(@p5))
endif
elseif @V=="2"
if real(fn3(log(pz)))>@p6+0.74737

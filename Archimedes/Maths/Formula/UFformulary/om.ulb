class OM_Devix(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
a=(0,0)
b=(0,0)
if @mj==1
pz=@pf(pz)
c=@js
else
pz=@sp
c=@pf(fpixel)
endif
return pz
endfunc
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if @dv==0
b=pz^@pow1+c/(pz-@dmp)^@pow2+@php*a
elseif @dv==1
b=pz^@pow1+c/(pz-@dmp)^@pow2+@php*a+c
elseif @dv==2
pz=pz+c
b=pz^@pow1+c/(pz-@dmp)^@pow2+@php*a
elseif @dv==3
b=pz^@pow1+c/(pz-@dmp)^@pow2+@php*a*c
elseif @dv==4
b=pz^@pow1+c/(pz-@dmp)^@pow2+@php*a*c+c
elseif @dv==5
pz=pz+c
b=pz^@pow1+c/(pz-@dmp)^@pow2+@php*a*c
elseif @dv==6
pz=pz+c
b=pz^@pow1+c/(pz-@dmp)^@pow2+@php*a*c+c



elseif @dv==7
b=pz^@pow1+c/(pz-@dmp)^@pow2+@php*a-c
elseif @dv==8
pz=pz-c
b=pz^@pow1+c/(pz-@dmp)^@pow2+@php*a*c
elseif @dv==9
pz=pz-c
b=pz^@pow1+c/(pz-@dmp)^@pow2+@php*a*c-c
elseif @dv==10
b=pz^@pow1+c/(pz-@dmp)^@pow2+@php*a*c-c



endif
a=pz
pz=b
return pz
endfunc

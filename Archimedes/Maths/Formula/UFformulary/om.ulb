elseif @jm==1
pz=@p1*pz^2*(pz-@p2*c)/(1-(2*@p2*c-3)*pz/(@p2*c-2))+@p3
elseif @jm==2
pz=@p1*pz^2*(pz-@p2)/(1-(2*@p2-3)*pz/(@p2-2))+(@p3+1)*c
else
pz=@p1*pz^2*(pz-@p2*c)/(1-(2*@p2*c-3)*pz/(@p2*c-2))+(@p3+1)*c
endif
return pz
endfunc

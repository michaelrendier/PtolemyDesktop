pz=@p1*x*(1-x/(@p3-1.8-0.45i))-@p2*x*y+flip(-@p2*x*y+(@p4+1.125+0.65i)*(@p5-y))
elseif @V=="Ikeda"
pz=@p1+(@p2-2.25+0.125i)*(x*cos(@p3-@p4/(x^2+y^2+1))-y*sin(@p3-@p4/(x^2+y^2+1))) \
+flip((@p2-2.25+0.125i)*(x*sin(@p3-@p4/(x^2+y^2+1))+y*cos(@p3-@p4/(x^2+y^2+1))))

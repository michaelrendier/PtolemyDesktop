class OM_IFB84(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
return @sf(pz)
endfunc
complex func Iterate(complex pz)
if real(fn2(pz))*imag(@p3)+real(@p3)*imag(fn2(pz))>=0
pz=(@p2+1i)*pz/@p1
else
pz=1-(@p2-1i)*pz/@p1
endif
return pz
endfunc

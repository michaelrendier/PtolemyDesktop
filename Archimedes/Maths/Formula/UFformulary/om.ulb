elseif @v==17
pz=pz^2+exp(log(pz)^2*(log(pz)-(-@xp1))/(1-(-@xp1)*log(pz))+log(c1))+a^2+exp(log(a)^2*(log(a)-(-@xp1))/(1-(-@xp1)*log(a))+log(c2-2.25))
elseif @v==18

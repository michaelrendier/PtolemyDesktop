elseif @krtpjv==7
pz=-1.6*flip(pz)
endif
i=0
endif
else
if i==0
u=@p1*pz+@p2*(pz^@pow1+@js1)+@p3*(pz^@pow2+@js2)+@p4*(pz^@pow3+@js3)
pz=@p1*pz+@p2*(pz^@pow2+@js2)+@p3*(pz^@pow3+@js3)+@p4*(u^@pow1+@js1)
if @krtpjv==2
pz=0.61*flip(pz)
elseif @krtpjv==3
pz=0.83649*conj(pz)
elseif @krtpjv==4
pz=flip(pz)
elseif @krtpjv==5
pz=-1.40865*abs(pz)
elseif @krtpjv==6
pz=abs(pz)
elseif @krtpjv==7
pz=-1.6*flip(pz)
endif
i=1
else
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
endif
if @krtpjv==6
pz=-0.9*conj(pz)
elseif @krtpjv==7
pz=-8.5*conj(pz)
endif
i=0
endif
endif
return pz
endfunc

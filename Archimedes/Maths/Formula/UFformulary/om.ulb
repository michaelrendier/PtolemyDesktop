caption="Bailout"
default=100.0
exponential=true
endparam
}

class OM_BivarX52(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
a=(0,0)
if @sv==0
pk=@sf(pz)
pz=@sp
else
pk=@sp+1.75
pz=@sf(pz)
endif
return pz
return pk
endfunc
private:
complex a
complex pk
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
a=pk
pk=@bp*pk/pz
pz=@p1*(2*@p2)^(1-pz)/(pz*(1-pz))+@p1*(2*@p2)^(1-a)/(a*(1-a))+@p2
return pz
return pk
endfunc

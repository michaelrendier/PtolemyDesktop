class OM_ModifiedAltPhoenix(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
a=(0,0)
b=(0,0)
if @jm==0
pz=@pf(pz)
else
pz=@sp
endif
c1=@js1
c2=@js2
c=@pf(fpixel)
i=0
return pz
endfunc
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if @jm==0
if i==0
b=pz^@pow1+pz^@pow2*c1+@mp1*a+@xp1/pz
a=pz
pz=b
i=i+1
else
b=pz^@pow3+pz^@pow4*c2+@mp2*a+@xp2/pz
a=pz
pz=b
i=0
endif
else
if i==0
b=pz^@pow1+pz^@pow2*@pp1*c+@mp1*a+@xp1*c/pz
a=pz
pz=b
i=i+1
else
b=pz^@pow3+pz^@pow4*@pp2*c+@mp2*a+@xp2*c/pz
a=pz
pz=b
i=0
endif
endif
return pz
endfunc
private:
complex a
complex b
complex c
complex c1
complex c2
int i
default:
title="Modified Alt Phoenix"
int param version
caption="Version"
default=100
visible=@version<100
endparam
param jm
caption="J/M"
enum="J""M"
endparam
param sp
caption="Start Parameter"
default=(-1,0)
visible=@jm==1
endparam
param mp1
caption="Phoenix Parameter 1"
default=(-0.5,0)
endparam
param mp2
caption="Phoenix Parameter 2"
default=(0.5,0)
endparam
param js1
caption="Julia Seed 1"
default=(-1,0)
visible=@jm==0
endparam
param js2
caption="Julia Seed 2"
default=(0.95,0)
visible=@jm==0
endparam
param pp1
caption="Pixel Parameter 1"
default=(1,0)
visible=@jm==1

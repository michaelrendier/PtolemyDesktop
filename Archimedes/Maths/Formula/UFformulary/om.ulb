elseif @av==20
pz=@zp1*pz+@zp2
pz=pz^@pow1+(c+(@ap-1.3)*@af(values[i2]))/(pz-@p1)^@pow2+(@ap-1.3)*@af(values[i2])
elseif @av==21
pz=@zp1*pz+@zp2
pz=(pz+(@ap-1.3)*@af(values[i2]))^@pow1+(c+(@ap-1.3)*@af(values[i2]))/(pz-@p1)^@pow2
elseif @av==22
pz=@zp1*pz+@zp2
pz=pz^@pow1+(c+(@ap-0.45)*@af(values[i2]))/(pz+(@ap-0.45)*@af(values[i2])-@p1)^@pow2
elseif @av==23

+flip(-(x+(@p1-1+1i)*sin(@p4*y))*sin(2*pi/(@p2+0.9+0.7i))+y*cos(2*pi/(@p2+0.9+0.7i)))
elseif @V=="11";
z=z+@p1*flip(@p2*z)/(@p3*z)+(@p4-2.85-0.45i)
elseif @V=="12";

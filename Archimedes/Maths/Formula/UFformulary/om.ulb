pz=exp(@p4*1i)*b^2*(b-@p3)/(1-@p3*b)+exp(@p4*1i)*pz^2*(pz-@p3)/(1-@p3*pz)+exp(@p4*1i)*a^2*(a-@p3)/(1-@p3*a)+@c
else
a=pw
b=pk
pw=@p1*recip(pw/pk/pz)+@p2
pk=exp(@p4*1i)*pk^2*(pk-@p3)/(1-@p3*pk)+exp(@p4*1i)*pz^2*(pz-@p3)/(1-@p3*pz)+c
pz=exp(@p4*1i)*b^2*(b-@p3)/(1-@p3*b)+exp(@p4*1i)*pz^2*(pz-@p3)/(1-@p3*pz)+exp(@p4*1i)*a^2*(a-@p3)/(1-@p3*a)+c
endif
return pz

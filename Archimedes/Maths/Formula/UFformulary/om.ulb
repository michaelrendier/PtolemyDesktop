u=(1-@p1)*pz+@p1*(sqr((pz^2+@mp1*c-1)/(2*pz+@mp1*c-2)))
pz=(1-@p2)*pz+@p2*(sqr((u^2+@mp2*c-1)/(2*u+@mp2*c-2)))
return pz

caption="Midpoint Parameter"
default=(1,0)
endparam
param c
caption="Constant"
default=(1,0)
endparam
param pow
caption="Exponent"
default=(3,0)
endparam
param p6
caption="Z Parameter 1"
default=(1,0)
endparam
param p7
caption="Z Parameter 2"
default=(0,0)
endparam
func sf
caption="Start Function"
default=ident()

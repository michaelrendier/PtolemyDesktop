+flip(y-(0.25,0.1)*sin(2*pi*(x+(0.25,0.1)*sin(2*pi*y))))+x^(2/3)+y^(2/3)-@p1^(2/3)
elseif @v=="27"
z=2i*x*(1-x)+y+sin(x)+flip((2,-1)*x*sin(y)/@p1+(0.45,0.7)-x)
elseif @v=="28"

class OM_FelixandtheSunGod2(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
ang=2*pi/3
c1=(1+@fp*1i)*@fn1(exp((0,0)*ang))
c2=(1+@fp*1i)*@fn1(exp((0,1)*ang))
c3=(1+@fp*1i)*@fn1(exp((0,2)*ang))
r=sqrt(3)/2
a=pi/3
c1b=(1+@fp2*1i)*@fn2((0,2))
c2b=(1+@fp2*1i)*@fn2(2*(sin(a)+flip(cos(a))))
c3b=(1+@fp2*1i)*@fn2(2*(sin(2*a)+flip(cos(2*a))))
c4b=(1+@fp2*1i)*@fn2((0,-2))
c5b=(1+@fp2*1i)*@fn2(2*(sin(4*a)+flip(cos(4*a))))
c6b=(1+@fp2*1i)*@fn2(2*(sin(5*a)+flip(cos(5*a))))
pz=@pf(pz)
i=0
i3=0
if @av==2
a2=(@p2+7.5)
elseif @av==5
a2=(@p2-7.5)
else
a2=@p2
endif
b[i3]=4
c[i3]=4
d[i3]=4
f=@p3;pixel
g=0.61803398
while i3<4
b[i3]=a2
c[i3]=f
d[i3]=1+a2*f
if @av==1
a2=(a2*(@p1-0.3))
elseif @av==3
a2=(a2*(@p1-0.67))
elseif @av==4
a2=(a2*(@p1-0.85))
else
a2=(a2*@p1)
endif
i3=i3+1
endwhile
return pz
endfunc
private:
complex c1
complex c2
complex c3
float r
complex c1b
complex c2b
complex c3b
complex c4b
complex c5b
complex c6b
int i
int i3
complex a2
complex b[0]
complex c[0]
complex d[0]
complex f
float g
complex func Iterate(complex pz)
if @av==4
pz=(@zp1-2.05)*@zf(pz)+@zp2
elseif @av==5
pz=(@zp1-0.025)*@zf(pz)+@zp2
else
pz=@zp1*@zf(pz)+@zp2
endif
if @av==0
if i==0
if cabs(pz-c1b)<1
pz=conj(1/(pz-c1b))+c1b
elseif cabs(pz-c2b)<1
pz=conj(1/(pz-c2b))+c2b
elseif cabs(pz-c3b)<1
pz=conj(1/(pz-c3b))+c3b
elseif cabs(pz-c4b)<1
pz=conj(1/(pz-c4b))+c4b
elseif cabs(pz-c5b)<1
pz=conj(1/(pz-c5b))+c5b
elseif cabs(pz-c6b)<1
pz=conj(1/(pz-c6b))+c6b
endif
i=1
elseif i==1
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
endif
i=2
else
g=g*(1-g)
int i4=trunc(g*4)
if i4==4
i4=3
endif
pz=(pz+b[i4])/(c[i4]*pz+d[i4])
pz=@fn3(pz)
i=0
endif
elseif @av==1
if i==0
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
endif
i=1
elseif i==1
if cabs(pz-c1b)<1
pz=conj(1/(pz-c1b))+c1b
elseif cabs(pz-c2b)<1
pz=conj(1/(pz-c2b))+c2b
elseif cabs(pz-c3b)<1
pz=conj(1/(pz-c3b))+c3b
elseif cabs(pz-c4b)<1
pz=conj(1/(pz-c4b))+c4b
elseif cabs(pz-c5b)<1
pz=conj(1/(pz-c5b))+c5b
elseif cabs(pz-c6b)<1
pz=conj(1/(pz-c6b))+c6b
endif
i=2
else
g=g*(1-g)
int i4=trunc(g*4)
if i4==4

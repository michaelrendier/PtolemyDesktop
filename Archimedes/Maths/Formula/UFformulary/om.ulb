class OM_BivarXPlog4(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fPixel=pz
if @mj==1
pk=@sf(pz)
pz=@sf(pz)
c1=@js1
c2=@js2
c3=@js3
else
pk=@sp1
pz=@sp2
c1=@sf(fpixel)
c2=@sf(fpixel)
c3=@sf(fpixel)
endif
return pz
return pk
endfunc
private:
complex c1
complex c2
complex c3
complex pk
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
pk=@kp1*pk+@kp2
a=pk
pk=@bp1*pk/pz+@bp2
if @mj==0
If @v==0
pz=pz^2+exp(log(pz)^2+@xp1*log(pz)+log(c1))^2+a^2+exp(log(a)^2+@xp1*log(a)+log(c2))^2+c3
else
pz=pz^2+exp(log(pz)^2+@xp1*log(pz)-log(c1))^2+a^2+exp(log(a)^2+@xp1*log(a)-log(c2))^2+c3
endif
else
If @v==0
pz=pz^2+exp(log(pz)^2+@xp1*log(pz)+log(c1))^2+a^2+exp(log(a)^2+@xp1*log(a)+log(c2))^2+(c3+0.7)
else
pz=pz^2+exp(log(pz)^2+(@xp1-0.5)*log(pz)-log(c1-1.05))^2+a^2+exp(log(a)^2+(@xp1-0.5)*log(a)-log(c2-0.83))^2+(c3-0.3)
endif
endif
return pz
return pk
endfunc
bool func IsBailedOut(complex pz)
bool bail=false
bail=(|(pz+pk)/2|>@p_bailout)
return bail
endfunc

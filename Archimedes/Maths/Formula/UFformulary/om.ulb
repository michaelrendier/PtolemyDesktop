if @version==100
b=log(cabs(y+@p1*(1-@p2*y^2)*y+@p3*x+2*(1-@p3)*x^2/(1+x^2)+flip \
(-x+@p3*(y+@p1*(1-@p2*y^2)*y+@p3*x+2*(1-@p3)*x^2/(1+x^2)) \
+2*(1-@p3)*(y+ @p1*(1-@p2*y^2)*y+@p3*x+2*(1-@p3)*x^2/(1+x^2))^2 \
/(1+(y+@p1*(1-@p2*y^2)*y+@p3*x+2*(1-@p3)*x^2/(1+x^2))^2))))
else
b=log(cabs(y-@p1*(1+@p2*y^2)*y+@p3*x+2*(1-@p3)*x^2/(1+x^2)+flip \
(-x+@p3*(y-@p1*(1+@p2*y^2)*y+@p3*x+2*(1-@p3)*x^2/(1+x^2)) \
+2*(1-@p3)*(y-@p1*(1+@p2*y^2)*y+@p3*x+2*(1-@p3)*x^2/(1+x^2))^2 \
/(1+(y-@p1*(1+@p2*y^2)*y+@p3*x+2*(1-@p3)*x^2/(1+x^2))^2))))
endif
elseif @V=="Gumowski-Mira 3"
k=y+(@p1-0.5+1i)*x+2*(1-(@p1-0.5+1i))*x^2*exp((1-x^2)/4)
b=log(cabs(y+(@p1-0.5+1i)*x+2*(1-(@p1-0.5+1i))*x^2*exp((1-x^2)/4)+flip(-k+(@p1-0.5+1i)*x+2*(1-(@p1-0.5+1i))*x^2*exp((1-x^2)/4))))
elseif @V=="Gumowski-Mira 4"
k=y+(@p2-1.5-3i)*y*(1-(@p2-1.5-3i)*y^2)+(@p1+1.5+0.25i)*x+2*(1-(@p1+1.5+0.25i))*x^2/(1-x^2)
b=log(cabs(y+(@p2-1.5-3i)*y*(1-(@p2-1.5-3i)*y^2)+(@p1+1.5+0.25i)*x+2*(1-(@p1+1.5+0.25i))*x^2/(1-x^2)+flip(-k+(@p1+1.5+0.25i)*x+2*(1-(@p1+1.5+0.25i))*x^2/(1-x^2))))
elseif @V=="Gumowski-Mira 5"
k=y+(@p2-1.4+0.15i)*y*(1-(@p2-1.4+0.15i)*y^2)+(@p1-1+1i)*x+2*(1-(@p1-1+1i))*x^2*exp((1-x^2)/4)
b=log(cabs(y+(@p2-1.4+0.15i)*y*(1-(@p2-1.4+0.15i)*y^2)+(@p1-1+1i)*x+2*(1-(@p1-1+1i))*x^2*exp((1-x^2)/4)+flip(-k+(@p1-1+1i)*x+2*(1-(@p1-1+1i))*x^2*exp((1-x^2)/4))))
elseif @V=="Gumowski-Mira 6"
b=log(cabs(@p1*(x*cos(@p2)-y*sin(@p2))+x*y+flip(@p1*(x*sin(@p2)+y*cos(@p2))+x^2+y^3)))
elseif @V=="Gumowski-Mira Mod"
b=log(cabs((1-@p1)*x+y+flip(y+@p2*x+2*(1-@p2)*x^2*(1+x^2)^(-2))))
elseif @V=="Gumowski-Mira Mod 2"
b=log(cabs((@p2-0.4+1.7i)*y+(@p1-0.05+0.4i)*x+2*(1-(@p1-0.05+0.4i))*x^2/(1+x^2)\
+flip(-x+(@p1-0.05+0.4i)*((@p2-0.4+1.7i)*y+(@p1-0.05+0.4i)*x+2*(1-(@p1-0.05+0.4i))*x^2/(1+x^2))\
+2*(1-(@p1-0.05+0.4i))*((@p2-0.4+1.7i)*y+(@p1-0.05+0.4i)*x+2*(1-(@p1-0.05+0.4i))*x^2/(1+((@p2-0.4+1.7i)*y\
+(@p1-0.05+0.4i)*x+2*(1-(@p1-0.05+0.4i))*x^2/(1+x^2))^2))^2/(1+x^2))))
elseif @V=="Hamilton"
if @version==100
b=log(cabs(x+@p1*@p2*sin(2*pi*y)+flip(y-(@p1/@p2)*sin(2*pi*(x+@p1*@p2*sin(2*pi*y))))))
else
b=log(cabs(x+(@p1-0.75-0.1i)*@p2*sin(2*pi*y)+flip(y-((@p1-0.75-0.1i)/@p2)*sin(2*pi*(x+(@p1-0.75-0.1i)*@p2*sin(2*pi*y))))))
endif
elseif @V=="Hamilton Torus"
b=log(cabs(-sin(imag(pz))*(2-@p1)+flip(sin(real(pz))*@p1)))
elseif @V=="HCA"
if @version==100
b=log(cabs(1-@p1*x^2+@p2*(y^2-x^2)+flip(1-@p1*y^2+@p2*(x^2-y^2))))
else
b=log(cabs(1-@p1*x^2+(@p2-1+1i)*(y^2-x^2)+flip(1-@p1*y^2+(@p2-1+1i)*(x^2-y^2))))
endif
elseif @V=="Henon"
b=log(cabs(1-@p1*x^2+y+flip(@p2*x)))
elseif @V=="Henon 2"
b=log(cabs(-(y-real(pz)^2)*sin(2*pi/(@p1+(0,0.1)))+x*cos(2*pi/(@p1+(0,0.1)))+flip((y-real(pz)^2)*cos(2*pi/(@p1+(0,0.1)))+x*sin(2*pi/(@p1+(0,0.1))))))
elseif @V=="Henon 3"
b=log(cabs(y+flip(-@p2^(-1)*(1-@p1*y^2-@p2*x))))
elseif @V=="Henon 4"
b=log(cabs(exp(-@p1*@p2/2)*(x*cos(@p2*@p3)+(1/@p3)*(y-(@p4+x^2)+@p1*x/2)*sin(@p2*@p3))+flip(exp(-@p1*@p2/2)*(-@p3*x*sin(@p2*@p3)+(y-(@p4+x^2)+@p1*x/2)*cos(@p2*@p3))-@p1*x/2)))
elseif @V=="Henon 5"
b=log(cabs(y+(@p1+1)*cos(pi*x/2)-1+flip((@p2-0.5)*x)))
elseif @v=="Henon Dual"
b=log(cabs((@p1-1+1i)*x-@p2*y+@p3*x^3+flip(x)))
elseif @V=="Henon-Heiles 1"
b=log(cabs(-@p1*x-@p2*x*y+flip(-@p3*y-@p4*x^2+@p7*y^2)))
elseif @V=="Henon-Heiles 2"
b=log(cabs(y+flip(-@p1*x-@p2*x^2+@p3)))
elseif @V=="Hopalong"
b=log(cabs(y-(x/cabs(x))*sqrt(cabs(@p2*x-@p3))+flip(@p1-x)))
elseif @V=="Horsthemke-Lefever"
b=log(cabs(@p1*x*(1-x/@p3)-@p2*x*y+flip(-@p2*x*y+@p4*(@p7-y))))
elseif @V=="Ikeda"
b=log(cabs(@p1+@p2*(x*cos(@p3-@p4/(x^2+y^2+1))-y*sin(@p3-@p4/(x^2+y^2+1))) \
+flip(@p2*(x*sin(@p3-@p4/(x^2+y^2+1))+y*cos(@p3-@p4/(x^2+y^2+1))))))
elseif @V=="Ilhem-Amel"
b=log(cabs(x^3+@p1*x+@p2+y+flip(@p3*x)))
elseif @V=="Ilhem-Amel 2"
b=log(cabs((@p4-0.5)*x^3+@p1*x+@p2/2+@p7*y+flip(@p3*x+@p9*y)))
elseif @v=="Jiang"
b=log(cabs(y+flip(x+@p1*x^2+@p2*y^2-@p3*x*y-@p4)))
elseif @v=="Jiang-Liu-Wei-Zhang"
b=log(cabs(y+flip(@p1*x+@p2*y+@p3*x^2+@p4*y^2+@p7*x*y+@p9)))
elseif @V=="Kam Torus"
b=log(cabs(x*cos(@p1)+(x^2-y)*sin(@p1)+flip(x*sin(@p1)-(x^2-y)*cos(@p1))))
elseif @V=="Kaplan-Yorke"
b=log(cabs(real(@p1)*x%1+flip(-@p2*y+cos(2*pi*x))))
elseif @V=="Khovanov-Luchinsky"
b=log(cabs(y+flip(-@p1*x+@p2*y-y^3+@p3)))
elseif @v=="Knot"
b=log(cabs(-y+flip(x^4-y)))
elseif @V=="Kolmogorov-Volterra"
b=log(cabs((x*(@p1-x^2)-@p2*x*y)/(1+x^2)+flip((@p3*x^2-1)*y/(1+x^2))))
elseif @V=="Latoocarfian"
if @version==100
b=log(cabs(sin(@p1*y)+@p2*sin(@p1*x)+flip(sin(@p3*x)+@p4*sin(@p3*y))))
else
b=log(cabs(sin(@p1*y)+@p2*sin(@p1*x)+flip(sin((@p3-1+1i)*x)+(@p4-1+1i)*sin((@p3-1+1i)*y))))
endif
elseif @V=="Limit Cycle"
b=log(cabs(x-y-@p1*x*(x^2+y^2)+(@p3-1.25)+flip(x+y-@p2*y*(x^2+y^2)+@p4)))
elseif @V=="Lozi"
b=log(cabs(1+y-@p1*cabs(x)+flip(@p2*x)))
elseif @V=="MacMillan"
b=log(cabs(y+flip(-x-2*@p1*y/(1-y^2)+@p2*y)))
elseif @V=="Marotto-Lorenz"
b=log(cabs((1-@p1*x-@p2*y)*(@p1*x+@p2*y)+flip(x)))
elseif @V=="Martin"
b=log(cabs(y+sin(x)+flip(@p1-x)))
elseif @V=="Maynard Smith"
b=log(cabs(y+flip(-@p1*y+@p2-x^2)))
elseif @V=="Mira"
b=log(cabs(@p2*y+@p1*x+2*(1-@p1)*x^2/(1+x^2)\
+flip(-x+@p1*(@p2*y+@p1*x+2*(1-@p1)*x^2/(1+x^2))\
+2*(1-@p1)*(@p2*y+@p1*x+2*(1-@p1)*x^2/(1+(@p2*y\
+@p1*x+2*(1-@p1)*x^2/(1+x^2))^2))^2/(1+x^2))))
elseif @V=="Mira 2"
b=log(cabs(x^2-y^2+@p1*x+@p2+flip(2*x*y-5*@p1*y/2)))
elseif @V=="Mira 3"
b=log(cabs((1-@p1)*x+y+flip(@p1*@p2*x+@p3*y-@p1*x^3)))
elseif @V=="Mira 4"
b=log(cabs((@p1-1+1i)*x+y+flip((@p2-1+1i)+x^2)))
elseif @V=="Modified Lozi"
b=log(cabs(1+@p1*(cabs(x)-y^2)+y+flip(@p2*x)))
elseif @V=="Nowicki-Swirszcz"
if @version==100
b=log(cabs(3*x*((x-y)^2-@p1)/((3*x-y)^2-@p2)+flip(y*(y^2+2*x*y-3*x^2-@p3)/((3*x-y)^2-@p4))))
else
b=log(cabs(3*x*((x-y)^2+@p1)/((3*x-y)^2-@p2)+flip(y*(y^2+2*x*y-3*x^2-@p3)/((3*x-y)^2-@p4))))
endif
elseif @V=="Multifold Henon"
b=log(cabs(1-@p1*sin(x)+@p2*y+flip(x)))
elseif @V=="Oscillating Chemical Reaction"
b=log(cabs((@p1-x-4*x*y)/(1+x^2)+flip(@p2*x*(1-y)/(1+x^2))))
elseif @V=="Pendulum"
b=log(cabs(y+flip(-sin(x)+(@p1+1i))))
elseif @V=="Pendulum Morozov"
b=log(cabs(y+flip(-sin(x)+y*((@p1-1-1i)+@p2*cos(@p3*x))*(-@p4))))
elseif @V=="Pharaoh"
b=log(cabs(-y-@p1*cos(x)*sin(1-x^2-y^2)+(@p3-1+0.5i)+flip(x+(@p2-1+0.5i)*cos(y)*sin(1-x^2-y^2)+@p4)))
elseif @V=="Pickover 1"
if @version==100
b=log(cabs(sin(@p1*y)+@p3*cos(@p1*x)+flip(sin(@p2*x)+@p4*cos(@p2*y))))
else
b=log(cabs(sin(@p1*y)+@p3*cos(@p1*x)+flip(sin((@p2-1+1i)*x)+(@p4-1+1i)*cos((@p2-1+1i)*y))))
endif
elseif @V=="Pickover 2"
if @version==100
b=log(cabs(sin(@p1*y)+(sin(@p1*x))^2+(sin(@p1*x))^3+flip(sin(@p2*x)+(sin(@p2*y))^2+(sin(@p3*y))^3)))
else
b=log(cabs(sin((@p1-1+1i)*y)+(sin((@p1-1+1i)*x))^2+(sin((@p1-1+1i)*x))^3+flip(sin(@p2*x)+(sin(@p2*y))^2+(sin(@p3*y))^3)))
endif
elseif @V=="Pickover 3"
if @version==100
b=log(cabs(sin(@p1*y)+(sin(@p1*x))^2+flip(sin(@p2*x)+(sin(@p2*y))^2)))
else
b=log(cabs(sin(@p1*y)+(sin(@p1*x))^2+flip(sin((@p2-1+1i)*x)+(sin((@p2-1+1i)*y))^2)))
endif
elseif @V=="Pickover 4"
if @version==100
b=log(cabs(cabs(sin(@p1*y))+(sin(@p1*x))^2+flip(cabs(sin(@p2*x))+(sin(@p2*y))^2)))
else
b=log(cabs(cabs(sin(@p1*y))+(sin(@p1*x))^2+flip(cabs(sin((@p2-1+1i)*x))+(sin((@p2-1+1i)*y))^2)))
endif
elseif @V=="Polyharmonic Pendulum"
b=log(cabs(y+flip(-@p1*sin(x)-@p2*sin(3*x)+@p3*sin(@p4))))
elseif @V=="Popcorn"
if @version==100
b=log(cabs(@p1*sin(y+tan(@p2*y))+flip(@p1*sin(x+tan(@p2*x)))))
else
b=log(cabs(@p1*sin(y+tan((@p2-1+1i)*y))+flip(@p1*sin(x+tan((@p2-1+1i)*x)))))
endif
elseif @V=="Popcorn 2"
if @version==100
b=log(cabs(x-@p1*sin(y+tan(@p2*y))+flip(y-@p1*sin(x+tan(@p2*x)))))
else
b=log(cabs(x-@p1*sin(y+tan((@p2-1+1i)*y))+flip(y-@p1*sin(x+tan((@p2-1+1i)*x)))))
endif
elseif @V=="Provenzale-Balmforth"
b=log(cabs((@p1*y+(@p2-1+1i))*x*(1-x)+flip(4*y*(1-y))))
elseif @V=="Quadruptwo"
if @version==100
b=log(cabs(y-(x/cabs(x))*sin(log(abs(@p2*x-@p3)))*atan(sqr(log(abs(@p3*x-@p2))))+flip(@p1-x)))
else
b=log(cabs(y-(x/cabs(x))*sin(log(abs(@p2*x-(@p3-1+1i))))*atan(sqr(log(abs((@p3-1+1i)*x-@p2))))+flip((@p1-1+1i)-x)))
endif
elseif @V=="Rayleigh"
b=log(cabs(y+flip(-(x+@p2*y^3-@p1*y)/@p3)))
elseif @v=="Rulkov"
b=log(cabs(@p1/(1+x^2)+y+flip(y-@p2*x-@p3)))
elseif @V=="Sine"
b=log(cabs(y+flip(@p1*sin(x)+@p2*y)))
elseif @V=="Sine-Sine"
b=log(cabs(sin(x)-sin(2*y)+flip(x)))
elseif @V=="Sprott"
b=log(cabs((1+@p1*@p2)*x-@p2*x*y+flip((1-@p2)*y+@p2*x^2)))
elseif @V=="Sprott-Elhadj"
b=log(cabs(@p1*x/(1+y^2)+flip(x+@p2*y)))
elseif @V=="Standard Map"
b=log(cabs(x+@p1*sin(y)+flip(y+x+@p1*sin(y))))
elseif @V=="Stommel Thermohaline 1"
b=log(cabs((@p1-1i)-x-x*(x-y)+flip(@p2-(@p3-1+1i)*y-y*(x-y))))
elseif @V=="Stommel Thermohaline 2"
b=log(cabs((@p1-1i)*(1-x)-@p2*x*cabs(y-@p3*x)+flip(1-y-@p2*y*cabs(y-@p3*x))))
elseif @V=="Strelkova-Anishchenko"
b=log(cabs(1-@p1*x^2+@p2*(y-x)+flip(1-@p1*y^2+@p2*(x-y))))
elseif @V=="Svensson"
if @version==100
b=log(cabs(@p4*sin(@p1*x)-sin(@p2*y)+flip(@p3*cos(@p1*x)+cos(@p2*y))))
else
b=log(cabs((@p4-1+0.5i)*sin(@p1*x)-sin(@p2*y)+flip((@p3+1.25)*cos(@p1*x)+cos(@p2*y))))
endif
elseif @V=="Tartan"
b=log(cabs(-(@p1-0.65-0.5i)*y-(@p2-0.25)+flip(@p3-x^2)))
elseif @V=="Threeply"
if @version==100
b=log(cabs(y-(x/cabs(x))*(abs(sin(x)*cos(@p2)+@p3-x*sin(@p1+@p2+@p3)))+flip(@p1-x)))
else
b=log(cabs(y-(x/cabs(x))*(abs(sin(x)*cos(@p2)+(@p3-1+1i)-x*sin((@p1-1+1i)+@p2+(@p3-1+1i))))+flip((@p1-1+1i)-x)))
endif
elseif @V=="Tinkerbell"
b=log(cabs(x^2+-y^2+@p1*x+@p2*y+flip(2*x*y+@p3*x+@p4*y)))
elseif @V=="Ushiki"
b=log(cabs((@p1-x-@p2*y)*x+flip((@p3-y-@p4*x)*y)))
elseif @V=="Van der Pol"
b=log(cabs(@p1*(x-x^3/3-y)+flip(x/@p1)))
elseif @V=="Van der Pol 2"
b=log(cabs(y+flip(@p1*(1-x^2)*y-x)))
elseif @V=="Volterra-Lotka"
b=log(cabs(@p1*x-@p2*x*y+flip(-@p3*y+@p4*x*y)))
elseif @V=="Volterra-Lotka 2"
b=log(cabs(@p1*x*(1-x-@p2*y)+flip((@p3-1+1i)*y*(1-y-(@p4-1+1i)*x))))
elseif @V=="Zaslavsky"
b=log(cabs((x+(@p1-0.5+2i)*sin(y))*cos(2*pi/(@p2+0.5+0.05i))+y*sin(2*pi/(@p2+0.5+0.05i))+flip(-(x+(@p1-0.5+2i)*sin(y))*sin(2*pi/(@p2+0.5+0.05i))+y*cos(2*pi/(@p2+0.5+0.05i)))))
elseif @V=="Zito"
b=log(cabs(x*y+@p1*x-y+flip(x+y)))
elseif @V=="OM1"
b=log(cabs(@p1*y-sin(x)+3*y^2+flip(@p2*x^2+cos(y)-3*x)))
elseif @V=="OM2"
b=log(cabs(@p1+@p2*y*x+y^2+flip(pz+@p3*x^2+y^3)))
elseif @V=="OM3"
b=log(cabs(@p1*y^2+x-3*x*y+flip(x-3*@p2*x^3-y)))
elseif @V=="OM4"
b=log(cabs(y-x^2/3+2*@p1*x*y+flip(x^3+2*y+@p2/2)))
elseif @V=="OM5"
if @version==100
b=log(cabs(y-@p1*x*sin(2*y)+0.001*cos(x)+flip(@p2*y*cos(2*x)+0.001*cos(y))))
else
b=log(cabs(y+@p1*x*sin(2*y)+x+flip(@p2*y*x+y)))
endif
elseif @V=="OM6"
if @version==100
b=log(cabs(x*sin(2*y)+@p1*cos(x)+flip(y*x+@p2*cos(y))))
else
b=log(cabs(x*sqr(2*y)+(@p1-3+2i)*x+flip(y*x+@p2*sqr(y))))
endif
elseif @V=="OM7"
b=log(cabs(sin(y)+y^3-x/2+flip(@p1*x-x^2-0.3*@p2*y)))
elseif @V=="OM8"
if @version==100
b=log(cabs(@p1*sinh((x^2-y^2)+2*sqrt(-1)*x*y+@p2-1)))
else
b=log(cabs((@p1+3-3i)*x+flip((x^2-y^2)+2*x*y+@p2-1)))
endif
elseif @V=="OM9"
b=log(cabs(@p1*x+y+x^2-2*y^2+flip(-x+@p1*y+x^2-x^3)))
elseif @V=="OM10"
if @version==100
b=log(cabs((x*(1-x)+y*cos(@p1-x)/(@p1+x))/@p2+flip(x-y)))
else
b=log(cabs((x*(1-x)+y*sqr(@p1-x)/(@p1+x))/@p2+flip(x-y)))
endif
elseif @V=="OM11"
b=log(cabs(|sin(@p1*y)|+(sin(@p1*x))^2+flip(|sin(@p2*x)|+(sin(@p2*y))^2)))
elseif @V=="OM12"
if @version==100
b=log(cabs(1-@p1*y^2-acosh(x)+flip(@p2*x)))
else
b=log(cabs(1-@p1*y^2-x^3+flip(@p2*x)))
endif
elseif @V=="OM13"
b=log(cabs(x-y-sin(x)*(@p1*x^2+@p2*y^2)+flip(x+y-sin(y)*(@p3*x^2+@p4*y^2))))
elseif @V=="OM14"
if @version==100
b=log(cabs(x-y-sin(x)*(@p1*x^2+@p2*y^2)+flip(x+y-cotanh(y)*(@p3*x^2+@p4*y^2))))
else
b=log(cabs(x-y-x^2*(@p1*x^2+@p2*y^2)+flip(x+y-y^3*(@p3*x^2+@p4*y^2))))
endif
elseif @V=="OM15"
if @version==100
b=log(cabs(x-y-cotanh(x)*(@p1*x^2+@p2*y^2)+flip(x+y-cotanh(y)*(@p3*x^2+@p4*y^2))))
else
b=log(cabs(x-y+x^4*(@p1*x^2+@p2*y^2)+flip(x+y-y^3*(@p3*x-@p4*y^2))))
endif
elseif @V=="OM16"
b=log(cabs(x-y-sin(x)*(@p1*x^2+@p2*y^2)+flip(x+y-flip(y)*(@p3*x^2+@p4*y^2))))
elseif @V=="OM17"
b=log(cabs(x-y-log(x)*(@p1*x^2+@p2*y^2)+flip(x+y-sqrt(y)*(@p3*x^2+@p4*y^2))))
elseif @V=="OM18"
if @version==100
b=log(cabs(x-y-tan(x)*(@p1*x^2+@p2*y^2)+flip(x+y-cotan(y)*(@p3*x^2+@p4*y^2))))
else
b=log(cabs(x-y-sqr(x-y)*(@p1*x^2+@p2*y^2)+flip(x+y-(y+x)^3*(@p3*x^2+@p4*y^2))))
endif
elseif @V=="OM19"
b=log(cabs(@p1*x+cos(y)+x^2-2*y^2+flip(-cos(x)+@p1*y+x^2-x^3)))
elseif @V=="OM20"
b=log(cabs(@p1*(y-x^2)+flip(-x^2+2*x*@p1*(y-x^2))))
elseif @V=="OM21"
b=log(cabs(@p1*(3*y+1)*x*(1-x)+flip((3*y+1)*y*(@p2-y)+@p3)))
elseif @V=="OM22"
b=log(cabs((x+@p1)*(3*x^2-y^2)^2+(x*y/(2*@p2))*y-@p1*x-y^2+flip(@p2*y+x*y)+y^4-x^4))
elseif @V=="OM23"
b=log(cabs(((x^2+y^2)*(@p1*x*y+@p2*y*sqr(x))-2*@p1*y^2)+flip(x^3-@p1*sqr(x^2-y^2)-@p2*x*y)-@p1*(x^2-y^2)-2*@p2*x*y))
elseif @V=="OM24"
if @version==100
b=log(cabs(@p1*sin(x)-tan(y)-abs(x+flip(y))+flip(-@p2*tan(x)+sin(y)+abs(x+flip(y)))))
else
b=log(cabs(@p1*(x-y)-sqr(y+x)-abs(x+flip(y))+flip(-@p2*x^3+sqr(y-x)+abs(x+flip(y)))))
endif
elseif @V=="OM25"
b=log(cabs(@p2*(x^2+y^2)*(x^2-y^2+x*y)^2-y+flip(x^4-y)+x^4+y^4-(@p1-1.5)^4))
elseif @V=="OM26"
b=log(cabs((@p1+1)*(x-x^3/3-y)+flip(x/(@p1+1))+(x^2-1)*(x-@p2)-y^2))
elseif @V=="OM27"
b=log(cabs(x-y-(@p1-0.5)*x*(x^2+y^2)+@p2+flip(x+y-@p3*y*(x^2+y^2)+@p4)+(x^2+y^2)^2-2*(@p1-0.5)^2*(x^2-y^2)+(@p1-0.5)^4-@p2^4))
elseif @V=="OM28"
b=log(cabs((x^2+y^2)^2+(x^2-(@p2-0.5+1i)*y)^2-@p1^2*(x^2-y^2)+1-@p1*x^2+y+flip((@p2-0.5+1i)*x)+(x^2-@p3^2)*(x-@p3)^2+(y^2-@p3^2)^2))
elseif @V=="OM29"
b=log(cabs((x*((@p1+0.9i)-x^2)-(@p2-1+1i)*x*y)/(1+x^2)+flip((@p3*x^2-1)*y/(1+x^2))+(x^2+y^2)*(x^2+(@p1+0.9i)^2-(@p2-1+1i)^2)^2-4*(@p1+0.9i)^2*x^4))
elseif @V=="OM30"
b=log(cabs(@p1*x^3-(x+y)^2+flip(-@p2+y^3+(x+y)^2-@p2*x*y+(@p4-0.25+1i)*(@p7-y))+@p1*x*(1-x/(@p3-1.5-0.1i))))
elseif @V=="OM31"
b=log(cabs(@p1*x^7+(x^2+@p2*y^2)^5+y^3+flip((@p3-2-2i)*x-y)))
elseif @V=="OM32"
b=log(cabs((@p1+0.5+2.75i)*x-2*y+flip(@p2/2+x^2+x^4-y)))
elseif @V=="OM33"
b=log(cabs(@p1*x+y+sin(x)+y^4+x^2-2*y^2+flip(@p2-x-2*x^3+@p1*y+x^2)))
elseif @V=="OM34"
b=log(cabs(2*@p1*y*x+x^2+flip(-2*@p2*x^2-@p3*x^3+y)))
elseif @V=="OM35"
b=log(cabs(conj(@p1*y-1)+flip(@p2*abs(@p3*x-@p4*y)-1)))
elseif @V=="OM36"
b=log(cabs(@p1*x+x*(y-(@p2-1+1i))+flip(abs(y)+(@p3-1+1i)*x*y^2+(@p2-1+1i))))
elseif @V=="OM37"
b=log(cabs(@p1*x+sqr(x)*(y-(@p2-1+1i))+flip(sqr(y)+@p3*x*y^2+(@p2-1+1i))))
elseif @V=="OM38"
b=log(cabs((@p1+1i)*x+x*y^3+flip(@p2*sqr(x-y)-@p3*x^4*y)))
elseif @V=="OM39"
b=log(cabs((@p1-1.5)*sqr(x)+x*y^3+flip(@p2*sqr(x-y)-@p3*x^4*y)))
elseif @V=="OM40"
b=log(cabs(x+y+flip(y+@p1*abs(y+2*x-y^2)+@p2*x*(x-1)+@p3*x*y-y^2)))
elseif @V=="OM41"
b=log(cabs(x-y-@p1*x*(x^2+y^2+x+y)+flip(x+y-@p3*y*(x^2+y^2)+@p2+x^2)))
elseif @V=="OM42"
b=log(cabs(@p1*(y-x)+x*y+flip(x*(@p2-x-y)-y-@p3*(x+y))))
elseif @V=="OM43"
b=log(cabs(-y+@p3*y^2+flip(@p1*y-(@p1+1)*x^3-@p2*x+@p4*x^2)))
elseif @V=="OM44"
b=log(cabs(@p1*(y-x)+flip(x*(@p2-x*y+@p3*(x+flip(y)))-y)))
elseif @V=="OM45"
b=log(cabs(-y-(@p2+(x-@p3)*(x+flip(y)))+flip(x+@p1*y)))
endif
b2=cabs(pz)+@f
b=abs(b^(0.01*@pow1)-b2^0.01)^2
a=b/(cabs(pz)+1)^@pow2+a
endif
endif
endfunc
float func ResultIndex(complex pz)
if @solid
if @invert
if 1000*a<@p8
index=1000*a
else
m_Solid=true
endif
else
if 1000*a>@p8
index=1000*a
else
m_Solid=true
endif
endif
else
index=1000*a
endif
return index
endfunc
private:
float a
int i
float b
float b2
float index
default:
title="Attraktor Traps 3"
int param version
caption="Version"
default=101
visible=@version<101
endparam
param V
caption="Trap"
enum="Bedhead""Bogdanov""Bogdanov-Takens""Borrelli""Brusselator""Buckling Column Model""Burgers"\
"Business Cycle""Cao-Lai""Cat""Cathala""Cathala 2"\
"Chip""Chirikov Mod""Coupled Logistic""Cross Chaotic""Damped Pendulum""de Jong""Duffing"\
"Duffing 2""Duffing 3""Duffing 4""Duffing Parametric""Duffing Quintic 1""Duffing Quintic 2""Duffing Septic""Fitzhugh-Nagumo 1""Fitzhugh-Nagumo 2"\
"Garrote-Mira""Ghost""Gingerbread""Gumowski-Mira""Gumowski-Mira 2""Gumowski-Mira 3""Gumowski-Mira 4"\
"Gumowski-Mira 5""Gumowski-Mira 6""Gumowski-Mira Mod""Gumowski-Mira Mod 2"\
"Hamilton""Hamilton Torus""HCA""Henon""Henon 2""Henon 3""Henon 4""Henon 5""Henon Dual""Henon-Heiles 1"\
"Henon-Heiles 2""Hopalong""Horsthemke-Lefever""Ikeda""Ilhem-Amel""Ilhem-Amel 2"\
"Jiang""Jiang-Liu-Wei-Zhang""Kam Torus""Kaplan-Yorke""Khovanov-Luchinsky"\
"Knot""Kolmogorov-Volterra""Latoocarfian""Limit Cycle""Lozi""MacMillan"\
"Marotto-Lorenz""Martin""Maynard Smith""Mira""Mira 2""Mira 3""Mira 4""Modified Lozi""Nowicki-Swirszcz"\
"Multifold Henon""Oscillating Chemical Reaction""Pendulum""Pendulum Morozov""Pharaoh""Pickover 1"\
"Pickover 2""Pickover 3""Pickover 4""Polyharmonic Pendulum""Popcorn""Popcorn 2""Provenzale-Balmforth""Quadruptwo""Rayleigh""Rulkov""Sine"\
"Sine-Sine""Sprott""Sprott-Elhadj""Standard Map""Stommel Thermohaline 1""Stommel Thermohaline 2""Strelkova-Anishchenko""Svensson"\
"Tartan""Threeply""Tinkerbell""Ushiki""Van der Pol""Van der Pol 2""Volterra-Lotka""Volterra-Lotka 2""Zaslavsky""Zito"\
"OM1""OM2""OM3""OM4""OM5""OM6""OM7""OM8""OM9""OM10""OM11""OM12""OM13""OM14""OM15""OM16""OM17""OM18""OM19""OM20""OM21""OM22"\
"OM23""OM24""OM25""OM26""OM27""OM28""OM29""OM30""OM31""OM32""OM33""OM34""OM35""OM36""OM37""OM38""OM39""OM40""OM41""OM42""OM43""OM44""OM45"
default=7
endparam
func fn1
default=sqr()
endfunc
func fn2
default=ident()
endfunc
param p1
caption="Trap Parameter 1"
default=(1,0)
visible=@V!="Cat" && @V!="Gingerbread" && @V!="Knot" && @V!="Sine-Sine"
endparam
param p2
caption="Trap Parameter 2"
default=(1,0)
visible=@V!="Martin" && @V!="Cat" && @V!="Chirikov Mod" && @V!="Gingerbread"  \
&& @V!="Gumowski-Mira 3" && @V!="Hamilton Torus" && @V!="Henon 2" \
&& @V!="Kam Torus" && @V!="Knot" && @V!="Pendulum" && @V!="Van der Pol" && @V!="Van der Pol 2" && @V!="Sine-Sine" \
&& @V!="OM9" && @V!="OM19" && @V!="OM20" && @V!="Standard Map" && @V!="Zito"
endparam
param p3
caption="Trap Parameter 3"
default=(1,0)
visible=@V=="Borrelli" || @V=="Brusselator" || @V=="Buckling Column Model" \
|| @V=="Fitzhugh-Nagumo 1" || @V=="Fitzhugh-Nagumo 2" || @V=="Rayleigh" || @V=="Hopalong" \
|| @V=="Ushiki" || @V=="de Jong" || @V=="Duffing 2" || @V=="Duffing 3" || @V=="Duffing 4" \
|| @V=="Duffing Parametric" || @V=="Duffing Quintic 1" || @V=="Duffing Quintic 2" || @V=="Duffing Septic" || @V=="Pickover 1"  || @V=="Svensson" \
|| @V=="Chip" || @V=="Quadruptwo" || @V=="Ikeda" || @V=="Ghost" || @V=="Gumowski-Mira" \
|| @V=="Gumowski-Mira 2" || @V=="Henon 4" || @V=="Henon Dual" || @V=="Henon-Heiles 1" || @V=="Henon-Heiles 2" \
|| @V=="Ilhem-Amel 2" || @V=="Jiang-Liu-Wei-Zhang" || @V=="Khovanov-Luchinsky" \
|| @V=="Kolmogorov-Volterra" || @V=="Bogdanov" || @V=="Mira 3" || @V=="Threeply"  \
|| @V=="Tinkerbell" || @V=="OM2" || @V=="Cathala 2" || @V=="Ilhem-Amel" || @V=="Jiang" \
|| @V=="Latoocarfian" || @V=="Limit Cycle" || @V=="Pendulum Morozov" || @V=="Pharaoh" || @V=="Pickover 2" || @V=="Horsthemke-Lefever" || @V=="OM13" \
|| @V=="OM14" || @V=="OM15" || @V=="OM16" || @V=="OM17" || @V=="OM18" || @V=="OM27" || @V=="OM28" || @V=="OM29" || @V=="OM30" \
|| @V=="OM31" || @V=="OM21" || @V=="OM34" || @V=="OM35" || @V=="OM36" || @V=="OM37" || @V=="OM38" || @V=="OM39" || @V=="OM40" \
|| @V=="OM41" || @V=="OM42" || @V=="OM43" || @V=="OM44" || @V=="OM45" \
|| @V=="Volterra-Lotka" || @V=="Volterra-Lotka 2" || @V=="Polyharmonic Pendulum" || @V=="Nowicki-Swirszcz" || @V=="Rulkov" \
|| @V=="Stommel Thermohaline 1" || @V=="Stommel Thermohaline 2" || @V=="Tartan"
endparam
param p4
caption="Trap Parameter 4"
default=(1,0)
visible=@V=="Borrelli" || @V=="Buckling Column Model" || @V=="Duffing 2" || @V=="Duffing 4" || @V=="Duffing Parametric" || @V=="Duffing Quintic 1" || @V=="Duffing Quintic 2" || @V=="Duffing Septic" || @V=="Ushiki" \
|| @V=="de Jong" || @V=="Fitzhugh-Nagumo 1" || @V=="Fitzhugh-Nagumo 2" || @V=="Ghost" || @V=="Henon 4" || @V=="Henon-Heiles 1" || @V=="Ilhem-Amel 2" \
|| @V=="Pickover 1"  || @V=="Svensson"  || @V=="Ikeda" || @V=="Jiang" || @V=="Jiang-Liu-Wei-Zhang" || @V=="Limit Cycle" || @V=="Pendulum Morozov" || @V=="Tinkerbell" \
|| @V=="Latoocarfian" || @V=="Horsthemke-Lefever" || @V=="OM13" \
|| @V=="OM14" || @V=="OM15" || @V=="OM16" || @V=="OM17" || @V=="OM18" || @V=="OM27" || @V=="OM30" || @V=="OM35" || @V=="OM43" \
|| @V=="Volterra-Lotka" || @V=="Volterra-Lotka 2" || @V=="Pharaoh" || @V=="Polyharmonic Pendulum" || @V=="Nowicki-Swirszcz"
endparam
param p7
caption="Trap Parameter 5"
default=(1,0)
visible=@V=="Horsthemke-Lefever" || @V=="Duffing 2" || @V=="Duffing Parametric" || @V=="Duffing Quintic 2" || @V=="Henon-Heiles 1" || @V=="Duffing Septic" || @V=="Ilhem-Amel 2" || @V=="Jiang-Liu-Wei-Zhang" || @V=="OM30"
endparam
param p9
caption="Trap Parameter 6"
default=(1,0)
visible=@V=="Duffing 2" || @V=="Duffing Quintic 2" || @V=="Ilhem-Amel 2" || @V=="Jiang-Liu-Wei-Zhang"
endparam
param p5
caption="Parameter 1"
default=-2.9
endparam
param p6
caption="Parameter 2"
default=1.0
endparam
param f
caption="Parameter 3"
default=1.0
endparam
param center
caption="Parameter 4"
default=(0,0)
endparam
param pow1
caption="Exponent 1"
default=.2
endparam
param pow2
caption="Exponent2"
default=1.0
endparam
param S
caption="Symmetrise"
default=false
endparam
param @solid
caption="Solid Colour"
default=false
endparam
param p8
caption="Solid Colour Adjustment"
default=0.14
visible=@solid==true
endparam
param invert
caption="Invert Solid Colour"
default=false
visible=@solid==true
endparam
}

class OM_SmescitResu3(common.ulb:GradientColoring) {
public:
func Init(complex pz, complex ppixel)
GradientColoring.Init(pz, ppixel)
if @version==100
a=0.0
else
a=3.0
endif
endfunc
func Iterate(complex pz)
GradientColoring.Iterate(pz)
pz=@zp1*@zf(pz)+@zp2
x=real(pz)
y=imag(pz)
if @version==100
if @V=="Bogdanov"
pz=flip(y+@p1*y+@p2*x*(x-1)+@p3*x*y)+x+y+@p1*y+@p2*x*(x-1)+@p3*x*y
elseif @V=="Bogdanov-Takens"
pz=y+flip(@p1+@p2*x+x^2-x*y)
elseif @V=="Brusselator"
pz=(1-(@p1+1)*x+y*x^2)/@p2+flip((@p1*x-y*x^2)/@p3)
elseif @V=="Buckling Column Model"
pz=y+flip(-(@p1*x^3+@p2*x+@p3*y)/@p4)
elseif @V=="Burgers"
pz=@p1*x-y^2+flip(@p2*y+x*y)
elseif @V=="Cao-Lai"
pz=@p1*x*(1-x)+flip(@p2*x*sin(2*pi*y)/(2*pi))
elseif @V=="Cathala 1"
pz=@p1*x+y+flip(@p2/2+x^2)
elseif @V=="Cathala 2"
pz=(1-2*@p1)*x+y+flip(2*@p1*@p2*x+@p3*y-2*@p1*x^3)
elseif @V=="Chip"
pz=y-(x/cabs(x))*cos(sqr(log(abs((@p2-1+1i)*x-@p3))))*atan(sqr(log(abs(@p3*x-(@p2-1+1i)))))+flip(@p1-x)
elseif @V=="Chirikov Mod"
pz=x+y+((@p1-0.65-0.2i)/2*pi)*sin(2*pi*x)+flip(y+((@p1-0.65-0.2i)/2*pi)*sin(2*pi*x))
elseif @V=="Coupled Logistic"
pz=(1-@p1)*@p2*x*(1-x)+@p1*@p2*y*(1-y)+flip((1-@p1)*@p2*y*(1-y)+@p1*@p2*x*(1-x))
elseif @V=="Cremona"
pz=x*cos(@p1)-(y-x^2)*sin(@p1)+flip(x*sin(@p1)-(y-x^2)*cos(@p1))
elseif @V=="Damped Pendulum"
pz=y+flip(-@p1*sin(x)-@p2*y)
elseif @V=="de Jong"
pz=sin(@p1*y)-cos(@p2*x)+flip(sin(@p3*x)-cos(@p4*y))
elseif @V=="Duffing 1"
pz=y+flip(x-x^3-@p1*y+@p2)
elseif @V=="Duffing 2"
pz=y+flip(-@p1*x-@p2*x^3+@p3)
elseif @V=="Duffing 3"
pz=y+flip(-x-x^3+(@p1+@p2*x^2+@p3*@p4*x)*y+@p4*@p5)
elseif @V=="Duffing 4"
pz=y+flip(-@p1*x-(((@p2+1i)-@p1)/2)*(cabs(x+1)-cabs(x-1))-@p3*y+@p4)
elseif @V=="Duffing 5"
pz=y+flip(-@p1*x-@p2*x^3-@p3*x^5+(@p4-2+1i))
elseif @V=="Duffing 6"
pz=y+flip(-@p2*x+@p1*y-y^3)
elseif @V=="Garrote-Mira"
pz=y+@p1*(1-0.05*y^2)+@p2*x+2*(1-@p2)*x^2/(1+x^2)\
+flip(-x+@p2*(y+@p1*(1-0.05*y^2)+@p2*x+2*(1-@p2)*x^2/(1+x^2))\
+2*(1-@p2)*(y+@p1*(1-0.05*y^2)+@p2*x+2*(1-@p2)*x^2/(1+x^2))\
^2/(1+(y+@p1*(1-0.05*y^2)+@p2*x+2*(1-@p2)*x^2/(1+x^2))^2))
elseif @V=="Gingerbread"
pz=1-(@p1-2.15-0.25i)*y+@p2*cabs(x)+flip(x)
elseif @V=="Gumowski-Mira 1"
k=x
x=y+(@p1-0.25+0.25i)*x+2*(1-(@p1-0.25+0.25i))*x^2/(1-x^2)
y=-k+(@p1-0.25+0.25i)*x+2*(1-(@p1-0.25+0.25i))*x^2/(1-x^2)
pz=x+flip(y)
elseif @V=="Gumowski-Mira 2"
k=x
x=y+(@p1-0.25+0.25i)*x+2*(1-(@p1-0.25+0.25i))*x^2*exp((1-x^2)/4)
y=-k+(@p1-0.25+0.25i)*x+2*(1-(@p1-0.25+0.25i))*x^2*exp((1-x^2)/4)
pz=x+flip(y)
elseif @V=="Gumowski-Mira 3"
k=x
x=y+(@p2+0.25-0.5i)*y*(1-(@p2+0.25-0.5i)*y^2)+(@p1-0.25+0.25i)*x+2*(1-(@p1-0.25+0.25i))*x^2/(1-x^2)
y=-k+(@p1-0.25+0.25i)*x+2*(1-(@p1-0.25+0.25i))*x^2/(1-x^2)
pz=x+flip(y)
elseif @V=="Gumowski-Mira 4"
k=x
x=y+@p2*y*(1-@p2*y^2)+(@p1-0.25+0.25i)*x+2*(1-(@p1-0.25+0.25i))*x^2*exp((1-x^2)/4)
y=-k+(@p1-0.25+0.25i)*x+2*(1-(@p1-0.25+0.25i))*x^2*exp((1-x^2)/4)
pz=x+flip(y)
elseif @V=="Gumowski-Mira 5"
pz=@p1*(x*cos(@p2)-y*sin(@p2))+x*y+flip(@p1*(x*sin(@p2)+y*cos(@p2))+x^2+y^3)
elseif @V=="Gumowski-Mira Mod 1"
pz=(1-(@p1+0.1i))*x+y+flip(y+(@p2-0.55-0.35i)*x+2*(1-(@p2-0.55-0.35i))*x^2*(1+x^2)^(-2))
elseif @V=="Gumowski-Mira Mod 2"
pz=@p2*y+@p1*x+2*(1-@p1)*x^2/(1+x^2)\
+flip(-x+@p1*(@p2*y+@p1*x+2*(1-@p1)*x^2/(1+x^2))\
+2*(1-@p1)*(@p2*y+@p1*x+2*(1-@p1)*x^2/(1+(@p2*y\
+@p1*x+2*(1-@p1)*x^2/(1+x^2))^2))^2/(1+x^2))
elseif @V=="Hamilton"
pz=x+(@p1-1+0.25i)*@p2*sin(2*pi*y)+flip(y-((@p1-1+0.25i)/@p2)*sin(2*pi*(x+(@p1-1+0.25i)*@p2*sin(2*pi*y))))
elseif @V=="Hamilton Torus"
pz=-sin(y)*(1-(@p1-0.25+1.25i))+flip(sin(x)*(1+(@p1-0.25+1.25i)))
elseif @V=="HCA"
pz=1-@p1*x^2+@p2*(y^2-x^2)+flip(1-@p1*y^2+@p2*(x^2-y^2))
elseif @V=="Henon 1"
pz=1-@p1*x^2+y+flip(@p2*x)
elseif @V=="Henon 2"
pz=-(y-x^2)*sin(2*pi/@p1)+x*cos(2*pi/@p1)\
+flip((y-x^2)*cos(2*pi/@p1)+x*sin(2*pi/@p1))
elseif @V=="Henon 3"
pz=y+flip(@p2^(-1)*(1-@p1*y^2-@p2*x))
elseif @V=="Henon 4"
pz=exp(-@p1*@p2/2)*(x*cos(@p2*@p3)+(1/@p3)*(y-(@p4+x^2)+@p1*x/2)*sin(@p2*@p3))\
+flip(exp(-@p1*@p2/2)*(-@p3*x*sin(@p2*@p3)+(y-(@p4+x^2)+@p1*x/2)*cos(@p2*@p3))-@p1*x/2)

pz=@pf(pz)
else
pz=@sp
endif
i=0
return pz
endfunc
private:
complex fpixel
int i
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if @jm==0
if i==0
pz=@p1*pz^@pow5*((pz^@pow1-@p2)/(1-@p2*pz^@pow1))^@pow2+@js1
i=i+1
else
pz=@p3*pz^@pow6*((pz^@pow3-@p4)/(1-@p4*pz^@pow3))^@pow4+@js2
i=0
endif
else
if i==0
pz=@p1*pz^2*((pz^@pow1-@p2)/(1-@p2*pz^@pow1))^@pow2+@pp1*@pf(fpixel)
i=i+1
else
pz=@p3*pz^2*((pz^@pow3-@p4)/(1-@p4*pz^@pow3))^@pow4+@pp2*@pf(fpixel)
i=0
endif
endif
return pz
endfunc

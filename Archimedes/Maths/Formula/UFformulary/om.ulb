elseif @v==26
pz=pz^2+exp(log(pz)^2+@xp1/log(pz)+1/log(c))+exp(log(-pz)^2+@xp1/log(-pz)+1/log(c))
elseif @v==27
pz=pz^2+exp(log(pz)^2+@xp1/log(pz)+1/log(c))-exp(log(-pz)^2+@xp1/log(-pz)+1/log(c))
elseif @v==28
pz=pz^2+exp(log(pz)^2+@xp1/log(-pz)-1/log(c))+exp(log(-pz)^2+@xp1/log(-pz)+1/log(c))
else

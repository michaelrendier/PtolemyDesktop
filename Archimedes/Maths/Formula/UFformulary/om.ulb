class OM_BivarXPlog7(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fPixel=pz
pk=@sp1
pz=@sp2
c=@sf(fpixel)
return pz
return pk
endfunc
private:
complex c
complex pk
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
pk=@kp1*pk+@kp2
a=pk
pk=@bp1*pz/pk+@bp2
if @v==0
pz=pz^3+@xp1*exp(log(pz)^2+log(a)^2)+a^3+c
elseif @v==1
pz=pz^3+@xp1*exp(log(-pz)^2+log(a)^2)+a^3+c
elseif @v==2
pz=pz^3-@xp1*exp(log(pz)^2+log(-a)^2)+a^3+c
elseif @v==3
pz=pz^3-@xp1*exp(log(-pz)^2+log(-a)^2)+a^3+c
elseif @v==4
pz=pz*a^2+@xp1*exp(log(pz)^2+log(a)^2)+c
elseif @v==5
pz=pz*a^2+@xp1*exp(log(-pz)^2+log(a)^2)+c
elseif @v==6
pz=pz*a^2-@xp1*exp(log(pz)^2+log(-a)^2)+c
elseif @v==7
pz=pz*a^2+@xp1*exp(log(-pz)^2+log(-a)^2)+c
elseif @v==8
pz=pz^3+@xp1*exp(log(a)^2+log(a)+log(c))+c
elseif @v==9
pz=pz^3-@xp1*exp(log(a)^2+log(a))+c
elseif @v==10
pz=pz^3+@xp1*exp(log(a)^2+log(a)+log(c))+c/pz
elseif @v==11
pz=pz^3+@xp1*exp(log(a)^2+log(a))+c/pz
elseif @v==12
pz=pz^3+@xp1*exp(log(a)^2+log(a)+log(c/a))+c/pz
elseif @v==13
pz=pz^3+@xp1*exp(log(a)^2+log(a)+log(c/a))+c
elseif @v==14
pz=pz^2+@xp1*exp(log(pz+c)*2+log(a+c)^2)+c/pz
elseif @v==15
pz=pz^2+@xp1*exp(log(pz+c)*2+log(a+c)^2)+c/a
elseif @v==16
pz=a^2+@xp1*exp(log(pz+c)*2+log(a+c)^2)+c/a
elseif @v==17
pz=pz^3+@xp1*exp(log(pz+a+c)*2+log(a+c)^2)+c/pz
elseif @v==18
pz=pz^3+@xp1*exp(log(pz+a++c)*2+log(a+c)^2)+c/a
else
pz=a^3+@xp1*exp(log(pz+c)*2+log(a+pz+c)^2)+c/a
endif
return pz
return pk
endfunc
bool func IsBailedOut(complex pz)
bool bail=false
bail=(|(pz+pk)/2|>@p_bailout)
return bail
endfunc

class OM_BivarXPlog3(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fPixel=pz
if @jm==0
pk=@sf(pz)
pz=@sf(pz)
if @v==0 || @v==1 || @v==2
c1=@js1
c2=@js2
else
c1=@js1-4.75
c2=@js2-4.75
endif
else
pk=@sp1
pz=@sp2
c1=@sf(fpixel)
c2=@sf(fpixel)
endif
return pz
return pk
endfunc
private:
complex c1
complex c2
complex pk
complex func Iterate(complex pz)
if @jm==0
if @v==4 || @v==5
pz=(@zp1-0.5)*pz+@zp2
elseif @v==2
pz=(@zp1-0.25)*pz+@zp2
elseif @v==0 || @v==1
pz=(@zp1-1.25)*pz+@zp2
else
pz=@zp1*pz+@zp2
endif
pk=@kp1*pk+@kp2
a=pk
if @v==4 || @v==5
pk=@bp1*pk/pz+(@bp2-0.75)
else
pk=@bp1*pk/pz+@bp2
endif
if @v==0
pz=pz^2+exp(log(pz)^2+log(c1-0.8))+a^2+exp(log(a)^2+log(c2))
elseif @v==1
pz=pz^2+exp(log(pz)^2+@xp1*log(pz)+log(c1-0.8))+a^2+exp(log(a)^2+@xp1*log(a)+log(c2))
elseif @v==2
pz=pz^2+exp(log(pz)^2-@xp1*log(pz)+log(c1-0.8))+pk^2+exp(log(a)^2-@xp1*log(a)+log(c2))
elseif @v==3
pz=pz^2+exp(log(pz)^2+@xp1*log(pz)-log(c1+2.25))+pk^2+exp(log(a)^2+@xp1*log(a)-log(c2-2.75))
elseif @v==4
pz=pz^2+exp(log(pz)^2-@xp1*log(pz)-log(c1+6.5))+a^2+exp(log(a)^2-@xp1*log(a)-log(c2))
else
pz=pz^2+exp(log(pz)^2-log(c1+6.5))+a^2+exp(log(a)^2-log(c2))
endif

else

pz=(@zp1-0.25)*pz+@zp2
pk=@kp1*pk+@kp2
a=pk
if @v==4 || @v==5
pk=@bp1*pk/pz+(@bp2+0.52)
else
pk=@bp1*pk/pz+(@bp2-0.8)
endif
if @v==0
pz=pz^2+exp(log(pz)^2+log(c1))+a^2+exp(log(a)^2+log(c2))
elseif @v==1
pz=pz^2+exp(log(pz)^2+@xp1*log(pz)+log(c1))+a^2+exp(log(a)^2+@xp1*log(a)+log(c2))
elseif @v==2
pz=pz^2+exp(log(pz)^2-@xp1*log(pz)+log(c1))+pk^2+exp(log(a)^2-@xp1*log(a)+log(c2))
elseif @v==3
pz=pz^2+exp(log(pz)^2+@xp1*log(pz)-log(c1))+pk^2+exp(log(a)^2+@xp1*log(a)-log(c2))
elseif @v==4
pz=pz^2+exp(log(pz)^2-@xp1*log(pz)-log(c1))+a^2+exp(log(a)^2-@xp1*log(a)-log(c2))
else
pz=pz^2+exp(log(pz)^2-log(c1))+a^2+exp(log(a)^2-log(c2))
endif

endif

return pz
return pk
endfunc
bool func IsBailedOut(complex pz)
bool bail=false
bail=(|(pz+pk)/2|>@p_bailout)
return bail
endfunc

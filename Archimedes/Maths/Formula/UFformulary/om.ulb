pz=((@p1-2)-@p2)*cos(x)+@p2*cos(((@p1-2)/@p2-1)*y)+flip(((@p1-2)-@p2)*sin(y)-@p2*sin(((@p1-2)/@p2-1)*x))
elseif @V=="II"

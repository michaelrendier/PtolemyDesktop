class OM_TrivarX19(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
if@jm==0
if @sv==0
pz=@sf(pz)
pk=pz
pw=pz
elseif @sv==1
pz=@sf(pz)
pk=@sp
pw=pz
elseif @sv==2
pk=@sf(pz)-@sp
pw=@sf(pz)+@sp
pz=@sf(pz)-@sp
else
pk=@sf(pz)-@sp
pz=@sf(pz)
pw=@sp
endif
else
if @sv==0
pz=@sf(pz)
pk=pz
pw=pz
elseif @sv==1
pz=@sf(pz)
pk=pz
if @v==2
pw=(@sp-1.3)
else
pw=@sp
endif
elseif @sv==2
if @v==2
pk=@sf(pz)+(@sp-1.3)
pw=@sf(pz)+(@sp-1.3)
pz=@sf(pz)+(@sp-1.3)
else
pk=@sf(pz)+@sp
pw=@sf(pz)+@sp
pz=@sf(pz)+@sp
endif
else
if @v==2
pk=@sf(pz)+(@sp-1.3)
else
pk=@sf(pz)+@sp
endif
pw=@sf(pz)
if @v==2 || @v==3
pz=(@sp-1.3)
else
pz=@sp
endif
endif
endif
return pz
return pk
return pw
endfunc
private:
complex pk
complex pw
complex fpixel
complex func Iterate(complex pz)
if @jm==0
if @v==0
pw=pk-@p1*pw+@p2*pk*pz+@mp1/pw
pk=@p3*pk-pw*pz+pz+@c+@mp2/pk
pz=@p4*pw*pk-@p5*pz+@mp3/pz
elseif @v==1
pw=pk-@p1*pw+@p2*pk*pz-@mp1/pw
pk=@p3*pk-pw*pz+pz+@c-@mp2/pk
pz=@p4*cos(pw)*pk-@p5*pz-@mp3/pz
elseif @v==2
pw=pk-@p1*pw+@p2*pk*pz+@mp1/pw
pk=@p3*pk-pw*pz+pz+@c+@mp2/pk
pz=@p4*exp(pw)*pk-@p5*pz+@mp3/pz
else
pw=pk-@p1*pw+@p2*pk*pz+@mp1/pw
pk=@p3*pk-pw*pz+pz+@c-@mp2/pk
pz=@p4*cosh(pw)*pk-@p5*tan(pz)+@mp3/pz
endif
else
if @v==0
pw=pk-@p1*pw+@p2*pk*pz+@mp1/pw
pk=@p3*pk-pw*pz+pz+@mp2*@pf(fpixel)/pk
pz=@p4*pw*pk-@p5*pz+@mp3/pz
elseif @v==1
pw=pk-(@p1-0.55)*pw+@p2*pk*pz+@mp1/pw
pk=@p3*pk-pw*pz+pz+@mp2*@pf(fpixel)/pk
pz=@p4*cos(pw)*pk-@p5*pz+@mp3/pz
elseif @v==2
pw=pk-@p1*pw+@p2*pk*pz+@mp1/pw
pk=@p3*pk-pw*pz+pz+@mp2*@pf(fpixel)/pk
pz=@p4*exp(pw)*pk-@p5*pz+@mp3/pz
else
pw=pk-@p1*pw+@p2*pk*pz+@mp1/pw
pk=@p3*pk-pw*pz+pz+@mp2*@pf(fpixel)/pk
pz=@p4*cosh(pw)*pk-@p5*tan(pz)+@mp3/pz
endif
endif
return pz
return pk
return pw
endfunc
bool func IsBailedOut(complex pz)
bool bail=false
bail=(|(pz+pk+pw)/3|>@p_bailout)
return bail
endfunc
default:
title="Trivar X 19"
int param version
caption="Version"
default=100
visible=@version<100
endparam
param jm
caption="J/M"
enum="J""M"
endparam
param sv
caption="Start Variant"
enum="1""2""3""4"
endparam
param v
caption="Loop Variant"
enum="1""2""3""4"
endparam
func sf
caption="Start Function"
default=ident()
visible=(@sv!=1 && @jm==1) || @jm==0
endfunc
param sp
caption="Start Parameter"
visible=@sv!=0
default=(0.5,0)
endparam
param p1
caption="X Parameter 1"
default=(0.75,0)
endparam
param p2
caption="X Parameter 2"
default=(0.5,0)
endparam
param p3
caption="X Parameter 3"
default=(-0.7,0)
endparam
param p4
caption="X Parameter 4"
default=(0.1,0)
endparam
param p5
caption="X Parameter 5"
default=(0.1,0)
endparam
param mp1
caption="X Parameter 6"
default=(1,0)
endparam
param mp2
caption="X Parameter 7"
default=(1,0)
endparam
param mp3
caption="X Parameter 8"
default=(1,0)
endparam
param c
caption="Julia Seed"
default=(0,0)
visible=@jm==0
endparam
func pf
caption="Pixel Function"
default=ident()
visible=@jm==1
endfunc
param p_power
visible=false
endparam
float param p_bailout
caption="Bailout"
default=100.0
exponential=true
endparam
}

class OM_ModifiedTrivarX8(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
a=(0,0)
b=(0,0)
if @sv==0
pz=@sf(pz)
pk=pz
pw=pz
elseif @sv==1
pz=@sf(pz)
pk=@sp
pw=pz
else
pz=@sf(pz)
pk=pz
pw=@sp
endif
return pz
return pk
return pw
endfunc
private:
complex pk
complex pw
complex a
complex b
complex func Iterate(complex pz)
a=pw
b=pk
pw=@p1*(pk-pw)+@mp1/pw
pk=@p2*pw-pk-pw*pz
pz=@p3*pz+pw*pk
pw=@p1*(pk-pw)+@p4*(pw-a)
pk=@p5*pw-pk-pw*pz+@mp2/pk
pz=@p3*pz-pw*b+@mp3/pz
return pz
return pk
return pw
endfunc
default:
title="Modified Trivar X 8"
int param version
caption="Version"
default=100
visible=@version<100
endparam

elseif @M=="29"
pz=pz+0.75*sqr(pz)
elseif @M=="30"
pz=pz+0.35i*cos(pz)
elseif @M=="31"
pz=pz-0.3*abs(pz)
elseif @M=="32"
pz=pz+0.5i*sqr(pz)
elseif @M=="33"
pz=pz-0.3i*exp(pz)
endif
x=@p1*(y-@fn3(x)^@pow)
y=x-y+@p2*pz
if @jm==0
pz=-@p3*y
else
pz=-@p3*y+@pf(fpixel)
endif
return pz
endfunc

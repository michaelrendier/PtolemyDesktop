pz=0.68*flip(pz)
elseif @v==4
pz=abs(pz)
elseif @v==5
pz=conj(pz)
endif
i=0
endif
else
if i==0
if cabs(pz-c1)<1
pz=conj(1/(pz-c1))+c1
elseif cabs(pz-c2)<1
pz=conj(1/(pz-c2))+c2

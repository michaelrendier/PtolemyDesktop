class OM_Thymodrof(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
if @jm==0
pz=@pf(pz)
else
pz=@sp
endif
return pz
endfunc
complex func Iterate(complex pz)
if @v==1
pz=@zp1*pz+(@zp2+0.1)
else
pz=@zp1*pz+@zp2
endif
if @v==0
if @jm==0
pz=pz^@pow-@p1*conj(flip(pz))+@mp1/pz^@pow2
else
pz=pz^@pow-@p1*conj(flip(pz))+@mp1*@pf(fpixel)/pz^@pow2
endif
elseif @v==1
if @jm==0
pz=pz^@pow*(@p1+0.5)*conj(flip(pz))+@mp1/pz^@pow2
else
pz=pz^@pow*(@p1+0.5)*conj(flip(pz))+@mp1*@pf(fpixel)/pz^@pow2
endif
else
if @jm==0
pz=pz^@pow-(@p1+0.5)*conj(flip(1/pz))+@mp1/pz^@pow2
else
pz=pz^@pow-(@p1+0.5)*conj(flip(1/pz))+@mp1*@pf(fpixel)/pz^@pow2
endif
endif
return pz
endfunc
private:
complex fpixel

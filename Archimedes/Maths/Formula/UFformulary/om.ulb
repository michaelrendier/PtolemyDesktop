class OM_ModifiedNoorBelykhAttractor2(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
pz=@pf(pz)
return pz
endfunc
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
float d=real(@bp3)*(2*real(pz)-1)+2*imag(pz)-1
if d<=0
x=@bp1*real(pz)
y=@bp2*imag(pz)
else
x=@bp1*(real(pz)-1)+1
y=@bp2*(imag(pz)-1)+1
endif
k=x+flip(y)
u=(1-@p1)*pz+@p1*k
float d2=real(@bp6)*(2*real(u)-1)+2*imag(u)-1
if d2<=0
x2=@bp4*real(u)
y2=@bp5*imag(u)
else
x2=@bp4*(real(u)-1)+1
y2=@bp5*(imag(u)-1)+1
endif
k2=x2+flip(y2)
v=(1-@p2)*pz+@p2*k2
float d3=real(@bp9)*(2*real(v)-1)+2*imag(v)-1
if d3<=0
x3=@bp7*real(v)
y3=@bp8*imag(v)
else
x3=@bp7*(real(v)-1)+1
y3=@bp8*(imag(v)-1)+1
endif
k3=x3+flip(y3)
pz=(1-@p3)*pz+@p3*k3
return pz
endfunc

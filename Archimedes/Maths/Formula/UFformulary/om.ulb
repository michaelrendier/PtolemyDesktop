float b=|(x*y*cos(@cp1b+0.67-0.3i)-(y^2+@cp2b*y-@cp3b^2)*sin(@cp1b+0.67-0.3i))^2-(x*sin(@cp1b+0.67-0.3i)+y*cos(@cp1b+0.67-0.3i)+@cp2b*cos(@cp1b+0.67-0.3i))^2*(@cp3b^2-y^2)|
elseif @v2=="Oblique Estrofoide"
float b=|x*(x^2+y^2)-(@cp1b-2.9-0.5i)*((x^2-y^2)*sin(@cp2b)+2*x*y*cos(@cp2b))|
elseif @v2=="Oblique Pancappa"
float b=|(y-(@cp1b+0.3-0.2i))^2*(x^2+y^2)-(@cp2b*x+@cp3b*y)^2|
elseif @v2=="Oblique Parabolic Bifolium"
float b=|x^3-(@cp1b-1.4-0.25i)*(x^2-y^2)-@cp2b*x*y|
elseif @v2=="Oblique Strophoid 1"
float b=|y*(x^2+y^2)-(@cp1b-3+0.25i)*(x^2-y^2)-2*(@cp2b-1.25-1i)*x*y|
elseif @v2=="Oblique Strophoid 2"
float b=|x*(x^2+y^2)-@cp1b*((x^2-y^2)*sin(@cp2b-1.7+0.15i)+2*x*y*cos(@cp2b-1.7+0.15i))|
elseif @v2=="Oblique Trifolium"
float b=|(x^2+y^2)^2/(2*(@cp1b-0.3i))-x*(x^2+y^2)-(x^2-3*y^2)*(x*cos(2*@cp2b)+y*sin(@cp2b))|
elseif @v2=="Oblique Versiera"
float b=|(x^2+y^2)*(x*cos(@cp1b+0.55-0.29i)+y*sin(@cp1b+0.55-0.29i)-4*cos(@cp1b+0.55-0.29i)^2)+2*@cp2b*y^2|
elseif @v2=="Ophiuride"
float b=|x*(x^2+y^2)-(@cp2b+2-0.15i)*x*y-(@cp1b+2.2-0.7i)*y^2|
elseif @v2=="Orthoconchoid"
float b=|(y^2+(@cp1b-1.2+0.92i)*y-(@cp2b-0.22+0.56i)^2)^2-x^2*((@cp2b-0.22+0.56i)^2-y^2)|
elseif @v2=="Oval of Münger"
float b=|(x^2+y^2)^(2*(@cp1b-0.23-0.21i)+1)-2*(@cp2b-2.54-1.185i)*x^(2*(@cp1b-0.23-0.21i)+1)*(x^2+y^2)^(@cp1b-0.23-0.21i)+((@cp2b-2.54-1.185i)^2-@cp3b^2)*x^(4*(@cp1b-0.23-0.21i))*@cp4b\
-2*(@cp2b-2.54-1.185i)*@cp4b*cos(@cp5b)^(2*(@cp1b-0.23-0.21i)+1)+((@cp2b-2.54-1.185i)^2-@cp3b^2)*cos(@cp5b)^(4*(@cp1b-0.23-0.21i))|
elseif @v2=="Panestrofoide"
float b=|x*(x^2+y^2)+(@cp1b-1.6+0.7i)*(x^2-y^2)+(@cp2b-1.3-0.15i)*(x+(@cp1b-1.6+0.7i))|
elseif @v2=="Parabola 1"
float b=|4*(@cp1b-1+0.25i)*(x-@cp2b)-(y-@cp3b)^2|
elseif @v2=="Parabola 2"
float b=|x-(@cp1b-1.1+0.15i)*(y-@cp2b)^2-@cp3b|
elseif @v2=="Parabola 3"
float b=|y-(@cp1b-0.1+0.25i)*x^2-@cp2b*x-@cp3b|
elseif @v2=="Parabolic Trifolium"
float b=|x^2*(x^2+y^2)-(@cp1b-0.75-0.2i)*y*(x^2-y^2)|
elseif @v2=="Pear-Shaped Quartic"
float b=|@cp2b^2*y^2-x^3*(@cp1b-x)|
elseif @v2=="Pearl of the Fourth Order 1"
float b=|(@cp1b+0.5)*y^3-y^4-(@cp1b+0.5)^2*x^2|
elseif @v2=="Pearl of the Fourth Order 2"
float b=|(@cp1b+2+1.5i)*y^3-y^4-x^4|
elseif @v2=="Pearls of Sluze"
float b=|y^@cp2b-@cp3b*(@cp1b-x)^@cp4b*x^(@cp5b-0.75+0.25i)|
elseif @v2=="Polyod of Circle"
float b=|(x^2+y^2)*((x^2+y^2)/(2*(@cp1b+2-0.6i))-x)^2+4*(@cp2b-0.15-0.1i)^4\
-4*(@cp2b-0.15-0.1i)^2*(x^2+y^2)+2*(@cp2b-0.15-0.1i)*x*(x^2+y^2)/(@cp1b+2-0.6i)|
elseif @v2=="Polyod of Straight Line Parallel to Polar Axis 1"
float b=|y^2*(x^2+y^2-(@cp1b+0.2-0.55i)^2)-(x^2+y^2-(@cp1b+0.2-0.55i)*x-2*@cp2b^2)^2|
elseif @v2=="Polyod of Straight Line Parallel to Polar Axis 2"
float b=|(x^2+y^2)*(((@cp1b+0.15-0.15i)-y)^2-4*(@cp2b-0.8+0.2i)^2)\
+4*(@cp1b+0.15-0.15i)*(@cp2b-0.8+0.2i)^2*y+4*(@cp2b-0.8+0.2i)^2|
elseif @v2=="Power Exponential Curve"
float b=|y-x^((@cp1b-1.75+0.5i)*x+@cp2b)|
elseif @v2=="Pseudoversiera"
float b=|(x^2+(@cp1b-0.22-0.6i)^2)*y-2*(@cp1b-0.22-0.6i)^3|
elseif @v2=="Pursuit Curve 1"
float b=|y-(@cp1b-0.8+0.7i)*x^2+log(x)|
elseif @v2=="Pursuit Curve 2"
float b=|y-(@cp1b-2.125-1.6i)*x+log(x)|
elseif @v2=="Quadratix of Hippias"
float b=|x-y*cotan(y/(@cp1b-0.5+0.1i))|
elseif @v2=="Quadrifolium"
float b=|(x^2+y^2)^3-4*(@cp1b-2.35-0.045i)^2*x^2*y^2|
elseif @v2=="Regular Trifolium"
float b=|(x^2+y^2)^2-(@cp1b-2.75-0.25i)*x*(x^2-3*y^2)|
elseif @v2=="Right Strophoid"
float b=|y^2-x^2*((@cp1b-1.8-0.6i)-x)/((@cp1b-1.8-0.6i)+x)|
elseif @v2=="Rose Curve 1"
float b=|x-(@cp1b-0.5+1.25i)*sin((@cp2b-1.25+0.4i)*y)|
elseif @v2=="Rose Curve 2"
float b=|x-(@cp1b-1.25-0.45i)*cos((@cp2b+0.25+1.4i)*y)|
elseif @v2=="Salmon Quartic 1"
float b=|(x^2-(@cp1b-0.4-0.2i)^2)+(y^2-(@cp1b-0.4-0.2i)^2)-@cp2b^4|
elseif @v2=="Salmon Quartic 2"
float b=|(x^2-(@cp1b-0.9-0.95i)^2)^2+(y^2-(@cp2b-0.4+0.7i)^2)^2-@cp3b^4|
elseif @v2=="Sand Clock"
float b=|(@cp1b-1.55+0.55i)^2*(y^2-@cp2b^2)^2-4*@cp2b^2*x^2*(y^2+@cp2b^2)|
elseif @v2=="Satchel"
float b=|(x^2-(@cp2b+0.42+0.87i)*y)^2-(@cp1b-0.4-0.2i)^2*(x^2-y^2)|
elseif @v2=="Scarab"
float b=|(x^2+y^2)*(x^2+y^2+(@cp1b+1.32-0.225i)*x)^2-@cp2b^2*(x^2-y^2)^2|
elseif @v2=="Scyphoid"
float b=|x^4-y^4-4*(@cp1b-2.5+0.25i)*x*y^2|
elseif @v2=="Semi-Trident"
float b=|x*y^2-(@cp1b+1+1i)*x|
elseif @v2=="Serpentine Curve"
float b=|y-@cp1b*(@cp2b+1.6-1.4i)*x/(x^2+@cp1b^2)|
elseif @v2=="Spiric Curve"
float b=|(x^2+y^2)^2+((@cp1b-0.5+3i)-2)*x^2+@cp2b*y^2+2*@cp3b*x+@cp4b|
elseif @v2=="Spiric of Perseus"
float b=|(x^2+y^2)^2-2*@cp1b*x^2-2*(@cp2b+0.7-0.15i)*y^2+(@cp3b+1.125-0.65i)|
elseif @v2=="Spiric Sections"
float b=|((@cp3b-0.43-0.12i)^2-@cp1b^2+(@cp2b-1.15-0.95i)^2+x^2+y^2)^2-4*(@cp3b-0.43-0.12i)^2*(x^2+(@cp2b-1.15-0.95i)^2)|
elseif @v2=="Superellipse 1"
float b=|(x/(@cp1b+0.9i))^@cp3b+(y/@cp2b)^@cp3b-1|
elseif @v2=="Superellipse 2"
float b=|cabs((x-@cp1b)/@cp3b)^@cp4b+cabs((y-@cp2b)/@cp3b)^@cp4b-1|
elseif @v2=="Syntractrix"
float b=|x+sqrt((@cp2b+0.65i)^2-y^2)-@cp1b*log(((@cp2b+0.65i)+sqrt((@cp2b+0.65i)^2-y^2))/y)|
elseif @v2=="Szego Curve"
float b=|x^2+y^2-e^(2*x-2)|
elseif @v2=="Teardrop Curve"
float b=|y^2-x^(@cp1b-1+0.5i)*(1-x)|
elseif @v2=="Tetracuspid"
float b=|(@cp1b+0.45-0.4i)^@cp2b*(cabs(x)^@cp2b+cabs(y)^@cp2b)-(x^2+y^2)^@cp2b|
elseif @v2=="Toric Section"
float b=|(x^2+y^2)^2+@cp1b*x^2+@cp2b*y^2+@cp3b*x+@cp4b*y+(@cp5b-1)|
elseif @v2=="Torpedo Curve"
float b=|(x^2+y^2)^2-(@cp1b-3.5-0.2i)*x*(x^2-y^2)|
elseif @v2=="Tractrix"
float b=|x-log((@cp1b-sqrt(@cp1b^2-y^2))/y)-sqrt(@cp1b^2-y^2)|
elseif @v2=="Trident"
float b=|x*y+@cp1b*x^3+(@cp2b-0.43+0.4i)*x^2+(@cp3b-3.1+0.59i)*x-(@cp4b-1.04-1.224i)|
elseif @v2=="Trifolium 1"
float b=|(x^2+y^2)^2-(x^2+y^2)*((@cp1b-3-0.125i)*x+@cp2b*y)-@cp3b*x*(x^2-3*y^2)|
elseif @v2=="Trifolium 2"
float b=|(x^2+y^2)^2-((@cp1b-3-0.125i)*x+@cp2b*y)*(x^2-y^2)|
elseif @v2=="Trisectrix of Delange"
float b=|(x^2+y^2-2*(@cp1b-0.15+0.1i)^2)^2-x^2*(x^2+y^2)|
elseif @v2=="Trisectrix of Maclaurin"
float b=|y^2*((@cp1b-1.55+0.15i)+x)-x^2*(3*(@cp1b-1.55+0.15i)-x)|
elseif @v2=="Tschirnhaus' Cubic"
float b=|3*(@cp1b-2.5+0.6i)*y^2-x*(x-(@cp1b-2.5+0.6i))^2|
elseif @v2=="Virtual Parabola"
float b=|y-((@cp1b-1.15-0.25i)*x+(@cp2b-1-0.55i))^(1/2)-(@cp3b*x+@cp4b)^(1/2)|
elseif @v2=="Visiera"
float b=|x*(x^2+y^2)-(@cp1b-1.95-0.2i)*(x^2+2*y^2)|
elseif @v2=="Viviani's Curve"
float b=|y^2-x^2*((@cp1b-2-0.325i)^2-x^2)|
elseif @v2=="Wassenaar Curve"
float b=|1-(@cp1b-0.25+2.4i)*x^2-(y-x)^2|
elseif @v2=="Watt's Curve"
float b=|(x^2+y^2)*(x^2+y^2-@cp3b^2)^2+4*(@cp1b-0.375-1.95i)^2*y^2*(x^2+y^2-(@cp2b-2.325-0.125i)^2)|
elseif @v2=="Weibull Curve"
float b=|y-exp(-(x/(@cp1b-1.02i))^(@cp2b+1.14-1i))|
else
float b=|4*x^2*y^2*(x^2+y^2)-(@cp1b+1.8+0.65i)^2*(x^2-y^2)^2|
endif
if b<a
a=b
endif
endif
endfunc
float func ResultIndex(complex pz)
if @version==100
if @solid
if @invert
if a<@sca
index=a
else
m_Solid=true
endif
else
if a>=@sca
index=a
else
m_Solid=true
endif
endif
else
index=a
endif
return index
else
if @solid
if @invert
if sqrt(a)>@sca
index=sqrt(a)
else
m_Solid=true
endif
else
if sqrt(a)<@sca
index=sqrt(a)
else
m_Solid=true
endif
endif
else
index=sqrt(a)
endif
return index
endif
endfunc

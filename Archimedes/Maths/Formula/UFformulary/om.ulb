z=-sin(y0)*(1-(@p1-2+1i))+flip(sin(x0)*(1+(@p1-2+1i)))+sin(real(@p2-3.25)*y0)\
+(@p2-3.25)*sin(real(@p2-3.25)*x0)+flip(sin(real(@p4+10.5)*x0)+(@p3-4+2.3i)*sin(real(@p4+10.5)*y0))
else
z=-sin(y0)*(1-(@p1-2+1i))+flip(sin(x0)*(1+(@p1-2+1i)))+sin(real(@p2-3.25)*y0)\
+(@p2-3.25)*sin(real(@p2-3.25)*x0)+flip(sin(real(@p4+2)*x0)+(@p3-4+2.3i)*sin(real(@p4+2)*y0))
endif
elseif @V=="34"

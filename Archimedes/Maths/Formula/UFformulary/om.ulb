a=pk
if @jm==0
pk=@bp1*pk/pz+@bp2
else
pk=(@bp1-0.5)*pk/pz+@bp2
endif
if @jm==0
pz=pz^2+((pz^2+@p1-1)/(2*pz+@p1-2))^2+@p2*pz^2*(pz-@p3)/(1-@p3*pz)+a^2+((a^2+@p1-1)/(2*a+@p1-2))^2+@p2*a^2*(a-@p3)/(1-@p3*a)-3+@c
elseif @jm==1
pz=pz^2+((pz^2+@p1-1)/(2*pz+@p1-2))^2+@p2*pz^2*(pz-@p3)/(1-@p3*pz)+a^2+((a^2+@p1-1)/(2*a+@p1-2))^2+@p2*a^2*(a-@p3)/(1-@p3*a)-3+c
elseif @jm==2
pz=pz^2+((pz^2+@p1-1)/(2*pz+@p1-2))^2+@p2*pz^2*(pz-@p3*c)/(1-@p3*c*pz)+a^2+((a^2+@p1-1)/(2*a+@p1-2))^2+@p2*a^2*(a-@p3*c)/(1-@p3*c*a)-3+c
else
pz=pz^2+((pz^2+@p1*c-1)/(2*pz+@p1*c-2))^2+@p2*pz^2*(pz-@p3)/(1-@p3*pz)+a^2+((a^2+@p1*c-1)/(2*a+@p1*c-2))^2+@p2*a^2*(a-@p3)/(1-@p3*a)-3+c
endif
return pz
return pk
endfunc

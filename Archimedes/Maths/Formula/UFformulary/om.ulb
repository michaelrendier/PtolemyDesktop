param p1
caption="Variant Parametr 1"
default=(1,0)
visible=@version==100
endparam
param p2
caption="Variant Parametr 2"
default=(1,0)
visible=(@V!=9 && @V!=14 && @V!=15) && @version==100
endparam
param p3
caption="Variant Parametr 3"
default=(1,0)
visible=(@V==0 || @V==2 || @V==3 || @V==4 || @V==6 || @V==7 || \
@V==8 || @V==10 || @V==11 || @V==13 || @V==16 || @V==18) && @version==100
endparam
param p4
caption="Variant Parametr 4"
default=(1,0)
visible=(@V==0 || @V==3 || @V==7 || @V==11 || @V==13 || @V==16) && @version==100
endparam

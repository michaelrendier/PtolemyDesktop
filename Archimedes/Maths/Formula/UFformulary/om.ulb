b=@pow*(pz-(2*pz^(1-@pow)*(pz^@pow-@c))/(3*@pow))^(@pow-1)*(1/3-(2*(1-@pow)*(pz^@pow-@c))/(3*@pow*pz^@pow))
pz=pz-@jp*(a/2-f/(f1-3*b))
return pz
endfunc

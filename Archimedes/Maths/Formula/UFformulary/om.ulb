class OM_Fermat-LucasSuper-Halley(common.ulb:ConvergentFormula) {
public:
complex func Init(complex pz)
ConvergentFormula.Init(pz)
return @sf(pz)
endfunc
complex func Iterate(complex pz)
ConvergentFormula.Iterate(pz)
m_ZOld=pz
pz=@pzp1*fn2(fn3(pz))+@pzp2
if @P=="3"
f=27*pz^3-18*pz-@p4
f1=81*pz^2-18
f2=162*pz
elseif @P=="4"
f=81*pz^4-72*pz^2+8-@p4
f1=324*pz^3-144*pz
f2=972*pz^2-144
elseif @P=="5"
f=243*pz^5-270*pz^3+60*pz-@p4
f1=1215*pz^4-810*pz^2+60
f2=4860*pz^3-1620*pz
elseif @P=="6"
f=729*pz^6-972*pz^4+324*pz^2-16-@p4
f1=4374*pz^5-3888*pz^3+648*pz
f2=21870*pz^4-11664*pz^2+648
elseif @P=="7"
f=2187*pz^7-3402*pz^5+1512*pz^3-168*pz-@p4
f1=15309*pz^6-17010*pz^4+4536*pz^2-168
f2=91854*pz^5-68040*pz^3+9072*pz
elseif @P=="8"
f=6561*pz^8-11664*pz^6+6480*pz^4-1152*pz^2+32-@p4
f1=52488*pz^7-69984*pz^5+25920*pz^3-2304*pz
f2=367416*pz^6-349920*pz^4+77760*pz^2-2304
else
f=19683*pz^9-39366*pz^7+26244*pz^5-6480*pz^3+432*pz-@p4
f1=177147*pz^8-275562*pz^6+131220*pz^4-19440*pz^2+432
f2=1417176*pz^7-1653372*pz^5+524880*pz^3-38880*pz
endif
a=f/f1
b=f*f2/sqr(f1)
return @p2*pz-@p1*a*(1+(b/(2*(1-b))))+@p3
endfunc
default:
title="Fermat-Lucas Super-Halley"

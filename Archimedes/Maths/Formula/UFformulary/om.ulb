pq=@qp1*pq+@qp2
a=pw
b=pk
c=pz
if @mj==0
pw=pw*(pk+pz+pq)+@p1*@pf(fpixel)
pk=(pk+a+pz+pq)^2+@p2*@pf(fpixel)
pz=pz^2*a+b*pq+@p3*@pf(fpixel)/pz
pq=pq^2+a*b*c+@p4*@pf(fpixel)/pq
else
pw=pw*(pk+pz+pq)+@p1
pk=(pk+a+pz+pq)^2+(@p2-3.2)
pz=pz^2*a+b*pq-@p3/pz
pq=pq^2+a*b*c+@p4/pq
endif
return pz
return pw
return pk
return pq
endfunc

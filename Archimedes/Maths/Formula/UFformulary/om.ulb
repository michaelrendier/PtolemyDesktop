pz=@zp1*pz+@zp2
pz=pz+@as*sqr(pz)
pz=pz+@ar/pz
u=(1-@p1)*pz+@p1*(imag(pz)+sin(real(pz))+flip(@mp1-real(pz)))
pz=(1-@p2)*(imag(pz)+sin(real(pz))+flip(@mp2-real(pz)))\
+@p2*(imag(u)+sin(real(u))+flip(@mp3-real(u)))
return pz
endfunc

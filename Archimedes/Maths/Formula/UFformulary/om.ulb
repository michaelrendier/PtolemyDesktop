+(y0^2+y0-1)^2-x0^2*(1-y0^2)+x0-@p1*sin(y0+tan(1i*y0))+flip(y0-@p1*sin(x0+tan(1i*x0)))\
+sin(real(@p2)*y0)+@p2*sin(real(@p2)*x0)+flip(sin(real(@p4+2)*x0)+@p3*sin(real(@p4+2)*y0))
endif
elseif @V=="33"

class OM_Jarratt2(common.ulb:ConvergentFormula) {
public:
complex func Init(complex pz)
ConvergentFormula.Init(pz)
return @sf(pz)
endfunc
complex func Iterate(complex pz)
ConvergentFormula.Iterate(pz)
pz=@zp1*pz+@zp2
if @v==0
f=pz^@pow-@c
f1=@pow*pz^(@pow-1)
elseif @v==1
f=pz^@pow-pz^(@pow-1)-pz^(@pow-2)-@c
f1=@pow*pz^(@pow-1)-(@pow-1)*pz^(@pow-2)-(@pow-2)*pz^(@pow-3)
else
f=pz^@pow+pz^(@pow-1)+pz^(@pow-2)-@c
f1=@pow*pz^(@pow-1)+(@pow-1)*pz^(@pow-2)+(@pow-2)*pz^(@pow-3)
endif
a=f/f1
if @v==0
b=@pow*(pz-2*a/3)^(@pow-1)
elseif @v==1
b=@pow*(pz-2*a/3)^(@pow-1)-(@pow-1)*(pz-2*a/3)^(@pow-2)-(@pow-2)*(pz-2*a/3)^(@pow-3)
else
b=@pow*(pz-2*a/3)^(@pow-1)+(@pow-1)*(pz-2*a/3)^(@pow-2)+(@pow-2)*(pz-2*a/3)^(@pow-3)
endif
pz=pz-@jp*(a/2-f/(f1-3*b))
return pz
endfunc

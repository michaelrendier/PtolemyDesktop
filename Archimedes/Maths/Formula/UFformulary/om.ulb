else
while i<@iter
i=i+1
pz=@p6*pz+@p7
float a=real(pz)
if @V=="1"
if a<@p4
pz=(sqrt(1i)*pz+@p17)*fn2(flip(@p1))+@p2
endif
pz=pz*@fn9(atan(@p8))+@p11

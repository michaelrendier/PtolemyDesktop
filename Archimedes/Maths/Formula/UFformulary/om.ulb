pzold=(0,0)
pkold=(0,0)
return pz
return pk
endfunc
private:
complex c
complex pk
complex pzold
complex pkold
complex func Iterate(complex pz)
ConvergentFormula.Iterate(pz)
pzold=pz
pkold=pk
pz=@zp1*pz+@zp2
pk=@kp1*pk+@kp2
a=pk
if @bv==0
pk=@bp1*@bf(pk/pz)+@bp2
elseif @bv==1
pk=@bp1*@bf(pk^2/pz)+@bp2+0.77
elseif @bv==2
pk=@bp1*@bf(pk/pz^2)+@bp2+0.5
else
pk=@bp1*@bf(pk^2/pz^2)+@bp2-0.57
endif
pz=pz+a-@np1*(pz^@zpow-@np2)/(@zpow*pz^(@zpow-1))-@np3*(a^@kpow-@np4)/(@kpow*a^(@kpow-1))+c
return pz
return pk
endfunc
bool func IsBailedOut(complex pz)
bool bail=false
bail=(|(pz-pzold+pk-pkold)/2|<@p_bailout)
return bail
endfunc

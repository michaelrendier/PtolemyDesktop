pz=pz+@ar/pz
u=(1-@p1)*pz+@p1*(sqr((pz^3+3*(@mp1-1)*pz+(@mp1-1)*(@mp1-2))/(3*pz^2+3*(@mp1-2)*pz+(@mp1-1)*(@mp1-2)+1)))
pz=(1-@p2)*pz+@p2*(sqr((u^3+3*(@mp2-1)*u+(@mp2-1)*(@mp2-2))/(3*u^2+3*(@mp2-2)*u+(@mp2-1)*(@mp2-2)+1)))
return pz

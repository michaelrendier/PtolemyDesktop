param p4
caption="Variant Parameter 4"
default=(1,0)
visible=@V=="Buckling Column Model" || @V=="Cartesian Oval" || @V=="Cissoid of Zahradnik" || @V=="Clifford" || @V=="de Jong" \
|| @V=="Duffing 3" || @V=="Duffing Parametric" || @V=="Duffing Quintic" \
|| @V=="Henon 4" || @V=="Ikeda 2" || @V=="Ikeda 3" || @V=="Ilhem-Amel 2" \

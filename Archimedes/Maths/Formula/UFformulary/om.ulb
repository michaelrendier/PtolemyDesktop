complex func Iterate(complex pz)
pw=@wp1*pw+@wp2
pk=@kp1*pk+@kp2
pz=@zp1*pz+@zp2
pq=@qp1*pq+@qp2
a=pw
b=pk
d=pz
if @mj==0
if @v==0
pw=pw/pz+@p1*c
pk=pk/pz+@p2*c
pz=pw^2+pk^2+pz^2+pq^2+@p3*c
pq=pq/d+@p4*c
c=@p5*c/2+@p6*pz
elseif @v==1
pw=pw/pz+@p1*c
pk=pk/pz+@p2*c
pz=pw^2+pk^2+pz^2+pq^2+@p3*c
pq=pq/d+@p4*c
c=@p5*c/2+@p6*(pz+pw)
elseif @v==2
pw=pw/pz+@p1*c
pk=pk/pz+@p2*c
pz=pw^2+pk^2+pz^2+pq^2+@p3*c
pq=pq/d+@p4*c
c=@p5*c/2+@p6*(pz+pw+pk)
elseif @v==3
pw=pw/pz+@p1*c
pk=pk/pz+@p2*c
pz=pw^2+pk^2+pz^2+pq^2+@p3*c
pq=pq/d+@p4*c
c=@p5*c/2+@p6*(pz+pw+pk+pq)
elseif @v==4
pw=pw/pz+@p1*c
pk=pk/pz+@p2*c
pz=a^2+b^2+pz^2+pq^2+@p3*c
pq=pq/d+@p4*c
c=@p5*c/2+@p6*pz
elseif @v==5
pw=pw/pz+@p1*c
pk=pk/pz+@p2*c
pz=a^2+b^2+pz^2+pq^2+@p3*c
pq=pq/d+@p4*c

class OM_TrivarX4(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
if @jm==1
pz=@sp
pk=@sp
pw=@sp
else
pz=@sf(pz)
pk=pz
pw=pz
endif
return pz
return pk
return pw
endfunc
private:
complex pk
complex pw
complex fpixel
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
pk=@kp1*pk+@kp2
pw=@wp1*pw+@wp2
pw=-@p1*(pk-pw)
pk=pw*(@p2-pz)-pk
if @jm==0
pz=pw*pk-@p3*pz+@c
else
pz=pw*pk-@p3*pz+@pf(fpixel)
endif
return pz
return pk
return pw
endfunc

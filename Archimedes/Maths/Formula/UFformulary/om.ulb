elseif @V=="51"
pz=@p3*(pz*sqrt(pz)/cos(pz))
elseif @V=="52"
pz=@p3*(pz*atanh(pz)/cabs(pz))
else
pz=@p3*(pz*tan(pz)/cabs(pz))
endif
d=cabs(fn2(pz)*fn1(pz)+1)
if d>=@p2 && d<=1 && a==0
a=b
c=cabs((d-@p2)*(2/(pz-@p2)))

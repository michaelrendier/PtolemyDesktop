elseif @v=="Pf4"
pz=@p2*fn4(log(abs(@fn5((1+pz^3)*(1+pz^11)*(1+pz^15)*(1+pz^23)))))^@pow+@p3
elseif @v=="Pe6"
pz=@p2*fn4(log(abs(@fn5((1+pz^3)*(1+pz^9)*(1+pz^11)*(1+pz^15)*(1+pz^17)*(1+pz^23)))))^@pow+@p3
elseif @v=="Pe7"

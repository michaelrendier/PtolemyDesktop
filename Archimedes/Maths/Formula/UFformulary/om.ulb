+(a^2+exp(log(a)^2+@xp1*log(a)+log(c2-1.05))+c2-1.05)^2+exp(log(a^2+exp(log(a)^2+@xp1*log(a)+log(c2-1.05))+c2-1.05)^2+@xp1*log(a^2+exp(log(a)^2+@xp1*log(a)+log(c2-1.05))+c2)+log(c2-1.05))
elseif @v==19

default=(1,0)
endparam
param bp2
caption="Bivar Parameter 2"
default=(0,0)
endparam
param bp3
caption="Bivar Parameter 3"
default=(1,0)
endparam
param js
caption="Julia Seed"
default=(-1.25,0)
visible=@jm==0
endparam

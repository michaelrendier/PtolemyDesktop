b=(b-@p1)*@p4
f=cabs(fn1(b))
if f>1e-10
d=b/f
f=@p2*0.5/(0.25+(@p2^2-0.25)*imag(d)^2)
c=f*d
f=cabs((c-b)^3)/0.05
if f<=1
g=false
endif
endif
endif
endfunc
float func ResultIndex(complex pz)
if g
m_Solid=true
else
if |b|>|c|
f=1+f
else
f=1-f
endif
endif
index=f/2
return index
endfunc

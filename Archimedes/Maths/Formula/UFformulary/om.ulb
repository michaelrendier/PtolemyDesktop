c1=@js1
c2=@js2
c3=@js3
else
pk=@sp1
pw=@sp2
pz=@sp3
c1=@sf(fpixel)
c2=@sf(fpixel)
c3=@sf(fpixel)
endif
return pz
return pk
return pw
endfunc

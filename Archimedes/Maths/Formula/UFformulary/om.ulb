ConvergentFormula.Init(pz)
return @sf(pz)
endfunc
complex func Iterate(complex pz)
ConvergentFormula.Iterate(pz)
;m_ZOld=pz
pz=@zp1*pz+@zp2
if @v==0
f=(pz+1)^2*(pz-1)^(@pow-2)-@c
f1=(pz+1)*(@pow*pz+@pow-4)*(pz-1)^(@pow-3)
a=pz-@p1*f/f1
fa=(a+1)^2*(a-1)^(@pow-2)-@c
b=pz-@p2*(fa/f1)*(1/(1-fa/f)^2)
fb=(b+1)^2*(b-1)^(@pow-2)-@c
elseif @v==1
f=pz^@pow+(pz+1)^2*(pz-1)^(@pow-2)-@c
f1=@pow*pz^(@pow-1)+(pz+1)*(@pow*pz+@pow-4)*(pz-1)^(@pow-3)

class OM_ParallelResistance(common.ulb:DivergentFormula) {
; Formula by Mike Frazier, as given here:
; http://www.fracton.org/fmlposts/two_mand.html
public:
complex func Init(complex pz)
fpixel=pz
c=@pf(fpixel)
pz=@sp
return pz
endfunc
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if @v=="1"
a=recip(pz^2+c-@p1)
b=recip(pz^2+c-@p2)
pz=recip(a+b)
else
a=recip(pz^2+c-(@p1+2))
b=recip(pz^2+c-(@p2-8))
d=recip(pz^2+c-@p3)
pz=recip(a+b+d)
endif
return pz
endfunc
private:
complex c
default:
title="Parallel Resistance"
int param version
caption="Version"
default=100
visible=@version<100
endparam
param v
caption="Variant"
enum="1""2"
endparam
param sp
caption="Start Parameter"
default=(0,0)
endparam
param p1
caption="PR Parameter 1"
default=(-2,0)
endparam
param p2
caption="PR Parameter 2"
default=(1,0)
endparam
param p3
caption="PR Parameter 3"
default=(-7,0)
visible=@v=="2"
endparam
param zp1
caption="Z Parameter 1"
default=(1,0)
endparam
param zp2
caption="Z Parameter 2"
default=(0,0)
endparam
func pf
caption="Pixel Function"
default=ident()
endfunc
param p_power
visible=false
endparam
float param p_bailout
caption="Bailout"
default=100.0
exponential=true
endparam
}

class OM_AltParallelResistance(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
c=@pf(fpixel)
pz=@sp
i=0
return pz
endfunc
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if i==0
if @v=="1"
a=recip(pz^2+@pp1*c-(@p1-3))
b=recip(pz^2+@pp1*c-@p2)
pz=recip(a+b)
else
a=recip(pz^2+@pp1*c-(@p1+8.5))
b=recip(pz^2+@pp1*c-@p2)
d=recip(pz^2+@pp1*c-(@p5-5.5))
pz=recip(a+b+d)
endif
i=1
else
if @v=="1"
a=recip(pz^2+@pp2*c-(@p3+1))
b=recip(pz^2+@pp2*c-(@p4-3.5))
pz=recip(a+b)
else
a=recip(pz^2+@pp2*c-(@p3-6.25))
b=recip(pz^2+@pp2*c-(@p4))
d=recip(pz^2+@pp2*c-@p6)
pz=recip(a+b+d)
endif
i=0
endif
return pz
endfunc
private:
complex c
int i
default:
title="Alt Parallel Resistance"
int param version
caption="Version"
default=100
visible=@version<100
endparam
param v
caption="Variant"
enum="1""2"
endparam
param sp
caption="Start Parameter"
default=(0,0)
endparam
param p1
caption="PR Parameter 1"
default=(1,0)
endparam
param p2
caption="PR Parameter 2"
default=(1,0)
endparam
param p3
caption="PR Parameter 3"
default=(1,0)
endparam
param p4
caption="PR Parameter 4"
default=(1,0)
endparam
param p5
caption="PR Parameter 5"
default=(1,0)
visible=@v=="2"
endparam
param p6
caption="PR Parameter 6"
default=(1,0)
visible=@v=="2"
endparam
param pp1
caption="Pixel Parameter 1"
default=(1,0)
endparam
param pp2
caption="Pixel Parameter 2"
default=(1,0)
endparam
param zp1
caption="Z Parameter 1"
default=(1,0)
endparam
param zp2
caption="Z Parameter 2"
default=(0,0)
endparam
func pf
caption="Pixel Function"
default=ident()
endfunc
param p_power
visible=false
endparam
float param p_bailout
caption="Bailout"
default=100.0
exponential=true
endparam
}

class OM_BivarX75(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
c1=@pf(fpixel)
c2=@js
pk=@pf(pz)
pz=@sp
return pz
return pk
endfunc
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
pk=@kp1*pk+@kp2
pk=@bp1*@bf(pk/pz)+@bp2
pz=pz^2+pk^2+c1+c2
c1=c1-pz/2
c2=c2-pk/5

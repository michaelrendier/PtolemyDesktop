elseif @v==47
fz=pz^@pow1+(pz-1i)^@pow1+(1i*pz)^@pow1-@p3
fz1=@pow1*pz^(@pow1-1)+1i*@pow1*(1i*pz)^(@pow1-1)+@pow1*(pz-1i)^(@pow1-1)
elseif @v==48
fz=(pz+1i*pz)^@pow1+pz^3/1i+(pz+cotanh(pz))^@pow1-@p3

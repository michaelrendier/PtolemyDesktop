elseif @T=="53"
d2=b-|1-a2*x2^2+(2,1.75)*(y2-x2)+sin(x2*y2/(2*a2))*y2+sin((2,1.75)*x2-y2)+flip(1-a2*y2^2+(2,1.75)*(x2-y2)+x2+sin(y2)/(2*a2))|
elseif @T=="54"
d2=b-|x2+a2*sin(x2)+a2*sin(x2)*sin(1-x2^2-y2^2)+(-0.5,-0.18)+flip(y2+a2*sin(x2)+x2+a2*sin(y2)*sin(1-x2^2-y2^2))|
elseif @T=="55"
d2=b-|1-a2*x2^2+(-2.15,-2.9)*(y2^2-x2)+x2+a2*(-2.15,-2.9)*sin(y2)^2+flip(1-a2*y2^2+(-2.15,-2.9)*(x2^2-y2)+y2+x2^2+a2*sin(y2)^2)|
endif




if d2>0
c2=@p3b*(d2+c2)
endif
endif
endfunc
float func ResultIndex(complex pz)
if @version==100
;m_Solid=true
if @solid
if @invert
if k>@sca
index=@p6*k/m_Iterations
else
m_Solid=true
endif
else
if k<=@sca
index=@p6*k/m_Iterations
else
m_Solid=true
endif
endif
else
index=@p6*k/m_Iterations
endif
return index
else
if @solid2==true
if @invert2
if c2<=@scab
index2=c2
else
m_Solid=true
endif
else
if c2>@scab
index2=c2
else
m_Solid=true
endif
endif
else
index2=c2
endif
return index2
endif
endfunc

class OM_Rootmod5(common.ulb:ConvergentFormula) {
public:
complex func Init(complex pz)
ConvergentFormula.Init(pz)
fPixel=pz
if @st==0
return @sf(pz)
else
return @sp
endif
endfunc
private:
complex fpixel
complex func Iterate(complex pz)
ConvergentFormula.Iterate(pz)
pz=@pzp1*@pzf(pz)+@pzp2
f=pz^@pow-@p2
f1=@pow*pz^(@pow-1)
return pz-@p1*(f/f1)*((f/f1)*(f^2/(2*f1))*(2*(f^2/(2*f1))+1)+1)+@p3+0.05*@pf(fpixel)
endfunc

class OM_Devurgh2(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
a=(0,0)
b=(0,0)
d=(0,0)
if @mj==1
pz=@pf(pz)
c=@js
else
if @v==2
pz=@sp+2.5
elseif @v==3
pz=@sp+3
elseif @v==4
pz=@sp+2.7
elseif @v==6
pz=@sp+1.3
elseif @v==7
pz=@sp+2.5
elseif @v==8
pz=@sp+1.3
elseif @v==10
pz=@sp+3
elseif @v==12
pz=@sp+3
elseif @v==16
pz=@sp+2.35
elseif @v==17
pz=@sp+2.5
elseif @v==20
pz=@sp+3
elseif @v==23
pz=@sp+0.85
else
pz=@sp
endif



c=@pf(fpixel)
endif
return pz
endfunc
complex func Iterate(complex pz)
if @v==1
pz=(@zp1+0.05)*pz+@zp2
elseif @v==5
pz=(@zp1-0.2)*pz+@zp2
elseif @v==6
pz=(@zp1-0.2)*pz+@zp2
elseif @v==7
pz=(@zp1-0.15)*pz+@zp2
elseif @v==11
pz=(@zp1-0.05)*pz+@zp2
elseif @v==12
pz=(@zp1-0.1)*pz+@zp2
elseif @v==13
pz=(@zp1-0.1)*pz+@zp2
elseif @v==14
pz=(@zp1-0.2)*pz+@zp2
elseif @v==15
pz=(@zp1-0.25)*pz+@zp2
elseif @v==16
pz=(@zp1-0.05)*pz+@zp2
elseif @v==17
pz=(@zp1-0.1)*pz+@zp2
elseif @v==20
pz=(@zp1-0.05)*pz+@zp2
elseif @v==21
pz=(@zp1-0.1)*pz+@zp2
elseif @v==24
pz=(@zp1-1)*pz+@zp2
else
pz=@zp1*pz+@zp2
endif
if @v==0
if @mj==0
pz=pz+c
d=pz^@pow1+c/(pz-(@dmp-1.25))^@pow2+@smp1*a+@smp2*b
else
d=pz^@pow1+(c+0.75)/(pz-@dmp)^@pow2+@smp1*a+@smp2*b
endif
elseif @v==1
pz=pz-c
d=pz^@pow1+(c+a)/(pz+b-@dmp)^@pow2-@smp1*a+@smp2*b+c
elseif @v==2
pz=pz+c
d=pz^@pow1+(c-a)/(pz-b-@dmp)^@pow2+@smp1*a+@smp2*b
elseif @v==3
pz=pz-c
d=pz^@pow1+(c+a)/(pz-b-@dmp)^@pow2-@smp1*a+@smp2*b
elseif @v==4
pz=pz-c
if @mj==0
d=pz^@pow1+(c-a)/(pz+b-@dmp)^@pow2+@smp1*a+@smp2*b+c
else
d=pz^@pow1+((c+1)-a)/(pz+b-@dmp)^@pow2+@smp1*a+@smp2*b+c
endif
elseif @v==5
pz=pz+c
d=(pz+a)^@pow1+(c+b)/(pz+@dmp)^@pow2+@smp1*a+(@smp2-1)*b
elseif @v==6
d=(pz+a)^@pow1+(c+a+b)/(pz-b-@dmp)^@pow2-@smp1*a+(@smp2-0.5)*b+c
elseif @v==7
pz=pz+c
d=(pz+a)^@pow1+(c-b)/(pz+@dmp)^@pow2+@smp1*a+(@smp2-1.5)*b
elseif @v==8
if @mj==0
d=pz^@pow1+(c+b)/(pz+a-@dmp)^@pow2-@smp1*a+@smp2*b+c
else
d=pz^@pow1+((c+0.55)+b)/(pz+a-@dmp)^@pow2-@smp1*a+@smp2*b+(c+0.55)
endif
elseif @v==9
pz=pz-c
if @mj==0
d=(pz+a)^@pow1+(c)/(pz+b-@dmp)^@pow2+@smp1*a+@smp2*b+c
else
d=(pz+a)^@pow1+(c+0.75)/(pz+b-@dmp)^@pow2+@smp1*a+@smp2*b+c
endif
elseif @v==10
pz=pz-c
d=pz^@pow1+(c+b)/(pz+a+b+@dmp)^@pow2-@smp1*a+@smp2*b+c
elseif @v==11
if @mj==0
d=(pz+a)^@pow1+(c)/(pz-b-(@dmp+0.5))^@pow2+@smp1*a+(@smp2-1)*b+c
else
d=(pz+a)^@pow1+(c-0.4)/(pz-b-(@dmp+0.5))^@pow2+@smp1*a+(@smp2-1)*b+(c-0.4)
endif
elseif @v==12
pz=pz+c
d=pz^@pow1+(c-b)/(pz-a-@dmp)^@pow2+@smp1*a+@smp2*b
elseif @v==13
pz=pz-c
d=pz^@pow1+(c+b)/(pz-a-@dmp)^@pow2-@smp1*a+@smp2*b+c
elseif @v==14
pz=pz+c
d=(pz+b)^@pow1+(c-a)/(pz-b+@dmp)^@pow2-@smp1*a-@smp2*b
elseif @v==15
pz=pz+c
if @mj==0
d=(pz-b)^@pow1+(c+a)/(pz-b-@dmp)^@pow2+@smp1*a-@smp2*b
else
d=(pz-b)^@pow1+((c+0.54)+a)/(pz-b-@dmp)^@pow2+@smp1*a-@smp2*b
endif
elseif @v==16
pz=pz-c
if @mj==0
d=pz^@pow1+(c-b)/(pz+a-@dmp)^@pow2+(@smp1-0.8)*a+@smp2*b+c
else
d=pz^@pow1+((c+0.52)-b)/(pz+a-@dmp)^@pow2+(@smp1-0.8)*a+@smp2*b+c
endif
elseif @v==17
pz=pz+c
d=pz^@pow1+(c+b-a)/(pz-b+a-@dmp)^@pow2+@smp1*a+@smp2*b
elseif @v==18
pz=pz-c
d=pz^@pow1+(c-a-b)/(pz+b-@dmp)^@pow2+@smp1*a+@smp2*b+c
elseif @v==19
pz=pz-c
d=pz^@pow1+(c+a+b)/(pz+a+b-@dmp)^@pow2+(@smp1-1.5)*a-(@smp2+1.1)*b+c
elseif @v==20
pz=pz+c
d=pz^@pow1+(c+a-b)/(pz-a+b-@dmp)^@pow2+@smp1*a+(@smp2+0.25)*b
elseif @v==21
pz=pz-c
d=pz^@pow1+(c+a+b)/(pz-@dmp)^@pow2+(@smp1-1.95)*a+(@smp2+0.9)*b+c
elseif @v==22
d=pz^@pow1+(c+a-b)/(pz-@dmp)^@pow2-@smp1*a+@smp2*b+c
elseif @v==23
d=pz^@pow1+(c-a+b)/(pz-@dmp)^@pow2-@smp1*a+@smp2*b+c
elseif @v==24
if @mj==0
pz=pz+c
d=pz^@pow1+(c-a-b)/(pz-@dmp)^@pow2+@smp1*a+@smp2*b
else
pz=pz+(c+1.05)
d=pz^@pow1+((c+1.05)-a-b)/(pz-@dmp)^@pow2+@smp1*a+@smp2*b
endif
endif

a=b
b=pz
pz=d
return pz
endfunc

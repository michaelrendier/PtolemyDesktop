elseif @M=="32"
pz=pz+0.5i*sqr(pz)
elseif @M=="33"
pz=pz-0.3i*exp(pz)
endif
y=@p1*(x-@agf(y)^@pow)
x=@p15*(x-y+@p2*pz)
pz=-@p3*y+@p17+@app*@pf(fpixel)
return pz

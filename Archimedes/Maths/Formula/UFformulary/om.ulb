default=(1,0)
visible=@version==101
endparam
param p2b
caption="Variant Parameter 2"
default=(1,0)
visible=@version==101 && (@Vb=="Bogdanov" || @Vb=="Brusselator" || @Vb=="Buckling Column Model" \
|| @Vb=="Burgers" || @Vb=="Cathala" || @Vb=="Coupled Logistic" \
|| @Vb=="Garrote-Mira" || @Vb=="Gingerbread" || @Vb=="HCA" || @Vb=="Henon" || @Vb=="Henon-Heiles" \
|| @Vb=="Ikeda" || @Vb=="Ilhem-Amel 1" || @Vb=="Ilhem-Amel 2" \
|| @Vb=="Jiang" || @Vb=="Kolmogorov-Volterra" \
|| @Vb=="Lozi" || @Vb=="Lozi Mod" || @Vb=="Magus 1" \
|| @Vb=="Magus 2" || @Vb=="Magus 3" || @Vb=="Magus 4" || @Vb=="Magus 5" || @Vb=="Magus 6" || @Vb=="Magus 7" \

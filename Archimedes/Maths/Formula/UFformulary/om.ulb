class OM_IteratedFunctionSyndrome12(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
pz=fn1(pz)
return pz
endfunc
complex func Iterate(complex pz)
pz=@p26*pz+@p27
x=real(pz)
y=imag(pz)
a=conj((@p1*x+@p2)/@p3+flip((@p4*y+@p5)/@p6))
b=|a-@p25|
c=flip((@p7*x+@p8)/@p9+flip((@p10*y+@p11)/@p12))
d=|c-@p25|
f=conj((@p13*x+@p14)/@p15+flip((@p16*y+@p17)/@p18))
g=|f-@p25|
h=(@p19*x+@p20)/@p21+flip((@p22*y+@p23)/@p24)
j=|h-@p25|
if real(b)<real(d) && real(b)<real(g) && real(b)<real(j)
pz=@p28*a+@p29
elseif real(d)<real(b) && real(d)<real(g) && real(d)<real(j)
pz=@p28*c+@p29
elseif real(g)<real(b) && real(g)<real(d) && real(g)<real(j)
pz=@p28*f+@p29
elseif real(j)<real(b) && real(j)<real(d) && real(j)<real(f)
pz=@p28*h+@p29
endif
return pz
endfunc

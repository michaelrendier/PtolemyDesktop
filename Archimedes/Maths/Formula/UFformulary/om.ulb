endif
elseif @av==3
if i==0
pz=(pz^2+@p1*c)^2+@p2*c^2+pz
i=i+1
elseif i==1
pz=((pz^2+@p1*c)^2+@p2*c^2+pz)^2+(@p3*c^2+pz)^2+pz^2+@p3*c
i=i+1
else
pz=pz^2+@p1*c
i=0
endif
elseif @av==4
if i==0
pz=((pz^2+@p1*c)^2+@p2*c^2+pz)^2+(@p3*c^2+pz)^2+pz^2+@p3*c
i=i+1
elseif i==1
pz=pz^2+@p1*c
i=i+1
else
pz=(pz^2+@p1*c)^2+@p2*c^2+pz
i=0
endif
else
if i==0

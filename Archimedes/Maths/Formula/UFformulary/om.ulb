b=pw
pk=@bp1*pk/pz+@bp2
pw=@bp3*pz/pw+@bp4
pz=pz^2+exp(log(pz)^2+@xp1*log(pz)+log(c1))+a^2+exp(log(a)^2+@xp1*log(a)+log(c2))+b^2+exp(log(b)^2+@xp1*log(b)+log(c3))
return pz
return pk
return pw
endfunc

z3=(z3^4*z1/z2+z1^4*z2/z3)/2+@p3*c
elseif @v==6
z1=z1^2*z2/z3+@p1*c
z2=z2^2*z3/a+@p2*c
z3=z3^2*a/b+@p3*c
elseif @v==7
z1=(z1^2*z2/z3+z2^2*z3/z1)/2+@p1*c
z2=(z2^2*z3/a+z3^2*a/z2)/2+@p2*c
z3=(z3^2*a/b+a^2*b/z3)/2+@p3*c
elseif @v==8
z1=z1^3*z2/z3+@p1*c
z2=z2^3*z3/a+@p2*c
z3=z3^3*a/b+@p3*c
elseif @v==9
z1=(z1^3*z2/z3+z2^3*z3/z1)/2+@p1*c
z2=(z2^3*z3/a+z3^3*a/z2)/2+@p2*c
z3=(z3^3*a/b+a^3*b/z3)/2+@p3*c
elseif @v==10

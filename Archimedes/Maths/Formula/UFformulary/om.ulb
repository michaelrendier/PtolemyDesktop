class OM_TetravarNewtonM(common.ulb:ConvergentFormula) {
public:
complex func Init(complex pz)
ConvergentFormula.Init(pz)
fpixel=pz
c=@sf(fpixel)
pw=@sp1
pk=@sp2
pq=@sp3
pz=@sp4
pzold=(0,0)
pkold=(0,0)
pwold=(0,0)
pqold=(0,0)
return pz
return pk
return pw
return pq
endfunc
private:
complex pk
complex pw
complex pq
complex pzold
complex pkold
complex pwold
complex pqold
complex c
complex func Iterate(complex pz)
ConvergentFormula.Iterate(pz)
pzold=pz
pkold=pk
pwold=pw
pqold=pq
pz=@zp1*pz+@zp2
pk=@kp1*pk+@kp2
pw=@wp1*pw+@wp2
pq=@qp1*pq+@qp2
a=pw
b=pk
d=pq
pw=@bp1*pw/pz+@bp2
pk=@bp3*pk/pz+@bp4
pq=@bp5*pq/pz+@bp6
pz=pz-@np9*(pz^3+@np1*c*pz^2+@np2*c)/(3*pz^2+2*@np1*c*pz)\
+a-@np10*(a^3+@np3*c*a^2+@np4*c)/(3*a^2+2*@np3*c*a)\
+b-@np11*(b^3+@np5*c*b^2+@np6*c)/(3*b^2+2*@np5*c*b)\
+d-@np12*(d^3+@np7*c*d^2+@np8*c)/(3*d^2+2*@np7*c*d)
return pz
return pk
return pw
return pq
endfunc
bool func IsBailedOut(complex pz)
bool bail=false
bail=(|(pz-pzold+pk-pkold+pw-pwold+pq-pqold)/4|<@p_bailout)
return bail
endfunc

"21""22""23""24""25""26"
endparam
param sp1
caption="Start Parameter 1"
default=(1,0)
visible=@mj==0
endparam
param sp2
caption="Start Parameter 2"
default=(1,0)
visible=@mj==0
endparam
param js1
caption="Julia Seed 1"
default=(0.25,0)
visible=@mj==1
endparam
param js2
caption="Julia Seed 2"
default=(0.25,0)
visible=@mj==1
endparam

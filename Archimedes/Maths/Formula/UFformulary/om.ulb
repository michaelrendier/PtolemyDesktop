class OM_BivarXPlog(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fPixel=pz
if @jm==0
pk=@sf(pz)
pz=@sf(pz)
if @v==0 || @v==1 || @v==2
c1=@js1
c2=@js2
else
c1=@js1-4.75
c2=@js2-4.75
endif
else
pk=@sp1
pz=@sp2
c1=@sf(fpixel)
c2=@sf(fpixel)
endif
return pz
return pk
endfunc
private:
complex c1
complex c2
complex pk
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
pk=@kp1*pk+@kp2
pk=@bp1*pk/pz+@bp2
If @v==0
pz=pz^2+exp(log(pz)^2+log(c1))+pk^2+exp(log(pk)^2+log(c2))
elseif @v==1
pz=pz^2+exp(log(pz)^2+@xp1*log(pz)+log(c1))+pk^2+exp(log(pk)^2+@xp1*log(pk)+log(c2))
elseif @v==2
pz=pz^2+exp(log(pz)^2-@xp1*log(pz)+log(c1))+pk^2+exp(log(pk)^2-@xp1*log(pk)+log(c2))
elseif @v==3
pz=pz^2+exp(log(pz)^2+@xp1*log(pz)-log(c1))+pk^2+exp(log(pk)^2+@xp1*log(pk)-log(c2))
elseif @v==4
if @jm==1 && @v==4
pz=pz^2+exp(log(pz)^2-(@xp1-3)*log(pz)-log(c1))+pk^2+exp(log(pk)^2-(@xp1-3)*log(pk)-log(c2))
else
pz=pz^2+exp(log(pz)^2-@xp1*log(pz)-log(c1))+pk^2+exp(log(pk)^2-@xp1*log(pk)-log(c2))
endif
else
pz=pz^2+exp(log(pz)^2-log(c1))+pk^2+exp(log(pk)^2-log(c2))
endif
return pz
return pk
endfunc
bool func IsBailedOut(complex pz)
bool bail=false
bail=(|(pz+pk)/2|>@p_bailout)
return bail
endfunc
default:
title="Bivar X-Plog"
int param version
caption="Version"
default=100
visible=@version<100
endparam
param jm
caption="J/M"
enum="J""M"
endparam
param v
caption="Variant"
enum="1""2""3""4""5""6"
endparam
param sp1
caption="Start Parameter 1"
default=(1,0)
visible=@jm==1
endparam
param sp2
caption="Start Parameter 2"
default=(1,0)
visible=@jm==1
endparam
param js1
caption="Julia Seed 1"
default=(-0.25,0)
visible=@jm==0
endparam
param js2
caption="Julia Seed 2"
default=(-0.25,0)
visible=@jm==0
endparam
param xp1
caption="X-Plog Parameter"
visible=@v!=0 && @v!=5
default=(1,0)
endparam
param bp1
caption="Bivar Parameter 1"
default=(0.5,0)
endparam
param bp2
caption="Bivar Parameter 2"
default=(0,0)
endparam
param zp1
caption="Z Parameter 1"
default=(0.75,0)
endparam
param zp2
caption="Z Parameter 2"
default=(0,0)
endparam
param kp1
caption="K Parameter 1"
default=(1.25,0)
endparam
param kp2
caption="K Parameter 2"
default=(0,0)
endparam
func sf
caption="Pixel Function"
default=ident()
endfunc
param p_power
visible=false
endparam
float param p_bailout
caption="Bailout"
default=10000.0
exponential=true
endparam
}

class OM_BivarXPlog2(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fPixel=pz
if @jm==0
pk=@sf(pz)
pz=@sf(pz)
c1=@js1
c2=@js2
else
if @v==0
pk=@sp1+0.5
elseif @v==1
pk=@sp1+0.75
elseif @v==4 || @v==5 || @v==6
pk=@sp1+1
else
pk=@sp1
endif
pz=@sp2
c1=@sf(fpixel)
c2=@sf(fpixel)
endif
return pz
return pk
endfunc
private:
complex c1
complex c2
complex pk
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
pk=@kp1*pk+@kp2
a=pk
pk=@bp1*pk/pz+@bp2
if @jm==1
if @v==0
pz=pz^2+exp(log(pz)^2-@xp1*log(pz)+pz*log(c1))+a^2+exp(log(a)^2-@xp1*log(a)+a*log(c2))
elseif @v==1
pz=pz^2+exp(log(pz)^2-@xp1*log(pz)-pz*log(c1))+a^2+exp(log(a)^2-@xp1*log(a)-a*log(c2))
elseif @v==2
pz=pz^2+exp(log(pz)^2+@xp1*pz*c1*log(pz)+log(c1))+a^2+exp(log(a)^2+@xp1*a*c2*log(a)+log(c2))
elseif @v==3
pz=pz^2+exp(log(pz)^2+@xp1*pz*c1*log(pz)-log(c1))+a^2+exp(log(a)^2+@xp1*a*c2*log(a)-log(c2))
elseif @v==4
pz=pz^2+exp(log(pz)^2+@xp1*pz*c1*log(pz)+pz^2*log(c1))+a^2+exp(log(a)^2+@xp1*a*c2*log(a)+a^2*log(c2))
elseif @v==5
pz=pz^2+exp(log(pz)^2+@xp1*pz*c1*log(pz)-pz^2*log(c1))+a^2+exp(log(a)^2+@xp1*a*c2*log(a)-a^2*log(c2))
elseif @v==6
pz=c1*pz^2+exp(log(pz)^2-@xp1*log(pz)+log(c1))+(c2+0.8)*a^2+exp(log(a)^2-@xp1*log(a)+log(c2+0.8))
elseif @v==7
pz=c1*pz^2+exp(log(pz)^2-@xp1*log(pz)-log(c1))+c2*a^2+exp(log(a)^2-@xp1*log(a)-log(c2))
elseif @v==8
pz=c1*pz^2+exp(log(pz)^2-@xp1*log(pz)+pz*log(c1))+c2*a^2+exp(log(a)^2-@xp1*log(a)+a*log(c2))
elseif @v==9
pz=c1*pz^2+exp(log(pz)^2-@xp1*log(pz)-pz*log(c1))+c2*a^2+exp(log(a)^2-@xp1*log(a)-a*log(c2))
elseif @v==10
pz=c1*pz^2+exp(log(pz)^2-@xp1*log(pz)+pz^2*log(c1))+c2*a^2+exp(log(a)^2-@xp1*log(a)+a^2*log(c2))
elseif @v==11
pz=c1*pz^2+exp(log(pz)^2-@xp1*log(pz)-pz^2*log(c1))+c2*a^2+exp(log(a)^2-@xp1*log(a)-a^2*log(c2))
elseif @v==12
pz=pz^2+exp(log(pz)^2+@xp1*log(pz)+pz*log(c1))+pk^2+exp(log(pk)^2+@xp1*log(pk)+pk*log(c2))
elseif @v==13
pz=pz^2+exp(log(pz)^2-@xp1*log(pz)-pz*log(c1))+pk^2+exp(log(pk)^2-@xp1*log(pk)-pk*log(c2))
elseif @v==14
pz=pz^2+exp(log(pz)^2+@xp1*pz*c1*log(pz)+log(c1))+pk^2+exp(log(pk)^2+@xp1*pk*c2*log(pk)+log(c2))
elseif @v==15
pz=pz^2+exp(log(pz)^2-@xp1*pz*c1*log(pz)-log(c1))+pk^2+exp(log(pk)^2-@xp1*pk*c2*log(pk)-log(c2))
elseif @v==16
pz=pz^2+exp(log(pz)^2+@xp1*pz*c1*log(pz)+pz^2*log(c1))+pk^2+exp(log(pk)^2+@xp1*pk*c2*log(pk)+pk^2*log(c2))
elseif @v==17
pz=pz^2+exp(log(pz)^2-@xp1*pz*c1*log(pz)-pz^2*log(c1))+pk^2+exp(log(pk)^2-@xp1*pk*c2*log(pk)-pk^2*log(c2))
elseif @v==18
pz=c1*pz^2+exp(log(pz)^2+@xp1*log(pz)+log(c1))+(c2)*pk^2+exp(log(pk)^2+@xp1*log(pk)+log(c2))
elseif @v==19
pz=c1*pz^2+exp(log(pz)^2-@xp1*log(pz)-log(c1))+c2*pk^2+exp(log(pk)^2-@xp1*log(pk)-log(c2))
elseif @v==20
pz=c1*pz^2+exp(log(pz)^2+@xp1*log(pz)+pz*log(c1))+c2*pk^2+exp(log(pk)^2+@xp1*log(pk)+pk*log(c2))
elseif @v==21
pz=c1*pz^2+exp(log(pz)^2-@xp1*log(pz)-pz*log(c1))+c2*pk^2+exp(log(pk)^2-@xp1*log(pk)-pk*log(c2))
elseif @v==22
pz=c1*pz^2+exp(log(pz)^2+@xp1*log(pz)+pz^2*log(c1))+c2*pk^2+exp(log(pk)^2+@xp1*log(pk)+pk^2*log(c2))
else
pz=c1*pz^2+exp(log(pz)^2-@xp1*log(pz)-pz^2*log(c1))+c2*pk^2+exp(log(pk)^2-@xp1*log(pk)-pk^2*log(c2))
endif
else
if @v==0
pz=pz^2+exp(log(pz)^2-@xp1*log(pz)+pz*log(-c1))+a^2+exp(log(a)^2-@xp1*log(a)+a*log(-c2))
elseif @v==1
pz=pz^2+exp(log(pz)^2-@xp1*log(pz)-pz*log(c1+7))+a^2+exp(log(a)^2-@xp1*log(a)-a*log(c2+7))
elseif @v==2
pz=pz^2+exp(log(pz)^2+@xp1*pz*(-c1)*log(pz)+log(-c1))+a^2+exp(log(a)^2+@xp1*a*c2*log(a)+log(c2))
elseif @v==3
pz=pz^2+exp(log(pz)^2-@xp1*pz*(c1+2.4)*log(pz)-log(c1+2.4))+a^2+exp(log(a)^2-@xp1*a*(c2+2.4)*log(a)-log(c2+2.4))
elseif @v==4
pz=pz^2+exp(log(pz)^2-@xp1*pz*(c1+8.25)*log(pz)+pz^2*log(c1+8.25))+a^2+exp(log(a)^2-@xp1*a*(-(c2-4.25))*log(a)+a^2*log(-(c2-4.25)))
elseif @v==5
pz=pz^2+exp(log(pz)^2-@xp1*pz*(c1+4.25)*log(pz)-pz^2*log(c1+4.25))+a^2+exp(log(a)^2-@xp1*a*(c2+9.25)*log(a)-a^2*log(c2+9.25))
elseif @v==6
pz=(c1+0.75)*pz^2+exp(log(pz)^2-@xp1*log(pz)+log(c1+0.75))+(c2+0.75)*a^2+exp(log(a)^2-@xp1*log(a)+log(c2+0.75))
elseif @v==7
pz=(c1-0.3)*pz^2+exp(log(pz)^2-@xp1*log(pz)-log(c1-0.3))+(c2+6.25)*a^2+exp(log(a)^2-@xp1*log(a)-log(c2+6.25))
elseif @v==8
pz=(c1+0.35)*pz^2+exp(log(pz)^2-@xp1*log(pz)+pz*log(c1+0.35))+(c2+0.75)*a^2+exp(log(a)^2-@xp1*log(a)+a*log(c2+0.75))
elseif @v==9
pz=(c1+0.75)*pz^2+exp(log(pz)^2-@xp1*log(pz)-pz*log(c1+0.75))+(c2+6.5)*a^2+exp(log(a)^2-@xp1*log(a)-a*log(c2+6.5))
elseif @v==10
pz=(-c1)*pz^2+exp(log(pz)^2-@xp1*log(pz)+pz^2*log(-c1))+(c2+0.45)*a^2+exp(log(a)^2-@xp1*log(a)+a^2*log(c2+0.45))
elseif @v==11
pz=(-c1)*pz^2+exp(log(pz)^2-@xp1*log(pz)-pz^2*log(-c1))+(c2+1.75)*a^2+exp(log(a)^2-@xp1*log(a)-a^2*log(c2+1.75))
elseif @v==12
pz=pz^2+exp(log(pz)^2-@xp1*log(pz)+pz*log(c1+0.425))+pk^2+exp(log(pk)^2-@xp1*log(pk)+pk*log(c2+0.425))
elseif @v==13
pz=pz^2+exp(log(pz)^2+@xp1*log(pz)-pz*log(c1+29.15))+pk^2+exp(log(pk)^2+@xp1*log(pk)-pk*log(c2+29.15))
elseif @v==14
pz=pz^2+exp(log(pz)^2+@xp1*pz*c1*log(pz)+log(c1))+pk^2+exp(log(pk)^2+@xp1*pk*c2*log(pk)+log(c2))
elseif @v==15
pz=pz^2+exp(log(pz)^2-@xp1*pz*(c1-0.85)*log(pz)-log(c1-0.85))+pk^2+exp(log(pk)^2-@xp1*pk*(c2-0.85)*log(pk)-log(c2-0.85))
elseif @v==16
pz=pz^2+exp(log(pz)^2-@xp1*pz*(c1+9)*log(pz)+pz^2*log(c1+9))+pk^2+exp(log(pk)^2-@xp1*pk*(-c2)*log(pk)+pk^2*log(-c2))
elseif @v==17
pz=pz^2+exp(log(pz)^2-@xp1*pz*(c1+1.75)*log(pz)-pz^2*log(c1+1.75))+pk^2+exp(log(pk)^2-@xp1*pk*(c2+9.25)*log(pk)-pk^2*log(c2+9.25))
elseif @v==18
pz=c1*pz^2+exp(log(pz)^2+@xp1*log(pz)+log(c1))+(c2+0.8)*pk^2+exp(log(pk)^2+@xp1*log(pk)+log(c2+0.8))
elseif @v==19
pz=(c1-2)*pz^2+exp(log(pz)^2-@xp1*log(pz)-log(c1-2))+(c2-0.3)*pk^2+exp(log(pk)^2-@xp1*log(pk)-log(c2-0.3))
elseif @v==20
pz=(c1+1.4)*pz^2+exp(log(pz)^2-@xp1*log(pz)+pz*log(c1+1.4))+(-c2)*pk^2+exp(log(pk)^2-@xp1*log(pk)+pk*log(-c2))
elseif @v==21
pz=(c1+1.25)*pz^2+exp(log(pz)^2-@xp1*log(pz)-pz*log(c1+1.25))+(c2+0.75)*pk^2+exp(log(pk)^2-@xp1*log(pk)-pk*log(c2+0.75))
elseif @v==22
pz=(c1+1)*pz^2+exp(log(pz)^2-@xp1*log(pz)+pz^2*log(c1+1))+(-c2)*pk^2+exp(log(pk)^2-@xp1*log(pk)+pk^2*log(-c2))
else
pz=(-c1)*pz^2+exp(log(pz)^2-@xp1*log(pz)-pz^2*log(-c1))+(-c2)*pk^2+exp(log(pk)^2-@xp1*log(pk)-pk^2*log(-c2))
endif
endif
return pz
return pk
endfunc
bool func IsBailedOut(complex pz)
bool bail=false
bail=(|(pz+pk)/2|>@p_bailout)
return bail
endfunc

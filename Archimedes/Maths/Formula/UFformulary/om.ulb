pz=@sp
pk=@sp
elseif @sv==3
pz=@sf(pz)
pk=@sp
pw=pz
elseif @sv==4
pk=@sf(pz)-@sp
pw=@sf(pz)+@sp
pz=@sf(pz)-@sp
else
pk=@sf(pz)-@sp
pz=@sf(pz)
pw=@sp
endif
else

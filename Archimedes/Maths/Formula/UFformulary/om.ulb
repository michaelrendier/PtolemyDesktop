class OM_TetravarX11(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
a=(0,0)
b=(0,0)
c=(0,0)
if @mj==0
pk=@sp
pq=@sp
pz=@sp
pw=@sp
else
pz=@pf(pz)
pk=pz
pq=pz
pw=pz
endif
return pz
return pq
return pk
return pw
endfunc
private:
complex pk
complex pw
complex pq
complex a
complex b
complex c
complex fpixel
complex func Iterate(complex pz)
pw=@wp1*pw+@wp2
pk=@kp1*pk+@kp2
pz=@zp1*pz+@zp2
pq=@qp1*pq+@qp2
a=pw
b=pk
c=pz
if @mj==0
if @v==0
pw=pw^2*(pk+@p1*@pf(fpixel))+pq*pz
pk=(pk-pz)^2+@p2*@pf(fpixel)*a*pq
pz=pz*pq+@p3*@pf(fpixel)+a*b
pq=pq^2+a^2+@p4*@pf(fpixel)/c+pk
elseif @v==1
pw=pw^2*(pz+@p1*@pf(fpixel))+pw*pq
pk=(pk-pq)^2+@p2*@pf(fpixel)*pk*a
pz=pz*pq+@p3*@pf(fpixel)+b*pz
pq=pq^2+a^2+@p4*@pf(fpixel)/c+pz
elseif @v==2
pw=pw^2*(pk+@p1*@pf(fpixel))+pk*pw
pk=(pk-pz)^2+(@p2+2.45)*@pf(fpixel)*pz*pk
pz=pz*pq+@p3*@pf(fpixel)+pz*pq
pq=pq^2+a^2+@p4*@pf(fpixel)/c+pq
else
pw=pw^2*(pk+@p1*@pf(fpixel))+pz*pk
pk=(pk-pz)^2+(@p2+3.1)*@pf(fpixel)*pq*pz
pz=pz*pq+@p3*@pf(fpixel)+pq*a
pq=pq^2+a^2+@p4*@pf(fpixel)/c+a
endif
else
if @v==0
pw=pw^2*(pk+@p1)+pq*pz
pk=(pk-pz)^2+@p2*a*pq
pz=pz*pq+@p3+a*b
pq=pq^2+a^2+@p4/c+pk
elseif @v==1
pw=pw^2*(pk+@p1)+pw*pq
pk=(pk-pz)^2+@p2*pk*a
pz=pz*pq+@p3+b*pz
pq=pq^2+a^2+@p4/c+pz
elseif @v==2
pw=pw^2*(pk+@p1)+pk*pw
pk=(pk-pz)^2+(@p2+3.6)*pz*pk
pz=pz*pq+@p3+pz*pq
pq=pq^2+a^2+@p4/c+pq
else
pw=pw^2*(pk+@p1)+pz*pk
pk=(pk-pz)^2+(@p2+3.1)*pq*pz
pz=pz*pq+@p3+pq*a
pq=pq^2+a^2+@p4/c+a
endif
endif
pz=pz+pk+pw+pq
return pz
return pw
return pk
return pq
endfunc

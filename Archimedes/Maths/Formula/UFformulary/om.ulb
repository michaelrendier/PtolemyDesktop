pk=pk/pz+@p2*c
pz=a^2+b^2+pz^2+pq^2+@p3*c
pq=pq/d+@p4*c
c=@p5*c/2+@p6*(pz+pw+pk+pq)
endif
else
if @v==0
pw=pw/pz+@p1*c
pk=pk/pz+@p2*c
pz=pw^2+pk^2+pz^2+pq^2+@p3*c

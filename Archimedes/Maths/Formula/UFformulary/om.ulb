class OM_Ahtanu(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fPixel=pz
if @v==0 || @v==1
return @sp
else
return @sp+1
endif
endfunc
private:
complex fPixel
complex func Iterate(complex pz)
if @v==0
pz=@p2*1i*pz
elseif @v==1
pz=(@p2-0.7)*1i*pz
elseif @v==2
pz=(@p2-1.1)*1i*pz
else
pz=(@p2-2.9)*1i*pz
endif
if @v==0
pz=exp(@p3*1i)*pz^2*(cos(@p1*tan(pz))+1i*sin(@p1*tan(pz)))+@pf(fpixel)
elseif @v==1
pz=exp(@p3*1i)*pz^2*(cos(@p1*tanh(pz))+1i*sin(@p1*tanh(pz)))+@pf(fpixel)
elseif @v==2
pz=exp(@p3*1i)*pz^2*(cos(@p1*cotan(pz))+1i*sin(@p1*cotan(pz)))+@pf(fpixel)
else
pz=exp(@p3*1i)*pz^2*(cos(@p1*cotanh(pz))+1i*sin(@p1*cotanh(pz)))+@pf(fpixel)
endif
return pz
endfunc

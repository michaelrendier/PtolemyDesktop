pz=@zp1*pz+@zp2
a=pk
pk=@bp1*@bf(pk/pz)+@bp2
if @lv==0
pz=pz^@pow-@p2*c*pz^(@pow-2)+a^@pow-@p2*c*a^(@pow-2)+@p1
elseif @lv==1
pz=pz^@pow-@p2*c*pz^(@pow-2)+pk^@pow-@p2*c*pk^(@pow-2)+@p1

class OM_FomulBedubur(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fPixel=pz
if @jm==0
pz=@sf(pz)
c=@c
else
pz=@sp
c=@pf(fpixel)
endif
return pz
endfunc
private:
complex fPixel
complex c
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if @jm==0
pz=@p1*(pz^2+1/pz)+c
else
pz=(@p1+1)*(pz^2+1/pz)+c
endif
return pz
endfunc

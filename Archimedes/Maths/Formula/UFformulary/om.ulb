class OM_WhittakerErratum1(common.ulb:ConvergentFormula) {
public:
complex func Init(complex pz)
pz=@sf(pz)
return pz
endfunc
complex func Iterate(complex pz)
return @fn2(pz-0.5*@p1*(pz^@p3-@p4)*(2-@p2*(pz^@p3-@p4)))
endfunc

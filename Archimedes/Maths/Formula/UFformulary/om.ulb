class OM_Schröder2(common.ulb:ConvergentFormula) {
;Schröder's root-finding method for various expressions of z
public:
complex func Init(complex pz)
ConvergentFormula.Init(pz)
return @sf(pz)
endfunc
complex func Iterate(complex pz)
ConvergentFormula.Iterate(pz)
if @v==0
f=(pz^2+pz)^@pow-@sp2
f1=@pow*(2*pz+1)*(pz*(pz+1))^(@pow-1)
f2=(@pow-1)*@pow*(2*pz+1)^2*(pz*(pz+1))^(@pow-2)+2*@pow*(pz*(pz+1))^(@pow-1)
elseif @v==1
f=tan(pz)^@pow-@sp2
f1=@pow*(1/sin(pz))*(1/cos(pz))*tan(pz)^@pow

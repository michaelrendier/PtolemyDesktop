class OM_Rootmod4(common.ulb:ConvergentFormula) {
public:
complex func Init(complex pz)
ConvergentFormula.Init(pz)
fPixel=pz
return @sf(pz)
endfunc
private:
complex fpixel
complex func Iterate(complex pz)
ConvergentFormula.Iterate(pz)
z=@zp1*@zf(z)+@zp2
f=pz^@pow-@p2
f1=@pow*pz^(@pow-1)
return pz+@p1*(2*f*f1^2-f^6)/(2*f1^3)+@p3+@p4*@pf(fpixel)
endfunc

class OM_AttraktorTraps2(common.ulb:GradientColoring) {
public:
func Init(complex pz, complex ppixel)
GradientColoring.Init(pz, ppixel)
b=@p5
c=0.0
d=0.0
k2=@at3
a2=0.0
f2=(@at2-1)/@at1
b2=0.0
d2=0.0
endfunc
func Iterate(complex pz)
GradientColoring.Iterate(pz)
if @version==100
float x=real(fn1(pz))
float y=imag(fn1(pz))
if @V=="Brusselator"
d=b-abs(atan2((1-(@p1+1)*x+y*x^2)/@p2+flip((@p1*x-y*x^2)/@p3)))
elseif @V =="Oscillating Chemical Reaction"
d=b-abs(atan2((@p1-x-4*x*y)/(1+x^2)+flip(@p2*x*(1-y)/(1+x^2))))
elseif @V=="Buckling Column Model"
d=b-abs(atan2(y+flip(-(@p1*x^3+@p2*x+@p3*y)/@p4)))
elseif @V=="Rayleigh"
d=b-abs(atan2(y+flip(-(x+@p2*y^3-@p1*y)/@p3)))
elseif @V=="Cathala"
d=b-abs(atan2(@p1*x+y+flip(@p2+x^2)))
elseif @V=="Sprott-Elhadj"
d=b-abs(atan2(@p1*x/(1+y^2)+flip(x+@p2*y)))
elseif @V=="Modified Lozi"
d=b-abs(atan2(1+@p1*(cabs(x)-y^2)+y+flip(@p2*x)))
elseif @V=="Multifold Henon"
d=b-abs(atan2(1-@p1*sin(x)+@p2*y+flip(x)))
elseif @V=="Mira"
d=b-abs(atan2(@p2*y+@p1*x+2*(1-@p1)*x^2/(1+x^2)\
+flip(-x+@p1*(@p2*y+@p1*x+2*(1-@p1)*x^2/(1+x^2))\
+2*(1-@p1)*(@p2*y+@p1*x+2*(1-@p1)*x^2/(1+(@p2*y\
+@p1*x+2*(1-@p1)*x^2/(1+x^2))^2))^2/(1+x^2))))
elseif @V=="Garrote-Mira"
d=b-abs(atan2(y+@p1*(1-0.05*y^2)+@p2*x+2*(1-@p2)*x^2/(1+x^2)\
+flip(-x+@p2*(y+@p1*(1-0.05*y^2)+@p2*x+2*(1-@p2)*x^2/(1+x^2))\
+2*(1-@p2)*(y+@p1*(1-0.05*y^2)+@p2*x+2*(1-@p2)*x^2/(1+x^2))\
^2/(1+(y+@p1*(1-0.05*y^2)+@p2*x+2*(1-@p2)*x^2/(1+x^2))^2))))
elseif @V=="Hopalong"
d=b-abs(atan2(y-(x/cabs(x))*sqrt(cabs(@p2*x-@p3))+flip(@p1-x)))
elseif @V=="Martin"
d=b-abs(atan2(y+sin(x)+flip(@p1-x)))
elseif @V=="Popcorn"
d=b-abs(atan2(@p1*sin(y+tan(@p2*y))+flip(@p1*sin(x+tan(@p2*x)))))
elseif @V=="Popcorn 2"
d=b-abs(atan2(x-@p1*sin(y+tan(@p2*y))+flip(y-@p1*sin(x+tan(@p2*x)))))
elseif @V=="Ushiki"
d=b-abs(atan2((@p1-x-@p2*y)*x+flip((@p3-y-@p4*x)*y)))
elseif @V=="Strelkova-Anishchenko"
d=b-abs(atan2(1-@p1*x^2+@p2*(y-x)+flip(1-@p1*y^2+@p2*(x-y))))
elseif @V=="Cat"
d=b-abs(atan2((2*x+y)%1+flip((x+y)%1)))
elseif @V=="HCA"
d=b-abs(atan2(1-@p1*x^2+@p2*(y^2-x^2)+flip(1-@p1*y^2+@p2*(x^2-y^2))))
elseif @V=="Coupled Logistic"
d=b-abs(atan2((1-@p1)*@p2*x*(1-x)+@p1*@p2*y*(1-y)+flip((1-@p1)*@p2*y*(1-y)+@p1*@p2*x*(1-x))))
elseif @V=="Sine"
d=b-abs(atan2(y+flip(@p1*sin(x)+@p2*y)))
elseif @V=="Henon"
d=b-abs(atan2(1-@p1*x^2+y+flip(@p2*x)))
elseif @V=="Burgers"
d=b-abs(atan2(@p1*x-y^2+flip(@p2*y+x*y)))
elseif @V=="Cao-Lai"
d=b-abs(atan2(@p1*x*(1-x)+flip(@p2*x*sin(2*pi*y)/(2*pi))))
elseif @V=="Marotto-Lorenz"
d=b-abs(atan2((1-@p1*x-@p2*y)*(@p1*x+@p2*y)+flip(x)))
elseif @V=="de Jong"
d=b-abs(atan2(sin(@p1*y)-cos(@p2*x)+flip(sin(@p3*x)-cos(@p4*y))))
elseif @V=="Clifford"
d=b-abs(atan2(sin(@p1*y)+@p3*cos(@p1*x)+flip(sin(@p2*x)+@p4*cos(@p2*y))))
elseif @V=="Svensson"
d=b-abs(atan2(@p4*sin(@p1*x)-sin(@p2*y)+flip(@p3*cos(@p1*x)+cos(@p2*y))))
elseif @V=="Chip"
d=b-abs(atan2(y-(x/cabs(x))*cos(sqr(log(abs(@p2*x-@p3))))*atan(sqr(log(abs(@p3*x-@p2))))+flip(@p1-x)))
elseif @V=="Chirikov Mod"
d=b-abs(atan2(x+y+(@p1/2*pi)*sin(2*pi*x)+flip(y+(@p1/2*pi)*sin(2*pi*x))))
elseif @V=="Duffing"
d=b-abs(atan2(y+flip(-@p2*x+@p1*y-y^3)))
elseif @V=="Quadruptwo"
d=b-abs(atan2(y-(x/cabs(x))*sin(log(abs(@p2*x-@p3)))*atan(sqr(log(abs(@p3*x-@p2))))+flip(@p1-x)))
elseif @V=="Ikeda"
d=b-abs(atan2(@p1+@p2*(x*cos(@p3-@p4/(x^2+y^2+1))-y*sin(@p3-@p4/(x^2+y^2+1))) \
+flip(@p2*(x*sin(@p3-@p4/(x^2+y^2+1))+y*cos(@p3-@p4/(x^2+y^2+1))))))
elseif @V=="Gumowski-Mira"
d=b-abs(atan2(y+@p1*x+2*(1-@p1)*x^2/(1+x^2)+@p2*(1-@p3*y^2)*y+ \
flip(-x+@p1*(y+@p1*x+2*(1-@p1)*x^2/(1+x^2)+@p2*(1-@p3*y^2)*y) \
+2*(1-@p1)*(y+@p1*x+2*(1-@p1)*x^2/(1+x^2)+ \
@p2*(1-@p3*y^2)*y)^2/(1+(y+@p1*x+2*(1-@p1)*x^2/(1+x^2)+@p2*(1-@p3*y^2)*y)^2))))
elseif @V=="Gumowski-Mira Mod"
d=b-abs(atan2((1-@p1)*x+y+flip(y+@p2*x+2*(1-@p2)*x^2*(1+x^2)^(-2))))
elseif @V=="Gumowski-Mira 2"
d=b-abs(atan2(y+@p1*(1-@p2*y^2)*y+@p3*x+2*(1-@p3)*x^2/(1+x^2)+flip \
(-x+@p3*(y+@p1*(1-@p2*y^2)*y+@p3*x+2*(1-@p3)*x^2/(1+x^2)) \
+2*(1-@p3)*(y+ @p1*(1-@p2*y^2)*y+@p3*x+2*(1-@p3)*x^2/(1+x^2))^2 \
/(1+(y+@p1*(1-@p2*y^2)*y+@p3*x+2*(1-@p3)*x^2/(1+x^2))^2))))
elseif @V=="Bogdanov"
d=b-abs(atan2(flip(y+@p1*y+@p2*x*(x-1)+@p3*x*y)+x+y+@p1*y+@p2*x*(x-1)+@p3*x*y))
elseif @V=="Mira 2"
d=b-abs(atan2(x^2-y^2+@p1*x+@p2+flip(2*x*y-5*@p1*y/2)))
elseif @V=="Mira 3"
d=b-abs(atan2((1-@p1)*x+y+flip(@p1*@p2*x+@p3*y-@p1*x^3)))
elseif @V=="Gingerbread"
d=b-abs(atan2(1-y+cabs(x)+flip(x)))
elseif @V=="Hamilton"
d=b-abs(atan2(x+@p1*@p2*sin(2*pi*y)+flip(y-(@p1/@p2)*sin(2*pi*(x+@p1*@p2*sin(2*pi*y))))))
elseif @V=="Kam Torus"
d=b-abs(atan2(x*cos(@p1)+(x^2-y)*sin(@p1)+flip(x*sin(@p1)-(x^2-y)*cos(@p1))))
elseif @V=="Lozi"
d=b-abs(atan2(1+y-@p1*cabs(x)+flip(@p2*x)))
elseif @V=="Threeply"
d=b-abs(atan2(y-(x/cabs(x))*(abs(sin(x)*cos(@p2)+@p3-x*sin(@p1+@p2+@p3)))+flip(@p1-x)))
elseif @V=="Tinkerbell"
d=b-abs(atan2(x^2+-y^2+@p1*x+@p2*y+flip(2*x*y+@p3*x+@p4*y)))
elseif @V=="Van der Pol"
d=b-abs(atan2(@p1*(x-x^3/3-y)+flip(x/@p1)))
elseif @V=="Van der Pol 2"
d=b-abs(atan2(y+flip(@p1*(1-x^2)*y-x)))
endif
if d>0
if @Va==0
c=abs(c^(2/3)+d^(2/3)-@p6)
elseif @Va==1
c=c+d+1-@p6
elseif @Va==2
c=abs(d-@p6*cosh(c/@p6))
elseif @Va==3
c=sqrt(c+d)+1-@p6
elseif @Va==4
c=|cabs(pz*d)-@p6|
endif
endif
else
pz=@zp1b*@zf2(pz)+@zp2b
x2=real(pz)
y2=imag(pz)
if @v2=="Bedhead"
a2=cabs((sin(x2*y2/(2*@p2b))*y2+cos(@p1b*x2-y2)+flip(x2+sin(y2)/(2*@p2b)))-k2)-@at4
elseif @v2=="Bogdanov"
a2=cabs((flip(y2+@p1b*y2+@p2b*x2*(x2-1)+@p3b*x2*y2)+x2+y2+@p1b*y2+@p2b*x2*(x2-1)+@p3b*x2*y2)-k2)-@at4
elseif @v2=="Buckling Column Model"
a2=cabs((y2+flip(-(@p1b*x2^3+@p2b*x2+@p3b*y2)/@p4b))-k2)-@at4
elseif @v2=="Business Cycle"
a2=cabs((x2+y2+flip((@p1b+0.95+1.2i)*y2-(@p1b+0.95+1.2i)*y2^3-(@p2b-1.95+0.15i)*x2))-k2)-@at4
elseif @v2=="Cathala"
a2=cabs(((@p1b-1-0.25i)*x2+y2+flip((@p2b-0.05+2.8i)/2+x2^2))-k2)-@at4
elseif @v2=="Chip"
a2=cabs((y2-(x2/cabs(x2))*cos(sqr(log(abs(@p2b*x2-(@p3b-0.5+1.15i)))))*atan(sqr(log(abs((@p3b-0.5+1.15i)*x2-@p2b))))+flip(@p1b-x2))-k2)-@at4
elseif @v2=="Chirikov Mod"
a2=cabs((x2+y2+((@p1b-0.85-0.1i)/2*pi)*sin(2*pi*x2)+flip(y2+((@p1b-0.85-0.1i)/2*pi)*sin(2*pi*x2)))-k2)-@at4
elseif @v2=="Coupled Logistic"
a2=cabs(((1-@p1b)*(@p2b-2.1-0.4i)*x2*(1-x2)+@p1b*(@p2b-2.1-0.4i)*y2*(1-y2)+flip((1-@p1b)*(@p2b-2.1-0.4i)*y2*(1-y2)+@p1b*(@p2b-2.1-0.4i)*x2*(1-x2)))-k2)-@at4
elseif @v2=="de Jong"
a2=cabs((sin(@p1b*y2)-cos((@p2b-3.35+0.25i)*x2)+flip(sin((@p3b-2.35+0.6i)*x2)-cos((@p4b-0.1-0.9i)*y2)))-k2)-@at4
elseif @v2=="Duffing"
a2=cabs((y2+flip(x2-x2^3-@p1b*y2+@p2b))-k2)-@at4
elseif @v2=="Gumowski-Mira 1"
a2=cabs((y2+@p1b*(1-0.05*y2^2)+(@p2b+0.5+0.4i)*x2+2*(1-(@p2b+0.5+0.4i))*x2^2/(1+x2^2)\
+flip(-x2+(@p2b+0.5+0.4i)*(y2+@p1b*(1-0.05*y2^2)+(@p2b+0.5+0.4i)*x2+2*(1-(@p2b+0.5+0.4i))*x2^2/(1+x2^2))\
+2*(1-(@p2b+0.5+0.4i))*(y2+@p1b*(1-0.05*y2^2)+(@p2b+0.5+0.4i)*x2+2*(1-(@p2b+0.5+0.4i))*x2^2/(1+x2^2))\
^2/(1+(y2+@p1b*(1-0.05*y2^2)+(@p2b+0.5+0.4i)*x2+2*(1-(@p2b+0.5+0.4i))*x2^2/(1+x2^2))^2)))-k2)-@at4
elseif @v2=="Gumowski-Mira 2"
a2=cabs((y2+@p1b*(1-@p2b*y2^2)*y2+(@p3b-0.75-0.7i)*x2+2*(1-(@p3b-0.75-0.7i))*x2^2/(1+x2^2)+flip \
(-x2+(@p3b-0.75-0.7i)*(y2+@p1b*(1-@p2b*y2^2)*y2+(@p3b-0.75-0.7i)*x2+2*(1-(@p3b-0.75-0.7i))*x2^2/(1+x2^2)) \
+2*(1-(@p3b-0.75-0.7i))*(y2+@p1b*(1-@p2b*y2^2)*y2+(@p3b-0.75-0.7i)*x2+2*(1-(@p3b-0.75-0.7i))*x2^2/(1+x2^2))^2 \
/(1+(y2+@p1b*(1-@p2b*y2^2)*y2+(@p3b-0.75-0.7i)*x2+2*(1-(@p3b-0.75-0.7i))*x2^2/(1+x2^2))^2)))-k2)-@at4
elseif @v2=="Gumowski-Mira Mod"
a2=cabs(((1-@p1b)*x2+y2+flip(y2+(@p2b-1.35-1.2i)*x2+2*(1-(@p2b-1.35-1.2i))*x2^2*(1+x2^2)^(-2)))-k2)-@at4
elseif @v2=="Hamilton"
a2=cabs((x2+(@p1b-0.93+0.15i)*@p2b*sin(2*pi*y2)+flip(y2-((@p1b-0.93+0.15i)/@p2b)*sin(2*pi*(x2+(@p1b-0.93+0.15i)*@p2b*sin(2*pi*y2)))))-k2)-@at4
elseif @v2=="Henon"
a2=cabs((1-@p1b*x2^2+y2+flip(@p2b*x2))-k2)-@at4
elseif @v2=="Henon-Heiles 1"
a2=cabs((-@p1b*x2-@p2b*x2*y2+flip(-@p3b*y2-@p4b*x2^2+@p5b*y2^2))-k2)-@at4
elseif @v2=="Henon-Heiles 2"
a2=cabs((y2+flip(-@p1b*x2-@p2b*x2^2+@p3b))-k2)-@at4
elseif @v2=="Hopalong"
a2=cabs((y2-(x2/cabs(x2))*sqrt(cabs((@p2b-2.3+0.55i)*x2-@p3b))+flip((@p1b-1.35-1.25i)-x2))-k2)-@at4
elseif @v2=="Horsthemke-Lefever"
a2=cabs((@p1b*x2*(1-x2/@p3b)-@p2b*x2*y2+flip(-@p2b*x2*y2+@p4b*(@p5b-y2)))-k2)-@at4
elseif @v2=="Ikeda"
a2=cabs((@p1b+@p2b*(x2*cos((@p3b-0.55+0.6i)-@p4b/(x2^2+y2^2+1))-y2*sin((@p3b-0.55+0.6i)-@p4b/(x2^2+y2^2+1))) \
+flip(@p2b*(x2*sin((@p3b-0.55+0.6i)-@p4b/(x2^2+y2^2+1))+y2*cos((@p3b-0.55+0.6i)-@p4b/(x2^2+y2^2+1)))))-k2)-@at4
elseif @v2=="Ilhem-Amel 1"
a2=cabs((x2^3+@p1b*x2+@p2b+y2+flip(@p3b*x2))-k2)-@at4
elseif @v2=="Ilhem-Amel 2"
a2=cabs((@p4b*x2^3+@p1b*x2+@p2b/2+@p5b*y2+flip(@p3b*x2+@p6b*y2))-k2)-@at4
elseif @v2=="Kam Torus"
a2=cabs((x2*cos(@p1b+1.05-0.95i)+(x2^2-y2)*sin(@p1b+1.05-0.95i)+flip(x2*sin(@p1b+1.05-0.95i)-(x2^2-y2)*cos(@p1b+1.05-0.95i)))-k2)-@at4
elseif @v2=="Knot"
a2=cabs((-y2+flip(x2^4-y2))-k2)-@at4
elseif @v2=="Kolmogorov-Volterra"
a2=cabs(((x2*((@p1b-3.2-1.2i)-x2^2)-@p2b*x2*y2)/(1+x2^2)+flip(((@p3b+0.8-0.55i)*x2^2-1)*y2/(1+x2^2)))-k2)-@at4
elseif @v2=="Limit Cycle"
a2=cabs((x2-y2-@p1b*x2*(x2^2+y2^2)+@p3b+flip(x2+y2-@p2b*y2*(x2^2+y2^2)+@p4b))-k2)-@at4
elseif @v2=="Lozi"
a2=cabs((1+y2-@p1b*cabs(x2)+flip((@p2b-0.4+0.1i)*x2))-k2)-@at4
elseif @v2=="Marotto-Lorenz"
a2=cabs(((1-@p1b*x2-@p2b*y2)*(@p1b*x2+@p2b*y2)+flip(x2))-k2)-@at4
elseif @v2=="Martin"
a2=cabs((y2+sin(x2)+flip((@p1b-0.1+0.75i)-x2))-k2)-@at4
elseif @v2=="Mira 1"
a2=cabs((x2^2-y2^2+@p1b*x2+(@p2b-0.35+0.15i)+flip(2*x2*y2-5*@p1b*y2/2+(@p3b-1-0.75i)))-k2)-@at4
elseif @v2=="Mira 2"
a2=cabs(((1-(@p1b-1.55-0.15i))*x2+y2+flip((@p1b-1.55-0.15i)*(@p2b+0.85+1.5i)*x2+@p3b*y2-(@p1b-1.55-0.15i)*x2^3))-k2)-@at4
elseif @v2=="Mira 3"
a2=cabs((@p1b*x2+y2+flip((@p2b-0.7-0.6i)+x2^2))-k2)-@at4
elseif @v2=="Modified Lozi"
a2=cabs((1+@p1b*(cabs(x2)-y2^2)+y2+flip(@p2b*x2))-k2)-@at4
elseif @v2=="Multifold Henon"
a2=cabs((1-(@p1b+1.6+0.55i)*sin(x2)+@p2b*y2+flip(x2))-k2)-@at4
elseif @v2=="Pharaoh"
a2=cabs((-y2+@p1b*cos(x2)*sin(1-x2^2-y2^2)+@p3b+flip(x2+@p2b*cos(y2)*sin(1-x2^2-y2^2)+@p4b))-k2)-@at4
elseif @v2=="Pickover 1"
a2=cabs((sin((@p1b+0.3-0.55i)*y2)+@p2b*sin((@p1b+0.3-0.55i)*x2)+flip(sin(@p3b*x2)+@p4b*sin(@p3b*y2)))-k2)-@at4
elseif @v2=="Pickover 2"
a2=cabs((sin((@p1b-1.5+0.1i)*y2)+sqr(sin((@p1b-1.5+0.1i)*x2))+flip(sin((@p2b-0.75+0.25i)*x2)+sqr(sin((@p2b-0.75+0.25i)*y2))))-k2)-@at4
elseif @v2=="Pickover 3"
a2=cabs((sin((@p1b-0.35-0.8i)*y2)+(sin((@p1b-0.35-0.8i)*x2))^2+(sin((@p1b-0.35-0.8i)*x2))^3+flip(sin(@p2b*x2)+(sin(@p2b*y2))^2+(sin(@p3b*y2))^3))-k2)-@at4
elseif @v2=="Pickover 4"
a2=cabs((abs(sin((@p1b-1-1.4i)*y2))+(sin((@p1b-1-1.4i)*x2))^2+flip(abs(sin((@p2b+4-0.5i)*x2))+(sin((@p1b-1-1.4i)*y2))^2))-k2)-@at4
elseif @v2=="Pickover 5"
a2=cabs((sin((@p1b+1.8-0.05i)*y2)+@p2b*cos((@p1b+1.8-0.05i)*x2)+flip(sin((@p3b-2.1+0.75i)*x2)+(@p4b-0.3-0.7i)*cos((@p3b-2.1+0.75i)*y2)))-k2)-@at4
elseif @v2=="Pickover 6"
a2=cabs((x2-(@p1b-1.9+0.5i)*sin(y2+tan((@p2b-1+1i)*y2))+flip(y2-(@p1b-1.9+0.5i)*sin(x2+tan((@p2b-1+1i)*x2))))-k2)-@at4
elseif @v2=="Provenzale-Balmforth"
a2=cabs(((@p1b*y2+@p2b)*x2*(1-x2)+flip(4*y2*(1-y2)))-k2)-@at4
elseif @v2=="Quadruptwo"
a2=cabs((y2-(x2/cabs(x2))*sin(log(abs((@p2b-0.65-0.65i)*x2-@p3b)))*atan(sqr(log(abs(@p3b*x2-(@p2b-0.65-0.65i)))))+flip(@p1b-x2))-k2)-@at4
elseif @v2=="Rayleigh"
a2=cabs((y2+flip(-(x2+@p2b*y2^3-@p1b*y2)/@p3b))-k2)-@at4
elseif @v2=="Stommel Thermohaline 1"
a2=cabs((@p1b-x2-x2*(x2-y2)+flip(@p2b-(@p3b+1.3-0.55i)*y2-y2*(x2-y2)))-k2)-@at4
elseif @v2=="Stommel Thermohaline 2"
a2=cabs((@p1b*(1-x2)-(@p2b-1.25+0.25i)*x2*cabs(y2-@p3b*x2)+flip(1-y2-(@p2b-1.25+0.25i)*y2*cabs(y2-@p3b*x2)))-k2)-@at4
elseif @v2=="Strelkova-Anishchenko"
a2=cabs((1-(@p1b+0.5-0.65i)*x2^2+@p2b*(y2-x2)+flip(1-(@p1b+0.5-0.65i)*y2^2+@p2b*(x2-y2)))-k2)-@at4
elseif @v2=="Threeply"
a2=cabs((y2-(x2/cabs(x2))*(abs(sin(x2)*cos(@p2b)+(@p3b-1+0.1i)-x2*sin((@p1b-0.5-0.2i)+@p2b+(@p3b-1+0.1i))))+flip((@p1b-0.5-0.2i)-x2))-k2)-@at4
elseif @v2=="Tinkerbell"
a2=cabs((x2^2+-y2^2+@p1b*x2+@p2b*y2+flip(2*x2*y2+@p3b*x2+@p4b*y2))-k2)-@at4
elseif @v2=="Ushiki"
a2=cabs((((@p1b+0.25+0.55i)-x2-(@p2b+1.9-0.1i)*y2)*x2+flip(((@p3b-0.37+2.85i)-y2-@p4b*x2)*y2))-k2)-@at4
elseif @v2=="Van der Pol 1"
a2=cabs(((@p1b+0.85+0.55i)*(x2-x2^3/3-y2)+flip(x2/(@p1b+0.85+0.55i)))-k2)-@at4
elseif @v2=="Van der Pol 2"
a2=cabs((y2+flip((@p1b-1-0.67i)*(1-x2^2)*y2-x2))-k2)-@at4
elseif @v2=="Volterra-Lotka 1"
a2=cabs((@p1b*x2-@p2b*x2*y2+flip(-@p3b*y2+@p4b*x2*y2))-k2)-@at4
elseif @v2=="Volterra-Lotka 2"
a2=cabs((@p1b*x2*(1-x2-(@p2b-3.75-1.85i)-1.6*y2)+flip(@p3b*y2*(1-y2-@p4b*x2)))-k2)-@at4
endif
if a2<@at1
b2=f2*a2+d2*128
endif
d2=d2+1
if d2>@at2-0.5
d2=0
endif
endif
endfunc
float func ResultIndex(complex pz)
if @version==100
if @solid
if @invert
if c<@p7
index=c
else
m_Solid=true
endif
else
if c>@p7
index=c
else
m_Solid=true
endif
endif
else
index=c
endif
return index
else
index2=b2*@at2/128
return index2
endif
endfunc
private:
float b
float c
float d
float index
float a2
float f2
float b2
float d2
complex k2
float index2
default:
title="Attraktor Traps 2"
int param version
caption="Version"
default=101
visible=@version<101
endparam
param Va
caption="Variant"
enum="1""2""3""4""5"
default=1
visible=@version==100
endparam
param p6
caption="Variant Parameter"
default=1.0
visible=@version==100
endparam
heading
visible=@version==100
endheading
param V
caption="Trap"
enum="Brusselator""Oscillating Chemical Reaction"\
"Buckling Column Model""Rayleigh""Cathala""Sprott-Elhadj"\
"Modified Lozi""Multifold Henon""Mira""Garrote-Mira"\
"Hopalong""Martin""Popcorn""Popcorn 2""Ushiki"\
"Strelkova-Anishchenko""Cat""HCA""Coupled Logistic"\
"Sine""Henon""Burgers""Cao-Lai""Marotto-Lorenz""de Jong"\
"Clifford""Svensson""Chip""Chirikov Mod""Duffing"\
"Quadruptwo""Ikeda""Gumowski-Mira""Gumowski-Mira Mod"\
"Gumowski-Mira 2""Bogdanov""Mira 2""Mira 3""Gingerbread" \
"Hamilton""Kam Torus""Lozi""Threeply""Tinkerbell" \
"Van der Pol""Van der Pol 2"
default=0
visible=@version==100
endparam
param p1
caption="Trap Parameter 1"
default=(1,0)
visible=@V!=16 && @V!=38 && @version==100
endparam
param p2
caption="Trap Parameter 2"
default=(1,0)
visible=@V!=11 && @V!=16 && @V!=28 && @V!=38 \
 && @V!=40 && @V!=44 && @V!=45 && @version==100
endparam
param p3
caption="Trap Parameter 3"
default=(1,0)
visible=(@V==0 || @V==2 || @V==3 || @V==10 \
|| @V==14 || @V==24 || @V==25  || @V==26 \
|| @V==27 || @V==30 || @V==31 || @V==32 \
|| @V==34 || @V==35 || @V==37 || @V==42  \
|| @V==43) &&  @version==100
endparam
param p4
caption="Trap Parameter 4"
default=(1,0)
visible=(@V==2 || @V==14 || @V==24 \
|| @V==25  || @V==26  || @V==31 || @V==43) &&  @version==100
endparam
heading
visible=@version==100
endheading
param p5
caption="Parameter"
default=0.25
visible=@version==100
endparam
func fn1
caption="Function"
default=ident()
visible=@version==100
endfunc
heading
visible=@version==100
endheading
param @solid
caption="Solid Colour"
default=false
visible=@version==100
endparam
param p7
caption="Solid Colour Adjustment"
default=0.0225
visible=@solid==true &&  @version==100
endparam
param invert
caption="Invert Solid Colour"
default=false
visible=@solid==true &&  @version==100
endparam
param v2
caption="Attraktor"
enum="Bedhead""Bogdanov""Buckling Column Model""Business Cycle""Cathala""Chip""Chirikov Mod"\
"Coupled Logistic""de Jong""Duffing""Gumowski-Mira 1""Gumowski-Mira 2""Gumowski-Mira Mod""Hamilton""Henon""Henon-Heiles 1"\
"Henon-Heiles 2""Hopalong""Horsthemke-Lefever""Ikeda""Ilhem-Amel 1"\
"Ilhem-Amel 2""Kam Torus""Knot""Kolmogorov-Volterra""Limit Cycle""Lozi""Marotto-Lorenz"\
"Martin""Mira 1""Mira 2""Mira 3""Modified Lozi""Multifold Henon""Pharaoh""Pickover 1""Pickover 2""Pickover 3"\
"Pickover 4""Pickover 5""Pickover 6""Provenzale-Balmforth""Quadruptwo""Rayleigh""Stommel Thermohaline 1"\
"Stommel Thermohaline 2""Strelkova-Anishchenko""Threeply""Tinkerbell""Ushiki"\
"Van der Pol 1""Van der Pol 2""Volterra-Lotka 1""Volterra-Lotka 2"
default=5
visible=@version==101
endparam
param p1b
caption="Attraktor Parameter"
default=(1,0)
visible=@version==101 && @v2!="Knot"
endparam
param p2b
caption="Attraktor Parameter 2"
default=(1,0)
visible=@version==101 && @v2!="Chirikov Mod" && @v2!="Kam Torus"\
 && @v2!="Knot" && @v2!="Martin" && @v2!="Van der Pol 1" && @v2!="Van der Pol 2"
endparam
param p3b
caption="Attraktor Parameter 3"
default=(1,0)
visible=@version==101 && (@v2=="Bogdanov" || @v2=="Buckling Column Model" || @v2=="Chip"\
 || @v2=="de Jong" || @v2=="Gumowski-Mira 2" || @v2=="Henon-Heiles 1" || @v2=="Henon-Heiles 2"\
 || @v2=="Hopalong" || @v2=="Horsthemke-Lefever" || @v2=="Ikeda" || @v2=="Ilhem-Amel 1"\
 || @v2=="Ilhem-Amel 2" || @v2=="Kolmogorov-Volterra" || @v2=="Limit Cycle" || @v2=="Mira 1"\
 || @v2=="Mira 2" || @v2=="Pharaoh" || @v2=="Pickover 1" || @v2=="Pickover 3" || @v2=="Pickover 5"\
 || @v2=="Quadruptwo" || @v2=="Rayleigh" || @v2=="Stommel Thermohaline 1" || @v2=="Stommel Thermohaline 2"\
 || @v2=="Threeply" || @v2=="Tinkerbell" || @v2=="Ushiki" || @v2=="Volterra-Lotka 1" || @v2=="Volterra-Lotka 2")
endparam
param p4b
caption="Attraktor Parameter 4"
default=(1,0)
visible=@version==101 && (@v2=="Buckling Column Model" || @v2=="de Jong" || @v2=="Henon-Heiles 1" || @v2=="Horsthemke-Lefever"\
 || @v2=="Ikeda" || @v2=="Ilhem-Amel 2" || @v2=="Limit Cycle" || @v2=="Pharaoh" || @v2=="Pickover 1" || @v2=="Pickover 5"\
 || @v2=="Tinkerbell" || @v2=="Ushiki" || @v2=="Volterra-Lotka 1" || @v2=="Volterra-Lotka 2")
endparam
param p5b
caption="Attraktor Parameter 5"
default=(1,0)
visible=@version==101 && (@v2=="Henon-Heiles 1" || @v2=="Horsthemke-Lefever" || @v2=="Ilhem-Amel 2")
endparam
param p6b
caption="Attraktor Parameter 6"
default=(1,0)
visible=@version==101 && @v2=="Ilhem-Amel 2"
endparam
param @at1
caption="AT Parameter 1"
default=0.6722
visible=@version==101
endparam
param at2
caption="AT Parameter 2"
default=10.0
visible=@version==101
endparam
param at3
caption="AT Parameter 3"
default=(0.5,0.5)
visible=@version==101
endparam
param at4
caption="AT Parameter 4"
default=0.1
visible=@version==101
endparam
param zp1b
caption="Z Parameter 1"
default=(1,0)
visible=@version==101
endparam
param zp2b
caption="Z Parameter 2"
default=(0,0)
visible=@version==101
endparam
func zf2
caption="Z Function"
default=ident()
visible=@version==101
endfunc
}

class OM_SnumLocret(common.ulb:GradientColoring) {
public:
func Init(complex pz, complex ppixel)
GradientColoring.Init(pz, ppixel)
k1=@p5
if k1>=#maxiter
k1=#maxiter-1
endif
a=0.0
b=1e20
c=-1.0
d=0.0
f=0.0
k2=0
a2=0.0
f2=(@q2-1)/@q1
b2=0.0
d2=0.0
endfunc
func Iterate(complex pz)
GradientColoring.Iterate(pz)
if @version==100
pz=@p1*fn1(pz)+@p2
if k2<=k1
if @v=="1"
d=cabs(pz^2*fn3((flip(pz)-@p3)/(1-@p3*flip(pz)))+@p4)
elseif @v=="2"
d=cabs(pz^2*fn3((cabs(pz)-@p3)/(1-@p3*cabs(pz)))+@p4)
elseif @v=="3"
d=cabs(pz-fn3((sqr(pz)^(-2)-@p3/2)/(-2*flip(pz)^(-3)))+@p4)
elseif @v=="4"
d=cabs(pz^2*fn3((exp(pz)-@p3)/(1-@p3*exp(pz)))+@p4)
elseif @v=="5"
d=cabs(pz^2*fn3((sqr(pz)-@p3)/(1-@p3*sqr(pz)))+@p4)
elseif @v=="6"
d=cabs(pz-fn3((conj(pz)^2-@p3/2)/(2*pz))+@p4)
elseif @v=="7"
d=cabs(pz^2*fn3((cos(pz)-@p3)/(1-@p3*cos(pz)))+@p4)
elseif @v=="8"
d=cabs(pz-0.5*fn3((tanh(pz)^4-@p3/2)/(4*sqrt(pz)^3))+@p4)
elseif @v=="9"
d=cabs(pz+pz^2*fn3((flip(pz)-@p3)/(1-@p3*flip(pz)))+@p4)
elseif @v=="10"

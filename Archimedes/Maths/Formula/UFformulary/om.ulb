class OM_BivarParallelResistance(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
c=@pf(fpixel)
if @version==100
pz=@sp1
pk=@sp2
else
if @v==1
pz=@sp1+2.1
pk=@sp2
else
pz=@sp1
pk=@sp2
endif
endif
return pz
return pk
endfunc
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
pk=@kp1*pk+@kp2
if @version==100
pk=@bp1*@bf(pk/pz)+@bp2
if @v=="1"
a=recip(pz^2+pk^2+@pp1*c-(@p1+1))
b=recip(pz^2+pk^2+@pp2*c-@p2)
pz=recip(a+b)
else
a=recip(pz^2+pk^2+@pp1*c-@p1)
b=recip(pz^2+pk^2+@pp2*c-(@p2-8.5))
d=recip(pz^2+pk^2+@pp3*c-@p3)
pz=recip(a+b+d)
endif
else
if @v=="1"
q=pk
pk=@bp1*@bf(pk/pz)+@bp2
a=recip(pz^2+q^2+@pp1*c-(@p1+1))
b=recip(pz^2+q^2+@pp2*c-(@p2-2.25))
pz=recip(a+b)
elseif @v=="2"
q=pk
pk=@bp1*@bf(pk/pz)+@bp2
a=recip(pz^2+q^2+@pp1*c-@p1)
b=recip(pz^2+q^2+@pp2*c-(@p2-8.5))
d=recip(pz^2+q^2+@pp3*c-@p3)
pz=recip(a+b+d)
elseif @v=="3"
pk=@bp1*@bf(pk/pz)+@bp2
a=recip(pz^2+pk^2+@pp1*c-(@p1+1))
b=recip(pz^2+pk^2+@pp2*c-@p2)
pz=recip(a+b)
else
pk=@bp1*@bf(pk/pz)+@bp2
a=recip(pz^2+pk^2+@pp1*c-@p1)
b=recip(pz^2+pk^2+@pp2*c-(@p2-8.5))
d=recip(pz^2+pk^2+@pp3*c-@p3)
pz=recip(a+b+d)
endif
endif
return pz
return pk
endfunc
bool func IsBailedOut(complex pz)
bool bail=false
bail=(|(pz+pk)/2|>@p_bailout)
return bail
endfunc
private:
complex c
complex pk
default:
title="Bivar Parallel Resistance"
int param version
caption="Version"
default=101
visible=@version<101
endparam
param v
caption="Variant"
enum="1""2""3""4"
endparam
param sp1
caption="Start Parameter 1"
default=(0.25,0)
endparam
param sp2
caption="Start Parameter 2"
default=(-0.5,0)
endparam
param p1
caption="PR Parameter 1"
default=(1,0)
endparam
param p2
caption="PR Parameter 2"
default=(1,0)
endparam
param p3
caption="PR Parameter 3"
default=(1,0)
visible=@v=="2"
endparam
param pp1
caption="Pixel Parameter 1"
default=(1,0)
endparam
param pp2
caption="Pixel Parameter 2"
default=(1,0)
endparam
param pp3
caption="Pixel Parameter 3"
default=(1,0)
visible=@v=="2"
endparam
param bp1
caption="Bivar Parameter 1"
default=(1,0)
endparam
param bp2
caption="Bivar Parameter 2"
default=(0,0)
endparam
param zp1
caption="Z Parameter 1"
default=(1,0)
endparam
param zp2
caption="Z Parameter 2"
default=(0,0)
endparam
param kp1
caption="K Parameter 1"
default=(1,0)
endparam
param kp2
caption="K Parameter 2"
default=(0,0)
endparam
func bf
caption="Bivar Function"
default=ident()
endfunc
func pf
caption="Pixel Function"
default=ident()
endfunc
param p_power
visible=false
endparam
float param p_bailout
caption="Bailout"
default=100.0
exponential=true
endparam
}

class OM_BivarSpider(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fPixel=pz
if @sv=="1"
pz=@sp1
pk=@sp2
elseif @sv=="2"
pk=@pf(pz)
pz=@sp1
elseif @sv=="3"
pz=@pf(pz)
pk=@sp1
elseif @sv=="4"
pk=@pf(pz)
pz=@pf(pz)
endif
c=@pf(fpixel)
return pz
return pk

endfunc
private:
complex c
complex pk
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
pk=@kp1*pk+@kp2
a=pk
pk=@bp1*@bf(pk/pz)+@bp2
pz=pz^2++a^2+c
c=c*@spp+(pz+pk)/2
return pz
return pk
endfunc
bool func IsBailedOut(complex pz)
bool bail=false
bail=(|(pz+pk)/2|>@p_bailout)
return bail
endfunc
default:
title="Bivar Spider"
param version
caption="Version"
default=100
visible=@version<100
endparam
param sv
caption="Start Variant"
enum="1""2""3""4"
endparam
param sp1
caption="Start Parameter"
default=(0.5,0)
visible=@sv!=3
endparam
param sp2
caption="Start Parameter 2"
default=(0.1,0)
visible=@sv==0
endparam
param spp
caption="Spider Parameter"
default=(0.5,0)
endparam
param bp1
caption="Bivar Parameter 1"
default=(0.5,0)
endparam
param bp2
caption="Bivar Parameter 2"
default=(0,0)
endparam
func bf
caption="Bivar function"
default=ident()
endfunc
func pf
caption="Pixel Function"
default=ident()
endfunc
param zp1
caption="Z Parameter 1"
default=(1,0)
endparam
param zp2
caption="Z Parameter 2"
default=(0,0)
endparam
param kp1
caption="K Parameter 1"
default=(1,0)
endparam
param kp2
caption="K Parameter 2"
default=(0,0)
endparam
param p_power
visible=false
endparam
float param p_bailout
caption="Bailout"
default=4.0
exponential=true
endparam
}

class OM_AltBivarX1(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
if @mj=="M"
fPixel=pz
if @sv=="1"
pz=@sp1
pk=@sp2
elseif @sv=="2"
pk=@pf(pz)
pz=@sp1
elseif @sv=="3"
pz=@pf(pz)
pk=@sp1
elseif @sv=="4"
pk=@pf(pz)
pz=@pf(pz)
endif
c=@pf(fpixel)
else
if @svj=="1"
pk=@pf(pz)
pz=@pf(pz)
elseif @svj=="2"
pk=@pf(pz)
pz=@sp1
else
pz=@pf(pz)
pk=@sp1
endif
c=@js
endif
i=0
return pz
return pk
endfunc
private:
complex c
complex pk
int i
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
pk=@kp1*pk+@kp2
a=pk
pk=@bp1*@bf(pk/pz)+@bp2
if @v=="1"
if i==0
pz=pz^2+a^2+@p1*c
i=1
else
pz=pz^2+a^2+@p2*c/(pz+a)
i=0
endif
else
if i==0
pz=pz^2+a^2+@p2*c/(pz+a)
i=1
else
pz=pz^2+a^2+@p1*c
i=0
endif
endif
return pz
return pk
endfunc
bool func IsBailedOut(complex pz)
bool bail=false
bail=(|(pz+pk)/2|>@p_bailout)
return bail
endfunc
default:
title="Alt Bivar X 1"
param version
caption="Version"
default=100
visible=@version<100
endparam
param mj
caption="M/J"
enum="M""J"
endparam
param sv
caption="Start Variant"
enum="1""2""3""4"
visible=@mj==0
endparam
param svj
caption="Start Variant"
enum="1""2""3"
visible=@mj==1
endparam

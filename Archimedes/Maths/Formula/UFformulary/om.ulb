pz=@zp1*pz+@zp2
z2=@z2p1*z2+@z2p2
pz=pz+@ar/pz
z2=z2+@ar/z2
a=pz
b=z2
u=(1-@p1)*pz+@p1*(pz^@pow1+@pp1*c)
pz=(1-@p2)*(pz^@pow2+@pp2*c)+@p2*(u^@pow3+@pp3*c)

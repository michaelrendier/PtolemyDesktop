class OM_AleatorMunsterJ(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
i=0
seed=@seed
while i<100
seed=random(seed)
values[i]=seed/#randomrange
i=i+1
endwhile
pz=@sf(pz)
i2=0
return pz
endfunc
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
pz=pz+@arp/pz
pz=pz+@acp*(pz-1i)/(pz+1i)
if @v==0
pz=@mp2*pz^2*(pz+@ap*@af(values[i2])-@mp1)/(1-@mp1*pz)+@mp3
elseif @v==1
pz=@mp2*pz^2*(pz+@ap*@af(values[i2])-@mp1)/(1-@mp1*pz)+@mp3+@ap*@af(values[i2])
elseif @v==2
pz=@mp2*pz^2*(pz+@ap*@af(values[i2])-@mp1)/(1-@mp1*(pz+@ap*@af(values[i2])))+@mp3
else
pz=@mp2*(pz+(@ap-0.5)*@af(values[i2]))^2*(pz+(@ap-0.5)*@af(values[i2])-@mp1)/(1-@mp1*pz)+@mp3
endif
i2=i2+1
return pz
endfunc

pz=flip(pz)
endif
elseif @Va=="14"
pz=pz-0.4/sqr(pz)
elseif @Va=="15"
pz=pz+3.63214*pz*cotan(pz)
elseif @Va=="16"
pz=pz-0.648*sqr(pz)
elseif @Va=="17"

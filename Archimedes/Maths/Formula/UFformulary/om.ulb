class OM_AleatorNewton(common.ulb:ConvergentFormula) {
public:
complex func Init(complex pz)
ConvergentFormula.Init(pz)
fpixel=pz
i=0
seed=@seed
while i<100
seed=random(seed)
values[i]=seed/#randomrange
i=i+1
endwhile
pz=@sf(pz)
pz=pz+@sp*@sf2(pz)
i2=0
return pz
endfunc
complex func Iterate(complex pz)
ConvergentFormula.Iterate(pz)
;m_ZOld=pz
if @v==0
pz=@zp1*pz+@zp2+@ap*@af(values[i2])
pz=pz+@arp/pz
pz=pz+@asp*sqr(pz)
f=pz^3-1
f1=3*pz^2
pz=pz-@np1*f/f1+@np2-0.5
elseif @v==1
pz=@zp1*pz+@zp2
pz=pz+@arp/pz
pz=pz+@asp*sqr(pz)

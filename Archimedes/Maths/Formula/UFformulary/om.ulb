caption="Alt Variant"
enum="1""2"
endparam
param sp1
caption="Start Parameter"
default=(0.5,0)
visible=(@mj==0 && @sv!=3) || (@mj==1 && @svj!=0)
endparam
param sp2
caption="Start Parameter 2"
default=(0.1,0)
visible=@sv==0 && @mj==0
endparam
param js
caption="Julia Seed"
default=(-0.55,0)
visible=@mj==1
endparam

z2=@p1b*z2+@p2b*(sqr((z2^2+@mp2-1)/(2*z2+@mp2-2)))+@p3b*(sqr((u2^2+@mp1-1)/(2*u2+@mp1-2)))
else
u=@p1a*pz+@p2a*(sqr((pz^2+@mp1-1)/(2*pz+@mp1-2)))+@p3a*(sqr((pz^2+@mp2-1)/(2*pz+@mp2-2)))
pz=@p1b*pz+@p2b*(sqr((pz^2+@mp2-1)/(2*pz+@mp2-2)))+@p3b*(sqr((u^2+@mp1-1)/(2*u+@mp1-2)))
u2=@p1a*z2+@p2a*(sqr((z2^2+@mp1-1)/(2*z2+@mp1-2)))+@p3a*(sqr((z2^2+@mp2-1)/(2*z2+@mp2-2)))
z2=@p1b*z2+@p2b*(sqr((z2^2+@mp2-1)/(2*z2+@mp2-2)))+@p3b*(sqr((u2^2+@mp1-1)/(2*u2+@mp1-2)))
a=z2
z2=@bp1*@bf(z2/pz)+@bp2
pz=sqr((pz^2+@mp3-1)/(2*pz+@mp3-2))+@bp3*sqr((a^2+@mp3-1)/(2*a+@mp3-2))
endif
return pz
return z2
endfunc

caption="Munster Parameter 1a"
default=(1.5,0)
endparam
param mp1b
caption="Munster Parameter 1b"
default=(1,0)
endparam
param mp2a
caption="Munster Parameter 2a"
default=(0.5,0)
endparam
param mp2b
caption="Munster Parameter 2b"
default=(1,0)
endparam
param zp1
caption="Z Parameter 1"
default=(1,0)
endparam
param zp2
caption="Z Parameter 2"
default=(0,0)
endparam
func sf

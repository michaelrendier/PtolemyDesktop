class OM_AleatorDevaney(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
i=0
seed=@seed
while i<100
seed=random(seed)
values[i]=seed/#randomrange
i=i+1
endwhile
if @mj==0
pz=@sp
c=@pf(fpixel)
else
pz=@pf(pz)
c=@js
endif
i2=0
return pz
endfunc
complex func Iterate(complex pz)
if @av==0
pz=@zp1*pz+@zp2+(@ap-0.4)*@af(values[i2])
pz=pz^@pow1+c/(pz-@p1)^@pow2
elseif @av==1
pz=@zp1*pz+@zp2
pz=pz^@pow1+c/(pz-@p1)^@pow2+(@ap-0.4)*@af(values[i2])
elseif @av==2
pz=@zp1*pz+@zp2+(@ap-0.5)*@af(values[i2])
pz=pz^@pow1+c/(pz-@p1)^@pow2+(@ap-0.5)*@af(values[i2])
elseif @av==3
pz=@zp1*pz+@zp2
pz=(pz+(@ap-1.45)*@af(values[i2]))^@pow1+c/(pz-@p1)^@pow2
elseif @av==4
pz=@zp1*pz+@zp2
pz=pz^@pow1+c/(pz+@ap*@af(values[i2])-@p1)^@pow2
elseif @av==5
pz=@zp1*pz+@zp2+@ap*@af(values[i2])
pz=pz^@pow1+c/(pz+@ap*@af(values[i2])-@p1)^@pow2
elseif @av==6
pz=@zp1*pz+@zp2
pz=pz^@pow1+c/(pz+@ap*@af(values[i2])-@p1)^@pow2+@ap*@af(values[i2])
elseif @av==7
pz=@zp1*pz+@zp2
pz=(pz+(@ap-0.2)*@af(values[i2]))^@pow1+c/(pz+(@ap-0.2)*@af(values[i2])-@p1)^@pow2
elseif @av==8
pz=@zp1*pz+@zp2+(@ap-0.4)*@af(values[i2])
pz=(pz+(@ap-0.4)*@af(values[i2]))^@pow1+c/(pz-@p1)^@pow2
elseif @av==9
pz=@zp1*pz+@zp2
pz=(pz+(@ap-0.4)*@af(values[i2]))^@pow1+c/(pz-@p1)^@pow2+(@ap-0.4)*@af(values[i2])
elseif @av==10
pz=@zp1*pz+@zp2+(@ap-0.4)*@af(values[i2])
pz=(pz+(@ap-0.4)*@af(values[i2]))^@pow1+c/(pz-@p1)^@pow2+(@ap-0.4)*@af(values[i2])
elseif @av==11
pz=@zp1*pz+@zp2+(@ap-1.5)*@af(values[i2])
pz=(pz+(@ap-1.5)*@af(values[i2]))^@pow1+c/(pz+(@ap-1.5)*@af(values[i2])-@p1)^@pow2+(@ap-1.5)*@af(values[i2])
elseif @av==12
pz=@zp1*pz+@zp2+@ap*@af(values[i2])
pz=(pz-@ap*@af(values[i2]))^@pow1+c/(pz+@ap*@af(values[i2])-@p1)^@pow2-@ap*@af(values[i2])
elseif @av==13
pz=@zp1*pz+@zp2-@ap*@af(values[i2])
pz=(pz+@ap*@af(values[i2]))^@pow1+c/(pz-@ap*@af(values[i2])-@p1)^@pow2+@ap*@af(values[i2])
elseif @av==14
pz=@zp1*pz+@zp2+(@ap-1.3)*@af(values[i2])
pz=(pz+(@ap-1.3)*@af(values[i2]))^@pow1+c/(pz-(@ap-1.3)*@af(values[i2])-@p1)^@pow2-(@ap-1.3)*@af(values[i2])
elseif @av==15
pz=@zp1*pz+@zp2-@ap*@af(values[i2])
pz=(pz-@ap*@af(values[i2]))^@pow1+c/(pz+@ap*@af(values[i2])-@p1)^@pow2+@ap*@af(values[i2])
elseif @av==16
pz=@zp1*pz+@zp2+@ap*@af(values[i2])
pz=(pz-@ap*@af(values[i2]))^@pow1+c/(pz-@ap*@af(values[i2])-@p1)^@pow2+@ap*@af(values[i2])
elseif @av==17
pz=@zp1*pz+@zp2
pz=pz^@pow1+(c+@ap*@af(values[i2]))/(pz-@p1)^@pow2
elseif @av==18
pz=@zp1*pz+@zp2+(@ap-0.2)*@af(values[i2])
pz=pz^@pow1+(c+(@ap-0.2)*@af(values[i2]))/(pz-@p1)^@pow2+(@ap-0.2)*@af(values[i2])

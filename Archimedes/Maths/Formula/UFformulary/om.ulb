endif
elseif @V=="OM15"
if @version==100
b=log(cabs(x-y-cotanh(x)*(@p1*x^2+@p2*y^2)+flip(x+y-cotanh(y)*(@p3*x^2+@p4*y^2))))
else
b=log(cabs(x-y+x^4*(@p1*x^2+@p2*y^2)+flip(x+y-y^3*(@p3*x-@p4*y^2))))
endif
elseif @V=="OM16"
b=log(cabs(x-y-sin(x)*(@p1*x^2+@p2*y^2)+flip(x+y-flip(y)*(@p3*x^2+@p4*y^2))))
elseif @V=="OM17"
b=log(cabs(x-y-log(x)*(@p1*x^2+@p2*y^2)+flip(x+y-sqrt(y)*(@p3*x^2+@p4*y^2))))
elseif @V=="OM18"
if @version==100

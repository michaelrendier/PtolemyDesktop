class OM_FelixandtheSunGod(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
i3=0
a=@p2
b[i3]=4
c[i3]=4
d[i3]=4
f=@p3
g=0.61803398 ;
while i3<4
b[i3]=a
c[i3]=f
d[i3]=1+a*f
a=(a*@p1)
i3=i3+1
endwhile
ang=2*pi/3
c1=(1+@fp*1i)*@fn1(exp((0,0)*ang))
c2=(1+@fp*1i)*@fn1(exp((0,1)*ang))
c3=(1+@fp*1i)*@fn1(exp((0,2)*ang))
r=sqrt(3)/2
pz=@pf(pz)
i=0
return pz
endfunc
private:
complex c1
complex c2
complex c3
float r
int i
int i3
complex a
complex b[0]
complex c[0]
complex d[0]
complex f
float g
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if @av==0
if i==0
int i4=trunc(g*4)
pz=(pz+b[i4])/(c[i4]*pz+d[i4])
i=1
else
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
endif
i=0
endif
else
if i==0
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
endif
i=1
else
int i4=trunc(g*4)
pz=(pz+b[i4])/(c[i4]*pz+d[i4])
i=0
endif
endif
return pz
endfunc

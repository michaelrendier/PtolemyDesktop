class OM_KleinHypernova(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
ang=2*pi/3
c1=(1+@fp*1i)*@fn1(exp((0,0)*ang))
c2=(1+@fp*1i)*@fn1(exp((0,1)*ang))
c3=(1+@fp*1i)*@fn1(exp((0,2)*ang))
r=sqrt(3)/2
pz=@pf(pz)
i=0
return pz
endfunc
private:
complex c1
complex c2
complex c3
float r
int i
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if @av==0
if i==0
f=@mp1*pz^2*(pz-@mp2)/(1-@mp2*pz)
pz=1/(@mp3+1/(@mp4+f))
i=1
else
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
endif
if @khv==1
pz=flip(pz)
endif
i=0
endif
else
if i==0
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
endif
if @khv==1
pz=flip(pz)
endif
i=1
else
f=@mp1*pz^2*(pz-@mp2)/(1-@mp2*pz)
pz=1/(@mp3+1/(@mp4+f))
i=0
endif
endif
return pz
endfunc

c=(0,0)
if @mj==0
pk=@sp
pq=@sp
pz=@sp
pw=@sp
else
pz=@pf(pz)
pk=pz
pq=pz
pw=pz
endif
return pz
return pq
return pk
return pw
endfunc
private:
complex pk
complex pw
complex pq
complex a
complex b
complex c
complex fpixel
complex func Iterate(complex pz)
pw=@wp1*pw+@wp2
pk=@kp1*pk+@kp2
pz=@zp1*pz+@zp2
pq=@qp1*pq+@qp2
a=pw
b=pk
c=pz
if @mj==0
if @v==0
pw=pw^2*@p1*@pf(fpixel)*pk+pq^2*(pq-@p5)/(1-@p5*pq)
pk=pk^2+@p2*@pf(fpixel)+pz+a^2*(a-@p5)/(1-@p5*a)
pz=pz^2*@p3*@pf(fpixel)/pq+b^2*(b-@p5)/(1-@p5*b)
pq=pq^2+(@p4-1.5)*@pf(fpixel)-a+c^2*(c-@p5)/(1-@p5*c)
elseif @v==1
pw=pw^2*@p1*@pf(fpixel)*pz+pq^2*(pq-@p5)/(1-@p5*pq)
pk=pk^2+(@p2-0.35)*@pf(fpixel)+pq+a^2*(a-@p5)/(1-@p5*a)
pz=pz^2*(@p3+0.6)*@pf(fpixel)/a+b^2*(b-@p5)/(1-@p5*b)
pq=pq^2+(@p4-0.55)*@pf(fpixel)-b+c^2*(c-@p5)/(1-@p5*c)
elseif @v==2
pw=pw^2*@p1*@pf(fpixel)*pq+pq^2*(pq-@p5)/(1-@p5*pq)
pk=pk^2+@p2*@pf(fpixel)+a+a^2*(a-@p5)/(1-@p5*a)
pz=pz^2*(@p3-0.9)*@pf(fpixel)/b+b^2*(b-@p5)/(1-@p5*b)
pq=pq^2+(@p4-1.2)*@pf(fpixel)-c+c^2*(c-@p5)/(1-@p5*c)
else
pw=pw^2*(@p1-1.55)*@pf(fpixel)*pw+pq^2*(pq-@p5)/(1-@p5*pq)
pk=pk^2+@p2*@pf(fpixel)+pk+a^2*(a-@p5)/(1-@p5*a)
pz=pz^2*@p3*@pf(fpixel)/pz+b^2*(b-@p5)/(1-@p5*b)
pq=pq^2+(@p4-2.75)*@pf(fpixel)-pq+c^2*(c-@p5)/(1-@p5*c)
endif
else
if @v==0
pw=pw^2*@p1*pk+pq^2*(pq-@p5)/(1-@p5*pq)
pk=pk^2+(@p2-0.71)+pz+a^2*(a-@p5)/(1-@p5*a)
pz=pz^2*@p3/pq+b^2*(b-@p5)/(1-@p5*b)
pq=pq^2+@p4-a+c^2*(c-@p5)/(1-@p5*c)
elseif @v==1
pw=pw^2*@p1*pz+pq^2*(pq-@p5)/(1-@p5*pq)
pk=pk^2+(@p2-4.41)+pq+a^2*(a-@p5)/(1-@p5*a)
pz=pz^2*@p3/a+b^2*(b-@p5)/(1-@p5*b)
pq=pq^2+(@p4+0.85)-b+c^2*(c-@p5)/(1-@p5*c)
elseif @v==2
pw=pw^2*(@p1+0.95)*pq+pq^2*(pq-@p5)/(1-@p5*pq)
pk=pk^2+@p2+a+a^2*(a-@p5)/(1-@p5*a)
pz=pz^2*@p3/b+b^2*(b-@p5)/(1-@p5*b)
pq=pq^2+(@p4-1)-c+c^2*(c-@p5)/(1-@p5*c)
else
pw=pw^2*@p1*pw+pq^2*(pq-@p5)/(1-@p5*pq)
pk=pk^2+(@p2-1.06)+pk+a^2*(a-@p5)/(1-@p5*a)
pz=pz^2*@p3/pz+b^2*(b-@p5)/(1-@p5*b)
pq=pq^2+(@p4-2.6)-pq+c^2*(c-@p5)/(1-@p5*c)
endif
endif
return pz
return pw
return pk
return pq
endfunc

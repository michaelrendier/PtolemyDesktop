class OM_IsaacsBird2(common.ulb:ConvergentFormula) {
public:
complex func Init(complex pz)
ConvergentFormula.Init(pz)
fpixel=pz
if @jm==0
pz=@pf(pz)
c=@js
else
pz=@sp
c=@pf(fpixel)
endif
a=(0,0)
b=(0,0)
return pz
endfunc
complex func Iterate(complex pz)
ConvergentFormula.Iterate(pz)
;m_ZOld=pz
pz=@zp1*pz+@zp2
b=(pz-@xp2*(pz^@pow1-1)/(@pow1*pz^(@pow1-1)))^@pow3+c*(pz-@xp3*(pz^@pow2-1)/(@pow2*pz^(@pow2-1)))^@pow4+@xp1*a+c
a=pz
pz=b
return pz
endfunc

elseif @bv==5
pz=pz-@sp1*(pz^@pow1-@sp2)/(@pow1*pz^(@pow1-1))+a-@sp3*(a^@pow2-@sp4)/(@pow2*pk^(@pow2-1))
elseif @bv==6
pz=pz-@sp1*(pz^@pow1-@sp2)/(@pow1*pz^(@pow1-1))+a-@sp3*(pk^@pow2-@sp4)/(@pow2*a^(@pow2-1))
else

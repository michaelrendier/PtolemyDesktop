elseif @lv==3
pz=a^@pow-@p2*c*pz^(@pow-2)+a^@pow-@p2*c*pz^(@pow-2)+@p1
elseif @lv==4
pz=pz^@pow-@p2*c*pk^(@pow-2)+pz^@pow-@p2*c*pk^(@pow-2)+@p1
else
pz=pk^@pow-@p2*c*pz^(@pow-2)+pk^@pow-@p2*c*pz^(@pow-2)+@p1
endif
return pz
return pk
endfunc

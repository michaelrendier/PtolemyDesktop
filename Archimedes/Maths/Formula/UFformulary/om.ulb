class OM_SigillumMysterii(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
if @mj==0
if @v==1
pz=@sp+1
elseif @v==2
pz=@sp+1.25
elseif @v==4
pz=@sp-0.3
elseif @v==5
pz=@sp-0.5
else
pz=@sp
endif
c=@pf(fpixel)
else
pz=@pf(pz)
if @v==6
c=@js+1.375
else
c=@js
endif
endif
i=0
return pz
endfunc
complex func Iterate(complex pz)
if @v==2
pz=(@zp1-0.1)*pz+@zp2
elseif @v==4
pz=(@zp1+0.1)*pz+@zp2
else
pz=@zp1*pz+@zp2
endif
if @v==0
pz=pz^2+c*(c*pz-+@p1*c/pz-1/(c*pz-@p1*c/pz)^2)
elseif @v==1
pz=pz^2+c/pz+@p1*c*(c*pz-c/pz-1/(c*pz-c/pz)^2)
elseif @v==2
pz=pz^2+1/pz+c*(c*pz-c/pz-1/(c*pz-c/pz)^2)+(@p1-1)
elseif @v==3
if i==0
pz=pz^2+@p1*c*(c*pz-c/pz-1/(c*pz-c/pz)^2)
i=1
elseif i==1
pz=pz^2+c/pz

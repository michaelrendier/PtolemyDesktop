class OM_TetravarX13(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
a=(0,0)
b=(0,0)
c=(0,0)
if @mj==0
pk=@sp
pq=@sp
pz=@sp
pw=@sp
else
pz=@pf(pz)
pk=pz
pq=pz
pw=pz
endif
return pz
return pq
return pk
return pw
endfunc
private:
complex pk
complex pw
complex pq
complex a
complex b
complex c
complex fpixel
complex func Iterate(complex pz)
pw=@wp1*pw+@wp2
pk=@kp1*pk+@kp2
pz=@zp1*pz+@zp2
pq=@qp1*pq+@qp2
a=pw
b=pk
c=pz
if @mj==0
if @v==0
pw=pw^2*@p1*@pf(fpixel)+pk*pz/pq
pk=pk^2+@p2*@pf(fpixel)+pz*pq/a
pz=pz^2/@p3*@pf(fpixel)+pq*a/b
pq=pq^2+@p4*a/@pf(fpixel)+b*c
elseif @v==1
pw=pw^2*@p1*@pf(fpixel)-pk*pz/pq
pk=pk^2+@p2*@pf(fpixel)-pz*pq/a
pz=pz^2/@p3*@pf(fpixel)-pq*a/b
pq=pq^2+@p4*a/@pf(fpixel)-b*c
elseif @v==2
pw=pw^2*@p1*@pf(fpixel)+(pk/pz*pq)
pk=pk^2+@p2*@pf(fpixel)+(pz/pq*a)
pz=pz^2/@p3*@pf(fpixel)+(pq/a*b)
pq=pq^2+(@p4-4.25)*a/@pf(fpixel)+(b/c)
else
pw=pw^2*@p1*@pf(fpixel)-(pk/pz*pq)
pk=pk^2+@p2*@pf(fpixel)-(pz/pq*a)
pz=pz^2/@p3*@pf(fpixel)-(pq/a*b)
pq=pq^2+(@p4-4.25)*a/@pf(fpixel)-(b/c)
endif
else
if @v==0
pw=pw^2*@p1+pk*pz/pq
pk=pk^2+@p2+pz*pq/a
pz=pz^2/(@p3+1.85)+pq*a/b
pq=pq^2+@p4*a+b*c
elseif @v==1
pw=pw^2*@p1-pk*pz/pq
pk=pk^2+@p2-pz*pq/a
pz=pz^2/(@p3+1.85)-pq*a/b
pq=pq^2-(@p4+0.7)*a+b*c
elseif @v==2
pw=pw^2*@p1+(pk/pz*pq)
pk=pk^2+@p2+(pz/pq*a)
pz=pz^2/(@p3+1.85)+(pq/a*b)
pq=pq^2+@p4*a+(b/c)
else
pw=pw^2*@p1-(pk/pz*pq)
pk=pk^2+@p2-(pz/pq*a)
pz=pz^2/(@p3+1.85)-(pq/a*b)
pq=pq^2+@p4*a-(b/c)
endif
endif
pz=pz+pk+pw+pq
return pz
return pw
return pk
return pq
endfunc

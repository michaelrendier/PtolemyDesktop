class OM_ModifiedSchröder2(common.ulb:ConvergentFormula) {
;https://cyberleninka.org/article/n/898315/viewer
public:
complex func Init(complex pz)
ConvergentFormula.Init(pz)
return @sf(pz)
endfunc
complex func Iterate(complex pz)
ConvergentFormula.Iterate(pz)
pz=@zp1*pz+@zp2
if @v==0
f=pz^@pow-@c
f1=@pow*pz^(@pow-1)
f2=(@pow-1)*@pow*pz^(@pow-2)
elseif @v==1
f=pz^@pow-pz^(@pow-1)-pz^(@pow-2)-@c
f1=@pow*pz^(@pow-1)-(@pow-1)*pz^(@pow-2)-(@pow-2)*pz^(@pow-3)
f2=(@pow-1)*@pow*pz^(@pow-2)-(@pow-2)*(@pow-1)*pz^(@pow-3)-(@pow-3)*(@pow-2)*pz^(@pow-4)
else
f=pz^@pow+pz^(@pow-1)+pz^(@pow-2)-@c
f1=@pow*pz^(@pow-1)+(@pow-1)*pz^(@pow-2)+(@pow-2)*pz^(@pow-3)
f2=(@pow-1)*@pow*pz^(@pow-2)+(@pow-2)*(@pow-1)*pz^(@pow-3)+(@pow-3)*(@pow-2)*pz^(@pow-4)
endif
pz=pz-@ms2*f*(f1-@ms1*f)/(f^2-f*f2)
return pz
endfunc

float func ResultIndex(complex pz)
if |pz-zold|<@adj
if @solid
if @invert
if b<@p7
index=b
else
m_Solid=true
endif
else
if b>@p7
index=b
else
m_Solid=true
endif
endif
else
index=b
endif
else
if @solid
if @invert
if a<@p7
index=a
else
m_Solid=true
endif
else
if a>@p7
index=a
else
m_Solid=true
endif
endif
else
index=a
endif
endif
return index
endfunc

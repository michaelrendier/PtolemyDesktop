z1=z1+@p11*sqr(z1)
z2=z2+@p11*sqr(z2)
z3=z2+@p11*sqr(z3)
z1=z1+@p14/z1
z2=z2+@p14/z2
z3=z3+@p14/z3
a=z1
b=z2
if @v==0
z1=@p5*z1^2*(z2-@p1*c)/(1-@p1*c*z3)
z2=@p6*z2^2*(z1-@p2)/(1-@p2*z3)+@p3*c
z3=@p7*z3^2*(z1-@p4*c)/(1-@p4*c*z2)+@p4*c
elseif @v==1

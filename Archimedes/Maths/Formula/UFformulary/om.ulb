class OM_TetravarJ/M(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
a=(0,0)
b=(0,0)
d=(0,0)
if @jm==0
pz=@sf(pz)
pq=pz
pk=pz
pw=pz
else
pk=@sp
pq=@sp
pz=@sp
pw=@sp
endif
return pz
return pq
return pk
return pw
endfunc
private:
complex pk
complex pw
complex pq
complex a
complex b
complex d
complex fpixel
complex func Iterate(complex pz)
pw=@wp1*pw+@wp2
pk=@kp1*pk+@kp2
pz=@zp1*pz+@zp2
pq=@qp1*pq+@qp2
if @jm==0
if @v==0
pw=pw/pq
pk=pk^2*(pw-2)/(1-2*pz)
pz=pz^2+pw^2+pk^2+pq^2+@c
pq=pq^2+pw+pk+pz
else
a=pw
b=pk
d=pz
pw=pw/pq
pk=pk^2*(a-2)/(1-2*pz)
pz=pz^2+a^2+b^2+pq^2+@c
pq=pq^2+a+b+d
endif
else
if @v==0
pw=pw/pq
pk=pk^2*(pw-2)/(1-2*pz)
pz=pz^2+pw^2+pk^2+pq^2+@pf(fpixel)
pq=pq^2+pw+pk+pz
else
a=pw
b=pk
d=pz
pw=pw/pq
pk=pk^2*(a-2)/(1-2*pz)
pz=pz^2+a^2+b^2+pq^2+@pf(fpixel)
pq=pq^2+a+b+d
endif
endif
return pz
return pw
return pk
return pq
endfunc

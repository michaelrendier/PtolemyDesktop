m_ZOld=pz
if @jm==0
pz=(pz^2-@p2)^2/(@p1*pz*(pz-1)*(pz-@p2))+@c
elseif @jm==1
pz=(pz^2-@pf(fpixel))^2/(@p1*pz*(pz-1)*(pz-@pf(fpixel)))
else
pz=(pz^2-(@p2-0.5))^2/(@p1*pz*(pz-1)*(pz-(@p2-0.5)))+@pf(fpixel)
endif
return pz

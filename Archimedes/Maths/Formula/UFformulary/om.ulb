class OM_Mobbom(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fPixel=pz
i=0
return fn1(pz)
endfunc
complex func Iterate(complex pz)
while i<@iter
i=i+1
pz=(pz-@p7)/(1-@p7*pz)
pz=pz/(@p8*pz+1)
pz=pz+@p9*(2*pz+1i)/(pz+2i)/(pz+1)*(1i-pz)
pz=pz+@p10*(pz+1i)*(pz-1)/(pz-1i)
pz=pz+@p6*tan(pz)
pz=pz+@p11/cos(pz)
pz=abs(fn2(((1i+@p1)*pz+1i*@p1+1)/((-1i+@p1)*pz-1i*@p1+1)))^@pow*@p2+@p3+@p13*fn3(fpixel)
endwhile
return @p4*pz/100
endfunc

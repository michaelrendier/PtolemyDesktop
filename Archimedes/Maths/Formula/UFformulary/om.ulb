endfunc
float func ResultIndex(complex pz)
if @solid
if @invert
if k>=@sca*10
index=@p6*k/m_Iterations
else
m_Solid=true
endif
else
if k<@sca*10
index=@p6*k/m_Iterations
else
m_Solid=true
endif
endif
else
index=@p6*k/m_Iterations
endif
return index
endfunc

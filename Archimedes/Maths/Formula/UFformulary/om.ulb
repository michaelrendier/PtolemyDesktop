g[i]=(h[i]-h[i-1])
i=i+1
endwhile
i=0
c=@hp2/10
d=@hp3/10
f=0.0
while(i<2)
c=c*real(g[i])
d=d*imag(g[i])
f=f+|g[i]|
i=i+1
endwhile
b=(@hp1*c+(1-@hp1)*d)/f
if b>a
a=b
endif
i=2
while(i>0)
h[i]=h[i-1]
i=i-1
endwhile
h[0]=j
endfunc
float func ResultIndex(complex pz)
index=@p3*real(@tf(a))
return index
endfunc

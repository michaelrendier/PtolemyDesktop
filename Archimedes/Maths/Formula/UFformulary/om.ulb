complex c1
complex c2
complex c3
complex c4
complex c5
complex c6
complex a
int i
complex func Iterate(complex pz)
pz=@zp1*@zf(pz)+@zp2
if @av==0
if i==0
pz=(pz^2+@p1)/(pz^2-1)
i=1
else
if cabs(pz-c1)<1
pz=conj(1/(pz-c1))+c1
elseif cabs(pz-c2)<1
pz=conj(1/(pz-c2))+c2
elseif cabs(pz-c3)<1
pz=conj(1/(pz-c3))+c3
elseif cabs(pz-c4)<1
pz=conj(1/(pz-c4))+c4
elseif cabs(pz-c5)<1

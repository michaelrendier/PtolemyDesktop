class OM_RexinEtophorbalt(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
if @jm==0
pz=@pf(pz)
c=@js
else
pz=@sp
c=@pf(fpixel)
endif
d=@xp2
a=(0,0)
b=(0,0)
return pz
endfunc
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
b=pz^2+c*pz+@xp1*a
a=pz
pz=b
d=d-1
if d<=0
d=d+@xp2
c=1/c
endif
return pz
endfunc

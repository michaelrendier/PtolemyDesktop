pz=@zp1*@zf(pz)+@zp2
if @av==0
if i==0
pz=pz^@pow1+c/(pz-@p2)^@pow2
i=1
else
if |pz-c1|<r^2
pz=r*conj(r/(pz-c1))+c1
elseif |pz-c2|<r^2
pz=r*conj(r/(pz-c2))+c2
elseif |pz-c3|<r^2
pz=r*conj(r/(pz-c3))+c3
endif
i=0
endif
else
if i==0
if |pz-c1|<r^2

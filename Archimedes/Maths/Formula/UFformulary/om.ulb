elseif @M=="21"
pz=pz-2.525*(cosh(pz)^3-1)/(3*cosh(pz)^2)
elseif @M=="22"
pz=pz-sqr(pz)
elseif @M=="23"
pz=pz-2.44*(exp(pz)^3-1)/(3*exp(pz)^2)
elseif @M=="24"
pz=pz^2*(sqr(pz)-3.7)/(1-3.7*sqr(pz))
elseif @M=="25"

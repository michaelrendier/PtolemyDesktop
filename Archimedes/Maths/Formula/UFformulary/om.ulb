class OM_BivarMajurec(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fPixel=pz
a=(0,0)
if @sv==0
pz=@sp
pk=@sp
elseif @sv==1
pz=@sf(pz)
pk=@sp
else
if @version<101
pz=@sf(pz)
pk=@sf(pz)
else
pk=@sf(pz)
pz=@sf(pz)
endif
endif
return pz
return pk
endfunc
private:
complex fPixel
complex a
complex pk
complex func Iterate(complex pz)
pz=@zp1*@lf(pz)+@zp2
pk=@kp1*@lf(pk)+@kp2
a=pz
if @v==0
pz=pz^2-pz*(pz^2-pz*(pz^2-pz*(pz^2-pz)))+@p1
pz=pz^2-pz*(pz^2-pz*(pz^2-pz*(pz^2-pz)))+@pf(fpixel)+@bf(@bp1)*pk
pk=pk^2-pk*(pk^2-pk*(pk^2-pk*(pk^2-pk)))+@p1
pk=pk^2-pk*(pk^2-pk*(pk^2-pk*(pk^2-pk)))+@pf(fpixel)+@bf(@bp2)*a
elseif @v==1
pz=pz^2-pz*(pz^2-pz*(pz^2-pz*(pz^2-pz)))+@pf(fpixel)
pz=pz^2-pz*(pz^2-pz*(pz^2-pz*(pz^2-pz)))+@p1+@bf(@bp1)*pk
pk=pk^2-pk*(pk^2-pk*(pk^2-pk*(pk^2-pk)))+@pf(fpixel)
pk=pk^2-pk*(pk^2-pk*(pk^2-pk*(pk^2-pk)))+@p1+@bf(@bp2)*a
elseif @v==2
pz=pz^2-pz*(pz^2-pz*(pz^2-pz*(pz^2-pz)))+@pf(fpixel)
pz=pz^2-pz*(pz^2-pz*(pz^2-pz*(pz^2-pz)))+@p1
pz=pz^2-pz*(pz^2-pz*(pz^2-pz*(pz^2-pz)))+@pf(fpixel)+@bf(@bp1)*pk
pk=pk^2-pk*(pk^2-pk*(pk^2-pk*(pk^2-pk)))+@pf(fpixel)
pk=pk^2-pk*(pk^2-pk*(pk^2-pk*(pk^2-pk)))+@p1
pk=pk^2-pk*(pk^2-pk*(pk^2-pk*(pk^2-pk)))+@pf(fpixel)+@bf(@bp2)*a
else
pz=pz^2-pz*(pz^2-pz*(pz^2-pz*(pz^2-pz)))+@p1
pz=pz^2-pz*(pz^2-pz*(pz^2-pz*(pz^2-pz)))+@pf(fpixel)
pz=pz^2-pz*(pz^2-pz*(pz^2-pz*(pz^2-pz)))+@p1+@bf(@bp1)*pk
pk=pk^2-pk*(pk^2-pk*(pk^2-pk*(pk^2-pk)))+@p1
pk=pk^2-pk*(pk^2-pk*(pk^2-pk*(pk^2-pk)))+@pf(fpixel)
pk=pk^2-pk*(pk^2-pk*(pk^2-pk*(pk^2-pk)))+@p1+@bf(@bp2)*a
endif
return pz
return pk
endfunc

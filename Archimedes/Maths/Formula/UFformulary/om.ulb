class OM_X-PlogPhoenix(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
a=(0,0)
b=(0,0)
if @jm==0
pz=@pf(pz)
c=@js
else
pz=@sp
c=@pf(fpixel)
endif
return pz
endfunc
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
b=pz^@pow1+pz^@pow2*c+@pp*a
b=b^2+exp(log(b)^2+@xp1*log(b)+log(c))
a=pz
pz=b
return pz
endfunc

+flip(sin(@p3*x)+@p4*sin(@p3*y))
elseif @V=="19"
z=z+@p1*flip(@p2*z)/(@p3*z)+(@p4+0.15-1.25i)+sin((@p1-1+2i)*y)\
+sqr(sin((@p1-1+2i)*x))+flip(sin((@p2-2.25-1.25i)*x)+sqr(sin((@p2-2.25-1.25i)*y)))
elseif @V=="20"

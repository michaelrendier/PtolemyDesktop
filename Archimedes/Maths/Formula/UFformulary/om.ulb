class OM_IFB82(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
return fn1(pz)
endfunc
complex func Iterate(complex pz)
pz=@p1*pz+@p2
if @V=="1"
pz=pz
elseif @V=="2"
pz=pz+1/pz
elseif @V=="3"
pz=pz+1.267/sqrt(pz)
elseif @V=="4"
pz=pz+0.198/exp(pz)
elseif @V=="5"
pz=pz+0.504/log(pz)
elseif @V=="6"
pz=pz+1/sqr(pz)
elseif @V=="7"
pz=pz-1/sqr(pz)
elseif @V=="8"
pz=pz-0.174/cotanh(pz)
elseif @V=="9"
pz=pz+1/cosh(pz)
elseif @V=="10"
pz=pz+0.5/asinh(pz)
elseif @V=="11"
pz=pz+1/sin(pz)
elseif @V=="12"
pz=pz+6.08/exp(sqrt(pz))
elseif @V=="13"
pz=pz+9.377/exp(sqrt(pz))
elseif @V=="14"
pz=pz+0.153/exp(atan(pz))
elseif @V=="15"
pz=pz-0.916/exp(acosh(pz))
elseif @V=="16"
pz=pz+0.153/exp(asinh(pz))+0.312
elseif @V=="17"
pz=pz+1/log(log(pz))+1.47
elseif @V=="18"
pz=pz-0.782/sqr(sqr(pz))
elseif @V=="19"
pz=pz+1/atanh(sqrt(pz))+0.713
elseif @V=="20"
pz=pz+1/atanh(tanh(pz))
elseif @V=="21"
pz=pz+1/atanh(cos(pz))-0.022
endif
float a=real(pz)
if a<@p3
pz=(@p8-pz)*fn3(@p5)+@p6
endif
if @p4<=a
pz=(@p8+pz)*fn4(@p5)+@p7
endif
return pz
endfunc

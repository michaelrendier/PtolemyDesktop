class OM_BivarXPlog5(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fPixel=pz
if @mj==1
pk=@sf(pz)
pz=@sf(pz)
c1=@js1
c2=@js2
else
if @v==3 || @v==6 || @v==7 || @v==12 || @v==13 || @v==14 || @v==15 || @v==23
pk=-@sp1
pz=-@sp2
elseif @v==11
pk=@sp1-1.5
pz=-@sp2
elseif @v==20
pk=@sp1-0.5
pz=@sp2-1.5
elseif @v==21
pk=-@sp1
pz=@sp2
elseif @v==24 || @v==25
pk=@sp1
pz=@sp2-1.6
else
pk=@sp1
pz=@sp2
endif
c1=@sf(fpixel)
c2=@sf(fpixel)
endif
return pz
return pk
endfunc
private:
complex c1
complex c2
complex pk
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
pk=@kp1*pk+@kp2
a=pk
pk=@bp1*pk/pz+@bp2
if @mj==0
if @v==0
pz=pz^2+exp(log(pz)^2+log(exp(log(pz)^2+@xp1*log(pz)+log(c1))))+a^2+exp(log(a)^2+log(exp(log(a)^2+@xp1*log(a)+log(c2))))
elseif @v==1
pz=pz^2+exp(pz^2+log(exp(log(pz)^2+@xp1*log(pz)+log(c1))))+a^2+exp(a^2+log(exp(log(a)^2+@xp1*log(a)+log(c2))))
elseif @v==2
pz=(pz+c1)^2+exp(log(pz+c1)^2+@xp1*log(pz+c1)+log(c1))+(a+c2)^2+exp(log(a+c2)^2+@xp1*log(a+c2)+log(c2))
elseif @v==3
pz=(exp(log(pz)+log(c1)))^2+exp(log(exp(log(pz)+log(c1)))^2+@xp1*log(exp(log(pz)+log(c1)))+log(c1))\
+(exp(log(a)+log(c2)))^2+exp(log(exp(log(a)+log(c2)))^2+@xp1*log(exp(log(a)+log(c2)))+log(c2))
elseif @v==4
pz=pz^2+exp(log(pz)^2+@xp1*log(pz^2)+log(1/c1))+a^2+exp(log(a)^2+@xp1*log(a^2)+log(1/c2))
elseif @v==5
pz=pz^2+exp(log(pz)^2+@xp1*log(pz+1)+log(c1))+a^2+exp(log(a)^2+@xp1*log(a+1)+log(c2))

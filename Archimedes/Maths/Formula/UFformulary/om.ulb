class OM_MoukonyFazurut(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
if @mj==0
if @st==0
pz=@sf(pz)
c=@sf(fpixel)
else
pz=@sp
c=@cf(fpixel)
endif
else
pz=@sf(pz)
if @version<101
c=@c
else
c=@c1
endif
endif
return pz
endfunc
private:
complex c
complex func Iterate(complex pz)
pz=@zp1*@zf(pz)+@zp2
d=(pz^2-@mfp1)/(pz^2+@mfp1)
f=@mfp2+@mfp3*@mff(pz+c)
pz=d*f*pz
return pz
endfunc

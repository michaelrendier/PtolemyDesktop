visible=false
endparam
float param p_bailout
caption="Bailout"
default=0.00000001
exponential=true
endparam
}

class OM_Rootmod2(common.ulb:ConvergentFormula) {
public:
complex func Init(complex pz)
ConvergentFormula.Init(pz)
return @sf(pz)
endfunc
complex func Iterate(complex pz)
ConvergentFormula.Iterate(pz)
m_ZOld=pz
pz=@pzp1*pz+@pzp2
f=pz^2-@p1
f1=2*pz
a=fn2(f/f1)
return a-@p3*(a/f1)*((f+@p2*a)/(f+(@p2-2)*a))+@c
endfunc

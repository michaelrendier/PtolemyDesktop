param v
caption="Variant"
enum="1""2""3""4""5"
visible=@version==100
endparam
param v1
caption="Variant"
enum="z=exp(log(z)^2+log(c))""z=exp(log(z)^2+log(z)+log(c))"\
"z=exp(log(z)^2-log(z)+log(c))""z=exp(log(z)^2+log(z)-log(c))"\

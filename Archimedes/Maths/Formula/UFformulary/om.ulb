|| @Vb=="Magus 16" || @Vb=="Magus 17" || @Vb=="Magus 18" || @Vb=="Magus 19" || @Vb=="Magus 20" || @Vb=="Magus 21" \
|| @Vb=="Magus 22" || @Vb=="Magus 23" || @Vb=="Magus 24" || @Vb=="Magus 25" || @Vb=="Magus 26" || @Vb=="Magus 27" \
|| @Vb=="Magus 28" || @Vb=="Magus 29" || @Vb=="Marotto-Lorenz" || @Vb=="Mira" || @Vb=="Multifold Henon" \
|| @Vb=="Nowicki-Swirszcz" || @Vb=="Strelkova-Anishchenko" || @Vb=="Tinkerbell" \
|| @Vb=="Ushiki" || @Vb=="Volterra-Lotka" || @Vb=="Zaslavsky")

class OM_Log-XP(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fPixel=pz
if @jm==0
pz=@sf(pz)
if @v==0
c=@js+1.2
elseif @v==1
c=@js+1.85
else
c=@js
endif
else
pz=@sp
c=@sf(fpixel)
endif
return pz
endfunc
private:
complex c
complex func Iterate(complex pz)
if @v==0 && @jm==1
pz=(@zp1+0.05)*pz+@zp2
else
pz=@zp1*pz+@zp2
endif
if @v==0
pz=pz^2+@xp2*log(1/(exp(1/pz)^2+@xp1*exp(1/pz)+exp(1/c)))+c
elseif @v==1
pz=pz^2+(@xp2-1.5)*log(1/(exp(1/pz)^2+@xp1*exp(1/pz)+exp(1/c)))^2+c
elseif @v==2
pz=pz^2+@xp2*log(1/(exp(1/pz)^2+@xp1*exp(1/pz)+exp(1/c)))
elseif @v==3
pz=pz^2+(@xp2-1.75)*log(1/(exp(1/pz)^2+@xp1*exp(1/pz)+exp(1/c)))^2
elseif @v==4
pz=pz^2+@xp2*log(1/(exp(1/pz)^2+@xp1*exp(1/pz)))+c
else
pz=pz^2+(@xp2-0.5)*log(1/(exp(1/pz)^2+@xp1*exp(1/pz)))^2+c
endif
return pz
endfunc

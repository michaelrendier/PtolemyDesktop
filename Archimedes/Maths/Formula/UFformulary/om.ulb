complex c
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if @jm==0
pz=pz*(pz-@p1)/(1-@p1*pz)
pz=(1-pz)^2*(1-@p2*pz)/(1+@p2*pz)
elseif @jm==1 && @st==0
pz=pz*(pz-@p1)/(1-@p1*pz)
pz=(1-pz)^2*(1-@p2*c*pz)/(1+@p2*c*pz)
else
pz=pz*(pz-@p1)/(1-@p1*pz)
pz=(1-pz)^2*(1+c*pz/2)/(1-c*pz/2)
endif
return pz
endfunc

endif
endif
if @JM=="J"
pz=pz^(-2)+2*pz^(-1/2)+pz^(1/3)+2*pz^(11/6)+pz^(8/3)+2*pz^(25/6)+pz^5+2*pz^(12/2)+8*@p2
elseif @JM=="M1"

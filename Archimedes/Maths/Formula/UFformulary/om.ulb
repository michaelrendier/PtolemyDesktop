pz=pz-@np1*f/f1+@np2+@ap*@af(values[i2])
elseif @v==4
pz=@zp1*pz+@zp2+@ap*@af(values[i2])
pz=pz-0.1*sqr(pz)
f=pz^i2-1+@ap*@af(values[i2])
f1=3*pz^(i2-1)
pz=pz-@np1*f/f1+@np2
elseif @v==5
pz=@zp1*pz+@zp2
pz=pz-0.1*sqr(pz)
f=pz^i2-1+@ap*@af(values[i2])
f1=3*pz^(i2-1)+@ap*@af(values[i2])
pz=pz-@np1*f/f1+@np2-0.3
elseif @v==6
pz=@zp1*pz+@zp2
pz=pz-0.1*sqr(pz)

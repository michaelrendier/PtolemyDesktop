elseif @v==4
pz=pz^2+c*(pz^2+c*(pz^2-c*(pz^2+c)))+a^2+c*(a^2+c*(a^2-c*(a^2+c)))+@p1
elseif @v==5
pz=pz^2+c*(pz^2+c*(pz^2+c*(pz^2-c)))+a^2+c*(a^2+c*(a^2+c*(a^2-c)))+@p1
else
pz=pz^2+c*(pz^2+c*(pz^2-c*(pz^2-c)))+a^2+c*(a^2+c*(a^2-c*(a^2-c)))+@p1

-(1.45+0.125i)^2*cos(1.45+0.125i)*((x^2+y^2)^2*cos(1.45+0.125i)+flip(-\
2*x*y*((x^2+y^2+2*x*cos(@p1)-(@p1)^2)-(@p1)^2))\
+y^(2/3)+@p1^(2/3))
elseif @v=="34"

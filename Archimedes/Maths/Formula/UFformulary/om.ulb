param cp1
caption="Curve Parameter"
default=(1,0)
visible=(@v!="Lemniscatrix of Ökinghaus" && @v!="Logarithmic Sinusoid" && @v!="Maltese Cross" \
&& @v!="Sinus Chain" && @v!="Szego" && @v!="Gudermannian") && @version==100
endparam
param cp2
caption="Curve Parameter 2"
default=(1,0)
visible=(@v!="Astroid" && @v!="Besace" && @v!="Biaxial Eight Reverse" && @v!="Bicorn"  \
&& @v!="Bicuspid" && @v!="Blade's Cubic" && @v!="Bow" && @v!="Braked Parabola" && @v!="Cardioid" \

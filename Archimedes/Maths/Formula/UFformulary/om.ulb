complex func Iterate(complex pz)
m_ZOld=pz
pz=@pzp1*@pzf(pz)+@pzp2
if @v==0
a=pz-@p1*(pz^@pow-@p4)/(@pow*pz^(@pow-1))
pz=a-@p2*a*(a^@pow-@p4)/((pz^@pow-@p4)-@p3*(a^@pow-@p4))+@pf(fPixel)
elseif @v==1
a=pz-@p1*(pz^@pow-@p4)/(@pow*pz^(@pow-1))+@pf(fPixel)
pz=a-@p2*a*(a^@pow-@p4)/((pz^@pow-@p4)-@p3*(a^@pow-@p4))
elseif @v==2
a=pz-@p1*(pz^@pow-@p4)/(@pow*pz^(@pow-1))+@pf(fPixel)
pz=a-@p2*a*(a^@pow-@p4)/((pz^@pow-@p4)-@p3*(a^@pow-@p4))+@pf(fPixel)
elseif @v==3
a=pz-@p1*(pz^@pow-@pf(fPixel))/(@pow*pz^(@pow-1))
pz=a-@p2*a*(a^@pow-@p4)/((pz^@pow-@p4)-(@p3+2.425)*(a^@pow-@p4))
else
a=pz-@p1*(pz^@pow-@p4)/(@pow*pz^(@pow-1))
pz=a-@p2*a*(a^@pow-@pf(fPixel))/((pz^@pow-@pf(fPixel))-(@p3+2.425)*(a^@pow-@pf(fPixel)))
endif
return pz

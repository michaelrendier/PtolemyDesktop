caption="Valmyst Variant"
enum="1""2""3""4""5"
endparam
param p1
caption="Valmyst Parameter 1"
default=3
endparam
param p2
caption="Valmyst Parameter 2"
default=(1,0)
endparam
func fn1
caption="Valmyst Function"
default=ident()
endfunc
param p_power
visible=false
endparam
param p_upperbailout
caption="Divergent Bailout value"
default=100.0
exponential=true
endparam

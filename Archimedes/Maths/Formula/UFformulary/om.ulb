pz=@p6*@fn2(pz)+@p7
float a=real(@fn3(pz))
float b=imag(@fn3(pz))
if @v==0
if a*imag(@p1)+real(@p1)*b<@p4
pz=pz*sin(@p1)+@p2
endif
if @p5<=a*imag(@p1)+real(@p1)*b
pz=pz*sinh(@p1)+@p3
endif
if a*imag(@p1)+real(@p1)*b<@p8
pz=pz*asin(@p1)+@p9
endif
if @p10<=a*imag(@p1)+real(@p1)*b
pz=pz*asinh(@p1)+@p11
endif
elseif @v==1

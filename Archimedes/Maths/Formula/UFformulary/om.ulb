class OM_Devix2(common.ulb:DivergentFormula) {
public:
complex func Init(complex pz)
fpixel=pz
a=(0,0)
b=(0,0)
if @mj==1
pz=@pf(pz)
c=@js
else
pz=@sp
c=@pf(fpixel)
endif
return pz
endfunc
complex func Iterate(complex pz)
pz=@zp1*pz+@zp2
if @dv==0
b=a*pz^@pow1+c/(a*pz-(@dmp-0.75))^@pow2+(@php-1.3)*a
elseif @dv==1
b=pz^@pow1+c/(pz-a-@dmp)^@pow2+@php*a
elseif @dv==2
if @mj==0
b=pz^@pow1+c/(a*pz-@dmp)^@pow2+@php*a
else
b=pz^@pow1+c/(a*pz-@dmp)^@pow2-@php*a
endif
elseif @dv==3
if @mj==0
b=(pz+a)^@pow1+c/(pz-@dmp)^@pow2+@php*a
else
b=(pz+a)^@pow1+(c+0.1)/(pz-(@dmp-1.25))^@pow2+@php*a
endif
elseif @dv==4
b=pz^@pow1+(c+a)/(a*pz-(@dmp+0.2))^@pow2-@php*a
elseif @dv==5
b=pz^@pow1+(c+a)/(pz+a-@dmp)^@pow2-@php*a
elseif @dv==6
b=pz^@pow1+c/(pz*sqr(a)+@dmp)^@pow2+@php*a
elseif @dv==7
b=pz^@pow1+(c-a)/(pz+@dmp)^@pow2+@php*a
elseif @dv==8
if @mj==0
b=pz^@pow1+c/(a*pz-a+@dmp)^@pow2-@php*a
else
b=pz^@pow1+(c-0.2)/(a*pz-a+@dmp)^@pow2-@php*a
endif
elseif @dv==9
b=pz^@pow1+(c+a)/(a*pz-@dmp)^@pow2-@php*a
elseif @dv==10
b=pz^@pow1+(c+a^2)/(a*pz-@dmp)^@pow2+@php*a
elseif @dv==11
if @mj==0
b=pz^@pow1+c/(pz*a^3+@dmp)^@pow2+@php*a
else
b=pz^@pow1+(c-0.5)/(pz*a^3+@dmp)^@pow2+@php*a
endif
elseif @dv==12
b=pz^@pow1+(c+a^3)/(pz+a-@dmp)^@pow2-@php*a
elseif @dv==13
if @mj==0
b=pz^@pow1+(c-a^3)/(pz+@dmp)^@pow2+@php*a
else
b=pz^@pow1+((c+0.2)-a^3)/(pz+@dmp)^@pow2+@php*a
endif
endif
a=pz
pz=b
return pz
endfunc

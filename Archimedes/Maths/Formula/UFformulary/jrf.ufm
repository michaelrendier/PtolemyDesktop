      elseif @oper == 1
        z = z^@power + (a - b)
        elseif @oper == 2
          z = z^@power + (a * b)
          else
          z = z^@power + (a / b)
    endif
    a = @fna(a + (@seed + .01))
    b = @fnb(b - (@seed + .1))
  bailout:
    |z| <= 128.0
  default:
    title = "Halloween J"
    param power
      caption = "Power of z"
      default = 2.0
    endparam

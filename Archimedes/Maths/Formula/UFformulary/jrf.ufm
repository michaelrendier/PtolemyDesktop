031006 {
  init:
    float count = 0
    float c = 0
    a = @astart
    b = @fnb(a/#pixel)
    z = 0
  loop:
    c = count % @itter
    if c == 0
      z = (a/b)^z + #pixel
      else
      z = z^(b/a) - #pixel
    endif
    count = count + 1
  bailout:
    |z| <= 25
  default:
    title = "031006"
    param astart
      caption = "Starting point"
      default = (1, 0)
    endparam
    param itter
      caption = "Every?"
      default = 3
      min = 3
      max = 25
    endparam
    func fnb
      caption = "Function of b"
      default = sin()
    endfunc
  switch:
    type = "031006j"
    seed = #pixel
    count = count
    c = c
    a = a
    b = b
    astart = astart
    itter = itter
    fnb = fnb
       
}

031006j {
  init:
    float count = 0

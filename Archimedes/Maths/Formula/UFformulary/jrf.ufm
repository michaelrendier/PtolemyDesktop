KelleysEnglish {
init:
  z = 0
  c = 1.618033989
loop:
  z = (z + sin (#pixel)) - (#pixel - @funk (c))
  if @oper == 0
    c = c + @fung(z)
    elseif @oper == 1
      c = c - @fung(z)
      elseif @oper == 2
        c = c * @fung(z)
        else
        c = c / @fung(z)
  endif 
bailout:
  |z| <= 128.0
default:
  title = "Kelley's English"
  func funk
    caption = "Function of c"
    default = recip()
  endfunc
  func fung
    caption = "Function of z"
    default = sin()
  endfunc
  param oper
    caption = "To combine z and c"
    enum = "+" "-" "*" "/"
    default = 0
  endparam
switch:
  type = "KelleysEnglishj"
  seed = #pixel
  c = c
  oper = oper
  funk = funk
  fung = fung
  
}

KelleysEnglish][ {
init:
  z = 0
  c = 1.618033989
loop:
  z = (z + @funk (#pixel)) - (#pixel - cos (c))
  if @oper == 0
    c = c + @fung(z)
    elseif @oper == 1
      c = c - @fung(z)
      elseif @oper == 2
        c = c * @fung(z)
        else
        c = c / @fung(z)
  endif 
bailout:
  |z| <= 128.0
default:

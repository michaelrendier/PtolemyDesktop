    caption = "Function of b"
    default = cos()
  endfunc
   heading
      caption = "Bailout Options"
    endheading
    param test
     caption = "Bailout Test"
     default = 4
      enum = "mod" "real" "imag" "or" "and" "manh" "manr"
    endparam
    param bailout
      caption = "Bailout value"
      default = 128.0
      min = 1.0
    endparam
switch:

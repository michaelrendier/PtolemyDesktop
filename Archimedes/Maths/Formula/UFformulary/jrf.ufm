}

030913cj {
  init:
    a = (@startb/(@starta^#pixel))
    b = (@starta/(@startb^#pixel))
    z = @funcy(@seed/(a+b))
  loop:
    if |(a)|*|(b)| <= 0
      z = z^@power + @seed
    else
      z = @seed^@power + z
    endif
    a = @funca(@seed^2/z^@power)
    b = sin(z^@power/@seed^b)
  bailout:
    |z| <= 128.0

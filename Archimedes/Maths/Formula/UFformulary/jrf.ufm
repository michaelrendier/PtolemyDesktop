      (@test == 2 && sqr(imag(z)) <= @bailout) || \
      (@test == 3 && (sqr(real(z)) <= @bailout && \
      sqr(imag(z)) < @bailout)) ||   \
      (@test == 4 && (sqr(real(z)) <= @bailout || \
      sqr(imag(z)) < @bailout)) ||   \
      (@test == 5 && (sqr(abs(real(z)) + \
        abs(imag(z))) <= @bailout)) ||          \
      (@test == 6 && (sqr(real(z) + imag(z)) <= @bailout))
default:
  title = "Autrey C J"
  param power
    caption = "Power of z"
    default = 2.0
  endparam
  func fa
    caption = "Function of a"

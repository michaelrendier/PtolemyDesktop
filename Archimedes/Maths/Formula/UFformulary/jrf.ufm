FunkyJazz {
  init:
    a = @astart
    b = @bstart
    z = @fn1(a^b)/#pixel
  loop:
    a = a^@p1 + b
    b = (@fn2(sqrt(z + b)))^@p2
    z = z^(a/b) + #pixel
  bailout:
    |z+a+b| <= 1e15
  default:
    title = "Funky Jazz"
    method = multipass
    param astart
      caption = "A Start"
      default = (0, 0)
    endparam
    param bstart
      caption = "B Start"
      default = (0,0)
    endparam
    param p1
      caption = "Power of A"
      default = 2
    endparam
    param p2
      caption = "Power of B"
      default = 2
    endparam
    heading
      caption = "Functions"
    endheading
    func fn1
      caption = "Function of z"
      default = sqrt()
    endfunc
    func fn2
      caption = "Function of b"
      default = ident()
    endfunc
  
}

FunkyMusic {
  init:
    z = pixel/2
    a = @astart
    b = @bstart
  loop:
    a = a^@powera + b
    b = cos(sqrt(z + b))^@powerb
    z = z^(a/b) + #pixel
  bailout:
    |z+a+b| <= 1e15
  default:
    title = "Funky Music"
    method = multipass
    param astart
      caption = "A Start"
      default = (0, 0)
    endparam
    param bstart
      caption = "B Start"
      default = (0,0)

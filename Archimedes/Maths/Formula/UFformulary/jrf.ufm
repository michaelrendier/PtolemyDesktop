  init:
    x = (@fnz1(z)) / 2
    z = 0
  loop:
    z = z^@pow - z^(@fnz2((1/x) - x)) + #pixel
    x = @fnx(x^@pow2 + .25)
  bailout:
    |z| <= 128.0
  default:
    title = "Sylvan ]|["
    param pow
      caption = "Power of z"
      default = (2.0, 0.0)

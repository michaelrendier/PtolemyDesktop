Harley {
init:
  z = #pixel/3
  a = @apoint
  b = @bpoint
  aold = 0
loop:
  aold = a
  a = #pixel^b + z
  b = z^aold + #pixel
  z = (a/b)^2 + #pixel
bailout:
  |z-aold+a+b| <= 1e20
default:
  title = "Harley"
  angle = 90
  param apoint
    caption = "A start"
    default = (0,0)
  endparam
  param bpoint
    caption = "B start"
    default = (0,0)
  endparam
}

Kaspar {
init:
  z=pixel
  a=(-1.0,1.0)
  b=(0,0)
loop:
  a=b^2+#pixel
  b=#pixel^@power+(a-(1/pi))
  z=a^b+(#pixel^z)
bailout:
  |(b/a)-z|<=1e10
default:
  title="Kaspar"
  param power
    caption = "Power"
    default = (2,0)
  endparam
  method = multipass
}


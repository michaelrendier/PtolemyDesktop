   default = 0
  endparam
  param opMixRadius
   caption = "Final Mix Harlequin Radius"
   enum = "Normal Harlequin""Harlequin + Polar""Harlequin - Polar""Harlequin * Polar""Harlequin / Polar""Harlequin ^ Polar""Polar^Harlequin"
   default = 0
  endparam

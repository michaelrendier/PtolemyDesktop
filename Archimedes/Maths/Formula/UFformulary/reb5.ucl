           newmain[k] = main[i]
           dep[kk] = j
           kk = kk + 1
           k = k + 1
         endif
         i = i + 1
       endwhile
       int newmainl = k
     ; copy newmain to main
       ii = 0
       while ii < newmainl
         main[ii] = newmain[ii]
         ii = ii + 1
       endwhile
       mainl = newmainl
       newmainl = k
       j = j + 1
       k = 0
     endwhile
   elseif @rewrite == "serial"
     while j < @iter

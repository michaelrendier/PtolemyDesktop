      while ii < newmainl
        main[ii] = newmain[ii]
        ii = ii + 1
      endwhile
      mainl = newmainl
      newmainl = k

      i = 0
      k = 0
      while i < mainl
        if main[i] ==0
          newmain[k] = main[i]
          dep[kk] = j
          kk = kk + 1

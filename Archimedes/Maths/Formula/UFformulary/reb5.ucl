	      elseif @imagemode == "subtraction"
	        finalcolor = compose(finalcolor,blend(imcolorf,mergesubtraction(finalcolor,imcolorf),alpha(finalcolor)),@finalop)
	      elseif @imagemode == "hsl addition"
	        finalcolor = compose(finalcolor,blend(imcolorf,mergehsladdition(finalcolor,imcolorf),alpha(finalcolor)),@finalop)
	      elseif @imagemode == "red"

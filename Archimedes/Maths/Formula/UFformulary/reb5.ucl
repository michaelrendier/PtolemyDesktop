   if @rewrite == "Parallel"
     while j < @iter
       ;repro #1
       i = 0
       while i < mainl
         if main[i] ==0   && @rlen1 > 0
           ii = 0
           while ii < @rlen1
             newmain[k] = repro1[ii]
             dep[kk] = j
             ii = ii + 1
             k =k + 1
             kk = kk + 1
           endwhile
         elseif main[i] ==1   && @rlen2 > 0
           ii = 0
           while ii < @rlen2
             newmain[k] = repro2[ii]
             dep[kk] = j
             ii = ii + 1
             kk = kk + 1

    elseif @colorchoice == "Tan"
      colorMap  [0,1] = @colorMax125,  colorMap  [0,0] = @colorMin125
    elseif @colorchoice == "Teal"
      colorMap  [0,1] = @colorMax126,  colorMap  [0,0] = @colorMin126
    elseif @colorchoice == "Thistle"
      colorMap  [0,1] = @colorMax127,  colorMap  [0,0] = @colorMin127

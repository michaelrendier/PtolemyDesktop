    visible = @finalxf_enabled && @visible_xform == 20 && @finalxf_var_julian > 0.0
  endparam
  float param finalxf_var_juliaScope
    caption = "JuliaScope"
    default = 0.0
    visible = @finalxf_enabled && @visible_xform == 20
  endparam
  float param finalxf_par_juliaScope_power
    caption = "JuliaScope Power"
    default = 0.0
    visible = @finalxf_enabled && @visible_xform == 20 && @finalxf_var_juliaScope > 0.0
  endparam
  float param finalxf_par_juliaScope_dist
    caption = "JuliaScope Distance"
    default = 0.0
    visible = @finalxf_enabled && @visible_xform == 20 && @finalxf_var_juliaScope > 0.0
  endparam
  float param finalxf_var_blur
    caption = "Blur"
    default = 0.0
    visible = @finalxf_enabled && @visible_xform == 20
  endparam
  float param finalxf_var_gaussian_blur
    caption = "Gaussian Blur"
    default = 0.0
    visible = @visible_xform == 20
  endparam
  float param finalxf_var_radial_blur
    caption = "Radial Blur"
    default = 0.0
    visible = @visible_xform == 20
  endparam
  float param finalxf_par_radial_blur_angle
    caption = "Radial Blur Angle"
    default = 0.0
    visible = @finalxf_enabled && @visible_xform == 20 && @finalxf_var_radial_blur != 0
  endparam
}

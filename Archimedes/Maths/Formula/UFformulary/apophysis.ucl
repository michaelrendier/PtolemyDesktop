  xform_vars[11,21] = @xf11_var21
  xform_vars[11,22] = @xf11_var22

; generate the gaussian kernel for spatial filtration
  int filter_width = round(2*2.5*@oversample*@spat_filt_rad);

; maintain parity with oversample
  int chk = filter_width + @oversample
  if (chk % 2 == 1 && filter_width > 0)
    filter_width = filter_width + 1
  endif

; limit to gutter width
  if (filter_width-@oversample)>(2*gutter_width)
    filter_width = filter_width - 2
  endif
  print(filter_width)

; calculate gaussian
  float ii, float jj, float tot=0.0
  x=0
  while (x<filter_width)
    y=0
    while (y<filter_width)
      ii = ((2.0*x + 1) / filter_width - 1.0) * 2.5
      jj = ((2.0*y + 1) / filter_width - 1.0) * 2.5
      sf_gauss[x,y] = exp(-2.0*(ii*ii + jj*jj))
      tot = tot + sf_gauss[x,y]
      y = y + 1
    endwhile
    x = x + 1
  endwhile

; normalize the gaussian  
  x = 0
  while (x<filter_width)
    y = 0
    while (y<filter_width)
      sf_gauss[x,y] = sf_gauss[x,y] / tot
      print(sf_gauss[x,y])
      y = y + 1
    endwhile
    x = x + 1
  endwhile
  
; create a new colormap based on the current gradient, normalizing to (0-@white_level)
  int cmidx=0
  while (cmidx<=255)
    newcmap[cmidx] = gradient(cmidx/255)
    ; convert colors to 0-@white_level integer range
    ; use biggest number you can without overflowing for most accurate color
    scl_cmap[cmidx,0] = round(red(newcmap[cmidx])*@white_level)
    scl_cmap[cmidx,1] = round(green(newcmap[cmidx])*@white_level)
    scl_cmap[cmidx,2] = round(blue(newcmap[cmidx])*@white_level)
    scl_cmap[cmidx,3] = @white_level
;    scl_cmap[cmidx,3] = round(alpha(newcmap[cmidx])*@white_level)
    cmidx = cmidx + 1
  endwhile
  
; adjust scaling for aspect ratio  
  float scale
  if 3 * #width < 4 * #height     
    scale = (#width * #magn) / 4
   else
    scale = (#height * #magn) / 3
  endif

; calculate the image boundaries, not forgetting the gutter
; (the gutter is used to prevent problems with spatial filtering
; near the edge of the image)
  float bounds[4]
  float t0 = gutter_width / (@oversample*scale)
  bounds[0] = xc - #width/scale/2 - t0
  bounds[1] = yc - #height/scale/2 - t0
  bounds[2] = bounds[0] + #width/scale + 2*t0
  bounds[3] = bounds[1] + #height/scale + 2*t0
    
  int ht = @oversample * #height + 2*gutter_width
  int wd = @oversample * #width + 2*gutter_width
  
  float nuscale = wd / (bounds[2] - bounds[0])
  float wd2 = wd/2, float ht2 = ht/2
  
; initialize array
  x = 0, y = 0, z = 0
  while x < wd
    y = 0
    while y < ht
      z = 0
      while z < 4
        pix[x, y, z] = 0
        z = z + 1
      endwhile
      y = y + 1
    endwhile
    x = x + 1
  endwhile

; pre-calculate the cos and sin of #angle, so that
; it is removed from the iterative binning loop
; (probably already done by the compiler, but...)
  float cosan = cos(#angle)
  float sinan = sin(#angle)
      
; start the iteration process
; Draves code divides by the square of the oversample, but that seems too
; harsh of a divisor unless an agressive gaussian is used.
  int nsamples = round(#width*#height*@iter_density/(@oversample*@oversample))
  if (nsamples<0)
    nsamples=round(#randomrange-1)
  endif
  int fn
  float tx, float ty
  int it = -fuse, int clr_index

  float xp, float yp

  ; first, generate the starting point, (-1:1, -1:1, 0:1)
  seed = random(seed), iterbuf[0,0] = (seed/#randomrange)
  seed = random(seed), iterbuf[0,1] = (seed/#randomrange)
  seed = random(seed), iterbuf[0,2] = abs(seed/#randomrange)

; loop through our iterations

  while(it < nsamples)
  

    seed = random(seed), float rd = abs(seed / #randomrange)
    int j=0
    repeat 
      ; Pick xform to use based on probability
      rd = rd - xform_density[j]
      fn = j, j = j + 1
    until (rd < 0) || (j == num_xforms)
            
    ; compute color of next point
    float s = xform_symmetry[fn]
    iterbuf[0,2] = (iterbuf[0,2] + xform_color[fn]) * 0.5 * (1 - s) + s * iterbuf[0,2]

    ; affine transformation
    tx = xform_coefs[fn,0]*iterbuf[0,0] + xform_coefs[fn,1]*iterbuf[0,1] + xform_coefs[fn,4]
    ty = xform_coefs[fn,2]*iterbuf[0,0] + xform_coefs[fn,3]*iterbuf[0,1] + xform_coefs[fn,5]
    
    iterbuf[0,0] = 0.0, iterbuf[0,1] = 0.0
    float c1, float c2, float r2, float a, float nx, float ny
    float dx, float dy

    ; add proportional amounts of each variation
    if (xform_vars[fn,0]!=0.0); linear
      iterbuf[0,0] = iterbuf[0,0] + xform_vars[fn,0]*tx
      iterbuf[0,1] = iterbuf[0,1] + xform_vars[fn,0]*ty
    endif
        
    if (xform_vars[fn,1]!=0.0); sinusoidal
      iterbuf[0,0] = iterbuf[0,0] + xform_vars[fn,1]*sin(tx)
      iterbuf[0,1] = iterbuf[0,1] + xform_vars[fn,1]*sin(ty)
    endif

    if (xform_vars[fn,2]!=0.0); complex
      r2 = tx*tx + ty*ty + .000001
      iterbuf[0,0] = iterbuf[0,0] + xform_vars[fn,2]*tx/r2
      iterbuf[0,1] = iterbuf[0,1] + xform_vars[fn,2]*ty/r2
    endif
      
    if (xform_vars[fn,3]!=0.0); swirl
      r2 = tx*tx + ty*ty
      c1 = sin(r2), c2 = cos(r2)  
      iterbuf[0,0] = iterbuf[0,0] + xform_vars[fn,3]*(c1*tx - c2*ty)
      iterbuf[0,1] = iterbuf[0,1] + xform_vars[fn,3]*(c2*tx + c1*ty)
    endif
      
    if (xform_vars[fn,4]!=0.0); horseshoe
      a=0.0
      if ( (tx < -EPS) || (tx > EPS) || (ty < -EPS) || (ty > EPS) )
        a = atan2(ty + flip(tx))
      endif    
      c1 = sin(a), c2 = cos(a)  
      iterbuf[0,0] = iterbuf[0,0] + xform_vars[fn,4]*(c1*tx - c2*ty)
      iterbuf[0,1] = iterbuf[0,1] + xform_vars[fn,4]*(c2*tx + c1*ty)
    endif
      
    if (xform_vars[fn,5]!=0.0); polar
      a=0.0
      if ( (tx < -EPS) || (tx > EPS) || (ty < -EPS) || (ty > EPS) )
        a = atan2(ty + flip(tx)) / #pi
      endif
      iterbuf[0,0] = iterbuf[0,0] + xform_vars[fn,5] * a
      iterbuf[0,1] = iterbuf[0,1] + xform_vars[fn,5] * (sqrt(tx * tx + ty * ty)-1.0)
    endif

    if (xform_vars[fn,6]!=0.0); folded handkerchief 
      a = 0.0
      if ( (tx < -EPS) || (tx > EPS) || (ty < -EPS) || (ty > EPS) )
        a = atan2(ty + flip(tx))
      endif
      r2 = sqrt(tx*tx + ty*ty);
      iterbuf[0,0] = iterbuf[0,0] + xform_vars[fn,6] * sin(a + r2) * r2
      iterbuf[0,1] = iterbuf[0,1] + xform_vars[fn,6] * cos(a - r2) * r2
    endif
      
    if (xform_vars[fn,7]!=0.0) ; heart
      a=0.0
      if ( (tx < -EPS) || (tx > EPS) || (ty < -EPS) || (ty > EPS) )
        a = atan2(ty + flip(tx))
      endif
      r2 = sqrt(tx * tx + ty * ty);
      a = a * r2
      iterbuf[0,0] = iterbuf[0,0] + xform_vars[fn,7] * sin(a) * r2
      iterbuf[0,1] = iterbuf[0,1] - xform_vars[fn,7] * cos(a) * r2
    endif

    if (xform_vars[fn,8]!=0.0) ; disk
      a=0.0
      float nx = tx * #pi
      float ny = ty * #pi
      if ( (tx < -EPS) || (tx > EPS) || (ty < -EPS) || (ty > EPS) )
        a = atan2(ty + flip(tx))
      endif
      r2 = sqrt(nx*nx + ny*ny);
      iterbuf[0,0] = iterbuf[0,0] + xform_vars[fn,8] * sin(r2) * a / PI
      iterbuf[0,1] = iterbuf[0,1] + xform_vars[fn,8] * cos(r2) * a / PI
    endif

    if (xform_vars[fn,9]!=0.0); spiral
      a=0.0
      if ( (tx < -EPS) || (tx > EPS) || (ty < -EPS) || (ty > EPS) )
        a = atan2(ty + flip(tx))
      endif
      r2 = sqrt(tx*tx + ty*ty) + 1E-6;
      iterbuf[0,0] = iterbuf[0,0] + xform_vars[fn,9]*(cos(a) + sin(r2))/r2
      iterbuf[0,1] = iterbuf[0,1] + xform_vars[fn,9]*(sin(a) - cos(r2))/r2
    endif

    if (xform_vars[fn,10]!=0.0) ; hyperbolic
      a=0.0
      if ( (tx < -EPS) || (tx > EPS) || (ty < -EPS) || (ty > EPS) )
        a = atan2(ty + flip(tx))
      endif
      r2 = sqrt(tx*tx + ty*ty) + 1E-6;
      iterbuf[0,0] = iterbuf[0,0] + xform_vars[fn,10]*sin(a)/r2
      iterbuf[0,1] = iterbuf[0,1] + xform_vars[fn,10]*cos(a)*r2
    endif

    if (xform_vars[fn,11]!=0.0)     ; Diamond aka square
      a=0.0
      if ( (tx < -EPS) || (tx > EPS) || (ty < -EPS) || (ty > EPS) )
        a = atan2(ty + flip(tx))
      endif
      r2 = sqrt(tx*tx + ty*ty);
      iterbuf[0,0] = iterbuf[0,0] + xform_vars[fn,11]*sin(a) * cos(r2);
      iterbuf[0,1] = iterbuf[0,1] + xform_vars[fn,11]*cos(a) * sin(r2)
    endif

    if (xform_vars[fn,12]!=0.0) ; Ex
      a=0.0
      if ( (tx < -EPS) || (tx > EPS) || (ty < -EPS) || (ty > EPS) )
        a = atan2(ty + flip(tx))
      endif
      r2 = sqrt(tx*tx + ty*ty);
      float n0 = sin(a+r2)
      float n1 = cos(a-r2)
      float m0 = n0^3 * r2
      float m1 = n1^3 * r2
      iterbuf[0,0] = iterbuf[0,0] + xform_vars[fn,12] * (m0+m1)
      iterbuf[0,1] = iterbuf[0,1] + xform_vars[fn,12] * (m0-m1)
    endif
  
    if (xform_vars[fn,13]!=0.0) ; julia
      a=0.0
      if ( (tx < -EPS) || (tx > EPS) || (ty < -EPS) || (ty > EPS) )
        a = atan2(ty + flip(tx)) / 2;
      endif
      seed = random(seed)
      ; seed seems to retain the same parity!...but jumps
      ; between positive and negative randomly
      if seed > 0 
        a = a + #pi
      endif
      r2 = (tx*tx + ty*ty)^0.25;
      nx = r2 * cos(a)
      ny = r2 * sin(a)
      iterbuf[0,0] = iterbuf[0,0] + xform_vars[fn,13] * nx
      iterbuf[0,1] = iterbuf[0,1] + xform_vars[fn,13] * ny
    endif
    
    if (xform_vars[fn,14]!=0.0); bent
      c1 = tx
      c2 = ty
      if (c1 < 0.0)
        c1 = 2*c1
      endif  
      if (c2 < 0.0)
        c2 = c2 / 2.0
      endif  
      iterbuf[0,0] = iterbuf[0,0] + xform_vars[fn,14] * c1
      iterbuf[0,1] = iterbuf[0,1] + xform_vars[fn,14] * c2
    endif

    if (xform_vars[fn,15]!=0.0) ; Waves
      dx = xform_coefs[fn,4]
      dy = xform_coefs[fn,5]
      nx = tx + xform_coefs[fn,1] * sin(ty / ((dx*dx) + EPS))
      ny = ty + xform_coefs[fn,3] * sin(tx / ((dy*dy) + EPS))
      iterbuf[0,0] = iterbuf[0,0] + xform_vars[fn,15] * nx
      iterbuf[0,1] = iterbuf[0,1] + xform_vars[fn,15] * ny
    endif

    if (xform_vars[fn,16]!=0.0) ; Fisheye
      r2 = sqrt(tx*tx + ty*ty)
      a = atan2(ty + flip(tx))
      r2 = 2.0 * r2 / ( r2 + 1.0 )
      nx = r2 * cos(a)
      ny = r2 * sin(a)
      iterbuf[0,0] = iterbuf[0,0] + xform_vars[fn,16] * nx
      iterbuf[0,1] = iterbuf[0,1] + xform_vars[fn,16] * ny
    endif

    if (xform_vars[fn,17]!=0.0) ; Popcorn
       dx = tan(3.0 * ty)
       dy = tan(3.0 * tx)
       nx = tx + xform_coefs[fn,4] * sin(dx)
       ny = ty + xform_coefs[fn,5] * sin(dy)
       iterbuf[0,0] = iterbuf[0,0] + xform_vars[fn,17] * nx
       iterbuf[0,1] = iterbuf[0,1] + xform_vars[fn,17] * ny
    endif
     
    if (xform_vars[fn,18]!=0.0) ; Exponential
       dx = exp(tx) / 2.718281828459045
       dy = #PI * ty
       nx = cos(dy) * dx
       ny = sin(dy) * dx
       iterbuf[0,0] = iterbuf[0,0] + xform_vars[fn,18] * nx
       iterbuf[0,1] = iterbuf[0,1] + xform_vars[fn,18] * ny
    endif

    if (xform_vars[fn,19]!=0.0) ; Power
       r2 = sqrt(tx * tx + ty * ty)
       a = atan2(ty + flip(tx))
       float sa = sin(a)
       r2 = r2^sa
       nx = r2 * cos(a)
       ny = r2 * sa
       iterbuf[0,0] = iterbuf[0,0] + xform_vars[fn,19] * nx
       iterbuf[0,1] = iterbuf[0,1] + xform_vars[fn,19] * ny
    endif
    
    if (xform_vars[fn,20]!=0.0) ; Cosine
       nx = cos(tx * #PI) * cosh(ty)
       ny = -sin(tx * #PI) * sinh(ty)
       iterbuf[0,0] = iterbuf[0,0] + xform_vars[fn,20] * nx
       iterbuf[0,1] = iterbuf[0,1] + xform_vars[fn,20] * ny
    endif
     
    if (xform_vars[fn,21]!=0.0) ; Rings
      dx = xform_coefs[fn,4]
      dx = dx * dx + EPS
    r2 = sqrt(tx * tx + ty * ty)
      r2 = ((r2 + dx) % (2 * dx)) - dx + r2 * (1 - dx)
      a = atan2(ty + flip(tx))
      nx = cos(a) * r2
      ny = sin(a) * r2
      iterbuf[0,0] = iterbuf[0,0] + xform_vars[fn,21] * nx
      iterbuf[0,1] = iterbuf[0,1] + xform_vars[fn,21] * ny
    endif

    if (xform_vars[fn,22]!=0.0) ; Fan
      dx = xform_coefs[fn,4]
      dy = xform_coefs[fn,5]
      dx = #PI * (dx * dx + EPS)
      float dx2 = dx / 2
      r2 = sqrt(tx * tx + ty * ty)
      a = atan2(ty + flip(tx))
      if ((a + dy) % dx) > dx2
        a = a + -dx2
      else
        a = a + dx2
      endif
      nx = cos(a) * r2
      ny = sin(a) * r2
      iterbuf[0,0] = iterbuf[0,0] + xform_vars[fn,22] * nx
      iterbuf[0,1] = iterbuf[0,1] + xform_vars[fn,22] * ny
     endif


    ; Bin the point if it's inside the image limits and past the fuse
    if (it>=0)
      ; generate the x and y location in the image      
      xp = (iterbuf[0,0]-xc)
      yp = (iterbuf[0,1]-yc)
      
      x = round((xp * cosan - yp * sinan) * nuscale + wd2)
      y = round((xp * sinan + yp * cosan) * nuscale + ht2)
                  
      ; is this in our image?
      if (x>=0 && x<wd && y>=0 && y<ht)
        clr_index = round(iterbuf[0,2] * 256.0)
        if (clr_index<0)
          clr_index = 0
        elseif (clr_index>255)
          clr_index = 255
        endif
        
        ; add the *color* to the accumulator
        ; check for overflow later
        pix[x,y,0] = pix[x,y,0] + scl_cmap[clr_index,0]
        pix[x,y,1] = pix[x,y,1] + scl_cmap[clr_index,1]
        pix[x,y,2] = pix[x,y,2] + scl_cmap[clr_index,2]
        pix[x,y,3] = pix[x,y,3] + scl_cmap[clr_index,3]
        
      endif
      
    endif
      
    ; iterate some more
    it = it + 1
  endwhile
  ; Now we do some log magic - calculate the 
  ; "where did these come from" k1 and k2 values
  float k1 = @contrast * @brightness * prefilter_white * 268.0 / 256.0
  float area = #height * #width / (scale * scale * @oversample * @oversample)
  float k2 = @oversample*@oversample / (@contrast * area * @white_level * @iter_density)
  
  ; loop through each pixel and perform log calculation
  x = 0
  float ls = 0, float lc[4]
  while (x < wd)
    y = 0
    while (y < ht)
      if (pix[x,y,3]>0)
        ; we can break up this calculation as follows:
        ; normalize each pixel's color by the number of iterations in the bucket * white_level
        ; this puts each component (R,G,B,Accum) in the range (0-1),
        ; and the last term is ALWAYS 1.0.
        ; Now, for each pixel, we have (R,G,B,1.0), and we want to scale the 'Y'
        ; component of this color by the log of the number of iterations.
        ; 
        ; contr*bright* prefilter_white * 268                    iters
        ; ----------------------------------- * log (1.0 + ----------------)
        ;                256                               contrast * nsamp
        ;
        ; the log term will be bounded by (0-.6931) for contrast values >= 1.0.
        ; standard values for the first terms lead to
        ;
        ; 4288*(0-.6931) or 0-2972 values.  The range doesn't really matter, since
        ; we re-normalize by prefilter white to give (0-2.902) range, then
        
        
        ; brightness is a multiplier for the color.
        
        ; scale by the log of the number of occurrences
        ls = k1 * log(1.0 + pix[x,y,3]*k2) / pix[x,y,3]
        lc[0] = pix[x,y,0] * ls
        lc[1] = pix[x,y,1] * ls
        lc[2] = pix[x,y,2] * ls
        lc[3] = pix[x,y,3] * ls

        pix[x,y,0] = round(lc[0] + 0.5)
        pix[x,y,1] = round(lc[1] + 0.5)
        pix[x,y,2] = round(lc[2] + 0.5)
        pix[x,y,3] = round(lc[3] + 0.5)
      endif
      y = y + 1
    endwhile
    x = x + 1
  endwhile
  
  ; precalculate a gamma term
  float g = 1/@gamma
  
final:
  
  float fr, float fg, float fb, float fo
  float t[4], float lgs
  int xid, int yid
  
  t[0] = 0, t[1] = 0, t[2] = 0, t[3] = 0
; apply the spatial filter, if necessary
  int xadj, int yadj
  int sfadj = gutter_width - floor((filter_width-1)/2)
  int xcrd = #x*@oversample
  int ycrd = #y*@oversample
  if (filter_width>0)
    xid = 0 
    while (xid<filter_width)
      xadj = xid + sfadj
      yid = 0
      while (yid<filter_width)
        yadj = yid + sfadj
        t[0] = t[0] + sf_gauss[xid,yid] * pix[xcrd+xadj,ycrd+yadj,0]
        t[1] = t[1] + sf_gauss[xid,yid] * pix[xcrd+xadj,ycrd+yadj,1]
        t[2] = t[2] + sf_gauss[xid,yid] * pix[xcrd+xadj,ycrd+yadj,2]
        t[3] = t[3] + sf_gauss[xid,yid] * pix[xcrd+xadj,ycrd+yadj,3]
        yid = yid + 1
      endwhile
      xid = xid + 1
    endwhile
  else
    ; average values from each of the @oversample^2 points.
    xid = 0
    int ov2 = round(@oversample*@oversample)
    int myadj = gutter_width - round(@oversample/2)
    while (xid<@oversample)
      xadj = xid + myadj
      yid = 0
      while (yid<@oversample)
        yadj = yid + myadj
        t[0] = t[0] + pix[xcrd+xadj,ycrd+yadj,0]/ov2
        t[1] = t[1] + pix[xcrd+xadj,ycrd+yadj,1]/ov2
        t[2] = t[2] + pix[xcrd+xadj,ycrd+yadj,2]/ov2
        t[3] = t[3] + pix[xcrd+xadj,ycrd+yadj,3]/ov2
        yid = yid + 1
      endwhile
      xid = xid + 1
    endwhile
  endif
  
  float alpha = t[3]
  if (alpha > 0.0)
    lgs = ((alpha/prefilter_white)^(g-1))/prefilter_white
    alpha = (alpha/prefilter_white)^g
    if alpha<0.0
      alpha = 0.0
    elseif alpha>1.0
      alpha = 1.0
    endif
  else
    lgs = 0.0
  endif
  float invalp = 1.0-alpha

  ; perhaps we should spatial filter / anti-alias here, in color space,
  ; instead of doing it in arbitrary space.

  fr = lgs * t[0]
  fg = lgs * t[1]
  fb = lgs * t[2]
  fo = lgs * t[3]

  #color = rgba(fr,fg,fb,fo) + @bk_color*invalp
  
default:
  
  title = "Flame Fractals (Apophysis 2.0)"
  
  render = false

  helpfile = "flame.chm"
  
  heading
    caption = "Render Settings"
  endheading

  int param iter_density
    caption = "Sample Density"
    default = 35
    min = 1
    hint = "By default, the number of iterations run by the program \
            is this value times the total number of pixels in the image. \
            If the image appears spotty, increase this value."
  endparam
  
  float param spat_filt_rad
    caption = "Filter Radius"
    default = 0.7
    min = 0.0
    hint = "This radius controls the amount of 'smearing' applied to the \
            image.  It specifically controls the size of the gaussian \
            kernel that is convolved with the image. Setting to 0.0 \
            turns the filter off.  Try values around 0.3, with the \
            spatial oversample set to 2 or 3 for nice results. "
  endparam
  
  int param oversample
    caption = "Oversample"
    default = 3
    min = 1
    hint = "Increasing this parameter increases the number of iterations \
            as well as the number of histogram bins, effectively allowing \
            anti-aliasing to be performed.  A value of 2 increases the \
            number of bins by 4x, 3 by 9x, etc."
  endparam
   
  heading
    caption = "Color Settings"
  endheading  
   
  color param bk_color
    caption = "Background Color"
    default = rgba(0,0,0,1.0)
  endparam
  
  float param contrast
    caption = "Contrast"
    default = 1.0
    min = 1.0
   endparam
   
  float param brightness
    caption = "Brightness"
    default = 4.0

   endparam
   
  float param gamma
    caption = "Gamma"
    default = 2.0
    min = 1.0
  endparam
   
  int param white_level
    caption = "White Level"
    default = 200
    min = 0
    max = 255
  endparam
  
  heading
    caption = ""
  endheading

  int param xforms
    caption = "No. of Transforms"
    default = 2
    max = 12
    min = 2
  endparam
  
  param visible_xform
    caption = "Visible Parameters"
    enum = "Transform 1" "Transform 2" "Transform 3" "Transform 4" "Transform 5" \
    "Transform 6" "Transform 7" "Transform 8" "Transform 9" "Transform 10" \
    "Transform 11" "Transform 12" 
    default = 0
  endparam
    
  heading
    caption = "Transform 1"
    visible = @visible_xform == 0
  endheading

  float param xf0_p
    caption = "Probability"
    default = 1.0
    max = 1.0
    min = 0.0
    hint = "Use this parameter to control the probability of \
            this transform's coefficients being used in the \
            iterative loop."
    visible = @visible_xform == 0
  endparam

  float param xf0_c
    caption = "Color"
    default = 1.0
    max = 1.0

  xform_vars[0,COSINE]       = @xf0_var_cosine
  xform_vars[0,RINGS]        = @xf0_var_rings
  xform_vars[0,FAN]          = @xf0_var_fan
  xform_vars[0,BLOB]         = @xf0_var_blob
  xform_pars[0,BLOB_WAVES]   = @xf0_par_blob_waves
  xform_pars[0,BLOB_LOW]     = @xf0_par_blob_low
  xform_pars[0,BLOB_HIGH]    = @xf0_par_blob_high
  xform_vars[0,PDJ]          = @xf0_var_pdj
  xform_pars[0,PDJ_A]        = @xf0_par_pdj_a
  xform_pars[0,PDJ_B]        = @xf0_par_pdj_b
  xform_pars[0,PDJ_C]        = @xf0_par_pdj_c
  xform_pars[0,PDJ_D]        = @xf0_par_pdj_d
  xform_vars[0,FAN2]         = @xf0_var_fan2

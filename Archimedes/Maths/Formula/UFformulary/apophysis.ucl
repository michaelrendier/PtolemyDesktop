  xform_vars[9,GAUSSIAN_BLUR]= @xf9_var_gaussian_blur
  xform_vars[9,RADIAL_BLUR]  = @xf9_var_radial_blur
  xform_pars[9,RADIAL_BLUR_ANGLE]  = @xf9_par_radial_blur_angle
  xform_vars[10,GAUSSIAN_BLUR]= @xf10_var_gaussian_blur
  xform_vars[10,RADIAL_BLUR]  = @xf10_var_radial_blur
  xform_pars[10,RADIAL_BLUR_ANGLE]  = @xf10_par_radial_blur_angle
  xform_vars[11,GAUSSIAN_BLUR]= @xf11_var_gaussian_blur
  xform_vars[11,RADIAL_BLUR]  = @xf11_var_radial_blur
  xform_pars[11,RADIAL_BLUR_ANGLE]  = @xf11_par_radial_blur_angle
  xform_vars[12,GAUSSIAN_BLUR]= @xf12_var_gaussian_blur
  xform_vars[12,RADIAL_BLUR]  = @xf12_var_radial_blur
  xform_pars[12,RADIAL_BLUR_ANGLE]  = @xf12_par_radial_blur_angle
  xform_vars[13,GAUSSIAN_BLUR]= @xf13_var_gaussian_blur
  xform_vars[13,RADIAL_BLUR]  = @xf13_var_radial_blur
  xform_pars[13,RADIAL_BLUR_ANGLE]  = @xf13_par_radial_blur_angle
  xform_vars[14,GAUSSIAN_BLUR]= @xf14_var_gaussian_blur
  xform_vars[14,RADIAL_BLUR]  = @xf14_var_radial_blur
  xform_pars[14,RADIAL_BLUR_ANGLE]  = @xf14_par_radial_blur_angle
  xform_vars[15,GAUSSIAN_BLUR]= @xf15_var_gaussian_blur
  xform_vars[15,RADIAL_BLUR]  = @xf15_var_radial_blur
  xform_pars[15,RADIAL_BLUR_ANGLE]  = @xf15_par_radial_blur_angle
  xform_vars[16,GAUSSIAN_BLUR]= @xf16_var_gaussian_blur
  xform_vars[16,RADIAL_BLUR]  = @xf16_var_radial_blur
  xform_pars[16,RADIAL_BLUR_ANGLE]  = @xf16_par_radial_blur_angle
  xform_vars[17,GAUSSIAN_BLUR]= @xf17_var_gaussian_blur
  xform_vars[17,RADIAL_BLUR]  = @xf17_var_radial_blur
  xform_pars[17,RADIAL_BLUR_ANGLE]  = @xf17_par_radial_blur_angle
  xform_vars[18,GAUSSIAN_BLUR]= @xf18_var_gaussian_blur
  xform_vars[18,RADIAL_BLUR]  = @xf18_var_radial_blur
  xform_pars[18,RADIAL_BLUR_ANGLE]  = @xf18_par_radial_blur_angle
  xform_vars[19,GAUSSIAN_BLUR]= @xf19_var_gaussian_blur
  xform_vars[19,RADIAL_BLUR]  = @xf19_var_radial_blur
  xform_pars[19,RADIAL_BLUR_ANGLE]  = @xf19_par_radial_blur_angle
  xform_vars[FINALXF,GAUSSIAN_BLUR]= @finalxf_var_gaussian_blur
  xform_vars[FINALXF,RADIAL_BLUR]  = @finalxf_var_radial_blur
  xform_pars[FINALXF,RADIAL_BLUR_ANGLE]  = @finalxf_par_radial_blur_angle


;
;
;bookmark1
;
;
; generate the gaussian kernel for spatial filtration
  int filter_width = round(2*2.5*@oversample*@spat_filt_rad);

; maintain parity with oversample
  int chk = filter_width + @oversample
  if (chk % 2 == 1 && filter_width > 0)
    filter_width = filter_width + 1
  endif

; limit to gutter width
  if (filter_width-@oversample)>(2*gutter_width)
    filter_width = filter_width - 2
  endif
  ; print(filter_width)

; calculate gaussian
  float ii, float jj, float tot=0.0
  x=0
  while (x<filter_width)
    y=0
    while (y<filter_width)
      ii = ((2.0*x + 1) / filter_width - 1.0) * 2.5
      jj = ((2.0*y + 1) / filter_width - 1.0) * 2.5
      sf_gauss[x,y] = exp(-2.0*(ii*ii + jj*jj))
      tot = tot + sf_gauss[x,y]
      y = y + 1
    endwhile
    x = x + 1
  endwhile

; normalize the gaussian
  x = 0
  while (x<filter_width)
    y = 0
    while (y<filter_width)
      sf_gauss[x,y] = sf_gauss[x,y] / tot
      ; print(sf_gauss[x,y])
      y = y + 1
    endwhile
    x = x + 1
  endwhile

; create a new colormap based on the current gradient, normalizing to (0-@white_level)
  int cmidx=0
  while (cmidx<=255)
    newcmap[cmidx] = gradient(cmidx/255)
    ; convert colors to 0-@white_level integer range
    ; use biggest number you can without overflowing for most accurate color
    scl_cmap[cmidx,0] = round(red(newcmap[cmidx])*@white_level)
    scl_cmap[cmidx,1] = round(green(newcmap[cmidx])*@white_level)
    scl_cmap[cmidx,2] = round(blue(newcmap[cmidx])*@white_level)
    scl_cmap[cmidx,3] = @white_level
;    scl_cmap[cmidx,3] = round(alpha(newcmap[cmidx])*@white_level)
    cmidx = cmidx + 1
  endwhile

; adjust scaling for aspect ratio
  float scale
  if 3 * #width < 4 * #height
    scale = (#width * #magn) / 4
   else
    scale = (#height * #magn) / 3
  endif

; calculate the image boundaries, not forgetting the gutter
; (the gutter is used to prevent problems with spatial filtering
; near the edge of the image)
  float bounds[4]
  float t0 = gutter_width / (@oversample*scale)
  bounds[0] = xc - #width/scale/2 - t0
  bounds[1] = yc - #height/scale/2 - t0
  bounds[2] = bounds[0] + #width/scale + 2*t0
  bounds[3] = bounds[1] + #height/scale + 2*t0

  int ht = @oversample * #height + 2*gutter_width
  int wd = @oversample * #width + 2*gutter_width

  float transx = pwid * 0.5
  float transy = phgt * 0.5

  float nuscale = wd / (bounds[2] - bounds[0])

  ht = @oversample * phgt + 2*gutter_width
  wd = @oversample * pwid + 2*gutter_width

  float wd2 = wd/2, float ht2 = ht/2

; initialize array
  x = 0, y = 0, z = 0
  while x < wd
    y = 0
    while y < ht
      z = 0
      while z < 4
        pix[x, y, z] = 0
        z = z + 1
      endwhile
      y = y + 1
    endwhile
    x = x + 1
  endwhile

; pre-calculate the cos and sin of #angle, so that
; it is removed from the iterative binning loop
; (probably already done by the compiler, but...)
  float cosan = cos(#angle)
  float sinan = sin(#angle)

; precalulate params for radial blur
  int j = 0
  while j < @xforms
     if xform_vars[j,RADIAL_BLUR] != 0
       spinvar[j] = sin(xform_pars[j,RADIAL_BLUR_ANGLE] * PI / 2);
       zoomvar[j] = cos(xform_pars[j,RADIAL_BLUR_ANGLE]* PI / 2);
     endif
     j = j + 1
  endwhile
  if @finalxf_enabled && @finalxf_var_radial_blur != 0
       spinvar[FINALXF] = sin(xform_pars[FINALXF,RADIAL_BLUR_ANGLE] * PI / 2);
       zoomvar[FINALXF] = cos(xform_pars[FINALXF,RADIAL_BLUR_ANGLE]* PI / 2);
  endif

; start the iteration process
; Draves code divides by the square of the oversample, but that seems too
; harsh of a divisor unless an agressive gaussian is used.
  int nsamples = round(#width*#height*@iter_density/(@oversample*@oversample))
  if (nsamples<0)
    nsamples=round(#randomrange-1)
  endif
  int fn
  float tx, float ty
  int it = -fuse, int clr_index

  float weight
  float xp, float yp

  ;print("normweights ", @normweights)
  if (@normweights)
     int j=0
     float total = 0.0;
     while (j < @xforms)
        ;print (j, " prob ", xform_probability[j])
        total = total + xform_probability[j]
        j = j + 1
     endwhile
     j = 0
     float factor = 1.0/total
     ;print("total ", total, "   factor ", factor)
     while (j < @xforms)
        ;print (j, " prob ", xform_probability[j])
        xform_probability[j] = xform_probability[j]*factor
        ;print (j, " norm prob ", xform_probability[j])
        j = j + 1
     endwhile
  endif

  ; first, generate the starting point, (-1:1, -1:1, 0:1)
  seed = random(seed), iterbuf[0,0] = (seed/#randomrange)
  seed = random(seed), iterbuf[0,1] = (seed/#randomrange)
  seed = random(seed), iterbuf[0,2] = abs(seed/#randomrange)

  int fin = 0
  int fincount = 0
  if @finalxf_enabled
     fin = 1
 endif

; loop through our iterations  --  bookmark2

  while(it < nsamples)

    seed = random(seed), float rd = abs(seed / #randomrange)

    int j=0
    repeat
      ; Pick xform to use based on probability
      rd = rd - xform_probability[j]
      fn = j, j = j + 1
    until (rd < 0) || (j == @xforms)

    fincount = 0
    repeat  ; twice if final transform enabled, second time with final tranform
        ; compute color of next point
        float s = xform_symmetry[fn]
        iterbuf[0,2] = (iterbuf[0,2] + xform_color[fn]) * 0.5 * (1 - s) + s * iterbuf[0,2]

        ; affine transformation
        tx = xform_coefs[fn,0]*iterbuf[0,0] + xform_coefs[fn,1]*iterbuf[0,1] + xform_coefs[fn,4]
        ty = xform_coefs[fn,2]*iterbuf[0,0] + xform_coefs[fn,3]*iterbuf[0,1] + xform_coefs[fn,5]

        ; pre calculate some things
        float r2 = tx*tx + ty*ty    ; radius squared
        float r = sqrt(r2)          ; radius
        float a = 0.0               ; angle to point
        float theta = 0.0
        if ( (tx < -EPS) || (tx > EPS) || (ty < -EPS) || (ty > EPS) )
          a = atan2(ty + flip(tx))
          theta = atan2(tx + flip(ty))
        endif
        float cosa = tx/r
        float sina = ty/r
        float cost = sina
        float sint = cosa
        float angle = a

        ;working variables
        float c1, float c2, float nx, float ny
        float dx, float dy, float rv, float rr

        ;collector
        iterbuf[0,0] = 0.0, iterbuf[0,1] = 0.0

        ; add proportional amounts of each variation
        weight = xform_vars[fn,BENT]        ; avoid excess indexing into arrays
        if (weight !=0.0); bent
          c1 = tx
          c2 = ty
          if (c1 < 0.0)
            c1 = 2*c1
          endif
          if (c2 < 0.0)
            c2 = c2 / 2.0
          endif
          iterbuf[0,0] = iterbuf[0,0] + weight*c1
          iterbuf[0,1] = iterbuf[0,1] + weight*c2
        endif

        weight = xform_vars[fn,BLOB]
        if (weight!=0.0) ; blob
          float p_waves = xform_pars[fn,BLOB_WAVES]
          float p_low   = xform_pars[fn,BLOB_LOW]
          float p_high  = xform_pars[fn,BLOB_HIGH]
          float height = weight * (p_high - p_low)*0.5
          float low   = weight * p_low + height
          float rr = low + height * sin(p_waves*angle)
          iterbuf[0,0] = iterbuf[0,0] + rr*tx
          iterbuf[0,1] = iterbuf[0,1] + rr*ty
        endif

        weight = xform_vars[fn,BLUR]
        if (weight!=0.0) ; blur
          seed = random(seed), rv = abs(seed/#randomrange) ; 0<rv<1
          float tmpr = rv * 2.0 * #PI
          seed = random(seed), rv = abs(seed/#randomrange) ; 0<rv<1
          float rr = weight * rv
          iterbuf[0,0] = iterbuf[0,0] + rr * cos(tmpr)
          iterbuf[0,1] = iterbuf[0,1] + rr * sin(tmpr)
        endif

        weight = xform_vars[fn,GAUSSIAN_BLUR]
        if (weight!=0.0) ; Gaussian blur
          seed = random(seed), rv = abs(seed/#randomrange) ; 0<rv<1
          float ang = rv * 2.0 * #PI
          seed = random(seed), rv = abs(seed/#randomrange) ; 0<rv<1
          seed = random(seed), float rv1 = abs(seed/#randomrange) ; 0<rv<1
          seed = random(seed), float rv2 = abs(seed/#randomrange) ; 0<rv<1
          seed = random(seed), float rv3 = abs(seed/#randomrange) ; 0<rv<1
          float rr = weight * (rv + rv1 + rv2 + rv3 - 2.0)
          iterbuf[0,0] = iterbuf[0,0] + rr * cos(ang)
          iterbuf[0,1] = iterbuf[0,1] + rr * sin(ang)
        endif


;rndG = W * (random + random + random + random - 2.0);
;rA = sqrt(X^2 + Y^2);
;tmpa = arctan2(Y, X) + spinvar*rndG;
;sa = sin(tmpa);
;ca = cos(tmpa);
;rz = zoomvar * rndG - 1;

;Vx = ra * ca + X*rz;
;Vy = ra * sa + Y*rz;

        weight = xform_vars[fn,RADIAL_BLUR]
        if (weight!=0.0) ; Gaussian blur
          seed = random(seed), rv = abs(seed/#randomrange)
          seed = random(seed), float rv1 = abs(seed/#randomrange)
          seed = random(seed), float rv2 = abs(seed/#randomrange)
          seed = random(seed), float rv3 = abs(seed/#randomrange)
          float rndG = weight * (rv + rv1 + rv2 + rv3 - 2.0)
          float tmpa = theta +spinvar[fn] * rndG
          float sa = sin(tmpa)
          float ca = cos(tmpa)
          float rz = zoomvar[fn] *rndG - 1
          iterbuf[0,0] = iterbuf[0,0] + r * ca + tx * rz
          iterbuf[0,1] = iterbuf[0,1] + r * sa + ty * rz
        endif

        weight = xform_vars[fn,BUBBLE]
        if (weight!=0.0) ; bubble
          rr = weight / ( r2 / 4.0 + 1.0 )
          iterbuf[0,0] = iterbuf[0,0] + rr * tx
          iterbuf[0,1] = iterbuf[0,1] + rr * ty
        endif

        weight = xform_vars[fn,COSINE]
        if (weight!=0.0) ; Cosine alternate coding suggested by Nils (nuj)
           if ty <= 0.0
              dx = exp(ty)       ; dx = e^ty
              dy = 1/(dx+EPS)    ; dy = e^(-ty)
           else
             dy = exp(-ty)      ; dy = e^(-ty)
             dx = 1/(dy+EPS)    ; dx = e^ty
           endif
           dx = (dx - dy)/2      ; dx =  sinh
           dy = dx + dy          ; dy =  cosh
           nx = cos(tx*#pi) * dy
           ny = -sin(tx*#pi)* dx
           iterbuf[0,0] = iterbuf[0,0] + weight*nx
           iterbuf[0,1] = iterbuf[0,1] + weight*ny
        endif

        weight = xform_vars[fn,CYLINDER]
        if (weight!=0.0) ; cylinder
          iterbuf[0,0] = iterbuf[0,0] + weight*sin(tx)
          iterbuf[0,1] = iterbuf[0,1] + weight*ty
        endif

        weight = xform_vars[fn,DIAMOND]
        if (weight!=0.0)     ; Diamond aka square
          iterbuf[0,0] = iterbuf[0,0] + weight*sin(a) * cos(r)
          iterbuf[0,1] = iterbuf[0,1] + weight*cos(a) * sin(r)
        endif

        weight = xform_vars[fn,DISC]
        if (weight!=0.0) ; disk
          float nx = tx * #pi
          float ny = ty * #pi
          float rr = sqrt(nx*nx + ny*ny);
          iterbuf[0,0] = iterbuf[0,0] + weight*sin(rr)*a/PI
          iterbuf[0,1] = iterbuf[0,1] + weight*cos(rr)*a/PI
        endif

        weight = xform_vars[fn,EX]
        if (weight!=0.0) ; Ex
          float n0 = sin(a+r)
          float n1 = cos(a-r)
          float m0 = n0^3 * r
          float m1 = n1^3 * r
          iterbuf[0,0] = iterbuf[0,0] + weight*(m0+m1)
          iterbuf[0,1] = iterbuf[0,1] + weight*(m0-m1)
        endif

        weight = xform_vars[fn,EXPONENTIAL]
        if (weight!=0.0) ; Exponential alternate coding suggested by Nils(nuj)
;            dx = exp(tx) / 2.718281828459045
;            dy = #pi * ty
             nx = tx - 1.0
             if nx > 0.0
                dx = 1.0 / (exp(-nx) + EPS)
             else
                 dx = exp(nx)
             endif
             dx = weight * dx
             dy = #PI * ty
             iterbuf[0,0] = iterbuf[0,0] + weight*dx*cos(dy)
             iterbuf[0,1] = iterbuf[0,1] + weight*dx*sin(dy)
        endif

        weight = xform_vars[fn,EYEFISH]
        if (weight!=0.0) ; eyefish
          rr = 2*weight/(r + 1.0)
          iterbuf[0,0] = iterbuf[0,0] + rr*tx
          iterbuf[0,1] = iterbuf[0,1] + rr*ty
        endif

        weight = xform_vars[fn,FAN]
        if (weight!=0.0) ; fan
          float aa = 0
          dx = xform_coefs[fn,4]
          dy = xform_coefs[fn,5]
          dx = #pi * (dx * dx + EPS)
          float dx2 = dx / 2
          if ((angle + dy) % dx) > dx2
            aa = angle - dx2
          else
            aa = angle + dx2
          endif
          nx = cos(aa) * r
          ny = sin(aa) * r
          iterbuf[0,0] = iterbuf[0,0] + weight*nx
          iterbuf[0,1] = iterbuf[0,1] + weight*ny
        endif

        weight = xform_vars[fn,FAN2]
        if (weight!=0.0) ; fan2
          float p_x   = xform_pars[fn,FAN2_X]
          float p_y   = xform_pars[fn,FAN2_Y]
          dy = p_y
          dx = #pi*(p_x*p_x + EPS)
          float dx2 = dx / 2.0
          float ta = angle+dy - trunc((angle+dy)/dx) * dx
          float gamma = angle + dx2
          if ta > dx2
             gamma = angle - dx2
          endif
          nx = r*sin(gamma)
          ny = r*cos(gamma)
          iterbuf[0,0] = iterbuf[0,0] + weight*nx
          iterbuf[0,1] = iterbuf[0,1] + weight*ny
        endif

        weight = xform_vars[fn,FISHEYE]
        if (weight!=0.0) ; Fisheye
         float rr = 2.0 * weight / ( r + 1.0 )
         iterbuf[0,0] = iterbuf[0,0] + rr * ty
         iterbuf[0,1] = iterbuf[0,1] + rr * tx
        endif

        weight = xform_vars[fn,HANDKERCHIEF]
        if (weight!=0.0); folded handkerchief
          iterbuf[0,0] = iterbuf[0,0] + weight*sin(a+r)*r
          iterbuf[0,1] = iterbuf[0,1] + weight*cos(a-r)*r
        endif

        weight = xform_vars[fn,HEART]
        if (weight!=0.0) ; heart
          float a2 = a * r
          iterbuf[0,0] = iterbuf[0,0] + weight*sin(a2)*r
          iterbuf[0,1] = iterbuf[0,1] - weight*cos(a2)*r
        endif

        weight = xform_vars[fn,HORSESHOE]
        if (weight!=0.0); horseshoe
          rr = weight / (r + EPS)
          iterbuf[0,0] = iterbuf[0,0] + rr * (tx-ty)*(tx+ty)
          iterbuf[0,1] = iterbuf[0,1] + rr * (2.0*tx*ty)
        endif

        weight = xform_vars[fn,HYPERBOLIC]
        if (weight!=0.0) ; hyperbolic
          iterbuf[0,0] = iterbuf[0,0] + weight*sin(a)/(r+EPS)
          iterbuf[0,1] = iterbuf[0,1] + weight*cos(a)*(r+EPS)
        endif

        weight = xform_vars[fn,JULIA]
        if (weight!=0.0) ; julia
          float aa = a / 2.0
          seed = random(seed)
          ; seed seems to retain the same parity!...but jumps
          ; between positive and negative randomly
          if seed > 0
            aa = aa + #pi
          endif
          float rr = r2^0.25;
          nx = rr * cos(aa)
          ny = rr * sin(aa)
          iterbuf[0,0] = iterbuf[0,0] + weight*nx
          iterbuf[0,1] = iterbuf[0,1] + weight*ny
        endif

        weight = xform_vars[fn,JULIAN]
        if (weight!=0.0) ; julian
          int irv = 0
          float newangle = 0.0
          float newradius = 0.0
          float jnPower = xform_pars[fn,JULIAN_POWER]
          int rn = round(jnPower)
          float c = xform_pars[fn,JULIAN_DIST]
          float cn = c / (rn * 2)
          seed = random(seed)
          irv = round(abs(seed/#randomrange)*rn)
;          print (irv)
          newangle = (theta + irv*#PI*2)/(jnPower+EPS)
          newradius = r2 ^ cn
          iterbuf[0,0] = iterbuf[0,0] + weight * newradius * cos(newangle)
          iterbuf[0,1] = iterbuf[0,1] + weight * newradius * sin(newangle)
        endif

        weight = xform_vars[fn,JULIASCOPE]
        if (weight!=0.0) ; juliaScope
           ;  based on coding suggestions from Nils Jakobsen
           ;  since seed is not random enough for small numbers
           float jsPower = xform_pars[fn,JULIASCOPE_POWER]
           float jsDist = xform_pars[fn,JULIASCOPE_DIST]
           int   rN = abs(round(jsPower))
           seed = random(seed), int ran = abs(seed) - (abs(seed) % 8)
           rv   = ran/8
           ran  = round(rv) % rN
           float   cn = jsDist/jsPower
           rv         = (2*#pi*ran + theta*(1 - 2*(ran % 2)))/rN
           float sinv = sin(rv)
           float cosv = cos(rv)
           rr  = weight*(r^cn)
           iterbuf[0,0] = iterbuf[0,0] + rr*cosv
           iterbuf[0,1] = iterbuf[0,1] + rr*sinv
        endif

        weight = xform_vars[fn,LINEAR]        ; avoid excess indexing into arrays
        if (weight!=0.0); linear
          iterbuf[0,0] = iterbuf[0,0] + weight*tx
          iterbuf[0,1] = iterbuf[0,1] + weight*ty
        endif

        weight = xform_vars[fn,NOISE]
        if (weight!=0.0) ; noise
          seed = random(seed), rv = abs(seed/#randomrange) ; 0<rv<1
          float tmpr = rv * 2.0 * #PI
          seed = random(seed), rv = abs(seed/#randomrange) ; 0<rv<1
          float rr = weight * rv
          iterbuf[0,0] = iterbuf[0,0] + tx * rr * cos(tmpr)
          iterbuf[0,1] = iterbuf[0,1] + ty * rr * sin(tmpr)
        endif

        weight = xform_vars[fn,PDJ]
        if (weight!=0.0) ; pdj
          float p_a   = xform_pars[fn,PDJ_A]
          float p_b   = xform_pars[fn,PDJ_B]
          float p_c   = xform_pars[fn,PDJ_C]
          float p_d   = xform_pars[fn,PDJ_D]
          nx = real(sin(p_a*ty) - cos(p_b*tx))
          ny = real(sin(p_c*tx) - cos(p_d*ty))
          iterbuf[0,0] = iterbuf[0,0] + weight*nx
          iterbuf[0,1] = iterbuf[0,1] + weight*ny
        endif

        weight = xform_vars[fn,PERSPECTIVE]
        if (weight!=0.0) ; perspective
          float focus = xform_pars[fn, PERSPECTIVE_DIST]
          float p_angle = xform_pars[fn, PERSPECTIVE_ANGLE]
          float sinv = sin(p_angle*#PI/2)
          float vf = weight*focus
          float cosvf = vf*cos(p_angle*#PI/2)
          float tt = 1.0 / (focus - ty * sinv)
          iterbuf[0,0] = iterbuf[0,0] + vf*tx*tt
          iterbuf[0,1] = iterbuf[0,1] + cosvf*ty*tt
        endif

        weight = xform_vars[fn,POLAR]
        if (weight!=0.0); polar
          iterbuf[0,0] = iterbuf[0,0] + weight*angle/#pi
          iterbuf[0,1] = iterbuf[0,1] + weight*(r-1)
        endif

        weight = xform_vars[fn,POPCORN]
        if (weight!=0.0) ; Popcorn
           dx = tan(3.0 * ty)
           dy = tan(3.0 * tx)
           nx = tx + xform_coefs[fn,4] * sin(dx)
           ny = ty + xform_coefs[fn,5] * sin(dy)
           iterbuf[0,0] = iterbuf[0,0] + weight*nx
           iterbuf[0,1] = iterbuf[0,1] + weight*ny
        endif

        weight = xform_vars[fn,POWER]
        if (weight!=0.0) ; Power
           float rr = weight*(r^sint)
           iterbuf[0,0] = iterbuf[0,0] + rr*cost
           iterbuf[0,1] = iterbuf[0,1] + rr*sint
        endif

        weight = xform_vars[fn,RINGS]
        if (weight!=0.0) ; Rings
          dx = sqr(xform_coefs[fn,4]) + EPS
          rr = weight*((2*r) - dx * (trunc((r/dx+1)*0.5) * 2 + r)    )
          iterbuf[0,0] = iterbuf[0,0] + rr*cost
          iterbuf[0,1] = iterbuf[0,1] + rr*sint
        endif

        weight = xform_vars[fn,RINGS2]
        if (weight!=0.0) ; rings2
          float p_val = xform_pars[fn,RINGS2_VAL]
          dx = sqr(p_val) + EPS
          ;rr = r + dx - ((r + dx) / (2*dx))*2*dx - dx + r*(1-dx)
          rr = weight*(2-dx*(trunc((r/dx+1)/2)*2/r+1))
          iterbuf[0,0] = iterbuf[0,0] + rr*tx
          iterbuf[0,1] = iterbuf[0,1] + rr*ty
        endif

        weight = xform_vars[fn,SINUSOIDAL]
        if (weight!=0.0); sinusoidal
          iterbuf[0,0] = iterbuf[0,0] + weight*sin(tx)
          iterbuf[0,1] = iterbuf[0,1] + weight*sin(ty)
        endif

        weight = xform_vars[fn,SPHERICAL]
        if (weight!=0.0); complex
          iterbuf[0,0] = iterbuf[0,0] + weight*tx/(r2+EPS)
          iterbuf[0,1] = iterbuf[0,1] + weight*ty/(r2+EPS)
        endif

        weight = xform_vars[fn,SPIRAL]
        if (weight!=0.0); spiral
          iterbuf[0,0] = iterbuf[0,0] + weight*(cos(a) + sin(r))/(r+EPS)
          iterbuf[0,1] = iterbuf[0,1] + weight*(sin(a) - cos(r))/(r+EPS)
        endif

        weight = xform_vars[fn,SWIRL]
        if (weight!=0.0); swirl
          c1 = sin(r2), c2 = cos(r2)
          iterbuf[0,0] = iterbuf[0,0] + weight*(c1*tx - c2*ty)
          iterbuf[0,1] = iterbuf[0,1] + weight*(c2*tx + c1*ty)
        endif

        weight = xform_vars[fn,WAVES]
        if (weight!=0.0) ; Waves
          dx = xform_coefs[fn,4]
          dy = xform_coefs[fn,5]
          nx = tx + xform_coefs[fn,1] * sin(ty / ((dx*dx) + EPS))
          ny = ty + xform_coefs[fn,3] * sin(tx / ((dy*dy) + EPS))
          iterbuf[0,0] = iterbuf[0,0] + weight*nx
          iterbuf[0,1] = iterbuf[0,1] + weight*ny
        endif


      fn = FINALXF  ; if there is a second time, use final XForm
      if fincount == 0
        saved[0] = iterbuf[0,0]
        saved[1] = iterbuf[0,1]
      endif
      fincount = fincount + 1
      ;print ("fincount ", fincount)
    until fincount > fin


    ; Bin the point if it's inside the image limits and past the fuse
    if (it>=0)
      ; generate the x and y location in the image
      xp = (iterbuf[0,0]-xc)
      yp = (iterbuf[0,1]-yc)

      x = floor((xp*cosan - yp*sinan)*nuscale + wd2)
      y = floor((xp*sinan + yp*cosan)*nuscale + ht2)

      ; is this in our image?
      if (x>=0 && x<wd && y>=0 && y<ht)
        clr_index = round(iterbuf[0,2] * 256.0)
        if (clr_index<0)
          clr_index = 0
        elseif (clr_index>255)
          clr_index = 255
        endif

        ; add the *color* to the accumulator
        ; check for overflow later
        pix[x,y,0] = pix[x,y,0] + scl_cmap[clr_index,0]
        pix[x,y,1] = pix[x,y,1] + scl_cmap[clr_index,1]
        pix[x,y,2] = pix[x,y,2] + scl_cmap[clr_index,2]
        pix[x,y,3] = pix[x,y,3] + scl_cmap[clr_index,3]

      endif

    endif

    iterbuf[0,0] = saved[0]   ; these should be the same unless
    iterbuf[0,1] = saved[1]   ; final xform is enabled

    ; iterate some more
    it = it + 1
  endwhile
  ; Now we do some log magic - calculate the
  ; "where did these come from" k1 and k2 values
  float k1 = @contrast * @brightness * prefilter_white * 268.0 / 256.0
  float area = #height * #width / (scale * scale * @oversample * @oversample)
  float k2 = @oversample*@oversample / (@contrast * area * @white_level * @iter_density)

  ; loop through each pixel and perform log calculation
  x = 0
  float ls = 0, float lc[4]
  while (x < wd)
    y = 0
    while (y < ht)
      if (pix[x,y,3]>0)
        ; we can break up this calculation as follows:
        ; normalize each pixel's color by the number of iterations in the bucket * white_level
        ; this puts each component (R,G,B,Accum) in the range (0-1),
        ; and the last term is ALWAYS 1.0.
        ; Now, for each pixel, we have (R,G,B,1.0), and we want to scale the 'Y'
        ; component of this color by the log of the number of iterations.
        ;
        ; contr*bright* prefilter_white * 268                    iters
        ; ----------------------------------- * log (1.0 + ----------------)
        ;                256                               contrast * nsamp
        ;
        ; the log term will be bounded by (0-.6931) for contrast values >= 1.0.
        ; standard values for the first terms lead to
        ;
        ; 4288*(0-.6931) or 0-2972 values.  The range doesn't really matter, since
        ; we re-normalize by prefilter white to give (0-2.902) range, then


        ; brightness is a multiplier for the color.

        ; scale by the log of the number of occurrences
        ls = k1 * log(1.0 + pix[x,y,3]*k2) / pix[x,y,3]
        lc[0] = pix[x,y,0] * ls
        lc[1] = pix[x,y,1] * ls
        lc[2] = pix[x,y,2] * ls
        lc[3] = pix[x,y,3] * ls

        pix[x,y,0] = round(lc[0] + 0.5)
        pix[x,y,1] = round(lc[1] + 0.5)
        pix[x,y,2] = round(lc[2] + 0.5)
        pix[x,y,3] = round(lc[3] + 0.5)
      endif
      y = y + 1
    endwhile
    x = x + 1
  endwhile

  ; precalculate a gamma term
  float g = 1/@gamma

final:

  float fr, float fg, float fb, float fo
  float t[4], float lgs
  int xid, int yid

  t[0] = 0, t[1] = 0, t[2] = 0, t[3] = 0
; apply the spatial filter, if necessary
  int xadj, int yadj
  int sfadj = gutter_width - floor((filter_width-1)/2)
  int xcrd = #x*@oversample
  int ycrd = #y*@oversample
  bool inside = true
  if (@applyMapping == true)
      ; generate the x and y location in the image
      float dxx = (real(#pixel)-real(#center))
      float dyy = (imag(#pixel)-imag(#center))

      xcrd = floor((transx + (dxx*cosan + dyy*sinan)*scale)*@oversample)
      ycrd = floor((transy + (dxx*sinan - dyy*cosan)*scale)*@oversample)

      ; is this in our image?
      if (xcrd<0 || xcrd>=wd || ycrd<0 || ycrd>=ht)
        inside = false
      endif
  endif
  if (inside)
    if (filter_width>0)
      xid = 0
      while (xid<filter_width)
        xadj = xid + sfadj
        yid = 0
        while (yid<filter_width)
          yadj = yid + sfadj
          t[0] = t[0] + sf_gauss[xid,yid] * pix[xcrd+xadj,ycrd+yadj,0]
          t[1] = t[1] + sf_gauss[xid,yid] * pix[xcrd+xadj,ycrd+yadj,1]
          t[2] = t[2] + sf_gauss[xid,yid] * pix[xcrd+xadj,ycrd+yadj,2]
          t[3] = t[3] + sf_gauss[xid,yid] * pix[xcrd+xadj,ycrd+yadj,3]
          yid = yid + 1
        endwhile
        xid = xid + 1
      endwhile
    else
      ; average values from each of the @oversample^2 points.
      xid = 0
      int ov2 = round(@oversample*@oversample)
      int myadj = gutter_width - round(@oversample/2)
      while (xid<@oversample)
        xadj = xid + myadj
        yid = 0
        while (yid<@oversample)
          yadj = yid + myadj
          t[0] = t[0] + pix[xcrd+xadj,ycrd+yadj,0]/ov2
          t[1] = t[1] + pix[xcrd+xadj,ycrd+yadj,1]/ov2
          t[2] = t[2] + pix[xcrd+xadj,ycrd+yadj,2]/ov2
          t[3] = t[3] + pix[xcrd+xadj,ycrd+yadj,3]/ov2
          yid = yid + 1
        endwhile
        xid = xid + 1
      endwhile
    endif

    float alpha = t[3]
    if (alpha > 0.0)
      lgs = ((alpha/prefilter_white)^(g-1))/prefilter_white
      alpha = (alpha/prefilter_white)^g
      if alpha<0.0
        alpha = 0.0
      elseif alpha>1.0
        alpha = 1.0
      endif
    else
      lgs = 0.0
    endif
    float invalp = 1.0-alpha

    ; perhaps we should spatial filter / anti-alias here, in color space,
    ; instead of doing it in arbitrary space.

    fr = lgs * t[0]
    fg = lgs * t[1]
    fb = lgs * t[2]
    fo = lgs * t[3]

    #color = rgba(fr,fg,fb,fo) + @bk_color*invalp

  else
    #color = @bk_color
  endif

default:     ;  bookmark3

  title = "Flame Fractals (Apophysis 2.05)"

 ; Pretend this is a normal formula for Ultra Fractal 3, so you can
 ; attempt to render it -- it will probably not work well!
 ; May work OK for single flame layer, small image size.
 ; render = false
$IFDEF VER40
 ; Set the render setting to false for Ultra Fractal 4 so it knows that this
 ; is a flame fractal and has to be treated differently.
 render = false
$ENDIF

  helpfile = "flame.chm"

  float param apo_version
    default = 2.05
    visible = false
  endparam

  float param version
    default = 1.00
    visible = false
  endparam

  int param randomseed
    caption = "Random Seed"
    default = 1234567890
  endparam

  bool param normweights
    caption = "Normalize Weights?"
    default = true
  endparam

  bool param applyMapping
    caption = "Apply Mapping"
    default = true
    visible = false
  endparam

  float param percentInc
    caption = "Oversize by (%)"
    default = 0.0
    visible = @applyMapping == true
  endparam

  heading
    caption = "Render Settings"
  endheading

  int param iter_density
    caption = "Sample Density"
    default = 35
    min = 1
    hint = "By default, the number of iterations run by the program \
            is this value times the total number of pixels in the image. \
            If the image appears spotty, increase this value."
  endparam

  float param spat_filt_rad
    caption = "Filter Radius"
    default = 0.7
    min = 0.0
    hint = "This radius controls the amount of 'smearing' applied to the \
            image.  It specifically controls the size of the gaussian \
            kernel that is convolved with the image. Setting to 0.0 \
            turns the filter off.  Try values around 0.3, with the \
            spatial oversample set to 2 or 3 for nice results. "
  endparam

  int param oversample
    caption = "Oversample"
    default = 3
    min = 1
    hint = "Increasing this parameter increases the number of iterations \
            as well as the number of histogram bins, effectively allowing \
            anti-aliasing to be performed.  A value of 2 increases the \
            number of bins by 4x, 3 by 9x, etc."
  endparam


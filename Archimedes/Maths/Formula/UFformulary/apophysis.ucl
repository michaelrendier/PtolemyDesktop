  xform_pars[6,RADIAL_BLUR_ANGLE]  = @xf6_par_radial_blur_angle
  xform_vars[7,GAUSSIAN_BLUR]= @xf7_var_gaussian_blur
  xform_vars[7,RADIAL_BLUR]  = @xf7_var_radial_blur

Carr1304S { 
; A "Modified Carr" formula, based on the original with permission.
; Functionality added by Sharon S. Schultz, May, 2003.
; Updated for UF2 by Erik Reckase, Feb 2000

init:
  z = (sqrt(5+1.224)*conj(cos(#pixel)))/@scale
  c = sqrt(#pixel)^#pixel

loop:
  z = fn1(fn2(fn3(conj(cos(z+2))+(z/c)/(z-2))))

bailout:
  |real(z)| <= @bailout

default:
  title = "Carr 1304S"
  method = multipass
  periodicity = 0
  maxiter = 100
  magn = .7
  center = (0,0)
  
heading 
  caption = "Parameters"
endheading

param scale
  caption = "Scale"
  default = 1.0
  hint = "Select a value to scale the image elements."
endparam
param bailout
  caption = "Bailout"
  default = 100
  hint = "Select a bailout value for the formula."
endparam

heading

Carr1387S (XAXIS_NOPARM) { 
; A "Modified Carr" formula, based on the original with permission.
; Functionality added by Sharon S. Schultz, May, 2003.
; Updated for UF2 by Erik Reckase, Feb 2000
; FractalFenderC Modified
; Edited for Fractint v. 20 By George Martin, 10/98

init:
  z = 0.224
  x = |z|
  c = (z*1/#pixel)/@scale
  
loop:
  IF (|x| > 1)
    z = fn1(fn2(fn3(cosh(z)+c)))
  ENDIF
  
  z = fn1(fn2(fn3(sqr(z)+#pixel)))
  x = |z|

bailout:
  x <= @bailout

default:
  title = "Carr 1387S"
  method = multipass
  periodicity = 0
  maxiter = 100
  magn = 1
  center = (0,0)
  
heading 
  caption = "Parameters"
endheading

param scale

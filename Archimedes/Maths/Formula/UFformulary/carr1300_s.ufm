Carr1382S { 
; A "Modified Carr" formula, based on the original with permission.
; Functionality added by Sharon S. Schultz, May, 2003.
; Updated for UF2 by Erik Reckase, Feb 2000
; SpNewton modified

init:
  z = (sqr(sqr(#pixel)))/@scale
  
loop:
  z1 = (z*z-1)*(z*z+0.16)
  z2 = 4*z^3-1.68*z
  z = fn1(fn2(fn3(z-z1/z2)))

bailout:
  |real(z)| <= @bailout

default:
  title = "Carr 1382S"
  method = multipass
  periodicity = 0
  maxiter = 100
  magn = 1
  center = (0,0)
  

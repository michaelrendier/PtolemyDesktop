Carr1360S { 
; A "Modified Carr" formula, based on the original with permission.
; Functionality added by Sharon S. Schultz, May, 2003.
; Updated for UF2 by Erik Reckase, Feb 2000
; Modified Peter Jack (Newton variation) frm.

init:
  z = #pixel/@scale

loop:
  z2 = cotanh(z*z)
  z3 = cotanh(z*z*z)
  z = fn1(fn2(fn3(cotanh(z-((z3-z*.25-1.25)/((z2*3-.25)))))))

bailout:
  |(z3-z*.25-1.25)| >= 0.000001*@bailout

default:
  title = "Carr 1360S"
  method = multipass
  periodicity = 0
  maxiter = 100
  magn = .4
  center = (0,0)
  

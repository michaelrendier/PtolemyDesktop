Carr1386S { 
; A "Modified Carr" formula, based on the original with permission.
; Functionality added by Sharon S. Schultz, May, 2003.
; Updated for UF2 by Erik Reckase, Feb 2000

init:
  z = #pixel/@scale
  c = z^(z-1)

loop:
  z = (z-z*1/(cotanh(c)/cosh(c)))/(#pixel-z*z+c)
  z = fn1(fn2(fn3(z-z*1/(cotanh(c)/cosh(c)))))

bailout:
  |z| <= @bailout

default:
  title = "Carr 1386S"
  method = multipass
  periodicity = 0
  maxiter = 100
  magn = 1
  center = (0,0)
  

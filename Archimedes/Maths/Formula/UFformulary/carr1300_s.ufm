Carr1344S { 
; A "Modified Carr" formula, based on the original with permission.
; Functionality added by Sharon S. Schultz, May, 2003.
; Updated for UF2 by Erik Reckase, Feb 2000

init:
  z = (conj(cos(1/#pixel)))/@scale
  z2 = flip(real(z))
  z3 = conj(imag(z))
  c = cotanh(1/#pixel)
  z4 = conj(sqr(#pixel))/conj(cos(sqr(#pixel)))

loop:
  z = fn1(fn2(fn3((z*1/c)+z4)))
  z2 = conj(z2^z3)/z
  z3 = conj(z3^z4)/z
  z4 = (1/z*z+z4)/(#pixel-z*z+c)

bailout:
  |real(z)| <= @bailout

default:
  title = "Carr 1344S"
  method = multipass
  periodicity = 0
  maxiter = 100

               - @lattFac1*sqrt(real(z)*imag(z)))^2)  \
      - @lattFac2*z^2

  endif

  if (z == #pixel)
    deriv = @derivFkt(#pixel)
  else
    deriv = (@derivFkt(z) - @derivFkt(#pixel))/(z-#pixel)
  endif

  ; Here comes the Joukowskij
  z = deriv^@exponent - @jouk/deriv

  if (@pure)

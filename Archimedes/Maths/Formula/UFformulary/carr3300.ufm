Carr3341 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  d=sqrt(1/pixel2-conj(cos(1/pixel2)))
  c=(.5+pixel2/2)^7-conj(.1/pixel2)-flip(.1/pixel2)+.3
  b5=(.5+pixel2/3)^4*conj(.5+pixel2/2)^4-conj(.15/pixel2) \
     -flip(.15/pixel2)+.3
  IF (@p3==1)
    z = (b5^.7456)
  ELSEIF (@p3==0)
    c = -c, z = -(b5)
  ELSE
    IF (whitesq)
      z = (b5^.7456)
    ELSE
      c = -c, z = -(b5)
    ENDIF
  ENDIF
  cmod = flip(|d/40*pixel2|)
  ctmp = conj(c-.075/c)-cmod
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    ctmp = conj(c1-.075/c1)-cmod, z = 0
  ELSEIF (iter==l2)
    ctmp = conj(c2-.075/c2)-cmod, z = 0
  ELSEIF (iter==l3)
    ctmp = conj(c3-.075/c3)-cmod, z = 0
  ELSEIF (iter==l4)
    ctmp = conj(c4-.075/c4)-cmod, z = 0
  ENDIF
  z=z*z+ctmp
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3341"
  periodicity = 0
  maxiter = 700
  magn = .6
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"

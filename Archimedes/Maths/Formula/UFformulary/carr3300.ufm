comment {
  Carr3300.ufm Version 1.6
  Ultra Fractal conversions of Robert Carr's formulas Carr3300 - Carr3399
  by Erik Reckase, February 25, 2000

  History:  Version 1.6 - Minor optimization tweaks + cleanup
 
            Version 1.5 - Formulas 3381-3384 optimized

            Version 1.4 - major optimization overhaul

            Version 1.3 - bailout condition typo'd in 3383-3399

            Version 1.2 - Modified whitesq code to eliminate warnings

            Version 1.1 - Removed unnecessary code in Carr2887-2899
                          for optimization

            Version 1.0 - Initial Release
                          Original formulas pulled from 43eCarr.frm
                                                        43fCarr.frm
                                                        43gCarr.frm
                                                        43hCarr.frm
                          Carr3300-3380,3386-3399  : pixel fix
                          Carr3385                 : |z|, cosxx fixes
                          Carr3316-3320,3353       : variable used before defined
                          Carr3337,3360,3373       : variables not used, removed
}

Carr3300 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  b6=conj(.015/pixel2), b7=flip(.025/pixel2)
  b8=sin(.002/pixel2-flip(.002/pixel2))
  b10=pixel2^10-conj(.01/pixel2-flip(.15/pixel2))
  c=abs(pixel2^2)*b10-.01/pixel2
  b5=cabs(pixel2^2)*abs(b10)^2*(.1-c)-(b8+b6+b7)/.65 \
     -.002/pixel2-.19
  IF (@p3==1)
    z = (b5)^.745
  ELSEIF (@p3==0)
    c = -c, z = -(b5)/2
  ELSE
    IF (whitesq)
      z = (b5)^.745
    ELSE
      c = -c, z = -(b5)/2
    ENDIF
  ENDIF
  cmod = .015 + (b8*b6)^3/1.5
  c = c - cmod - .24
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = c1 - cmod, z = 0
  ELSEIF (iter==l2)
    c = c2 - cmod, z = 0
  ELSEIF (iter==l3)
    c = c3 - cmod, z = 0
  ELSEIF (iter==l4)
    c = c4 - cmod, z = 0
  ENDIF
  z = z^2 + c
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3300"
  periodicity = 0
  maxiter = 700
  magn = 1.4
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr3301 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  b6=conj(.015/pixel2), b7=flip(.025/pixel2)
  b8=cabs(.002/pixel2+cabs(.002/pixel2))
  b10=flip(pixel2^8)-.4/cos(pixel2) \
      -conj(.01/pixel2-flip(.15/pixel2))
  c=cabs(pixel2^2)*b10-.01/pixel2
  b5=cabs(pixel2^2)*abs(b10)^2*(.1-c)-(b8+b6+b7)/.65 \
     -.002/pixel2-.1951
  IF (@p3==1)
    z = (b5)^.745
  ELSEIF (@p3==0)
    c = -c, z = -(b5)/2
  ELSE
    IF (whitesq)
      z = (b5)^.745
    ELSE
      c = -c, z = -(b5)/2
    ENDIF
  ENDIF
  cmod = .015 + (b8^2*b6/pixel2)^3/1.5
  c = c - cmod-.24
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = c1 - cmod, z = 0
  ELSEIF (iter==l2)
    c = c2 - cmod, z = 0
  ELSEIF (iter==l3)
    c = c3 - cmod, z = 0
  ELSEIF (iter==l4)
    c = c4 - cmod, z = 0
  ENDIF
  z = |z/2.5| + z^2 + c
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3301"
  periodicity = 0
  maxiter = 700
  magn = 1.4
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr3302 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  b6=conj(0.015/pixel2), b7=flip(0.025/pixel2)
  b8=cabs(.002/pixel2+cabs(.002/pixel2))
  b10=flip(pixel2^8)-.4/cos(pixel2) \
      -conj(.01/pixel2-flip(.15/pixel2))
  c=cabs(pixel2^2)*b10^3-.01/pixel2
  b5=sinh(pixel2^4)*flip(b10)^3*conj(.25-c) \
     -(b8+b6+b7)/.65-.002/pixel2-.1951
  IF (@p3==1)
    z = (b5)^.745
  ELSEIF (@p3==0)
    c = -c, z = -(b5/2*pixel2^2)
  ELSE
    IF (whitesq)
      z = (b5)^.745
    ELSE
      c = -c, z = -(b5/2*pixel2^2)
    ENDIF
  ENDIF
  cmod = .015 + ((b8^2*b6/pixel2)^3)/1.5
  c = c - cmod - .24
  z = z + .15
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = c1 - cmod, z = 0
  ELSEIF (iter==l2)
    c = c2 - cmod, z = 0
  ELSEIF (iter==l3)
    c = c3 - cmod, z = 0
  ELSEIF (iter==l4)
    c = c4 - cmod, z = 0
  ENDIF
  z = |z/2.5| + z^2 + c
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3302"
  periodicity = 0
  maxiter = 700
  magn = 1.4
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr3303 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  b6=conj(.015/pixel2), b7=flip(.025/pixel2)
  b8=cabs(.002/pixel2+cabs(.002/pixel2))
  b10=flip(pixel2^8)-.4/cos(pixel2) \
      -conj(.01/pixel2-flip(.15/pixel2))
  c=cabs(pixel2^2)*b10^3-.01/pixel2
  b5=sinh(pixel2^4)*flip(b10)^3*conj(.25-c) \
     -(b8+b6+b7)/.65-.002/pixel2-.1951
  IF (@p3==1)
    z = (b5)^.745+.15
  ELSEIF (@p3==0)
    c = -c, z = -(b5/2*pixel2^2)+.15
  ELSE
    IF (whitesq)
      z = (b5)^.745+.15
    ELSE
      c = -c, z = -(b5/2*pixel2^2)+.15
    ENDIF
  ENDIF
  cmod = .015 + (b8^2*b6/pixel2)^3/1.5
  c = .875*(c-.24) - cmod
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = .875*c1 - cmod, z = 0
  ELSEIF (iter==l2)
    c = .875*c2 - cmod, z = 0
  ELSEIF (iter==l3)
    c = .875*c3 - cmod, z = 0
  ELSEIF (iter==l4)
    c = .875*c4 - cmod, z = 0
  ENDIF
  z = |z/2.5| + z^2 + c
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3303"
  periodicity = 0
  maxiter = 700
  magn = 1.4
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr3304 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  b6=conj(.015/pixel2), b7=flip(.025/pixel2)
  b8=cabs(.002/pixel2+cabs(.002/pixel2))
  b10=flip(pixel2^8)-.4/cos(pixel2) \
      -conj(.01/pixel2-flip(.15/pixel2))
  c=cabs(pixel2^2)*b10^3-.01/pixel2
  b5=flip(b10)^3*conj(.25-c)/pixel2-(b8+b6+b7)/.65 \
     -.002/pixel2-.1951
  IF (@p3==1)
    z = (b5)^.745
  ELSEIF (@p3==0)
    c = -c, z = -(b5/2*pixel2^2)
  ELSE
    IF (whitesq)
      z = (b5)^.745
    ELSE
      c = -c, z = -(b5/2*pixel2^2)
    ENDIF
  ENDIF
  c = c - .24
  z = z + .15
  c = c + |c/8| - .015
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = c1 + |c1/8| - .015, z = 0
  ELSEIF (iter==l2)
    c = c2 + |c2/8| - .015, z = 0
  ELSEIF (iter==l3)
    c = c3 + |c3/8| - .015, z = 0
  ELSEIF (iter==l4)
    c = c4 + |c4/8| - .015, z = 0
  ENDIF
  z = |z/2.5| + z^2 + c
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3304"
  periodicity = 0
  maxiter = 700
  magn = 1.4
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr3305 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  b6=conj(.015/pixel2), b7=flip(.025/pixel2)
  b10=flip(pixel2^8)*.2/cotanh(pixel2^4) \
      -conj(.01/pixel2-flip(.125/pixel2))
  b5=conj(pixel2+b6)^4*pixel2^3*b10-(b6+b7)/.64+.1345
  c=conj(conj(pixel2/2)*sin(abs(pixel2/3)^5)) \
    *flip(pixel2^6-b7)-b6
  IF (@p3==1)
    z = (b5)^.745
  ELSEIF (@p3==0)
    c = -c, z = -(b5)/.75
  ELSE
    IF (whitesq)
      z = (b5)^.745
    ELSE
      c = -c, z = -(b5)/.75
    ENDIF
  ENDIF
  c = 12*c/11
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = 12*c1/11, z = 0
  ELSEIF (iter==l2)
    c = 12*c2/11, z = 0
  ELSEIF (iter==l3)
    c = 12*c3/11, z = 0
  ELSEIF (iter==l4)
    c = 12*c4/11, z = 0
  ENDIF
  z = z^2 - c
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3305"
  periodicity = 0
  maxiter = 700
  magn = 1.3
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr3306 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  d=sqrt(1/pixel2-conj(cos(1/pixel2)))
  b6=conj(.015/pixel2), b7=flip(.025/pixel2)
  b8=cabs(.002/pixel2+cabs(.002/pixel2))
  b10=flip(pixel2^8)*.2/cotanh(pixel2^4) \
      -conj(.01/pixel2-flip(.125/pixel2))
  b5=tanh(pixel2+b6)^4*pixel2^3*b10-(b8+b7)/.64+.1345+.1/cos(b6)
  c=conj(conj(pixel2/2)+sin(abs(pixel2/3)^5)) \
    *flip(pixel2^6-b7)-b6
  zmod1 = .25*b6
  cmod = flip(|d/70*pixel2|) + .33*b7
  IF (@p3==1)
    z = (b5)^.745
  ELSEIF (@p3==0)
    c = -(c^2), z = -(b5)/.75
  ELSE
    IF (whitesq)
      z = (b5)^.745
    ELSE
      c = -(c^2), z = -(b5)/.75
    ENDIF
  ENDIF
  c = cmod + c/8 - conj(c+zmod1)
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = cmod + c1/8 - conj(c1+zmod1), z = 0
  ELSEIF (iter==l2)
    c = cmod + c2/8 - conj(c2+zmod1), z = 0
  ELSEIF (iter==l3)
    c = cmod + c3/8 - conj(c3+zmod1), z = 0
  ELSEIF (iter==l4)
    c = cmod + c4/8 - conj(c4+zmod1), z = 0
  ENDIF
  z = z^2 + c
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3306"
  periodicity = 0
  maxiter = 700
  magn = 1.4
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr3307 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  b6=conj(.015/pixel2), b7=flip(.025/pixel2)
  b8=cabs(.002/pixel2+cabs(.002/pixel2))
  b10=flip(pixel2^8)*.2/cotanh(pixel2^4) \
      -conj(.01/pixel2-flip(.125/pixel2))
  b5=tanh(pixel2+b6)^4*pixel2^3*b10-(b8+b7)/.64+.1345+.1/cos(b6)
  c=conj(conj(pixel2/2)+sin(abs(pixel2/3)^5))*flip(pixel2^6-b7)-b6
  cmod = (b8^2*b6/pixel2)^3/1.5
  IF (@p3==1)
    z = (b5)^.745
  ELSEIF (@p3==0)
    c = -(c^2), z = -(b5)/.75
  ELSE
    IF (whitesq)
      z = (b5)^.745
    ELSE
      c = -(c^2), z = -(b5)/.75
    ENDIF
  ENDIF
  c = c + cmod
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = c1 + cmod, z = 0
  ELSEIF (iter==l2)
    c = c2 + cmod, z = 0
  ELSEIF (iter==l3)
    c = c3 + cmod, z = 0
  ELSEIF (iter==l4)
    c = c4 + cmod, z = 0
  ENDIF
  z = z^2 - c
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3307"
  periodicity = 0
  maxiter = 700
  magn = 1.4
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr3308 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  b6=conj(.015/pixel2), b7=flip(.025/pixel2)
  b10=flip(pixel2^8)*2/cotanh(pixel2^4) \
      -conj(.01/pixel2-flip(.125/pixel2))
  b5=conj(pixel2^2)*flip(pixel2^5)-b6-b7-.066/b10
  c=b5-.1/conj(conj(pixel2/2)+sin(abs(pixel2/3)^5)) \
    *flip(pixel2^6-b7)-b6
  IF (@p3==1)
    z = (b5)^.745
  ELSEIF (@p3==0)
    c = -(c^2), z = -(b5)/.75
  ELSE
    IF (whitesq)
      z = (b5)^.745
    ELSE
      c = -(c^2), z = -(b5)/.75
    ENDIF
  ENDIF
  c = 12*c/11
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = 12*c1/11, z = 0
  ELSEIF (iter==l2)
    c = 12*c2/11, z = 0
  ELSEIF (iter==l3)
    c = 12*c3/11, z = 0
  ELSEIF (iter==l4)
    c = 12*c4/11, z = 0
  ENDIF
  z = z^2 - c
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3308"
  periodicity = 0
  maxiter = 700
  magn = 1.4
  center = (0,0)

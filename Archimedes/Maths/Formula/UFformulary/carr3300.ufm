Carr3355 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  d=flip(|sqrt(1/pixel2-conj(cos(1/pixel2)))/70*pixel2|)
  b1=pixel2/2*conj(abs(pixel2/3))*abs(pixel2/4)
  ba=8*conj(.1-pixel2)*conj(sinh(pixel2))*flip(tanh(pixel2))
  m3=tanh(pixel2/2)*pixel2/2*ba*b1, b5=conj(m3)-tanh(.1/pixel2)
  c=cabs(b5/2)-conj(.015/pixel2)
  IF (@p3==1)
    z = (b5^.745)
  ELSEIF (@p3==0)
    c = -c, z = -(b5)
  ELSE
    IF (whitesq)
      z = (b5^.745)
    ELSE
      c = -c, z = -(b5)
    ENDIF
  ENDIF
  c = c+2
  ctmp = -conj(.1/pixel2)/c + d
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = c1+2, z = 0
    ctmp = -conj(.1/pixel2)/c + d
  ELSEIF (iter==l2)
    c = c2+2, z = 0
    ctmp = -conj(.1/pixel2)/c + d
  ELSEIF (iter==l3)
    c = c3+2, z = 0
    ctmp = -conj(.1/pixel2)/c + d
  ELSEIF (iter==l4)
    c = c4+2, z = 0
    ctmp = -conj(.1/pixel2)/c + d
  ENDIF
  z = (3*z^2-1)/c + ctmp
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3355"
  periodicity = 0
  maxiter = 700
  magn = 1.2
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}


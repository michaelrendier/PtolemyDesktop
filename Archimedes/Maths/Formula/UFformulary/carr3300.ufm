Carr3316 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
                  ; Cannot emulate Fractint behavior with 
                  ;   variable carryover
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  b6=conj(.015/pixel2), b7=flip(.025/pixel2)
  b8=cabs(.002/pixel2+cabs(.002/pixel2))
  b10=flip(pixel2^8)*2/cotanh(pixel2^4) \
      -conj(.01/pixel2-flip(.125/pixel2))
  b3=exp(.0045/pixel2)/conj(cos(.1-pixel2))-conj(0.01/pixel2)
  b5=pi*(b6-pixel2^4)*b10^3*b7^3-(b8+b6+b7)/.65-.002/pixel2+.15
  c=pixel2^6-.33*(pixel2^4-b3)-.025/b5
  cmod = (b8^2*b6/pixel2)^3/1.5 - b6
  IF (@p3==1)
    z = (b5^.745)
  ELSEIF (@p3==0)
    c = -c, z = -(b5)
  ELSE
    IF (whitesq)
      z = (b5^.745)
    ELSE
      c = -c, z = -(b5)
    ENDIF
  ENDIF
  c = 12*c/11 + cmod
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = 12*c1/11 + cmod, z = 0
  ELSEIF (iter==l2)
    c = 12*c2/11 + cmod, z = 0
  ELSEIF (iter==l3)
    c = 12*c3/11 + cmod, z = 0
  ELSEIF (iter==l4)
    c = 12*c4/11 + cmod, z = 0
  ENDIF
  z=z*z-c
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3316"
  periodicity = 0
  maxiter = 700
  magn = 1.4
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)

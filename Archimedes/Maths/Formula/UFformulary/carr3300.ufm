    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr3338 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  c=.3*pixel2^4/cos(.1/cotanh(pixel2)) \
     -.1/log(pixel2-.2/sqrt(.5/pixel2))^2.5-conj(.05/pixel2)
  b5=.2-conj(.025/pixel2)
  IF (@p3==1)
    z = (b5^.7456)
  ELSEIF (@p3==0)
    c = -c, z = -(b5)
  ELSE
    IF (whitesq)
      z = (b5^.7456)
    ELSE
      c = -c, z = -(b5)
    ENDIF
  ENDIF
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = c1, z = 0
  ELSEIF (iter==l2)
    c = c2, z = 0
  ELSEIF (iter==l3)
    c = c3, z = 0
  ELSEIF (iter==l4)
    c = c4, z = 0
  ENDIF
  z=z*z+c
  iter=iter+1
bailout:
  |z|<=bailout
default:

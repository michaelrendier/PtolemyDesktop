  IF (@p3==1)
    c = -c, z = -z
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -c, z = -z
    ENDIF
  ENDIF
  ctemp = conj(pixel2-c-.175) + cmod
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    ctemp = conj(pixel2-c1-.175) + cmod, z = 0
  ELSEIF (iter==l2)
    ctemp = conj(pixel2-c2-.175) + cmod, z = 0
  ELSEIF (iter==l3)
    ctemp = conj(pixel2-c3-.175) + cmod, z = 0
  ELSEIF (iter==l4)
    ctemp = conj(pixel2-c4-.175) + cmod, z = 0
  ENDIF
  z = z^2 + ctemp
  iter=iter+1
bailout:
  |z|<=bailout

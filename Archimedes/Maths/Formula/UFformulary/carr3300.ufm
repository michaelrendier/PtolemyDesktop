Carr3310 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  d=sqrt(1/pixel2-conj(cos(1/pixel2)))
  b6=conj(.015/pixel2), b7=flip(.025/pixel2)
  b8=cabs(.002/pixel2+cabs(.002/pixel2))
  b10=flip(pixel2^8)*2/cotanh(pixel2^4) \
      -conj(.01/pixel2-flip(.125/pixel2))
  c=(-.3278,-.066)
  z=tanh(pixel2^4)*flip(b10)^3*conj(.25-c)-(b8+b6+b7)/.65 \
    -.002/pixel2

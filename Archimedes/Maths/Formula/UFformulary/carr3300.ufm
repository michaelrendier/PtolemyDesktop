  b3=exp(.0045/pixel2)/conj(cos(.1-pixel2))-conj(.01/pixel2)
  b2=(b8-b6-b7)/.55-.001/pixel2
  c=|pixel2|^5+conj(.1/pixel2+flip(.01/pixel2))
  b9=conj(.007/c-flip(.007/c))
  b5=flip(imag(.33+sin(|pixel2|)))*cabs(pixel2^4)-b2+.001*b3 \
     -.42*conj(cos(b9))+.3
  zmod = .33*b7+b2
  IF (@p3==1)

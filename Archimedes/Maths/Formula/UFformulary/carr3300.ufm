  b10a=pixel2-2*sinh(.01/pixel2)-tanh(.01/pixel2)
  b1=tanh(pixel2)^2-conj(.075*cos(.2-pixel2^-.025))
  b5=conj(b10^3)*conj(b10a^2*pixel2^2.5)-.2*b1-b6-b8-.1945

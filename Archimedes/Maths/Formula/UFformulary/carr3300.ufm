  ENDIF
  c=c*13/12
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = c1*13/12, z = 0
  ELSEIF (iter==l2)
    c = c2*13/12, z = 0
  ELSEIF (iter==l3)
    c = c3*13/12, z = 0
  ELSEIF (iter==l4)
    c = c4*13/12, z = 0
  ENDIF
  z = z^2 - conj(.15*z) + c
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3336"
  periodicity = 0
  maxiter = 700
  magn = 1.4
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr3337 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  b6=conj(.055/pixel2), b7=flip(.025/pixel2)
  z=conj(pixel2^2)*conj(flip(pixel2^3))-b6^2-b7+.1534
  c=conj(z/2.5)+flip(z/2.5)-b6
  IF (@p3==0)
    c = -c, z = -conj(z-b6)
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -c, z = -conj(z-b6)
    ENDIF
  ENDIF
  c = c*9/8
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = c1*9/8, z = 0
  ELSEIF (iter==l2)
    c = c2*9/8, z = 0
  ELSEIF (iter==l3)
    c = c3*9/8, z = 0
  ELSEIF (iter==l4)
    c = c4*9/8, z = 0
  ENDIF
  z=z*z-conj(0.25*z)+c
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3337"
  periodicity = 0
  maxiter = 700
  magn = 1.5
  center = (0,-.04)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"

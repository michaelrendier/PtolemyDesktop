Carr3317 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
                  ; Cannot emulate Fractint behavior with 
                  ;   variable carryover
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  b6=conj(.015/pixel2), b7=flip(.025/pixel2)
  b8=cabs(.002/pixel2+cabs(.002/pixel2))
  b10=flip(pixel2^8)*2/cotanh(pixel2^4) \
      -conj(.01/pixel2-flip(.125/pixel2))
  b3=exp(.0045/pixel2)/conj(cos(.1-pixel2))-conj(.01/pixel2)
  b2=(b8-b6-b7)/.55-.001/pixel2
  z=(b6-cabs(pixel2^4))*b10^5*b7^3-b2^1.25+.1
  c=abs(pixel2)^6-.33*(pixel2^4-b3)-.025/z
  cmod = (-.7456,-.132)^2.5
  IF (@p3==0)
    c = -(c^2), z = -z
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -(c^2), z = -z
    ENDIF
  ENDIF
  c = 2*c^2 + cmod
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = 2*c1^2 + cmod, z = 0
  ELSEIF (iter==l2)
    c = 2*c2^2 + cmod, z = 0
  ELSEIF (iter==l3)
    c = 2*c3^2 + cmod, z = 0
  ELSEIF (iter==l4)
    c = 2*c4^2 + cmod, z = 0
  ENDIF
  z = z^3/5 + z^2 + c
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3317"
  periodicity = 0
  maxiter = 700
  magn = 1.4
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"

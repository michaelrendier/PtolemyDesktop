  ELSEIF (iter==l2)
    z = 0
  ELSEIF (iter==l3)
    z = 0
  ELSEIF (iter==l4)
    z = 0
  ENDIF
  z=z^2+(-.7612073214,.080996112)
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3399"
  periodicity = 0
  maxiter = 700
  magn = 1.3
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

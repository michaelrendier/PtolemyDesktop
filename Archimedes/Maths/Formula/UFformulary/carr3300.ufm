Carr3378 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  d=flip(|sqrt(1/pixel2-conj(cos(1/pixel2)))|/40*pixel2)
  c=pixel2^4-conj(.1/pixel2-flip(.01/pixel2))
  z=pixel2^4-conj(.01/pixel2-flip(.01/pixel2))-conj(.1/pixel2)-.2
  IF (@p3==0)
    c = -c, z = -(z/2)
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -c, z = -(z/2)
    ENDIF
  ENDIF
  ctmp = conj(c-.075/c)-d
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    ctmp = conj(c1-.075/c1)-d,z = 0
  ELSEIF (iter==l2)
    ctmp = conj(c2-.075/c2)-d,z = 0
  ELSEIF (iter==l3)
    ctmp = conj(c3-.075/c3)-d,z = 0
  ELSEIF (iter==l4)
    ctmp = conj(c4-.075/c4)-d,z = 0
  ENDIF
  z = z^2 + ctmp
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3378"
  periodicity = 0
  maxiter = 700
  magn = 1.4
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}


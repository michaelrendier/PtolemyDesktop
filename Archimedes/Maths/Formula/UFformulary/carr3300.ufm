  pixel2=-abs(real(pixel))+flip(imag(pixel))
  b6=conj(.0015/pixel2), b8=cabs(.002/pixel2+cabs(.002/pixel2))
  c=flip(abs(pixel2))^4/flip(asinh(pixel2))-conj(.1/pixel2)
  b5=(conj(flip(abs(pixel2-b8))^6 \

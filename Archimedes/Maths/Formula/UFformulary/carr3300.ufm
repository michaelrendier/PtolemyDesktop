Carr3327 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  b6=conj(.01/pixel2), b7=flip(.02/pixel2)
  b1=pixel2^2-conj(.2*cos(.2-pixel2^-.025))
  b5=flip(conj(pixel2^4))*abs(pixel2)*b1 \
     -conj(.0125/pixel2-flip(.005/pixel2))-.075
  c=conj(1.5*b5)^2-conj(.001/b5-flip(.001/b5))
  zmod = -b7+b6
  IF (@p3==1)
    z = (b5^.66)
  ELSEIF (@p3==0)
    c = -c, z = -(b5)
  ELSE
    IF (whitesq)
      z = (b5^.66)
    ELSE
      c = -c, z = -(b5)
    ENDIF
  ENDIF
  c = 1.1*c + zmod
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = 1.1*c1 + zmod, z = 0
  ELSEIF (iter==l2)
    c = 1.1*c2 + zmod, z = 0
  ELSEIF (iter==l3)
    c = 1.1*c3 + zmod, z = 0
  ELSEIF (iter==l4)
    c = 1.1*c4 + zmod, z = 0
  ENDIF
  z = z^2 + c
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3327"
  periodicity = 0
  maxiter = 700
  magn = 1.5
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"

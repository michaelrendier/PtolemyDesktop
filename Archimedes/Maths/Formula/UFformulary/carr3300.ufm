  b8=cabs(.002/pixel2+cabs(.002/pixel2))
  b10a=pixel2-2*sinh(.01/pixel2)-tanh(.01/pixel2)
  b10=|pixel2^3|*abs(pixel2)
  b5=conj(b10^1.5)*b10a^2*pixel2-b6-b7-b8-.1945
  c=conj(1.5*b5)^2-conj(.001/b5-flip(.001/b5))
  IF (@p3==1)

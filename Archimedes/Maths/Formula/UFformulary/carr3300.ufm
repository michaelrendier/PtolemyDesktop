    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr3318 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
                  ; Cannot emulate Fractint behavior with 
                  ;   variable carryover
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  b6=conj(.015/pixel2), b7=flip(.025/pixel2)
  b8=cabs(.002/pixel2+cabs(.002/pixel2))
  b10=flip(pixel2^8)*2/cotanh(pixel2^4) \
      -conj(.01/pixel2-flip(.125/pixel2))
  b3=exp(.0045/pixel2)/conj(cos(0.1-pixel2))-conj(.01/pixel2)
  b2=(b8-b6-b7)/.55-.001/pixel2
  z=(b6-cabs(pixel2^4))*b10^5*b7^3+b2^1.25+.1
  c=abs(pixel2)^6-.33*(pixel2^4-b3)-.015/z-|.015/z*b3|
  zmod = (-.7456,-.132)^2.5
  IF (@p3==1)
    c = -(c^2), z = -(z)
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -(c^2), z = -(z)
    ENDIF
  ENDIF
  c = 2*c^2 + zmod
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = 2*c1^2 + zmod, z = 0
  ELSEIF (iter==l2)
    c = 2*c2^2 + zmod, z = 0
  ELSEIF (iter==l3)
    c = 2*c3^2 + zmod, z = 0
  ELSEIF (iter==l4)
    c = 2*c4^2 + zmod, z = 0
  ENDIF
  z = z^3/5 + z^2 + c
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3318"
  periodicity = 0
  maxiter = 700
  magn = 1.4
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}

Carr3319 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  b6=conj(.015/pixel2), b7=flip(.025/pixel2)
  b8=cabs(.002/pixel2+cabs(.002/pixel2))
  b3=exp(.0045/pixel2)/conj(cos(.1-pixel2))-conj(.01/pixel2)
  b2=(b8-b6-b7)/.55-.001/pixel2
  c=1.2*|pixel2/0.75|^5+conj(.1/pixel2+flip(.01/pixel2))
  b9=conj(.007/c-flip(.007/c))
  b5=flip(imag(.33+sin(|pixel2|)))*cabs(pixel2^4)-b2+.001*b3 \
     -.42*cos(b9)+.35
  zmod = .33*b7+b2
  IF (@p3==1)
    z = (b5^.745)
  ELSEIF (@p3==0)
    c = -(c/2), z = -(b5)
  ELSE
    IF (whitesq)
      z = (b5^.745)
    ELSE
      c = -(c/2), z = -(b5)
    ENDIF
  ENDIF
  c = conj(c+.1*b6) + c/4 + zmod
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = conj(c1+.1*b6) + c1/4 + zmod, z = 0
  ELSEIF (iter==l2)
    c = conj(c2+.1*b6) + c2/4 + zmod, z = 0
  ELSEIF (iter==l3)
    c = conj(c3+.1*b6) + c3/4 + zmod, z = 0
  ELSEIF (iter==l4)
    c = conj(c4+.1*b6) + c4/4 + zmod, z = 0
  ENDIF
  z = z^2 - c
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3319"
  periodicity = 0
  maxiter = 700
  magn = 1.9
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"

  b10=flip(pixel2^8)*2/cotanh(pixel2^4) \
      -conj(.01/pixel2-flip(.125/pixel2))
  c=pixel2^4-b6-b7
  b5=pixel2^4*b10^3*(c-.15)-(b8+b6+b7)/0.65-.002/pixel2
  IF (@p3==1)

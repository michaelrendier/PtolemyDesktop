Carr3322 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  d=sqrt(1/pixel2-conj(cos(1/pixel2)))
  b3=conj(.01/pixel2-flip(.001/pixel2))
  b5=conj(conj(pixel2/12)*sin(abs(pixel2/13))) \
     *conj(pixel2^8)-b3-conj(.1/pixel2)+.2
  c=b5/2.5-conj(.01/pixel2)+.25
  zmod = .09 + .055/pixel2 - flip(abs(d/60*pixel2))
  IF (@p3==1)
    z = (b5^.75)
  ELSEIF (@p3==0)
    c = -c, z = -(b5)
  ELSE
    IF (whitesq)
      z = (b5^.75)
    ELSE
      c = -c, z = -(b5)
    ENDIF
  ENDIF
  c = .875*c + zmod
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = .875*c1 + zmod, z = 0
  ELSEIF (iter==l2)
    c = .875*c2 + zmod, z = 0
  ELSEIF (iter==l3)
    c = .875*c3 + zmod, z = 0
  ELSEIF (iter==l4)
    c = .875*c4 + zmod, z = 0
  ENDIF
  z = |z/6| + z^2 + c
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3322"
  periodicity = 0
  maxiter = 700
  magn = .8
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam

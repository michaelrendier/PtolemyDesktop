Carr3351 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  c=2.64*conj(.1-pixel2)*conj(sinh(pixel2))*flip(tanh(pixel2))
  b5=pixel2^4-flip(.05/pixel2)-conj(.001/pixel2)-.001/c
  IF (@p3==1)
    z = (b5^.745)
  ELSEIF (@p3==0)
    c = -c, z = -(b5)
  ELSE
    IF (whitesq)
      z = (b5^.745)
    ELSE
      c = -c, z = -(b5)
    ENDIF
  ENDIF
  ctmp = (-.745,-.132)-flip(conj(c/10))
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    ctmp = (-.745,-.132)-flip(conj(c1/10)), z = 0
  ELSEIF (iter==l2)
    ctmp = (-.745,-.132)-flip(conj(c2/10)), z = 0
  ELSEIF (iter==l3)
    ctmp = (-.745,-.132)-flip(conj(c3/10)), z = 0
  ELSEIF (iter==l4)
    ctmp = (-.745,-.132)-flip(conj(c4/10)), z = 0
  ENDIF
  z = z^2 + ctmp
  iter=iter+1
bailout:
  real(z)<=bailout
default:
  title = "Carr 3351"
  periodicity = 0
  maxiter = 700
  magn = 1.2
  center = (0,0)
  method = multipass

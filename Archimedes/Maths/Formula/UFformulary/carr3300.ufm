Carr3367 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  b6=conj(.065/pixel2), b7=flip(.03/pixel2)
  b8=cabs(.002/pixel2+cabs(.002/pixel2))
  ba=8*conj(.1-pixel2)*conj(sinh(pixel2))*flip(tanh(pixel2))
  b5=conj(ba)*conj(abs(pixel2^2))*abs(pixel2+.125)^4 \
     -b7-b6-2*b8-.165
  c=flip(b5)^2-conj(.001/b5-flip(.001/b5)) \
     -conj(.1/pixel2-flip(.01/pixel2))
  IF (@p3==1)
    z = (b5^.5456)
  ELSEIF (@p3==0)
    c = -c, z = -(b5*.75)
  ELSE
    IF (whitesq)
      z = (b5^.5456)
    ELSE
      c = -c, z = -(b5*.75)
    ENDIF
  ENDIF
  c = c + cabs(c/10)
  c1=1.5*z^1.2,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = c1 + cabs(c1/10), z = 0
  ELSEIF (iter==l2)
    c = c2 + cabs(c2/10), z = 0
  ELSEIF (iter==l3)
    c = c3 + cabs(c3/10), z = 0
  ELSEIF (iter==l4)
    c = c4 + cabs(c4/10), z = 0
  ENDIF
  z = z^2 - |.15*z| + c
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3367"
  periodicity = 0
  maxiter = 700
  magn = 1.7
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"

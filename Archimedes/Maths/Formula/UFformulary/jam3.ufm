	visible =  @traptype == "parametric functions" && \
		((@parashape1 == "cycloid") || (@parashape1 == "cycloid variant"))
endparam
param cyccosfreq1
	caption = "Cycloid Cos Freq"
	default = 1.0
	hint = "If 'Trap Shape' is set to 'cycloid', then this setting \

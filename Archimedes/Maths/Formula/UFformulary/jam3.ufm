	ellipseheight1 = ellipseheight1
	ellipsewidth1 = ellipsewidth1
	hypotrochA1 = hypotrochA1
	hypotrochB1 = hypotrochB1
	hypotrochH1 = hypotrochH1
	cycloidamp1 = cycloidamp1
	cycloidconst1 = cycloidconst1
	cycloidlength1 = cycloidlength1

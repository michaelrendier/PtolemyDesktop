    if @blend
      ztemp1 = @weight1*ztemp1, ztemp2 = @weight2*ztemp2
      ztemp3 = @weight3*ztemp3
    endif ; @blend

    if @combo == 0
      z = ztemp1 + ztemp2 + ztemp3
    elseif @combo == 1
      z = ztemp1 * ztemp2 * ztemp3
    elseif @combo == 2
      z = (ztemp1 + ztemp2) * ztemp3
    elseif @combo == 3
      z = (ztemp1 * ztemp2) + ztemp3
    elseif @combo == 4
      z = ztemp1 + ztemp2 - ztemp3
    elseif @combo == 5
      z = ztemp1 - ztemp2 - ztemp3
    elseif @combo == 6
      z = (ztemp1 - ztemp2) * ztemp3
    elseif @combo == 7

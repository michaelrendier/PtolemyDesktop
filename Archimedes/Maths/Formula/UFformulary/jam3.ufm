	hint = "This value is the denominator parameter 'b3' in the series \
			representation of the hypergeometric function \
			2F3(a1, a2; b1, b2, b3; z)."
endparam
param terms
	caption = "Number of Terms"
	default = 6
	min = 2
	max = 24
	hint = "This value is the number of terms to compute in the series \
			representation of the hypergeometric function 2F3(a1, a2; b1, b2, b3; z). \
			The default is six terms; the range is 2-24."
endparam
param bail
    caption = "Bailout Value"
    default = 1e6
    hint = "Value needed to 'escape' to infinity."
endparam
param jconstant
	caption = "Seed/Perturbation"
	default = (0,0)

    visible = @formula2 == "3-term polynomial"
  endparam
  param coeff2c
    caption = "Coefficient GC"
    default = (1,0)
    hint = "If 'Formula G' is set to '3-term polynomial', this is the coefficient \
          of the 3rd term"
    visible = @formula2 == "3-term polynomial"
  endparam
  param exponent2c
    caption = "Exponent GC"
    default = (2,0)
    hint = "If 'Formula G' is set to '3-term polynomial', this is the exponent \
          of the 3rd term"
    visible = @formula2 == "3-term polynomial"
  endparam
  param coeff3a
    caption = "Coefficient HA"
    default = (1,0)
    hint = "If 'Formula H' is set to '3-term polynomial', this is the coefficient \
          of the 1st term"
    visible = @formula3 == "3-term polynomial"
  endparam
  param exponent3a
    caption = "Exponent HA"
    default = (6,0)
    hint = "If 'Formula H' is set to '3-term polynomial', this is the exponent \
          of the 1st term"
    visible = @formula3 == "3-term polynomial"
  endparam
  param coeff3b

default:
title = "PolySeries Exponential"
center = (0.001, 0.001)
magn = 0.25
method = multipass
periodicity = 0
maxiter = 500

param variant
	caption = "Series Variant"
	enum = "3" "4" "5" "6" "7" "8"
	default = 3
	hint = "This setting selects the number of terms in the series expansion \
		of the function to iterate."
endparam
param innerpixfunc

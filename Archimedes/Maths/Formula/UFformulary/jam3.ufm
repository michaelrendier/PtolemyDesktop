; function 3F3(a1, a2, a3; b1, b2, b3; z):
;
; 3F3(a1, a2, a3; b1, b2, b3; z) = Sum[ ( a1(n)*a2(n)*a3(n) / (b1(n)*b2(n)*b3(n)) ) *
; (z^n)/n! ],
; n = 0 -> infinity, or,
;
;                                  ___
; 3F3(a1, a2, a3; b1, b2, b3; z) = \     [ (a1)n * (a2)n * (a3)n / ((b1)n * (b2)n *
;                                  /__
;                                   n
;
;											(b3)n)  * z^n / n!],
;
; where the (ai)n and (bi)n are rising Pochhammer symbols.

global:
; Declare arrays for various coefficient components
float a1numer[@terms]
float a2numer[@terms]
float a3numer[@terms]
float b1denom[@terms]
float b2denom[@terms]
float b3denom[@terms]

          "1/log" "zlog" "sin(z)/z" "cos(z)/z" "sin*cos" "sin(z^2)" \
          "e^(-1/z)" "ze^z" "ze^-z" "ze^(1/z)" "ze^(-1/z)" "1/z^3" \
          "acot" "asec" "acsc" "tan(z)/z" "cot(z)/z" "sec(z)/z" \
          "csc(z)/z" "zsin" "zcos" "ztan" "zcot" "zsec" "zcsc" \

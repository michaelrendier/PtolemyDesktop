endwhile ; lindex

; Calculate the new value of #z as z(n+1) = 3F1(a1, a2, a3; b; z(n)) + jc
lindex = 0
#z = (0,0)
while lindex < @terms
	#z = #z + coefficient[lindex] * zpower[lindex]
	lindex = lindex + 1
endwhile ; lindex
#z = #z + jc


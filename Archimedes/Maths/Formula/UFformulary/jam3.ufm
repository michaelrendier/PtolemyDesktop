		#z = exp(-#z)
	elseif @cyclefunc == "exp(1/z)" ; recip exponential
		#z = exp(1/#z)
	elseif @cyclefunc == "exp(-1/z)" ; neg recip exponential
		#z = exp(-1/#z)
	elseif @cyclefunc == "exp(z^2)" ; z^2 exponential
		#z = exp(sqr(#z))
	elseif @cyclefunc == "exp(-z^2)" ; -z^2 exponential
		#z = exp(-sqr(#z))
	elseif @cyclefunc == "exp(1/z^2)" ; recip z^2 exponential

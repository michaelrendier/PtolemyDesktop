	elseif @cyclefunc == "sinh" ; hyperbolic sine
		#z = sinh(#z)
	elseif @cyclefunc == "asinh" ; inverse hyperbolic sine
		#z = asinh(#z)
	elseif @cyclefunc == "cosh" ; hyperbolic cosine

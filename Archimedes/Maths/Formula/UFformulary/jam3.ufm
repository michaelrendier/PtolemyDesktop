endif ; @traptype

	; shaping variables for 'parametric functions' traps
if @traptype == "parametric functions"
	hyponumer = @hyponumerator1
	hypodenom = @hypodenom1
	companC1 = @companC11
	companC2 = @companC21
	companfreq = @companfreq1

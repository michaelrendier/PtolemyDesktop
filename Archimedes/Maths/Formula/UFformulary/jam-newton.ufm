	z2 = sqr(z1)
	z3 = z2 * z1
	z4 = sqr(z2) * jc2
	z5 = z3 * z2
	z6 = z4 * z2
	z7 = z4 * z3 * jc3
elseif @eqselection == 21
	z1 = zworking + jc1
	z2 = sqr(z1)
	z3 = z2 * z1
	z4 = sqr(z2) + jc2
	z5 = z3 * z2
	z6 = z4 * z2
	z7 = z4 * z3 * jc3
elseif @eqselection == 22

; bailout value to some large number.
;

global:
complex jc1 = complex jc2 = complex jc3 = (0,0)

; fix the jc's for those that are multiplicative rather than additive
if !@explore
	if @eqselection == 7
		jc1 = (1,0)
	elseif @eqselection == 8
		jc2 = (1,0)
	elseif @eqselection == 9
		jc3 = (1,0)
	elseif @eqselection == 10
		jc1 = (1,0), jc2 = (1,0)
	elseif @eqselection == 11
		jc2 = (1,0), jc3 = (1,0)

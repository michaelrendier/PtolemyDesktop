	ztan = tan(zworking * jc1)
	zcos = cos(zfreq * jc2)
endif ; @eqselection

zsin = sin(zfreq)
ztan2 = sqr(ztan)
funcresult = ztan - @amplitude * zcos + @const
derivresult = 1 + ztan2 + @amplitude * zsin * @freq
deriv2result = 2 * ztan * (1 + ztan2) + @amplitude * freq2 * zcos
zquotient = funcresult * derivresult / (0.5 * funcresult * deriv2result - sqr(derivresult))
zworking = zworking + zquotient


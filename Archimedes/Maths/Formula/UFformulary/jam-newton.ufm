		Selection' options 2, 4, 5, 6, 9, 11, 12, 13, 15, 16, 18, 19, 20, \
		21, 22, 23, 24, and 25."
	visible = @explore
endparam
param bailout
	caption = "Bailout Value"
	default = 100.0
	min = 0.0
	hint = "Use a large bailout value."
endparam

	znminus = (zworking * jc1)^powerminus
	zn = zworking * znminus
	ztan = tan(zworking * jc3)
elseif @eqselection == 13
	znminus = (zworking * jc1)^powerminus
	zn = (zworking * jc2) * znminus
	ztan = tan(zworking * jc3)
elseif @eqselection == 14
	znminus = (zworking + jc1)^powerminus
	zn = (zworking * jc2) * znminus
	ztan = tan(zworking)
elseif @eqselection == 15
	znminus = (zworking)^powerminus
	zn = (zworking + jc2) * znminus
	ztan = tan(zworking * jc3)
elseif @eqselection == 16
	znminus = (zworking + jc1)^powerminus
	zn = zworking * znminus
	ztan = tan(zworking * jc3)

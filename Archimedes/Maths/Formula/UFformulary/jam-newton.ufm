	ztan = tan(zworking + jc1)
	zcos = cos(zfreq * jc2)
elseif @eqselection == 21
	zfreq = @freq*zworking * jc3
	ztan = tan(zworking + jc1)
	zcos = cos(zfreq + jc2)

	z6 = z4 * z2
	z7 = z4 * z3
elseif @eqselection == 2
	z1 = zworking
	z2 = sqr(z1)
	z3 = z2 * z1
	z4 = sqr(z2)
	z5 = z3 * z2
	z6 = z4 * z2
	z7 = z4 * z3 + jc3
elseif @eqselection == 3
	z1 = zworking + jc1
	z2 = sqr(z1)
	z3 = z2 * z1
	z4 = sqr(z2) + jc2
	z5 = z3 * z2
	z6 = z4 * z2
	z7 = z4 * z3
elseif @eqselection == 4
	z1 = zworking
	z2 = sqr(z1)
	z3 = z2 * z1
	z4 = sqr(z2) + jc2
	z5 = z3 * z2
	z6 = z4 * z2
	z7 = z4 * z3 + jc3
elseif @eqselection == 5
	z1 = zworking + jc1
	z2 = sqr(z1)
	z3 = z2 * z1
	z4 = sqr(z2)
	z5 = z3 * z2
	z6 = z4 * z2
	z7 = z4 * z3 + jc3

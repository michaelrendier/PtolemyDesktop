funcresult = z7 + @coeff6 * z6 + @coeff5 * z5 + @coeff4 * z4 + @coeff3 * z3 + \
	@coeff2 * z2 + @coeff1 * z1 + @constant
derivresult = 7 * z6 + 6 * @coeff6 * z5 + 5 * @coeff5 * z4 + 4 * @coeff4 * z3 + \
	3 * @coeff3 * z2 + 2 * @coeff2 * z1 + @coeff1
zquotient = funcresult/derivresult
zworking = zworking - zquotient


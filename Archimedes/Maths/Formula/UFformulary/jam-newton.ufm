		if parameter 'Explore Mode' is enabled.  'Seed 1' is used in 'Equation \
		Selection' options 0, 3, 5, 6, 7, 10, 12, 13, 14, 16, 17, 19, 20, \
		21, 22, 23, 24, and 25."
	visible = @explore
endparam
param jconstant2
	caption = "Seed 2"
	default = (0,0)
	hint = "This seed is used for some of the 'Equation Selection' options \
		if parameter 'Explore Mode' is enabled.  'Seed 2' is used in 'Equation \
		Selection' options 1, 3, 4, 6, 8, 10, 11, 13, 14, 15, 17, 18, 20, \
		21, 22, 23, 24, and 25."
	visible = @explore
endparam
param jconstant3
	caption = "Seed 3"
	default = (0,0)
	hint = "This seed is used for some of the 'Equation Selection' options \

	@coeff3 * z3 + @coeff2 * z2 + @coeff1 * z1 + @constant
derivresult = 8 * z7 + 7 * @coeff7 * z6 + 6 * @coeff6 * z5 + 5 * @coeff5 * z4 + 4 * @coeff4 * z3 + \
	3 * @coeff3 * z2 + 2 * @coeff2 * z1 + @coeff1
zquotient = funcresult/derivresult
zworking = zworking - zquotient

#z = 1/zquotient

bailout:
|#z| < @bailout

default:
title = "General Degree 8 Newton"
maxiter = 1000
periodicity = 0
method = multipass
center = (0,0)
magn = 1.0
angle = 0.0

param coeff7
	caption = "Coefficient 7"

	zcos = cos(zworking * jc2)
	ztan = tan(zworking + jc3)
endif ; @eqselection

zn = znminus * zworking
zsec = 1/zcos
funcresult = zn * zsec + @const
derivresult = @power * znminus * zsec + zn * zsec * ztan
zquotient = funcresult/derivresult

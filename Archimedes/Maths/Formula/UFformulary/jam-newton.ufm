	zcos = cos(zworking + jc3)
endif ; @eqselection

zn = znminus * zworking
zvcs = 1 + zcos
funcresult = zn * zvcs + @const
derivresult = @power * znminus * zvcs - zn * zsin
zquotient = funcresult/derivresult
zworking = zworking - zquotient

#z = 1/zquotient

bailout:
|#z| < @bailout

default:

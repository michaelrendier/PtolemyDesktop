	zexp = exp(zworking * jc1)
	ztan = tan(zworking * jc3)
	ztan2 = sqr(ztan * jc2)
elseif @eqselection == 14
	zexp = exp(zworking + jc1)
	ztan = tan(zworking)
	ztan2 = sqr(ztan * jc2)

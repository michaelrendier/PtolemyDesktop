	zsin = sin(zworking/2 * jc2)
	zcos = cos(zworking/2 + jc3)
endif ; @eqselection

zn = znminus * zworking
zcrd = 2 * zsin
funcresult = zn * zcrd + @const
derivresult = @power * znminus * zcrd + zn * zcos
zquotient = funcresult/derivresult
zworking = zworking - zquotient


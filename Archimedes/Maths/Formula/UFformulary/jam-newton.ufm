z2 = sqr(zworking)
funcresult = zexp - @amplitude * zcos + @const
derivresult = 2 * zworking * zexp + @amplitude * zsin * @freq
deriv2result = 2 * zexp + 4 * z2 * zexp + @amplitude * sqr(@freq) * zcos
zquotient = funcresult * derivresult / (0.5 * funcresult * deriv2result - sqr(derivresult))
zworking = zworking + zquotient


	zn = (zworking + jc2) * znminus
	ztan = tan(zworking * jc3)
elseif @eqselection == 25
	znminus = (zworking * jc1)^powerminus
	zn = (zworking * jc2) * znminus
	ztan = tan(zworking + jc3)
endif ; @eqselection

ztan2 = sqr(ztan)
funcresult = zn - ztan + @const
derivresult = @power * znminus - ztan2 - 1
zquotient = funcresult/derivresult
zworking = zworking - zquotient

#z = 1/zquotient

bailout:
|#z| < @bailout

default:
title = "z^n - tan(z) + c"
maxiter = 1000
periodicity = 0
method = multipass
center = (0,0)
magn = 1.0
angle = 0.0

param power
	caption = "Exponent"
	default = (2,0)
	hint = "This is the power to which #z will be raised."

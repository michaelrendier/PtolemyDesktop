    hint = "The size of the petals.  Suggested range (0.01 to 2.0)."
    visible = (@trapType == "Petals")
  endparam

  float param petalOffset
    caption = "Petal Offset"
    default = 0.1
    hint = "The offset of the petals.  Suggested range (0.0 to 0.2)."
    visible = (@trapType == "Petals")

    hint = "The angle multiplier for the harlequin trap."
    visible = (@trapType == "Harlequin")
  endparam
  
  complex param harlequinSeed
    caption = "Harlequin Seed"
    default = (0.15,1.26875)
    hint = "The seed for the harlequin trap."
    visible = (@trapType == "Harlequin")
  endparam
  
  func harlequinFunction
    caption = "Modifier Function"
    default = ident()

    hint = "The size of the balls.  Suggested range (0.01 to 2.0)."
    visible = (@trapType == "Flexballs")
  endparam
  
  float param flexballRadius
    caption = "Flexball Radius"
    default = 0.15
    hint = "The radius of the balls.  Suggested range (0.01 to 2.0)."
    visible = (@trapType == "Flexballs")

  param hypoFactor
    caption = "Fixed Radius"
    default = 0.1
    hint = "The fixed radius.  Suggested range (0.1 to 1.2)."
    visible = (@trapType == "Hypocycloid")
  endparam

;--------------------------------------------------------------------
; Petals Parameters
;--------------------------------------------------------------------
  
  float param petalSize
    caption = "Petal Size"

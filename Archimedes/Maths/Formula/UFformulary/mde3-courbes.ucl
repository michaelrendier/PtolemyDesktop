    enum    = "real" "imag" "real+imag" "real*imag" "real-imag" \
              "real/imag" "imag/real" "real^imag" "imag^real" \
              "1/real" "1/imag" "angle" "magnitude" "arith. mean" \
              "geom. mean"
    visible = (@txtr_gnarl > 0) 
  endparam  

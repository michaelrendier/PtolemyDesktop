    caption = "Barnsley Function"
    default = flip()
    visible = (@barn > 0)
  endfunc 
  heading
    caption = "Odd-even Toolbox"
  endheading  
  int param pairimp
    caption = "Odd-even type"
    enum = "none" "real" "imag" "real*imag" "real+imag" \
           "distance" "angle" "magnitude" "path" "trap real" \
           "trap imag" "trap r*i" "trap r+i" "trap distance" \
           "trap angle" "trap magnitude" "trap path" "iteration" \
           "trap iter"
  endparam

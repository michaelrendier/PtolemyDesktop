    enum = "ceil" "floor" "trunc" "round"
    visible = (@pairimp > 0)
  endparam
  func fnpi
    caption = "Odd-even Function"
    default = flip()
    visible = (@pairimp > 0)
  endfunc 
  heading
    caption = "Random Texture"
  endheading       

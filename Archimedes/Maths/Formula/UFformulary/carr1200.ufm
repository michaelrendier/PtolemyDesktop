comment {
  Carr1200.ufm Version 1.0
  Ultra Fractal conversions of Robert Carr's formulas Carr1200 - Carr1299
  by Erik Reckase/Lale Erguner, December 12, 2002

  History:  Version 1.1 - Fixes for UF3 compatibility by
                          Lale Erguner

            Version 1.0 - Initial Release
                          Original formulas pulled from _rc1.frm

                          Carr1200-1212,1215,1217,
                              1219-1221,1223-1227,
                              1235-1238,1240-1241,
                              1247-1250,1253-1255,
                              1258-1268,1270,1282,
                              1284-1285,1294       : cosxx fix
}

Carr1200 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=1/pixel, z2=z+flip(conj(cos(1/pixel))), z3=z+z2
  c=conj(cos(sqr(imag(1/pixel))))
loop:
  z=z*z2*z3+c
  z2=z2^z3
  z3=z3^z2
bailout:
  |real(z)| <=100
default:
  title = "Carr 1200"
  periodicity = 0
  maxiter = 500
  magn = .3
  center = (0,0)
  method = guessing
}

Carr1201 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=1/pixel, z2=z^1/z*z, z3=z^z2
  c=conj(cos(1/pixel))
loop:
  z=(z*z+c)*(z*z2*z3+c)
  z2=z-(z2^z3)
  z3=z-(z3^z2)
bailout:
  |real(z)| <=100
default:
  title = "Carr 1201"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing
}

Carr1202 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=conj(cos(1/pixel)), z2=z, z3=z^z2
  c=cabs(1/pixel)
loop:
  z=(z/c)/(1/z^c/c)
  z2=z-(z2^z3)
  z3=z-(z3^z2)
bailout:
  |real(z)| <=100
default:
  title = "Carr 1202"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing
}

Carr1203 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=conj(cos(1/pixel)), z2=abs(real(z)), z3=abs(imag(z))
  c=cotanh(1/pixel)
loop:
  z=(z*1/c)/(pixel-z*z)
  z2=(1-z2^z3)
  z3=(1-z3^z2)
bailout:
  |real(z)| <=100
default:
  title = "Carr 1203"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing
}

Carr1204 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=conj(cos(1/pixel)), z2=abs(real(z)), z3=abs(imag(z))
  c=cotanh(1/pixel)
loop:
  z=sqr(sqr(z*c))+c+1.224
  z2=conj(z2^z3)/c
  z3=conj(z3^z2)
bailout:
  |real(z)| <=100
default:
  title = "Carr 1204"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing
}

Carr1205 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=conj(cos(1/pixel)), z2=flip(real(z)), z3=conj(imag(z))
  c=cotanh(1/pixel)
loop:
  z=sqr(sqr(z*c))+c+1.224
  z2=conj(z2^z3)/c*c
  z3=conj(z3^z2)/c
bailout:
  |real(z)| <=100
default:
  title = "Carr 1205"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing
}

Carr1206 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=conj(cos(1/pixel)), z2=flip(real(z)), z3=conj(imag(z))
  c=cotanh(1/pixel), z4=conj(sqr(pixel))/conj(cos(sqr(pixel)))
loop:
  z=(z*1/c)+z4
  z2=conj(z2^z3)/z
  z3=conj(z3^z4)/z
  z4=(1/z*z+z4)/(pixel-c*c)
bailout:
  |real(z)| <=100
default:
  title = "Carr 1206"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing
}

Carr1207 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=conj(cos(sqr(1/pixel))), c=cotanh(1/pixel)
  z2=conj(sqr(pixel-1))/conj(cos(sqr(pixel)))
loop:
  z=z*1/c
  z2=z2*1/c
bailout:
  |real(z)| <=100
default:
  title = "Carr 1207"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing
}

Carr1208 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=conj(cos(sqr(1/pixel))), c=cotanh(1/pixel*0.91/pixel)
  z2=conj(sqr(pixel-1))/conj(cos(sqr(pixel+1)))
loop:
  z=z*1/c
  z2=z2*1/z
bailout:
  |real(z)| <=100
default:
  title = "Carr 1208"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing
}

Carr1209 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=conj(cos(sqr(1/pixel))), c=cotanh(1/pixel*0.91/pixel)
  z2=conj(sqr(pixel-1))/conj(cos(sqr(pixel+1)))
loop:
  z=(z-(z/c+z*1/c))/(pixel-c*c)
  z2=z*1/z2
bailout:
  |real(z)| <=100
default:
  title = "Carr 1209"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing
}

Carr1210 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=conj(cos(sqr(1/pixel))), c=cotanh(1/pixel*0.91/pixel)
  z2=conj(sqr(pixel-1))/conj(cos(sqr(pixel+1))), zp1=z+c+z2
loop:
  z=(zp1-(z/c+z*1/c))/(pixel-c*c)
  z=(z-(z/c+z*1/c))/(pixel-c*c)
  z2=z*1/z2
  |real(z)| <=100
default:
  title = "Carr 1210"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing
}

Carr1211 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=conj(cos(sqr(1/pixel))), c=cotanh(1/pixel*0.91/pixel)
  z2=conj(sqr(pixel-1))/conj(cos(sqr(pixel+1))), zp1=z+c+z2
loop:
  z=(zp1-(z*1/c))/(pixel-c*c)
  z=(z-(z*1/c))/(pixel-c*c)
  z2=z*1/zp1
bailout:
  |real(z)| <=100
default:
  title = "Carr 1211"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing
}

Carr1212 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=conj(cos(sqr(1/pixel))), c=cotanh(1/pixel*0.91/pixel)
  z1=conj(sqr(pixel-1))/conj(cos(sqr(pixel+1)))
  c1=conj(z+c+z1)
loop:
  z=z*1/c
  z=z1*1/c1
bailout:
  |real(z)| <=100
default:
  title = "Carr 1212"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing
}

Carr1213 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=conj(cos(sqr(1/pixel))), c=cotanh(1/pixel*0.91/pixel)
  z1=conj(sqr(pixel-1))/conj(cos(sqr(pixel+1)))
  c1=conj(z+c+z1)
loop:
  z=z*z+c
  z=z1*z1+c
  z=z*z+c1
bailout:
  |real(z)| <=100
default:
  title = "Carr 1213"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing
}

Carr1214 { ; Updated for UF2 by Erik Reckase, Feb 2000
           ; Newton variant
init:
  z=sinh(sqr(1/pixel)), z1=conj(sqr(pixel-1))/flip(sqr(pixel+1))
  c1=sqr(z+c+z1)
loop:
  z1=z*z*z
  c1=z1*z
  z=(3*c1+1)/(4*(z*z*z))
bailout:
  |real(z)| <=100
default:
  title = "Carr 1214"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing
}

Carr1215 { ; Updated for UF2 by Erik Reckase, Feb 2000
           ; Newton variant (sort of)
init:
  z=sinh(sqr(1/pixel)), c=conj(cos(1/pixel*0.91/pixel))
  z1=conj(sqr(pixel-1))/flip(sqr(pixel+1)), c1=sqr(z+c+z1)
loop:
  z1=conj(z*z*z)
  c1=z1*z
  z=(3*c1+1)/(4*(z*z*z))
bailout:
  |real(z)| <=100
default:
  title = "Carr 1215"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing
}

Carr1216 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=(real((1.099,0))+1)/pixel, c=(imag((2.0,0))-1)/pixel
loop:
  z=z/c
  z=z*z+c
bailout:
  |real(z)| <=100
default:
  title = "Carr 1216"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing
}

Carr1217 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=(real((1.099,0))+1)/pixel, c=(imag((2.0,0))-1)/pixel
loop:
  z=conj(cos(z/c))
  z=z*z+c
bailout:
  |real(z)| <=100
default:
  title = "Carr 1217"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing
}

Carr1218 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=(real((1.099,0))+1)/pixel, c=(imag((2.0,0))-1)/pixel
loop:
  z=(z/c)
  z=z-(z*z+c)
  z=z*1/c
bailout:
  |real(z)| <=100
default:
  title = "Carr 1218"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing
}

Carr1219 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=1/(pixel*pixel), c=imag(conj(cos(1/pixel)))
loop:
  z=z-(pixel-z*z)/(pixel-c*c)
  c=(1+flip(imag(c)))*real(c)/2+z
bailout:
  |real(z)| <=100 
default:
  title = "Carr 1219"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing
}

Carr1220 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=1/(pixel*pixel*pixel)
  c=pixel-sqr(imag(conj(cos(1/pixel))))
loop:
  z=c-z*pixel
bailout:
  |real(z)| <=100 
default:
  title = "Carr 1220"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing
}

Carr1221 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=pixel, c=pixel
  z1=conj(cos(pixel)), c1=conj(cos(pixel))
loop:
  z=z*z1+c
  z=z1*z+c1
bailout:
  |real(z)| <=100 
default:
  title = "Carr 1221"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing
}

Carr1222 { ; Updated for UF2 by Erik Reckase, Feb 2000
           ; Modified Rollo Silver formula
init:
  z=1/pixel, zz=z*z, zzz=zz*z
  z=(1.-(1.099,0))*zz+((1.099,0)*zzz)
loop:
  z=z+1/pixel
  zsq=z*1/z
  zcu=zsq*1/z
  z=(1.-(1.099,0))*zsq+(1.099,0)*1/zcu
bailout:
  |real(z)| <=100
default:
  title = "Carr 1222"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing
}

Carr1223 { ; Updated for UF2 by Erik Reckase, Feb 2000
           ; Modified Rollo Silver formula
init:
  z=(1/pixel*0.91/pixel), zz=z*z, zzz=zz*z
  z=(1.-(2.099,0))*zz+((2.099,0)*zzz)
loop:
  z=conj(cos(z+1/pixel))
  zsq=z*1/z
  zcu=zsq*1/z
  z=z-((1.-(2.099,0))*zsq+(2.099,0)*1/zcu)
bailout:
  |real(z)| <=100
default:
  title = "Carr 1223"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing
}

Carr1224 { ; Updated for UF2 by Erik Reckase, Feb 2000
           ; Modified Rollo Silver formula
init:
  z=(1/pixel*0.91/pixel), zz=z*z, zzz=zz*z
  z=(1.-(2.099,0))*zz+((2.099,0)*zzz)
loop:
  z=conj(cos(z+1/pixel))/(z*1/z)
  zsq=z*1/z
  zcu=zsq*1/z
  z=z-((1.-(2.099,0))*zsq+(2.099,0)*1/zcu)/(pixel-z*z)
bailout:
  |real(z)| <=100
default:
  title = "Carr 1224"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing
}

Carr1225 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=(1/pixel*0.91/pixel)
  c=(conj(cos(1.7/z)))/(1.099,0)
loop:
  z=cotanh(sqr(z*1/c))+(2.099,0)
bailout:
  |real(z)| <=100
default:
  title = "Carr 1225"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing
}

Carr1226 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=(1/pixel*0.91/pixel)
loop:
  z=z^(z-1)*conj(cos(z))+pixel
bailout:
  |real(z)| <=100
default:
  title = "Carr 1226"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing
}

Carr1227 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=(1/pixel*0.91/pixel), c=(1.7/z)/(1.099,0)
loop:
  z=c-(z^(z-1)*conj(cos(z))+pixel)
bailout:
  |real(z)| <=100
default:
  title = "Carr 1227"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing
}

Carr1228 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=(1/pixel*0.91/pixel), c=(1.7/z)/(1.099,0)
loop:
  z=z*1/c+((1.099,0)-1)*z-(1.099,0)
bailout:

Carr1247 (XAXIS_NOPARM) {; Updated for UF2 by Erik Reckase
                         ;   Feb 2000
                         ; FractalFenderC modified
                         ; Modified Lee Skinner frm.
                         ; Edited for Fractint v. 20 
                         ;   by George Martin, 10/98
init:
  z=(pixel)/(5.8,2.01)
  x=|real(z)|, c=conj(cos(sqr(1/pixel)))
loop:
  IF (x>1)
    z=conj(cos(z))+pixel
  ENDIF
  z=sqr(z*1/c)+pixel
  x=|real(z)|
bailout:
  x<=4 
default:
  title = "Carr 1247"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing
}


Carr1248 (XAXIS_NOPARM) {; Updated for UF2 by Erik Reckase
                         ;   Feb 2000
                         ; FractalFenderC modified
                         ; Modified Lee Skinner frm.
                         ; Edited for Fractint v. 20 
                         ;   by George Martin, 10/98
init:
  z=imag(sqr(pixel))
  x=|real(z)|, c=conj(cos(sqr(pixel)))
loop:
  IF (x>1)
    z=imag(conj(cos(z))+sqr(pixel))
  ENDIF
  z=sqr(z/c)+(pixel*pixel)
  x=|real(z)|
bailout:
  x<=100
default:
  title = "Carr 1248"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing
}


Carr1245 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=(sqr(1/pixel*0.91/pixel))
  c=sqr(z*(1.4/pixel))
loop:
  z=(pixel^pixel-z^z)/(pixel^pixel-c^c)
bailout:
  |real(z)| <=100
default:
  title = "Carr 1245"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing
}

Carr1246 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=cabs(1/pixel)
  c=abs(1/pixel)
loop:
  z=(exp(z)*1/c)/(pixel-c*c)
bailout:
  |real(z)| <=100
default:
  title = "Carr 1246"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing

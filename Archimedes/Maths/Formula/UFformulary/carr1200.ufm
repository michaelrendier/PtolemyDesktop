Carr1294 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=1/sqr(sqr(pixel)), c=sqr(sqr(conj(cos(pixel))))
loop:
  z=z-(z+c-conj(imag(z*1/c)))
bailout:
  |real(z)| <=100
default:
  title = "Carr 1294"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing
}

Carr1295 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=1/pixel, c=1/sqr(pixel)
loop:
  z=z-(z*pixel)-(c-(pixel/sqr(z*1/c)))
bailout:
  |real(z)| <=100
default:
  title = "Carr 1295"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing
}

Carr1296 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=1/pixel, c=(1/sqr(pixel))
loop:
  z=z-(z*pixel)-(c-(pixel/sqr(z*1/c)))
  z=z+(z*pixel)+(c+(pixel/sqr(z*1/c)))
bailout:
  |real(z)| <=100
default:
  title = "Carr 1296"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing
}

Carr1297 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=1/pixel, c=(1/sqr(pixel))
loop:
  z=(z-(z*pixel))/((1.099,0)-c*c)
bailout:
  |real(z)| <=100
default:
  title = "Carr 1297"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing
}

Carr1298 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=real(pixel)+flip(imag(pixel))
  c=real(pixel)+conj(imag(pixel))
loop:
  z=(z*z+pixel)/(pixel*pixel+z)
bailout:
  |real(z)| <=100
default:
  title = "Carr 1298"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing
}

Carr1299 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=real(pixel)+flip(imag(pixel))
  c=real(pixel)+conj(imag(pixel))
loop:
  z=((z*z+pixel*pixel)/(pixel*pixel+z))
bailout:
  |real(z)| <=100
default:
  title = "Carr 1299"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing
}

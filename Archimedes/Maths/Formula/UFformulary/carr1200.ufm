}

Carr1235 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=conj(cos(1/pixel*1.4/pixel)), c=flip(pixel)-1
loop:
  z=z-(sqr(pixel/z))/c-(sqr(pixel/c))
bailout:

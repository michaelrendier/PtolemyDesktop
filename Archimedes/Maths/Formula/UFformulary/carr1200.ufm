Carr1232 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=1/sqr(pixel/(1.099,0)), c=(1.4/z)/(2.099,0)
loop:
  z=z*1/c
  z=(z-(z*z+c))+((1.099,0)-1)*z-(1.099,0)
bailout:
  |real(z)| <=100
default:
  title = "Carr 1232"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
  method = guessing
}

Carr1233 { ; Updated for UF2 by Erik Reckase, Feb 2000
init:
  z=sqr(1/pixel*1.4/pixel)
loop:
  z=(1.099,0)*z*(1-flip(z)*flip(z))
bailout:

        endif
        bMergedCells = true
        if ((j < iColEnd) || (@enMrgRng6 == "Restore Rectangle"))
          rg_b_cell_exceptions[i,j,iMR]  = (@enMrgRng6 == "Remove Gridlines")
         endif
         if ((i < iRowEnd) || (@enMrgRng6 == "Restore Rectangle"))
           rg_b_cell_exceptions[i,j,iMD]  = (@enMrgRng6 == "Remove Gridlines")
          endif
        j = j+1

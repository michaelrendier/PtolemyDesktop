  ; ------ Merge Range #7 --------------------
  if (((@iSRM7 < @iERM7) || (@iSCM7 < @iECM7)))
    int iRowStart = @iSRM7
    int iColStart = @iSCM7
    int iRowEnd =   @iERM7
    int iColEnd =   @iECM7
    if (iRowStart < 1), iRowStart = 1, endif
    if (iColStart < 1), iColStart = 1, endif
    if (iRowEnd   > @iCRows), iRowEnd   = @iCRows, endif
    if (iColEnd   > @iCCols), iColEnd   = @iCCols, endif

    ; Set the range of cells to the same values
    i = iRowStart
    j = iColStart
    while(i <= iRowEnd)
      if ((@iSCM7 > 1) && (@enMrgRng7 == "Restore Rectangle"))
         rg_b_cell_exceptions[i,@iSCM7-1,iMR] = false
      endif
      while(j <= iColEnd)
        if ((@iSRM7 > 1) && (@enMrgRng7 == "Restore Rectangle"))

Carr1996 (XAXIS) {; Updated for UF2 by Erik Reckase, March 2000
                  ; Modified Sylvie Gallet frm. [101324,3444], 1996
init:
  z=c=pixel, c1=1.5*z, c2=2.25*z, c3=3.375*z, p0=.099/pixel
  l1=round(real(p1)), l2=round(imag(p1)), l3=round(real(p2))

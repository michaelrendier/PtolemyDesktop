          tempx = real(V8)
          tempy = tempx * tan( pixangle )
        else ; non-vertical line, so calculate slope & intercept
          slope = ( imag(V8) - imag(S7) )/temp
          intercept = imag(V8) - slope * real(V8)
          tempx = intercept / ( tan(pixangle) - slope )
          tempy = slope * tempx + intercept
        endif ; temp
      elseif ( pixangle <= s8angle ) ; pixel lies between V8 and S8
        temp = real(S8) - real(V8)
        if ( abs(temp) < verticallimit ) ; vertical line
          tempx = real(S8)
          tempy = tempx * tan( pixangle )
        else ; non-vertical line, so calculate slope & intercept
          slope = ( imag(S8) - imag(V8) )/temp
          intercept = imag(S8) - slope * real(S8)

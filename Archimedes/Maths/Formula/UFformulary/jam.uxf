jam-OTDistortion {

; jam 190222
; Distorts to complex plane according to the relationship of the current
; pixel to a selected geometric shape.

global:
	; Common constants
	float twopi = 2.0 * #pi
	float halfpi = #pi/2
	float degconversion = twopi/360

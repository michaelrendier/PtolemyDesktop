  param structure2
   caption = "Structure 2"
   default = 2
  endparam
func fn1
     caption = "Function 1"
     default = abs()
   endfunc
func fn2
     caption = "Function 2"
     default = sqr()
   endfunc
func fn3
     caption = "Function 3"
     default = sin()
   endfunc
func fn4
     caption = "Function 4"
     default = cos()

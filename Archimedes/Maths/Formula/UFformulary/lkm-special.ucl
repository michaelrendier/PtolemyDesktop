comment {

Special coloring schemes developed by Kerry Mitchell 

Note! These are experimental, beta tests, highly specialized, 
or worse. Not for the faint of heart or new to UF. In general, 
there's little to no support or documentation. In short, you're 
on your own.

Have fun! :-)
}
 
aug01-tangent-sine {
init:
  float dx=#pi*2/@nx
  float x=0.0
  float y=0.0
  float h=0.0
  float k=0.0
  float m=0.0
  float r=0.0
  float rmin=1e20
  int ix=0
loop:
final:
  ix=-1
  x=real(#z)
  y=imag(#z)
  while(ix<@nx)
    ix=ix+1
    h=ix*dx-#pi
    k=@a*sin(@b*h)
    m=@a*@b*cos(@b*h)
    if(@linetype==1)         ; normal
      r=abs(y-k+(x-h)/m)*abs(m)
    else                     ; tangent
      r=abs(y-k-m*(x-h))
    endif
    if(@updown==1)
      if((r<rmin)&&(y<k))
        rmin=r
      endif
    elseif(@updown==2)
      if((r<rmin)&&(y>=k))
        rmin=r
      endif
    else
      if(r<rmin)
        rmin=r
      endif
    endif
  endwhile
  #index=rmin
default:
  title="tangent sine"
  param a
    caption="amplitude"
    default=1.0
  endparam
  param b
    caption="frequency"
    default=1.0
  endparam
  param nx
    caption="# x points"
    default=100
  endparam
  param linetype
    caption="line type"
    default=0
    enum="tangent" "normal"
  endparam
  param updown
    caption="above/below"
    default=0
    enum="both" "below only" "above only"
  endparam
}

aug01-tangent-quadratic {
init:
  float dx=(@xmax-@xmin)/@nx
  float x=0.0
  float y=0.0
  float h=0.0
  float k=0.0
  float m=0.0
  float r=0.0
  float rmin=1e20
  int ix=0
loop:
final:
  ix=-1
  x=real(#z)
  y=imag(#z)
  while(ix<@nx)
    ix=ix+1
    h=ix*dx+@xmin
    k=(@a*h+@b)*h+@c
    m=2*@a*h+@b
    if(@linetype==1)         ; normal
      r=abs(y-k+(x-h)/m)*abs(m)
    else                     ; tangent
      r=abs(y-k-m*(x-h))
    endif
    if(@updown==1)
      if((r<rmin)&&(y<k))
        rmin=r
      endif
    elseif(@updown==2)
      if((r<rmin)&&(y>=k))
        rmin=r
      endif
    else
      if(r<rmin)
        rmin=r
      endif
    endif
  endwhile
  #index=rmin
default:
  title="tangent quadratic"
  param a
    caption="a"
    default=1.0
  endparam
  param b
    caption="b"
    default=0.0
  endparam
  param c
    caption="c"
    default=0.0
  endparam
  param xmin
    caption="minimum x"
    default=-1.0
  endparam
  param xmax
    caption="maximum x"
    default=1.0
  endparam
  param nx
    caption="# x points"
    default=100
  endparam
  param linetype
    caption="line type"
    default=0
    enum="tangent" "normal"
  endparam
  param updown
    caption="above/below"
    default=0
    enum="both" "below only" "above only"
  endparam
}

aug01-tangent-rose {
init:
  float dt=#pi*2/@nt
  float x=0.0
  float y=0.0
  float xp=0.0
  float yp=0.0
  float h=0.0
  float k=0.0
  float r=0.0
  float rmin=1e20
  float rz=0.0
  float rc=0.0
  float t=0.0
  int it=0
loop:
final:
  x=real(#z)
  y=imag(#z)
  rz=cabs(#z)
  it=-1
  while(it<@nt)
    it=it+1
    t=it*dt+dt/2
    rc=@a*cos(@b*t)
    h=rc*cos(t)
    k=rc*sin(t)
    xp=-@a*(cos(@b*t)*sin(t)+3*sin(@b*t)*cos(t))
    yp=@a*(cos(@b*t)*cos(t)-3*sin(@b*t)*sin(t))
    if(@linetype==1)         ; normal
      r=abs(yp*(y-k)+xp*(x-h))
    else                     ; tangent
      r=abs(xp*(y-k)-yp*(x-h))
    endif
    if(@updown==1)
      if((r<rmin)&&(rz<rc))
        rmin=r
      endif
    elseif(@updown==2)
      if((r<rmin)&&(rz>=rc))
        rmin=r
      endif
    else
      if(r<rmin)
        rmin=r
      endif
    endif
  endwhile
  #index=rmin
default:
  title="tangent rose"
  param a
    caption="amplitude"
    default=1.0
  endparam
  param b
    caption="frequency"
    default=3.0
  endparam
  param nt
    caption="# points"
    default=100
  endparam
  param linetype
    caption="line type"
    default=0
    enum="tangent" "normal"
  endparam
  param updown
    caption="above/below"
    default=0
    enum="both" "below only" "above only"
  endparam
}

aug01-hilbert-spline2 {
init:
  float x=0.0
  float y=0.0
  float r=0.0
  float rmin=1e20
  float u=0.0
  float v=0.0
  int iter=0
  int nlast=0
  int n=0
  int fac3=0
  int fac4=0
  int power4=0
  zh=(0,0)
;
; set up endpoints for the lines
;
  float h=0.5
  float ooh=1/h
  float ooomh=1/(1-h)
  float hoomh=h/(1-h)
  z0a=@enterexit
  z0b=flip(@enterexit)
  z1=@centerll
  z2=@centerul
  z3=@centerur
  z4=@centerlr
  z5=1+flip(@enterexit)
loop:
final:
  iter=0
  zh=#z*0.25+(0.5,0.5)
  while(iter<@niter)
    iter=iter+1
    x=real(zh)
    y=imag(zh)
;
; lower left sub-square:  shrink, flip horizontally, rotate by -90 degrees
;
    if((x<h)&&(y<h))
      nlast=3
      u=ooh*y
      v=ooh*x
;
; upper left sub-square:  just shrink
;
    elseif((x<h)&&(y>=h))
      nlast=2
      u=ooh*x
      v=ooomh*y-hoomh
;
; upper right sub-square:  shrink & flip horizontally
;
    elseif((x>=h)&&(y>=h))
      nlast=1
      u=ooomh-ooomh*x
      v=ooomh*y-hoomh
;
; lower right sub-square:  shrink, rotate by 90 degrees
;
    elseif((x>=h)&&(y<h))
      nlast=4
      u=ooh*y
      v=ooomh-ooomh*x
    else
      nlast=-1
      u=x
      v=y
    endif
    zh=u+flip(v)
    n=n*4+nlast-1
  endwhile
;
; determine how to start line 0-1
;
  z0=z0a
  c01=@control01
  iter=0
  fac3=2
  fac4=1
  power4=4
  while(iter<@niter)
    iter=iter+1
    if(iter%2==1)
      if(n%power4==fac3)
        z0=z0b
        c01=flip(@control01)
      endif
    else
      if(n%power4==fac3)
        z0=z0a
        c01=@control01
      endif
    endif
    power4=4*power4
    fac4=4*fac4
    fac3=fac3+2*fac4
  endwhile
;
; spline from enter to lower left sub-square
;
  zz0=z0
  zz2=z1
  c=c01
  if(c==(99,99))
    zz1=(zz0+zz2)/2
  else
    zz1=c
  endif
  c=zz0-zh
  b=2*(zz1-zz0)
  a=zz2-2*zz1+zz0
  if(cabs(a)==0.0)
    root1=-c/b
    root2=-c/b
  else
    d=sqrt(sqr(b)-4*a*c)
    root1=(-b+d)/2/a
    root2=(-b-d)/2/a
  endif
  x=real(root1)
  y=imag(root1)
  if(x<0.0)
    r=cabs(root1)
  elseif(x>1.0)
    r=cabs(root1-1)
  else
    r=abs(y)
  endif
  r=r/@scale01
  if(r<rmin)
    rmin=r
  endif
  x=real(root2)
  y=imag(root2)
  if(x<0.0)
    r=cabs(root2)
  elseif(x>1.0)
    r=cabs(root2-1)
  else
    r=abs(y)
  endif
  r=r/@scale01
  if(r<rmin)
    rmin=r
  endif
;
; spline from lower left to upper left sub-square
;
  zz0=z1
  zz2=z2
  c=@control12
  if(c==(99,99))
    zz1=(zz0+zz2)/2
  else
    zz1=c
  endif
  c=zz0-zh
  b=2*(zz1-zz0)
  a=zz2-2*zz1+zz0
  if(cabs(a)==0.0)
    root1=-c/b
    root2=-c/b
  else
    d=sqrt(sqr(b)-4*a*c)
    root1=(-b+d)/2/a
    root2=(-b-d)/2/a
  endif
  x=real(root1)
  y=imag(root1)
  if(x<0.0)
    r=cabs(root1)
  elseif(x>1.0)
    r=cabs(root1-1)
  else
    r=abs(y)
  endif
  r=r/@scale12
  if(r<rmin)
    rmin=r
  endif
  x=real(root2)
  y=imag(root2)
  if(x<0.0)
    r=cabs(root2)
  elseif(x>1.0)
    r=cabs(root2-1)
  else
    r=abs(y)
  endif
  r=r/@scale12
  if(r<rmin)
    rmin=r
  endif
;
; spline from upper left to upper right sub-square
;
  zz0=z2
  zz2=z3
  c=@control23
  if(c==(99,99))
    zz1=(zz0+zz2)/2
  else
    zz1=c
  endif
  c=zz0-zh
  b=2*(zz1-zz0)
  a=zz2-2*zz1+zz0
  if(cabs(a)==0.0)
    root1=-c/b
    root2=-c/b
  else
    d=sqrt(sqr(b)-4*a*c)
    root1=(-b+d)/2/a
    root2=(-b-d)/2/a
  endif
  x=real(root1)
  y=imag(root1)
  if(x<0.0)
    r=cabs(root1)
  elseif(x>1.0)
    r=cabs(root1-1)
  else
    r=abs(y)
  endif
  r=r/@scale23
  if(r<rmin)
    rmin=r
  endif
  x=real(root2)
  y=imag(root2)
  if(x<0.0)
    r=cabs(root2)
  elseif(x>1.0)
    r=cabs(root2-1)
  else
    r=abs(y)
  endif
  r=r/@scale23
  if(r<rmin)
    rmin=r
  endif
;
; spline from upper right to lower right sub-square
;
  zz0=z3
  zz2=z4
  c=@control34
  if(c==(99,99))
    zz1=(zz0+zz2)/2
  else
    zz1=c
  endif
  c=zz0-zh
  b=2*(zz1-zz0)
  a=zz2-2*zz1+zz0
  if(cabs(a)==0.0)
    root1=-c/b
    root2=-c/b
  else
    d=sqrt(sqr(b)-4*a*c)
    root1=(-b+d)/2/a
    root2=(-b-d)/2/a
  endif
  x=real(root1)
  y=imag(root1)
  if(x<0.0)
    r=cabs(root1)
  elseif(x>1.0)
    r=cabs(root1-1)
  else
    r=abs(y)
  endif
  r=r/@scale34
  if(r<rmin)
    rmin=r
  endif
  x=real(root2)
  y=imag(root2)
  if(x<0.0)
    r=cabs(root2)
  elseif(x>1.0)
    r=cabs(root2-1)
  else
    r=abs(y)
  endif
  r=r/@scale34
  if(r<rmin)
    rmin=r
  endif
;
; spline from lower right sub-square to exit
;
  zz0=z4
  zz2=z5
  c=@control45
  if(c==(99,99))
    zz1=(zz0+zz2)/2
  else
    zz1=c
  endif
  c=zz0-zh
  b=2*(zz1-zz0)
  a=zz2-2*zz1+zz0
  if(cabs(a)==0.0)
    root1=-c/b
    root2=-c/b
  else
    d=sqrt(sqr(b)-4*a*c)
    root1=(-b+d)/2/a
    root2=(-b-d)/2/a
  endif
  x=real(root1)
  y=imag(root1)
  if(x<0.0)
    r=cabs(root1)
  elseif(x>1.0)
    r=cabs(root1-1)
  else
    r=abs(y)
  endif
  r=r/@scale45
  if(r<rmin)
    rmin=r
  endif
  x=real(root2)
  y=imag(root2)
  if(x<0.0)
    r=cabs(root2)
  elseif(x>1.0)
    r=cabs(root2-1)
  else
    r=abs(y)
  endif
  r=r/@scale45
  if(r<rmin)
    rmin=r
  endif
;
  #index=rmin
default:
  title="Hilbert spline 2"
  param niter
    caption="iterations"
    default=0
    min=0
  endparam
  param centerll
    caption="lower left center"
    default=(0.25,0.25)
    hint="Center of the lower left sub-square. Make both coordinates \
    between 0 & 1; use (0.25,0.25) for standard Hilbert curve."
  endparam
  param centerul
    caption="upper left center"
    default=(0.25,0.75)
    hint="Center of the upper left sub-square. Make both coordinates \
    between 0 & 1; use (0.25,0.75) for standard Hilbert curve."
  endparam
  param centerur
    caption="upper right center"
    default=(0.75,0.75)
    hint="Center of the upper right sub-square. Make both coordinates \
    between 0 & 1; use (0.75,0.75) for standard Hilbert curve."
  endparam
  param centerlr
    caption="lower right center"
    default=(0.75,0.25)
    hint="Center of the lower right sub-square. Make both coordinates \
    between 0 & 1; use (0.75,0.25) for standard Hilbert curve."
  endparam
  param enterexit
    caption="enter/exit"
    default=0.25
    min=0.0
    max=1.0
    hint="Where the curve enters and exits the block of 4 sub-squares. \
      Between 0 & 1; use 0.25 for standard Hilbert curve."
  endparam
  param control01
    caption="0-1 control pt"
    default=(99,99)
    hint="Both between 0 & 1; use (99,99) for average of endpoints."
  endparam
  param control12
    caption="1-2 control pt"
    default=(99,99)
    hint="Both between 0 & 1; use (99,99) for average of endpoints."
  endparam
  param control23
    caption="2-3 control pt"
    default=(99,99)
    hint="Both between 0 & 1; use (99,99) for average of endpoints."
  endparam
  param control34
    caption="3-4 control pt"
    default=(99,99)
    hint="Both between 0 & 1; use (99,99) for average of endpoints."
  endparam
  param control45
    caption="4-5 control pt"
    default=(99,99)
    hint="Both between 0 & 1; use (99,99) for average of endpoints."
  endparam
  param scale01
    caption="0-1 scale"
    default=1.0
    hint="Decrease to make line thinner."
  endparam
  param scale12
    caption="1-2 scale"
    default=1.0
    hint="Decrease to make line thinner."
  endparam
  param scale23
    caption="2-3 scale"
    default=1.0
    hint="Decrease to make line thinner."
  endparam
  param scale34
    caption="3-4 scale"
    default=1.0
    hint="Decrease to make line thinner."
  endparam
  param scale45
    caption="4-5 scale"
    default=1.0
    hint="Decrease to make line thinner."
  endparam
}

aug01-metagon-semicircles2 {
init:
  float r=0.0
  float rmin=1e20
  float theta=0.0
  float dtheta=0.0
  t=(0,0)
  int iter=0
  int iside=0
  int kflip=-1
  z1=(0,0)
  z2=(0,0)
loop:
final:
  iside=2
  iter=0
  z1=@metagoncenter
  theta=@rotdeg*#pi/180-#pi
  z2=z1+@length*(cos(theta)+flip(sin(theta)))
  t=(#z-z1)/(z2-z1)
  kflip=-kflip
  if(imag(t*kflip)>=0.0)
    r=abs(cabs(t-0.5)-0.5)*cabs(z2-z1)
  else
    r=1e20
  endif
  if(r<rmin)
    rmin=r
  endif
  r=cabs(#z-z1)
  if(r<rmin)
    rmin=r
  endif
  z1=z2
  while(iside<@nside)
    iside=iside+1
    dtheta=#pi-(iside-2)*#pi/iside
    iter=1
    kflip=-1
    while(iter<iside)
      iter=iter+1
      theta=theta+dtheta
      z2=z1+@length*(cos(theta)+flip(sin(theta)))
      t=(#z-z1)/(z2-z1)
      kflip=-kflip
      if(imag(t*kflip)>=0.0)
        r=abs(cabs(t-0.5)-0.5)*cabs(z2-z1)
      else
        r=1e20
      endif
      if(r<rmin)
        rmin=r
      endif
      r=cabs(#z-z1)
      if(r<rmin)
        rmin=r
      endif
      z1=z2
    endwhile
  endwhile
  if(rmin<=@width)
    #index=rmin/@width
  else
    #solid=true
  endif
default:
  title="metagon semicircles 2"
  param nside
    caption="final # of sides"
    default=8
    min=3
  endparam
  param length
    caption="side length"
    default=1.0
  endparam
  param metagoncenter
    caption="center"
    default=(0,0)
  endparam
  param rotdeg
    caption="rotation, deg."
    default=0.0
  endparam
  param width
    caption="thickness"
    default=0.1
  endparam
}

aug01-hilbert-spline4 {
init:
  float x=0.0
  float y=0.0
  float r=0.0
  float rmin=1e20
  float u=0.0
  float v=0.0
  int iter=0
  int nlast=0
  int n=0
  int fac3=0
  int fac4=0
  int power4=0
  zh=(0,0)
;
; set up endpoints for the lines
;
  float h=0.5
  float ooh=1/h
  float ooomh=1/(1-h)
  float hoomh=h/(1-h)
  z0a=@enterexit
  z0b=flip(@enterexit)
  z1=@centerll
  z2=@centerul
  z3=@centerur
  z4=@centerlr
  z5=1+flip(@enterexit)
  control01=(0,0)
  control12=(0,0)
  control34=(0,0)
  control45=(0,0)
;
; control points
;
; line 3-4
;
  if(@type34==1)             ; normal to 2-3
    if(imag(z3)==imag(@control23))
      y=real(z3)-real(@control23)+imag(z3)
    else
      y=(real(z3)-real(@control23))/(imag(z3)-imag(@control23))\
        *(real(z3)-@xc34)+imag(z3)
    endif
  else                       ; tangent to 2-3
    if(real(z3)==real(@control23))
      y=2*imag(z3)-imag(@control23)
    else
      y=(imag(z3)-imag(@control23))/(real(z3)-real(@control23))\
        *(@xc34-real(z3))+imag(z3)
    endif
  endif
  control34=@xc34+flip(y)
;
; line 4-5
;
  if(@type45==1)             ; normal to 3-4
    if(real(z4)==real(control34))
      x=real(z4)-imag(z4)-imag(control34)
    else
      x=-(imag(z4)-imag(control34))/(real(z4)-real(control34))\
        *(@yc45-imag(z4))+real(z4)
    endif
  else                       ; tangent to 3-4
    if(imag(z4)==imag(control34))
      x=2*real(z4)-real(control34)
    else
      x=(real(z4)-real(control34))/(imag(z4)-imag(control34))\
        *(@yc45-imag(z4))+real(z4)
    endif
  endif
  control45=x+flip(@yc45)
;
; line 1-2
;
  if(@type12==1)             ; normal to 2-3
    if(imag(z2)==imag(@control23))
      y=imag(z2)-real(@control23)+real(z2)
    else
      y=(real(@control23)-real(z2))/(imag(@control23)-imag(z2))\
        *(real(z2)-@xc12)+imag(z2)
    endif
  else                       ; tangent to 2-3
    if(real(z2)==real(@control23))
      y=2*imag(z2)-imag(@control23)
    else
      y=-(imag(@control23)-imag(z2))/(real(@control23)-real(z2))\
        *(real(z2)-@xc12)+imag(z2)
    endif
  endif
  control12=@xc12+flip(y)
;
; line 0-1
;
  if(@type01==1)             ; normal to 1-2
    if(imag(z1)==imag(control12))
      y=imag(z1)-real(control12)+real(z1)
    else
      y=(real(control12)-real(z1))/(imag(control12)-imag(z1))\
        *(real(z1)-@xc01)+imag(z1)
    endif
  else                       ; tangent to 1-2
    if(real(z1)==real(control12))
      y=2*imag(z1)-imag(control12)
    else
      y=-(imag(control12)-imag(z1))/(real(control12)-real(z1))\
        *(real(z1)-@xc01)+imag(z1)
    endif
  endif
  control01=@xc01+flip(y)
loop:
final:
  iter=0
  zh=#z*0.25+(0.5,0.5)
  while(iter<@niter)
    iter=iter+1
    x=real(zh)
    y=imag(zh)
;
; lower left sub-square:  shrink, flip horizontally, rotate by -90 degrees
;
    if((x<h)&&(y<h))
      nlast=3
      u=ooh*y
      v=ooh*x
;
; upper left sub-square:  just shrink
;
    elseif((x<h)&&(y>=h))
      nlast=2
      u=ooh*x
      v=ooomh*y-hoomh
;
; upper right sub-square:  shrink & flip horizontally
;
    elseif((x>=h)&&(y>=h))
      nlast=1
      u=ooomh-ooomh*x
      v=ooomh*y-hoomh
;
; lower right sub-square:  shrink, rotate by 90 degrees
;
    elseif((x>=h)&&(y<h))
      nlast=4
      u=ooh*y
      v=ooomh-ooomh*x
    else
      nlast=-1
      u=x
      v=y
    endif
    zh=u+flip(v)
    n=n*4+nlast-1
  endwhile
;
; determine how to start line 0-1
;
  z0=z0a
  c01=control01
  iter=0
  fac3=2
  fac4=1
  power4=4
  while(iter<@niter)
    iter=iter+1
    if(iter%2==1)
      if(n%power4==fac3)
        z0=z0b
        c01=flip(control01)
      endif
    else
      if(n%power4==fac3)
        z0=z0a
        c01=control01
      endif
    endif
    power4=4*power4
    fac4=4*fac4
    fac3=fac3+2*fac4
  endwhile
;
; spline from enter to lower left sub-square
;
  zz0=z0
  zz2=z1
  zz1=c01
  c=zz0-zh
  b=2*(zz1-zz0)
  a=zz2-2*zz1+zz0
  if(cabs(a)==0.0)
    root1=-c/b
    root2=-c/b
  else
    d=sqrt(sqr(b)-4*a*c)
    root1=(-b+d)/2/a
    root2=(-b-d)/2/a
  endif
  x=real(root1)
  if((x>=0.0)&&(x<=1.0))
    ztemp=(a*x+b)*x+c
    r=cabs(ztemp)
    if(r<rmin)
      rmin=r
    endif
  endif
  x=real(root2)
  if((x>=0.0)&&(x<=1.0))
    ztemp=(a*x+b)*x+c
    r=cabs(ztemp)
    if(r<rmin)
      rmin=r
    endif
  endif
;
; spline from lower left to upper left sub-square
;
  zz0=z1
  zz2=z2
  zz1=control12
  c=zz0-zh
  b=2*(zz1-zz0)
  a=zz2-2*zz1+zz0
  if(cabs(a)==0.0)
    root1=-c/b
    root2=-c/b
  else
    d=sqrt(sqr(b)-4*a*c)
    root1=(-b+d)/2/a
    root2=(-b-d)/2/a
  endif
  x=real(root1)
  if((x>=0.0)&&(x<=1.0))
    ztemp=(a*x+b)*x+c
    r=cabs(ztemp)
    if(r<rmin)
      rmin=r
    endif
  endif
  x=real(root2)
  if((x>=0.0)&&(x<=1.0))
    ztemp=(a*x+b)*x+c
    r=cabs(ztemp)
    if(r<rmin)
      rmin=r
    endif
  endif
;
; spline from upper left to upper right sub-square
;
  zz0=z2
  zz2=z3
  zz1=@control23
  c=zz0-zh
  b=2*(zz1-zz0)
  a=zz2-2*zz1+zz0
  if(cabs(a)==0.0)
    root1=-c/b
    root2=-c/b
  else
    d=sqrt(sqr(b)-4*a*c)
    root1=(-b+d)/2/a
    root2=(-b-d)/2/a
  endif
  x=real(root1)
  if((x>=0.0)&&(x<=1.0))
    ztemp=(a*x+b)*x+c
    r=cabs(ztemp)
    if(r<rmin)
      rmin=r
    endif
  endif
  x=real(root2)
  if((x>=0.0)&&(x<=1.0))
    ztemp=(a*x+b)*x+c
    r=cabs(ztemp)
    if(r<rmin)
      rmin=r
    endif
  endif
;
; spline from upper right to lower right sub-square
;
  zz0=z3
  zz2=z4
  zz1=control34
  c=zz0-zh
  b=2*(zz1-zz0)
  a=zz2-2*zz1+zz0
  if(cabs(a)==0.0)
    root1=-c/b
    root2=-c/b
  else
    d=sqrt(sqr(b)-4*a*c)
    root1=(-b+d)/2/a
    root2=(-b-d)/2/a
  endif
  x=real(root1)
  if((x>=0.0)&&(x<=1.0))
    ztemp=(a*x+b)*x+c
    r=cabs(ztemp)
    if(r<rmin)
      rmin=r
    endif
  endif
  x=real(root2)
  if((x>=0.0)&&(x<=1.0))
    ztemp=(a*x+b)*x+c
    r=cabs(ztemp)
    if(r<rmin)
      rmin=r
    endif
  endif
;
; spline from lower right sub-square to exit
;
  zz0=z4
  zz2=z5
  zz1=control45
  c=zz0-zh
  b=2*(zz1-zz0)
  a=zz2-2*zz1+zz0
  if(cabs(a)==0.0)
    root1=-c/b
    root2=-c/b
  else
    d=sqrt(sqr(b)-4*a*c)
    root1=(-b+d)/2/a
    root2=(-b-d)/2/a
  endif
  x=real(root1)
  if((x>=0.0)&&(x<=1.0))
    ztemp=(a*x+b)*x+c
    r=cabs(ztemp)
    if(r<rmin)
      rmin=r
    endif
  endif
  x=real(root2)
  if((x>=0.0)&&(x<=1.0))
    ztemp=(a*x+b)*x+c
    r=cabs(ztemp)
    if(r<rmin)
      rmin=r
    endif
  endif
;
; balls at corners
;
  r=cabs(zh-z0)
  if(r<rmin)
    rmin=r
  endif
  r=cabs(zh-z1)
  if(r<rmin)
    rmin=r
  endif
  r=cabs(zh-z2)
  if(r<rmin)
    rmin=r
  endif
  r=cabs(zh-z3)
  if(r<rmin)
    rmin=r
  endif
  r=cabs(zh-z4)
  if(r<rmin)
    rmin=r
  endif
  r=cabs(zh-z5)
  if(r<rmin)
    rmin=r
  endif
;
; set color
;
  #index=rmin
default:
  title="Hilbert spline 4"
  param niter
    caption="iterations"
    default=0
    min=0
  endparam
  param centerll
    caption="lower left center"
    default=(0.25,0.25)
    hint="Center of the lower left sub-square. Make both coordinates \
    between 0 & 1; use (0.25,0.25) for standard Hilbert curve."
  endparam
  param centerul
    caption="upper left center"
    default=(0.25,0.75)
    hint="Center of the upper left sub-square. Make both coordinates \
    between 0 & 1; use (0.25,0.75) for standard Hilbert curve."
  endparam
  param centerur
    caption="upper right center"
    default=(0.75,0.75)
    hint="Center of the upper right sub-square. Make both coordinates \
    between 0 & 1; use (0.75,0.75) for standard Hilbert curve."
  endparam
  param centerlr
    caption="lower right center"
    default=(0.75,0.25)
    hint="Center of the lower right sub-square. Make both coordinates \
    between 0 & 1; use (0.75,0.25) for standard Hilbert curve."
  endparam
  param enterexit
    caption="enter/exit"
    default=0.25
    min=0.0
    max=1.0
    hint="Where the curve enters and exits the block of 4 sub-squares. \
      Between 0 & 1; use 0.25 for standard Hilbert curve."
  endparam
  param control23
    caption="2-3 control pt"
    default=(0.5,0.75)
    hint="Both between 0 & 1."
  endparam
  param type01
    caption="0-1 line type"
    default=0
    enum="tangent" "normal"
    hint="Relative to line 1-2."
  endparam
  param type12
    caption="1-2 line type"
    default=0
    enum="tangent" "normal"
    hint="Relative to line 2-3."
  endparam
  param type34
    caption="3-4 line type"
    default=0
    enum="tangent" "normal"
    hint="Relative to line 2-3."
  endparam
  param type45
    caption="4-5 line type"
    default=0
    enum="tangent" "normal"
    hint="Relative to line 3-4."
  endparam
  param xc01
    caption="xc01"
    default=0.25
  endparam
  param xc12
    caption="xc12"
    default=0.25
  endparam
  param xc34
    caption="xc34"
    default=0.75
  endparam
  param yc45
    caption="yc45"
    default=0.25
  endparam
}

aug01-tangent-tangent {
init:
  float dx=#pi*2/@nx
  float x=0.0
  float y=0.0
  float h=0.0
  float k=0.0
  float m=0.0
  float r=0.0
  float rmin=1e20
  int ix=0
loop:
final:
  ix=-1
  x=real(#z)
  y=imag(#z)
  while(ix<@nx)
    ix=ix+1
    h=ix*dx-#pi
    k=@a*tan(@b*h)
    m=@a*@b/sqr(cos(@b*h))
    if(@linetype==1)         ; normal
      r=abs(y-k+(x-h)/m)*abs(m)
    else                     ; tangent
      r=abs(y-k-m*(x-h))
    endif
    if(@updown==1)
      if((r<rmin)&&(y<k))
        rmin=r
      endif
    elseif(@updown==2)
      if((r<rmin)&&(y>=k))
        rmin=r
      endif
    else
      if(r<rmin)
        rmin=r
      endif
    endif
  endwhile
  #index=rmin
default:
  title="tangent tangent"
  param a
    caption="amplitude"
    default=1.0
  endparam
  param b
    caption="frequency"
    default=1.0
  endparam
  param nx
    caption="# x points"
    default=100
  endparam
  param linetype
    caption="line type"
    default=0
    enum="tangent" "normal"
  endparam
  param updown
    caption="above/below"
    default=0
    enum="both" "below only" "above only"
  endparam
}

aug01-square-trap {
init:
  float x=0.0
  float y=0.0
  float t=0.0
  float halfside=@side/2
  int iter=0
  int iterin=0
  z1=(0,0)
  zn=(0,0)
loop:
  iter=iter+1
  temp=#z-@squarecenter
  x=real(temp)
  y=imag(temp)
  if((abs(x)<=halfside)&&(abs(y)<=halfside))
    iterin=iterin+1
    zn=#z
    if(iterin==1)
      iterin=iter
      z1=zn
    endif
  endif
final:
  if(iterin==0)
    #solid=true
  else
    if(@colorby==1)          ; 1st magnitude
      #index=cabs(z1)
    elseif(@colorby==2)      ; 1st angle
      t=atan2(z1)/pi
      if(t<0.0)
        t=t+2.0
      endif
      #index=0.5*t
    elseif(@colorby==3)      ; 1st real
      temp=z1-@squarecenter
      #index=(real(temp)+halfside)/@side
    elseif(@colorby==4)      ; 1st imag
      temp=z1-@squarecenter
      #index=(imag(temp)+halfside)/@side
    elseif(@colorby==5)      ; last magnitude
      #index=cabs(zn)
    elseif(@colorby==6)      ; last angle
      t=atan2(zn)/pi
      if(t<0.0)
        t=t+2.0
      endif
      #index=0.5*t
    elseif(@colorby==7)      ; last real
      temp=zn-@squarecenter
      #index=(real(temp)+halfside)/@side
    elseif(@colorby==8)      ; last imag
      temp=zn-@squarecenter
      #index=(imag(temp)+halfside)/@side
    else                     ; howmany
      #index=iterin/10
    endif
  endif
default:
  title="square trap"
  param squarecenter
    caption="center"
    default=(0.0,0.0)
  endparam
  param side
    caption="side"
    default=1.0
    min=0.0
  endparam
  param colorby
    caption="color by"
    default=0
    enum="how many" "1st mag" "1st angle" "1st real" "1st imag"\
      "last mag" "last angle" "last real" "last imag"
  endparam
}

aug01-square-trap2 {
init:
  float x=0.0
  float y=0.0
  float t=0.0
  float halfside=@side/2
  int iter=0
  int iterin=0
  z1=(0,0)
  zn=(0,0)
  float rangelo=(@iblock-1)/@nblock
  float rangehi=@iblock/@nblock
loop:
  iter=iter+1
  temp=#z-@squarecenter
  x=real(temp)
  y=imag(temp)
  if((x>=-halfside)&&(x<halfside)&&\
    (y>=-halfside)&&(y<halfside))
    iterin=iterin+1
    zn=#z
    if(iterin==1)
      iterin=iter
      z1=zn
    endif
  endif
final:
  if(iterin==0)
    #solid=true
  else
    if(@colorby==1)          ; 1st magnitude
      #index=cabs(z1)
    elseif(@colorby==2)      ; 1st angle
      t=atan2(z1)/pi
      if(t<0.0)
        t=t+2.0
      endif
      #index=0.5*t
    elseif(@colorby==3)      ; 1st real
      temp=z1-@squarecenter
      #index=(real(temp)+halfside)/@side
    elseif(@colorby==4)      ; 1st imag
      temp=z1-@squarecenter
      #index=(imag(temp)+halfside)/@side
    elseif(@colorby==5)      ; last magnitude
      #index=cabs(zn)
    elseif(@colorby==6)      ; last angle
      t=atan2(zn)/pi
      if(t<0.0)
        t=t+2.0
      endif
      #index=0.5*t
    elseif(@colorby==7)      ; last real
      temp=zn-@squarecenter
      x=(real(temp)+halfside)/@side
      if((x>=rangelo)&&(x<rangehi))
        #index=(x-rangelo)*@nblock
      else
        #solid=true
      endif
    elseif(@colorby==8)      ; last imag
      temp=zn-@squarecenter
      y=(imag(temp)+halfside)/@side
      if((y>=rangelo)&&(y<rangehi))
        #index=(y-rangelo)*@nblock
      else
        #solid=true
      endif
    else                     ; howmany
      #index=iterin/10
    endif
  endif
default:
  title="square-trap2"
  param squarecenter
    caption="center"
    default=(0.0,0.0)
  endparam
  param side
    caption="side"
    default=1.0
    min=0.0
  endparam
  param colorby
    caption="color by"
    default=0
    enum="how many" "1st mag" "1st angle" "1st real" "1st imag"\
      "last mag" "last angle" "last real" "last imag"
  endparam
  param nblock
    caption="# of blocks"
    default=1
    min=1
    hint="integer number of color blocks"
  endparam
  param iblock
    caption="which block"
    default=1
    min=1
    hint="min = 1, max = # of blocks"
  endparam
}

nov01-billiards {
;
; Simulates the bouncing of a perfect cue ball on a perfect
; billiard table.  The ball rolls at a constant speed without
; friction and in a straight line, only changing direction when
; hitting a rail.  The table is rectangular with rails parallel
; to the axes and pockets only at the corners.  The path stops when
; the ball hits a corner pocket.
;
init:
  float x=real(@xy0)
  float y=imag(@xy0)
  float u=real(@uv0)/cabs(@uv0)
  float v=imag(@uv0)/cabs(@uv0)
  float t=atan2(u+flip(v))
  float xmax=@tablelength
  float ymax=@tablewidth
  float x1=0.0
  float y1=0.0
  float t1=0.0
  float x2=xmax
  float y2=0.0
  float t2=0.0
  float x3=xmax
  float y3=ymax
  float t3=0.0
  float x4=0.0
  float y4=ymax
  float t4=0.0
  float dx=0.0
  float dy=0.0
  float r=0.0
  float rmin=1e20
  float xl=0.0
  float yl=0.0
  float xnew=0.0
  float ynew=0.0
  tl=(0,0)
  z1=(0,0)
  z2=(0,0)
  int iter=0
  float x=real(#pixel)
  float y=imag(#pixel)
  bool cornerflag=false
loop:
final:
  if((x<0)||(x>xmax)||(y<0)||(y>ymax))
    #solid=true
  else
    x=real(@xy0)
    y=imag(@xy0)
    iter=0
    while((iter<@niter)&&(cornerflag==false))
      iter=iter+1
;
; find angles to corners
;
  dx=x1-x
  dy=y1-y
  t1=atan2(dx+flip(dy))
  dx=x2-x
  dy=y2-y
  t2=atan2(dx+flip(dy))
  dx=x3-x
  dy=y3-y
  t3=atan2(dx+flip(dy))
  dx=x4-x
  dy=y4-y
  t4=atan2(dx+flip(dy))
;
; determine which rail to use
;
  if((t>t1)&&(t<=t2))        ; bottom rail
    r=x-y*u/v
    xnew=r
    ynew=0
    v=-v
    t=atan2(u+flip(v))
  elseif((t>t2)&&(t<=t3))    ; right rail
    r=y+v/u*(xmax-x)
    xnew=xmax
    ynew=r
    u=-u
    t=atan2(u+flip(v))
  elseif((t>t3)&&(t<=t4))    ; top rail
    r=x+u/v*(ymax-y)
    xnew=r
    ynew=ymax
    v=-v
    t=atan2(u+flip(v))
  else                       ; left rail
    r=y-x*v/u
    xnew=0
    ynew=r
    u=-u
    t=atan2(u+flip(v))
  endif
;
; see if ball landed in a corner pocket
;
  r=sqr(xnew-x1)+sqr(ynew-y1)
  if(r<1e-12)
    cornerflag=true
  endif
  r=sqr(xnew-x2)+sqr(ynew-y2)
  if(r<1e-12)
    cornerflag=true
  endif
  r=sqr(xnew-x3)+sqr(ynew-y3)
  if(r<1e-12)
    cornerflag=true
  endif
  r=sqr(xnew-x4)+sqr(ynew-y4)
  if(r<1e-12)
    cornerflag=true
  endif
;
; draw lines
;
  z1=x+flip(y)
  z2=xnew+flip(ynew)
  tl=(#pixel-z1)/(z2-z1)
  xl=real(tl)
  yl=sqr(imag(tl))
  if(xl<0.0)
    r=sqr(xl)+yl
  elseif(xl>1.0)
    r=sqr(xl-1.0)+yl
  else
    r=yl
  endif
  r=sqrt(r)*cabs(z2-z1)
  if(r<rmin)
    rmin=r
  endif
  x=xnew
  y=ynew
;
  endwhile
  endif
  #index=rmin
default:
  title="billiards"
  param niter
    caption="# iterations"
    default=100
  endparam
  param xy0
    caption="initial position"
    default=(0,0)
    hint="real part = x, imag = y"
  endparam
  param uv0
    caption="initial velocity"
    default=(1,1)
    hint="real part = u, imag = v; normalized to mag = 1"
  endparam
  param bailout
    caption="bailout"
    default=1000.0
  endparam
  param tablelength
    caption="table length"
    default=2.0
    hint="horizontal dimension"
  endparam
  param tablewidth
    caption="table width"
    default=1.0
    hint="vertical dimension"
  endparam
}

dec01-sinusoid {
;
; Draws sine and cosine functions
; y = ac cos(bc x) + as sin(bs x)
; Use with "pixel" formula
;
init:
  float r=0.0
  float rmax=0.0
  float xp=real(#pixel)
  float yp=imag(#pixel)
  float dydx=0.0
  float ys=0.0
  float argc=0.0
  float args=0.0
loop:
final:
  argc=@bc*xp+@cc
  args=@bs*xp+@cs
  ys=@ac*cos(argc)+@as*sin(args)
  r=ys-yp
  if(@weight==true)
    dydx=@as*@bs*cos(args)-@ac*@bc*sin(argc)
    dydx=sqrt(1+sqr(dydx))
    rmax=@tmax*dydx
  else
    rmax=@tmax
  endif
  if((r>rmax)||(r<-rmax))
    #solid=true
  else
    #index=(r+rmax)/(2*rmax)
  endif
default:
  title="Sinusoid"
  param ac
    caption="cosine amplitude"
    default=1.0
    hint="amplitude of cosine function"
  endparam
  param bc
    caption="cosine frequency"
    default=1.0
    hint="frequency of cosine function"
  endparam
  param cc
    caption="cosine phase"
    default=0.0
    hint="phase of cosine function, radians"
  endparam
  param as
    caption="sine amplitude"
    default=0.0
    hint="amplitude of sine function"
  endparam
  param bs
    caption="sine frequency"
    default=0.0
    hint="frequency of sine function"
  endparam
  param cs
    caption="sine phase"
    default=0.0
    hint="phase of sine function, radians"
  endparam
  param weight
    caption="slope weighted?"
    default=true
  endparam
  param tmax
    caption="maximum thickness?"
    default=0.1
    min=0.0
  endparam
}

nov02-billiards3 {
;
; Simulates the bouncing of a perfect cue ball on a perfect
; billiard table.  The ball rolls at a constant speed without
; friction and in a straight line, only changing direction when
; hitting a rail.
;
; The table is triangular with arbitrarily placed corners and
; pockets only at the corners.  The path stops when the ball 
; hits a corner pocket.
;
$define debug
global:
  float x=0.0
  float y=0.0
  float u=0.0
  float v=0.0
  float t=0.0
  float t1=0.0
  float t2=0.0
  float t3=0.0
  float r=0.0
  float xnew=0.0
  float ynew=0.0
  float eps=1e-6
  int iter=0
  bool cornerflag=false
  float t12=atan2(@corner2-@corner1)
  float ct12=cos(t12)
  float st12=sin(t12)
  float t23=atan2(@corner3-@corner2)
  float ct23=cos(t23)
  float st23=sin(t23)
  float t31=atan2(@corner1-@corner3)
  float ct31=cos(t31)
  float st31=sin(t31)
  float capa1=0.0
  float capb1=0.0
  float capc1=0.0
  float capa2=0.0
  float capb2=0.0
  float capc2=0.0
  float twopi=2*#pi
  float tenpi=10*#pi
  zb=@xy0
  complex zball[@niter]
  zball[0]=zb
  x=real(zb)
  y=imag(zb)
  if(@uvchoice==1)           ; velocity angle
    u=cos(@vangle/180*#pi)
    v=sin(@vangle/180*#pi)
  else                       ; explicit components
    u=real(@uv0)/cabs(@uv0)
    v=imag(@uv0)/cabs(@uv0)
  endif
  t=atan2(u+flip(v))
  iter=0
  while((iter<@niter-1)&&(cornerflag==false))
    iter=iter+1
;
; find angles to corners
;
    t1=atan2(@corner1-zb)
    t2=atan2(@corner2-zb)
    t3=atan2(@corner3-zb)
;
; determine which rail to use
;
    if((t>t1)&&(t<=t2))      ; rail from 1 to 2
      capa1=sin(t)
      capb1=-cos(t)
      capc1=sin(t)*x-cos(t)*y
      capa2=st12
      capb2=-ct12
      capc2=st12*real(@corner1)-ct12*imag(@corner1)
      t1=capa1*capb2-capa2*capb1
      xnew=(capb2*capc1-capb1*capc2)/t1
      ynew=(capa1*capc2-capa2*capc1)/t1
      t=(2*t12-t+tenpi)%twopi
      if(t>#pi)
        t=t-twopi
      endif
    elseif((t>t2)&&(t<=t3))  ; rail from 2 to 3
      capa1=sin(t)
      capb1=-cos(t)
      capc1=sin(t)*x-cos(t)*y
      capa2=st23
      capb2=-ct23
      capc2=st23*real(@corner2)-ct23*imag(@corner2)
      t2=capa1*capb2-capa2*capb1
      xnew=(capb2*capc1-capb1*capc2)/t2
      ynew=(capa1*capc2-capa2*capc1)/t2
      t=(2*t23-t+tenpi)%twopi
      if(t>#pi)
        t=t-twopi
      endif
    else                     ; rail from 3 to 1
      capa1=sin(t)
      capb1=-cos(t)
      capc1=sin(t)*x-cos(t)*y
      capa2=st31
      capb2=-ct31
      capc2=st31*real(@corner3)-ct31*imag(@corner3)
      t3=capa1*capb2-capa2*capb1
      xnew=(capb2*capc1-capb1*capc2)/t3
      ynew=(capa1*capc2-capa2*capc1)/t3
      t=(2*t31-t+tenpi)%twopi
      if(t>#pi)
        t=t-twopi
      endif
    endif
    x=xnew
    y=ynew
    zb=x+flip(y)
    zball[iter]=zb
;
; see if ball landed in a corner pocket
;
    r=cabs(@corner1-zb)
    if(r<eps)
      cornerflag=true
    endif
    r=cabs(@corner2-zb)
    if(r<eps)
      cornerflag=true
    endif
    r=cabs(@corner3-zb)
    if(r<eps)
      cornerflag=true
    endif
  endwhile
init:
  int liter=0
  float xl=0.0
  float yl=0.0
  float rl=0.0
  float rmin=1e20
  tl=(0,0)
  z1=(0,0)
  z2=(0,0)
loop:
final:
;
; draw lines
;
  liter=0
  z1=zball[liter]
  while(liter<iter)
    liter=liter+1
    z2=zball[liter]
    tl=(#pixel-z1)/(z2-z1)
    xl=real(tl)
    yl=sqr(imag(tl))
    if(xl<0.0)
      rl=sqr(xl)+yl
    elseif(xl>1.0)
      rl=sqr(xl-1.0)+yl
    else
      rl=yl
    endif
    rl=sqrt(rl)*cabs(z2-z1)
    if(rl<rmin)
      rmin=rl
    endif
    z1=z2
  endwhile
;
  #index=rmin
default:
  title="billiards 3"
  int param niter
    caption="# iterations"
    default=100
  endparam
  complex param xy0
    caption="initial ball position"
    default=(0,0)
    hint="real part = x, imag = y"
  endparam
  param uvchoice
    caption="specify velocity"
    default=1
    enum="components" "angle"
  endparam
  complex param uv0
    caption="velocity components"
    default=(1,1)
    hint="real part = horizontal, imag = vertical; \
      normalized to mag = 1"
    visible=@uvchoice==0
  endparam
  float param vangle
    caption="velocity angle"
    default=45.0
    hint="In degrees, +ccw"
    visible=@uvchoice==1
  endparam
  complex param corner1
    caption="corner 1"
    default=(-1,-1.73205080756887729352744634150587)
    hint="Location of corner 1 (closest to -180 degrees)"
  endparam
  complex param corner2
    caption="corner 2"
    default=(2,0)
    hint="Location of corner 2"
  endparam
  complex param corner3
    caption="corner 3"
    default=(-1,1.73205080756887729352744634150587)
    hint="Location of corner 3 (closest to 180 degrees)"
  endparam
}

may03-signature {
$define debug
global:
  bool donesort=false
  complex ctemp=(0,0)
  complex zl[10000]
  float element[10000]
  float irrat=0.0
  float temp=0.0
  int i=0
  int j=0
  int k=0
  int kmax=0
;
; determine seed
;
  if(@seedtype==1)           ; sqrt(2)
    irrat=sqrt(2)
  elseif(@seedtype==2)       ; phi
    irrat=(1+sqrt(5))/2
  elseif(@seedtype==3)       ; e
    irrat=exp(1)
  elseif(@seedtype==4)       ; pi
    irrat=#pi
  else                       ; manual
    irrat=@seed
  endif
  irrat=real(@fn1(irrat))
  if(@negate==true)
    irrat=-irrat
  endif
;
; initial fill of element vector
;
  j=@jmin-1
  k=-1
  while(j<@jmax)
    j=j+1
    i=@imin-1
    while(i<@imax)
      i=i+1
      k=k+1
      element[k]=i+j*irrat
      zl[k]=i+flip(j)
    endwhile
  endwhile
  kmax=k
;
; sort element vector
;
  donesort=false
  while(donesort==false)
    nflip=0
    k=0
    while(k<kmax)
      k=k+1
      if(element[k]<element[k-1])
        nflip=nflip+1
        temp=element[k-1]
        element[k-1]=element[k]
        element[k]=temp
        ctemp=zl[k-1]
        zl[k-1]=zl[k]
        zl[k]=ctemp
      endif
    endwhile
    if(nflip==0)
      donesort=true
    endif
  endwhile
init:
  complex t=(0,0)
  complex z1=(0,0)
  complex z2=(0,0)
  float x=0.0
  float y=0.0
  float r=0.0
  float rmin=1e20
  int il=0
loop:
final:
;
; draw lines between subsequent i,j pairs
;
  il=0
  while(il<kmax)
    il=il+1
    z1=zl[il-1]
    z2=zl[il]
    t=(#pixel-z1)/(z2-z1)
    x=real(t)
    y=imag(t)
    if(x<0.0)
      r=sqr(x)+sqr(y)
    elseif(x>1.0)
      r=sqr(x-1.0)+sqr(y)
    else
      r=sqr(y)
    endif
    r=sqrt(r)*cabs(z2-z1)
    if(r<rmin)
      rmin=r
    endif
  endwhile
  #index=rmin
default:
  title="Signature"
;
; seed parameters
;
  heading
    caption="Seed parameters"
  endheading
  param seedtype
    caption="seed type"
    default=2
    enum="manual" "sqrt(2) ~ 1.414"\
      "phi ~ 1.618" "e ~ 2.718" "pi ~ 3.1416"
  endparam
  float param seed
    caption="manual seed"
    default=1.73205080756887729352744634150587
    visible=@seedtype==0
  endparam
  func fn1
    caption="modifying function"
    default=ident()
  endfunc
  bool param negate
    caption="negate seed"
    default=false
  endparam
;
; grid parameters
;
  heading
    caption="Grid parameters"
  endheading
  int param imin
    caption="i min"
    default=1
  endparam
  int param imax
    caption="i max"
    default=3
  endparam
  int param jmin
    caption="j min"
    default=1
  endparam
  int param jmax
    caption="j max"
    default=3
  endparam
}

fresnel-integral { ; Kerry Mitchell 21may2011
;
; Computes approximations to the Fresnel integrals and uses them
; to draw curves in the plane. Uses rectangular, trapezoidal, and
; Simpson's rules to approximate the integrals.
;
; See http://mathworld.wolfram.com/FresnelIntegrals.html, equations
; 3 and 4 for the mathematically accurate equations.
;
$define debug
global:
  complex tot=(0,0)
  tot=@rectweight+@trapweight+@simpweight
  if(tot==(0,0))
    print("Weight total must not be 0!")
  endif
  complex weightr=@rectweight/tot
  complex weightt=@trapweight/tot
  complex weights=@simpweight/tot
  complex zf[round(@nbase*@nbase+1)]
  int npoint=round(@nbase*@nbase)
  float thetamax=@mult*@nbase
  float dtheta=thetamax/npoint
  float c0=0
  float c1=0
  float cmid=0
  float ct=0
  float pio2=#pi/2
  float r=0
  float rmax=0
  float s0=0
  float s1=0
  float smid=0
  float st=0
  float t=0
  float cosfreq=@cfreq*pio2
  float sinfreq=@sfreq*pio2
  int ipoint=0
;
  ipoint=0
  c1=1
  s1=0
  zf[0]=0
  while(ipoint<npoint)
    ipoint=ipoint+1
    t=dtheta*(ipoint-0.5)
    ct=cosfreq*t^@cpower
    st=sinfreq*t^@spower
    cmid=cos(ct)
    smid=sin(st)
    c0=c1
    s0=s1
    t=dtheta*ipoint
    ct=cosfreq*t^@cpower
    st=sinfreq*t^@spower
    c1=cos(ct)
    s1=sin(st)
    zr=dtheta*(cmid+flip(smid))
    zt=dtheta/2*(c0+c1+flip(s0+s1))
    zs=dtheta/6*(c0+4*cmid+c1+flip(s0+4*smid+s1))
    zf[ipoint]=zf[ipoint-1]+weightr*zr+weightt*zt+weights*zs
    tot=tot+zf[ipoint]
  endwhile
;
; center & scale
;
  if(@centerscale==true)
    tot=tot/npoint
    ipoint=-1
    while(ipoint<npoint)
      ipoint=ipoint+1
      zf[ipoint]=zf[ipoint]-tot
      r=cabs(zf[ipoint])
      if(r>rmax)
        rmax=r
      endif
    endwhile
    ipoint=-1
    while(ipoint<npoint)
      ipoint=ipoint+1
      zf[ipoint]=zf[ipoint]/rmax
    endwhile
  endif
;
; print longest
;
  if(@printlong==true)
    r=0
    rmax=0
    ipoint=0
    while(ipoint<npoint)
      ipoint=ipoint+1
      r=cabs(zf[ipoint]-zf[ipoint-1])
      if(r>rmax)
        rmax=r
      endif
    endwhile
    print("Set speedup more than ",rmax)
  endif
;
; print last
;
  if(@printlast==true)
    print("Last line ",npoint)
  endif
init:
  complex tl=(0,0)
  complex z1=(0,0)
  complex z2=(0,0)
  float x=0
  float y=0
  float rl=0
  float rmin=1e20
  int il=0
  int jl=0
  int lastline=0
  int nin=0
  int nmin=0
  if((@last==0)||(@last>npoint))
    lastline=npoint
  else
    lastline=@last
  endif
loop:
final:
  il=@first
  while(il<lastline)
    il=il+1
    jl=il-1
    z1=zf[il]
    z2=zf[jl]
    rl=cabs((z1+z2)/2-#pixel)
    if(rl<@speedup)
      tl=(#pixel-z1)/(z2-z1)
      x=real(tl)
      y=imag(tl)
      if(x<0)
        rl=sqr(x)+sqr(y)
      elseif(x>1)
        rl=sqr(x-1)+sqr(y)
      else
        rl=sqr(y)
      endif
      rl=sqrt(rl)*cabs(z2-z1)
      if(rl<@thick)
        nin=nin+1
        if(rl<rmin)
          rmin=rl
          nmin=il
        endif
      endif
    endif
  endwhile
  if(rmin>@thick)
    #solid=true
  else
    if(@colorby==1)          ; which line
      #index=nmin/npoint
    else                     ; outline
      #index=rmin/@thick
    endif
  endif
default:
  title="Fresnel Integral"
  heading
    caption="About"
    text="This coloring draws various spirals that arise from \
      numerically calculating the Fresnel equations. It can create \
      some very interesting curves, but it can also be tricky to manage."
  endheading
;
; function parameters
;
  heading
    caption="Function parameters"
  endheading
  float param cfreq
    caption="cosine frequency (hint)"
    default=1
    hint="Frequency is this multiplied by pi/2"
  endparam
  float param sfreq
    caption="sine frequency (hint)"
    default=1
    hint="Frequency is this multiplied by pi/2"
  endparam
  float param cpower
    caption="cosine power"
    default=2
  endparam
  float param spower
    caption="sine power"
    default=2
  endparam
;
; integration parametes
;
  heading
    caption="Integration parameters"
  endheading
  complex param rectweight
    caption="rectangular weight"
    default=0
  endparam
  complex param trapweight
    caption="trapezoidal weight"
    default=1
  endparam
  complex param simpweight
    caption="Simpson weight"
    default=0
  endparam
;
; drawing parameters
;
  heading
    caption="Drawing parameters"
  endheading
  float param nbase
    caption="base (hint)"
    default=31
    min=2
    hint="Number of points = base^2"
  endparam
  float param mult
    caption="multiple (hint)"
    default=3
    hint="Maximum angle = base * multiple"
  endparam
  param colorby
    caption="color by"
    default=0
    enum="outline" "which line"
  endparam
  float param thick
    caption="line thickness"
    default=0.01
  endparam
  int param first
    caption="first line (hint)"
    default=0
    min=0
    hint="Set larger than 0 to only draw last part of curve; use 0 for all lines"
  endparam
  int param last
    caption="last line (hint)"
    default=0
    hint="Set larger than 0 to only draw first part of curve; use 0 for all lines"
    min=0
  endparam
  float param speedup
    caption="speedup threshold"
    default=1
    hint="Larger is slower but more accurate, smaller is \
      faster but less accurate."
  endparam
  bool param centerscale
    caption="center and scale"
    default=true
  endparam
  bool param printlong
    caption="print longest"
    default=false
  endparam
  bool param printlast
    caption="print last"
    default=false
  endparam
}

square-space-filling {
$define debug
global:
  complex zsf[2,round(sqr(@block_size)^@nlevel)]
  int go=0
  int gn=1
  int iblock=0
  int ilevel=0
  int ipoint=0
  int jpoint=0
  int nblock=@block_size*@block_size
  int npoint=0
  int xbwd=0
  int xfwd=0
  int xslope_size[round(sqr(@block_size))]
  int xslope_xfwd[round(sqr(@block_size))]
  int xslope_yfwd[round(sqr(@block_size))]
  int xslope_xbwd[round(sqr(@block_size))]
  int xslope_ybwd[round(sqr(@block_size))]
  int xnew=0
  int xoffset[round(sqr(@block_size))]
  int ybwd=0

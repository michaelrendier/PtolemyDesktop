  int yslope_ybwd[round(sqr(@block_size))]
  int ynew=0
  int yoffset[round(sqr(@block_size))]
;
; color list for manual mosaic coloring
;
  float colorlist[100]
  colorlist[00]=@color00
  colorlist[01]=@color01
  colorlist[02]=@color02

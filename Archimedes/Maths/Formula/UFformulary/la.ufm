gravijul-lla1 { ; Linda Allison
;
; 3-4-98 variation of the generalized
; r^(-2) formula by Mark "Bud" Christenson 1/25/98
; defaults: p1 = (1,0) p2 = (4,0)
;
  z = c = pixel:
  w = fn1(z)*fn1(z)
  z = fn3(p1/fn2(w*w)) + c
  |z| < p2
  }

100196-004 { ; Linda Allison
  z = pixel:
  z2 = (1/z ^ 2)
  z = fn1(z2) + fn2((z2 ^ 2)/p1)
  |z| <= p2
  }

040297-002 { ; Linda Allison
z = c = pixel:
z2 = (fn1(z)/p1) - (fn2(z)/p2)
z = z2 * z * z2 + (c + (c/p1))
|z| <= p2
}




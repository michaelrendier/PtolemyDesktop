Carr2793 (XAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm.
init:
  pixel2=real(pixel)-flip(abs(imag(pixel)))
  c=b5=pixel2^5+.1/pixel2-.3-conj(.1/pixel2)^12
  IF (@p3==1)
    z = b5^4
  ELSEIF (@p3==0)
    c = -c, z = -b5
  ELSE
    IF (whitesq)
      z = b5^4
    ELSE
      c = -c, z = -b5
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = pixel2/imag(p2) + .0095
  k2 = conj(.1/pixel2)
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = c1, z = 0
  ELSEIF (iter==l2)
    c = c2, z = 0
  ELSEIF (iter==l3)
    c = c3, z = 0
  ELSEIF (iter==l4)
    c = c4, z = 0
  ENDIF
  c = c + k
  z = z*z + c - k2
  iter=iter+1
bailout:
  (|real(z)|)<=bailout
default:
  title = "Carr 2793"
  periodicity = 0
  maxiter = 500
  magn = 1.3
  center = (0,0)
  method = multipass
  param p1

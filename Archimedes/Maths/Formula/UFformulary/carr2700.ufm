    ELSE
      c = -conj(b4), z = -flip(b5)
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k1 = pixel/imag(p2)
  k2 = (-.7456,.132)
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = c1, z = 0
  ELSEIF (iter==l2)
    c = c2, z = 0
  ELSEIF (iter==l3)
    c = c3, z = 0
  ELSEIF (iter==l4)
    c = c4, z = 0
  ENDIF
  c = c + k1
  z = z*z + c + k2
  iter=iter+1
bailout:
  |real(z)|<=bailout
default:
  title = "Carr 2739"
  periodicity = 0
  maxiter = 500
  magn = 1.2
  center = (0,-.15)

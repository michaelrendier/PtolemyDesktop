Carr2739 {; Updated for UF2 by Erik Reckase, February 2000
          ; Modified Sylvie Gallet frm.
init:
  b = pixel-flip(.01/pixel)-conj(.1/pixel)
  b4=pixel/3*cos(b), b5=pixel*b+.0001/pixel

Carr2742 {; Updated for UF2 by Erik Reckase, February 2000
          ; Modified Sylvie Gallet frm.
init:
  d=sqrt(1/pixel-conj(0.1/pixel))
  b=pixel-flip(.01/pixel)-conj(.1/pixel)
  c=pixel/3*cos(b)/d, z=(pixel*b+.0001/pixel)/d*10
  IF (@p3==0)
    c = -c, z = -z
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -c, z = -z
    ENDIF
  ENDIF
  k1 = pixel/imag(p2)
  k2 = (-.7456,.132)
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    c = c1 + k1, z = 0
  ELSEIF (iter==l2)

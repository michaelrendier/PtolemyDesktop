  pixel2=real(pixel)-flip(abs(imag(pixel)))
  c=.15/log(exp(pixel2^150-1/acos(pixel2^30.5)-.4)-.8)
  z=pixel2
  IF (@p3==0)
    c = -c, z = -z
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -c, z = -z
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = pixel2/imag(p2)
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0, float zro=0
loop:
  IF (iter==l1)
    c = c1, z = z*zro
  ELSEIF (iter==l2)
    c = c2, z = z*zro
  ELSEIF (iter==l3)
    c = c3, z = z*zro
  ELSEIF (iter==l4)
    c = c4, z = z*zro
  ENDIF
  c = c + k
  z = z*z + c
  iter=iter+1
bailout:
  |real(z)|<=bailout

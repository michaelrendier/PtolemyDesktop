Lobsters {
;Recommended initial coloring Smooth Mandelbrot
init:
  z=#pixel

loop:
  z=z^(@f(z))+z
bailout:
  |z|<=@bailout
default:
  center = (-0.36778,-0.13061)
  magn = 0.7
  method=onepass
  param bailout
  default = 4
  endparam
  func f
  caption = "Function"
  default = tan()
  endfunc
  title = "Lobsters"
switch:
}

Lobsters2 {
;Recommended initial coloring Smooth Mandelbrot
init:
 if @mode == "M1"
   z = @startseed
   c = #pixel
  else
   z = #pixel
   c = @startseed
  endif
  if @scale != 1.0
      z = z / @scale
  endif
  if @center != (0.0,0.0)
      z = z + @center
  endif
x = #pixel

loop:

  z=x^(@f(x))+c

Wings {
init:
  z=#pixel
loop:
  z=1/((@multiplier*z)^@power)+z
bailout:
  |z|<=4
default:
  param multiplier
  default = (2,0)
  endparam
  param power
  default = (2,0)
  endparam
  center =(0.20549,-0.05629)
  magn = 0.69933
  title = "Wings"
switch:
}


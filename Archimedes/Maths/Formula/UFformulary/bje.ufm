    visible = @show
endparam
complex param center
    caption = "Center Reset"
    default = (0,0)
    visible = @show
endparam
float param bailout
    caption = "Bailout"
    default = 1000
endparam
complex param startseed
    caption = "Start/Seed"
    default = (0,0)
    hint = "Defines the init z value in the Mandelbrot, \
            the seed value in the Julia"
endparam


  title = "Up And Down"
switch:
  type = "UpAndDown"
  startSeed = #pixel
  mode = switchMode
  switchMode =@mode
  center=@swcenter
  scale=@swscale
  bailout = @bailout

Well {
init:

  c = @seed
  if @pseed == true
  c = #pixel
  endif
  z=#pixel

loop:
  z=@f1(@f2(@f3(z^@power)))+c
bailout:
  |z|<=@bailout
default:
  param power
  default = (5,0)
  endparam
  param seed
  default=(0,0)
  visible = !(@pseed)
  endparam
  bool param pseed
  caption = "Use pixel as seed?"
  default = false
  endparam
  func f1
  default = sin()
  endfunc
  func f2
  default = tan()
  endfunc
  func f3
  default = cos()
  endfunc
  method = onepass
  float param bailout
  default=4
  endparam
  title = "Well"


}


Well2 {
init:
  c = @seed
  if @pseed == true
  c = #pixel
  endif
  z=#pixel

loop:
  z=@f1(@f2(@f3(z^@power)))+c
bailout:
 sin(|z|)<=@bailout
default:
  float param bailout
  default = 0
  endparam
  param power
  default = (5,0)
  endparam
  param seed
  default=(0,0)
  visible = !(@pseed)
  endparam
  bool param pseed
  caption = "Use pixel as seed?"
  default = false
  endparam
  func f1
  default = sin()
  endfunc
  func f2
  default = tan()
  endfunc
  func f3
  default = cos()
  endfunc
  method = onepass
  center = (-0.26638,-0.149240)
  magn = 0.6993
  title = "Well2"
switch:
}



Well3 {
init:
  c = @seed
  if @pseed == true
  c = #pixel
  endif
  z=#pixel

loop:
  z=@f1(@f2(@f3(z^@power)))+c
bailout:
 abs(cotan(|z|))<=@bailout
default:
  float param bailout
  default = 4
  endparam
  param power
  default = (5,0)
  endparam
  param seed
  default=(0,0)
  visible = !(@pseed)
  endparam
  bool param pseed
  caption = "Use pixel as seed?"
  default = false
  endparam
  func f1
  default = sin()
  endfunc
  func f2
  default = tan()
  endfunc
  func f3
  default = cos()
  endfunc
  method = onepass
  center = (-0.26638,-0.149240)
  magn = 0.6993
  title = "Well3"
switch:
}


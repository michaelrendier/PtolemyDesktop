#pixel = j



default:
    title = "random10"


heading
  caption = "    Z Tweakers"
endheading 

bool paramztweak1
caption = "  1/z"
    default = false
  endparam 

bool paramztweak2
caption = "  z ^ 2 + p1"
    default = false
  endparam 

bool paramztweak3
caption = "  p1 *z * ( 1 - z ) ^ ( p2 - 1 )"
    default = false
  endparam 

bool paramztweak4
caption = "  z ^ p1  +  z ^ p2 * #pi  +  p3 * z"
    default = false
  endparam 

bool paramztweak5
caption = "  ((p1 - 1) * z^p1 + p2) / (p1 * z ^ (p1 - 1))"

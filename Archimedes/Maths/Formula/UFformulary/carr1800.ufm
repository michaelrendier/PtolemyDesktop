  periodicity = 0
  maxiter = 500
  magn = .7
  center = (1,0)
}

Carr1874 { ; Updated for UF2 by Erik Reckase, March 2000
           ; Modified Lee Skinner formula
init:
  p=1/(pixel-conj(1/pixel)-flip(1/pixel))
  t3=3*cos(p), t2=p*p, a=(t2+1)/t3
  b=2*a^3+(t2-2)/t3, aa3=a*a*3, z=-a
loop:
  z=z*z-aa3*z+b
bailout:
  |real(z)| <= 4
default:
  title = "Carr 1874"
  periodicity = 0
  maxiter = 500
  magn = .5
  center = (0,0)
}


Carr1818 { ; Updated for UF2 by Erik Reckase, March 2000
           ; Mandelbrot
init:
  op = 1/pixel, c=conj(op)/exp(op)
  z=1/(pixel-atan(op-conj(c)+.55)+conj(op)+flip(op))
loop:
  z = z^2 + c
bailout:
  |real(z)| <= 4
default:
  title = "Carr 1818"
  periodicity = 0
  maxiter = 500
  magn = .7
  center = (0,0)
}

Carr1819 { ; Updated for UF2 by Erik Reckase, March 2000
           ; Mandelbrot
init:
  op = 1/pixel, c=conj(op)/sqr(sin(op))
  z=1/(pixel-atan(op-conj(c)+.55)+conj(op)+flip(op))
loop:
  z = z^2 + c
bailout:
  |real(z)| <= 4
default:
  title = "Carr 1819"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (0,0)
}

Carr1820 { ; Updated for UF2 by Erik Reckase, March 2000
           ; Mandelbrot
init:
  op=1/pixel, c=op/(pixel-flip(op)-conj(op))
  z=1/(cos(pixel)-sqr(conj(exp(1.79*op))))
loop:
  z = z^2 + c
bailout:
  |real(z)| <= 4
default:
  title = "Carr 1820"
  periodicity = 0
  maxiter = 500
  magn = .7
  center = (0,0)
}

Carr1821 { ; Updated for UF2 by Erik Reckase, March 2000
           ; Julia
init:
  op = pixel - flip(1/pixel) - conj(1/pixel)
  c=1/pixel/op, z=1/op
loop:
  z = z^2 + c
  c=(1+flip(imag(sqrt(sin(c)))))*real(sqrt(tan(c)))/9+z
bailout:
  |real(z)| <= 4
default:
  title = "Carr 1821"
  periodicity = 0
  maxiter = 500
  magn = .25
  center = (0,0)
}

Carr1822 { ; Updated for UF2 by Erik Reckase, March 2000

comment {
  Carr1800.ufm Version 1.1
  Ultra Fractal conversions of Robert Carr's formulas Carr1800 - Carr1899
  by Erik Reckase, March 10, 2000

  History:  Version 1.1 - Major optimization overhaul, cleanup

            Version 1.0 - Initial Release
                          Original formulas pulled from _rc1.frm

                          Carr1800                  : divide by undefined variable                          
                          Carr1809,1812,1847-1851,
                              1854-1855,1877-1878   : cosxx fix
}

Carr1800 { ; Updated for UF2 by Erik Reckase, March 2000
init:
  z=1/pixel, c=1/(pixel-sqr(z/z^z+z)/atan(pixel))
loop:
  z = z^3 + c
bailout:
  |real(z)| <= 10
default:
  title = "Carr 1800"
  periodicity = 0
  maxiter = 500
  magn = .6
  center = (0,0)
}

Carr1801 { ; Updated for UF2 by Erik Reckase, March 2000
           ; Mandelbrot
init:
  z=1/(pixel-conj(1/pixel)-flip(1/pixel))
  c=1/(pixel-z-cos(sqr(z/(pixel-.124))))
loop:
  z = z^2 + c
bailout:
  |real(z)| <= 10
default:
  title = "Carr 1801"
  periodicity = 0
  maxiter = 500
  magn = .6
  center = (1.6,0)
}

Carr1802 { ; Updated for UF2 by Erik Reckase, March 2000
           ; Mandelbrot
init:
  z=1/pixel, c=1/(pixel-conj(z^2/|pixel|+pixel/z))
loop:
  z = z^2 + c
bailout:
  |real(z)| <= 10
default:
  title = "Carr 1802"
  periodicity = 0
  maxiter = 500
  magn = .6
  center = (0,0)
}

Carr1803 { ; Updated for UF2 by Erik Reckase, March 2000
           ; Spider type
init:
  z=1/pixel, c=1/(pixel-conj(z^2/|pixel|+pixel/z))
loop:
  z = z^2 + c
  c = z + c/2.125
bailout:
  |real(z)| <= 4
default:
  title = "Carr 1803"
  periodicity = 0
  maxiter = 500
  magn = .8
  center = (0,0)
}

Carr1804 { ; Updated for UF2 by Erik Reckase, March 2000
           ; Mandelbrot
init:
  z=1/pixel, c=1/(pixel-cosh(z^2/cos(pixel)/pixel+pixel/z))
loop:
  z = z^2 + c
bailout:
  |real(z)| <= 4
default:
  title = "Carr 1804"
  periodicity = 0
  maxiter = 500
  magn = .6
  center = (0,0)
}

Carr1805 { ; Updated for UF2 by Erik Reckase, March 2000
           ; Mandelbrot
init:
  z=1/asin(1/atanh(1/pixel-conj(1/pixel)))
  c=1/pixel+(z+1)/pixel
loop:
  z = z^2 + c
bailout:
  |real(z)| <= 4
default:
  title = "Carr 1805"
  periodicity = 0
  maxiter = 500
  magn = .4
  center = (1.7,0)
}

Carr1806 { ; Updated for UF2 by Erik Reckase, March 2000
           ; Mandelbrot
init:
  c3=conj(tan(pixel)), c2=c3+conj(sinh(pixel))
  ct = conj(1/pixel)+flip(1/pixel)
  c=1/(sin(c3)+cos(c2))-ct, z=1/(pixel-ct)
loop:
  z = z^2 + c
bailout:
  |real(z)| <= 4
default:
  title = "Carr 1806"
  periodicity = 0
  maxiter = 500
  magn = .3
  center = (0,0)
}

Carr1807 { ; Updated for UF2 by Erik Reckase, March 2000
           ; Mandelbrot
init:
  c3=tan(pixel), c2=|c3|+conj(sin(pixel)), op = 1/pixel
  c=1/(c3+flip(c2))-asin(op)-atan(op)
  z=1/(pixel-conj(op)-flip(op))
loop:
  z = z^2 + c
bailout:
  |real(z)| <= 4
default:
  title = "Carr 1807"
  periodicity = 0
  maxiter = 500
  magn = .22
  center = (-1.5,0)
}

Carr1808 { ; Updated for UF2 by Erik Reckase, March 2000
           ; Mandelbrot
init:
  c3=sin(conj(pixel)), c2=|c3|+conj(atan(pixel)), op = 1/pixel
  c=1/(conj(c3)+flip(c2))-asin(op)-atan(op)
  z=1/(pixel-conj(op)-flip(op))
loop:
  z = z^2 + c
bailout:
  |real(z)| <= 4
default:
  title = "Carr 1808"
  periodicity = 0
  maxiter = 500
  magn = .17
  center = (0,0)
}

Carr1809 { ; Updated for UF2 by Erik Reckase, March 2000
           ; Mandelbrot
init:
  c3=asin(conj(pixel)), c2=|c3|+cos(pixel), op = 1/pixel
  c=1/(conj(c3)+flip(c2))-asin(op)-atan(op)
  z=1/(pixel-conj(op)-flip(op))
loop:
  z = z^2 + c
bailout:
  |real(z)| <= 4
default:
  title = "Carr 1809"
  periodicity = 0
  maxiter = 500
  magn = .25
  center = (0,0)
}

Carr1810 { ; Updated for UF2 by Erik Reckase, March 2000
           ; Mandelbrot
init:
  op = 1/pixel, z1=conj(op)-flip(op)
  z=1/(pixel+sqrt(op)-log(op)-|z1|), c=1/(pixel+sqrt(7*op))
loop:
  z = z^2 + c
bailout:
  |real(z)| <= 4
default:
  title = "Carr 1810"
  periodicity = 0
  maxiter = 500
  magn = .5
  center = (0,0)
}

Carr1811 { ; Updated for UF2 by Erik Reckase, March 2000
           ; Mandelbrot
init:
  op = 1/pixel, z1=conj(op)-flip(op)
  z=1/(pixel+.45-sqrt(op)+log(2*op)+|z1|-cos(5*op))
  c=1/(pixel+sqrt(7*op))
loop:
  z = z^2 + c
bailout:
  |real(z)| <= 4
default:
  title = "Carr 1811"
  periodicity = 0
  maxiter = 500
  magn = .5
  center = (0,0)
}

Carr1812 { ; Updated for UF2 by Erik Reckase, March 2000
           ; Mandelbrot
init:
  op = 1/pixel, z1=conj(op)-flip(op)
  z=1/(pixel+.45-sqrt(op)-log(2*op)+z1-cos(5*op))
  c=1/(pixel-cos(op)-conj(cos(op))+sqrt(7*op)-log(op/2))
loop:
  z = z^2 + c
bailout:
  |real(z)| <= 4
default:
  title = "Carr 1812"
  periodicity = 0
  maxiter = 500
  magn = .7
  center = (0,0)
}

Carr1813 { ; Updated for UF2 by Erik Reckase, March 2000
           ; Mandelbrot
init:
  z=1/flip(pixel)/conj(atan(5/pixel-.724))
  c=1/(flip(pixel)*tan(7/pixel-.524)-flip(1/pixel)-conj(1/pixel))
loop:
  z = z^2 + c
bailout:
  |real(z)| <= 4
default:
  title = "Carr 1813"
  periodicity = 0
  maxiter = 500
  magn = .6
  center = (0,0)
}

Carr1814 { ; Updated for UF2 by Erik Reckase, March 2000
           ; Mandelbrot
init:
  z=1/(conj(pixel)-cos(7/pixel-.524)-sin(1/pixel)+conj(1/pixel))
  c=1/pixel/real(5/pixel-.724)
loop:
  z = z^2 + c
bailout:
  |real(z)| <= 4
default:
  title = "Carr 1814"
  periodicity = 0
  maxiter = 500
  magn = .2
  center = (0,0)
}

Carr1815 { ; Updated for UF2 by Erik Reckase, March 2000
           ; Mandelbrot
init:
  z=1/(conj(pixel)-cos(7/pixel-.524)-sin(1/pixel)+conj(1/pixel))
  c=1/(pixel-conj(z-1.1)*z*z^conj(cotanh(pixel-.2)))
loop:
  z = z^2 + c
bailout:
  |real(z)| <= 4
default:
  title = "Carr 1815"
  periodicity = 0
  maxiter = 500
  magn = .5
  center = (0,0)
}


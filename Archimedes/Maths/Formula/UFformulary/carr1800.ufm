Carr1889 { ; Updated for UF2 by Erik Reckase, March 2000
           ; Modification of Sylvie Gallet frm. Redone by Sylvie
init:
  z=c=pixel, bool test1=TRUE
  float b1=16, float b2=.0001
loop:
  test1 = !test1
  z=z^2+c+(.35776,-.08294)
  IF (test1)
    float ztest = |z|
    float btest = b1
  ELSE
    IF (z==0)
      z1 = (z^5-1)
    ELSE
      z1 = (z^5-1)/(4*z^4)
    ENDIF
    float ztest = b2
    float btest = |z1|
  ENDIF
bailout:
  ztest <= btest
default:
  title = "Carr 1889"
  periodicity = 0
  maxiter = 500
  magn = 1.4
  center = (-.5,0)
}


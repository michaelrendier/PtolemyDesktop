Carr1847 { ; Updated for UF2 by Erik Reckase, March 2000
           ; Spider
init:
  op = 1/pixel, z=1/(pixel-exp(op)-tan(|op|)-conj(op))
  c=1/(pixel-asinh(op-cos(|z|)-|z|)-conj(1/exp(pixel-0.85)))
loop:
  z = z^2 + c
  c = z + c/2.125
bailout:
  |real(z)| <= 4

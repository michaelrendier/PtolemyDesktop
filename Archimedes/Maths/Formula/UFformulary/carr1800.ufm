Carr1872 { ; Updated for UF2 by Erik Reckase, March 2000
           ; Modified Sylvie Gallet formula
init:
  z=conj(1/pixel), c=1/(pixel-z-flip(1/pixel))
  float compt=0, float limit=.3, float bailout=4
loop:
  IF (compt>=limit)
    c = (-.743380900000982,-.131850030300002)
  ENDIF
  z = z*z + c
  compt = compt + 1
bailout:
  |z| <= bailout
default:
  title = "Carr 1872"
  periodicity = 0
  maxiter = 500
  magn = .01
  center = (0,0)
}

Carr1873 { ; Updated for UF2 by Erik Reckase, March 2000
init:
  op = 1/pixel, c1=1/(pixel-sin(op))
  z1=c1-conj(op), c=1/(pixel-(z1+c1)*op)
  z=1/(pixel-(c-cos(z1))/z1/c1)
loop:
  z = z*z + c
bailout:
  |real(z)| <= 4
default:

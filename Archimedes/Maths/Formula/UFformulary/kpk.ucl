    enum    = "None" "Bottom to Top" "Top to Bottom" "Between Top&Bottom" "Mirror TB" \
                     "Left to Right" "Right to Left" "Between Left&Right" "Mirror LR" \
                     "Circle 1" "Circle 2"
    default = 0
  endparam


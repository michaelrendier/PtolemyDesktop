elseif @Va=="29"
z=z+2.684*z/cotan(z)
elseif @Va=="30"
z=z+0.92854*z*abs(z)
elseif @Va=="31"
z=z-1.37673*sqr(z)/cotan(z)
elseif @Va=="32"
z=z-3.25*z/tan(z)
elseif @Va=="33"
z=z+0.65*z^4
elseif @Va=="34"
z=z+3.51248*sqr(z)/tan(z)
elseif @Va=="35"
z=z+2.51525*sqr(z)/tan(z)
elseif @Va=="36"
z=z+0.72909*z*cabs(z)

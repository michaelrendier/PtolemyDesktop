visible=@bt==1
endparam
}

Gumshir3 {
init:
z1=@sp1*fn1(pixel)
z2=@sp2*fn1(pixel)
z3=@sp3*fn1(pixel)
z=pixel
c=@c
int i=0
loop:
i=i+1
c=@p16*@fn5(c)+@p17
if @v==0
z3=((z3^2+c-1)/(2*z+c-2))^2+p1*z2+p2*z1
elseif @v==1
z3=((z1^2+c-1)/(2*z+c-2))^2+p1*z2+p2*z3
elseif @v==2
z3=((z^2+c-1)/(2*z+c-2))^2+p1*z1+p2*z3
elseif @v==3
z3=((z^2+c-1)/(2*z1+c-2))^2+p1*z2+p2*z3
elseif @v==4
z3=((z3^2+c-1)/(2*z2+c-2))^2+p1*z2+p2*z1
elseif @v==5
z3=((z1^2+c-1)/(2*z2+c-2))^2+p1*z2+p2*z3
elseif @v==6
z3=((z3^2+c-1)/(2*z+c-2))^i+p1*z2+p2*z1
elseif @v==7
z3=((z1^2+c-1)/(2*z+c-2))^i+p1*z2+p2*z3
elseif @v==8
z3=((z^2+c-1)/(2*z1+c-2))^i+p1*z2+p2*z3
elseif @v==9
z3=((z^i+c-1)/(2*z1+c-2))^2+p1*z2+p2*z3
elseif @v==10
z3=((z^2+c-1)/(2*z+c-2))^2+p1*z2+p2*z3
elseif @v==11
z3=((z^2+c-1)/(2*z2+c-2))^2+p1*z2+p2*z3
elseif @v==12
z3=((z^2+c-1)/(2*z+c-2))^i+p1*z2+p2*z3
endif
z1=p3*fn2(z2)+p4
z2=p5*fn3(z)+p6
z=@p7*fn4(z3)+@p8
bailout:
|z|<@bail

elseif @S=="36"
z=((sqr(pixel)^2+15-1i)/(2*cos(pixel)+15-2i))^2
elseif @S=="37"
z=((cosh(pixel)^2+8-1i)/(2*sqr(pixel)+8-2i))^2
elseif@S=="38"
if real(pixel)<imag(pixel)
z=pixel
else
z=flip(pixel)
endif
z=sqr(z)
elseif@S=="39"
if real(pixel)<imag(pixel)
z=pixel
else
z=flip(pixel)
endif
z=2.75*cotan(z)
elseif @S=="40"
if |pixel|<1
z=pixel/|pixel|
else
z=pixel
endif
elseif @S=="41"
if |pixel|<1
z=pixel/|pixel|
else
z=pixel
endif
z=2*z
elseif @S=="42"
if |pixel|<1
z=pixel/|pixel|
else
z=pixel
endif
z=z-0.85*exp(z)
elseif @S=="43"
if |pixel|<1
z=pixel/|pixel|
else
z=pixel
endif
z=z+2*sqr(z)
elseif @S=="44"
if |pixel|<1
z=pixel/|pixel|
else
z=pixel
endif
z=z-4*cotanh(z)
elseif @S=="45"
if |pixel|<1
z=pixel/|pixel|
else
z=pixel
endif
z=z-2.5*tan(z)
elseif @S=="46"
if |pixel|<1
z=pixel/|pixel|
else
z=pixel
endif
z=z-2.5*cos(z)
elseif @S=="47"
if |pixel|<1
z=pixel/|pixel|
else
z=pixel
endif
z=z-4*recip(z)
elseif @S=="48"
if |pixel|<1
z=pixel/|pixel|
else
z=pixel
endif
z=z+1i*exp(z)
elseif @S=="49"
if |pixel|<1
z=pixel/|pixel|
else
z=pixel
endif
z=z+1i*sqr(z)
elseif @S=="50"
if |pixel|<1
z=pixel/|pixel|
else
z=pixel
endif
z=z+1i*cotanh(z)
elseif @S=="51"
if |pixel|<1
z=pixel/|pixel|
else
z=pixel
endif

caption="GA Parameter 1"
default=(0.67,0)
endparam
param p2
caption="GA Parameter 2"
default=(-1.385,0)
endparam
param mp1a
caption="Munster Parameter 1a"
default=(1.6,0)
endparam
param mp1b
caption="Munster Parameter 1b"
default=(1,0)
endparam
param mp2a
caption="Munster Parameter 2a"
default=(3.8,0)
endparam
param mp2b
caption="Munster Parameter 2b"
default=(1,0)
endparam
param mp3a
caption="Munster Parameter 3a"
default=(1.5,0)
endparam

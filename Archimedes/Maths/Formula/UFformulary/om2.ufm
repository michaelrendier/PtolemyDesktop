elseif @Va=="3"
x=real(z)
y=imag(z)
x=x/|z|
y=y/|z|
z=x+flip(y)
endif
z=p1*z^2*(-p2+p3*z)/(p3-p2*z)+@p7
bailout:
(|zold-z|>@bailcon && @bt=="Convergent") || (|z|<@baildiv && @bt=="Divergent")

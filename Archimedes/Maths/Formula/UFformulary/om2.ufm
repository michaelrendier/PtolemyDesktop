u=(1-@p1)*z+@p1*(sqr((z^2+@mp1*c-1)/(2*z+@mp1*c-2)))
z=(1-@p2)*z+@p2*(sqr((u^2+@mp2*c-1)/(2*u+@mp2*c-2)))

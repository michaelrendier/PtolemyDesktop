z=(z-@p7)/(1-@p7*z)
z=z/(@p8*z+1)
z=z+p5/z
z=z+p6*sqr(z)
if @Va=="None"
z=z
elseif @Va=="1"
if |z|<1
z=z/|z|
endif
z=-0.575*z
elseif @Va=="2"
if real(z)<0
z=-real(z)+flip(imag(z))
endif
z=1.086*z
elseif @Va=="3"
if |z|<1
z=z/|z|
endif
z=-0.55*flip(z)
elseif @Va=="4"
if |z|<1
z=z/|z|
endif
z=-0.55*abs(z)
elseif @Va=="5"
if |z|<1
z=z/|z|
endif
z=-1.129839*recip(z)
elseif @Va=="6"
if real(z)<0
z=-real(z)+flip(imag(z))
endif
z=-0.4675*exp(z)
elseif @Va=="7"
if real(z)<0
z=-real(z)+flip(imag(z))
endif
z=0.75*sqr(z)
elseif @Va=="8"
if |z-2.14|<1
z=(1/(z-2.14))+2.14
endif
elseif @Va=="9"
if |z+0.45|<1
z=(1/(z+0.45))-0.45
endif
elseif @Va=="10"
z=recip(z)^3
elseif @Va=="11"
z=-recip(z)^3
elseif @Va=="12"
z=0.65*z^3
elseif @Va=="13"
z=z-0.2*recip(z)^2
elseif @Va=="14"
z=z+1i*z*cos(z)
elseif @Va=="15"
z=z+1/exp(z)
elseif @Va=="16"
z=z-0.7*z*exp(z)
elseif @Va=="17"

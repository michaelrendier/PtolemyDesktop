elseif @Va=="23"
if real(z)<imag(z)
z=flip(z)
endif
z=-conj(z)
elseif @Va=="24"
z=abs((z+0.3)/(1+0.3*z))
elseif @Va=="25"
if real(z)<imag(z)
z=flip(z)
endif
z=-3*flip(z)
elseif @Va=="26"
if real(z)<imag(z)
z=flip(z)
endif
z=-3*z
elseif @Va=="27"
z=conj((z+5)/(1+5*z))

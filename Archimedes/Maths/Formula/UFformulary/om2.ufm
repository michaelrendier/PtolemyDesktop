caption="Yacyel Function"
default=ident()
endfunc
func fn1
caption="C Function"
default=ident()
endfunc
param sz
caption="Sqr(Z)"
default=false
endparam
param bail
caption="Bailout"
default=100.0
endparam
}

Mildatos {

BivarX21 {
;https://fractalforums.org/fractal-mathematics-and-new-theories/28/holomorphic-mandelbrot-extensions/1475/msg15529#new
init:
z=fn1(@p14)
k=-z
loop:
zold=z
z=p6*z+@p7
k=@p8*k+@p9
z=z+p4/z
k=k+p4/k
z=z+p5*sqr(z)
k=k+p5*sqr(k)
z=z^2+p1*k+fn2(pixel)
k=p2/fn3(k^2+fn2(pixel))
bailout:
(@bt==0 && |z|<@baildiv) || (@bt==1 && |z-zold|>@bailcon)

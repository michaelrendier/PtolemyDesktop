caption="Gumshir Parameter 7"
default=(1,0)
endparam
param p8
caption="Gumshir Parameter 8"
default=(0,0)
endparam
param p16
caption="C Parameter 1"
default=(1,0)
endparam
param p17
caption="C Parameter 2"
default=(0,0)
endparam
func fn1
caption="C Function 1"
default=ident()
endfunc
func fn5
caption="C Function 2"
default=ident()
endfunc
func fn2
caption="Gumshir Function 1"
default=ident()
endfunc
func fn3
caption="Gumshir Function 2"
default=ident()
endfunc
func fn4
caption="Gumshir Function 3"
default=ident()
endfunc
param bail

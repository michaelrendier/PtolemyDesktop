Nedzhibov {
init:
z=@sf(pixel)
loop:
zold=z
z=@zp1*z+@zp2
f=z^@pow-@c
f1=@pow*z^(@pow-1)
a=z-@np3*f/f1
fa=a^@pow-@c
z=a-@np2*f*fa/(f1*(f-@np1*fa))
bailout:
|z-zold|>@bail
default:
title="Nedzhibov"

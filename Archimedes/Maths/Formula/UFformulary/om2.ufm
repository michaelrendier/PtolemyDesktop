z=z-5.75*((z)^3-1i)/(3*(z)^2)
a=a-5.75*((a)^3-1i)/(3*(a)^2)
elseif @V=="20"
z=z-0.3/sqr(z)
a=a-0.3/sqr(a)
elseif @V=="21"
z=z+0.5*(exp(z)^3-1i)/(3*exp(z)^2)
a=a+0.5*(exp(a)^3-1i)/(3*exp(a)^2)
elseif @V=="22"
z=z+0.5*tanh(z)
a=a+0.5*tanh(a)
elseif @V=="23"
z=z+1.41*(tan(z)^3-1i)/(3*tan(z)^2)
a=a+1.41*(tan(a)^3-1i)/(3*tan(a)^2)
elseif @V=="24"
z=z-0.5*cos(z)
a=a-0.5*cos(a)
elseif @V=="25"

AleatorGanthraleBivar {
global:
float values[#maxiter]
int i=0
int seed=@seed
while i<100
seed=random(seed)
values[i]=seed/#randomrange
i=i+1
endwhile
init:
z=fn1(pixel)
z=z+@sp*@sf2(z)
k=fn1(pixel)
k=k+@sp*@sf2(k)
int i2=0
loop:
zold=z
z=@zp1*fn2(z)+@zp2
k=@kp1*fn2(k)+@kp2
z=z+@asp*sqr(z)
k=k+@asp*sqr(k)
a=k
if @v==0
k=@bp1*@bf(k/z)+@bp2
z=(sqrt(1i*z+p2)*z)+(sqrt(1i*a+p2)*a)+p1+@ap*@af(values[i2])
elseif @v==1
k=@bp1*@bf(k/z)+@bp2+@ap*@af(values[i2])
z=(sqrt(1i*z+p2+(-0.68,-1.33))*z)+(sqrt(1i*a+p2+(-0.68,-1.33))*a)+p1
elseif @v==2
k=@bp1*@bf(k/z)+@bp2
z=(sqrt(1i*z+p2)*z)+(sqrt(1i*k+p2)*k)+p1+@ap*@af(values[i2])
elseif @v==3
k=@bp1*@bf(k/z)+@bp2+@ap*@af(values[i2])
z=(sqrt(1i*z+p2+(-0.21,0.78))*z)+(sqrt(1i*k+p2+(-0.21,0.78))*k)+p1
elseif @v==4
k=@bp1*@bf(k/z)+@bp2+@ap*@af(values[i2])
z=(sqrt(1i*z+p2)*z)+(sqrt(1i*a+p2)*a)+p1+@ap*@af(values[i2])
elseif @v==5
k=@bp1*@bf(k/z)+@bp2+@ap*@af(values[i2])
z=(sqrt(1i*z+p2+(-0.47,1.66))*z)+(sqrt(1i*k+p2+(-0.47,1.66))*k)+p1+@ap*@af(values[i2])
endif
i2=12+1
bailout:
(|zold-z|>@bailcon && @bt=="Convergent") || (|z|<@baildiv && @bt=="Divergent")
default:
title="Aleator Ganthrale Bivar"
center=(0.001,1.267)
periodicity=0
magn=0.5
func fn1
caption="Start Function"
default=ident()
endfunc
param sp
caption="Start Parameter"
default=(0,0)
endparam
func sf2
caption="Start Function 2"
default=sin()
visible=@sp!=0
endfunc
param v
caption="Variant"
enum="1""2""3""4""5""6"
endparam
param ap
caption="Aleator Parameter"
default=(1,0)
endparam
func af
caption="Aleator Function"
default=ident()
endfunc
param seed
caption="Random Seed"
default=12345678
endparam
param bp1
caption="Bivar Parameter 1"
default=(1,0)
endparam
param bp2
caption="Bivar Parameter 2"
default=(0,0)
endparam
func bf
caption="Bivar Function"
default=ident()
endfunc
param p1
caption="Ganthrale Parameter 1"
default=(0.2,0.15)
endparam
param p2
caption="Ganthrale Parameter 2"
default=(1.85,0)
endparam
param zp1
caption="Z Parameter 1"
default=(0.67,0)
endparam
param zp2
caption="Z Parameter 2"
default=(0,0)
endparam
param kp1
caption="K Parameter 1"
default=(0.6,0)
endparam
param kp2
caption="K Parameter 2"
default=(0,0)
endparam
func fn2
caption="Loop Function"
default=ident()
endfunc
param asp
caption="Add Sqr Parameter"
default=(0.04356,0)
endparam
param bt
caption="Bailout Type"
enum="Convergent""Divergent"
endparam
param bailcon
caption="Bailout"
default=0.00000000000001
visible=@bt==0
endparam
param baildiv
caption="Bailout"
default=100.0
visible=@bt==1
endparam
}

AleatorMandelBox {
;This is a modification of "Mister Lowe's Marvelous Box" by Erik Wahl (eew.ufm),
;from a formula originally by Tom Lowe
global:
float values[#maxiter]
int i=0
int seed=@seed
while i<@ac
seed=random(seed)
values[i]=seed/#randomrange
i=i+1
endwhile
init:
float x=0.0
float y=0.0
float a1=0.0
float a2=0.0
if @st==0
z=fn2(@sp)
else
z=fn2(pixel)
endif
c=fn1(fn2(pixel))
int i2=0
loop:
z=@zp1*@zf(z)+@zp2
c=@cp1*@cf(c)+@cp2
z=z+@arp/(z*1000000)
z=z+@asp*sqr(z)
x=real(z)
y=imag(z)
if x>p1
x=2*p1-x
elseif x<-p1
x=-2*p1-x
endif
if y>p2
y=2*p2-y
elseif y<-p2
y=-2*p2-y
endif
x=x*p3
y=y*p3
a1=sqrt(sqr(x)+sqr(y))
a2=a1
if a1<p4
a2=a1/p4^2
elseif a1<p5
a2=p5/a1
endif
x=(x/a1)*a2
y=(y/a1)*a2
if @a==true
if @av==0
z=x+flip(y)
z=(z*p6)^@pow+1.5*c+@ap*@af(values[i2])
elseif @av==1
z=x+flip(y)+@ap*@af(values[i2])
z=(z*p6)^@pow+1.5*c+@ap*@af(values[i2])
elseif @av==2
z=x+flip(y)+@ap*@af(values[i2])
z=(z*p6)^@pow+1.5*c
elseif @av==3
z=x+flip(y)
z=(z*p6)^@pow+1.5*c*@ap*@af(values[i2])
elseif @av==4
z=(x+flip(y))*@ap*@af(values[i2])
z=(z*p6)^@pow+1.5*c*@ap*@af(values[i2])
elseif @av==5
z=(x+flip(y))*@ap*@af(values[i2])
z=(z*p6)^@pow+1.5*c
elseif @av==6
z=(x+flip(y))*@ap*@af(values[i2])
z=(z*p6)^@pow+1.5*c+@ap*@af(values[i2])
elseif @av==7
z=x+flip(y)+@ap*@af(values[i2])
z=(z*p6)^@pow+1.5*c*@ap*@af(values[i2])
endif
i2=i2+1
else
z=x+flip(y)
z=(z*p6)^@pow+1.5*c
endif
bailout:
|z|<@bail
default:
title="Aleator Mandelbox"
magn=2
maxiter=10
param a
caption="Aleator"
default=true
endparam
param av
caption="Aleator Variant"
enum="1""2""3""4""5""6""7""8"
visible=@a==true
endparam
param ap
caption="Aleator Parameter"
default=(1,0)
visible=@a==true
endparam
func af
caption="Aleator Function"
default=ident()
visible=@a==true
endfunc
param ac
caption="Aleator Conditional"
default=100
visible=@a==true
endparam
param seed
caption="Random Seed"
default=12345685
visible=@a==true
endparam
param zp1
caption="Z Parameter 1"
default=(1,0)
endparam
param zp2
caption="Z Parameter 2"
default=(0,0)
endparam
param p6
caption="Z Parameter 3"
default=(2,0)
endparam
param cp1
caption="C Parameter 1"
default=(1,0)
endparam
param cp2
caption="C Parameter 2"
default=(0,0)
endparam
func zf
caption="Z Function"
default=ident()
endfunc
func fn1
caption="C Function 1"
default=ident()
endfunc
func fn2
caption="C Function 2"
default=ident()
endfunc
func cf
caption="C Function 3"
default=ident()
endfunc
param st
caption="Start Type"
enum="Parameter""Pixel"
endparam
param sp
caption="Start Parameter"
default=(1e-6,0)
visible=@st==0
endparam
param pow
caption="Exponent"
default=(1,0)
endparam
param p1
caption="MB Parameter 1"
default=0.4
endparam
param p2
caption="MB Parameter 2"
default=0.1
endparam
param p3
caption="MB Parameter 3"
default=1.2
endparam
param p4
caption="MB Parameter 4"
default=0.8
endparam
param p5
caption="MB Parameter 5"
default=1.9
endparam
param arp
caption="Add Recip Parameter"
default=(0,0)
endparam
param asp
caption="Add Sqr Parameter"
default=(0,0)
endparam
param bail
caption="Bailout"
default=1e12
min=1.0
exponential=true
endparam

}

AleatorFloorPhoenix2 {
global:
float values[#maxiter]
int i=0
int seed=@seed
while i<100
seed=random(seed)
values[i]=seed/#randomrange
i=i+1
endwhile
init:
z=fn1(pixel)
z2=0
z1=fn2(Z)
int i2=0
loop:
z=@zp1*z+@zp2
z=z+@arp/z
z=z+@asp*sqr(z)
z=z^@pow1+p1*z^@pow2+p2*z*z2+floor(values[i2])
z2=z1
i2=i2+1
bailout:
|z|<@bailout
default:
title="Aleator Floor Phoenix 2"
periodicity=0
param p1
caption="Phoenix Parameter 1"
default=(1,0)
endparam
param p2
caption="Phoenix Parameter 2"
default=(1,0)
endparam

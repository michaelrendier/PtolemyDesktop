k=asinh(1/(z/k))
elseif @bf=="exsec"
k=1.3*(1/cos(z/k)-1)
elseif @bf=="aexsec"
k=acos(1/((z/k)+1))
elseif @bf=="excosec"
k=0.45*(1/sin(z/k)-1)
elseif @bf=="aexcosec"
k=asin(1/((z/k)+1))
elseif @bf=="crd"
k=2*sin((z/k)/2)
elseif @bf=="acrd"
k=2*asin((z/k)/2)
elseif @bf=="gd"
k=asin(tanh(z/k))
elseif @bf=="agd"
k=asinh(tan(z/k))

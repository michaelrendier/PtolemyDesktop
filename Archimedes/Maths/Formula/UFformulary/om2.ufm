z=fn2(@sp)
else
z=fn2(pixel)
endif
c=fn1(fn2(pixel))
int i3=0
int i2=0
loop:
while i3<@iter
i3=i3+1
z=@zp1*z+@zp2
z=z+@afp*@aff(z)
float x=real(z)
float y=imag(z)
if x>p1
x=2*p1-x
elseif x<-p1
x=-2*p1-x
endif
if y>p2
y=2*p2-y
elseif y<-p2
y=-2*p2-y
endif
x=x*p3
y=y*p3
float a=sqrt(sqr(x)+sqr(y))
float b=a
if a<p4
b=a/p4^2
elseif a<p5
b=p5/a
endif
x=(x/a)*b
y=(y/a)*b
if @a==true
if @av==0
z=x+flip(y)
z=(z*p6)^@pow+c+@ap*@af(values[i2])
elseif @av==1
z=x+flip(y)+@ap*@af(values[i2])
z=(z*p6)^@pow+c+@ap*@af(values[i2])
elseif @av==2
z=x+flip(y)+@ap*@af(values[i2])
z=(z*p6)^@pow+c
elseif @av==3
z=x+flip(y)
z=(z*p6)^@pow+1.5*c*@ap*@af(values[i2])
elseif @av==4
z=(x+flip(y))*(@ap+1)*@af(values[i2])
z=(z*p6)^@pow+c*(@ap+1)*@af(values[i2])
elseif @av==5
z=(x+flip(y))*(@ap+1)*@af(values[i2])
z=(z*p6)^@pow+c
elseif @av==6
z=(x+flip(y))*(@ap+1)*@af(values[i2])
z=(z*p6)^@pow+c+(@ap+1)*@af(values[i2])
elseif @av==7
z=x+flip(y)+@ap*@af(values[i2])
z=(z*p6)^@pow+c*@ap*@af(values[i2])
endif
i2=i2+1
else
z=x+flip(y)
z=(z*p6)^@pow+c
endif
endwhile
z=@adj*z
bailout:
|z|<=@bail
default:

elseif @sv=="3"
if real(z)>imag(z)
z=flip(z)
endif
elseif @sv=="4"
if real(z)<imag(z)
z=flip(z)
endif
z=-0.5*z
elseif @sv=="5"
if real(z)<imag(z)
z=flip(z)
endif
z=0.5*z
elseif @sv=="6"
if real(z)<imag(z)
z=flip(z)
endif
if real(z)<imag(z)
z=flip(z)
endif
z=-0.5*abs(z)
elseif @sv=="7"
if real(z)<imag(z)
z=flip(z)
endif
z=0.5*abs(z)
elseif @sv=="8"
if real(z)<imag(z)
z=flip(z)
endif
z=0.1*sqr(z)
elseif @sv=="9"
if real(z)<imag(z)
z=flip(z)
endif
z=-0.1*sqr(z)
elseif @sv=="10"
if real(z)<imag(z)
z=flip(z)
endif
z=50*recip(z)
elseif @sv=="11"
if real(z)>imag(z)
z=flip(z)
endif
z=-0.5*z
elseif @sv=="12"
if real(z)>imag(z)
z=flip(z)
endif
z=0.5*z
elseif @sv=="13"
if real(z)>imag(z)
z=flip(z)
endif
z=-0.5*abs(z)
elseif @sv=="14"
if real(z)>imag(z)
z=flip(z)
endif
z=0.5*abs(z)
endif
int i=0
loop:
while i<@iter
i=i+1
z=p1*fn2(recip(fn3(z)))+p4
z=(z-p6)/(1-p6*z)
z=z/(@p7*z+1)
z=z+@p8*sqr(z)
if @Va=="1"
z=z
elseif @Va=="2"
if real(z)<imag(z)
z=flip(z)
endif
elseif @Va=="3"
if real(z)<imag(z)
z=flip(z)
endif
z=flip(z)
elseif @Va=="4"
if real(z)<imag(z)
z=flip(z)
endif
z=-z
elseif @Va=="5"
if real(z)<imag(z)
z=flip(z)
endif
z=-flip(z)
elseif @Va=="6"
if real(z)<imag(z)
z=flip(z)
endif
z=z-0.3*sqr(z)
elseif @Va=="7"
z=z+0.3*cabs(z)
elseif @Va=="8"
z=z^2*(z-4)/(0.3+4*z)
elseif @Va=="9"
z=z^2*(z-4)/(-0.3+4*z)
elseif @Va=="10"
z=z^2*(z-18)/(1-18*z)
elseif @Va=="11"
z=(z+0.075)/(1+0.075*z)
elseif @Va=="12"
z=flip((z+0.075)/(1+0.075*z))
elseif @Va=="13"
z=abs((z-0.075)/(1-0.075*z))
elseif @Va=="14"
z=flip((z-0.075)/(1-0.075*z))
elseif @Va=="15"
if real(z)>imag(z)
z=flip(z)
endif
z=2*abs(z)
elseif @Va=="16"
if real(z)>imag(z)
z=flip(z)
endif
z=-2*abs(z)
elseif @Va=="17"
if real(z)>imag(z)
z=flip(z)
endif
z=1.75*tanh(z)
elseif @Va=="18"
if real(z)<0
z=-real(z)+flip(imag(z))
endif
elseif @Va=="19"
if real(z)<0
z=-real(z)+flip(imag(z))
endif
z=flip(z)
elseif @Va=="20"
if real(z)<0
z=-real(z)+flip(imag(z))
endif
z=2.3*z
endif
z=recip(z)
z=p2*fn4(log(abs((10*z^9-495*z^8+10560*z^7-127050*z^6+946638*z^5\
-4510275*z^4+13667720*z^3-25228500*z^2+25507152*z\
-10628640)/10628640)))^2+p3*@fn5(pixel)
endwhile
z=@adj*z/100
bailout:
|z|<@bail

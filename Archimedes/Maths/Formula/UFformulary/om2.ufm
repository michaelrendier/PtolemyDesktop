Gisti {
init:
z=fn1(pixel)
if @S=="1"
z=(@sp+1)*z+@sp*(z-1i)/(z+1i)
elseif @S=="2"
z=z+(@sp+1)*(z-1i)/(z+1i)
elseif @S=="3"
z=z+(@sp+1)*(z^2-1i)/(z+1)
elseif @S=="4"
z=z^2*(z-(@sp+2))/(1-(@sp+2)*z)
elseif @S=="5"
z=z+(@sp+1)*z^3/(z^2-1i)
elseif @S=="6"
z=z+(@sp+1)*(z-1)*(z+1i)
elseif @S=="7"
z=z+(@sp+1)*(z+1)*(z-1i)
elseif @S=="8"
z=z-(@sp+1)*(3*z^2)/(z^3-1i)
elseif @S=="9"
z=z+(@sp+1)*(z+1)*(z-1i)/(z-1)
elseif @S=="10"
z=z+(@sp+1)*(z+1)/(z-1i)*(z-1)
elseif @S=="11"
z=(@sp+1)*(z+1)/(z-1i)*(z+1i)
elseif @S=="12"
z=(@sp+1)*(z+1)/z*(z+1i)
elseif @S=="13"
z=z+(@sp+1)*(z^2-z-1)/(z+1)
elseif @S=="14"
z=z+(@sp+1)*(z^2-1)
elseif @S=="15"
z=z+(@sp+1)*(z^3-1i)
elseif @S=="16"
z=z+(@sp+1)/exp(z)
endif
loop:
zold=z

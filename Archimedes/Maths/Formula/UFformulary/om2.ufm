elseif @S=="19"
z=z+1.5i*tan(1i*z)
elseif @S=="20"
z=z+1i*tan(1i*z)
elseif @S=="21"
z=z+0.3i*tan(1i*z)
elseif @S=="22"
z=z+1.5i*tanh(1i*z)
elseif @S=="23"

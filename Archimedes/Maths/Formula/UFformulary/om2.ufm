LabsX11J {
init:
z=fn1(pixel)
z=z+@sp*(z-1i)/(z+1i)
int i=0
loop:
while i<@iter
i=i+1
z=p4*fn2(z)+p5
z=(z-p6)/(1-p6*z)
z=z/(@p7*z+1)
z=z+@p8*sqr(z)
z=z+@p9/z
if @Va=="None"
z=z
elseif @Va=="1"
if |z|<1
z=z/|z|
endif
elseif @Va=="2"
if |z|>1
z=z/|z|
endif
elseif @Va=="3"
x=real(z)
y=imag(z)
x=x/|z|
y=y/|z|
z=x+flip(y)
elseif @Va=="4"
z=z+0.3i*sin(z)
elseif @Va=="5"
z=z+0.3i*cosh(z)
elseif @Va=="6"
z=z+0.3i*sqr(z)
elseif @Va=="7"
z=z+exp((z-4i)/(z+4i))
elseif @Va=="8"
z=z+0.3i/exp(z)
elseif @Va=="9"
z=z+0.3i*exp(z)
elseif @Va=="10"
z=z-0.3i/exp(z)
elseif @Va=="11"
z=z+cos((z+4i)/(z-4i))
elseif @Va=="12"
z=z-0.3i*cos(z)
elseif @Va=="13"
z=z+0.3i*z
elseif @Va=="14"
z=z-0.3i*sin(z)
elseif @Va=="15"
z=z+0.3i*sinh(z)
elseif @Va=="16"
z=z-0.3i*cosh(z)
elseif @Va=="17"
z=z+sqr((z-0.3)/(1-0.3*z))
elseif @Va=="18"
z=z-0.3i*sinh(z)
elseif @Va=="19"
z=z-0.3i*exp(z)
elseif @Va=="20"
z=z+exp((z+4i)/(z-4i))
elseif @Va=="21"
z=z-0.3i*sqr(z)
elseif @Va=="22"
z=z-0.3i*z
elseif @Va=="23"
z=z+cos((z-4i)/(z+4i))
elseif @Va=="24"
z=z+0.3i*cos(z)
elseif @Va=="25"
z=z+((z-0.3i)/(z+0.3i))
endif
z=p2*(z^2-p1)^2/(4*z*(z-1)*(z-p1))
z=@p10*fn3(log(abs(z)))+@p11
endwhile
z=z*51/50
bailout:
|z|<@bail

k=1-cos(k/z)
elseif @bf=="aversin"
k=0.3*acos(1-(k/z))
elseif @bf=="haversin"
k=(1-cos(k/z))/2
elseif @bf=="ahaversin"
k=2*asin(sqrt(k/z))

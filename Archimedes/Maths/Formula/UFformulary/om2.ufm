z=z^@pow+@c1
i=i+1
elseif i==1
z=(z^(@pow+1)-1)/(z^(@pow-1)+1)+@c2
i=i+1
else
z=(z^(@pow+2)-1)/(z^@pow+1)+@c3
i=0
endif
elseif @v==1
if i==0
z=z^@pow+@c1
i=i+1
elseif i==1
z=(z^(@pow+2)-1)/(z^@pow+1)+@c3

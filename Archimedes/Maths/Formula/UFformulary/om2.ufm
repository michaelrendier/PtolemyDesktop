HamChunLee {
;https://core.ac.uk/download/pdf/82505151.pdf
;(45)
init:
z=@sf(pixel)
loop:
zold=z
z=@zp1*z+@zp2
if @v==0
f=z^@pow-@c
f1=@pow*z^(@pow-1)
a=z-f/f1
f1a=@pow*a^(@pow-1)
b=z-2*f/(f1+f1a)
fb=b^@pow-@c
elseif @v==1

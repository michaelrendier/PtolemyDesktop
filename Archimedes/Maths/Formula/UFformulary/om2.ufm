init:
z=fn1(pixel)
loop:
zold=z
z=p4*fn2(z)+p5
if @JM=="J"
if @Va=="none"
z=z
elseif @Va=="1"
z=z+1.21/sin(z)
elseif @Va=="2"
z=z+0.3/z
elseif @Va=="3"

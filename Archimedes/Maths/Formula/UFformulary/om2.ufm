z=z+@p7/z
k=k+@p7/k
z=z+p2*sqr(z)
k=k+p2*sqr(k)
k=@p12*k/z+@p13
z=z^4+p3*k+cz
k=tan(k)^2+p4*z+ck
cz=tan(cz)^2+p5*ck+z
ck=tanh(ck)^2+p6*cz+k
bailout:
|z|<@bail
default:

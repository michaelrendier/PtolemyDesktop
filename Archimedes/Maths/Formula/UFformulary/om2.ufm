BivarBarnsley {
init:
z=fn1(pixel)
k=fn1(pixel)
loop:
z=p5*fn2(z)+p6
k=p1*fn2(K)+p2
k=@p7*k/z+@p8
if real(fn3(z))<0
z=p3*(z+k-p4)
else
z=p3*(z+k+p4)
endif
bailout:
|z|<=@bail
default:
title="Bivar Barnsley"
center=(0.001,0.001)
magn=0.5
periodicity=0
param p3
caption="Barnsley Parameter 1"
default=(1,0)
endparam

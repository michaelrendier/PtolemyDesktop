z=p3*fn3(z)+p4
a=p5*fn4(a)+p6
b=z
if @JM=="M"
z=(1-@p7*@fn5(pixel))*(z^3-1)+@p7*@fn5(pixel)*(a^4-1)
a=(1-@p8*@fn5(pixel))*b+@p8*@fn5(pixel)*(b^3-1)
else
z=(1-@fn5(@p7))*(z^3-1)+@fn5(@p7)*(a^4-1)
a=(1-@fn5(@p8))*b+@fn5(@p8)*(b^3-1)

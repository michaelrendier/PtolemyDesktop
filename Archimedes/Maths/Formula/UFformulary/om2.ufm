c=p5*i^fn3(k/z)
elseif @v==3
a=k
k=p2*fn2(k/z)+p3
z=sqr((z^i+c-1)/(2*z+c-2))+sqr((k^i+c-1)/(2*k+c-2))+p4
c=p5*i^fn3(a/z)

elseif @Va=="38"
z=z+0.57064*sqr(z)*cosh(z)
elseif @Va=="39"
z=z+0.92854*z*abs(z)
elseif @Va=="40"
x=real(z)
y=imag(z)
x=x/|z|
y=y/|z|
z=x+flip(y)
elseif @Va=="41"
z=z-0.7*sqr(z)/cotanh(z)

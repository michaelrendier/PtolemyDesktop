a=a+(sinh(a)^3-1i)/(3*sinh(a)^2)
elseif @V=="26"
if |z|<1
z=z/|z|
endif
if |a|<1
a=a/|a|
endif
z=1.5*z
a=1.5*a
endif
z=(z^3-z-p1)/(z^3+z^2-p1)+@p12
a=(a^3-a+p1)/(a^3-a^2+p1)+@p12

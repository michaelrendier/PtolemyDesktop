elseif @sv==7
k=-cotan(z)
elseif @sv==8
k=-cos(z)
elseif @sv==9
k=-recip(z)
elseif @sv==10
k=flip(z)+1
elseif @sv==11
k=sqr(z)+1
elseif @sv==12
k=cotanh(z)+1
elseif @sv==13
k=acosh(z)-1
elseif @sv==14
k=cotan(z)+1
elseif @sv==15

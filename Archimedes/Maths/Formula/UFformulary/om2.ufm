init:
z=fn1(pixel)
int i=0
loop:
i=i+1
z=p6*z+@p7
z=z+@p8*sqrt(z)
z=z+@p9*atanh(z)
z=z+@p10*atan(z)
z=z+@p11*asinh(z)
z=z+@p12*asin(z)
z=z+@p13*ceil(z)
float a=real(z)
if a<p4
z=(z+i)*p1+p2
endif
if p5<=a
z=(z-i)*conj(fn2(p1))+p2
endif
bailout:
|z|<=@bail

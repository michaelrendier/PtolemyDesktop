default=(1,0)
endparam
param zp2
caption="Z Parameter 2"
default=(0,0)
endparam
param pow1
caption="Exponent 1"
default=2
endparam
param pow2
caption="Exponent 2"
default=1
endparam
param seed
caption="Random Seed"
default=12345678
endparam
func fn1
caption="Start Function"
default=ident()
endfunc
func fn2
caption="Phoenix Function"
default=ident()
endfunc
param arp
caption="Add Recip Parameter"
default=(0,0)
endparam
param asp
caption="Add Sqr Parameter"
default=(0,0)
endparam
param bailout
caption="Bailout"
default=100.0
endparam
}

AleatorJBivar2 {
global:
float values[#maxiter]
int i=0
int seed=@seed
while i<100
seed=random(seed)
values[i]=seed/#randomrange
i=i+1
endwhile
init:
z=fn1(pixel)
k=fn1(pixel)
z=z+@sp*fn2(z)
k=k+@sp*fn2(k)
int i2=0
c=@c
loop:
if @av==0
z=@zp1*z+@zp2
k=@kp1*k+@kp2
a=k
k=@bp1*fn3(k/z)+@bp2
z=z^2+a^2+@ap*@af(values[i2])+c
elseif @av==1
z=@zp1*z+@zp2
k=@kp1*k+@kp2
a=k
k=@bp1*fn3(k/z)+@bp2+@ap*@af(values[i2])
z=z^2+a^2+c
elseif @av==2
z=@zp1*z+@zp2
k=@kp1*k+@kp2+@ap*@af(values[i2])
a=k
k=@bp1*fn3(k/z)+@bp2
z=z^2+a^2+c
elseif @av==3
z=@zp1*z+@zp2+@ap*@af(values[i2])
k=@kp1*k+@kp2
a=k
k=@bp1*fn3(k/z)+@bp2
z=z^2+a^2+c
elseif @av==4
z=@zp1*z+@zp2
k=@kp1*k+@kp2
k=@bp1*fn3(k/z)+@bp2
z=z^2+k^2+@ap*@af(values[i2])+c
elseif @av==5
z=@zp1*z+@zp2
k=@kp1*k+@kp2
k=@bp1*fn3(k/z)+@bp2+@ap*@af(values[i2])
z=z^2+k^2+c
elseif @av==6
z=@zp1*z+@zp2
k=@kp1*k+@kp2+@ap*@af(values[i2])
k=@bp1*fn3(k/z)+@bp2
z=z^2+k^2+c
else
z=@zp1*z+@zp2+@ap*@af(values[i2])
k=@kp1*k+@kp2
k=@bp1*fn3(k/z)+@bp2
z=z^2+k^2+c
endif
i2=i2+1
bailout:
|z|<=@bail
default:
title="Aleator J Bivar 2"
center=(0.001,0.001)
periodicity=0
param av
caption="Variant"
enum="1""2""3""4""5""6""7""8"
endparam
param ap
caption="Aleator Parameter"

elseif @S=="27"
z=((pixel^2-1-1i)/(2*cos(pixel)-1-2i))^2
elseif @S=="28"
z=((pixel^2+15-1i)/(2*sin(pixel)+15-2i))^2
elseif @S=="29"
z=((sqr(pixel)^2+14-1i)/(2*pixel+14-2i))^2
elseif @S=="30"
z=((cos(pixel)^2+16-1i)/(2*pixel+16-2i))^2
elseif @S=="31"
z=((conj(pixel)^2+1-1i)/(2*cabs(pixel)+1-2i))^2
elseif @S=="32"
z=((sqr(pixel)^2+8-1i)/(2*tanh(pixel)+8-2i))^2
elseif @S=="33"
z=((sqr(pixel)^2+8-1i)/(2*tan(pixel)+8-2i))^2
elseif @S=="34"

k=trunc(z/k)
elseif @bf=="round"
k=round(z/k)
elseif @bf=="+sqrt"
k=(z/k)+sqrt(z/k)
elseif @bf=="+sqr"
k=(z/k)+sqr(z/k)
elseif @bf=="+cotanh"
k=(z/k)+cotanh(z/k)
elseif @bf=="+cotan"
k=(z/k)+cotan(z/k)
elseif @bf=="+cos"
k=(z/k)+cos(z/k)
elseif @bf=="+sin"
k=(z/k)+sin(z/k)
elseif @bf=="+round"
k=(z/k)+round(z/k)
elseif @bf=="+recip"
k=(z/k)+recip(z/k)
elseif @bf=="-exp"
k=(z/k)-exp(z/k)
elseif @bf=="-log"
k=(z/k)-log(z/k)
elseif @bf=="-acosh"
k=(z/k)-acosh(z/k)
elseif @bf=="-cosh"
k=(z/k)-cosh(z/k)
elseif @bf=="-cos"
k=(z/k)-cos(z/k)
elseif @bf=="*sqrt"
k=(z/k)*sqrt(z/k)
elseif @bf=="*cotanh"
k=(z/k)*cotanh(z/k)
elseif @bf=="*atan"

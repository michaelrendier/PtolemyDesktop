k=@p12*fn2(k/z)+@p13
z=z^z+a^a+p3
else
k=@p12*fn2(k/z)+@p13
z=z^z+k^k+p3
endif
endwhile
z=@adj*z
k=@adj*k
endif
bailout:
(@bt==0 && |z|<@baildiv) || (@bt==1 && |z-zold|>@bailcon)

a=@p10*fn2(a)+@p11

a=p1*a/z+p2
z=(z-1i)/(z+1i)+p1*(a-1i)/(a+1i)+p2

bailout:
(|zold-z|>@bailcon && @bt=="Convergent") || (|z|<@baildiv && @bt=="Divergent")
default:
title="Bivar Cayley"
center=(0.001,0.001)

TrivarMandelbrot {
init:
z=fn1(pixel)
k=fn1(pixel)
w=fn1(pixel)
loop:
zold=z
z=p6*z+@p7
k=@p9*k+@p10
w=@p11*w+@p12
z=z+p4/z
k=k+p4/k
w=w+p4/w
z=z+p5*sqr(z)
k=k+p5*sqr(k)
w=w+p5*sqr(w)
z=z^2+p1*k+p2*w+pixel
k=k^2+p2*w+p3*z+pixel
w=w^2+p3*z+p1*k+pixel
bailout:
(@bt==0 && |z|<@baildiv) || (@bt==1 && |z-zold|>@bailcon)

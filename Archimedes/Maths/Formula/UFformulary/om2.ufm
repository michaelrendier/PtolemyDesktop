k=k+@p10/k
z=z+@p11*sqr(z)
k=k+@p11*sqr(k)
k=p3*fn3(k/z)+p4
z=z^@pow+p1*z*z2+k^@pow+p2*k*k2+c
z2=z1
k2=k1
bailout:

elseif @sv==15
k=sin(z)
elseif @sv==16
k=-sin(z)
elseif @sv==17
k=-recip(z)
else
k=-recip(z)-1
endif
k2=0
k1=fn2(k)
c=p5
loop:
z=p6*z+@p7
k=@p8*k+@p9
z=z+@p10/z
k=k+@p10/k
z=z+@p11*sqr(z)
k=k+@p11*sqr(k)
a=z
k=@p12*fn3(z/k)^2+@p13
z=(z-1)^2+p1*z*z2+(k+1)^2+p2*k*k2+p3*k+c
k=(k-1)^2+p1*a*z2+(a+1)^2+p2*k*k2+p4*a+c
z2=z1
k2=k1
bailout:
|z|<@bailout

elseif @Va=="9"
z=-flip(z)
z=z+0.2*sin(z)
elseif @Va=="10"
if real(z)>imag(z)
z=flip(z)
endif
elseif @Va=="11"
z=-sqr(z)
elseif @Va=="12"
z=cos(z)
elseif @Va=="13"
z=sinh(z)
elseif @Va=="14"
z=sin(z)
elseif @Va=="15"
z=z+0.3/z
elseif @Va=="16"

default=1000.0
endparam
}

Mul {
init:
z=fn1(pixel)
zn=0
zn1=0
zn2=0
if @S==0
z=z+@sp*z^2
elseif @S==1
z=z+(@sp+2.5)/z
elseif @S==2
z=z^2*(z-(@sp+3))/(1-(@sp+3)*z)
elseif @S==3
z=((z^2+@sp+2)/(2*z+@sp+1))^2
elseif @S==4
z=z-(@sp+7)*(z^3-1i)/(3*z^2)
elseif @S==5
z=(@sp-2.5)*(z-1i)/(z+1i)
endif
loop:
zold=z
z=p5*fn2(z)+p6
if @Va=="None"
z=z
elseif @Va=="1"
if |z|<1
z=z/|z|
endif
elseif @Va=="2"
if |z|>1
z=z/|z|
endif
z=0.75*recip(z)
elseif @Va=="3"
z=recip(z)
z=0.96*cotan(z)
elseif @Va=="4"
if real(z)<imag(z)
z=flip(z)
endif
z=0.9*conj(z)
elseif @Va=="5"
if real(z)>imag(z)
z=flip(z)
endif
elseif @Va=="6"
z=z+0.15*z*cos(1-z)
elseif @Va=="7"
z=recip(z)
z=0.895*cotanh(z)
elseif @Va=="8"
if |z|<1
z=z/|z|
endif
z=-abs(z)
elseif @Va=="9"
z=0.5*z*(1-z)
elseif @Va=="10"
z=flip((z^2+1.42779)/(2*z+0.42779))^2
elseif @Va=="11"
if |z|>1
z=z/|z|
endif
z=0.85*cotanh(z)
elseif @Va=="12"
z=z^2*exp((z-2)/(8.1156+2*z))
elseif @Va=="13"
z=z+0.25*z*recip(1-z)
elseif @Va=="14"
z=z-0.3*(recip(z)^3-1i)/(3*recip(z))
elseif @Va=="15"
if |z|<1
z=z/|z|
endif
z=-0.5*sqr(z)
elseif @Va=="16"
z=z^2*sqr((z-4)/(-3.71612+4*z))
elseif @Va=="17"

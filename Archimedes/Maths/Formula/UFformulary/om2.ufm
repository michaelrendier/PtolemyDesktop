elseif @Va=="48"
z=1.5*z*recip(1-z)
elseif @Va=="49"
z=flip((z^2+0.5)/(2*z-0.5))^2
elseif @Va=="50"
z=flip((z^2-6.912-1i)/(2*z-6.912-2i))^2
elseif @Va=="51"
z=cotanh(0.67/(z-1))+1
elseif @Va=="52"
z=flip((z^2-2.5)/(2*z-3.5))^2
elseif @Va=="53"
if real(z)<imag(z)
z=flip(z)
endif
z=-0.36*z

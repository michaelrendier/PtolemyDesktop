elseif @S2=="24"
a=sqr(pixel)*(pixel-2)/(1i-2*pixel)
elseif @S2=="25"
a=1i*sqr(pixel)+pixel
elseif @S2=="26"
a=sqr(pixel)*(sin(pixel)+1)/(1i+sin(pixel))
elseif @S2=="27"
a=sqr(pixel)*(pixel+1)/(1i+pixel)
elseif @S2=="28"
a=sqr(pixel)*(pixel+2)/(1i+2*pixel)
endif
if @S2!=0
a=fn2(a)+p4
else
a=fn2(a)
endif
loop:
zold=z
z=@p8*fn3(z)+@p9
a=@p10*fn4(a)+@p11
if @V=="1"
a=p1*a/z+p2*@fn5(pixel)

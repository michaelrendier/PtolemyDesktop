if real(z)>imag(z)
z=flip(z)
endif
z=1.15*recip(z)
endif
z=(-0.5*(p1*conj(p1/(z-p2))+p2)-a)/(a*(p1*conj(p1/(z-p2))+p2*@fn5(pixel))-0.5)
z=(1i*z+1i)/(-z+1)
z=(-0.5*z+a)/(-a*z-0.5)
z=fn3((z-1i)/(z+1i))+p3
z=@p10*fn4(log(abs(z)))+@p11
endwhile
z=z*51/50
bailout:
|z|<@bail
default:
title="Labs X 3 M"

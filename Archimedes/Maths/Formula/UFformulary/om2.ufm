elseif @bf=="*cos"
k=(z/k)*cos(z/k)
elseif @bf=="*sin"
k=(z/k)*sin(z/k)
elseif @bf=="third"
k=(z/k)/3
elseif @bf=="half"
k=0.5*(z/k)
elseif @bf=="double"
k=2*(z/k)
endif
k=@p8*k+@p9
z=z*(p2+cos(pi*z))/4+((3*z+p3)/16)*(p2-cos(pi*z))*(3-sqrt(2)*cos((2*z-1)*pi/4))+@p8*(k*(p2+cos(pi*k))/4+((3*k+p3)/16)*(p2-cos(pi*k))*(3-sqrt(2)*cos((2*k-1)*pi/4)))+@p9
bailout:
(|z-zold|>@bailcon && @bt=="Convergent") || (|z|<@baildiv && @bt=="Divergent")
default:

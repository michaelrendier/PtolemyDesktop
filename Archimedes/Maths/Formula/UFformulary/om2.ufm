elseif @Va=="43"
z=z-(sinh(z)^3-1i)/(3*sinh(z)^2)
elseif @Va=="44"
z=z^2*(z+2)/(1+2*z)
elseif @Va=="45"
z=z-(tanh(z)^3-1i)/(3*tanh(z)^2)
elseif @Va=="46"

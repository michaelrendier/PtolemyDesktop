z=(z^(@pow+1)-1)/(z^(@pow-1)+1)+@c2
i=i+1
elseif i==1
z=(z^(@pow+2)-1)/(z^@pow+1)+@c3
i=i+1
else
z=z^@pow+@c1
i=0
endif
elseif @v==4
if i==0
z=(z^(@pow+2)-1)/(z^@pow+1)+@c3
i=i+1
elseif i==1
z=(z^(@pow+1)-1)/(z^(@pow-1)+1)+@c2
i=i+1
else
z=z^@pow+@c1
i=0
endif
elseif @v==5
if i==0
z=(z^(@pow+2)-1)/(z^@pow+1)+@c3
i=i+1
elseif i==1
z=z^@pow+@c1
i=i+1
else
z=(z^(@pow+1)-1)/(z^(@pow-1)+1)+@c2
i=0
endif
endif
bailout:
|z|<@bail

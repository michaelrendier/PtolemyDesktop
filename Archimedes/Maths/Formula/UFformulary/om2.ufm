Siviki {
init:
z=fn1(fn2(pixel))
c=fn2(@c)
loop:
z=@zp1*z+@zp2
z=z+@afp*@aff(z)
if real(z)>1
z=2-z+p2
elseif real(z)<-1
z=-2-z-p2
endif
if cabs(z)<0.5
z=4*z
elseif cabs(z)<1
z=z/|z|
endif
z=p1*z^@pow+c
bailout:
|z|<=@bail
default:
title="Siviki"
param p2
caption="Siviki Parameter 1"
default=(0,0)
endparam
param p1
caption="Siviki Parameter 2"
default=(1.0363,-0.0218)
endparam
param c
caption="Julia Seed"
default=(-1.8638,-0.4665)
endparam
func fn1
caption="Start Function 1"
default=ident()
endfunc
func fn2
caption="Start Function 2"
default=ident()
endfunc
param zp1
caption="Z Parameter 1"
default=(1,0)
endparam
param zp2
caption="Z Parameter 2"
default=(0,0)
endparam
param pow
caption="Exponent"
default=(1.0435,-0.0726)
endparam
param @afp
caption="Add Func Parameter"
default=(0,0)
endparam
func aff
caption="Add Func Function"
default=sqr()
visible=@afp!=0
endfunc
param bail
caption="Bailout"
default =100.0
endparam
}

AleatorJuliabox2 {
global:
float values[#maxiter]
int i=0
int seed=@seed
while i<@ac
seed=random(seed)
values[i]=seed/#randomrange
i=i+1
endwhile
init:
z=fn1(fn2(pixel))
c=fn2(@c)
int i3=0
int i2=0
loop:
while i3<@iter
i3=i3+1
z=@zp1*z+@zp2
z=z+@afp*@aff(z)
float x=real(z)
float y=imag(z)
if x>p1
x=2*p1-x
elseif x<-p1
x=-2*p1-x
endif
if y>p2
y=2*p2-y
elseif y<-p2
y=-2*p2-y
endif
x=x*p3
y=y*p3
float a=sqrt(sqr(x)+sqr(y))
float b=a
if a<p4
b=a/p4^2
elseif a<p5
b=p5/a
endif
x=(x/a)*b
y=(y/a)*b
if @a==true
if @av==0
z=x+flip(y)
z=(z*p6)^@pow+c+@ap*@af(values[i2])+@app*pixel
elseif @av==1
z=x+flip(y)+@ap*@af(values[i2])
z=(z*p6)^@pow+c+@ap*@af(values[i2])+@app*pixel
elseif @av==2
z=x+flip(y)+@ap*@af(values[i2])
z=(z*p6)^@pow+c+@app*pixel
elseif @av==3
z=x+flip(y)
z=(z*p6)^@pow+1.5*c*@ap*@af(values[i2])+@app*pixel
elseif @av==4
z=(x+flip(y))*(@ap+1)*@af(values[i2])
z=(z*p6)^@pow+c*(@ap+1)*@af(values[i2])+@app*pixel
elseif @av==5
z=(x+flip(y))*(@ap+1)*@af(values[i2])
z=(z*p6)^@pow+c+@app*pixel
elseif @av==6
z=(x+flip(y))*(@ap+1)*@af(values[i2])
z=(z*p6)^@pow+c+(@ap+1)*@af(values[i2])+@app*pixel
elseif @av==7
z=x+flip(y)+@ap*@af(values[i2])
z=(z*p6)^@pow+c*@ap*@af(values[i2])+@app*pixel
endif
i2=i2+1
else
z=x+flip(y)
z=(z*p6)^@pow+c+@app*pixel
endif
endwhile
z=@adj*z
bailout:
|z|<=@bail
default:
title="Aleator Juliabox 2"
center=(0.001,0.001)
periodicity=0
magn=0.5
maxiter=250
param a
caption="Aleator"
default=false
endparam
param av
caption="Aleator Variant"
enum="1""2""3""4""5""6""7""8"
visible=@a==true
endparam
param ap
caption="Aleator Parameter"
default=(1,0)
visible=@a==true
endparam
func af
caption="Aleator Function"
default=ident()
visible=@a==true
endfunc
param ac
caption="Aleator Conditional"
default=100
visible=@a==true
endparam
param seed
caption="Random Seed"
default=12345678
visible=@a==true
endparam
param iter
caption="Iterations"
default=4
endparam
param c
caption="Julia Seed"
default=(1.2,1.05)
endparam
param p6
caption="JB Parameter 1"
default=(0.95,-0.6)
endparam
param p1
caption="JB Parameter 2"
default=1.0
endparam
param p2
caption="JB Parameter 3"
default=1.0
endparam
param p3
caption="JB Parameter 4"
default=1.0
endparam
param p4
caption="JB Parameter 5"
default=0.5
endparam
param p5
caption="JB Parameter 6"
default=1.0
endparam
func fn1
caption="Start Function 1"
default=ident()
endfunc
func fn2
caption="Start Function 2"
default=ident()
endfunc
param pow
caption="Exponent"
default=(1,0)
endparam
param zp1
caption="Z Parameter 1"
default=(1,0)
endparam
param zp2
caption="Z Parameter 2"
default=(0,0)
endparam
param @afp
caption="Add Func Parameter"
default=(0,0)
endparam
func aff
caption="Add Func Function"
default=sqr()
visible=@afp!=0
endfunc
param app
caption="Add Pixel Parameter"
default=(0,0)
endparam
param adj
caption="Adjustment"
default=1.02
endparam
param bail
caption="Bailout"
default =100.0
endparam
}

AleatorMandelbox2 {
global:
float values[#maxiter]
int i=0

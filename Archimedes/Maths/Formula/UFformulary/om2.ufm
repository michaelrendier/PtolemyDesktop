elseif @Va=="21"
z=z-1.3518*sqr(z)/tanh(z)
elseif @Va=="22"
z=z+z^3
elseif @Va=="23"
z=z+1.32965*sqr(z)/tan(z)
elseif @Va=="24"
z=z+0.5236*sqr(z)/cotanh(z)
elseif @Va=="25"
z=z+0.73407*tan(z)/sqr(z)
elseif @Va=="26"
z=z-1.06059/sinh(z)
elseif @Va=="27"
if |z|>1
z=z/|z|

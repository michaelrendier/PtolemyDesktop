elseif @Va=="15"
z=((cosh(z)^2-7.7106)/(2*cosh(z)-8.7106))^2
elseif @Va=="16"
z=z^2*(abs(z)+1.3)/(1+1.3*abs(z))
elseif @Va=="17"
z=((sqr(z)^2-61)/(2*sqr(z)-62))^2
elseif @Va=="18"
z=((z^2-1.75)/(2*z-2.75))^2
elseif @Va=="19"
z=((sqr(z)^2+217)/(2*sqr(z)+216))^2
elseif @Va=="20"
z=((cos(z)^2+37)/(2*cos(z)+36))^2
elseif @Va=="21"
z=((exp(z)^2+49.33)/(2*exp(z)+48.33))^2
elseif @Va=="22"

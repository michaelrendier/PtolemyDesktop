elseif @S=="21"
z=pixel-(sqr(pixel)-1i)/(sqr(pixel)+1i)
elseif @S=="22"
z=((pixel^2+1-1i)/(2*pixel+1-2i))^2
elseif @S=="23"
z=((pixel^2+5-1i)/(2*recip(pixel)+5-2i))^2
elseif @S=="24"

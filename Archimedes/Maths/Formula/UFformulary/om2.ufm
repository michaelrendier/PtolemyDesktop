"z^p-z^p*(z-0.5)/(1-0.5*z)-z^(p-1)-z^(p-2)-c""z^p+z^p*(z-0.5)/(1-0.5*z)+z^(p-1)+z^(p-2)-c"\
"z^p*(z-1.5)/(1-1.5*z)-c""z^p+z^p*(z-1.5)/(1-1.5*z)-c""z^p-z^p*(z-1.5)/(1-1.5*z)-c"
endparam

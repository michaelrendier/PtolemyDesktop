param p12
caption="X Parameter 3"
default=(0,0)
endparam
param p8
caption="Loop Parameter 1a"
default=(1,0)
endparam
param p9
caption="Loop Parameter 1b"
default=(0,0)
endparam
param p10
caption="Loop Parameter 2a"
default=(1,0)
endparam
param p11
caption="Loop Parameter 2b"
default=(0,0)
endparam
param p5
caption="Möbius Parameter 1"
default=(0,0)
endparam
param p6
caption="Möbius Parameter 2"
default=(0,0)
endparam
func fn1
caption="Start Function"
default=ident()
endfunc
func fn2
caption="Loop Function"
default=ident()
endfunc
func fn3
caption="X Function"
default=ident()
endfunc
param bt
caption="Bailout Type"

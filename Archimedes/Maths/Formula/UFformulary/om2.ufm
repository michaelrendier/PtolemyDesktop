elseif @S=="54"
if |pixel|<1
z=pixel/|pixel|
else
z=pixel
endif
z=z+3i*recip(z)
endif
z=fn1(z)
loop:
zold=z
z=fn2(z)
z=(z-p6)/(1-p6*z)
z=z/(@p10*z+1)
z=z*(1-@p8*z)
if @Va=="none"

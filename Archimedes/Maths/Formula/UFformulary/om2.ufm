z=z+1/conj(flip(z))
elseif @Va=="20"
z=z+1/abs(flip(z))
elseif @Va=="21"
z=z+1/exp(exp(z))
elseif @Va=="22"
z=z-0.2/exp(sqr(z))
elseif @Va=="23"
z=z+1/exp(cotan(z))
elseif @Va=="24"
z=z+1/exp(cosh(z))
elseif @Va=="25"
z=z-0.35*sqr(z)
elseif @Va=="26"
z=z+cosh(z)
elseif @Va=="27"
z=z+0.18*flip(abs(z))
elseif @Va=="28"
z=z-0.18*flip(abs(z))

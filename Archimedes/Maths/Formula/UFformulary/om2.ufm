z=z+p4/z
k=k+p4/k
z=z+p5*sqr(z)
k=k+p5*sqr(k)
a=z
z=z^log(z)+@p12*k+Fn2(pixel)
k=k^log(k)+@p13*a+Fn2(pixel)

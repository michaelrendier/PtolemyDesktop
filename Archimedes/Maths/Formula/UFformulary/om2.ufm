Veydaen {
init:
z=p5
int i=0
c=fn1(pixel)
loop:
i=i+1
z=p6*z+@p7
c=@p8*fn3(c)
if @v==0
z=z^i+p1/fn2(z-p2)^@pow+c
c=c+p3*z^2+p4
elseif @v==1
a=z
z=z^i+p1/fn2(z-p2)^@pow+c
c=c+p3*a^2+p4
elseif @v==2
z=z^i+(p1-0.7)/fn2(z-p2+1.9)^@pow-c
c=c+p3*z^2+p4
else
a=z
z=z^i+(p1-0.7)/fn2(z-p2+1.9)^@pow-c
c=c+p3*a^2+p4
endif
bailout:
|z|<@bail

caption="Start Parameter 1"
default=(0,0)
endparam
func fn1
caption="Start Function"
default=ident()
endfunc
param v
caption="Loop Variant"
enum="1""2""3""4""5""6""7""8"
endparam
param p1
caption="Tengawn Parameter 1"
default=(1,0)
endparam
param p2
caption="Tengawn Parameter 2"
default=(0,0)
endparam
param p3
caption="Tengawn Parameter 3"
default=(1,0)
endparam

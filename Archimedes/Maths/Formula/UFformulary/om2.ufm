elseif @Va=="2"
z=z^2*recip((z+0.5)/(1+0.5*z))
elseif @Va=="3"
z=z^2*exp((z-2)/(1-2*z))
elseif @Va=="4"
z=((z^2-1i)/(2*z-2i))^2
elseif @Va=="5"
z=z^2*sqr((z+2)/(1+2*z))
elseif @Va=="6"
z=z^2*tanh((z+2)/(1i+2*z))

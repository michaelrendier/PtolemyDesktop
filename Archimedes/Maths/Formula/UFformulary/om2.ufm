k=-z-1
elseif @sv==3
k=-1
elseif @sv==4
k=-exp(z)
elseif @sv==5
k=-exp(z)-1
elseif @sv==6
k=sqr(z)-1
elseif @sv==7
k=cotanh(z)-1
elseif @sv==8
k=-cotanh(z)
elseif @sv==9

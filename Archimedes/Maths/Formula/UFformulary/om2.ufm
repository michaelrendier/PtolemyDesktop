BivarKaleidotet {
init:
z=fn1(abs(pixel))
k=-1i*z
loop:
zold=z
z=p6*z+@p7
k=@p8*k+@p9
z=z+p4/z
k=k+p4/k
z=z+p5*sqr(z)
k=k+p5*sqr(k)
a=k
k=p1*fn2(k/z)+p2
z=log(z)^log(z)+log(a)^log(a)+p3
bailout:
|z-zold|>@bail

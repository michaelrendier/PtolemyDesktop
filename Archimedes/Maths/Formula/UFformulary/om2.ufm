z=p4*fn4(log(abs(@fn5((z^2*@p11)+1/(z^3*@p11+1)))))+p5+@p17*@fn6(pixel)
elseif @V=="12"
z=p4*fn4(log(abs(@fn5((z^2*@p11)+1/(z^3*@p11)))))+p5+@p17*@fn6(pixel)

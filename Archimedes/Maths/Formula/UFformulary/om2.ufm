elseif @Va=="15"
z=z+3.63214*z*cotan(z)
elseif @Va=="16"
z=z-0.648*sqr(z)
elseif @Va=="17"
z=z-0.32959*sqr(z)/cotanh(z)
elseif @Va=="18"
z=z-1/z
elseif @Va=="19"

caption="Dioteld Parameter 4"
default=(0,0)
endparam
param p3
caption="Loop Parameter 1"
default=(1,0)
endparam
param p4
caption="Loop Parameter 2"
default=(0,0)
endparam
func fn1
caption="Start Function"
default=ident()
endfunc
func fn2
caption="Loop Function"
default=ident()
endfunc
func fn3
caption="C Function"
default=ident()
visible=@JM=="M"
endfunc
param bt
caption="Bailout Type"
enum="Divergent""Convergent"
default=1
endparam
param bailcon
caption="Bailout"
default=0.00000000001
visible=@bt==1
endparam
param baildiv
caption="Bailout"
default=1000000.0
visible=@bt==0
endparam
}


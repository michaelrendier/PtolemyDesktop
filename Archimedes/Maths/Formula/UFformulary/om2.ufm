elseif @Va=="29"
if real(z)<imag(z)
z=flip(z)
endif
z=-abs(z)
elseif @Va=="30"
z=tanh((z+4.65i)/(z-4.65i))
elseif @Va=="31"
if real(z)<imag(z)
z=flip(z)
endif
z=-7.7*recip(z)
elseif @Va=="32"

elseif @S2=="11"
a=pixel^2+1i
elseif @S2=="12"
a=(sqr(pixel)-1i)/(sqr(pixel)+1i)
elseif @S2=="13"
a=(pixel-1i)/(pixel+1)
elseif @S2=="14"
a=(pixel+1i)/(1i*pixel)

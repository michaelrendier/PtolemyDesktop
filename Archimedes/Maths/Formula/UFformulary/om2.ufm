default=(0.5,0)
visible=@sv==0
endparam
param c1
caption="Pixel Parameter 1"
default=(-0.25,0)
endparam
param c2
caption="Pixel Parameter 2"
default=(1.75,0)
endparam
param c3
caption="Pixel Parameter 3"
default=(2.5,0)
endparam
param c4

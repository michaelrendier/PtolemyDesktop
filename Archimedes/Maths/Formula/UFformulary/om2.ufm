elseif @S2=="19"
a=pixel-sqr(pixel)
elseif @S2=="20"
a=pixel+sqr(pixel)
elseif @S2=="21"
a=pixel-1i/pixel
elseif @S2=="22"
a=pixel-(pixel^2-1i)/(2*pixel)
elseif @S2=="23"

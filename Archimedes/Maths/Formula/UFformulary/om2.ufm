BivarVeydaen {
init:
if @v==0 || @v==1
z=p5
elseif @p5==4
z=p5-1.7
else
z=p5+1.3
endif
k=z
int i=0
c=fn1(pixel)
loop:
i=i+1
z=p6*z+@p7
k=@p12*k+@p13
c=@p8*fn3(c)
if @v==0 || @v==1
z=z+@p11*sqr(z)
k=k+@p11*sqr(k)
else
z=z+(@p11+0.7)*sqr(z)
k=k+(@p11+0.7)*sqr(k)
endif
z=z+@p14/z
k=k+@p14/k
if @v==0
b=k
k=@p9*fn4(z/k)+@p10
z=z^i+p1/fn2(z-p2)^@pow+b^i+p1/fn2(b-p2)^@pow+c
c=c+p3*z^2+p4
elseif @v==1
b=k
a=z
k=@p9*fn4(z/k)+@p10
z=z^i+p1/fn2(z-p2)^@pow+b^i+p1/fn2(b-p2)^@pow+c
c=c+p3*a^2+p4
elseif @v==2
k=@p9*fn4(z/k)+@p10+1
z=z^i+p1/fn2(z-p2)^@pow+k^i+p1/fn2(k-p2)^@pow-c
c=c+p3*z^2+p4
elseif @v==3
a=z
k=@p9*fn4(z/k)+@p10+1
z=z^i+p1/fn2(z-p2)^@pow+k^i+p1/fn2(k-p2)^@pow-c
c=c+p3*a^2+p4
elseif @v==4
k=@p9*fn4(z/k)+@p10
z=z^i+p1/fn2(z-p2)^@pow+k^i+p1/fn2(k-p2)^@pow+c
c=c+p3*z^2+p4+0.5
elseif @v==5
a=z
k=@p9*fn4(z/k)+@p10
z=z^i+p1/fn2(z-p2)^@pow+k^i+p1/fn2(k-p2)^@pow+c
c=c+p3*a^2+p4
else
b=k
a=z
k=@p9*fn4(z/k)+@p10+1
z=z^i+p1/fn2(z-p2+1.65)^@pow+b^i+p1/fn2(b-p2+1.65)^@pow-c
c=c+p3*a^2+p4
endif
bailout:
|z|<@bail
default:
title="Bivar Veydaen"
center=(2.001,0.001)
periodicity=0
param v
caption="Variant"
enum="1""2""3""4""5""6""7"
endparam
param p5
caption="Start Parameter"
default=(-0.3,0)
endparam

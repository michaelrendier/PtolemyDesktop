BivarCayley2 {
init:
z=fn1(pixel)
k=-z
int i=0
loop:
zold=z
if @vers=="1"
z=p6*z+@p7
k=@p8*k+@p9
z=z+p4/z
k=k+p4/k
z=z+p5*sqr(z)
k=k+p5*sqr(k)
a=k
k=p1*fn2(k/z)+p2
z=((z-1i)/(z+1i))^@pow+((a-1i)/(a+1i))^@pow+p3
else
while i<@iter
i=i+1
z=p6*z+@p7
k=@p8*k+@p9
z=z+p4/z
k=k+p4/k
z=z+p5*sqr(z)
k=k+p5*sqr(k)
a=k
k=p1*fn2(k/z)+p2
z=((z-1i)/(z+1i))^@pow+((a-1i)/(a+1i))^@pow+p3
endwhile
z=z*@adj

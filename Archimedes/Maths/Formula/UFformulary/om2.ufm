Stirling2 {
init:
z=@sf(pixel)
loop:
zold=z
z=@zp1*z+@zp2
if @v==0
f=z^@pow-@c
a=@pow*f^(@pow-1)
elseif @v==1
f=z^@pow-z^(@pow-1)-z^(@pow-2)-@c
a=@pow*f^(@pow-1)-(@pow-1)*f^(@pow-2)-(@pow-2)*f^(@pow-3)
else
f=z^@pow+z^(@pow-1)+z^(@pow-2)-@c
a=@pow*f^(@pow-1)+(@pow-1)*f^(@pow-2)+(@pow-2)*f^(@pow-3)

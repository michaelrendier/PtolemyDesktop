Tengawn8 {
init:
z1=p5
z2=@p15
z3=@p18
c=fn1(pixel)
z=pixel
loop:
zold=z
z1=p6*z1+@p7
z2=@p12*z2+@p13
z3=@p19*z3+@p20
c=@p8*fn3(c)
z1=z1+@p11*sqr(z1)
z2=z2+@p11*sqr(z2)
z3=z2+@p11*sqr(z3)
z1=z1+@p14/z1
z2=z2+@p14/z2
z3=z3+@p14/z3
a=z1
b=z2
if @v==0
z1=z1-p1*(z1/3+(c*z1^2+b*(c*b-2*c*z1))/(3*sqr(z1^2-z2^2-z3^2)))+p2*z2*z3+c
z2=z2^2*(z2-p3)/(1-p3*z2)+p4*a*z3+c
z3=z3-@p16*(z3^4-z3^3-4*z3^2+7*c*z3-2)/(z3^3-3*z3^2+z3+3)+@p17*a*b+c
elseif @v==1
z1=z1-p1*(z1/3+(c*z1^2+b*(c*b-2*c*z1))/(3*sqr(z1^2-z2^2-z3^2)))+p2*z2*z3+c
z2=sqr((z2^2+p3-2)/(2*z2+p3-3))+p4*a*z3+c
z3=z3-@p16*(z3^4-z3^3-4*z3^2+7*c*z3-2)/(z3^3-3*z3^2+z3+3)+@p17*a*b+c
elseif @v==2
z1=z1-p1*(z1/3+(c*z1^2+b*(c*b-2*c*z1))/(3*sqr(z1^2-z2^2-z3^2)))+p2*z2*z3+c
z2=z2^2*(1-p3*z2)/(z2-p3)+p4*a*z3+c
z3=z3-@p16*(z3^4-z3^3-4*z3^2+7*c*z3-2)/(z3^3-3*z3^2+z3+3)+@p17*a*b+c
elseif @v==3
z1=z1-p1*(z1/3+(c*z1^2+b*(c*b-2*c*z1))/(3*sqr(z1^2-z2^2-z3^2)))+p2*z2*z3+c
z2=sqr((2*z2+p3-2)/(z2^2+p3-1))+(p4-1.75)*a*z3+c
z3=z3-@p16*(z3^4-z3^3-4*z3^2+7*c*z3-2)/(z3^3-3*z3^2+z3+3)+@p17*a*b+c
elseif @v==4
z1=z1-p1*(z1/3+(c*z1^2+b*(c*b-2*c*z1))/(3*sqr(z1^2-z2^2-z3^2)))+p2*z2*z3+c
z2=z2-(p3-1.8)*((z2^3-1)/(3*z2^2*(z2-(z2^3-1)/(6*z2^2))))+p4*a*z3+c
z3=z3-@p16*(z3^4-z3^3-4*z3^2+7*c*z3-2)/(z3^3-3*z3^2+z3+3)+@p17*a*b+c
elseif @v==5
z1=z1-p1*(z1/3+(c*z1^2+b*(c*b-2*c*z1))/(3*sqr(z1^2-z2^2-z3^2)))+p2*z2*z3+c
z2=z2-(p3-1.6)*((3*z2^2*(z2-(z2^3-1)/(6*z2^2)))/(z2^3-1))+p4*a*z3+c
z3=z3-@p16*(z3^4-z3^3-4*z3^2+7*c*z3-2)/(z3^3-3*z3^2+z3+3)+@p17*a*b+c
else
z1=z1-p1*(z1/3+(c*z1^2+b*(c*b-2*c*z1))/(3*sqr(z1^2-z2^2-z3^2)))+p2*z2*z3+c
z2=z2-(p3-2.9)*(z2^3-1)*(3*z2^2)/((3*z2^2)^2-(z2^3-1)*(6*z2))+p4*a*z3+c
z3=z3-@p16*(z3^4-z3^3-4*z3^2+7*c*z3-2)/(z3^3-3*z3^2+z3+3)+@p17*a*b+c
endif
z=z1+z2+z3
bailout:
|z-zold|>@bail
default:
title="Tengawn 8"
center=(-0.751,0.001)
magn=1.5

endparam
param p13
caption="Add Sqr Parameter"
default=(0,0)
endparam
param bail
caption="Bailout"
default=10000000.0
endparam
}

BivarX17 {
init:
z=fn1(pixel)
k=-z
loop:
zold=z
z=p6*z+@p7
k=@p8*k+@p9
z=z+p4/z
k=k+p4/k
z=z+p5*sqr(z)
k=k+p5*sqr(k)
a=k
k=p1*fn2(k/z)+p2
z=((z-@p10)/(1-@p10*z))^@pow+((a-@p10)/(1-@p10*a))^@pow+p3
bailout:
(@bt==0 && |z|<@baildiv) || (@bt==1 && |z-zold|>@bailcon)

LabsX14 {
init:
z=fn1(pixel)
if @S=="1"
z=z^2+@sp*(2*z-1i)/(z+2i)/(z-1)
elseif @S=="2"
z=z+(z-@sp*1i)/(z+@sp*1i)
elseif @S=="3"
z=(z+@sp*1i)/(z-@sp*1i)
elseif @S=="4"
z=z^2*(z-@sp)/(1-@sp*z)
elseif @S=="5"
z=(cotanh(z)-@sp*1i)/(z+cotanh(@sp))
elseif @S=="6"
z=z+((z^2+@sp-1)/(2*z+@sp-2))^2
elseif @S=="7"
z=z^2*((z-(@sp-0.5))/(1-(@sp-0.5)*z))
elseif @S=="8"
z=(z+@sp*1i)/(z-@sp*1i)
elseif @S=="9"
z=@sp*(z+1i)*(z-1)/(z+1)
elseif @S=="10"
z=@sp*(z+1i)*(z-1)/(z-1i)
elseif @S=="11"
z=z+z^2*cosh((z-@sp)/(1-@sp*z))
elseif @S=="12"
z=z+@sp*z^3
elseif @S=="13"
z=@sp*(z-0.5)/(1-0.5*z)/(z-1i)
elseif @S=="14"
z=@sp*(z-0.5)/(1i-0.5*z)/(z-1)
elseif @S=="15"
z=(sqr(z)-@sp*1i)/(z+sqr(@sp))
elseif @S=="16"
z=z+z^2*cos((z-@sp)/(1-@sp*z))
elseif @S=="17"
z=z^2*sqr((z-(@sp-0.5))/(1-(@sp-0.5)*z))
elseif @S=="18"
z=z^2*exp((z-(@sp-0.5))/(1-(@sp-0.5)*z))
endif
int i=0
loop:
while i<@iter
i=i+1
z=@p12*fn2(z)+@p13
z=(z-p6)/(1-p6*z)
z=z/(@p7*z+1)
z=z+@p8*sqr(z)
z=z+@p9/z
if @Va=="None"
z=z
elseif @Va=="1"
z=z-1/sqr(z)
elseif @Va=="2"
z=z+(z+1i)/(z-1i)
elseif @Va=="3"
if real(z)<imag(z)
z=flip(z)
endif
z=0.67*conj(z)
elseif @Va=="4"
z=z-cotanh(z)
elseif @Va=="5"
if real(z)>imag(z)
z=flip(z)
endif
z=0.5*z
elseif @Va=="6"
z=z+(sqr(z)+1)/(sqr(z)-1)
elseif @Va=="7"
if |z|<1
z=z/|z|
endif
z=0.75*z
elseif @Va=="8"
z=z+(z+1)/(z-1)
elseif @Va=="9"
z=z+cotan(z)
elseif @Va=="10"
if real(z)>imag(z)
z=flip(z)
endif
z=0.54*conj(z)
elseif @Va=="11"
z=z+(z-1)/(z+1)
elseif @Va=="12"
if real(z)<imag(z)
z=flip(z)
endif
z=-0.67*z
elseif @Va=="13"
z=z+1/cosh(z)
elseif @Va=="14"
z=z-tan(z)
elseif @Va=="15"
z=z+cotanh((z-1i)/(z+1i))
elseif @Va=="16"
z=z+(exp(z)-1)/(exp(z)+1)
elseif @Va=="17"
if real(z)<imag(z)
z=flip(z)
endif
z=-0.67*conj(z)
elseif @Va=="18"
z=z+(exp(z)+1)/(exp(z)-1)
elseif @Va=="19"
z=((z^2-0.8)/(2*z-1.8))^2
elseif @Va=="20"
z=z+1/sin(z)
elseif @Va=="21"
z=conj((z-0.155)/(1-0.155*z))
elseif @Va=="22"
z=z+tanh(z)
elseif @Va=="23"
z=cotan(-1/(z-1))+1
elseif @Va=="24"
z=conj((z-0.258)/(1-0.258*z))
elseif @Va=="25"
z=flip((z+0.177)/(1+0.177*z))
elseif @Va=="26"
z=z-tanh(z)
elseif @Va=="27"
if real(z)<imag(z)
z=flip(z)
endif
z=-abs(z)
elseif @Va=="28"
z=z+(sinh(z)-1)/(sinh(z)+1)
elseif @Va=="29"
z=cotanh(-1/(z-1))+1
elseif @Va=="30"
z=z+(z-1i)/(z+1i)
elseif @Va=="31"
z=z+1i*tan(1i*z)
elseif @Va=="32"
z=z+tan(z)
elseif @Va=="33"
z=z+(sqr(z)-1)/(sqr(z)+1)
elseif @Va=="34"
z=z+cotanh(z)
elseif @Va=="35"
z=z+(recip(z)+1)/(recip(z)-1)
elseif @Va=="36"
z=z+(sinh(z)+1)/(sinh(z)-1)
endif
if real(z)>imag(z)
z=flip(z)
endif
z=(p1-1.45)*abs(z)+p2
z=((z^2-0.8)/(2*z-1.8))^2
z=(z^2/(2*z-1))^2
f=z+1/z
f1=1-1/z^2
z=z-p3*f/f1
if @JM=="J"
z=@p10*fn4(log(abs(z)))+(@p11-1)
else
z=@p10*fn4(log(abs(z)))+@p11*@fn5(pixel)
endif
endwhile
z=z*51/50
bailout:
|z|<@bail

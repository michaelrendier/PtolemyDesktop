z=z+1.5i*tanh(1i*z)
elseif @S=="23"
z=z+1.5i*cosh(1i*z)
elseif @S=="24"
z=z+1i*cosh(1i*z)
elseif @S=="25"
z=z+1i*cos(1i*z)

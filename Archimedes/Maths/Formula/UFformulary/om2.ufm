else
a=p3*a/z+p2*fn3(pixel)
z=1i*(z-p1)^2-(z-p1)^3+p3*1i*(a-p1)^2-(a-p1)^3+p2*fn3(pixel)
endif
else
if @JM=="J"
a=p3*z/a+p2
z=1i*(z-p1)^2-(z-p1)^3+p3*1i*(a-p1)^2-(a-p1)^3+p2
else
a=p3*z/a+p2*fn3(pixel)
z=1i*(z-p1)^2-(z-p1)^3+p3*1i*(a-p1)^2-(a-p1)^3+p2*fn3(pixel)
endif
endif

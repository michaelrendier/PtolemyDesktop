k=@p9*k+@p10
z=z+@p11*sqr(z)
k=k+@p11*sqr(k)
z=z+@p12/z
k=k+@p12/k
a=z
k=p2*fn2(z/k)+p3
if @v==0
z=z^i*(z-c)/(1-c*z)+p4*k
k=k^i*(k-c)/(1-c*k)+p5*a
elseif @v==1
z=z^i*(z-c)/(1-c*z)+p4*k

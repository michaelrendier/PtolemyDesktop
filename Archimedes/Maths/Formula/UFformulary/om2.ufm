elseif @Va=="41"
z=1.25*(3*z^2)/(z^3-1)
elseif @Va=="42"
z=z^2*sinh((z-4)/(-1+4*z))
endif
if @MV=="1"
z=p1*z^2*(z^3-z+p2*fn3(pixel))/(z^3-z^2+p2*fn3(pixel))+@p9
elseif @MV=="2"
z=p1*fn3(pixel)*z^2*(z^3-z+p2)/(z^3-z^2+p2)+@p9
elseif @MV=="3"
z=p1*fn3(pixel)*z^2*(z^3-z+p2*fn3(pixel))/(z^3-z^2+p2*fn3(pixel))+@p9
elseif @MV=="4"
z=p1*fn3(pixel)*z^2*(z^3-z+p2*fn3(pixel))/(z^3-z^2+p2)+@p9
elseif @MV=="5"

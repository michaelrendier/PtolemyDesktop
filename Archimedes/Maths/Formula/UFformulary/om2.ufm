elseif @Va=="22"
z=z-0.75*sin(z)
elseif @Va=="23"
z=abs((z+1i)/(z-1i))
elseif @Va=="24"
z=z-0.5*sqr(z)
elseif @Va=="25"
z=exp((z+1i)/(z-1i))
elseif @Va=="26"
z=exp((z+0.3i)/(z-0.3i))
elseif @Va=="27"

caption="Veydaen Parameter 1"
default=(0.5,0)
endparam
param p2
caption="Veydaen Parameter 2"
default=(3.5,0)
endparam
param p3
caption="Veydaen Parameter 3"
default=(-1,0)
endparam
param p4
caption="Veydaen Parameter 4"
default=(0,0)
endparam
param p9
caption="Bivar Parameter 1"
default=(-0.3,0)
endparam
param p10
caption="Bivar Parameter 2"
default=(0,0)
endparam
param p6
caption="Z Parameter 1"
default=(1,0)
endparam
param p7
caption="Z Parameter 2"
default=(0,0)
endparam
param p12
caption="k Parameter 1"
default=(1,0)
endparam

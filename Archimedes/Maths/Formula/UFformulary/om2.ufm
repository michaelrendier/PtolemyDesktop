elseif @Va=="25"
z=z^2*(z+5)/(1+5*z)
elseif @Va=="26"
z=z+sin(z^2/(z+0.67))
elseif @Va=="27"
z=z^2*(tanh(z)-2)/(0.5i+2*tanh(z))
elseif @Va=="28"
z=z+sqr(z^2/(z+2))
elseif @Va=="29"
z=z+1.5*(recip(z)^3-1i)/(3*recip(z)^2)
elseif @Va=="30"

loop:
i=i+1
z=@zp1*z+@zp2
k=@kp1*k+@kp2
z=z+@asp*sqr(z)
k=k+@asp*sqr(k)
z=z+@arp/z
k=k+@arp/k
a=k
k=@bp1*@bf1(z/k)+@bp2
z=sqr(z-a)^i+c
c=c+@bp3*@bf2(tan(k/z))
bailout:
|z|<@bail

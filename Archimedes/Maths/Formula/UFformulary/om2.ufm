z=z+(@sp+1)*z^3/(z^2-1i)
elseif @S=="6"
z=z+(@sp+1)*(z-1)*(z+1i)
elseif @S=="7"
z=z+(@sp+1)*(z+1)*(z-1i)
elseif @S=="8"
z=z-(@sp+1)*(3*z^2)/(z^3-1i)
elseif @S=="9"
z=z+(@sp+1)*(z+1)*(z-1i)/(z-1)
elseif @S=="10"
z=z+(@sp+1)*(z+1)/(z-1i)*(z-1)
elseif @S=="11"
z=(@sp+1)*(z+1)/(z-1i)*(z+1i)
elseif @S=="12"
z=(@sp+1)*(z+1)/z*(z+1i)
elseif @S=="13"

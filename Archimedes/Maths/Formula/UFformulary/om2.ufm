z=z-0.3*flip(abs(z))
elseif @Va=="40"
z=z-0.45*abs(cabs(z))
elseif @Va=="41"
z=z-0.1*cabs(exp(z))
elseif @Va=="42"
z=z+z/sin(z)
elseif @Va=="43"
z=z-0.25/sin(z)

LabsX22 {
init:
z=fn1(pixel)
z=z+@sp*z^2
int i=0
loop:
while i<@iter
i=i+1
z=@p12*fn2(z)
z=(z-p6)/(1-p6*z)
z=z/(@p7*z+1)
z=z+@p8*sqr(z)
if @Va=="None"
z=z
elseif @Va=="1"
if real(z)<imag(z)
z=flip(z)
endif
elseif @Va=="2"
if real(z)<imag(z)
z=flip(z)
endif
z=flip(z)
elseif @Va=="3"
if real(z)<imag(z)
z=flip(z)
endif
z=-z
elseif @Va=="4"
if real(z)<imag(z)
z=flip(z)
endif
z=-flip(z)
elseif @Va=="5"
if real(z)<imag(z)
z=flip(z)
endif
z=z-0.3*sqr(z)
elseif @Va=="6"
if real(z)<imag(z)
z=flip(z)
endif
z=z+cabs(z)
elseif @Va=="7"
z=z^2*(z-8)/(1-8*z)
elseif @Va=="8"
z=z^2*(z-8)/(1+8*z)
elseif @Va=="9"
z=z+0.3i*exp(z)
elseif @Va=="10"
z=z-0.3*cabs(z)
elseif @Va=="11"
z=z-0.3i*sin(z)
elseif @Va=="12"
z=z-0.3*flip(z)
elseif @Va=="13"
z=z+0.3*cos(z)
elseif @Va=="14"
z=z-0.3*abs(z)
elseif @Va=="15"
z=z+0.3*cabs(z)
elseif @Va=="16"
z=z+0.3i*abs(z)
elseif @Va=="17"
z=z+0.3i*sqr(z)
elseif @Va=="18"
z=z+0.3i*cos(z)
elseif @Va=="19"
z=z-0.3*sqr(z)
elseif @Va=="20"
z=z+0.3*sin(z)
elseif @Va=="21"
z=z-0.3*cos(z)
elseif @Va=="22"
z=z+0.3i*sin(z)
elseif @Va=="23"
z=z-0.3i*cos(z)
elseif @Va=="24"
z=z+0.3*flip(z)
elseif @Va=="25"
z=z+0.3*abs(z)
elseif @Va=="26"
z=z-0.3i*sqr(z)
elseif @Va=="27"
z=z-0.3*sin(z)
elseif @Va=="28"
z=z-0.3i*exp(z)
elseif @Va=="29"
z=z+0.3*sqr(z)
elseif @Va=="30"
z=z-0.3i*abs(z)
endif
z=p1*z*fn3(cos(1-z))+p2
z=(10*z^9-495*z^8+10560*z^7-127050*z^6+946638*z^5-4510275*z^4+13667720*z^3-25228500*z^2+25507152*z-10628640)/10628640
z=@p10*fn4((log(abs(z))))+@p11*@fn5(pixel)
endwhile
z=z*51/50
bailout:
|z|<@bail

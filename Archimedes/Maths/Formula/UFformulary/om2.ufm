endparam
}

ModifiedNewton2 {
init:
if @S=="1"
z=pixel
elseif @S=="2"
z=pixel+1i*exp(1i*pixel)
elseif @S=="3"
z=pixel+2i*exp(1i*pixel)
elseif @S=="4"
z=pixel+3i*exp(1i*pixel)
elseif @S=="5"
z=pixel+0.3i*sqr(1i*pixel)
elseif @S=="6"
z=pixel-0.3i*sqr(1i*pixel)
elseif @S=="7"
z=pixel+1i*sqr(1i*pixel)
elseif @S=="8"
z=pixel-1i*sqr(1i*pixel)

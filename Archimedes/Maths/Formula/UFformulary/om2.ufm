elseif @Va=="31"
z=z^2*(z-0.42)/(1i-0.42*z)
elseif @Va=="32"
z=z^2*exp((z-0.08873)/(1i-0.08873*z))
endif
z=fn4(p1^2*z*(1-z^2)*(1-p1*z*(1-z)))+p2^fn3(pixel)
bailout:

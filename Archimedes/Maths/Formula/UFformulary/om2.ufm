elseif @Va=="19"
z=z+0.3i*z*cos(z)
elseif @Va=="20"
z=-1.675*z*sin(1-z)
elseif @Va=="21"
z=0.2*(0.2/(z^2-1))+1
elseif @Va=="22"
z=0.5*flip(0.5/(z^2-1))+1
elseif @Va=="23"
z=0.375*abs(0.375/(z^2-1))+1
elseif @Va=="24"
z=-0.575*abs(-0.575/(z^2-1))+1
elseif @Va=="25"
z=0.5i*(0.5/(z^2-1))+1
elseif @Va=="26"
z=0.6i*flip(0.6/(z^2-1))+1
elseif @Va=="27"
z=0.35i*flip(0.35/(z^2-1))+1
elseif @Va=="28"
z=0.35i*conj(0.35/(z^2-1))+1
elseif @Va=="29"

DasDebataDevaney {
;Das-Debata iteration from
;https://link.springer.com/article/10.1007/s11071-017-3813-6
;(21)
init:
if @jm==0
z=@sf(pixel)
else
z=@sp
endif
c=@sf(pixel)
loop:
z=@zp1*z+@zp2
z=z+@as*sqr(z)
z=z+@ar/z
if @jm==0
u=(1-@p1)*z+@p1*(z^@pow1a+@jsa/(z-@mpa)^@pow2a)
z=(1-@p2)*z+@p2*(u^@pow1b+@jsb/(u-@mpb)^@pow2b)
else
u=(1-@p1)*z+@p1*(z^@pow1a+@ppa*c/(z-@mpa)^@pow2a)
z=(1-@p2)*z+@p2*(u^@pow1b+@ppb*c/(u-@mpb)^@pow2b)
endif
bailout:
|z|<@bail

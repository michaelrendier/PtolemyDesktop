Yedib {
init:
z=p5
k=@p15
int i=0
c=fn1(pixel)
loop:
i=i+1
z=p6*z+@p7
k=@p12*k+@p13
c=@p8*fn3(c)
z=z+@p11*sqr(z)
k=k+@p11*sqr(k)
z=z+@p14/z
k=k+@p14/k
a=z
b=k
if @v==0
k=p1*fn2(k*z)-p2*z^i/k+c
z=p3*z*b^i+p4*fn4(b/z)+c
elseif @v==1
k=(p1-3.2)*fn2(k*z)-p2*z^i/k+c
z=p3*z*k^i+p4*fn4(k/z)+c
elseif @v==2
k=p1*fn2(k*z)-p2*z^i/k+c
z=(p3+5.5)*z*b^i+p4*fn4(z/b)+c
elseif @v==3
k=p1*fn2(k*z)-p2*z^i/k+c
z=(p3+6.15)*z*k^i+(p4-1.1)*fn4(z/k)+c
elseif @v==4

caption="Exponent"
default=(3,0)
endparam
param zp1
caption="Z Parameter 1"
default=(1,0)
endparam
param zp2
caption="Z Parameter 2"
default=(0,0)
endparam
func sf
caption="Start Function"
default=ident()
endfunc
param bail
caption="Bailout"
default=0.000000000001
endparam
}


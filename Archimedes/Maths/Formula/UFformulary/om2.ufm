LabsMunster2M {
init:
z=fn1(pixel)
if @S=="1"
z=(z^2-(@sp+1))/(z^2+(@sp+1))
elseif @S=="2"
z=(z^2-(@sp+1)*1i)/(z^2+(@sp+1)*1i)
elseif @S=="3"
z=(z-(@sp+1)*1i)/(z+(@sp+1)*1i)
elseif @S=="4"
z=(z-(@sp+1))/(z+(@sp+1))
elseif @S=="5"
z=z+((z^2+@sp-1i)/(2*z+@sp+2i))^2
elseif @S=="6"
z=z+((z^2+@sp-1)/(2*z+@sp+2))^2
elseif @S=="7"
z=((z^2+@sp-1i)/(2*z+@sp+2i))^2
elseif @S=="8"
z=((z^2+@sp-1)/(2*z+@sp+2))^2
elseif @S=="9"
z=z+(@sp+1)*sqr(z)
elseif @S=="10"
z=z+(@sp+1)/z
elseif @S=="11"
z=z+z^2*(z-(@sp+0.5))/(1-(@sp+0.5)*z)
elseif @S=="12"
z=z+z^2*(z-(@sp+0.5))/(1i-(@sp+0.5)*z)
elseif @S=="13"
z=z^2*(z-(@sp+0.5))/(1-(@sp+0.5)*z)
elseif @S=="14"
z=z^2*(z-(@sp+0.5))/(1i-(@sp+0.5)*z)
elseif @S=="15"
z=z+(@sp+1)*z*(1-z)
elseif @S=="16"
z=z+(@sp+1)*z*(1i-z)
elseif @S=="17"
z=(@sp+1)*z*(1-z)
elseif @S=="18"
z=(@sp+1)*z*(1i-z)
endif
int i=0
loop:
while i<@iter
i=i+1
z=p4*fn2((z))+p5
z=(z-p6)/(1-p6*z)
z=z/(@p7*z+1)
z=z+@p8*sqr(z)
z=z+@p9/z
if @Va=="None"
z=z
elseif @Va=="1"
z=z+1i/cos(z)
elseif @Va=="2"
z=z-exp(z)
elseif @Va=="3"
z=z-0.4*cosh(z)
elseif @Va=="4"
z=z+sqr(z)
elseif @Va=="5"
if real(z)<imag(z)
z=flip(z)
endif
elseif @Va=="6"
z=z-2*tan(z)
elseif @Va=="7"
z=z+1/cosh(z)
elseif @Va=="8"
z=z-cos(z)
elseif @Va=="9"
z=z-2*sinh(z)
elseif @Va=="10"
z=z+0.38i*cotan(z)
elseif @Va=="11"
z=z-1/cos(z)
elseif @Va=="12"
z=z-1/sin(z)
elseif @Va=="13"
z=z+1i/z
elseif @Va=="14"
z=z+1i*sin(z)
elseif @Va=="15"
z=z+1i/cosh(z)
elseif @Va=="16"
z=z+1/sinh(z)
elseif @Va=="17"
z=z-1i/sinh(z)
elseif @Va=="18"
z=z-1i/sin(z)
elseif @Va=="19"
z=z+0.3i*sqr(z)
elseif @Va=="20"
z=z-0.4*cos(z)
elseif @Va=="21"
z=z+tanh(z)
elseif @Va=="22"
z=z-0.75*sin(z)
elseif @Va=="23"
z=z-0.3i*tanh(z)
elseif @Va=="24"
z=z-0.5*sqr(z)
elseif @Va=="25"
z=z+0.38i*cotanh(z)
elseif @Va=="26"
z=z+0.3i*tanh(z)
elseif @Va=="27"
z=z-1i/cosh(z)
elseif @Va=="28"
z=z+1i/sqr(z)
elseif @Va=="29"
z=z+1/sqr(z)
elseif @Va=="30"
z=z+0.3*sinh(z)
elseif @Va=="31"
z=z-cotanh(z)
elseif @Va=="32"
z=z-0.3*tan(z)
elseif @Va=="33"
z=z-1.7*cosh(z)
elseif @Va=="34"
z=z+1i*cotanh(z)
elseif @Va=="35"
z=z-0.5i*exp(z)
elseif @Va=="36"
z=z-3*sin(z)
elseif @Va=="37"
z=z-2*tanh(z)
elseif @Va=="38"
z=z-1/sinh(z)
elseif @Va=="39"
z=z-1i/cos(z)
elseif @Va=="40"
z=z-1i*sinh(z)
elseif @Va=="41"
z=z+1i/sin(z)
elseif @Va=="42"
z=z-1/sqr(z)
elseif @Va=="43"
z=z-1i*sin(z)
elseif @Va=="44"
z=z-1i/sqr(z)
elseif @Va=="45"
z=z+1i*sinh(z)
elseif @Va=="46"
z=z+1i*tanh(z)
elseif @Va=="47"
z=z+recip(z)
elseif @Va=="48"
z=z+1i/sinh(z)
elseif @Va=="49"
z=z+0.4*cos(z)
elseif @Va=="50"
z=z+1i*cotan(z)
elseif @Va=="51"
z=z-0.3i*sqr(z)
elseif @Va=="52"
z=z-1i/z
elseif @Va=="53"
z=z-1.5i*exp(z)
elseif @Va=="54"
z=z-0.3*sinh(z)
elseif @Va=="55"
z=z+1/sin(z)
elseif @Va=="56"
z=z-tan(z)
elseif @Va=="57"
z=z+cotanh(z)
elseif @Va=="58"
z=z-2.6*cos(z)
elseif @Va=="59"
z=z-1/cosh(z)
elseif @Va=="60"
z=z+cotan(z)
elseif @Va=="61"
z=z-tanh(z)
endif
z=exp(p1*1i)*((p2*fn3(pixel)-z)/(1-conj(p2)*z))^2/z+p3
z=@p10*fn4(log(abs(z)))+@p11
endwhile
z=z*51/50
bailout:
|z|<@bail

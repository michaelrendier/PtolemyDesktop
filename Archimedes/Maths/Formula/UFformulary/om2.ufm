Kreen {
init:
z=fn1(pixel)
int i=0
loop:
while i<@iter
i=i+1
z=fn2(z)
if @JM=="J"
if @Va=="none"
z=z
elseif @Va=="1"
if real(z)<imag(z)
z=flip(z)
endif
elseif @Va=="2"
if real(z)>imag(z)
z=flip(z)
endif
elseif @Va=="3"
z=1/flip(conj(z))
elseif @Va=="4"
z=1/flip(abs(z))

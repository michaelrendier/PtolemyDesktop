k=-exp(z)+1
elseif @sv==14
k=-exp(z)-1
elseif @sv==15
k=sqr(z)
elseif @sv==16
k=-sqr(z)
elseif @sv==17
k=-recip(z)-1
elseif @sv==18
k=sqr(z)+1
elseif @sv==19
k=sqr(z)-1
elseif @sv==20
k=1-sqr(z)
elseif @sv==21
k=-sqr(z)-1
elseif @sv==22
k=cotanh(z)
elseif @sv==23
k=-cotanh(z)
elseif @sv==24
k=cotanh(z)+1
elseif @sv==25
k=cotanh(z)-1
elseif @sv==26
k=1-cotanh(z)
elseif @sv==27
k=-cotanh(z)-1
elseif @sv==28
k=cos(z)
elseif @sv==29
k=-cos(z)
elseif @sv==30
k=cos(z)+1
elseif @sv==31
k=cos(z)-1
elseif @sv==32
k=1-cos(z)
elseif @sv==33
k=-cos(z)-1
elseif @sv==34
k=sin(z)
elseif @sv==35
k=-sin(z)
elseif @sv==36
k=sin(z)+1
elseif @sv==37
k=sin(z)-1
elseif @sv==38

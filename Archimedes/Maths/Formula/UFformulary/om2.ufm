elseif @Va=="9"
z=cotan((z-4)/(2.5+4*z))
elseif @Va=="10"
z=z^2*tan((z-4)/(-1+4*z))
elseif @Va=="11"
z=(sqr(z)-0.67)/(1-0.67*z)
elseif @Va=="12"
z=-1.25*(z^3-1)/(3*z^2)
elseif @Va=="13"
z=cotan((z-4)/(-2.5+4*z))
elseif @Va=="14"
z=(cosh(z)+3)/(1+3*z)
elseif @Va=="15"
z=z+0.3i/cosh(z)
elseif @Va=="16"
z=-1.25*(3*z^2)/(z^3-1)
elseif @Va=="17"

caption="Loop Function 2"
default=ident()
endfunc
param p7
caption="Pongbrot Parameter"
default=(1,0)
endparam
func fn5
caption="C Function"
default=ident()
visible=@JM=="M"
endfunc
param bt
caption="Bailout Type"
enum="Convergent""Divergent"
default=1
endparam
param bailcon
caption="Bailout"
default=0.000000001
visible=@bt==0
endparam
param baildiv
caption="Bailout"
default=100.0
visible=@bt==1
endparam
}

Munster13 {
init:
z=fn1(pixel)+p1
a=fn2(pixel)+p2
loop:
zold=z
z=p3*fn3(z)+p4
a=p5*fn4(a)+p6
if @JM=="J"
a=z*(@p7*a-a^3)/(@fn5(@p8)+@p7*a^2)
z=a*(@p7*z-z^3)/(@fn5(@p8)+@p7*z^2)
else
a=z*(@p7*a-a^3)/(@p8*@fn5(pixel)+@p7*a^2)
z=a*(@p7*z-z^3)/(@p8*@fn5(pixel)+@p7*z^2)
endif
bailout:
(|zold-z|>@bailcon && @bt=="Convergent") || (|z|<@baildiv && @bt=="Divergent")
default:

endparam
}

LabsX6M {
init:
z=fn1(pixel)
if @S=="1"
z=z^2+@sp*(2*z-1i)/(z+2i)/(z-1)
elseif @S=="2"
z=z+@sp*(2*z-1i)/(z+2i)*(z-1)
elseif @S=="3"
z=z^2+@sp*(2*z-1i)/(z+2i)*(z-1)
elseif @S=="4"
z=z+@sp*(2*z-1i)/(z+2i)/(z-1)
elseif @S=="5"
z=@sp*(2*z-1i)/(z+2i)*(z-1)
elseif @S=="6"
z=@sp*(2*z-1i)/(z+2i)/(z-1)
elseif @S=="7"
z=z^2+@sp*(2*z-1i)/(z+2i)/(z-1i)
elseif @S=="8"
z=z^2+@sp*(2*z-1i)/(z+2i)*(z-1i)
elseif @S=="9"
z=@sp*(z+1i)*(z-1)/(z+1)
elseif @S=="10"
z=@sp*(z+1i)*(z-1)/(z-1i)
elseif @S=="11"
z=@sp*(z-2)/(1-2*z)/(z-1i)
elseif @S=="12"
z=@sp*(z-2)/(1i-2*z)/(z-1)
elseif @S=="13"
z=@sp*(z-0.5)/(1-0.5*z)/(z-1i)
elseif @S=="14"
z=@sp*(z-0.5)/(1i-0.5*z)/(z-1)
endif
int i=0
loop:
while i<@iter
i=i+1
z=p4*fn2(z)+p5
z=(z-p6)/(1-p6*z)
z=z/(@p7*z+1)
z=z+@p8*sqr(z)
z=z+@p9/z
if @Va=="1"
z=z+z^2*sqr((z-3)/(1-3*z))
elseif @Va=="2"
if real(z)<imag(z)
z=flip(z)
endif
z=0.1*sqr(z)
elseif @Va=="3"
z=sqr((z+0.425)/(1+0.425*z))
elseif @Va=="4"
z=z-3*(z^3-1)/(3*z^2)
elseif @Va=="5"
z=((z^2-4)/(2*z-5))^2
elseif @Va=="6"
z=recip((z^2-1)/(2*z-2))^2
elseif @Va=="7"
z=sinh((z^2-4)/(2*z-5))^2
elseif @Va=="8"
z=recip((z^2+2)/(2*z+1))^2
elseif @Va=="9"
z=((z^2-1)/(2*z-2))^2
elseif @Va=="10"

ShiftedStirling {
init:
z=@sf(pixel)
loop:
zold=z
z=@zp1*z+@zp2
if @v==0
f=z^@pow-@c
a=@pow*(z-f)^(@pow-1)
elseif @v==1
f=z^@pow-z^(@pow-1)-z^(@pow-2)-@c
a=@pow*(z-f)^(@pow-1)-(@pow-1)*(z-f)^(@pow-2)-(@pow-2)*(z-f)^(@pow-3)
else
f=z^@pow+z^(@pow-1)+z^(@pow-2)-@c
a=@pow*(z-f)^(@pow-1)+(@pow-1)*(z-f)^(@pow-2)+(@pow-2)*(z-f)^(@pow-3)
endif
z=z-@sp*f/a
bailout:
|z-zold|>=@bail
default:

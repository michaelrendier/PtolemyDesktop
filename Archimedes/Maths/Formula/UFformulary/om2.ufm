elseif @S=="14"
z=z+(@sp+1)*(z^2-1)
elseif @S=="15"
z=z+(@sp+1)*(z^3-1i)
elseif @S=="16"
z=z+(@sp+1)/exp(z)
endif
loop:
z=p3*fn2(z)+p4
z=(z-@p7)/(1-@p7*z)
z=z/(@p8*z+1)
z=z+p5/z
z=z+p6*sqr(z)
if @Va=="None"
z=z
elseif @Va=="1"
z=z-0.5*tan(z)
elseif @Va=="2"
z=z+0.3/sqr(z)
elseif @Va=="3"

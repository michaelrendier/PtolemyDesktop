elseif @S=="27"
z=z*(1i-0.9*cos(z))
elseif @S=="28"
z=((z^2-2.5)/(2*z-3.5))^2
elseif @S=="29"
z=z-(cos(z)-1i)/(cos(z)+1i)
elseif @S=="30"
z=(z-1i)/(z+1i)
elseif @S=="31"
z=-0.75*((tan(z)^2-1i)/(2*tan(z)-2i))^2
elseif @S=="32"
z=-(sqr(z)-1i)/(sqr(z)+1i)
elseif @S=="33"

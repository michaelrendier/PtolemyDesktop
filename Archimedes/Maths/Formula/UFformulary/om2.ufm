func fn1
caption="Start Function"
default=ident()
endfunc
func fn2
caption="Loop Function"
default=ident()
endfunc
param bt
caption="Bailout Type"
enum="Convergent""Divergent"
endparam
param bailcon
caption="Bailout"
default=0.000000001
visible=@bt==0
endparam
param baildiv
caption="Bailout"
default=4.0
visible=@bt==1
endparam

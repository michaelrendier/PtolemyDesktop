z=z-0.3*cotan(z)/z
elseif @Va=="19"
z=z+cotan(z)/z
elseif @Va=="20"
z=z-0.3/cosh(z)
elseif @Va=="21"
z=z+1/tan(z)
elseif @Va=="22"
z=z-0.3*tan(z)/z
elseif @Va=="23"
z=z-0.3*z/cotanh(z)
elseif @Va=="24"
z=z+0.3*sqr(z)*sinh(z)
elseif @Va=="25"
z=z+0.3*tan(z)/z
elseif @Va=="26"
z=z+0.3/tanh(z)
elseif @Va=="27"
z=z-0.3*tanh(z)/z
elseif @Va=="28"
z=z+0.3/sinh(z)
elseif @Va=="29"
z=z+cotanh(z)/z
elseif @Va=="30"
z=z-tan(z)/z
elseif @Va=="31"
z=z+0.3*tanh(z)
elseif @Va=="32"
z=z-0.2/sqr(z)
elseif @Va=="33"
z=z-0.3*z/sin(z)
elseif @Va=="34"
z=z-0.3/tanh(z)
elseif @Va=="35"
z=z+0.3*z/sin(z)
elseif @Va=="36"
z=z+1/sqr(z)
elseif @Va=="37"
z=z-0.3*z/sinh(z)
elseif @Va=="38"
z=z-1/tanh(z)
elseif @Va=="39"
z=z-0.3*z/cos(z)
elseif @Va=="40"
z=z+0.3*z/sinh(z)
elseif @Va=="41"
z=z-0.5/sqr(z)
elseif @Va=="42"
z=z-0.3*sqr(z)*cosh(z)
elseif @Va=="43"
z=z+1/sinh(z)
elseif @Va=="44"
z=z+0.3*sqr(z)*sin(z)
elseif @Va=="45"
z=z+0.3*sqr(z)*cosh(z)
elseif @Va=="46"
z=z-0.1/z
elseif @Va=="47"
z=z-sqr(z)*cosh(z)

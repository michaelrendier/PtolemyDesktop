}

ErreugalM {
; A modification of the Laguerre root finding algorithm
init:
z=fn1(pixel)
loop:
zold=z
z=p3*fn2(z)
z=z*(1-p4*z)
if @Va=="none"
z=z
elseif @Va=="1"
z=z+0.5/sinh(sqr(z))
elseif @Va=="2"
z=z-0.5*sqr(cotanh(z))
elseif @Va=="3"
z=z-0.01*cotanh(z)^4
elseif @Va=="4"
z=z-0.035*cotan(z)^4
elseif @Va=="5"
z=0.08/sqr(z)
elseif @Va=="6"
z=-0.1/sqr(z)
elseif @Va=="7"
z=0.04675/abs(sqr(z))
elseif @Va=="8"
z=-0.6/tan(sqr(z))
elseif @Va=="9"
z=-1.2/tan(tan(z))
elseif @Va=="10"
z=z-0.75/exp(z)
elseif @Va=="11"
z=-0.3/z^4
elseif @Va=="12"
z=-1/z
elseif @Va=="13"
z=0.085*cotanh(cotan(z))

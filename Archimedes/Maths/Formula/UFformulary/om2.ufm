elseif @Va=="65"
z=z-0.15*flip(z)/z
elseif @Va=="66"
z=z-0.15*z^4
elseif @Va=="67"
z=z-0.15/z
elseif @Va=="68"
z=z-0.25*abs(cos(z))
elseif @Va=="69"
z=z-0.2/exp(sqr(z))
elseif @Va=="70"
z=z+0.4/cos(z)
elseif @Va=="71"
z=z-0.2/conj(cotan(z))
elseif @Va=="72"
z=z-z/tan(z)
elseif @Va=="73"
z=z-5/exp(cotanh(z))
elseif @Va=="74"
z=z-0.12*sin(sqr(z))

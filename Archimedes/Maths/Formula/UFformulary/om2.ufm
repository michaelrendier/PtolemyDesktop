z=z/|z|
endif
z=flip(z)
elseif @Va=="17"
z=z+0.3/sinh(z)
elseif @Va=="18"
z=z+1i/z
elseif @Va=="19"
z=z-0.3/sqr(z)
elseif @Va=="20"
z=z+0.3i/sin(z)
elseif @Va=="21"
if |z|>1
z=z/|z|
endif

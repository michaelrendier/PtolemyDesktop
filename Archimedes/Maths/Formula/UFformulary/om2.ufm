elseif @Va=="43"
z=2*exp((1-z)/z)
elseif @Va=="44"
z=0.42*z*(1-exp(z))
elseif @Va=="45"
z=0.355*cosh((1-z)/z)
elseif @Va=="46"
if real(z)<imag(z)
z=flip(z)
endif
z=-3*recip(z)
elseif @Va=="47"

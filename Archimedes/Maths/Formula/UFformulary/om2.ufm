elseif @Va=="31"
z=z^2*(tan(z)-2)/(2*tan(z))
elseif @Va=="32"
z=z+(z/(z-2i))
elseif @Va=="33"
z=z+2*(z^3-1i)/(3*z^2)
elseif @Va=="34"
z=z+(sqr(z)^3-1i)/(3*sqr(z)^2)
elseif @Va=="35"

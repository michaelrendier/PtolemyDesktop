elseif @S2=="9"
a=sqr(pixel)*(pixel+2)/(1i+2*pixel)
elseif @S2=="10"
a=pixel+pixel^2+pixel^3
elseif @S2=="11"
a=pixel^2+1i
elseif @S2=="12"
a=(sqr(pixel)-1i)/(sqr(pixel)+1i)
elseif @S2=="13"
a=(pixel-1i)/(pixel+1)
elseif @S2=="14"
a=(pixel+1i)/(1i*pixel)
elseif @S2=="15"
a=sqr(pixel)*(cotan(pixel)+1)/(1i+cotan(pixel))
elseif @S2=="16"
a=(pixel^3-1i)/(pixel^3+1i)

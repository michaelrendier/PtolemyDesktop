elseif @sv==5
k=1-exp(z)
elseif @sv==6
k=1-log(z)
elseif @sv==7
k=-sqrt(z)
elseif @sv==8
k=1+sqrt(z)
elseif @sv==9
k=sqr(z)
elseif @sv==10
k=recip(z)-1
endif
c=@cf(pixel)

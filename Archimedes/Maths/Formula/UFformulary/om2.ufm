elseif @Va=="14"
if |z|>1
z=z/|z|
endif
z=2*abs(z)
elseif @Va=="15"
z=z+0.3*1i/cotan(1i*z)
elseif @Va=="16"
if |z|>1
z=z/|z|
endif
z=-2*z
elseif @Va=="17"
if real(z)<imag(z)
z=flip(z)
endif
z=-0.67*conj(z)
elseif @Va=="18"
z=z+0.3*1i/cosh(1i*z)
elseif @Va=="19"
z=((z^2-0.8)/(2*z-1.8))^2
elseif @Va=="20"
if real(z)<imag(z)
z=flip(z)
endif
z=0.67*z
elseif @Va=="21"
z=conj((z-0.155)/(1-0.155*z))
elseif @Va=="22"
z=(z-2i)/(z+2i)
elseif @Va=="23"
z=cotan(-1/(z-1))+1
elseif @Va=="24"
z=conj((z-0.258)/(1-0.258*z))
elseif @Va=="25"
z=flip((z+0.177)/(1+0.177*z))
elseif @Va=="26"
if real(z)<imag(z)
z=flip(z)
endif
z=-0.67*recip(z)
elseif @Va=="27"
if real(z)<imag(z)
z=flip(z)
endif
z=-abs(z)
elseif @Va=="28"
z=z+0.3*(z^2-1)/(2*z)
elseif @Va=="29"
z=cotanh(-1/(z-1))+1
elseif @Va=="30"
if |z|>1
z=z/|z|
endif
z=abs(z)
elseif @Va=="31"
z=z+1i*tan(1i*z)
elseif @Va=="32"
if |z|>1
z=z/|z|
endif
z=2*conj(z)
elseif @Va=="33"
if real(z)<imag(z)
z=flip(z)
endif
z=-3*recip(z)
elseif @Va=="34"
z=((z-0.587)/(1-0.587*z))
elseif @Va=="35"
if |z|>1
z=z/|z|
endif
z=-2*conj(z)
endif
if real(z)>imag(z)
z=flip(z)
endif
z=p1*abs(z)
z=z*(1+p2*z^2+p3*fn3(z)^2)
z=@p10*fn4(log(abs(z)))+@p11*@fn5(pixel)
endwhile
z=z*51/50
bailout:
|z|<@bail

elseif @Va=="55"
z=z+recip(z^2/(z-1.5))
endif
z=p1*fn3(pixel)*Z^2*(Z-4)/(p2+4*Z)+p3
bailout:
(@bt==0 && |z|<@baildiv) || (@bt==1 && |zold-z|>@bailcon)
default:
title="Munster 10 M"

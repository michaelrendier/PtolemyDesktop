DazPlusMinM {;Mandelbrot version
init:
  z=#pixel
loop:
  x=#pixel+z
  a=fn1(x)
  b=fn1(x-1)
  c=fn1(x+1)
  z=(a*b*c)/(a+b+c)
bailout:
  |z|<=@bailout
default:
  title="DazPlusMinM"
  param bailout
    default=4.0
    min=0.0
    caption="Bailout"
    hint="The bailout value"
  endparam
}

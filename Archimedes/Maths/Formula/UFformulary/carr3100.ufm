Carr3115 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
                  ; * Warning : Very Slow Render *
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  b4=1/log(exp(pixel2^450-cosh(pixel2^50.5)))
  z=conj(pixel2^3)+.5-conj(.1/pixel2-flip(.01/pixel2))
  IF (@p3==1)
    c = |b4|
  ELSEIF (@p3==0)
    c = -b4, z = -z
  ELSE
    IF (whitesq)
      c = |b4|
    ELSE
      c = -b4, z = -z
    ENDIF
  ENDIF
  k = (-.7456,-.132)
  ct1 = |c/9|^4 + k
  ct2 = 2*c^2 + k
  c1=1.5*z,c2=2.25*z,c3=3.375*z,c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0,float zro = 0
loop:
  IF (iter==l1)
    ct1 = |c1/9|^4 + k, ct2 = 2*c1^2 + k, z = z*zro
  ELSEIF (iter==l2)
    ct1 = |c2/9|^4 + k, ct2 = 2*c2^2 + k, z = z*zro
  ELSEIF (iter==l3)
    ct1 = |c3/9|^4 + k, ct2 = 2*c3^2 + k, z = z*zro
  ELSEIF (iter==l4)
    ct1 = |c4/9|^4 + k, ct2 = 2*c4^2 + k, z = z*zro
  ENDIF
  z=z^2+ct1-.0038*|.2*z^3+z*z+ct2|
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3115"
  periodicity = 0
  maxiter = 700
  magn = 1.2
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3

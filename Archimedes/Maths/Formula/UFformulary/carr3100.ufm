Carr3152 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  z=(sin(pixel2)-tan(pixel2))/(sin(pixel2)-abs(pixel2^4))
  c=pixel2^2-.1/z-conj(.1/pixel2)-flip(.01/pixel2)
  IF (@p4==0)
    c = -|c|, z = -z
  ELSEIF (@p4==2)
    IF (whitesq)
      c = -|c|, z = -z
    ENDIF
  ENDIF
  ct = (-.7456,-.132) + |c/8|/pixel2
  z1=imag(p1)*z-p2
  int iter=0,int limit=round(real(p1)),float bailout=16
loop:
  IF (iter==limit)
    z = z1, ct = (-.7456,-.132) + |p3/8|/pixel2
  ENDIF
  z = z^2 + ct
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3152"
  periodicity = 0
  maxiter = 700
  magn = .4
  center = (0,-.5)
  method = multipass
  param p1

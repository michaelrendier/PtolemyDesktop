    z = 0, ct1 = |c2/9|^4 + k, ct2 = 2*c2/3 + k
  ELSEIF (iter==l3)
    z = 0, ct1 = |c3/9|^4 + k, ct2 = 2*c3/3 + k
  ELSEIF (iter==l4)
    z = 0, ct1 = |c4/9|^4 + k, ct2 = 2*c4/3 + k
  ENDIF
  z=z^2+ct1-.0025*|.2*z^3+z^2+ct2|

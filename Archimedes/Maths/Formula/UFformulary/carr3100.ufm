Carr3106 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  z=conj(abs(pixel2))^3/cotan(.1-pixel2)^1.3-.5
  c=tanh(pixel2)^3/cotan(.1-pixel2)^1.3
  IF (@p3==0)
    c = -c, z = -z
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -c, z = -z
    ENDIF
  ENDIF
  k = (-.7456,-.132)
  ct1 = (c/9)^4 + k
  ct2 = 2*c/3 + k
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    z = 0, ct1 = (c1/9)^4 + k, ct2 = 2*c1/3 + k
  ELSEIF (iter==l2)
    z = 0, ct1 = (c2/9)^4 + k, ct2 = 2*c2/3 + k
  ELSEIF (iter==l3)
    z = 0, ct1 = (c3/9)^4 + k, ct2 = 2*c3/3 + k
  ELSEIF (iter==l4)
    z = 0, ct1 = (c4/9)^4 + k, ct2 = 2*c4/3 + k
  ENDIF
  z=z^2+ct1-.0025*|.2*z^3+z^2+ct2|
  iter=iter+1
bailout:

Carr3187 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  d=log(1/pixel2-conj(1/pixel2))
  z=abs(cotanh(.35-pixel2)^1.5*conj(pixel2)^2 \
    -1/log(conj(.1/pixel2+1.25))^2.5)+.19
  c=pixel2+.25/(atan(.1/pixel2)+sqr(acos(.25/-pixel2))^3.7)
  IF (@p4==0)
    c = -c, z = -z
  ELSEIF (@p4==2)
    IF (whitesq)
      c = -c, z = -z
    ENDIF
  ENDIF
  k = (-.7456,-.132) + flip(|d/100*pixel2|)
  ct = |c/10| + k
  z1=imag(p1)*z-p2
  int iter=0,int limit=round(real(p1)),float bailout=16
loop:
  IF (iter==limit)
    z = z1, ct = |p3/10| + k
  ENDIF
  z = z^2 + ct
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3187"
  periodicity = 0
  maxiter = 700
  magn = 16
  center = (0,.001)
  method = multipass
  param p1
    caption = "Iter Lim/Z-Scale"
    default = (100,2)
    hint = "The real part of this parameter is the iteration \
            limit, at which point the iterated value is reset. \
            The imag. part is the scalar multiplier of 'z' \
            when iterations reach Iter Lim."
  endparam
  param p2
    caption = "Z-Offset"
    default = (-.3,0)
    hint = "This is the complex constant added to 'z' at the \
            point when iterations reach Iter Lim."
  endparam
  param p3
    caption = "C-Value"
    default = (.3485,.075)
    hint = "This is the new value of 'c', changed when \
            iterations reach Iter Lim."
  endparam
  param p4
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}


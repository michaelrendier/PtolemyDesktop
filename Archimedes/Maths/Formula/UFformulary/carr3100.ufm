Carr3111 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  z=pixel2^3^exp(.02*pixel2)+.25
  c=cabs(z^6)/cotanh(.1-pixel2)+conj(.1/pixel2)
  IF (@p3==0)
    c = -|c|, z = -z
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -|c|, z = -z
    ENDIF
  ENDIF
  k =  (-.7456,-.132)
  ct1 = (c/9)^4 + k
  ct2 = .0025*(c*2/3 + k)
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    ct1 = (c1/9)^4 + k, ct2 = .0025*(c1*2/3 + k), z = 0
  ELSEIF (iter==l2)
    ct1 = (c2/9)^4 + k, ct2 = .0025*(c2*2/3 + k), z = 0
  ELSEIF (iter==l3)
    ct1 = (c3/9)^4 + k, ct2 = .0025*(c3*2/3 + k), z = 0
  ELSEIF (iter==l4)
    ct1 = (c4/9)^4 + k, ct2 = .0025*(c4*2/3 + k), z = 0
  ENDIF
  z = .9975*z^2 - .0005*z^3 + ct1 - ct2
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3111"
  periodicity = 0
  maxiter = 700
  magn = 1.5
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"

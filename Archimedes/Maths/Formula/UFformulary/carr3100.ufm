loop:
  IF (iter==l1)
    ct = (c1/8) + k, z = 0
  ELSEIF (iter==l2)
    ct = (c2/8) + k, z = 0
  ELSEIF (iter==l3)
    ct = (c3/8) + k, z = 0
  ELSEIF (iter==l4)
    ct = (c4/8) + k, z = 0
  ENDIF
  z = z^2 + ct
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3131"
  periodicity = 0
  maxiter = 700
  magn = 1.4
  center = (0,.05)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"

Carr3191 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  d=log(1/pixel2-cos(1/pixel2))
  b3=exp(.0025/pixel2)/conj(cos(.1-pixel2))-conj(.01/pixel2)
  z=flip(pixel2^3)-cabs(pixel2)^6-conj(.1/pixel2 \
     -flip(.01/pixel2))+.25
  c=cabs(pixel2/2)-pixel2^5+conj(.1/b3)
  IF (@p3==0)
    c = -c, z = -abs(z)
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -c, z = -abs(z)
    ENDIF
  ENDIF
  c1=1.5*z^1.2,c2=2.25*conj(z)
  c3=3.375*flip(z),c4=5.0625*flip(z)
  k = (-.7456,-.132) + flip(|d/100*pixel2|)
  ct = |c/10| + k
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    ct = |c1/10| + k, z = 0
  ELSEIF (iter==l2)
    ct = |c2/10| + k, z = 0
  ELSEIF (iter==l3)
    ct = |c3/10| + k, z = 0
  ELSEIF (iter==l4)
    ct = |c4/10| + k, z = 0
  ENDIF
  z = z^2 + ct
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 3191"
  periodicity = 0
  maxiter = 700
  magn = 1.3
  center = (0,-.1)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (200,300)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (400,550)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"

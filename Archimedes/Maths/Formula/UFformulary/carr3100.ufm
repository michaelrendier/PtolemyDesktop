    ct1 = |c1/9|^4 + k1, ct2 = 2*c1^2 + k2, z = 0
  ELSEIF (iter==l2)
    ct1 = |c2/9|^4 + k1, ct2 = 2*c2^2 + k2, z = 0
  ELSEIF (iter==l3)
    ct1 = |c3/9|^4 + k1, ct2 = 2*c3^2 + k2, z = 0
  ELSEIF (iter==l4)
    ct1 = |c4/9|^4 + k1, ct2 = 2*c4^2 + k2, z = 0
  ENDIF
  z=z^2+ct1-.0038*|.2*z^3+z^2+ct2|
  iter=iter+1
bailout:
  |z|<=bailout
default:

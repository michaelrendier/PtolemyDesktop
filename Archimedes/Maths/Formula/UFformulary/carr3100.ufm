Carr3134 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  z=abs(pixel2^5)-pixel2*((.3,.6)+pixel2)-conj(.1/pixel2)+.25
  c=z^2-conj(.1/z-flip(.01/z))^2 \
    -conj(.1/pixel2-flip(.01/pixel2))^3
  IF (@p3==0)
    c = -c, z = -z
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -c, z = -z
    ENDIF
  ENDIF
  c1=1.5*cabs(z/2),c2=2.25*conj(z/2)
  c3=3.375*flip(z/2),c4=5.0625*z^2
  k = (-.7456,-.144)
  ct = c/10 + k - |.0035/c/21|
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    ct = c1/10 + k - |.0035/c1/21|, z = 0
  ELSEIF (iter==l2)
    ct = c2/10 + k - |.0035/c2/21|, z = 0
  ELSEIF (iter==l3)
    ct = c3/10 + k - |.0035/c3/21|, z = 0
  ELSEIF (iter==l4)
    ct = c4/10 + k - |.0035/c4/21|, z = 0
  ENDIF
  z = z^2 + ct
  iter=iter+1
bailout:
  |z|<=bailout
default:

Carr3110 (YAXIS) {; Updated for UF2 by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  z=flip(pixel2)*conj(pixel2)*cabs(pixel2)/cotanh(.1-pixel2) \
    -.35-conj(.01/pixel2)
  c=flip(pixel2^2)*conj(pixel2/2)*cabs(pixel2) \
    /flip(abs(.33-pixel2))

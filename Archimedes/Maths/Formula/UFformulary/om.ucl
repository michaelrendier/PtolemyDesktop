elseif @v=="Yf"
float b=cabs(p3*10*fn2(log(cabs(fn3(z^20-228*z^15+494*z^10+228*z^5+1))))-3*p4)
else
float b=cabs(p3*10*fn2(log(cabs(fn3(z^30+522*z^25-10005*z^20-10005*z^10-522*z^5+1))))-3*p4)
endif
if b<a
a=b
endif
final:
#index=sqrt(a)*75/256
default:

Boubaker {
init:
float a=1e100
loop:
z=p1*fn1(#z)+p2
if @Va=="1"
if cabs(z)>1
z=z/cabs(z)
endif
elseif @Va=="2"
if cabs(z)<1
z=z/cabs(z)
endif
elseif @Va=="3"
z=z
elseif @Va=="4"
if real(z)<imag(z)
z=flip(z)
endif
elseif @Va=="5"
if real(z)>imag(z)
z=flip(z)
endif
endif

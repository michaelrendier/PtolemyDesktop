Texturation3 {
; This is a modification of 'Perlin Noise' by Mark Townsend (mt.ucl)
; Original code by Ken Perlin
global:
int i[514]
float a[514,2]
int i2=0
int i3=0
int i4=0
int seed=@seed
while i2<256
i[i2]=i2
i3=0
while i3<2
seed=random(seed)
a[i2,i3]=seed/#randomrange
i3=i3+1
endwhile
float m=sqrt(a[i2,0]*a[i2,0]+a[i2,1]*a[i2,1])
a[i2,0]=a[i2,0]/m

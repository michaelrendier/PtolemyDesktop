elseif @V=="Kam Torus"
z=real(z)*cos(p1)+(real(z)^2-imag(z))*sin(p1)+flip(real(z)*sin(p1)-(real(z)^2-imag(z))*cos(p1))
elseif @V=="Kampyle of Eudoxus"
z=p1^2*real(z)^4-p2^4*(real(z)^2+imag(z)^2)

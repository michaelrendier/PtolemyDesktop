z=x+flip(y)
elseif @V=="Hopalong Mod 2"
x=imag(z)-cabs(p2*real(z)-p3)*real(z)/cabs(real(z))
y=p1-real(z)
z=x+flip(y)
elseif @V=="Hopalong Mod 3"
x=imag(z)-cos(cabs(p2*real(z)-p3))*real(z)/cabs(real(z))
y=p1-real(z)
z=x+flip(y)
elseif @V=="Hopalong Mod 4"

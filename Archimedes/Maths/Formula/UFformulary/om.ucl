elseif @V=="Hyperbola"
z=real(z)^2/p1^2-imag(z)^2/@p2^2-1
elseif @V=="Hyperelliptic Curve"
z=imag(z)^2-real(z)*(real(z)+1)*(real(z)-3)*(real(z)+2)*(real(z)-2)

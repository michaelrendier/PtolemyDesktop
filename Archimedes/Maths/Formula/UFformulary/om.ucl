elseif @V=="4"
b=fn2(log(#z^2*fn3((#z-4)/(p3+4*#z))))
elseif @V=="5"
z=#z
if |z|<1
z=z/|z|
endif
b=fn2(log(-p3*fn3(z)))
elseif @V=="6"
z=#z
if |z|>1
z=z/|z|
endif
b=fn2(log(p3*fn3(z)))
elseif @V=="7"
z=#z
if real(z)<imag(z)
z=flip(z)
endif
b=fn2(log(p3*fn3(z)))
elseif @V=="8"
z=#z
if real(z)>imag(z)
z=flip(z)
endif
b=fn2(log(p3*fn3(z)))
elseif @V=="9"
b=fn2(log(-p3*fn3((#z-1i)/(#z+1i))))
elseif @V=="10"

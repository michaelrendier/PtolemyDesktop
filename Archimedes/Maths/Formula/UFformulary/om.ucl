elseif @V=="Latoocarfian"
z=sin(p1*imag(z))+p2*sin(p1*real(z))+flip(sin(p3*real(z))+p4*sin(p3*imag(z)))
elseif @V=="Lemniscate of Bernoulli"
z=(real(z)^2+imag(z)^2)^2-(p1+1)^2*(real(z)^2-imag(z)^2)

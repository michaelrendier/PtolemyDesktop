+42*imag(z)^2*real(z)^4+42*imag(z)^2*real(z)^2+2*imag(z)^3*real(z)^4+26*imag(z)^3*real(z)^2\
+8*imag(z)^3+12*imag(z)^4*real(z)^2+12*imag(z)^4+6*imag(z)^5+imag(z)^6
elseif @V=="Henon 1"
x=1-p1*real(z)^2+imag(z)

&& @trap!="Biquartic" && @trap!="Butterfly Curve" && @trap!="Bean Curve" \
&& @trap!="Bean Curve 2" && @trap!="Egg of Columbus" && @trap!="Sinus Chain" \
&& @trap!="Szego Curve" && @trap!="Links Curve" && @trap!="Double Egg 2" \
&& @trap!="Heart Curve" && @trap!="Cornoid 2" \

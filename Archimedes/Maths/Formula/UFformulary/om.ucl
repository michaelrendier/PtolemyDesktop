elseif @V=="Standard Map"
x=real(z)+p1*imag(z)+p2+(p3/(2*pi))*sin(2*pi*real(z))
y=p1*imag(z)+p2+(p3/(2*pi))*sin(2*pi*real(z))
z=x+flip(y)
elseif @V=="Strophoid"
z=imag(z)^2-real(z)^2*(p1-real(z))/(p1+real(z))
elseif @V=="Svensson"

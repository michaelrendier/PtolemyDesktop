|| @V=="Oblique Strophoid"  || @V=="Superellipse 2" || @V=="Oblique Cissoid" \
|| @V=="Hippopede" || @V=="Oblique Pancappa" || @V=="Oblique Cappa" \
|| @V=="Oblique Bifolium" || @V=="Lemniscate of Booth" \

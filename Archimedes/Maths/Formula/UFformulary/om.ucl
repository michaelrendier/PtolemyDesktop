BoF61Mod2 {
init:
float a=1000
float i=0
float i2=0
loop:
i=i+1
if i>1
z=p1*fn1(#z)+p2
if @M=="None"
z=z
elseif @M=="1"
z=z+p3*fn2(z)
else
z=z+p3/fn2(z)
endif
if cabs(z)<a
a=cabs(z)
i2=i*0.1
endif
endif
final:
if @V=="1"
#index=a
elseif @V=="2"
#index=i2*a
elseif @V=="3"
#index=i2
endif

&& @V!="Biquartic" && @V!="Butterfly Curve" && @V!="Bean Curve" \
&& @V!="Bean Curve 2" && @V!="Egg of Columbus" && @V!="Sinus Chain" \
&& @V!="Szego Curve" && @V!="Links Curve" && @V!="Double Egg 2" \

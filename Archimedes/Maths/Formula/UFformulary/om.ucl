init:
loop:
final:
  float ratio
  if !im.getempty()
  ratio=im.getwidth()/im.getheight()
  else
  ratio=1
  endif
  i=(0,1)
  k= fn1(.5*(#z-p1)*exp(i*@rot*#pi/180)/p2)^@pow
  #color= im.getColor(real(fn2(k)) + flip(imag(fn2(k)) * ratio))
default:
  title = "Image Import 6"
  image param imageparam
  caption = "image"
  endparam

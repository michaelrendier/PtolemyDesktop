d = 0
bool f = true

loop:
d = #z+p1
a  = cabs(fn1(d)-fn1(#pixel))
b  = cabs(fn2(d)-fn3(#pixel))

if f && p2 < b && b < p3
f = false
c =a
endif

final:

  #index = c


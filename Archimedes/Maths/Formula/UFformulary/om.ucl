param p2
caption="Parameter 2"
default = 0.75
endparam
}

Boffles {
; Modification of 'Bubbles' by Kerry Mitchell and Fractint's bof60 and bof61
init:
float a=p1+cabs(p2)+p3
if(a==0.0)
a=1.0
endif
float b=p1/a
float c=cabs(p2)/a
float d=p3/a
float f=0.0
float g=p4
float h=0.0
j=(0,0)
bool k=false
float m=0.0
float n=0.0
loop:
m=m+1
if @V==0
f=cabs(#z^2+@p5)
elseif @V==1
f=cabs(#z^2+#z+@p5)
elseif @V==2
f=cabs(log(#z)/#z+@p5)
elseif @V==3
f=cabs(#z^3+#z^2+#z+@p5)
elseif @V==4
f=cabs(#z^2+pixel+@p5)
elseif @V==5
f=cabs(#z-(#z^3-1)/(3*#z^2)+@p5)
elseif @V==6
f=cabs(conj(1/(#z-p5))+p5)
elseif @V==7
f=cabs(#z^3+2*sqr(#z)+3*#z+1+p5)
elseif @V==8
f=cabs(log(#z)/#z+#z+@p5)
elseif @V==9
f=cabs(sqr(log(#z)/#z)+@p5)
elseif @V==10
f=cabs(cotanh(#z-(#z^3-1)/(3*#z^2))+@p5)
elseif @V==11
f=cabs(cotanh(conj(1/(#z-p5))+p5))
elseif @V==12
f=cabs(cotanh(#z^3+2*sqr(#z)+3*#z+1)+p5)
endif
if f<g
k=true
g=f
j=fn2(cabs(sqr(#z)+#z))
n=m
endif
final:
if k==true
g=g/p4
h=atan2(j)
if h<0
h=h+2*pi
endif
h=h/(2*pi)
if p2<0
h=1-h
endif
m=n/m
#index=cabs(fn3(b*g+c*h+d*m))
else
#index=0.0
#solid=true
endif
default:
title="Boffles"
param V
caption="Function 1"
enum="sqr""sqr+""logc""cube+""sqr+pixel""mf1""mf2""mf3"\
"logc+""sqrlogc""cotanhmf1""cotanhmf2""cotanhmf3"
default=0
endparam
func fn2
default=ident()
endfunc
func fn3
default=ident()
endfunc
param p1
caption="Parameter 1"
default=1.0
endparam
param p2
caption="Parameter 2"
default=1.0
endparam
param p3
caption="Parameter 3"
default=1.0
endparam
param p4
caption="Parameter 4"
default=1.0
min=0.0
endparam
param p5
default=(0,0)
endparam
}

CroggorlomaLinith2 {
init:
float a = 0
float b = 0
float c = 0.01
d = 0
bool f = true
loop:
if @V=="a"
d = #z+p1
elseif @V=="b"
d=sqr(#z)+p1
elseif @V=="c"
d=sqr(#z)+#z+p1
elseif @V=="d"
d=#z^3+p1
elseif @V=="e"
d=#z^3+sqr(#z)+#z+p1
elseif @V=="f"
d=sqr(#z)+pixel+p1
elseif @V=="g"
d=#z-p1*(#z^3-1)/(3*#z^2)
elseif @V=="h"
d=#z^2*(#z-p1)/(1-p1*#z)
elseif @V=="i"
d=conj(1/(#z-p1))+p1
elseif @V=="j"
if imag(#z)>0
k=#z
else
k=conj(#z)
endif
d=log(k+p1)
elseif @V=="k"
d=#z^3+2*sqr(#z)+3*#z+p1
elseif @V=="l"
d=cotanh(#z)+#z+p1
elseif @V=="m"
d=flip(#z)/#z+p1
elseif @V=="n"
d=conj(#z)/#z+p1
elseif @V=="o"
d=cotan(#z)/#z+p1
elseif @V=="p"
d=(#z-sqrt(-1))/(#z+sqrt(-1))+p1
elseif @V=="q"
d=(p1*conj(#z))/(conj(#z)^2-1)
elseif @V=="r"
d=(p1*conj(#z)^2)/(conj(#z)^3-1)
elseif @V=="s"
d=#z-p1*2*(#z^3-1)*(3*#z^2)/(2*(3*#z^2)^2-(#z^3-1)*6*#z)
elseif @V=="t"
if |#z-p1|<1
d=conj(1/(#z-p1))
else
d=conj(1/#z)
endif
elseif @V=="u"
d=asin(tanh(#z))+p1
elseif @V=="v"
d=#z^4+2*#z^3+3*#z^2+4*#z+p1
elseif @V=="w"
d=cotanh(#z)/sin(#z)+p1
elseif @V=="x"
d=cabs(#z)/sqr(#z)+p1
elseif @V=="y"
d=cotanh(#z)*cosh(#z)+p1
elseif @V=="z"
d=log(#z)*cosh(#z)+p1
endif
a=cabs(fn1(d)-fn1(#pixel))
b=cabs(fn2(d)-fn3(#pixel))
if f && p2<b && b<p3
f=false
c=a
endif
final:
#index = c
default:
  title = "Croggorloma Linith 2"
  param V
  caption="Variant"
  enum="a""b""c""d""e""f""g""h""i""j""k""l"\
  "m""n""o""p""q""r""s""t""u""v""w""x""y""z"
  default=0
  endparam
  param p1
  default = (1,0)
  endparam
  param p2
  caption="Parameter 2"
  default = 1.0
  endparam
  param p3
  caption="Parameter 3"
  default = 2.0
  endparam
  func fn1
  default =ident()
  endfunc
  func fn2
  default = ident()
  endfunc
  func fn3
  default = ident()
  endfunc
}

OrgumaLocus2 {
init:
a=(0,0)
b=(0,0)
c=(0,0)
float d=0.0
bool f=true
loop:
if f
if @V=="ident"
a=p1*fn1(#z)+p2
elseif @V=="+pixel"
a=p1*fn1(#z+pixel)+p2
elseif @V=="*pixel"
a=p1*fn1(#z*pixel)+p2
elseif @V=="sqr+pixel"
a=p1*fn1(#z^2+pixel)+p2
elseif @V=="loglog"
a=p1*fn1(log(log(#z)))+p2
elseif @V=="sin"
a=p1*fn1(sin(#z))+p2
elseif @V=="sinh"
a=p1*fn1(sinh(#z))+p2
elseif @V=="cosh"
a=p1*fn1(cosh(#z))+p2
elseif @V=="acos"
a=p1*fn1(acos(#z))+p2
elseif @V=="tan"
a=p1*fn1(tan(#z))+p2
elseif @V=="cotanh"
a=p1*fn1(cotanh(#z))+p2
elseif @V=="sqrt"
a=p1*fn1(sqrt(#z))+p2
elseif @V=="exp"
a=p1*fn1(exp(#z))+p2
elseif @V=="flip"
a=p1*fn1(flip(#z))+p2
elseif @V=="recip"
a=p1*fn1(recip(#z))+p2
elseif @V=="third"
a=p1*fn1(#z/3)+p2
elseif @V=="half"
a=p1*fn1(#z/2)+p2
elseif @V=="double"
a=p1*fn1(2*#z)+p2
elseif @V=="triple"
a=p1*fn1(3*#z)+p2
elseif @V=="mf1"
a=p1*fn1(sqr(#z)+2*#z)+p2
elseif @V=="mf2"
a=p1*fn1(#z^3+2*sqr(#z)+3*#z)+p2
elseif @V=="mf3"
a=p1*fn1(#z-(#z^3-1)/(3*#z^2))+p2
elseif @V=="mf4"
a=p1*fn1(conj(1/(#z-1))+1)+p2
elseif @V=="sin+"
a=p1*fn1(sin(#z)+#z)+p2
elseif @V=="sin*"
a=p1*fn1(sin(#z)*#z)+p2
elseif @V=="sinc"
a=p1*fn1(sin(#z)/#z)+p2
elseif @V=="cosh+"
a=p1*fn1(cosh(#z)+#z)+p2
elseif @V=="cosh*"
a=p1*fn1(cosh(#z)*#z)+p2
elseif @V=="coshc"
a=p1*fn1(cosh(#z)/#z)+p2
elseif @V=="tan+"
a=p1*fn1(tan(#z)+#z)+p2
elseif @V=="tan*"
a=p1*fn1(tan(#z)*#z)+p2
elseif @V=="tanc"
a=p1*fn1(tan(#z)/#z)+p2
elseif @V=="sec"
a=p1*fn1(1/cos(#z))+p2
elseif @V=="sec+"
a=p1*fn1(1/cos(#z)+#z)+p2
elseif @V=="sec*"
a=p1*fn1(#z/cos(#z))+p2
elseif @V=="secc"
a=p1*fn1(1/(#z*cos(#z)))+p2
endif
d=cabs(a)
c=a/d
d=recip(sqrt(imag(c)^(-2)))
b=d*c
d=20*sqr(cabs(sqr(fn2(b-a))))
if d<1
f=false
endif
endif
final:
if f
#solid=true
else
if |a|>|b|
d=1+d
else
d=1-d
endif
#index=d/2
endif
default:
title="Orguma Locus 2"
param V
caption="Function 1"
enum="ident""+pixel""*pixel""sqr+pixel""loglog"\
"sin""sinh""cosh""acos""tan""cotanh"\
"sqrt""exp""flip""recip""third""half""double""triple"\
"mf1""mf2""mf3""mf4""sin+""sin*""sinc""cosh+""cosh*""coshc"\
"tan+""tan*""tanc""sec" "sec+""sec*""secc"
default=1
endparam
func fn1
caption="Function 2"
default=ident ()
endfunc
func fn2
caption="Function 3"
default=ident()
endfunc
param p1
default=(1,0)
endparam
param p2
default=(0,0)
endparam
}

GleesanChang {
init:

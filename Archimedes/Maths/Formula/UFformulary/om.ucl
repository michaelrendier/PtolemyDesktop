elseif @V=="Magus 17"
z=p1^2*(real(z)^2-imag(z)^2)^2-p1*tan(real(z)^2+imag(z)^2)^2-real(z)^2*imag(z)^2
elseif @V=="Magus 18"
x=p1*sin(real(z)*cos(imag(z)))-p2*cos(real(z)*sin(imag(z)))
y=p1*cos(imag(z)*sin(real(z)))+p2*sin(imag(z)*cos(real(z)))

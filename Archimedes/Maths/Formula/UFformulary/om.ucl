y=p1-real(z)
z=x+flip(y)
elseif @V=="Hopalong Mod 5"
x=imag(z)-1-asinh(sqrt(abs(p2*real(z)-1-p3)))*((real(z)-1)/cabs(real(z)-1))
y=p1-real(z)-1
z=x+flip(y)
elseif @V=="Hopalong Mod 6"

y=(p2+1)*(real(z)*sin(p3-p4/(real(z)^2+imag(z)^2+1))+imag(z)*cos(p3-p4/(real(z)^2+imag(z)^2+1)))
z=x+flip(y)
elseif @V=="Inkle"
z=p1*conj(p1/(z-p2))+p2
elseif @V=="Isoptic Curve"

x=imag(z)
y=real(z)-real(z)^3-p1*imag(z)+p2
z=x+flip(y)
elseif @V=="Duffing 2"
x=imag(z)
y=-p1*real(z)-p2*real(z)^3+p3
z=x+flip(y)
elseif @V=="Duffing 3"
x=imag(z)
y=-p1*real(z)-((p2-p1)/2)*(cabs(real(z)+1)-cabs(real(z)-1))-p3*imag(z)+p4
z=x+flip(y)
elseif @V=="Duffing Parametric"
x=imag(z)
y=-real(z)-real(z)^3+(p1+p2*real(z)^2+p3*p4*real(z))*imag(z)+p4*p5
z=x+flip(y)
elseif @V=="Duffing Quintic"
x=imag(z)
y=-p1*real(z)-p2*real(z)^3-p3*real(z)^5+p4
z=x+flip(y)
elseif @V=="Egg of Granville"
z=real(z)^2*imag(z)^2-(real(z)-p1)*(1-real(z))
elseif @V=="Fish Curve"
z=(2*real(z)^2+imag(z)^2)^2+2*sqrt(2)*p1*real(z)*(2*real(z)^2-3*imag(z)^2)+2*p1^2*(imag(z)^2-real(z)^2)
elseif @V=="Focal Conic Conchoid"

visible=@V=="Clinoid/Pickover" || @V=="Conchoid/Svensson" || @V=="Cubic/Cissoid" \
|| @V=="de Jong/Spiskonvencivich" || @V=="Henon-Heiles" || @V=="Hyperbola/Parabola" \
|| @V=="Mackey-Glass" \
|| @V=="Parametric/Polyharmonic Pendulum" || @V=="Pickover"
endparam
param p4
default=(1,0)
visible=@V=="Clinoid/Pickover" || @V=="Conchoid/Svensson" || @V=="Cubic/Cissoid" \
|| @V=="de Jong/Spiskonvencivich" || @V=="Henon-Heiles" \
|| @V=="Parametric/Polyharmonic Pendulum" || @V=="Pickover"
endparam
param p5
default=(1,0)
visible=@V=="Cubic/Cissoid" || @V=="Henon-Heiles"
endparam
param b
caption="Adjustment 1"
default=1.0
endparam
param c
caption="Adjustment 2"
default=1.0
endparam
param S
caption="Symmetrise"
default=false
endparam
}


endif
elseif @v==1
if i>1
a=a+(h-b)^@pow+(j-c)^@pow+(k-d)^@pow
endif
elseif @v==2
if i>-1
a=a+(h-b)^@pow+(j-c)^@pow+(k-d)^@pow
endif
elseif @v==3
if i>2
a=a+(h-b)^@pow+(j-c)^@pow+(k-d)^@pow
endif

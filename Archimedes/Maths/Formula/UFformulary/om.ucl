elseif @V=="Magus 7"
z=p1*sin(real(z))-tan(imag(z))-abs(real(z)+flip(imag(z)))+flip(-p2*tan(real(z))+sin(imag(z))+abs(real(z)+flip(imag(z))))
elseif @V=="Magus 8"

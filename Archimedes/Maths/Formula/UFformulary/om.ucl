loop:
z=p1*fn1(#z)+p2
if @Va=="1"
z=z
elseif @Va=="2"
if |z|<1
z=z/|z|+p5
endif
elseif @Va=="3"
if |z|>1
z=z/|z|+p5
endif
elseif @Va=="4"
x=real(z)
y=imag(z)
x=x/|z|+real(p5)
y=y/|z|+imag(p5)
z=x+flip(y)
elseif @Va=="5"
if real(z)<imag(z)
z=flip(z)+p5
endif
elseif @Va=="6"
if real(z)>imag(z)
z=flip(z)+p5

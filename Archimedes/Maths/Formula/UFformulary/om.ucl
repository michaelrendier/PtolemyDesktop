Tiggray {
; This is a modification of Wavy Traps by Piotr Borys (pb.ucl)
init:
float a=1e38
float b=0.0
complex c[#maxiter+1]
c[0]=#z
d=(0,0)
int i=0
f=p3
float h
float j
float k
float m
loop:
i=i+1
d=p1*fn1(#z)+p2
if @V=="1"
d=d
elseif @V=="2"
d=d+cabs(d)
elseif @V=="3"
d=d-cabs(d)
elseif @V=="4"
d=d+log(d)
elseif @V=="5"
d=d-log(d)
elseif @V=="6"
d=d-cotanh(d)
elseif @V=="7"
d=d+atanh(d)
elseif @V=="8"
d=d-atanh(d)
elseif @V=="9"
d=d-1/d
endif
d=d-f
c[i]=d
if i>0 && i<@p8
h=abs(imag(d))
j=cabs(asinh(((real(d))^2)*0.24))
b=abs(h-2.5-j)
if i>1
k=abs(imag(c[i-1]))
m=cabs(asinh(((real(c[i-1]))^2)*0.24))
b=b+0.3*cabs(asinh(abs(k-2.5+m)))
endif
endif
if b<a
a=b
endif
final:
#index=a
default:
title="Tiggray"
param V
caption="Variant"
enum="1""2""3""4""5""6""7""8""9"
endparam
param p1
default=(2,0)
endparam
param p2
default=(0,0)
endparam
param p3
default=(0,0)
endparam
func fn1
caption="Function"
default=ident()
endfunc
param p8
caption="Iterations"
default=5
endparam
}


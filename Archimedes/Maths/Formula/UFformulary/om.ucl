z=(x^4-(@a+1)*x^2*y+y^3)
elseif @V=="Bullet-Nose Curve"
z=((@a^2-x^2)*(@a2^2+y^2)-@a^2*@a2^2)
elseif @V=="Butterfly Curve"
z=(x^6+y^6-x^2)
elseif @V=="Butterfly Knot"

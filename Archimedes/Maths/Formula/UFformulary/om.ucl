param p4
default=(1,0)
visible=@V=="Cartesian Oval" || @V=="Cissoid of Zahradnik" || @V=="Clifford" || @V=="de Jong" \
|| @V=="Duffing 3" || @V=="Duffing Parametric" || @V=="Duffing Quintic" \

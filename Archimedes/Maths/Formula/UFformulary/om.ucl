if @S==true
z1=abs(z1)
z2=abs(z2)
else
z1=z1
z2=z2
endif
if @V=="Astroid/Cardioid"
z1=(real(z1)^2+imag(z1)^2-2*p1*real(z1))^2-4*p1^2*(real(z1)^2+imag(z1)^2)
z2=real(z2)^(2/3)+imag(z2)^(2/3)-p1^(2/3)
elseif @V=="Clinoid/Pickover"
x1=sin(p1*imag(z1))+(p2-0.5)*cos(p1*real(z1))
y1=sin(p3*real(z1))+p4*cos(p3*imag(z1))
z1=x1+flip(y1)
z2=imag(z2)-(p2-0.5)*exp(real(z2)/p1)-p3*exp(-real(z2)/p1)
elseif @V=="Conchoid/Svensson"
z1=(real(z1)-p1)^2*(real(z1)^2+imag(z1)^2)-p2^2*real(z1)^2
x2=p1*sin(p2*real(z2))-sin(p3*imag(z2))
y2=p4*cos(p2*real(z2))-cos(p3*imag(z2))
z2=x2+flip(y2)
elseif @V=="Cornoid/Scyphoid"
z1=real(z1)^4-imag(z1)^4-4*(p1+1)*real(z1)*imag(z1)^2
z1=(real(z2)^2+imag(z2)^2)^3+(p1+1)^2*(3*real(z2)^4-6*real(z2)^2*imag(z2)^2-5*imag(z2)^4)+8*(p1+1)^4*imag(z2)^2-4*(p1+1)^6
elseif @V=="Cremona"
x1=real(z1)*cos(p1)-(imag(z1)-real(z1)^2)*sin(p1)
y1=real(z1)*sin(p1)-(imag(z1)-real(z1)^2)*cos(p1)
z1=x1+flip(y1)
x2=real(z2)*cos(p1)+imag(z2)*sin(p1)
y2=-real(z2)*sin(p1)+imag(z2)*cos(p1)+(real(z2)*cos(p1)+imag(z2)*sin(p1))^2
z2=x2+flip(y2)
elseif @V=="Cubic/Cissoid"
z1=real(z1)*(real(z1)^2+imag(z1)^2)+p1*real(z1)^2+p2*imag(z1)^2+2*p3*real(z1)+2*p4*imag(z1)+p5
z2=p3*real(z2)^2+2*p4*real(z2)*imag(z2)+(p5+1)*imag(z2)^2-2*p1*real(z2)-2*p2*imag(z2)
elseif @V=="Cycloid/Nephroid"
z1=(real(z1)^2+imag(z1)^2-4*p1^2)^3-108*p1^4*real(z1)^2
z2=real(z2)-p1*recip(cos(1-imag(z2)/p1))+sqrt(imag(z2)*(2^p1-imag(z2)))
elseif @V=="de Jong/Spiskonvencivich"
x1=cos(p1*real(z1))-sin(p2*imag(z1))
y1=sin(p3*real(z1))+cos(p4*imag(z1))
z1=x1+flip(y1)
x2=sin(p1*imag(z2))-cos(p2*real(z2))
y2=sin(p3*real(z2))-cos(p4*imag(z2))
z2=x2+flip(y2)
elseif @V=="Gumowski-Mira"
x1=imag(z1)+p1*(1-0.05*imag(z1)^2)*imag(z1)+p2*real(z1)+2*(1-p2)*real(z1)^2/(1+real(z1)^2)
y1=-real(z1)+p2*(imag(z1)+p1*(1-0.05*imag(z1)^2)*imag(z1)+p2*real(z1)+2*(1-p2)*real(z1)^2/(1+real(z1)^2))\
+2*(1-p2)*(imag(z1)+p1*(1-0.05*imag(z1)^2)*imag(z1)+p2*real(z1)+2*(1-p2)*real(z1)^2/(1+real(z1)^2))^2/\
(1+(imag(z1)+p1*(1-0.05*imag(z1)^2)*imag(z1)+p2*real(z1)+2*(1-p2)*real(z1)^2/(1+real(z1)^2))^2)
z1=x1+flip(y1)
if real(z2)<-0.5
x2=(1-p1)*real(z2)+imag(z2)
y2=imag(z2)+(-2*p1*real(z2)-0.9*p1)
elseif cabs(real(z2))<0.5
x2=(1-p1)*real(z2)+imag(z2)
y2=imag(z2)-p1*real(z2)/5
else
x2=(1-p1)*real(z2)+imag(z2)
y2=imag(z2)+(-2*p1*real(z2)+0.9*p1)
endif
z2=x2+flip(y2)
elseif @V=="Hamilton/Kam Torus"
x1=-sin(imag(z1))*(1-p1)
y1=sin(real(z1))*(1+p1)
z1=x1+flip(y1)
x2=real(z2)*cos(p1)+(real(z2)^2-imag(z2))*sin(p1)
y2=real(z2)*sin(p1)-(real(z2)^2-imag(z2))*cos(p1)
z2=x2+flip(y2)
elseif @V=="Henon-Heiles"
x1=-p1*real(z1)-p2*real(z1)*imag(z1)
y1=-p3*imag(z1)-p4*real(z1)^2+p5*imag(z1)^2
z1=x1+flip(y1)
x2=imag(z2)
y2=-p1*real(z2)-p2*real(z2)^2+p3
z2=x2+flip(y2)
elseif @V=="Hyperbola/Parabola"
z1=real(z1)^2/p1^2-imag(z1)^2/p2^2-1
z2=imag(z2)-p1*real(z2)^2-p2*real(z2)-p3
elseif @V=="Inkle/Munster"
z1=p1*conj(p1/(z1+p2))+p2
z2=p1*z2^2*(z2-p2)/(1-p2*z2)
elseif @V=="Julia/Mandelbrot"
z1=z1^2+pixel
z2=z2^2+p1
elseif @V=="Mackey-Glass"
z1=(p1*z1*p2^p3)/(p2^p3+z1^p3)
z2=p1*z2/(1+z2^p3)-p2*z2
elseif @V=="Magnet"
z1=sqr((z1^2+p1-1)/(2*z1+p1-2))
z2=sqr( (z2^3+3*(p1-1)*z2+(p1-1)*(p1-2)) /(3*z2^2+3*(p1-2)*z2+(p1-1)*(p1-2)+1))
elseif @V=="Newton/Nova"
z1=z1-p1*(z1^3-p2)/(3*z1^2)+pixel
z2=z2-p1*(z2^3-p2)/(3*z2^2)
elseif @V=="Parametric/Polyharmonic Pendulum"
x1=imag(z1)
y1=p1*sin(real(z1))/2+imag(z1)*(p2+p3*cos(real(z1)))
z1=x1+flip(y1)
x2=imag(z2)
y2=-p1*sin(real(z2))-p2*sin(3*real(z2))+p3*sin(p4)
z2=x2+flip(y2)
elseif @V=="Pickover"
x1=sin(p1*imag(z1))+p2*sin(p1*real(z1))
y1=sin(p3*real(z1))+p4*sin(p3*imag(z1))
z1=x1+flip(y1)
x2=sin(p1*imag(z2))+p2*cos(p1*real(z2))
y2=sin(p3*real(z2))+p4*cos(p3*imag(z2))
z2=x2+flip(y2)
elseif @V=="Secantoid/Sinusoid"
z1=imag(z1)-p1/cos(real(z1)/p2)
z2=imag(z2)-p1*sin(real(z2)/p2)
elseif @V=="Van der Pol"
x1=p1*(real(z1)-real(z1)^3/3-imag(z1))
y1=real(z1)/p1
z1=x1+flip(y1)
x2=imag(z2)
y2=p1*(1-real(z2)^2)*imag(z2)-real(z2)
z2=x2+flip(y2)
endif
a=abs(cabs(z2)-abs(atan2(z2)))
if a<b
b=a
endif
final:
#index=abs(@b*b-@c*cabs(log(z1)))/#numiter
default:
title="Biquate"
param V
caption="Variant"
enum="Astroid/Cardioid""Clinoid/Pickover""Conchoid/Svensson""Cornoid/Scyphoid""Cremona""Cubic/Cissoid"\
"Cycloid/Nephroid""de Jong/Spiskonvencivich""Gumowski-Mira""Hamilton/Kam Torus""Henon-Heiles"\
"Hyperbola/Parabola""Inkle/Munster""Julia/Mandelbrot""Mackey-Glass""Magnet""Newton/Nova"\
"Parametric/Polyharmonic Pendulum""Pickover""Secantoid/Sinusoid""Van der Pol"
default=0
endparam
param Fs
caption="Function"
enum="sin""sinh""asin""asinh""cos""cosh""acos""acosh""tan""tanh""atan"\
"atanh""cotan""cotanh""sqr""sqrt""log""exp""abs""cabs""conj"\
"flip""ident""recip""versin""aversin""haversin""ahaversin""coversin""acoversin"\

elseif @V=="Magus 9"
z=imag(z)^2+real(z)^2-((real(z)+(p3*(real(z)-p1))/sqrt((real(z)-p1)^2+(imag(z)-p2)^2))-(imag(z)+(p3*(imag(z)-p2))/sqrt((real(z)-p1)^2+(imag(z)-p2)^2)))
elseif @V=="Magus 10"
z=p1*imag(z)-p2/(real(z)*cos(real(z)))+p3/(real(z)*cos(imag(z)))
elseif @V=="Magus 11"

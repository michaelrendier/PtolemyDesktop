ca147{
init:
x=pixel
y=1/pixel
a=sin(pixel)
b=cos(pixel)
c=tan(pixel)
loop:
if @loop==0
x=fn1(cotan(((x^3)/y)+a+b+c))+@par
elseif @loop==1
y=fn1(conj(recip(((y^3)/a)+x+a+c)))+@par
elseif @loop==2
a=fn1(atanh(((a^3)/b)+x+y+c))+@par
elseif @loop==3
b=fn1(cotanh(((b^3)/c)+x+y+a))+@par
elseif @loop==4
c=fn1(recip(((c^3)/x)+y+a+b))+@par
endif
final:
if @fin==0
#index=real(fn2(acosh(#numiter*x*y*a*b*c)))+sqr(imag(fn2(acosh(#numiter*x*y*a*b*c))))+@par2
elseif @fin==1
#index=real(fn2(asin(#numiter+x+y+a+b+c)))+sqr(imag(fn2(asin(#numiter+x+y+a+b+c))))+@par2
elseif @fin==2
#index=real(fn2(log(#numiter/x/y/a/b/c)))+sqr(imag(fn2(log(#numiter/x/y/a/b/c))))+@par2
elseif @fin==3
#index=real(fn2(sin(#numiter^x^y^a^b^c)))+sqr(imag(fn2(sin(#numiter^x^y^a^b^c))))+@par2
endif
default:
  title="ca147"
  param loop
  caption="Loop"
  enum="1" "2" "3" "4" "5"
  default=0
  endparam
  func fn1
  caption="Function (Loop)"
  default=ident()
  endfunc
  param par
  caption="Parameter (Loop)"
  default=(0,0)
  endparam
  param fin
  caption="Final"
  enum= "1" "2" "3" "4"
  default=0
  endparam
  func fn2
  caption="Function (Final)"
  default=ident()
  endfunc
  param par2
  caption="Parameter (Final)"
  default=0.5
  endparam
}

ca149{
init:
x=pixel
y=1/pixel
a=sin(pixel)
b=cos(pixel)
c=tan(pixel)
loop:
if @loop==0
x=fn1(cotan(((x^3)/y)+a+b+c))+@par
elseif @loop==1
y=fn1(conj(recip(((y^3)/a)+x+a+c)))+@par
elseif @loop==2
a=fn1(atanh(((a^3)/b)+x+y+c))+@par
elseif @loop==3
b=fn1(cotanh(((b^3)/c)+x+y+a))+@par
elseif @loop==4
c=fn1(recip(((c^3)/x)+y+a+b))+@par
endif
final:
if @fin==0

Tricol(Direct){
; Modification of 'hot and Cold 2' from https://github.com/edyoung/gnofract4d/blob/master/formulas/experiments.cfrm
init:
float a=0.0
color c=@c1
loop:
if @V=="ident"
a=|fn2(#z)|
elseif @V=="sqr+"
a=|fn2(sqr(#z)+#z)|
elseif @V=="cube"
a=|fn2(#z^3)|
elseif @V=="cube+"
a=|fn2(#z^3+sqr(#z)+#z)|
elseif @V=="+pixel"
a=|fn2(#z+pixel)|
elseif @V=="-pixel"
a=|fn2(#z-pixel)|
elseif @V=="*pixel"
a=|fn2(#z*pixel)|
elseif @V=="/pixel"
a=|fn2(#z/pixel)|
elseif @V=="mf1"
a=|fn2(sqr(#z)+pixel)|
elseif @V=="mf2"
a=|fn2(#z^3+pixel)|
elseif @V=="mf3"
a=|fn2(#z-(#z^3-1)/(3*#z^2))|
elseif @V=="mf4"
a=|fn2(conj(1/(#z-1))+1)|
elseif @V=="mf5"
a=|fn2(sqr(#z)*(#z-2)/(1-2*#z))|
elseif @V=="primecount"
a=|fn2(#z/log(#z))|
elseif @V=="gauss"
a=|fn2(exp(-sqr(#z)))|
elseif @V=="sinc"
a=|fn2(sin(#z)/#z)|
elseif @V=="cosc"
a=|fn2(cos(#z)/#z)|
elseif @V=="tanc"
a=|fn2(tan(#z)/#z)|
elseif @V=="cotanc"
a=|fn2(cotan(#z)/#z)|
elseif @V=="sinc*pixel"
a=|fn2(sin(#z)*pixel/#z)|
elseif @V=="cosc*pixel"
a=|fn2(cos(#z)*pixel/#z)|
elseif @V=="tanc*pixel"
a=|fn2(tan(#z)*pixel/#z)|
elseif @V=="cotanc*pixel"
a=|fn2(cotan(#z)*pixel/#z)|
endif
if a<p1
c=compose(c,blend(@c2,@mergemode(c,@c2),1.0),@mergeopacity)
else
c=compose(c,blend(@c3,@mergemode(c,@c3),1.0),@mergeopacity)
endif
final:
#color=c
default:
title="Tricol (Direct)"
param p1
caption="Parameter"
default=2.0
endparam
color param c1
caption="Colour 1"
default=rgb(0.86,0.92,0.73)
endparam
color param c2
caption="Colour 2"
default=rgb(0.21,0.73,0.45)
endparam
color param c3
caption="Colour 3"
default=rgb(0.03,0.18,0.39)
endparam
color func mergemode
caption="Blend Mode"
default=mergenormal()
endfunc
param mergeopacity
caption="Blend Opacity"
default=0.5
endparam
param V
caption="Function 1"
enum="ident""sqr+""cube""cube+"\
"+pixel""-pixel""*pixel""/pixel"\
"mf1""mf2""mf3""mf4""mf5"\
"primecount""gauss"\
"sinc""cosc""tanc""cotanc"\
"sinc*pixel""cosc*pixel""tanc*pixel""cotanc*pixel"
default=0
endparam
func fn2
default=ident()
endfunc
}

Tricol2(Direct) {
;Modification of 'Spin' from https://github.com/edyoung/gnofract4d/blob/master/formulas/experiments.cfrm
init:
float b=0.0
color c=@c1
complex zold=(0,0)
loop:
if @F1=="ident"
b=cabs(fn2(ident(#z)+p2)-zold)
elseif @F1=="sqr"
b=cabs(fn2(sqr(#z)+p2)-zold)
elseif @F1=="sqr+"
b=cabs(fn2(sqr(#z)+#z+p2)-zold)
elseif @F1=="cube"
b=cabs(fn2(#z^3+p2)-zold)
elseif @F1=="cube+"
b=cabs(fn2(#z^3+#z^2+#z+p2)-zold)
elseif @F1=="mf1"
b=cabs(fn2(#z^3+2*#z^2+3*#z+p2)-zold)
elseif @F1=="mf2"
b=cabs(fn2(#z^2+2*#z+p2)-zold)
elseif @F1=="mf3"
b=cabs(fn2(#z^2+pixel+p2)-zold)
elseif @F1=="mf4"
b=cabs(fn2(#z-(#z^3-1)/(3*#z^2)+p2)-zold)
elseif @F1=="mf5"
b=cabs(fn2(conj(1/(#z-1))+1+p2)-zold)
elseif @F1=="mf6"
b=cabs(fn2(#z^2*(#z-2)/(1-2*#z)+p2 )-zold)
elseif @F1=="mf7"
b=cabs(fn2(pixel*#z*(1-#z)+p2)-zold)
elseif @F1=="mf8"
b=cabs(fn2(sqr(sqr(#z)+pixel)/(#z-pixel)+p2)-zold)
elseif @F1=="mf9"
b=cabs(fn2(sqr(#z+sin(#z))+#z^0.5+p2)-zold)
elseif @F1=="mf10"
b=cabs(fn2(sqr(#z+sin(#z))+pixel*exp(#z)+p2)-zold)
elseif @F1=="+pixel"
b=cabs(fn2(#z+pixel+p2)-zold)
elseif @F1=="-pixel"
b=cabs(fn2(#z-pixel+p2)-zold)
elseif @F1=="*pixel"
b=cabs(fn2(#z*pixel+p2)-zold)
elseif @F1=="/pixel"
b=cabs(fn2(#z/pixel+p2)-zold)
elseif @F1=="pixel*(sin+cos)"
b=cabs(fn2(pixel*(sin(#z)+cos(#z))+p2)-zold)
endif
if b<p1
c=compose(c,blend(@c2,@blendmode(c,@c2),1.0),@blendopac)
else
c=compose(c,blend(@c3,@blendmode(c,@c3),1.0),@blendopac)
endif
zold=#z
final:
#color=c
default:
title="Tricol 2 (Direct)"
param p1
caption="Parameter 1"
default=1.0
endparam
param p2
default=(0,0)
endparam
param F1
caption="Function 1"
enum="ident""sqr""sqr+""cube""cube+""mf1""mf2""mf3""mf4""mf5"\
"mf6""mf7""mf8""mf9""mf10""+pixel""-pixel""*pixel""/pixel""pixel*(sin+cos)"
default=0
endparam
func fn2
default=ident()
endfunc
color param c1
caption="Colour 1"
default=rgb(0.86, 0.83, 0.63)
endparam
color param c2
caption="Colour 2"
default=rgb(0.82, 0.71, 0.45)
endparam
color param c3
caption="Colour 3"
default=rgb(0.83, 0.46, 0.16)
endparam
color func blendmode
caption="Blend Mode"
default=mergenormal()
endfunc
param blendopac
caption="Blend Opacity"
default=2.0
endparam
}

MagmaGrolthius2 {
init:
float a = 0.0
float b = 0.0
float c = 0.0
d=(0,0)
int f=0
bool g=false
loop:
if !g
b=|d|/|fn1(sin(#z))+p1|
if @F2=="sqr"
d=fn3(sqr(#z))+p2
elseif @F2=="sqr+"
d=fn3(sqr(#z)+#z)+p2
elseif @F2=="cube"
d=fn3(#z^3)+p2
elseif @F2=="cube+"
d=fn3(#z^3+sqr(#z)+#z)+p2
elseif @F2=="+pixel"
d=fn3(#z+pixel)+p2
elseif @F2=="*pixel"
d=fn3(#z*pixel)+p2
elseif @F2=="/pixel"
d=fn3(#z/pixel)+p2
elseif @F2=="exp"
d=fn3(exp(#z))+p2
elseif @F2=="asinh"
d=fn3(asinh(#z))+p2
elseif @F2=="sqrexp"
d=fn3(sqr(exp(#z)))+p2
elseif @F2=="sqrtan"
d=fn3(sqr(tan(#z)))+p2
elseif @F2=="sqrtanh"
d=fn3(sqr(tanh(#z)))+p2
elseif @F2=="sqrsqr"
d=fn3(sqr(sqr(#z)))+p2
elseif @F2=="sqrlog"
d=fn3(sqr(log(#z)))+p2
elseif @F2=="mf1"
d=fn3(#z-(#z^3-1)/(3*#z^2))+p2
elseif @F2=="mf2"
d=fn3(conj(1/(#z-1))+1)+p2
endif
if b<p3 && f>0
g=true
c=((imag((-50,150)-1))/p3)*b+a*imag((-50,150))
endif
f=f+1
a=f%(-50)
endif
final:
if g
#index=((real(c)+1)%300)/300
else
#solid=true
endif
default:
title="Magma Grolthius 2"
func fn1
default=ident()
endfunc
param F2
caption="Function 2"
enum="sqr""sqr+""cube""cube+""+pixel""*pixel""/pixel"\
"exp""asinh""sqrexp""sqrtan""sqrtanh""sqrsqr""sqrlog"\
"mf1""mf2"
default=0
endparam
func fn3
default=ident()
endfunc
param p1
default=(0,0)
endparam
param p2
default=(0,0)
endparam
param p3
caption="Parameter 3"
default=0.2
endparam

}


elseif @Fs=="vercos"
z=1+cos(#z)
elseif @Fs=="avercos"
z=acos(1+#z)
elseif @Fs=="havercos"
z=(1+cos(#z))/2
elseif @Fs=="ahavercos"
z=2*acos(sqrt(#z))
elseif @Fs=="covercos"
z=1+sin(#z)
elseif @Fs=="acovercos"
z=asin(1+#z)
elseif @Fs=="hacovercos"
z=(1+sin(#z))/2

elseif @V=="Logistic Map"
z=p1*z*(1-z)
elseif @V=="Magus 1"
z=(real(z)^2-imag(z)^2)*(real(z)^2+imag(z)^2)^2-2*p1*real(z)*imag(z)*(real(z)-p1^2)
elseif @V=="Magus 2"

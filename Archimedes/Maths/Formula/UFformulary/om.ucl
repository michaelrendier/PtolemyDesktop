z=x+flip(y)
elseif @V=="Threeply"
z=imag(z)-(real(z)/cabs(real(z)))*(abs(sin(real(z))*cos(p1)+p2-real(z)*sin(p1+p2+p3)))+flip(p3-real(z))
elseif @V=="Tinkerbell"
z=real(z)^2-imag(z)^2+p1*real(z)+p2*imag(z)+flip(2*real(z)*imag(z)-p3*real(z)+p4*imag(z))
elseif @V=="Torpedo Curve"
z=(real(z)^2+imag(z)^2)^2-(p1+1)*real(z)*(real(z)^2-imag(z)^2)
elseif @V=="Tractrix"
z=real(z)-log((p1-sqrt(p1^2-imag(z)^2))/imag(z))-sqrt(p1^2-imag(z)^2)
elseif @V=="Trisectrix of Delange"

z=x+flip(y)
elseif @V=="Henon 5"
x=imag(z)+p1*cos(pi*real(z)/2)-1
y=p2*real(z)
z=x+flip(y)
elseif @V=="Hippopede of Proclus"
z=(real(z)^2+imag(z)^2)^2+4*p2*(p2-p1)*(real(z)^2+imag(z)^2)-4*p2^2*real(z)^2
elseif @V=="Hopalong"
x=imag(z)-sqrt(cabs(p2*real(z)-p3))*((real(z))/cabs(real(z)))

z=(x^2*(3*x^2-y^2)^2-y^2*(x^2+y^2))
elseif @V=="Astroid"
z=(x^(2/3)+y^(2/3)-@a^(2/3))
elseif @V=="Atriphthaloid"
z=(x^4*(x^2+y^2)-(@a2*x^2-@a^3)^2)
elseif @V=="Bean Curve"
z=((x^2+y^2)^2-x^3-y^3)
elseif @V=="Bean Curve 2"
z=(x^4+x^2*y^2+y^4-x*(x^2+y^2))
elseif @V=="Beetle"
z=((x^2+y^2)*(x^2+y^2-@a*x-@a2*y)-@a3^2*x^2*y^2)
elseif @V=="Biaxial Eight Reverse"
z=(@a^2*y^2-x^2*(y^2-x^2))

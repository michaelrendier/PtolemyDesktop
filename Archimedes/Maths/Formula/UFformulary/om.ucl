NIC{
; Normalized iteration count, as given here: http://math.unipa.it/~grim/Jbarrallo.PDF
; Try Sqrt, CubeRoot, Log or Arctan transfer function. This does not seem to work well with the default Linear
final:
if @V==0
#index=#numiter+1-log(log(cabs(fn1(#z)^@pow-p1)))/log(2)
elseif @V==1
#index=#numiter+(log(log(p2))-log(log(cabs(fn1(#z)^@pow-p1))))/log(2)
endif

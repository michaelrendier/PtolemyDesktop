z=p1+(p2+2)*z*e^(sqrt(-1)*(cabs(z)^2+p3))
elseif @V=="Ikeda 2"
z=p1+p2*z*e^(sqrt(-1)*(p3+2)/(cabs(Z)^2+1)+p4)

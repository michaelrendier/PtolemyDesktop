SoftTraps{
init:
float a=0
float b=1e+318
loop:
k=fn1(abs(#z))+p1
if @trap==0
a=abs(real(log(exp(k)))/imag(atanh(cosh(k))))
elseif @trap==1
a=cabs(recip(2*k^(-1)+1))
elseif @trap==2
a=imag(log(acos(conj(1/k))))
elseif @trap==3
a=sin(real(flip(3*k))+imag(flip(k^2-1)))
elseif @trap==4
a=cotanh(real(recip(k)+(( 1-k)/(1-k))))
elseif @trap==5
a=cabs(acosh(k)+k)
elseif @trap==6
a=sin(real(k)+imag(k))
else
a=log(real(sqrt(k)/acos(-k)))
endif
if a<b
b=a
endif
final:
float c=b*p2
d=fn2(cos(c)+flip(sin(c)))
float f=atan2(d)
if f<0
f=f+p3
endif
#index=f*0.16
default:
title = "Trapsoft"
param trap
caption="Trap"
enum="1" "2" "3" "4" "5" "6" "7" "8"
default=0
endparam
func fn1
default=ident()
endfunc
func fn2
default=ident()
endfunc
param p1
default=(0,0)
endparam
param p2
caption="Parameter 2"
default=3.5
endparam
param p3
caption="Parameter 3"
default=6.3
endparam

}


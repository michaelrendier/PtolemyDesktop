i=i+1
z=fn2(z)
x=real(z)+real(p2)
y=imag(z)+imag(p2)
a=x^2+y^2
x=x/a+real(p1)
y=y/a+imag(p1)
if @V1=="1"
z=(x+flip(y))^2-(x+flip(y))+p5
if real(z)<imag(z)
z=flip(z)

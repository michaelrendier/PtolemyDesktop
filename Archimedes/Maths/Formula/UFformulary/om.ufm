y=y/a+imag(p1)
z=x+flip(y)
if @v=="0-3"
z=p2*log(abs(z*(5*z^2-3)/2))^@pow+p3
elseif @v=="0-4"
z=p2*log(abs((35*z^4-30*z^2+3)/8))^@pow+p3
elseif @v=="0-5"
z=p2*log(abs(z*(63*z^4-70*z^2+15)/8))^@pow+p3
elseif @v=="0-6"
z=p2*log(abs((231*z^6-315*z^4+105*z^2-5)/16))^@pow+p3
elseif @v=="0-7"
z=p2*log(abs(z*(429*z^6-693*z^4+315*z^2-35)/16))^@pow+p3
elseif @v=="0-8"

z=z-cosh(z)
elseif @Va=="34"
z=z-sinh(z)
elseif @Va=="35"
z=z-sin(z)
elseif @Va=="36"
z=z+2*sqr(z)
elseif @Va=="37"
z=z-2*sqr(z)
elseif @Va=="38"

loop:
if imag(z)>p1
z=fn2(p2*real(z)+flip(p2*imag(z)-p3))
elseif real(z)>p1
z= fn3(p2*real(z)-p3+flip(p2*imag(z)))
else
z= fn4(p2*real(z)+flip(p2*imag(z)))
endif
bailout:|z|<@bailout

elseif @Fs=="exsec"
z=1/cos(pixel)-1
elseif @Fs=="aexsec"
z= acos(1/(pixel+1))
elseif @Fs=="excosec"
z=1/sin(pixel)-1
elseif @Fs=="aexcosec"
z=asin(1/(pixel+1))
elseif @Fs=="crd"

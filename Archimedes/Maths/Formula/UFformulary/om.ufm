b=b+1
c=(-0.5*(p1*abs(conj(p1/(z-p2)))+p2)-a)/(a*(p1*abs(conj(p1/(z-p2)))+p2)-0.5)
d=(i*c+i)/(-c+1)
f=(-0.5*d+a)/(-a*d-0.5)
z=flip((f-i)/(f+i)+pixel)^@pow*p3+p4
endwhile
z=z*p5/100

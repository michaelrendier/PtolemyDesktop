f1=5*z^4+z/(1-sin(@p8*z))+sin(@p8*z)/(1+sin(@p8*z))+sin(@p8*z)+1+sin(@p8*z)/(1+sin(@p8*z))
elseif @V==19
f=z^4+sin(z*(@p9-@p8))/(2*(@p9-@p8))-sin(z*(@p8+@p9))/(2*(@p8+@p9))-cos(@p8*z)/@p8-p2

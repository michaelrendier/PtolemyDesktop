default=4.0
endparam
}

Bofnewt{
;From 'The Beauty of Fractals' via Bofmaps.frm
init:
z=fn1(pixel)
loop:
a=p1*fn2(z)
b=a^2
c=a^3
d=a^4
z=z-((d-c*0.5+b*0.5-a*0.5-0.5)/((c*4-b*1.5+a-0.5)+p2))
bailout:
|d-c*0.5+b*0.5-a*0.5-0.5|>@bail
default:
title="Bofnewt"
center=(0.001,0.001)
periodicity=0
param p1
default=(1,0)

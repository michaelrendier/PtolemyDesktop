f=(0,0)
f1=(0,0)
loop:
z=fn2(sqr(z))
if @V=="sin(z)"
f=sin(z)+p2
f1=cos(z)
elseif @V=="cos(z)"
f=cos(z)+p2
f1=-sin(z)
elseif @V=="tan(z)"
f=tan(z)+p2
f1=1/cos(z)^2
elseif @V=="cotan(z)"
f=cotan(z)+p2
f1=-1/sin(z)^2
elseif @V=="sec(z)"
f=1/cos(z)+p2
f1=tan(z)/cos(z)
elseif @V=="cosec(z)"
f=1/sin(z)+p2
f1=-cotan(z)/sin(z)
elseif @V=="sinh(z)"
f=sinh(z)+p2
f1=cosh(z)
elseif @V=="cosh(z)"
f=cosh(z)+p2
f1=sinh(z)
elseif @V=="tanh(z)"
f=tanh(z)+p2
f1=1/cosh(z)^2
elseif @V=="sech(z)"
f=1/cosh(z)+p2
f1=-tanh(z)/cosh(z)
elseif @V=="cosech(z)"

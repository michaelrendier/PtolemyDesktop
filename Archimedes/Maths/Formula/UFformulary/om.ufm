elseif @Fs=="softplus"
z=log(1+exp(pixel))
elseif @Fs=="primecount"
z=pixel/log(pixel)
endif
a=2*pi/3
c1=exp((0,0)*a)
c2=exp((0,1)*a)
c3=exp((0,2)*a)
r=sqrt(3)/2
loop:
if @fn2=="ident"
z=p1*ident(z)+p2
elseif @fn2=="flip"
z=p1*flip(z)+p2
elseif @fn2=="conj"
z=p1*conj(z)+p2
elseif @fn2=="abs"
z=p1*abs(z)+p2
elseif @fn2=="recip"
z=p1*recip(z)+p2
elseif @fn2=="flipconj"
z=p1*flip(conj(z))+p2
elseif @fn2=="flipabs"

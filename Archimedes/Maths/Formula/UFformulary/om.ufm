  caption="Bailout"
  default=4.0
  endparam
}

Sicchin-U-Bigh{
init:
z=fn1(sqr(pixel))
a=p1*fn2(abs(exp((p2))))
loop:
z=(fn3(z)^2+a)/(fn3(z)^2-a)
bailout:|z|<@bailout
default:
 title="Sicchin-U-Bigh"
 center=(0.001,0.001)
 maxiter=500
 param p1
 caption="Parameter 1"
 default=0.715
 endparam
 param p2
 default=(0,0)
 endparam

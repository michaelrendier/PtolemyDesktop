z=z/|z|
endif
elseif @Va=="3"
if |z|>1
z=z/|z|
endif
elseif @Va=="4"
x=real(z)
y=imag(z)
x=x/|z|
y=y/|z|
z=x+flip(y)
elseif @Va=="5"
if real(z)<imag(z)
z=flip(z)
endif
elseif @Va=="6"
if real(z)>imag(z)
z=flip(z)
endif
endif
if @P=="2"
f=z^2+3*z+2
f1=2*z+3
f2=2
elseif @P=="3"
f=z^3+4*z^2+5*z+2
f1=3*z^2+8*z+5
f2=6*z+8
elseif @P=="4"
f=z^4+5*z^3+9*z^2+7*z+2
f1=4*z^3+15*z^2+18*z+7

elseif @fn2=="2abs"
z=p1*(abs(z*2))+p2
elseif @fn2=="2recip"
z=p1*(recip(z*2))+p2
endif
if |z-c1|<|r|
z=p3*(r*conj(r/(z-c1))+c1)
elseif |z-c2|<|r|
z=p3*(r*conj(r/(z-c2))+c2)
elseif |z-c3|<|r|
z=p3*(r*conj(r/(z-c3))+c3)
endif
z=conj(1/(z-p4))+p4
z=flip(z)
bailout:
|z|<@bail

}

NineKlein{
init:
z=fn1(pixel)
a=2*pi/9
c1=p1*fn2(exp((0,0)*a))
c2=p1*fn2(exp((0,1)*a))
c3=p1*fn2(exp((0,2)*a))
c4=p1*fn2(exp((0,3)*a))
c5=p1*fn2(exp((0,4)*a))
c6=p1*fn2(exp((0,5)*a))
c7=p1*fn2(exp((0,6)*a))
c8=p1*fn2(exp((0,7)*a))
c9=p1*fn2(exp((0,8)*a))
loop:
b=fn3(z)
if |b-c1|<|p2|
z= p3*fn4(p2*conj(p2/(b-c1))+c1)+p4
elseif |b-c2|<|p2|
z= p3*fn4(p2*conj(p2/(b-c2))+c2)+p4
elseif |b-c3|<|p2|
z= p3*fn4(p2*conj(p2/(b-c3))+c3)+p4
elseif |b-c4|<|p2|
z= p3*fn4(p2*conj(p2/(b-c4))+c4)+p4
elseif |b-c5|<|p2|
z= p3*fn4(p2*conj(p2/(b-c5))+c5)+p4
elseif |b-c6|<|p2|
z= p3*fn4(p2*conj(p2/(b-c6))+c6)+p4
elseif |b-c7|<|p2|
z= p3*fn4(p2*conj(p2/(b-c7))+c7)+p4
elseif |b-c8|<|p2|
z= p3*fn4(p2*conj(p2/(b-c8))+c8)+p4
elseif |b-c9|<|p2|
z= p3*fn4(p2*conj(p2/(b-c9))+c9)+p4
else
z=p3*fn4(p2*conj(p2/b))+p4
endif
bailout:
|z|<@bail
default:
  title="Nine Klein"
  center=(0.001,0.001)
  maxiter=250
  param p1
  default=(-0.05,-0.76)
  endparam
  param p2
  default=(0.73,0)
  endparam
  param p3
  default=(1,0)
  endparam
  param p4
  default=(0,0)
  endparam
  func fn1
  default=sqr()
  endfunc
  func fn2
  default=ident()
  endfunc
  func fn3
  default=ident()
  endfunc
  func fn4
  default=ident()
  endfunc
  param bail
  caption="Bailout"
  default=4.0
  endparam
}

Klein123{
; Adapted and modified from Morgan_L_Owens.frm
init:
z=fn1(pixel)
a=2*pi/3
c1=p1*fn2(exp((0,1)*a))
c2=p1*fn2(exp((0,2)*a))
c3=p1*fn2(exp((0,3)*a))
r=fn3(sqrt(p2)/2)
loop:
if |z-c1|<|r|
v=p3*fn4(r*conj(r/(z-c1))+c1)+p4
else
v=p3*fn4(r*conj(r/z))+p4
endif
if |v-c1|<|r|
w=p3*fn4(r*conj(r/(v-c1))+c1)+p4
elseif |v-c2|<|r|
w=p3*fn4(r*conj(r/(v-c2))+c2)+p4
else
w=p3*fn4(r*conj(r/v))+p4
endif
if |w-c1|<|r|
z=p3*fn4(r*conj(r/(w-c1))+c1)+p4
elseif |w-c2|<|r|
z=p3*fn4(r*conj(r/(w-c2))+c2)+p4
elseif |w-c3|<|r|
z=p3*fn4(r*conj(r/(w-c3))+c3)+p4
else
z=p3*fn4(r*conj(r/w))+p4
endif
bailout:|z|<@bailout
default:
 title="Klein 123"
 center=(0.001,0.001)
 maxiter=500
 param p1
 default=(1,0)
 endparam
 param p2
 caption="Parameter 2"
 default= 3.0
 endparam
 param p3
 default=(1,0)
 endparam
 param p4
 default=(0,0)
 endparam
 func fn1
 default=ident()
 endfunc
 func fn2
 default=ident()
 endfunc
 func fn3
 default=ident()
 endfunc
 func fn4
 default=ident()
 endfunc
 param bailout
 caption="Bailout"
 default=4.0
 endparam
}

ThreeKlein4{
; Adapted and modified from Morgan_L_Owens.frm
init:
a=2*pi/3
c1=p3*fn2(exp((0,0)*a))
c2=p3*fn2(exp((0,1)*a))
c3=p3*fn2(exp((0,2)*a))
r=fn3(sqrt(p4)/2)
z=fn4(pixel)
loop:
if |z-c1|<|r|
z=p1*fn1(c1+r*(z-c1)/(|z-c1|))+p2
elseif |z-c2|<|r|
z=p1*fn1(c2+r*(z-c2)/(|z-c2|))+p2
elseif |z-c3|<|r|
z=p1*fn1(c3+r*(z-c3)/(|z-c3|))+p2
else
z=p1*fn1(r*z/(|z|))+p2
endif
bailout:
|z|<@bailout
default:
 title="Three Klein 4"
 center=(0.001,0.001)
 maxiter=500
 magn=0.5
 param p1
 default=(1,0)
 endparam
 param p2
 default= (0,0)
 endparam
 param p3
 default= (1,0)
 endparam
 param p4
 caption="Parameter 4"
 default= 3.0
 endparam
 func fn4
 caption="Start Function 1"
 default=ident()
 endfunc
 func fn2
 caption="Start Function 2"
 default=ident()
 endfunc
 func fn3
 caption="Start Function 3"
 default=ident()
 endfunc
 func fn1
 caption="Loop Function"
 default=ident()
 endfunc
 param bailout
 caption="Bailout"
 default=4.0
 endparam
}


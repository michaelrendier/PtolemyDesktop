x=x/a+real(p1)
y=y/a+imag(p1)
z=x+flip(y)
if @v=="2"
z=p2*log(abs(2*z^2+4*z+1))^@pow+p3
elseif @v=="3"
z=p2*log(abs(2*z^3+6*z^2+3*z+1))^@pow+p3
elseif @v=="4"

z=z+p6*tan(z)
z=z+@p7*sqr(z)
x=real(z)
y=imag(z)
a=x^2+y^2
x=x/a+real(p1)
y=y/a+imag(p1)
z=x+flip(y)
if @v=="2"
z=p2*fn4(log(abs(3*z^2+z)))^@pow+p3+@p9*pixel
elseif @v=="3"
z=p2*fn4(log(abs(11*z^3+9*z^2+z)))^@pow+p3+@p9*pixel
elseif @v=="4"
z=p2*fn4(log(abs(50*z^4+66*z^3+21*z^2+z)))^@pow+p3+@p9*pixel
elseif @v=="5"

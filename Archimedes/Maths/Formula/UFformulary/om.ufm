caption="Möbius Parameter 1"
default=(0,0)
endparam
param p6
caption="Möbius Parameter 2"
default=(0,0)
endparam
param p7
caption="Quasi-Logistic Parameter"
default=(0,0)
endparam
param p4
caption="Add Recip Parameter"
default=(0,0)
endparam
func fn1
caption="Start Function"
default=ident()
endfunc

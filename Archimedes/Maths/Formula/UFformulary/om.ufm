z=flip(z)
endif
elseif @Va=="33"
if real(z)>imag(z)
z=flip(z)
endif
elseif @Va=="34"
z=z+1/z
elseif @Va=="35"
z=z+1/exp(z)
elseif @Va=="36"
z=z+1/sqr(z)
elseif @Va=="37"
z=z+1/tan(z)
elseif @Va=="38"
z=z+1/cosh(z)
elseif @Va=="39"
z=z+1/sinh(z)
elseif @Va=="40"
z=z-1/z
elseif @Va=="41"
z=z-1/sqr(z)
elseif @Va=="42"
z=z-1/cotanh(z)
elseif @Va=="43"
z=z-1/cotan(z)

PascalPolynomials3 {
init:
z=fn1(pixel)
int i=0
loop:
while i<@iter
i=i+1
z=fn2(z)
x1=real(z)
y1=imag(z)
a=x1^2+y1^2
x1=x1/a+real(p1)
y1=y1/a+imag(p1)
z=x1+flip(y1)
x=log(z)
y=fn3(z)
if @v=="Quadratic"
z=p2*log(abs(x^2+2*x*y+y^2))^@pow+p3
elseif @v=="Cubic"
z=p2*log(abs(x^3+3*x^2*y+3*x*y^2+y^3))^@pow+p3
elseif @v=="Quartic"
z=p2*log(abs(x^4+4*x^3*y+6*x^2*y^2+4*x*y^3+y^4))^@pow+p3
elseif @v=="Quintic"
z=p2*log(abs(x^5+5*x^4*y+10*x^3*y^2+10*x^2*y^3+5*x*y^4+y^5))^@pow+p3
elseif @v=="Sextic"
z=p2*log(abs(x^6++6*x^5*y+15*x^4*y^2+20^x^3*y^3+15*x^2*y^4+6*x*y^5+y^6))^@pow+p3
elseif @v=="Septic"
z=p2*log(abs(x^7+7*x^6*y+21*x^5*y^2+35*x^4*y^3+35*x^3*y^4+21*x^2*y^5+7*x*y^6+y^7))^@pow+p3
endif
endwhile
z=@adj*z/100
bailout:
|z|<@bail
default:

}

WhittakerHybrid{
init:
z=fn1(fn2(pixel))
loop:
a=z^4-1
b=0.5*p3*a*(2+a)
c=log(z-b)-p2
z=p1+((p2+c/(cabs(c)^2))-p1)/(cabs((p2+c/(cabs(c)^2))-p1)^2)
bailout:
(|z|<@baildiv && @B==0) || (|z|>@bailcon && @B==1)
default:
 title="Whittaker Hybrid"

SawResister {
init:
z=fn1(pixel)
loop:
zold=z
z=(z-p5)/(1-p5*z)
z=z/(p6^z+1)
z=z+p4/fn3(z)
z=z*(1-@p7*z)
if imag(z)>0
z=z
else
z=conj(z)
endif
z=fn2(z)
z=p1^@pow*cos(p2^@pow*pi*z)+p3
bailout:
|zold-z|>@bail
default:
title="Saw Resister"
center=(0.001,0.001)
periodicity=0
param p1
caption="Parameter 1"
default=(1.5,0)
endparam
param p2
caption="Parameter 2"
default=(0.5,0)
endparam

f1=(21*z^6-54*z^5+25*z^4+20*z^3-6*z^2-4*z)/24
elseif @P=="8"
f=(10*z^8-35*z^7+25*z^6+25*z^5-17*z^4-17*z^3+3*z^2+3*z)/90
f1=(80*z^7-245*z^6+150*z^5+125*z^4-68*z^3-51*z^2+6*z+3)/90
elseif @P=="9"
f=(2*z^9-8*z^8+7*z^7+7*z^6-7*z^5-7*z^4+3*z^3+3*z^2)/20
f1=(18*z^8-64*z^7+49*z^6+42*z^5-35*z^4-28*z^3+9*z^2+6*z)/20

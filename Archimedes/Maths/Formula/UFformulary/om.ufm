f507{
;various distortions of the mandelbrot set
init:
if @start==0
z=fn1(real(pixel)+sqr(imag(pixel)))+@par
elseif @start==1
z=fn1(real(pixel)-sqr(imag(pixel)))+@par
elseif @start==2
z=fn1(real(pixel)/sqr(imag(pixel)))+@par
elseif @start==3
z=fn1(sqr(imag(pixel))/real(pixel))+@par
elseif @start==4
z=fn1(sqr(real(pixel))+sqr(imag(pixel)))+@par
elseif @start==5
z=fn1(sqr(real(pixel))-sqr(imag(pixel)))+@par
elseif @start==6
z=fn1(sqr(real(pixel))/sqr(imag(pixel)))+@par
elseif @start==7
z=fn1(sqr(imag(pixel))/sqr(real(pixel)))+@par
endif
loop:
  if @loop==0
  z=fn2(z^2)+(pixel^2)+@par2
  elseif @loop==1
  z=fn2(z^2)+(pixel^2)+pixel+@par2

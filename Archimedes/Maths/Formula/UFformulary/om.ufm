f606{
init:
x=((@par1+1.2)+(@par2-1.9)*cos(pixel))*cos(pixel)
y=((@par1+1.2)+(@par2-1.9)*cos(pixel))*sin(pixel)
z=(@par2-1.9)*sin(pixel)
loop:
z=@fn(recip(z-y*z*(z-x)*(z-1)-(@par1+1.2)*z+(@par2-1.9)*z+x*z))
bailout:
|z|<@bailout
default:

z=fn1(pixel)^@pow1
loop:
z=fn2(p1*cos(p2)*real(z^2+@p7)-p3*sin(p4)*imag(z^2+@p7)+p5+flip(p1*sin(p2)*real(z^2+@p7)+p3*cos(p4)*imag(z^2+@p7)+p6))^@pow2
bailout:
|z|<@bailout

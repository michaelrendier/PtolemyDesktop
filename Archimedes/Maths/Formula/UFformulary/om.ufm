z=flip(z)
endif
endif
if |z|<1
z=z/|z|
endif
endif
z=p3*fn3(log(abs(fn4((z^3-1)+(3*z^2)*(z-z^3+1)+3*z*(z-z^3+1)^2))))^@pow+p4
endwhile

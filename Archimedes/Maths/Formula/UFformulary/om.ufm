ZernikePolynomials11 {
;http://www.mpia.de/AO/INSTRUMENTS/FPRAKT/ZernikePolynomialsForTheWeb.pdf
init:
z=fn1(pixel)
int i=0
loop:
while i<@iter
i=i+1
z=fn2(z)
x=real(z)+real(p2)
y=imag(z)+imag(p2)
a=x^2+y^2
x=x/a+real(p1)
y=y/a+imag(p1)
if @V1=="1"
z=(x+flip(y))^3-(x+flip(y))
if real(z)<imag(z)
z=flip(z)
endif
elseif @V1=="2"
z=(x+flip(y))-((x+flip(y))^2-1)/(2*(x+flip(y)))
if real(z)<imag(z)
z=flip(z)
endif
elseif @V1=="3"
z=(x+flip(y))-((x+flip(y))^3-1)/(3*(x+flip(y))^2)
if real(z)<imag(z)
z=flip(z)
endif
elseif @V1=="4"
z=(x+flip(y)-1)/(x+flip(y)+1)
if real(z)<imag(z)
z=flip(z)
endif
elseif @V1=="5"
z=(x+flip(y)-sqrt(-1))/(x+flip(y)+sqrt(-1))
if real(z)<imag(z)
z=flip(z)
endif
elseif @V1=="6"
z=(x+flip(y))-tan(x+flip(y))
if real(z)<imag(z)
z=flip(z)
endif
elseif @V1=="7"
z=log(x+flip(y))^2/exp(x+flip(y))
if real(z)<imag(z)
z=flip(z)
endif
elseif @V1=="8"
z=acos(x+flip(y))^2-(x+flip(y))
if real(z)<imag(z)
z=flip(z)
endif
elseif @V1=="9"
z=exp(x+flip(y))^2-cotanh(x+flip(y))
if real(z)<imag(z)
z=flip(z)
endif
elseif @V1=="10"
z=sqrt(x+flip(y))*(x+flip(y))-(x+flip(y))
if real(z)<imag(z)
z=flip(z)
endif
elseif @V1=="11"
z=sqrt(x+flip(y))*sqr(x+flip(y))-(x+flip(y))
if real(z)<imag(z)
z=flip(z)
endif
elseif @V1=="12"
z=(x+flip(y))-((x+flip(y))^2-1)/(2*(x+flip(y)))/2
if real(z)<imag(z)
z=flip(z)
endif
elseif @V1=="13"
z=(x+flip(y))-((x+flip(y))^3-1)/(3*(x+flip(y))^2)/(6*(x+flip(y)))
if real(z)<imag(z)
z=flip(z)
endif
elseif @V1=="14"
z=(x+flip(y))-((x+flip(y))^4-1)/(4*(x+flip(y))^3)/(12*(x+flip(y))^2)
if real(z)<imag(z)
z=flip(z)
endif
elseif @V1=="15"
z=((x+flip(y))^2-1)/(2*(x+flip(y)))/2
if real(z)<imag(z)
z=flip(z)
endif
elseif @V1=="16"
z=((x+flip(y))^3-1)/(3*(x+flip(y))^2)/(6*(x+flip(y)))
if real(z)<imag(z)
z=flip(z)
endif
elseif @V1=="17"
z=((x+flip(y))^4-1)/(4*(x+flip(y))^3)/(12*(x+flip(y))^2)
if real(z)<imag(z)
z=flip(z)
endif
elseif @V1=="18"
z=(x+flip(y))*(1-(x+flip(y))-(x+flip(y))^2)
if real(z)<imag(z)
z=flip(z)
endif
elseif @V1=="19"
z=(x+flip(y))*(1-(x+flip(y))+(x+flip(y))^2)
if real(z)<imag(z)
z=flip(z)
endif
endif
if @v=="4"
z=p3*log(log(abs(6*z^4-6*z^2+1)))^@pow+p4
elseif @v=="6"
z=p3*log(log(abs(20*z^6-30*z^4+12*z^2-1)))^@pow+p4
elseif @v=="8"
z=p3*log(log(abs(70*z^8-140*z^6+90*z^4-20*z^2+1)))^@pow+p4
elseif @v=="10"
z=p3*log(log(abs(252*z^10-630*z^8+560*z^6-210*z^4+30*z^2-1)))^@pow+p4
elseif @v=="12"
z=p3*log(log(abs(924*z^12-2772*z^10+3150*z^8-1680*z^6+420*z^4-42*z^2+1)))^@pow+p4
elseif @v=="14"
z=p3*log(log(abs(3432*z^14-12012*z^12+16632*z^10-11550*z^8+4200*z^6-756*z^4+56*z^2-1)))^@pow+p4
elseif @v=="16"
z=p3*log(log(abs(12870*z^16-51480*z^14+84084*z^12-72072*z^10+34650*z^8-9240*z^6+1260*z^4-72*z^2+1)))^@pow+p4
endif
endwhile
z=@adj*z/100
bailout:
|z|<@bail
default:

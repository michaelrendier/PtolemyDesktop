elseif @Va=="52"
z=z-2*tanh(z)
elseif @Va=="53"
z=z-2*tan(z)
elseif @Va=="54"
z=z-cosh(z)
elseif @Va=="55"
z=z-cos(z)
elseif @Va=="56"
z=z-sinh(z)

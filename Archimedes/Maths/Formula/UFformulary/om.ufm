Appell3 {
;This takes the recurrence relation for Appell Polynomials
;given here: https://en.wikipedia.org/wiki/Appell_sequence
;P0 is set to z^2-1, and the constant is -1 for the other terms
init:
z=fn1(pixel)
int i=0
loop:
while i<@iter
i=i+1
z=fn2(fn3(z))
x=real(z)
y=imag(z)
a=x^2+y^2
x=x/a+real(p1)
y=y/a+imag(p1)
z=x+flip(y)
if @v=="0"
z=p2*log(abs(z^2-1))^@pow+p3
elseif @v=="1"
z=p2*log(abs(z^3/3-z-1))^@pow+p3
elseif @v=="2"
z=p2*log(abs(z^4/6-z^2-2*z-1))^@pow+p3
elseif @v=="3"
z=p2*log(abs(z^5/10-z^3-3*z^2-3*z-1))^@pow+p3
elseif @v=="4"
z=p2*log(abs(z^6/15-z^4-4*z^3-6*z^2-4*z-1))^@pow+p3
elseif @v=="5"
z=p2*log(abs(z^7/21-z^5-5*z^4-10*z^3-10*z^2-5*z-1))^@pow+p3
elseif @v=="6"
z=p2*log(abs(z^8/28-z^6-6*z^5-15*z^4-20*z^3-15*z^2-6*z-1))^@pow+p3
elseif @v=="7"
z=p2*log(abs(z^9/36-z^7-7*z^6-21*z^5-35*z^4-35*z^3-21*z^2-7*z-1))^@pow+p3
elseif @v=="8"
z=p2*log(abs(z^10/45-z^8-8*z^7-28*z^6-56*z^5-70*z^4-56*z^3-28*z^2-8*z-1))^@pow+p3
elseif @v=="9"
z=p2*log(abs(z^11/55-z^9-9*z^8-36*z^7-84*z^6-126*z^5-126*z^4-84*z^3-36*z^2-9*z-1))^@pow+p3
elseif @v=="10"
z=p2*log(abs(z^12/66-z^10-10*z^9-45*z^8-120*z^7-210*z^6-252*z^5-210*z^4-120*z^3-45*z^2-10*z-1))^@pow+p3
endif
endwhile
z=@adj*z/100
bailout:
|z|<@bail

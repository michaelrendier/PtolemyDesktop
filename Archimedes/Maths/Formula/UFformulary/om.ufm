Cayley{
global:
import "common.ulb"
import "reb.ulb"
Formula f = new @formulaClass(0)
init:
z=fn1(pixel)^@pow1
i=sqrt(-1)
loop:
if @plugin
z=p1*fn2(f.Iterate((z-i)/(z+i)))^@pow2
else
z=p1*fn2((z-i)/(z+i))^@pow2
endif
bailout:
|z|<@bailout

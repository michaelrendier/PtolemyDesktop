}

IFS4{
init:
z=fn1(pixel)
loop:
if imag(z)>1
z=p1*fn2(asin(2*real(z)+flip(2*imag(z)-1)))+p4
elseif real(z)>1
z=p2*fn3(asinh(2*real(z)-1+flip(2*imag(z))))+p5
else
z=p3*fn4(2*real(z)+flip(2*imag(z)))+p6
endif
bailout:
|z|<@bail
default:

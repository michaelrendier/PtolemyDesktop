Barnsley5{
init:
z=fn1(pixel)
k=fn2(pixel)
loop:
if real(z)>=0
a=(z-1)*p1
b=(z-1)*k+p2
else
a=0
b=0
endif
if real(z)<0
c=(z+1)*p1
d=(z+1)*k+p2
else
c=0
d=0
endif
z=fn3(a+b+c+d)+p3
bailout:
|z|<@bailout
default:
  title="Barnsley 5"
  center=(0.001,0.001)
  param p1
  default=(1,0)
  endparam
  param p2
  default=(1,0)
  endparam

z=p2*log(log(abs(70*z^8-140*z^6+90*z^4-20*z^2+1)))^@pow+p3+fn3(pixel)
elseif @v=="10"
z=p2*log(log(abs(252*z^10-630*z^8+560*z^6-210*z^4+30*z^2-1)))^@pow+p3+fn3(pixel)
elseif @v=="12"
z=p2*log(log(abs(924*z^12-2772*z^10+3150*z^8-1680*z^6+420*z^4-42*z^2+1)))^@pow+p3+fn3(pixel)
elseif @v=="14"
z=p2*log(log(abs(3432*z^14-12012*z^12+16632*z^10-11550*z^8+4200*z^6-756*z^4+56*z^2-1)))^@pow+p3+fn3(pixel)
elseif @v=="16"
z=p2*log(log(abs(12870*z^16-51480*z^14+84084*z^12-72072*z^10+34650*z^8-9240*z^6+1260*z^4-72*z^2+1)))^@pow+p3+fn3(pixel)
endif
endwhile
z=@adj*z/100
bailout:
|z|<@bail

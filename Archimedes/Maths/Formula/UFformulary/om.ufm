elseif @Va=="19"
z=z+3*tan(z)
elseif @Va=="20"
z=z-3*tan(z)
elseif @Va=="21"
z=z+cos(z)
elseif @Va=="22"
z=z-0.7/exp(z)
elseif @Va=="23"
z=z+0.7/cosh(z)
elseif @Va=="24"
z=z-0.7/cosh(z)
elseif @Va=="25"
z=z+0.7/cos(z)
elseif @Va=="26"
z=z-0.7/cos(z)
endif
else
if @Va=="none"
z=z
elseif @Va=="1"
if real(z)>imag(z)
z=flip(z)
endif
elseif @Va=="2"
z=2*z
elseif @Va=="3"
z=3*z
elseif @Va=="4"
z=-3*z
elseif @Va=="5"
z=z+4*flip(z)
elseif @Va=="6"
z=z-4*flip(z)
elseif @Va=="7"
z=z+3.5*abs(z)
elseif @Va=="8"
z=z-3.5*abs(z)
elseif @Va=="9"
z=z+3*exp(z)
elseif @Va=="10"
z=z+5*exp(z)
elseif @Va=="11"
z=z+sqr(z)
elseif @Va=="12"
z=z-sqr(z)
elseif @Va=="13"
z=z+2*sqr(z)
elseif @Va=="14"
z=z-2*sqr(z)
elseif @Va=="15"
z=z+tanh(z)
elseif @Va=="16"
z=z+2*tanh(z)
elseif @Va=="17"
z=z-3.5*tanh(z)
elseif @Va=="18"
z=z-7.5*tanh(z)
elseif @Va=="19"
z=z+tan(z)
elseif @Va=="20"
z=z+2*tan(z)
elseif @Va=="21"
z=z-0.5/exp(z)
elseif @Va=="22"
z=z-0.7/cosh(z)
elseif @Va=="23"
z=z-0.7/cos(z)
elseif @Va=="24"
z=z-1.4/cosh(z)
elseif @Va=="25"
z=z-1.4/cos(z)
elseif @Va=="26"
z=z+3/cotanh(z)
endif
endif
z=z^z
if @JM=="J"
z=p5*log(abs(z))^@pow2+p6
else
z=p5*log(abs(z))^@pow2+p6+fn4(pixel)
endif
if @JM=="J"
if @Va=="none"
z=z
elseif @Va=="27"
if |z|>1
z=z/|z|
endif
elseif @Va=="28"
if |z|<1
z=z/|z|
endif
elseif @Va=="29"
if real(z)<imag(z)
z=flip(z)
endif
elseif @Va=="30"
z=z+1/z
elseif @Va=="31"
z=z+2/z
elseif @Va=="32"
z=z+1/tan(z)
elseif @Va=="33"
z=z+0.5/cosh(z)
elseif @Va=="34"
z=z+1/cosh(z)
elseif @Va=="35"
z=z+2/sinh(z)
elseif @Va=="36"
z=z+1.5/sinh(z)
elseif @Va=="37"
z=z+0.3*flip(z)
elseif @Va=="38"
z=z-0.3*abs(z)
elseif @Va=="39"
z=z+1.1*exp(z)
elseif @Va=="40"
z=z-0.8*exp(z)
elseif @Va=="41"
z=z+sqr(z)
elseif @Va=="42"
z=z+5*sqr(z)
elseif @Va=="43"
z=z-0.5*sqr(z)
elseif @Va=="44"
z=z+cosh(z)
elseif @Va=="45"
z=z+cos(z)
endif
else
if @Va=="none"
z=z
elseif @Va=="27"
if |z|>1
z=z/|z|
endif
elseif @Va=="28"
if |z|<1
z=z/|z|
endif
elseif @Va=="29"
if real(z)>imag(z)
z=flip(z)
endif
elseif @Va=="30"
z=z+0.25/exp(z)
elseif @Va=="31"
z=z-1.5/cotanh(z)
elseif @Va=="32"
z=z+0.2/sinh(z)
elseif @Va=="33"
z=z+0.3*flip(z)
elseif @Va=="34"
z=z+0.3*cabs(z)
elseif @Va=="35"
z=z-0.7*exp(z)
elseif @Va=="36"
z=z+0.7*sqr(z)
elseif @Va=="37"
z=z+0.2*cotan(z)
elseif @Va=="38"
z=z-2*tan(z)
elseif @Va=="39"
z=z-tan(z)
elseif @Va=="40"
z=z-0.5*tan(z)
elseif @Va=="41"
z=z+0.5*cosh(z)
elseif @Va=="42"
z=z-0.3*cosh(z)
elseif @Va=="43"
z=z-1.1*cosh(z)
elseif @Va=="44"
z=z-0.4*sinh(z)
elseif @Va=="45"
z=z-2*sin(z)
endif
endif
endwhile
z=@adj*z/100
bailout:
|z|<@bail

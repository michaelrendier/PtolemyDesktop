Formula param formulaClass
caption="Plug-In"
default=MT_BarnsleyIJulia
endparam
}

Barnsley4{
global:
import "common.ulb"
import "reb.ulb"
Formula f = new @formulaClass(0)
init:
z=fn1(abs(pixel))
loop:
if @plugin
if real(z)>0
z=f.Iterate(fn2(z)^2+p1)
else
z=f.Iterate(fn3(z)^2+p2)
endif
else
if real(z)>0
z=fn2(z)^2+p1
else
z=fn3(z)^2+p2
endif
endif
bailout:
|z|<@bailout

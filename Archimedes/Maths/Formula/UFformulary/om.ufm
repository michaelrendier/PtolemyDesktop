KleinLatticePlus{
; Adapted and modified from Morgan_L_Owens.frm
init:
r=p1*(1/2)
z=fn1(pixel)
c=p2*fn2(z)
loop:
if |z-c|<|r|
z=p4*fn3(r*conj(r/(fn4(z)-c))+c)^@pow+p3
endif
bailout:
|z|<=@bail
default:

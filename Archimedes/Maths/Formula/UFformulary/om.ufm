Pickover5{
init:
z=fn2(pixel)^@pow1
loop:
x=|sin(p1*imag(z))|+(sin(p1*real(z)))^2
y=|sin(p2*real(z))|+(sin(p2*imag(z)))^2
z=fn1(x+flip(y))^@pow2
bailout:
|z|<@bail

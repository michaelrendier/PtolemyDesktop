z=@mult*fn1((p1*(p1*conj(z)+p2)/(p3*conj(z)+p4)+p2)/(p3*(p1*conj(z)+p2)/(p3*conj(z)+p4)+p4))^@pow
elseif @f==1
z=@mult*fn1((p1* (p3*conj(z)+p4) /(p1*conj(z)+p2)+p2)/(p3* (p3*conj(z)+p4) /(p1*conj(z)+p2)+p4))^@pow
elseif @f==2
z=@mult*fn1((p1*(-p3*conj(z)+p1)/ (p4*conj(z)-p2)+p2)/(p3*(-p3*conj(z)+p1)/ (p4*conj(z)-p2)+p4))^@pow
elseif @f==3
z=@mult*fn1((p1*conj(z)+p2)/(p3*conj(z)+p4)+(p3*conj(z)+p4)/(p1*conj(z)+p2))^@pow
elseif @f==4
z=@mult*fn1((p1*conj(z)+p2)/(p3*conj(z)+p4)-(p3*conj(z)+p4)/(p1*conj(z)+p2))^@pow
elseif @f==5
z=@mult*fn1((p1*conj(z)+p2)/(p3*conj(z)+p4)+(p4*conj(z)-p2)/(-p3*conj(z)+p1))^@pow
elseif @f==6
z=@mult*fn1((p1*conj(z)+p2)/(p3*conj(z)+p4)-(p4*conj(z)-p2)/(-p3*conj(z)+p1) )^@pow
elseif @f==7
z=@mult*fn1(((p1*conj(z)+p2)/(p3*conj(z)+p4))*(p4*conj(z)-p2)/(-p3*conj(z)+p1)  )^@pow
elseif @f==8
z=@mult*fn1((p1*conj(z)+p2)/(p3*conj(z)+p4)/(p4*conj(z)-p2)/(-p3*conj(z)+p1) )^@pow
endif
bailout:
|z|<@bail

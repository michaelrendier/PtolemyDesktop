if real(z)<imag(z)
z=flip(z)
endif
endif
if |z|<1
z=z/|z|
endif
z=p3*fn3(log(abs(fn4(1-((z/2)*(log(z/2+0.5)-log(z/2)-0.5))))))^@pow+p4
endwhile
elseif @V2=="3"
if |z|<1
z=z/|z|
endif
while i<@iter
i=i+1
z=fn2(z)
x=real(z)+real(p2)
y=imag(z)+imag(p2)
a=x^2+y^2
x=x/a+real(p1)
y=y/a+imag(p1)

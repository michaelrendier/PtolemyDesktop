f727{
init:
z=fn1(pixel)
loop:
z=fn2(z)
z=(p1+sqrt(p1^2-p2*cos(z)*cos(z-p3)))/cos(z)
z=fn3(z)
bailout:
|z|<@bail
default:
  title="f727"
  center=(0.001,0.001)
  func fn1
  default=cos()
  endfunc
  func fn2
  default=cos()
  endfunc
  func fn3
  default=cos()
  endfunc
  param p1
  default=(1.65,0)
  endparam
  param p2
  default=(1,0)
  endparam
  param p3
  default=(0,0)
  endparam
  param bail
  caption="Bailout"
  default=4.0
  endparam
}

f728{
init:
z=fn1(pixel)
loop:
x=p1*log(z)
y=p1*(z+recip(z))/2
z=p3*@fn(x+flip(y))+p2
bailout:
|z|<@bail
default:
title="f728"
center=(0.79,-0.06)
magn=2.8
maxiter=500

sqr(z)KleinMidpoint {
init:
z=fn1(pixel)
int i=0
f=(0,0)
f1=(0,0)
loop:
zold=z
if @V=="1"
z=fn2(sqr(fn3(z)))
if @P=="Tv"
f=z^4+2*sqrt(3)*sqrt(-1)*z^2+1
f1=4*z^3+4*sqrt(3)*sqrt(-1)*z
elseif @P=="Tf"
f=z^4-2*sqrt(3)*sqrt(-1)*z^2+1
f1=4*z^3-4*sqrt(3)*sqrt(-1)*z
elseif @P=="Ov"
f=z^5-z
f1=5*z^4-1

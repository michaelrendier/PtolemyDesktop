f705 (hamiltonian){
;https://physics.ucsd.edu/students/courses/spring2011/physics221a/LECTURES/CH07_CHAOS.pdf
init:
z=fn1(pixel)^p4
loop:
x=real(z)+p1*p2*sin(2*pi*imag(z))
y=imag(z)-(p1/p2)*sin(2*pi*(real(z)+p1*p2*sin(2*pi*imag(z))))
z=@fn(x+flip(y))^p3
bailout:
|z|<@bail
default:
title="Hamilton"
center=(0.001,0.001)
param p1
default=(0.274907,-0.010433)
endparam

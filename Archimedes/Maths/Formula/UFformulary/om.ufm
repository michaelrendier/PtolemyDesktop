loop:
while i<@iter
i=i+1
z=abs(fn1(z-p1*((z*fn2(z)-p2)/((fn2(z)*(z+1)-(z+2)*(z*fn2(z)-p2)/(2*z+2))+p3))))^@pow*p4
endwhile

z=2*sin(z^@pow/2)+p1
elseif @F=="acrd"
z=2*asin(z^@pow/2)+p1
elseif @F=="gd"
z=  asin(tanh(z^@pow))+p1
elseif @F=="agd"
z=asinh(tan(z^@pow))+p1
elseif @F =="sinc"
z=sin(z^@pow)/(z^@pow)+p1
elseif @f=="sinhc"
z=sinh(z^@pow)/(z^@pow)+p1
elseif @F=="cosc"
z=cos(z^@pow)/(z^@pow)+p1

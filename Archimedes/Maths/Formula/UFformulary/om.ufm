c2=p3*fn2(exp((0,1)*a))
c3=p3*fn2(exp((0,2)*a))
r=fn3(sqrt(p4)/2)
loop:
b=p5*conj(p5/(@fn5(z)-p6))+p6
if |b-c1|<|r|
z=p1*fn4(r*conj(r/(b-c1))+c1)+p2
elseif |b-c2|<|r|
z=p1*fn4(r*conj(r/(b-c2))+c2)+p2
elseif |b-c3|<|r|
z=p1*fn4(r*conj(r/(b-c3))+c3)+p2
else

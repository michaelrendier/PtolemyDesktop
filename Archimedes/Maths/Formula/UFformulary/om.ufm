Lenkan {
init:
z=fn1(pixel)
int i=0
loop:
while i<@iter
i=i+1
z=fn2(fn3(z))
float x=real(z)+real(p6)
float y=imag(z)+imag(p6)
float a=x^2+y^2
x=x/a+real(p1)
y=y/a+imag(p1)
if real(z)<0
z=-real(z)+flip(imag(z))
endif
z=x+flip(y)
if real(z)<0
z=-real(z)+flip(imag(z))
endif
if @V=="1"
z=p2*log(abs(flip(p3/(z-p4))+p4))^@pow+p5
elseif @V=="2"
z=p2*log(abs(flip(p3/(z-p4))-p4))^@pow+p5
elseif @V=="3"
z=p2*log(abs(flip(p3/(z^2-p4))+p4))^@pow+p5-0.5
elseif @V=="4"
z=p2*log(abs(flip(p3/(z^2-p4))-p4))^@pow+p5-1
elseif @V=="5"
z=p2*log(abs(flip(p3/(z^3-p4))+p4))^@pow+p5-0.6
elseif @V=="6"
z=p2*log(abs(flip(p3/(z^3-p4))-p4))^@pow+p5-1
endif
endwhile
z=@adj*z/100
bailout:
|z|<@bail
default:
title="Lenkan"
center=(0.001,0.001)
maxiter=500

LucasPolynomials {
init:
z=fn1(pixel)
int i=0
loop:
while i<@iter
i=i+1
z=fn2(z)
x=real(z)
y=imag(z)
a=x^2+y^2
x=x/a+real(p1)
y=y/a+imag(p1)
z=x+flip(y)
if @V=="4"
z=p2*log(abs(z^4+4*z^2+2))^@pow+p3
elseif @v=="5"
z=p2*log(abs(z^5+5*z^3+5*z))^@pow+p3
elseif @v=="6"
z=p2*log(abs(z^6+6*z^4+9*z^2+2))^@pow+p3
elseif @v=="7"
z=p2*log(abs(z^7+7*z^5+14*z^3+7*z))^@pow+p3
elseif @v=="8"
z=p2*log(abs(z^8+8*z^6+20*z^4+16*z^2+2))^@pow+p3
elseif @v=="9"
z=p2*log(abs(z^9+9*z^7+27*z^5+30*z^3+9*z))^@pow+p3
elseif @v=="10"
z=p2*log(abs(z^10+10*z^8+35*z^6+50*z^4+25*z^2+2))^@pow+p3
elseif @v=="11"
z=p2*log(abs(z^11+11*z^9+44*z^7+77*z^5+55*z^3+11*z))^@pow+p3
elseif @v=="12"
z=p2*log(abs(z^12+12*z^10+54*z^8+112*z^6+105*z^4+36*z^2+2))^@pow+p3
endif
endwhile
z=@adj*z/100
bailout:
|z|<@bail
default:
title="Lucas Polynomials"
center=(0.001,0.001)
maxiter=500
periodicity=0
param V

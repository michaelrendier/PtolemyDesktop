Variations {
;http://www.math.chalmers.se/Math/Grundutb/GU/MMG510/V12/PoincareBendixson.pdf
init:
z=fn1(pixel)
loop:
z=fn2(z)
if @V==0
x=imag(z)-p1*real(z)*(cabs(real(z))-1)
elseif @V==1
x=imag(z)-p1*real(z)*(real(z)^4+real(z)^2-1)/10
elseif @V==2
x=imag(z)-p1*real(z)*(2*real(z)^2-sin(pi*real(z))^2-2)
elseif @V==3
x=imag(z)-p1*(real(z)-cabs(real(z)+1)+cabs(real(z)-1))
else
x=imag(z)-p1*(cabs(real(z))*real(z)^3-real(z))
endif
y=-real(z)
z=x+flip(y)
bailout:
|z|<@bail
default:
title="Van der Pol Variations"
center=(0.001,0.001)
maxiter=260
periodicity=0

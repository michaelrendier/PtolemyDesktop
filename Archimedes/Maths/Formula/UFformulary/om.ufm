Labsy5 {
;Note: The Iterations parameter controls the amount of detail.
;It will be necessary to increase the value of this parameter when zooming in.
init:
z=sqr(fn1(pixel))
int i=0
loop:
while i<@iter
i=i+1
float k=real(z)
if k<0
z=z*@p1-1
else
z=z*conj(@p1)+1
endif
if @V=="1"
z=p2*log(abs(flip(fn2(z))))^@pow+pixel+p3
elseif @V=="2"
z=pixel*p2*log(abs(flip(fn2(z))))^@pow+p3
elseif @V=="3"
z=p2*log(abs(flip(fn2(z))))^@pow+p3
elseif @V=="4"
z=p2*log(abs(flip(sqr(fn2(z*pixel)))))^@pow+p3+sqrt(-1)
endif
endwhile
z=p4*z/100
bailout:
|z|<=@bail

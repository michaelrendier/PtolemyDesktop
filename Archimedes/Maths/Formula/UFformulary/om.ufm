caption="Function 2"
default=ident()
endfunc
param pow
caption="Exponent 1"
default=1
endparam
param p3
caption="Exponent 2"
default=(1,0)
endparam
param bail
caption="Bailout"
default=7.0
endparam
}

f700 (svensson){

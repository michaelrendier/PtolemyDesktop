}

SierpinskiTriangle {
;Based very closely on 'Twisted Sierpinski' in sam.ufm
; I have added extra parameters and functions
init:
z=fn1(pixel)^@pow
loop:
if imag(z)>p6
z=fn2((p1*real(z))/p3+flip((p2*imag(z)-@p7)/p3))+@p8
elseif real(z)>p6
z=fn3((p1*real(z)-@p7)/p4+flip((p2*imag(z))/p4))+@p9
else
z=fn4((p1*real(z))/p5+flip((p2*imag(z))/p5))+@p10
endif
bailout:
|z|<@bailout
default:
 title="Sierpinski Triangle"
 center=(0.001,0.001)
 maxiter=500
 periodicity=0
 param p1
 caption="Multiply 1"
 default=(2,0)
 endparam
 param p2
 caption="Multiply 2"
 default=(2,0)
 endparam
 heading
 endheading

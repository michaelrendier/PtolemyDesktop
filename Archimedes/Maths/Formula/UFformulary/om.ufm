elseif @Va=="17"
z=z+0.3*cos(z)
elseif @Va=="18"
z=z-0.3*sqr(z)
elseif @Va=="19"
z=z-0.3*abs(z)
endif
else
if @Va=="none"
z=z
elseif @Va=="1"
z=z+1/z
elseif @Va=="2"
z=z+1/exp(z)
elseif @Va=="3"
z=z+1/tanh(z)
elseif @Va=="4"
z=z+1/sinh(z)
elseif @Va=="5"
z=z+1/sin(z)
elseif @Va=="6"
z=z-1/cotanh(z)
elseif @Va=="7"
z=z-1/cotan(z)
elseif @Va=="8"

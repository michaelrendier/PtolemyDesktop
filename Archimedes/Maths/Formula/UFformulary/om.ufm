Unginongus{
init:
z=fn1(pixel)
loop:
a=p1*fn3(p1/(fn2(z)-p2))+p2
z=p3*fn4(p3/(fn2(a)-p4))+p4
bailout:
|z|<@bailout
default:
  title="Unginongus"
  center=(0.001,0.001)
  magn=0.5
  maxiter=250

SinTitulo {
init:
z=fn1(exp(pixel))
loop:
z=fn2(z)
if @Va=="none"
z=z
elseif @Va=="1"
x=real(z)
y=imag(z)
x=x/|z|
y=y/|z|
z=x+flip(y)
elseif @Va=="2"
x=real(z)
y=imag(z)

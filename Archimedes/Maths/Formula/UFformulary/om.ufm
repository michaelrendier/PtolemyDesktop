init:
z=fn1(pixel)
int i=0
loop:
while i<@iter
i=i+1
if @V=="1"
z=p1*abs(fn2(z^2+z^2*pixel))^@pow+p2
elseif @V=="2"
z=p1*abs(log(fn2(z^2+z^2*pixel)))^@pow+p2
elseif @V=="3"
z=p1*abs(flip(fn2(z^2+z^2*pixel)))^@pow+p2
elseif @V=="4"
z=p1*abs(log(fn2(z^2+sqr(z^2)*pixel)))^@pow+p2
elseif @V=="5"
z=p1*log(abs(fn2(z^2+sqr(z^2)*pixel)))^@pow+p2
elseif @V=="6"
z=p1*log(abs(fn2(z^2+z^2*pixel)))^@pow+p2
elseif @V=="7"
z=p1*abs(fn2(z^2+sqr(z^2)*pixel))^@pow+p2
elseif @V=="8"
z=p1*abs(fn2(z^2+tan(z^2)*pixel))^@pow+p2
elseif @V=="9"
z=p1*abs(fn2(z^2+tanh(z^2)*pixel))^@pow+p2
elseif @V=="10"
z=p1*abs(fn2(z^2+log(z)^2*pixel))^@pow+p2
elseif @V=="11"
z=p1*abs(fn2(z^2+tanh(z)^2*pixel))^@pow+p2
elseif @V=="12"
z=p1*abs(log(fn2(z^2+tanh(z)^2*pixel)))^@pow+p2
elseif @V=="13"
z=p1*abs(log(fn2(z^2+atanh(z)^2*pixel)))^@pow+p2
elseif @V=="14"

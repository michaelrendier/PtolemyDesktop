King'sDream {
; http://softology.com.au/tutorials/attractors2d/tutorial.htm
init:
z=fn1(pixel)
loop:
x=sin(p1*imag(z))+p2*sin(p1*real(z))
y=sin(p3*real(z))+p4*sin(p3*imag(z))
z=fn2(x+flip(y))^@pow
bailout:
|z|<@bail
default:
  title="King's Dream"
  center=(0.001,0.001)
  magn=0.5
  periodicity=0
  param p1
  default=(-1.48,0.29)
  endparam

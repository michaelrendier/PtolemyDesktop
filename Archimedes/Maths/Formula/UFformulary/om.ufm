param p2
default=(0,0)
endparam
param p3
default=(1,0)
endparam
param p4
default=(0,0)
endparam
func fn1
default=ident()
endfunc
func fn2
default=ident()
endfunc
func fn3
default=ident()
endfunc
func fn4
default=ident()
endfunc
param pow
caption="Exponent"
default=1.0
endparam
param iter
caption="Iterations"
default=17
endparam
param adj
caption="Adjustment"
default=102.0
endparam
param bail
caption="Bailout"
default=1000000.0
endparam
}


if real(z)<imag(z)
z=flip(z)
endif
elseif @Va=="3"
z=2*z
elseif @Va=="4"
z=5*z
elseif @Va=="5"
z=-3*z
elseif @Va=="6"
z=z+0.15*flip(z)
elseif @Va=="7"
z=z-0.15*flip(z)
elseif @Va=="8"
z=z+6*flip(z)
elseif @Va=="9"
z=z-6*flip(z)
elseif @Va=="10"
z=z+3*abs(z)
elseif @Va=="11"
z=z-3*abs(z)
elseif @Va=="12"
z=z+2*exp(z)
elseif @Va=="13"
z=z+0.5*sqr(z)
elseif @Va=="14"
z=z+sqr(z)
elseif @Va=="15"
z=z+1.5*sqr(z)
elseif @Va=="16"
z=z+2*sqr(z)
elseif @Va=="17"

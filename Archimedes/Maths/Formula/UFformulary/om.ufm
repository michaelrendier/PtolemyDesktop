z=fn2(real(z)^2-imag(z)^2-1+flip(2*real(z)*imag(z)))^@pow+p2
else
z=fn2(real(z)^2-imag(z)^2-1+real(p1)*real(z)+flip(2*real(z)*imag(z) +imag(p1)*real(z)))^@pow+p2
endif

z=z-0.081488/cos(cos(z))
else
z=z+0.6315/sin(z)
endif
elseif @Va=="23"
if @JM=="J"
z=z+0.78/sqr(exp(z))
else
z=z+1.67017/sqr(recip(z))
endif
elseif @Va=="24"
z=z-1.51834/sqr(recip(z))
elseif @Va=="25"
if @JM=="J"
z=z-0.85635/cos(sqr(z))
else
z=z+1.72928/z
endif
elseif @Va=="26"
if @JM=="J"
z=z-0.8114605/cos(sqr(z))
else
z=z-2.11216/cotan(cotanh(z))
endif
elseif @Va=="27"
if @JM=="J"
z=z+0.07252/tan(exp(z))
else
z=z+0.18618/sqr(cotanh(z))
endif
elseif @Va=="28"
z=z-0.89986/tan(recip(z))
endif
bailout:
|zold-z|>@bail
default:
title="Secant 7"
center=(0.001,0.001)
periodicity=0

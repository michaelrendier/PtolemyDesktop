Hyperharmonic-ExponentialPolynomials {
;https://arxiv.org/pdf/0912.1834.pdf
init:
z=fn1(pixel)
int i=0
loop:
while i<@iter
i=i+1
z=fn2(fn3(z))
x=real(z)
y=imag(z)
a=x^2+y^2
x=x/a+real(p1)
y=y/a+imag(p1)
z=x+flip(y)
if @v=="a2"
z=p2*log(abs(z+2.5*z^2))^@pow+p3
elseif @v=="a3"
z=p2*log(abs(z+7.5*z^2+(13/3)*z^3))^@pow+p3
elseif @v=="a4"
z=p2*log(abs(z+17.5*z^2+26*z^3+(77/12)*z^4))^@pow+p3
elseif @v=="a5"
z=p2*log(abs(z+37.5*z^2+(325/3)*z^3+(385/6)*z^4+8.7*z^5))^@pow+p3
elseif @v=="b2"

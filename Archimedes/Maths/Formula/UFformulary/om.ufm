AnotherNewton2 {
init:
if @S=="Pixel"
z=fn1(pixel)^@powS2
else
z=fn1(pixel-(pixel^@powS-1)/(@powS*pixel^(@powS-1)))
endif
loop:
zold=z
z=fn2(z)
z=(z-p5)/(1-p5*z)
z=z+p6/fn3(z)
f=((1-@pow)*z-p3)/((@pow-1)*(@pow-2)*(z+p3)^(@pow-1))-1
f1=z/(z+p3)^@pow
z=z-p1*f/f1+p2
bailout:
|zold-z|>@bail

  default=1000.0
  endparam
}

f755 {
init:
z=fn1(log(pixel))
loop:
if real(fn2(z^2+p4))<p1
z=(z^2+p4)*p2-p3
endif
if real(fn2(z^2+p4))>=p1
z=(z^2+p4)*conj(p2)+p3
endif
bailout:
|z|<@bail
default:
  title="Luisijaf 1"
  angle=90
  maxiter=500
  center=(1,0.6)
  param p1
  caption="Parameter 1"
  default=2.38
  endparam
  param p2
  default=(0.48,-1.02)
  endparam
  param p3
  default=(1,0)
  endparam
  param p4
  default=(1,0)

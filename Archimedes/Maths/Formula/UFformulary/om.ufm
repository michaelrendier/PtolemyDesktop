"sec""sech""asec""asech""cosec""cosech""acosec""acosech""exsec""aexsec"\
"excosec""aexcosec""crd""acrd""gd""agd""sinc""sinhc""cosc""coshc"\
"tanc""tanhc""cotanc""cotanhc""secc""sechc""cosecc""cosechc"

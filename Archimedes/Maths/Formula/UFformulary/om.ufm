 caption="Start Function 2"
 default=ident()
 endfunc
 func fn3
 caption="Start Function 3"
 default=ident()
 endfunc
 func fn1
 caption="Loop Function"
 default=ident()
 endfunc
 param bail
 caption="Bailout"
 default=4.0
 endparam
}

Klein3mod{
init:
a=2*pi/3
c1=p3*fn2(exp((0,0)*a))
c2=p3*fn2(exp((0,1)*a))
c3=p3*fn2(exp((0,2)*a))
r=fn3(sqrt(p4)/2)
z=fn4(pixel)
loop:
if |z-c1|<|r|
k=p1*fn1(r*conj(r/(z-c1))+c1)+p2
elseif |z-c2|<|r|
k=p1*fn1(r*conj(r/(z-c2))+c2)+p2
elseif |z-c3|<|r|
k=p1*fn1(r*conj(r/(z-c3))+c3)+p2
else
k=p1*fn1(r*conj(r/(z)))+p2
endif
z=(@fn5(k)+p5)/(@fn5(k)-p5)
bailout:|z|<@bailout

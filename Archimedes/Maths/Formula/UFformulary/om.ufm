Saventeest{
init:
z=fn1(pixel)
loop:
a=p1*fn2(z)^@pow+p2
b=(2*a-1)/(-a+1)
z=(b-1)/(-b+2)
bailout:
|z|<@bail
default:
title="Saventeest"
center=(0.001,0.001)
maxiter=250
periodicity=0
param p1
default=(-1.6,0)
endparam
param p2
default=(1,0)
endparam

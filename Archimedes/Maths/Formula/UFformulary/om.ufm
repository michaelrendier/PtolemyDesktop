; Adapted and modified from Morgan_L_Owens.frm
init:
a=2*pi/3
c1=p3*fn2(exp((0,0)*a))
c2=p3*fn2(exp((0,1)*a))
c3=p3*fn2(exp((0,2)*a))
r=fn3(sqrt(p4)/2)
z=fn4(pixel)
loop:
if |z-c1|<|r|
z=p1*fn1(r*conj((z-c1)/(|z-c1|)))+p2
elseif |z-c2|<|r|
z=p1*fn1(r*conj((z-c2)/(|z-c2|)))+p2
elseif |z-c3|<|r|
z=p1*fn1(r*conj((z-c3)/(|z-c3|)))+p2
else
z=p1*fn1(r*conj(z/(|z|)))+p2
endif

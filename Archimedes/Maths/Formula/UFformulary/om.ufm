Mozint{
init:
z=fn1(pixel)
loop:
a=fn2(abs(exp(p1/(1+sqrt(p2)-z)-(1+sqrt(p1))/(2+sqrt(p2)))))
if imag(a)>0
k=a
else
k=conj(a)
endif
z=log(k+p3)
bailout:|z|<@bailout
default:
  title="Mozint"
  center=(0.001,0.001)
  maxiter=500
  param p1
  default=(1.2,0)
  endparam
  param p2
  default=(0.3,0)

endparam
}

Vurg {
init:
z=fn1(pixel)
int i=0
loop:
if @V=="1"
z=p3*sinh(z)+p4
while (i<@iter)
i=i+1
z=p2*fn2(z)+p1/(1-p5^fn3(-z))
i=i+1
endwhile
z=z^2+1
z=cotan(z)
elseif @V=="2"
while (i<@iter)
z=p3*sinh(z)+p4
i=i+1
z=p2*fn2(z)+p1/(1-p5^fn3(-z))
i=i+1
endwhile
z=z^2+1
z=cotan(z)
elseif @V=="3"
while (i<@iter)
i=i+1
z=p2*fn2(z)+p1/(1-p5^fn3(-z))
i=i+1
z=p3*sinh(z)+p4

Magmod2 {


init:
z=fn1(pixel)

int i=0
loop:

while i<@iter
i=i+1
z=fn2(sqr(fn3(z)))

x=real(z)+real(p1)
y=imag(z)+imag(p1)

a=x^2+y^2

x=x/a*p2+real(p3)
y=y/a*p2+imag(p3)
if real(x)-real(y)<0
k=y
y=x
x=k
endif

z=x+flip(y)
if @V=="1"
z=pixel*p4*log(abs(fn4(sqr((z^2+p5-1)/(2*z+p5-2)))))^@pow+p6
elseif @V=="2"
z=pixel*p4*log(abs(fn4(sqr((z^3+3*(p5-1)*z+(p5-1)*(p5-2))/(3*z^2+3*(p5-2)*z+(p5-1)*(p5-2)+1)))))^@pow+p6
endif
endwhile
z=@adj*z/100
bailout:
|z|<@bail

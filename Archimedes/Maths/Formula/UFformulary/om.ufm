-z*(z*(z*(z*(z-1)-z)-z*(z-1))-z*(z*(z-1)-z)))-z*(z*(z*(z*(z*(z-1)-z)-z*(z-1))-z*(z*(z-1)-z))\
-z*(z*(z*(z-1)-z)-z*(z-1))))))^@pow+p3
elseif @v=="9"
z=p2*log(abs(z*(z*(z*(z*(z*(z*(z*(z*(z-1)-z)-z*(z-1))-z*(z*(z-1)-z))-z*(z*(z*(z-1)-z)-z*(z-1)))\
-z*(z*(z*(z*(z-1)-z)-z*(z-1))-z*(z*(z-1)-z)))-z*(z*(z*(z*(z*(z-1)-z)-z*(z-1))-z*(z*(z-1)-z))-z*\

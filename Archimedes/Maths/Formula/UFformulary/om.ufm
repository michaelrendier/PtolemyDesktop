 param @p10
 caption="Add 3"
 default=(0,0)
 endparam
 heading
 endheading
 param p6
 caption="Conditional"
 default=0.5
 endparam
 heading
 endheading
 func fn1
 default=ident()
 endfunc
 func fn2
 default=ident()
 endfunc
 func fn3
 default=ident()
 endfunc
 func fn4
 default=ident()
 endfunc
 heading
 endheading
 param pow
 caption="Exponent"
 default=1
 endparam
 heading

AmanitaAbrupta {
init:
z=fn1(pixel)
loop:
x=real(z)
y=imag(z)
x=x^2-y^2+abs(real(pixel))
y=2*conj(real(z))*abs(y)+fn2(imag(pixel))
z=p1*fn3(x+flip(y))+p2
bailout:
|z|<@bail
default:

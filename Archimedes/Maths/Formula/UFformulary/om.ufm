}

Wobite {
init:
z=fn1(pixel)
loop:
x=real(z)
y=imag(z)
x=x^2-y^2+real(fn2(cosh(p1*pixel)))
y=2*conj(real(z))*abs(y)+imag(fn2(cosh(p1*pixel)))
if @V=="1"
z=p2*(x+flip(y))+p3
elseif @V=="2"
z=p2*conj(x+flip(y))+p3
elseif @V=="3"
z=p2*abs(x+flip(y))+p3
elseif @V=="4"
z=p2*cosh(x+flip(y))+p3
elseif @V=="5"
z=p2*sin(x+flip(y))+p3
elseif @V=="6"
z=p2*conj(sqr(x+flip(y)))+p3
elseif @V=="7"
z=x+flip(y)
z=p2*(exp(z)-z)+p3
endif
if real(z)>imag(z)
z=flip(z)
endif
bailout:
|z|<@bail
default:
title="Wobite"
angle=90
param V
caption="Variant"
enum="1""2""3""4""5""6""7"
endparam

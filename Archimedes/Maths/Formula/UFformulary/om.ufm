x=x/a
y=y/a
z=x+flip(y)
if @V=="1"
z=p2*log(abs(sqr(recip((p1/fn4(z)-(z^sqrt(-1)-1)/z^(sqrt(-1)-1))/z^sqrt(-1)))))^@pow+p3

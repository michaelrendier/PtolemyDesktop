default=0.00004
endparam
}

Disc {
;adapted from RSP.frm by Rui S. Parracho
init:
z=fn1(fn2(fn3(pixel)))
if cabs(p1)==0
k=1
else
k=p1
endif
loop:
a=(p2*z+p3)^2
b=2*a*cos(a)+(a^2-2)*sin(a)+p1
c=a^2*cos(a)
z=a-k*b/c
bailout:
cabs(z)>@bail
default:
title="Disc"
center=(0.001,0.001)
param p1
default=(0.019029,-0.009514)
endparam
param p2
default=(1,0)

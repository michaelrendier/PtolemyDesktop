Toonu {
init:
z=fn1(pixel)
int i=0
loop:
zold=z
if @V=="1"
x=real(z)
y=imag(z)
a=x^2+y^2
x=x/a+real(p3)
y=y/a+imag(p3)
z=x+flip(y)
if |z|>1
z=z/|z|
endif
z=fn2(z-p1*(z*(1+z)*(1+10*z+z^2)/(1-z)^5)/((10+2*z)/(5*(1-z)^4)))+p2
else
while i<@iter
i=i+1
x=real(z)
y=imag(z)
a=x^2+y^2
x=x/a+real(p3)
y=y/a+imag(p3)
z=x+flip(y)
if |z|>1
z=z/|z|
endif
z=fn2(z-p1*(z*(1+z)*(1+10*z+z^2)/(1-z)^5)/((10+2*z)/(5*(1-z)^4)))+p2
endwhile
z=51*z/50
endif
bailout:
(|z|<@bail2 && @V=="2") || (|zold-z|>@bail1 && @V=="1")

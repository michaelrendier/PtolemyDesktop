Sastambor{
init:
z=fn1(pixel)
i=sqrt(-1)
loop:
a=((z^4-1)-i)/((z^4-1)+i)
b=((p1*fn2(a)+p2)-1)/((p1*fn2(a)+p2)+1)
z=p3*conj(p3/(b-p4))+p4
bailout:
|z|<@bailout
default:
  title="Sastambor"
  center=(0.001,0.001)
  maxiter=250
  func fn1
  default=ident()
  endfunc
  func fn2
  default=ident()
  endfunc

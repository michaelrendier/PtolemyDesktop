f656 (kam torus){
; http://www.fredsfractalpage.nl/contents.html
init:
z=fn1(pixel)
loop:
x=real(z)*cos(p1)+(real(z)^2-imag(z))*sin(p1)
y=real(z)*sin(p1)-(real(z)^2-imag(z))*cos(p1)
z=p2*@fn(x+flip(y))+p3
bailout:
|z|<@bail

elseif @Va=="11"
z=z+cos(z)
elseif @Va=="12"
z=z-sqr(z)
elseif @Va=="13"
z=z-cosh(z)
elseif @Va=="14"
z=z-cos(z)
elseif @Va=="15"
z=z-sinh(z)
elseif @Va=="16"
z=z-sin(z)
endif
endif
f=(z^4-p4)/z-p1
f1=(p4+3*z^4)/z^2
f2=6*z-2*p4/z^3
a=f/f1
b=f*f2/sqr(f1)
if @M=="Whittaker 1"
z=z-p2*(a/2)*(2-b)+p3
else
z=z-p2*(a/4)*(2-b+((4+2*b)/(2-b*(2-b))))+p3
endif
if @JM=="J"
z=p5*log(abs(z))^@pow+p6
else
z=p5*log(abs(z))^@pow+p6+fn4(pixel)
endif
if @JM=="J"
if @Va=="none"
z=z
elseif @Va=="17"
if |z|<1
z=z/|z|
endif
elseif @Va=="18"
if |z|>1
z=z/|z|
endif
elseif @Va=="19"
if real(z)<imag(z)
z=flip(z)
endif
elseif @Va=="20"
z=z+1/z
elseif @Va=="21"
z=z+1/sqr(z)
elseif @Va=="22"
z=z+1/cotanh(z)
elseif @Va=="23"
z=z+1/tan(z)
elseif @Va=="24"
z=z+1/cos(z)
elseif @Va=="25"
z=z+1/sinh(z)
elseif @Va=="26"
z=z-1/exp(z)
elseif @Va=="27"
z=z-1/cotanh(z)
elseif @Va=="28"
z=z-1/cotan(z)
elseif @Va=="29"
z=z-1/cos(z)
elseif @Va=="30"
z=z-1/sin(z)
elseif @Va=="31"
z=z-sqr(z)
elseif @Va=="32"
z=z-sinh(z)
elseif @Va=="33"
z=z-sin(z)
endif
else
if @Va=="none"
z=z
elseif @Va=="17"
if |z|<1
z=z/|z|
endif
elseif @Va=="18"
if |z|>1
z=z/|z|
endif
elseif @Va=="19"
if real(z)<imag(z)
z=flip(z)
endif
elseif @Va=="20"
z=z+1/exp(z)
elseif @Va=="21"
z=z+1/cotan(z)
elseif @Va=="22"
z=z+1/cos(z)
elseif @Va=="23"
z=z-1/exp(z)
elseif @Va=="24"
z=z-1/sqr(z)
elseif @Va=="25"
z=z-1/cotanh(z)
elseif @Va=="26"
z=z-1/cotan(z)
elseif @Va=="27"
z=z-1/tanh(z)

a=x^2+y^2
x=x/a+real(p1)
y=y/a+imag(p1)
z=x+flip(y)
z=p2*log(abs(recip(p3-log(z+exp(pixel))^2-z)))^@pow+p4
endwhile
elseif @V=="8"
while i<@iter
i=i+1
z=fn2(flip(exp(z)))
x=abs(real(z))+real(p5)
y=abs(imag(z))+imag(p5)
a=x^2+y^2
x=x/a+real(p1)
y=y/a+imag(p1)
z=x+flip(y)
if |z|<1
z=z/|z|
endif
z=p2*log(abs(p3-log(z+cosh(pixel))^2-z))^@pow+p4
endwhile
endif
z=@adj*z/100
bailout:
|z|<@bail

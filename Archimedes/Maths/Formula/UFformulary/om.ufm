elseif @Va=="49"
z=z-exp(z)
elseif @Va=="50"
z=z-sqr(z)
elseif @Va=="51"
z=z-cotanh(z)
elseif @Va=="52"
z=z-2*tanh(z)
elseif @Va=="53"
z=z-2*tan(z)
elseif @Va=="54"
z=z-cosh(z)
elseif @Va=="55"
z=z-sinh(z)
elseif @Va=="56"
z=z-sin(z)
elseif @Va=="57"
z=z-0.5*sqr(z)
endif
endif
endwhile

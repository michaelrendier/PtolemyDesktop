elseif @fn2=="exp flip"
z=exp(flip(z))
elseif @fn2=="flip exp"
z=flip(exp(z))
elseif @fn2=="flip sqr"
z=flip(sqr(z))
elseif @fn2=="sqr"
z=sqr(z)
elseif @fn2=="sqr recip"
z=sqr(recip(z))
elseif @fn2=="abs sqr"
z=abs(sqr(z))
endif
x=real(z)
y=imag(z)
a=x^2+y^2
x=x/a+real(p3)
y=y/a+imag(p3)
z=x+flip(y)
if |z|<1
z=z/|z|
endif
z=z^@pow/(p1+z)+p2
bailout:
|z|<@bail

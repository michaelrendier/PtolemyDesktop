elseif real(z^@pow1+pixel/(z-p1)^@pow2)> 0.5
z=fn3(2*real(z^@pow1+pixel/(z-p1)^@pow2)-1+flip(2*imag(z^@pow1+pixel/(z-p1)^@pow2)))
else
z=fn4(2*real(z^@pow1+pixel/(z-p1)^@pow2)+flip(2*imag(z^@pow1+pixel/(z-p1)^@pow2)))
endif
bailout:
|z|<@bail

SmawnTebold {
init:
z=fn1(pixel)
int i=0
loop:
while i<@iter
i=i+1
z=fn2(flip(sqr(fn3(z))))
z=z+p1
if |z|==0
z=0
elseif |z|<1
z=z/|z|
endif
if @v=="1"
z=p2*log(abs(z*pixel*p3+pixel))^@pow+p4
elseif @V=="2"
z=pixel*p2*log(abs(z*p3))^@pow+p4+pixel
elseif @V=="3"
z=pixel*p2*log(abs(z*p3))^@pow+p4
elseif @V=="4"
z=p2*log(abs(z*p3))^@pow+p4+pixel
elseif @V=="5"
z=p2*log(abs(z*pixel*p3))^@pow+p4
elseif @V=="6"
z=p2*log(abs(z*p3+pixel))^@pow+p4
elseif @V=="7"
z=pixel*p2*log(abs(z*pixel*p3+pixel))^@pow+p4+pixel
elseif @V=="8"
z=p2*log(abs(z*p3+pixel))^@pow+p4+pixel
elseif @V=="9"
z=pixel*p2*log(abs(z*pixel*p3))^@pow+p4
elseif @V=="10"
z=pixel*p2*log(abs(z*p3+pixel))^@pow+p4
elseif @V=="11"
z=p2*log(abs(z*pixel*p3))^@pow+p4+pixel
elseif @V=="12"
z=pixel*p2*log(abs(z*pixel*p3+pixel))^@pow+p4
elseif @V=="13"

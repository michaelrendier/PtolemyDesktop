EmacybinMetra{
init:
z=fn1(sqr(pixel))
loop:
if |z-p1|<|p2|
z=p2*conj(real(p2)/(fn2(z)-p1))+p1
elseif |z-p2|<|p3|
z=p3*conj(imag(p3)/(fn2(z)-p2))+p2
elseif |z-p3|<|p4|
z=p4*conj(real(p4)/(fn2(z)-p3))+p3
elseif |z-p4|<|p1|
z=p1*conj(imag(p1)/(fn2(z)-p4))+p4
endif
bailout:
|z|<@bailout
default:
 title="Emacybin Metra"
 center=(0.001,0.001)

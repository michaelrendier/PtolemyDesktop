elseif @Va=="2"
if |z|>1
z=z/|z|
endif
elseif @Va=="3"
x=real(z)
y=imag(z)
x=x/|z|
y=y/|z|
z=x+flip(y)
elseif @Va=="4"
if real(z)<imag(z)
z=flip(z)

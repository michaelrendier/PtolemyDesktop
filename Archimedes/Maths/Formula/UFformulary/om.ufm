f677 (bogdanov){
;https://en.wikipedia.org/wiki/Bogdanov_map
init:
z=fn1(pixel)^@pow1
loop:
y=imag(z)+p1*imag(z)+p2*real(z)*(real(z)-1)+p3*real(z)*imag(z)
x=real(z)+y
z=@fn(x+flip(y))^@pow2
bailout:
|z|<@bail
default:
title="Bogdanov"
center=(0.53,0.001)
angle=-110
maxiter=500
periodicity=0
param p1
default=(-2.0015,0)
endparam

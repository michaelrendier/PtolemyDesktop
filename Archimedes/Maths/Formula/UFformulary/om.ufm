}

Notwen2 {
; Notwen formulas are based on an inversion of part of the Newton formula:
; Newton z=z-f/f'
; Notwen z=z-f'/f
init:
z=fn1(pixel)
loop:
zold=z
z=(p4-0.5)*fn2(z)+p5
z=(z-p6)/(1-p6*z)
z=z+@p7/fn3(z)
f=z^3+log(1+exp(z))-p2
f1=3*z^2+exp(z)/(1+exp(z))
if @V=="Notwen"
z=z-p1*f1/f+p3
else
z=z-p1*f1/f+fn4(pixel)
endif
bailout:
|zold-z|>@bail

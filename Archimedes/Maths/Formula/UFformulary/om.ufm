caption="Start Function"
default=ident()
endfunc
func fn2
caption="Loop Function"
default=ident()
endfunc
param bail
caption="Bailout"
default=4.0
endparam
}

Collatz{
;https://en.wikipedia.org/wiki/Collatz_conjecture
init:
z=fn1(pixel)
loop:
z=p5*fn2(z)+p6
if @V==0
z=0.25*(p1+7*z-(p2+5*z)*cos(pi*z))
else
z=0.25*(p3+4*z-(p4+2*z)*cos(pi*z))
endif
bailout:
|z|<@bail
default:
  title="Collatz"
  center=(0.001,0.001)
  magn=2
  periodicity=0
  param V
  caption="Variant"
  enum="1""2"
  default=1
  endparam
  param p1
  caption="Parameter 1"
  default=2.0
  visible=@V==0

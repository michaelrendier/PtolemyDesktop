Castle {
;A modification of the formula found here:
; http://www.fracton.org/fmlposts/castle.html
init:
float a=real(p1)
float b=real(@pow)
float c=imag(p1)
float d=imag(@pow)
z=0
f=fn1(pixel)-p2
g=fn1(pixel)-p3
loop:
z=1/(1/(a*(fn2(z^b))+f)+1/(c*(fn2(z^d))+g))
bailout:
|z|<@bailout
default:
title="Castle"
center=(0.001,0.001)
magn=0.25
maxiter=250
param p1
default=(1,0)
endparam
param p2
default=(0,0)
endparam
param p3
default=(0,0)
endparam
param pow
caption="Exponent"
default=2.0
endparam
func fn1
default=ident()
endfunc
func fn2
default=ident()
endfunc
param bailout
caption="Bailout"
default=4.0
endparam
}


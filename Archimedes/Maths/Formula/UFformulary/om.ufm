f1=(10*z^4-16*z^3+3*z^2+2*z)/12
elseif @P=="6"
f=(6*z^6-15*z^5+6*z^4+6*z^3-z^2-z)/42
f1=(36*z^5-75*z^4+24*z^3+18*z^2-2*z-1)/42
elseif @P=="7"

ThreeKlein3{
;Adapted and modified from Morgan_L_Owens.frm
init:
a=2*pi/3
c1=p3*fn2(exp((0,0)*a))
c2=p3*fn2(exp((0,1)*a))
c3=p3*fn2(exp((0,2)*a))
r=fn3(sqrt(p4)/2)
z=fn4(pixel)
loop:
if |z-c1|<|r|
z1=p1*fn1(r*conj(r/(z-c1))+c1)+p2
elseif |z-c2|<|r|
z1=p1*fn1(r*conj(r/(z-c2))+c2)+p2
elseif |z-c3|<|r|
z1=p1*fn1(r*conj(r/(z-c3))+c3)+p2
else
z1=p1*fn1(r*conj(r/(z)))+p2
endif
z2=(2*z1+1)/(z1+1)
z=(p5^(2*z2+1)-p5^(-2*z2+1))/sqrt(5)
bailout:|z|<@bail
default:
 title="Three Klein 3"
 center=(0.001,0.001)
 maxiter=500
 periodicity=0
 param p1
 default=(1.23,0)
 endparam
 param p2
 default=(0.08,0)
 endparam
 param p3
 default=(2,0)

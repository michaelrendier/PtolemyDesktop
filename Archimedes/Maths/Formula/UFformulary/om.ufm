Notwen3 {
; Notwen formulas are based on an inversion of part of the Newton formula:
; Newton z=z-f/f'
; Notwen z=z-f'/f
init:
z=fn1(pixel)
loop:
zold=z
z=(p4-0.5)*fn2(z)+p5
z=(z-p6)/(1-p6*z)

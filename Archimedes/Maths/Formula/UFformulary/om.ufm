y=y/|z|
z=y+flip(x)
elseif @Va=="3"
x=real(z)
y=imag(z)
x=x/|z|
y=y/|z|
z=sqr(asin(x+flip(y)))
elseif @Va=="4"
if @JM=="J"
z=conj(z)+1/flip(z)
else
if |z|>1
z=z/|z|
endif
endif
elseif @Va=="5"
if @JM=="J"
x=real(z)
y=imag(z)
x=x/|z|
y=y/|z|
z=sqr(acosh(x+flip(y)))
else
x=real(z)
y=imag(z)
x=x/|z|
y=y/|z|
z=sqr(x+flip(y))
endif
elseif @Va=="6"

Labstet {
init:
z=fn1(pixel)
int i=0
loop:
while i<@iter
i=i+1
z=p1*fn2(fn3(z))+p2
x=real(z)
y=imag(z)
x=x/|z|+real(@p7)
y=y/|z|+imag(@p7)
z=x+flip(y)
if |z|>1
z=z/|z|
endif
if @JM=="J"
if @Va=="none"
z=z
elseif @Va=="1"
if real(z)>imag(z)
z=flip(z)
endif

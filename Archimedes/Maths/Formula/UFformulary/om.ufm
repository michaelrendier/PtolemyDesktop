}

f706 (brusselator){
;http://www-dimat.unipv.it/boffi/teaching/download/Brusselator.pdf
init:
z=fn1(pixel)^p4
loop:
x=1-(p2+1)*real(z)+p1*imag(z)*real(z)^2
y=p2*real(z)-p1*imag(z)*real(z)^2
z=@fn(x+flip(y))^p5
bailout:
|z|<@bail
default:

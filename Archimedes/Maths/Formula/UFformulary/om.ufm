 default=ident()
 endfunc
 func fn2
 default=ident()
 endfunc
 func fn3
 default=ident()
 endfunc
 param bailout
 caption="Bailout"
 default=10.0
 endparam
}

Slusenite{
init:
z=fn1(pixel)
loop:
a=(2*p1*fn2(abs(z+p2))-sqrt(-1))/(-sqrt(-1)*p1*fn2(abs(z+p2)))
z=a+2
bailout:
|z|<@bailout
default:
  title="Slusenite"
  center=(0.001,0.001)

elseif @Va=="18"
z=z-3*sin(z)
elseif @Va=="19"
z=z+7*sqr(z)
endif
endif
f=z*(z-1)*(z+1)/(z-2)-p1
f1=(2*(z^3-3*z^2+1))/(z-2)^2
a=f1/f
z=z-p2*a+p3

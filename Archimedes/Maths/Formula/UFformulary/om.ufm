f632{
init:
z=pixel
y=sin(pixel)
x=cos(pixel)
u=tan(pixel)
v=1-pixel
w=1+pixel
loop:
x=@par1*(y-x)
y=@par3*y-x*z
z=-@par2*z+x*y+u
u=fn1(sqr(v))
v=-fn2(atan(w^2*u))
bailout:
|z|<@bail
default:
title="f632"
center=(0.57,0.001)
maxiter=500

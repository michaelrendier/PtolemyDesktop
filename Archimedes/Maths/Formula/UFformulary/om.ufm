elseif 4*p1*p3-p2^2<0
f=(1/sqrt(p2^2-4*p1*p3))*log(cabs((2*p1*z+p2-sqrt(p2^2-4*p1*p3))/(2*p1*z+p2+sqrt(p2^2-4*p1*p3))))-p4
else
f=-2/(2*p1*z+p2)-p4
endif

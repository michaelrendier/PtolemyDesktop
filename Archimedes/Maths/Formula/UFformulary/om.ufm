Luisijaf4 {
init:
z=fn1(log(pixel))
int i=0
loop:
if @V2=="1"
z=fn2(z)
if @V=="2"
if real(z)>imag(z)
z=flip(z)
endif
endif
if |z|<1
z=z/|z|
endif
if real(fn3(z^2+p1))<p3
z=(z^2+p1)*0.5-p2
else
z=(z^2+p1)*0.5+p2
endif
elseif @V2=="2"
while i<@iter
i=i+1
z=fn2(z)
if @V=="2"
if real(z)>imag(z)
z=flip(z)
endif
endif
if |z|<1
z=z/|z|
endif
if real(fn3(z^2+p1))<p3
z=(z^2+p1)*0.5-p2
else
z=(z^2+p1)*0.5+p2
endif
endwhile
z=@adj*z/100
endif
bailout:
|z|<@bail
default:

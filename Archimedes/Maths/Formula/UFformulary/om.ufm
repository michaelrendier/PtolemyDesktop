elseif @Fl=="doublecube"
z=2*z^3
elseif @Fl=="triplecube"
z=3*z^3
elseif @Fl=="halfsqr+"
z=(sqr(z)+z)/2
elseif @Fl=="sqr+"
z=sqr(z)+z
elseif @Fl=="doublesqr+"
z=2*(sqr(z)+z)
elseif @Fl=="halfcube+"
z=(z^3+sqr(z)+z)/2

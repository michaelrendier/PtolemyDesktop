elseif @Va=="7"
z=z+1/cos(z)
elseif @Va=="8"
z=z+1/sinh(z)
elseif @Va=="9"
z=z+1/sin(z)
elseif @Va=="10"
z=z-1/sqr(z)
elseif @Va=="11"
z=z-1/cotanh(z)

 caption="Start Function 1"
 default=ident()
 endfunc
 func fn2
 caption="Start Function 2"
 default=ident()
 endfunc
 func fn3
 caption="Start Function 3"
 default=ident()
 endfunc
 func fn1
 caption="Loop Function"
 default=ident()
 endfunc
 param bail
 caption="Bailout"
 default=4.0
 endparam
}


elseif @v=="1-3"
z=p2*log(abs(3*sqrt(1-z^2)*(5*z^2-1)/2))^@pow+p3
elseif @v=="1-4"
z=p2*log(abs(5*sqrt(1-z^2)*(7*z^3-3*z)/2))^@pow+p3
elseif @v=="1-5"
z=p2*log(abs(15*sqrt(1-z^2)*(21*z^4-14*z^2+1)/8))^@pow+p3
elseif @v=="1-6"
z=p2*log(abs(21*sqrt(1-z^2)*z*(33*z^4-18*z^2+1)/8))^@pow+p3
elseif @v=="1-7"
z=p2*log(abs(7*sqrt(1-z^2)*(429*z^6-495*z^4+135*z^2-5)/16))^@pow+p3
elseif @v=="1-8"
z=p2*log(abs(9*sqrt(1-z^2)*z*(715*z^6-1001*z^4+385*z^2-35)/16))^@pow+p3
endif
endwhile

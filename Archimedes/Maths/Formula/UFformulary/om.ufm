QuackHybrid{
init:
z=fn1(pixel)
loop:
if imag((z-1)/(z+1))>0
k=p1*fn2((z-1)/(z+1))
else
k=p1*fn2(conj((z-1)/(z+1)))
endif
z=p2*fn3(log(k+p3))+p4
bailout:
(|z|<@baildiv1 && @B==0) || (|(z-1)/(z+1)|<@baildiv2 && @B==1) || (|z|>@bailcon1 && @B==2) || (|(z-1)/(z+1)|>@bailcon2 && @B==3)

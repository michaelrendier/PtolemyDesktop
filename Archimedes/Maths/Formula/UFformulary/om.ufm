caption="Start Parameter 1"
default=(0,0)
endparam
param p17
caption="Start Parameter 2"
default=(0,0)
endparam
param V1
caption="Variant 1"
enum="z^2-z""Munster""z^3-z""z^3-z^2""z^3-z^2-z""Cayley""Inverse Cayley"\
"Newton 1""Newton 2""Halley""Inkle""Magnet 1""Magnet 2"
default=7
endparam
param V2
caption="Variant 2"
enum="1""2""3"
default=0
endparam
param V3
caption="Variant 3"
enum="1""2""3"
default=1
endparam
param V
caption="Polynomial"
enum="Q1(B2)""Q2(A2)""Q3(B2)"\
"Q8(A3)""Q9(A3)""Q10(B3)""Q11(B3)""Q12(B3)"\
"Q16(G2)""Q17(B3)""Q18(G2)""Q19(B3)""Q20(G2)""Q21(D4)""Q22(B4)""Q23(D4)"\
"Q24(G2)""Q25(B2)""Q26(A2)""Q27(B2)""Q28(G2)""Q29(G2)"\
"Q36(A3)""Q37(B3)""Q38(B3)""Q39(B3)""Q40(B3)"\
"Q43(B3)""Q44(B3)"\
"Q46(D4)""Q47(D5)""Q48(B5)"\
"Pg2""Pf4""Pe6""Pe7""Pe8"
default=0

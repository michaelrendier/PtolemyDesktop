f1=20*z^19+153*z^16+504*z^13+847*z^10+720*z^7+255*z^4+20*z
endif
z=p3*z-p1*f/f1+p2
endwhile
z=51*z/50
endif
bailout:
(|z|<@bail2 && @V=="2") || (|zold-z|>@bail1 && @V=="1")

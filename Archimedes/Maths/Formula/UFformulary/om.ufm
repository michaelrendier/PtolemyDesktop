f699 (popcorn 2) {
;http://www.3d-meier.de/tut19/Seite61.html
init:
z=fn1(pixel)^@pow
loop:
if @V==0
x=p1*sin(imag(z)+tan(p2*imag(z)))
y=p1*sin(real(z)+tan(p2*real(z)))
else
x=real(z)-p1*sin(imag(z)+tan(p2*imag(z)))
y=imag(z)-p1*sin(real(z)+tan(p2*real(z)))
endif
z=@fn(x+flip(y))^p3
bailout:
|z|<@bail
default:
title="Popcorn"
center=(0.001,0.001)
magn=0.125
periodicity=0
param V
caption="Variant"
enum="1""2"
default=0
endparam
param p1
default=(1,0)

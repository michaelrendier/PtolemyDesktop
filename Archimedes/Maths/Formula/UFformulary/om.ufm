int i=0
f=(0,0)
f1=(0,0)
loop:
zold=z
if @V=="1"
z=fn2(sqr(fn3(z)))
if @P=="3"
f=(z^3-z^2)/4
f1=(3*z^2-2*z)/4
elseif @P=="4"
f=(6*z^4-9*z^3+z^2+z)/30
f1=(24*z^3-27*z^2+2*z+1)/30
elseif @P=="5"
f=(2*z^5-4*z^4+z^3+z^2)/12
f1=(10*z^4-16*z^3+3*z^2+2*z)/12
elseif @P=="6"
f=(6*z^6-15*z^5+6*z^4+6*z^3-z^2-z)/42
f1=(36*z^5-75*z^4+24*z^3+18*z^2-2*z-1)/42
elseif @P=="7"
f=(3*z^7-9*z^6+5*z^5+5*z^4-2*z^3-2*z^2)/24
f1=(21*z^6-54*z^5+25*z^4+20*z^3-6*z^2-4*z)/24
elseif @P=="8"
f=(10*z^8-35*z^7+25*z^6+25*z^5-17*z^4-17*z^3+3*z^2+3*z)/90
f1=(80*z^7-245*z^6+150*z^5+125*z^4-68*z^3-51*z^2+6*z+3)/90
elseif @P=="9"
f=(2*z^9-8*z^8+7*z^7+7*z^6-7*z^5-7*z^4+3*z^3+3*z^2)/20
f1=(18*z^8-64*z^7+49*z^6+42*z^5-35*z^4-28*z^3+9*z^2+6*z)/20
endif
z=p2*z-p1*(f/(f1*(z-(f/f1)/2)))+p3
else
while i<@iter
i=i+1
z=fn2(sqr(fn3(z)))
if @P=="3"
f=(z^3-z^2)/4
f1=(3*z^2-2*z)/4
elseif @P=="4"
f=(6*z^4-9*z^3+z^2+z)/30
f1=(24*z^3-27*z^2+2*z+1)/30

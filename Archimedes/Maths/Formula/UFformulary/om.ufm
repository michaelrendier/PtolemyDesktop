z=pixel
c=pixel^2/2
loop:
z=@fn(flip((c/sqrt(@par))*exp(@par*z)*(log(|z|)-1)))
bailout:
|z|<@bailout
default:
  title="f602"
  center=(0.001,0.001)
  maxiter=250
  func fn
  caption="Function"
  default=ident()
  endfunc
  param par
  caption="Parameter"
  default=(1,0)
  endparam
  param bailout
  caption="Bailout"
  default=4.0
  endparam
}

f603{

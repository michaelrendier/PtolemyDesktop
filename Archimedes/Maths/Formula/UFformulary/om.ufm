else
z=z+1/exp(cos(z))
endif
endif
z=z^2+cabs(z)/(1+cabs(z))+p1
if @JM=="J"
z=z^2*(z-p2)/(1-p2*z)
else
z=z^2*(z-p2)/(1-p2*z)+fn4(pixel)
endif
z=fn3(z)
bailout:
|z|<@bail

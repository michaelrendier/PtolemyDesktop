z=z
elseif @Va=="1"
if |z|>1
z=z/|z|
endif
elseif @Va=="2"
if real(z)<imag(z)
z=flip(z)
endif
elseif @Va=="3"
if real(z)>imag(z)
z=flip(z)
endif
elseif @Va=="4"
z=z+1/z
elseif @Va=="5"
z=z+1/tan(z)
elseif @Va=="6"

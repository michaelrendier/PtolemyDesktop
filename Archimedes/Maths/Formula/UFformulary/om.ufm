XisTiph{
init:
z=pixel
y=sin(pixel)
x=cos(pixel)
u=tan(pixel)
v=1-pixel
w=1+pixel
loop:
x=p1*(y-x)
y=p3*y-x*z
z=-p2*z+x*y+u
u=fn1(sqr(v))
v=-fn2(atan(w^2*u))
bailout:
|z|<@bailout
default:

Threeply{
;Formula by Martin Peters, from Fractint
init:
z=fn1(pixel)
loop:
x=imag(z)-(real(z)/cabs(real(z)))*(abs(sin(real(z))*cos(p1)+p2-real(z)*sin(p1+p2+p3)))
y=p3-real(z)
z=x+flip(y)
z=fn2(z)
bailout:

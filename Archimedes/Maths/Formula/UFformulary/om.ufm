f1=2*z-1
z=z-p3*f/f1+p4
elseif @V=="2"
f=z^2-z+fn4(pixel)
f1=2*z-1
z=z-p3*f/f1+fn4(pixel)+p4
elseif @V=="3"
f=z^2-z
f1=2*z-1
z=z-p3*f/f1+fn4(pixel)+p4
endif
z=fn3(sqr(z))
bailout:

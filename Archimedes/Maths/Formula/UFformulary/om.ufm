init:
z=fn1(pixel)
loop:
if imag(p5*conj(p5/(z-p6))+p6)>0
k=p1*fn2(p5*conj(p5/(z-p6))+p6)
else
k=p1*fn2(conj(p5*conj(p5/(z-p6))+p6))
endif
z=p2*fn3(log(k+p3))+p4
bailout:
|z|<@bailout
default:
title="Quack / Inkle 2"
center=(0.001,0.001)
angle=90
maxiter=250
param p1
default=(0.34,0.09)
endparam

z=z-1/cosh(z)
elseif @Va=="14"
z=z+sqr(z)
elseif @Va=="15"
z=z+cotanh(z)
elseif @Va=="16"
z=z+0.3*cotan(z)
elseif @Va=="17"
z=z+cosh(z)
elseif @Va=="18"
z=z+cos(z)
elseif @Va=="19"
z=z-exp(z)
elseif @Va=="20"
z=z-sqr(z)
elseif @Va=="21"
z=z-tanh(z)
elseif @Va=="22"
z=z-tan(z)
elseif @Va=="23"
z=z-cos(z)
elseif @Va=="24"
z=z-sinh(z)
elseif @Va=="25"
z=z-sin(z)
elseif @Va=="26"
z=z+0.2*flip(z)
elseif @Va=="27"
z=z+0.2*conj(z)
elseif @Va=="28"
z=z-0.2*flip(z)
elseif @Va=="29"
z=z-0.2*conj(z)
endif
endif
z=(z+p1)-((z+p1)^@pow1-p2)*(p1/(((z+p1)^@pow1-p2)-(z^@pow1-p2)))

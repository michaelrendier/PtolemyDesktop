caption="Start Function"
default=ident()
endfunc
func fn2
caption="Loop Function"
default=ident()
endfunc
func fn3
caption="Add Recip Function"
default=ident()
visible=@p7!=0
endfunc
func fn4
caption="Nova Function"
default=ident()
visible=@V=="Nova"
endfunc
param bail
caption="Bailout"
default=0.000000001
endparam
}


f657 (tinkerbell){
; https://en.wikipedia.org/wiki/Tinkerbell_map
init:
z=fn1(pixel)
loop:
x=real(z)^2-imag(z)^2+p1*real(z)+p2*imag(z)
y=2*real(z)*imag(z)-p3*real(z)+p4*imag(z)
z=@fn(x+flip(y))^@pow
bailout:|z|<@bail
default:

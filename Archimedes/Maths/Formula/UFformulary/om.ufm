b=2*a*cos(a)+(a^2-2)*sin(a)+p1
c=a^2*cos(a)
if @V=="J"
z=p4*log(abs(fn2(a-p1*b/c)))^@pow+p5
elseif @V=="M1"
z=p4*log(abs(fn2(a-p1*b/c+fn3(pixel))))^@pow+p5
elseif @V=="M2"

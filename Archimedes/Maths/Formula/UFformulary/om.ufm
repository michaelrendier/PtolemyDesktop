f1=7*z^6+48*z^5+135*z^4+200*z^3+165*z^2+72*z+13
f2=42*z^5+240*z^4+540*z^3+600*z^2+330*z+72
elseif @P=="8"
f=z^8+9*z^7+35*z^6+77*z^5+105*z^4+91*z^3+49*z^2+15*z+2
f1=8*z^7+63*z^6+210*z^5+385*z^4+420*z^3+273*z^2+98*z+15
f2=56*z^6+378*z^5+1050*z^4+1540*z^3+1260*z^2+546*z+98
elseif @P=="9"
f=z^9+10*z^8+44*z^7+112*z^6+182*z^5+196*z^4+140*z^3+64*z^2+17*z+2
f1=9*z^8+80*z^7+308*z^6+672*z^5+910*z^4+784*z^3+420*z^2+128*z+17
f2=72*z^7+560*z^6+1848*z^5+3360*z^4+3640*z^3+2352*z^2+840*z+128
elseif @P=="10"
f=z^10+11*z^9+54*z^8+156*z^7+294*z^6+378*z^5+336*z^4+204*z^3+81*z^2+19*z+2
f1=10*z^9++99*z^8+432*z^7+1092*z^6+1764*z^5+1890*z^4+1344*z^3+612*z^2+162*z+19
f2=90*z^8++792*z^7+3024*z^6+6552*z^5+8820*z^4+7560*z^3+4032*z^2+1224*z+162
endif
z=p2*z-p1*2*f*f1/(2*f1^2-f*f2)+p3
else
while i<@iter
i=i+1
z=fn2(sinh(fn3(z)))
if @Va=="1"
z=z
elseif @Va=="2"
if |z|<1
z=z/|z|
endif
elseif @Va=="3"
if |z|>1
z=z/|z|
endif
elseif @Va=="4"
x=real(z)
y=imag(z)
x=x/|z|
y=y/|z|
z=x+flip(y)
elseif @Va=="5"
if real(z)<imag(z)
z=flip(z)
endif
elseif @Va=="6"
if real(z)>imag(z)
z=flip(z)
endif
endif
if @P=="2"
f=z^2+3*z+2
f1=2*z+3
f2=2
elseif @P=="3"
f=z^3+4*z^2+5*z+2
f1=3*z^2+8*z+5
f2=6*z+8
elseif @P=="4"
f=z^4+5*z^3+9*z^2+7*z+2
f1=4*z^3+15*z^2+18*z+7
f2=12*z^2+30*z+18
elseif @P=="5"
f=z^5+6*z^4+14*z^3+16*z^2+9*z+2
f1=5*z^4+24*z^3+42*z^2+32*z+9
f2=20*z^3+72*z^2+84*z+32
elseif @P=="6"
f=z^6+7*z^5+20*z^4+30*z^3+25*z^2+11*z+2
f1=6*z^5+35*z^4+80*z^3+90*z^2+50*z+11
f2=30*z^4+140*z^3+240*z^2+180*z+50
elseif @P=="7"
f=z^7+8*z^6+27*z^5+50*z^4+55*z^3+36*z^2+13*z+2
f1=7*z^6+48*z^5+135*z^4+200*z^3+165*z^2+72*z+13
f2=42*z^5+240*z^4+540*z^3+600*z^2+330*z+72
elseif @P=="8"

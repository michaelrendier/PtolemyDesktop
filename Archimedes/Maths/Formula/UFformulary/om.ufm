  default=ident()
  endfunc
  func fn2
  default=tan()
  endfunc
  param bailout
  caption="Bailout"
  default=4.0
  endparam
}

Talis{
;This is based on 'Talis' in sam.ufm. I have added parameters, functions and a plug-in option.
global:
import "common.ulb"
import "tma.ulb"
formula f=new @formulaClass(0)
init:
z=p1
c=fn1(pixel)
loop:
if @plugin
z=f.Iterate(fn2(z^@pow1+c))
c=f.Iterate(fn3(c^@pow2/(c+p2)+z))
else
z=fn2(z^@pow1+c)
c=fn3(c^@pow2/(c+p2)+z)
endif
bailout:
|z|<@bailout
default:
title="Talis"
center=(0.001,0.001)
magn=2
angle=90
periodicity=0
param p1
default=(0,0)
endparam
param p2
default=(-1.1,0)
endparam
heading
endheading

  elseif @loop==7
  z=fn2(z^2)+(pixel^4)+(pixel^3)+(pixel^2)+@par2
  elseif @loop==8
  z=fn2(z^2)+(pixel^4)+(pixel^3)+(pixel^2)+pixel+@par2
  endif
bailout:
  |z|<@bail
default:

Mackey-GlassMod2 {
;http://www.scholarpedia.org/article/Noninvertibility
init:
z=fn1(pixel)
int i=0
loop:
while i<@iter
i=i+1
z=fn2(z)
if @V1=="2"
x=real(z)
y=imag(z)
a=x^2+y^2
x=x/a+real(p5)
y=y/a+imag(p5)
z=x+flip(y)
endif
if @V2=="2"
if |z|<1
z=z/|z|
endif
elseif @V2=="3"
if |z|>1
z=z/|z|
endif
endif
if @V3=="2"
if real(z)<imag(z)
z=flip(z)
endif
elseif @V3=="3"
if real(z)>imag(z)
z=flip(z)
endif
endif
z=p3*fn3(log(abs(fn4((p1*z*p2^@pow)/(p2^@pow+z^@pow)))))+p4
endwhile
z=@adj*z/100
bailout:
|z|<@bail
default:
title="Mackey-Glass Mod 2"
center=(0.001,0.001)
periodicity=0

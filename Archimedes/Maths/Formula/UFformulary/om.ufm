BurningShipVariant {
;Note: Increase value of the Iterations parameter when zooming in
init:
z=fn1(pixel)
int i=0
loop:
while i<@iter
i=i+1
x=abs(real(z)+p1)-abs(real(z)-p1)-real(z)
y=abs(imag(z)+p2)-abs(imag(z)-p2)-imag(z)
z=x+flip(y)
z=abs(fn2(z^2+pixel))^@pow*p3+p4
endwhile
z=z*p5/100
bailout:
|z|<@bail

default=(1,0)
endparam
param p3
default=(0,0)
endparam
param bail
caption="Bailout"
default=4.0
endparam
}

CarotidMod {
init:
z=fn1(pixel)
loop:
z=p4*fn2(z)+p5
z=cos(1i*z*acos(p1*fn3(exp(z))+p2))+p3
z=sqrt(1-abs(z)^2)
bailout:
|z|<@bail
default:
title="Carotid Mod"
center=(0.001,0.001)
periodicity=0
param p1
default=(1,0)
endparam

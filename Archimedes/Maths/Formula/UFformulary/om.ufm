else
z=cotan(z)+1/sqr(z)
endif
endif
z=log(z)-p1
if @JM=="J"
z=p2*(cotanh(z)+conj(p3))/(1+p3*cotanh(z))+p1
else
z=p2*(cotanh(z)+conj(p3))/(1+p3*cotanh(z))+p1+fn4(pixel)
endif
z=fn3(z)
bailout:
|z|<@bail

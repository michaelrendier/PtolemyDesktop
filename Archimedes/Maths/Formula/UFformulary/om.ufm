caption="Constant"
default=(1,0)
visible=@V=="Notwen"
endparam
func fn4
caption="Avon Function"
default=ident()
visible=@V=="Avon"
endfunc
param p4
caption="Loop Parameter 1"
default=(1,0)
endparam
param p5
caption="Loop Parameter 2"
default=(0,0)
endparam
func fn2
caption="Loop Function"

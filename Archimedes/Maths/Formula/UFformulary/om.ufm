ZernikePolynomials7 {
;http://www.mpia.de/AO/INSTRUMENTS/FPRAKT/ZernikePolynomialsForTheWeb.pdf
init:
z=fn1(pixel)
int i=0
loop:
while i<@iter
i=i+1
z=fn2(exp(flip(fn3(z))))
float x=real(z)+real(p1)
float y=imag(z)+imag(p1)
float a=x^2+y^2
x=x/a
y=y/a
if x-y<0
float k=y
y=x
x=k
endif
z=x+flip(y)+pixel
if @v=="4"
z=p2*log(abs(6*z^4-6*z^2+1))^@pow+p3
elseif @v=="6"
z=p2*log(abs(20*z^6-30*z^4+12*z^2-1))^@pow+p3

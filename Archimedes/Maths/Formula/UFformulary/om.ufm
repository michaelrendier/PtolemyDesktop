elseif @Va=="9"
z=z+2/sinh(z)
elseif @Va=="10"
z=z-2/cotanh(z)
elseif @Va=="11"
z=z-sinh(z)
elseif @Va=="12"
z=z-sin(z)
elseif @Va=="13"

BrahmaguptaPolynomials {
init:
z=fn1(pixel)
int i=0
t=-abs(p2)
loop:
while i<@iter
i=i+1
z=fn2(fn3(z))
a=real(z)
b=imag(z)
c=a^2+b^2
a=a/c+real(p1)
b=b/c+imag(p1)
z=a+flip(b)
if @V=="2"
x=real(z)^2+t*imag(z)^2
y=2*real(z)*imag(z)
elseif @V=="3"
x=real(z)^3+3*t*real(z)*imag(z)^2
y=3*real(z)^2*imag(z)+t*imag(z)^3
elseif @V=="4"
x=real(z)^4+6*t*real(z)^2*imag(z)^2+t^2*imag(z)^4
y=4*real(z)^3*imag(z)+4*t*real(z)*imag(z)^3
else
x=real(z)^5+10*t*real(z)^3*imag(z)^2+5*t^2*real(z)*imag(z)^4
y=5*imag(z)*real(z)^4+10*t*real(z)^2*imag(z)^3+t^2*imag(z)^5
endif
z=p3*log(abs(x+flip(y)))^@pow+p4
endwhile
z=@adj*z/100
bailout:
|z|<@bail
default:
title="Brahmagupta Polynomials"
center=(0.001,0.001)
maxiter=500
periodicity=0

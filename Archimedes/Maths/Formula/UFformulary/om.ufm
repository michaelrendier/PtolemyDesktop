Mayan{
init:
z=p4*fn1(abs(pixel))
loop:
if imag(z)>0.4
z=p1*fn2(asinh(1.9*real(z)+flip(1.9*imag(z)-1.6)))
elseif real(z)>0.4
z=p2*fn3(conj(1.9*real(z)-1.6+flip(1.9*imag(z))))
else
z=p3*fn4(exp(1.9*real(z)+flip(1.9*imag(z))))
endif
bailout:
|z|<@bail
default:
 title="Mayan"
 center=(0.001,0.001)
 maxiter=500
 magn=0.8
 angle=90
 param p1
 default=(1,0)
 endparam
 param p2
 default=(1,0)
 endparam
 param p3
 default=(1,0)

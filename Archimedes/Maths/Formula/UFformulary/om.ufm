f1=5*z^4+24*z^3+42*z^2+32*z+9
f2=20*z^3+72*z^2+84*z+32
z=p6*(z-p1*f/f1-p2*(f/f1)^2*f2/(2*f1))+p3
bailout:
|zold-z|>@bail

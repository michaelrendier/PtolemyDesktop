Mandabs3/1Labs {
init:
z=fn1(pixel)
int i=0
loop:
while i<@iter
i=i+1
z=fn2(z)
z=z+p1/fn3(z)
x=real(z)
y=imag(z)
x=x/|z|+real(p5)
y=y/|z|+imag(p5)
z=x+flip(y)
if @JM=="J"
z=p2*log(abs(abs(z)^3*z))+p3
else
z=p2*log(abs(abs(z)^3*z))+fn4(pixel)
endif
z=z+p4*@fn5(z)
endwhile

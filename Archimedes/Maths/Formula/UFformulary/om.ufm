elseif @V=="14"
z=pixel*p2*log(abs(z*p3+pixel))^@pow+p4+pixel
elseif @V=="15"
z=p2*log(abs(z*pixel*p3+pixel))^@pow+p4+pixel
elseif @V=="16"
z=p2*log(abs(z*p3/pixel+pixel))^@pow+p4
elseif @V=="17"
z=p2*log(abs(z*p3/pixel))^@pow+p4+pixel
elseif @V=="18"
z=pixel*p2*log(abs(z*p3/pixel))^@pow+p4
elseif @V=="19"
z=p2*log(abs(z*p3/pixel+pixel))^@pow+p4+pixel
elseif @V=="20"
z=pixel*p2*log(abs(z*p3/pixel+pixel))^@pow+p4
elseif @V=="21"
z=pixel*p2*log(abs(z*p3/pixel))^@pow+p4+pixel
elseif @V=="22"

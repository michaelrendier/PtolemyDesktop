SquareElipseV1.00 {
; Setemkia FallingTree
;
; This may very well be a finished image.  I'm not sure.
; Feedback and tweaks are welcome.
;
; I am hooked on eliptical orbit trapping.  This largely
; a response to Kerry Mitchell's wonderful "Ring Toss."
; Circular (degenerate elipses) tend to show up as circles
; in most fractal sets.  However, elipses, especially when
; not alligned with the real and imaginary axies are
; weirdly distorted.  In this case, the points falling in
; the eliptical trap are roughly rectangular.
;
fractal:
  title="Square Elipse v1.00" width=400 height=300 numlayers=1
layer:
  inalpha=0 outalpha=0 method=linear caption="Layer 1" visible=yes
  alpha=yes
mapping:
  center=-1.62864742397276544/0 magn=50 angle=90
formula:
  filename="Standard.ufm" entry="FastMandel" maxiter=50 percheck=normal
  p_Start=0/0 p_Bailout=128
inside:
  filename="sft.ucl" entry="ElipseFirst" transfer=linear repeat=yes
  p_choose="Full Range" p_a=0.75 p_b=1 p_delta=0.1 p_center=0/0
  p_rotation=0
outside:
  filename="sft.ucl" entry="ElipseFirst" transfer=linear repeat=yes
  p_choose="Full Range" p_a=0.75 p_b=1 p_delta=0.1 p_center=0/0
  p_rotation=0
gradient:
  smooth=yes numnodes=10 index=0 color=0 index=40 color=3102606 index=80
  color=1409001 index=120 color=4169727 index=160 color=8102899 index=200
  color=16777215 index=240 color=8105459 index=280 color=4169727 index=320
  color=1409001 index=360 color=3102606
alpha:
  smooth=no numnodes=10 index=0 alpha=0 index=40 alpha=94 index=80
  alpha=127 index=120 alpha=159 index=159 alpha=183 index=200 alpha=255
  index=240 alpha=183 index=280 alpha=159 index=320 alpha=127 index=360
  alpha=94
}


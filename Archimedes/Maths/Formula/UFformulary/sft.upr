AvgMandelV1Clover {
; Setemkia FallingTree
; Exploratory image of experimental fractal type.
; Copyright (C) 2001
; Completed image.
;
; This three leaf clover resulted from the formula
;     z[n+1] = z[n]^2*z[n-1]^2 + c
; This was completely unexpected.
;
; sft.ufm can be obtained from the UF Formula page at:
; http://formulas.ultrafractal.com/cgi-bin/formuladb?browse
;
fractal:
  title="AvgMandel v1 Clover" width=480 height=360
  author="Setemkia FallingTree" created="July 22, 2001" numlayers=1
layer:
  inalpha=0 outalpha=0 method=linear caption="Primary" opacity=100
  visible=yes alpha=yes
mapping:
  center=-0.2/0 magn=1.45 angle=90
formula:
  filename="sft.ufm" entry="AvgMandelV1" maxiter=800 percheck=normal
  p_start=0/0 p_pow0=2/0 p_pow1=2/0 p_bailout=4
inside:
  filename="lkm.ucl" entry="statistics" density=2 transfer=log repeat=yes
  p_vartype="magnitude" p_stattype="fractal dimension"
outside:
  filename="lkm.ucl" entry="statistics" density=2 transfer=log repeat=yes
  p_vartype="magnitude" p_stattype="fractal dimension"
gradient:
  smooth=yes numnodes=9 index=0 color=254 index=50 color=49150 index=100
  color=65151 index=150 color=4193792 index=200 color=16711168 index=250
  color=16662272 index=305 color=16646271 index=350 color=12517630
  index=399 color=262398
alpha:
  smooth=no numnodes=4 index=0 alpha=0 index=2 alpha=0 index=3 alpha=255
  index=399 alpha=255
}

AvgMandelV1Defalt {
; Setemkia FallingTree
; Exploratory image of experimental fractal type.
;
; z[n+1] = z[n]*z[n-1] + c
;
; Compare this with the Mandelbrot iteration
;
; z[n+1] = z[n]^2 + c
;
; It amounts to an average of the last two iterations
; and is quadratic.  Yet how different the results!
; This is now my default parameter set for exploring
; this fractal type.
;
; sft.ufm can be obtained from the UF Formula page at:
; http://formulas.ultrafractal.com/cgi-bin/formuladb?browse
;
fractal:
  title="AvgMandel v1 Defalt" width=480 height=360
  author="Setemkia FallingTree" created="July 25, 2001" numlayers=1
layer:
  method=multipass caption="Layer 1" visible=yes alpha=no
mapping:
  center=-0.35/0 magn=1.7 angle=270
formula:
  filename="sft.ufm" entry="AvgMandelV1" maxiter=100 percheck=normal
  p_start=0/0 p_pow0=1/0 p_pow1=1/0 p_bailout=4
inside:
  transfer=none repeat=yes
outside:
  transfer=linear repeat=yes
gradient:
  smooth=yes numnodes=9 index=0 color=254 index=50 color=49150 index=100
  color=65151 index=150 color=4193792 index=200 color=16711168 index=250
  color=16662272 index=305 color=16646271 index=350 color=12517630
  index=399 color=262398
}

Pi5 {
; Setemkia FallingTree
;
; This may very well be a finished image.  I'm not sure.
; Feedback and tweaks are welcome.
;
; This uses one of the fractal formulae I found while
; looking for information about quaternion arithmetic.
; The formulas were coded by Godwin Vickers and can be
; found at http://www.hypercomplex.org. For convenience
; copies of them can be found in my sft.ufm file at
; http://formulas.ultrafractal.com/cgi-bin/formuladb?browse

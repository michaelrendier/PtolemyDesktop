CubistPhoenixV1 {
; Setemkia FallingTree
; Copyright (C) 2001
; Completed image.
; Personal embossing technique #1
;
; Challenge #1:
; The image must be of two or more layers, at
; least one of which uses the alpha channel.
; Each layer must use the Phoenix (Julia)
; formula found in the dmj.ufm file included with
; Ultra Fractal. There are no other restrictions.
;
; This image and it's fraternal twin were motivated
; solely by the challenge.  Exploring using my
; eliptical trap has become my momentary preference.
; when I found an interesting region in the phoenix
; (my first experience with the phoenix) I duplicated
; the layer and looked at more traditional colorings.
; The two colorings did not seem to lay over each
; other properly, so I did something new and shifted
; and magified the layers independently of each other.
; Voila!  I had it.  Now I doubled the eliptical
; trap layer to try to duplicate the embossing
; technique.  Finally, I took the circular matte from
; the UF Thrift Store and adjusted it to fit.
;
fractal:
  title="Cubist Phoenix v1" width=400 height=300
  author="Setemkia FallingTree" created="July 31, 2001" numlayers=4
layer:
  inalpha=0 outalpha=0 method=multipass caption="Matte" opacity=100
  visible=yes alpha=yes mergemode=screen
mapping:
  center=0/0 magn=1.95 angle=0 numtransforms=1
transform:
  filename="obsolete.uxf" entry="stretch" p_ar=1.33333333333
formula:
  filename="Fractint.ufm" entry="lambda[fn||fn]" maxiter=1000
  percheck=normal p_lambda=1/0.1 p_shift=1 p_test="mod" p_bailout=64
  f_fn1=zero f_fn2=sqr
inside:
  transfer=none repeat=yes
outside:
  filename="dmj.ucl" entry="dmj-Smooth" transfer=linear repeat=yes
  p_power=2/0 p_bailout=128
gradient:
  smooth=no numnodes=4 index=0 color=0 index=101 color=15856113 index=201
  color=0 index=301 color=16777215
alpha:
  smooth=yes numnodes=5 index=0 alpha=0 index=53 alpha=48 index=96
  alpha=212 index=148 alpha=255 index=399 alpha=255
layer:
  inalpha=0 outalpha=0 method=multipass caption="Embossing A" opacity=100
  visible=yes alpha=yes mergemode=luminance
mapping:
  center=-0.313084778526511872/0.0123862348308822048 magn=1.2 angle=0
formula:
  filename="dmj.ufm" entry="dmj-PhoenixJulia" maxiter=1000 percheck=normal
  p_seed=0.34/0.29 p_power1=2/0 p_power2=0/0 p_induct=-0.5/0 p_bailout=1E20

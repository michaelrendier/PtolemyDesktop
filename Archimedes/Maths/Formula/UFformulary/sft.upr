AvgMandelV1#01#001 {
; Setemkia FallingTree
; Exploratory image of experimental fractal type.
;
; I was thinking about the Fibonacci series of
; integers (1, 1, 2, 3, 5, 8, 13, 21, ...) one
; night in the dark and wondered if there was
; a way to create a fractal iteration out of it.
; Clearly I had to find a way to provide a
; potential upper bound on the iteration.  What
; emerged were various explorations of averaging
; and my first fractal formula.  This is my
; first look at my new toy.
;
; sft.ufm can be obtained from the UF Formula page at:
; http://formulas.ultrafractal.com/cgi-bin/formuladb?browse
;
fractal:
  title="AvgMandel v1 #01 #001" width=480 height=360
  author="Setemkia FallingTree" created="July 22, 2001" numlayers=1
layer:
  method=linear caption="Layer 1" visible=yes alpha=no
mapping:
  center=0/0 magn=1.41421 angle=270
formula:
  filename="sft.ufm" entry="AvgMandelV1" maxiter=2000 percheck=off
  p_start=0/0 p_pow0=1.414213562/0 p_pow1=1.414213562/0 p_bailout=4
inside:
  filename="lkm.ucl" entry="statistics" density=4 transfer=sin repeat=yes
  p_vartype="magnitude" p_stattype="fractal dimension"
outside:
  filename="dmj.ucl" entry="dmj-Spiral" transfer=cuberoot offset=200
  repeat=yes p_decscale=4 p_potscale=10 p_bailout=4
gradient:
  smooth=yes numnodes=15 index=0 color=0 index=2 color=0 index=3
  color=66047 index=36 color=98559 index=69 color=131071 index=102
  color=130944 index=135 color=130817 index=168 color=8453889 index=201
  color=16776961 index=234 color=16744449 index=267 color=16711937
  index=300 color=16712064 index=333 color=16712191 index=366 color=5636607
  index=399 color=328191
}


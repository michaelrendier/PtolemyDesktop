  color=16316664 index=399 color=16777215
alpha:
  smooth=yes numnodes=5 index=0 alpha=192 index=1 alpha=0 index=35 alpha=35
  index=383 alpha=248 index=399 alpha=255
layer:
  inalpha=0 outalpha=0 method=multipass caption="Embossing B" opacity=100
  visible=yes alpha=yes mergemode=multiply
mapping:
  center=-0.313084778526511872/0.0123862348308822048 magn=1.2 angle=0
formula:
  filename="dmj.ufm" entry="dmj-PhoenixJulia" maxiter=1000 percheck=normal
  p_seed=0.34/0.29 p_power1=2/0 p_power2=0/0 p_induct=-0.5/0 p_bailout=1E20
inside:

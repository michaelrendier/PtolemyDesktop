Comment {

Contents: Fractal Parameter Sets
Author:   Setemkia FallingTree
Mod Date: 1 August 2001

Notes:
  20+ images generated in my first 9 days playing with UF.
  Some of these are merely explorations that happen to
  please my eye.  Some are works in progress as I develop
  my repetoire of techniques and tools.  Others are
  completed works that completely astonish me.  I first
  started playing with fractals almost 15 years ago, first
  writing my own software, then using early versions of
  FractInt.  However, until this past week I have never
  produced what I would consider to be "art."

}

Default {
; Setemkia FallingTree
;
; My starting point for many images.
;
fractal:
  title="Default" width=400 height=300 numlayers=1
layer:
  inalpha=0 outalpha=0 caption="Layer 1" visible=yes alpha=yes
mapping:
  center=-0.49/-0.0091579365678573504 magn=1.29693008666577184 angle=0
formula:
  filename="Standard.ufm" entry="FastMandel" maxiter=100 percheck=normal
  p_Start=0/0 p_Bailout=128
inside:
  filename="sft.ucl" entry="ElipseFirst" transfer=linear repeat=yes
  p_choose="Full Range" p_a=0.75 p_b=0.75 p_delta=0.0625 p_center=0/0
  p_rotation=0
outside:
  filename="sft.ucl" entry="ElipseFirst" transfer=linear repeat=yes
  p_choose="Full Range" p_a=0.75 p_b=0.75 p_delta=0.0625 p_center=0/0
  p_rotation=0
gradient:
  smooth=yes numnodes=3 index=152 color=12706790 index=290 color=5013051
  index=383 color=5583458
}


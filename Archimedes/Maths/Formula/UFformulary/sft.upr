AlienClown {
; Setemkia FallingTree
; Copyright (C) 2001
; Completed image.
;
; This wonderful image appeared completely
; by accident.  I was playing around with
; transformations and sudenly I noticed the
; "eyes."  Looking at the image and its
; coloration I thought of circus clowns.
; However, other features made me think of
; the creatures in the film series "Alien."
; Happy nightmares!
;
fractal:
  title="Alien Clown" width=450 height=600 author="Setemkia FallingTree"
  created="July 22, 2001" numlayers=1
layer:
  inalpha=0 outalpha=0 method=linear caption="Primary" opacity=100
  visible=yes alpha=yes
mapping:
  center=-0.2/0 magn=1 angle=90 numtransforms=3
transform:
  filename="lp.uxf" entry="Inverse2" p_center=-0.125/0 p_radius=0.75
transform:
  filename="lp.uxf" entry="lp-HemiSphere1" p_n=1.5 p_width=3 p_ctr=-0.75/0
transform:
  filename="dmj.uxf" entry="dmj-Twirl" p_twirlcenter=-0.5/0 p_centermove=no
  p_twirlscale=0.666666666666659968 p_twirlpitch=10 p_twirlfade=1
  p_twirltype="Forward and Back"
formula:
  filename="standard.ufm" entry="FastMandel" maxiter=100 percheck=normal
  p_Start=0/0 p_Bailout=4
inside:
  filename="lp.ucl" entry="EpsilonCross" transfer=arctan repeat=yes
  p_xcolour=0.2 p_xdis=0.1 p_ycolour=0.6 p_ydis=0.025 p_colourf=0.5
  p_center=0/0 p_angle=0 p_skip=yes
outside:
  filename="lp.ucl" entry="lp-Curv" density=0.1 transfer=log repeat=yes
  p_trapmode="Smallest r" p_colourmethod="Distance of center" f_fn1=exp
gradient:
  smooth=yes numnodes=9 index=0 color=254 index=50 color=49150 index=100
  color=65151 index=150 color=4193792 index=200 color=16711168 index=250
  color=16662272 index=305 color=16646271 index=350 color=12517630
  index=399 color=262398
alpha:
  smooth=no numnodes=4 index=0 alpha=0 index=2 alpha=0 index=3 alpha=255
  index=399 alpha=255
}

MandelOverview {
; Setemkia FallingTree
; Completed image, no copyright.
;
; This was one of my very first explorations utilizing
; transparency and layers.  It's no earth shattering
; work of art, yet it is quite pleasing to the eye.
;
fractal:
  title="Mandel Overview" width=600 height=450 numlayers=2
layer:
  inalpha=0 caption="Mandelbrot" opacity=100 visible=yes alpha=yes
mapping:
  center=-0.7/0 magn=1.222 angle=0
formula:
  filename="Standard.ufm" entry="FastMandel" maxiter=100 percheck=normal
  p_Start=0/0 p_Bailout=128
inside:
  filename="mt.ucl" entry="TangentCircles" transfer=linear repeat=yes
  p_r=0.2 p_skip=20 p_off=1
outside:
  filename="dmj.ucl" entry="dmj-Smooth" transfer=linear repeat=yes
  p_power=2/0 p_bailout=128
gradient:
  smooth=yes position=103 numnodes=15 index=3 color=16712064 index=36
  color=16712191 index=69 color=5636607 index=102 color=328191 index=103
  color=0 index=105 color=0 index=106 color=66047 index=139 color=98559
  index=172 color=131071 index=205 color=130944 index=238 color=130817
  index=271 color=8453889 index=304 color=16776961 index=337 color=16744449
  index=370 color=16711937
alpha:
  smooth=no position=139 numnodes=4 index=0 alpha=0 index=2 alpha=0 index=3
  alpha=255 index=399 alpha=255
layer:
  caption="Base" visible=yes alpha=no
mapping:
  center=-0.7/0 magn=1.222 angle=0
formula:
  filename="Standard.ufm" entry="FastMandel" maxiter=100 percheck=normal
  p_Start=0/0 p_Bailout=128
inside:
  filename="lkm.ucl" entry="statistics" density=4 transfer=arctan
  repeat=yes p_vartype="magnitude" p_stattype="fractal dimension"
outside:
  filename="dmj.ucl" entry="dmj-Smooth" transfer=linear repeat=yes
  p_power=2/0 p_bailout=128
gradient:
  smooth=yes position=-166 numnodes=12 index=1 color=13281218 index=34
  color=6901431 index=67 color=16064321 index=101 color=3590642 index=134
  color=1777473 index=167 color=10621466 index=201 color=14456654 index=234
  color=16393398 index=267 color=10874815 index=301 color=16229613
  index=334 color=5826379 index=367 color=15427554
}

PrettyJulia2 {
; Setemkia FallingTree
;
; I stumbled over this region while switching between
; fast mandelbrot and fast julia.  It was apealing to the
; eye, so I saved the parameters for future exploration.
; "Floral Vortex" is this region colored several ways!
;
; As an open challenge: I would love to see what others
; can do with this using only this julia set (location,
; magnification, and seed) and possibly matting layers
; to frame the image.
;
fractal:
  title="Pretty Julia" width=400 height=300 author="Setemkia FallingTree"
  created="July 28, 2001" numlayers=1
layer:
  caption="Layer 1" visible=yes alpha=no
mapping:
  center=0/0 magn=1.5 angle=15.3576107358648617
formula:
  filename="standard.ufm" entry="FastJulia" maxiter=100 percheck=normal
  p_Seed=-0.46/0.56 p_Bailout=4
inside:
  transfer=none repeat=yes
outside:
  transfer=linear repeat=yes
gradient:
  smooth=yes numnodes=9 index=0 color=254 index=50 color=49150 index=100
  color=65151 index=150 color=4193792 index=200 color=16711168 index=250
  color=16662272 index=305 color=16646271 index=350 color=12517630
  index=399 color=262398
}

FloralVortex {
; Setemkia FallingTree
; Copyright (C) 2001
; Completed image.
;
; This wonderful image evoking a delicate feminine
; sense of the Victorian era was resulted from coloring
; experiments on "Pretty Julia."  I had saved a set of
; parameters that caught my eye and returned to it with
; no preconceptions.  As I played with coloring methods
; and gradients I realized I had something special.
; However, it took over an hour of playing with gradients
; for the base layer before I saw an almost finished
; image.  The final touch was doubling the eliptical
; orbit layer and accidently discovering a way to make
; the orbits appear to be impressed, embossed, into the
; the base layer.  I would later attempt to duplicate
; this technique in "Cubist Phoenix."  In the process
; I found a way to produce an even more striking
; version of this effect.
;
; "Floral Vortex" has captured my heart.  It seems to
; express a delicate femininity I usually fail to overtly
; display. I guess I am too much the tomboy.
;
fractal:
  title="Floral Vortex" width=400 height=300 author="Setemkia FallingTree"
  created="July 28, 2001" numlayers=3
layer:
  inalpha=0 outalpha=0 method=linear caption="Grey Luminance" opacity=100
  visible=yes alpha=yes mergemode=luminance
mapping:
  center=0/0 magn=1.5 angle=15.357610735864864
formula:
  filename="standard.ufm" entry="FastJulia" maxiter=100 percheck=normal
  p_Seed=-0.46/0.56 p_Bailout=4
inside:
  filename="sft.ucl" entry="ElipseFirst" transfer=linear repeat=yes
  p_choose="Full Range" p_a=0.75 p_b=0.75 p_delta=0.0125 p_center=0/0
  p_rotation=0
outside:
  filename="sft.ucl" entry="ElipseFirst" transfer=linear repeat=yes
  p_choose="Full Range" p_a=0.75 p_b=0.75 p_delta=0.0125 p_center=0/0
  p_rotation=0
gradient:
  smooth=no numnodes=5 index=0 color=0 index=41 color=4210752 index=42
  color=4671303 index=382 color=12632256 index=399 color=16777215
alpha:
  smooth=yes numnodes=4 index=0 alpha=8 index=41 alpha=64 index=382
  alpha=192 index=399 alpha=255
layer:
  inalpha=0 outalpha=0 method=linear caption="Shadow" opacity=42
  visible=yes alpha=yes mergemode=multiply
mapping:
  center=0.005/0.0075 magn=1.5 angle=15.357610735864864
formula:
  filename="standard.ufm" entry="FastJulia" maxiter=100 percheck=normal
  p_Seed=-0.46/0.56 p_Bailout=4
inside:
  filename="sft.ucl" entry="ElipseFirst" transfer=linear repeat=yes
  p_choose="Full Range" p_a=0.75 p_b=0.75 p_delta=0.0125 p_center=0/0
  p_rotation=0
outside:
  filename="sft.ucl" entry="ElipseFirst" transfer=linear repeat=yes
  p_choose="Full Range" p_a=0.75 p_b=0.75 p_delta=0.0125 p_center=0/0
  p_rotation=0
gradient:
  smooth=no numnodes=5 index=0 color=0 index=41 color=4210752 index=42
  color=4671303 index=382 color=12632256 index=399 color=16777215
alpha:
  smooth=yes numnodes=4 index=0 alpha=8 index=41 alpha=64 index=382
  alpha=192 index=399 alpha=255
layer:
  inalpha=0 outalpha=0 caption="Prety Julia" visible=yes alpha=yes
mapping:
  center=0/0 magn=1.5 angle=15.357610735864864
formula:
  filename="standard.ufm" entry="FastJulia" maxiter=100 percheck=normal
  p_Seed=-0.46/0.56 p_Bailout=4
inside:
  filename="lkm.ucl" entry="basic-plus" density=2 transfer=sqrt repeat=yes
  p_vartype="pixel" p_colorby="magnitude"
outside:
  transfer=linear repeat=yes
gradient:
  smooth=yes position=-8 numnodes=12 index=25 color=9464751 index=59
  color=12370914 index=92 color=6924856 index=125 color=10320324 index=159
  color=5014885 index=192 color=8882899 index=225 color=7087981 index=259

Carr1442S { 
; A "Modified Carr" formula, based on the original with permission.
; Functionality added by Sharon S. Schultz, May, 2003.
; Updated for UF2 by Erik Reckase, Feb 2000
; Fractal Fender C Modified.
; Edited for Fracint v. 20 by George Martin, 10/98

init:
  z = 0.224
  x = |z|
  c = (-0.7456,0.2)

loop:
  IF (x > 1)
    z = fn1(fn2(fn3(cosh(z)+c)))
  ENDIF
  z = fn1(fn2(fn3(sqr(z)+(#pixel/@scale))))
  x = |z|

bailout:
  |z| <= @bailout

default:
  title = "Carr 1442S"
  method = multipass
  periodicity = 0
  maxiter = 100
  magn = .8
  center = (0,0)

heading 

  center=0/0 magn=2 transforms=1
transform:
  filename="Standard.uxf" entry="Inverse" p_radius=1.0 p_center=0/0
  p_usescreen=no
formula:
  maxiter=100000 percheck=conservative filename="pgd.ufm"
  entry="pgd_HRing_Mandelbrot_c" p_cp="Critical point #1"
  p_what="Points diverging" p_aexp=yes p_a=0.4/0 p_bailout=100000.0
inside:
  transfer=none

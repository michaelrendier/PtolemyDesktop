Penrose1 {
fractal:
  title="Penrose1" width=640 height=480 layers=1
  credits="Paul Derbyshire;10/30/2004"
layer:
  method=linear caption="Background" opacity=100
mapping:
  center=-0.4375/0 magn=1 transforms=2
transform:
  filename="sam.uxf" entry="KDPenroseTiling" p_mode="All the tiles"
  p_center=0/0 p_rot=0.0 p_magn=1.0 p_mask="None" p_invm=no p_zccenter=0/0
  p_zcrot=0.0 p_zcsize=1.0 p_stab=no p_niter=10
transform:
  filename="Standard.uxf" entry="Inverse" p_radius=2 p_center=0/0
  p_usescreen=no
formula:
  maxiter=1 filename="Standard.ufm" entry="FastMandel" p_start=0/0
  p_bailout=4.0
inside:
  density=4 transfer=linear filename="Standard.ucl" entry="Gradient"
  p_type="Linear"
outside:
  transfer=linear filename="Standard.ucl" entry="Gradient" p_type="Linear"
gradient:
  comments="Simple grayscale gradient." smooth=yes rotation=2 index=2
  color=0 index=202 color=16777215
opacity:
  smooth=no index=0 opacity=255
}


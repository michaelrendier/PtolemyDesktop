            please note that the real part sets the value in F() \
            and the imaginary part sets the value in G()."
    visible = @fdegree>4 || @gdegree>4
  endparam
  param addfunc
    caption = "Add functions"
    default = false
    hint = "Allows you to add functions of x and/or y to the \
            equations of F() and/or G()."
  endparam
  param ffnx
    caption = "F() fn(x)"
    enum = "unused" "sin" "cos" "tan" "sinh" "cosh" "tanh" \
           "asin" "acos" "atan" "asinh" "acosh" "atanh" \
           "exp" "ln" "inv"
    default = 0
    hint = "Adds a function of x to the equation for F(x,y)."
    visible = @addfunc
  endparam
  param gfnx
    caption = "G() fn(x)"
    enum = "unused" "sin" "cos" "tan" "sinh" "cosh" "tanh" \
           "asin" "acos" "atan" "asinh" "acosh" "atanh" \
           "exp" "ln" "inv"
    default = 0
    hint = "Adds a function of x to the equation for G(x,y)."
    visible = @addfunc
  endparam
  param ffny
    caption = "F() fn(y)"
    enum = "unused" "sin" "cos" "tan" "sinh" "cosh" "tanh" \
           "asin" "acos" "atan" "asinh" "acosh" "atanh" \
           "exp" "ln" "inv"
    default = 0
    hint = "Adds a function of y to the equation for F(x,y)."
    visible = @addfunc
  endparam
  param gfny
    caption = "G() fn(y)"
    enum = "unused" "sin" "cos" "tan" "sinh" "cosh" "tanh" \
           "asin" "acos" "atan" "asinh" "acosh" "atanh" \
           "exp" "ln" "inv"
    default = 0
    hint = "Adds a function of y to the equation for G(x,y)."
    visible = @addfunc
  endparam
  param ffnx2
    caption = "F() fn(x^2)"
    enum = "unused" "sin" "cos" "tan" "sinh" "cosh" "tanh" \
           "asin" "acos" "atan" "asinh" "acosh" "atanh" \
           "exp" "ln" "inv"
    default = 0
    hint = "Adds a function of x^2 to the equation for F(x,y)."
    visible = @addfunc
  endparam
  param gfnx2

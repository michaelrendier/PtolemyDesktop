ariadne { ;a formula by Konstantin Schwarze
init:
  x=0
  y=0
loop:
  xa=x
  ya=y
  x=fn2(xa^2-ya^2+#pixel)
  y=1/fn1(2*xa*ya+#pixel)
  t=x+y
bailout:
  |t|<100
default:
  title = "ariadne"
  func fn1
    caption = "First Function"
    default = ident()
  endfunc
  func fn2
    caption = "Second Function"
    default = ident()
  endfunc
switch:
  type="ariadne2"
  a=#pixel
  fn1=fn1
  fn2=fn2
}


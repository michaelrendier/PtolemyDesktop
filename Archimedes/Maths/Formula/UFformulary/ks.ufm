;##########################

dragon { ;a formula by Konstantin Schwarze
init:
  j=0
loop:
  j=1/(j^2+#pixel)
bailout:
  |j|<4
default:
  title = "dragon"
switch:
  type="dragon2"
  p=#pixel
}

dragon2 { ;a formula by Konstantin Schwarze
init:
  j=#pixel
loop:
  j=1/(j^2+@p)
bailout:
  |j|<4
default:
  title = "dragon2"
}

;####################

sphinx { ;a formula by Konstantin Schwarze
init:
  ja=0
  j=0
loop:
  jx=fn1(1/fn2(j^2+ja+#pixel))
  ja=j
  j=jx
bailout:
  |j|<4
default:
  title = "sphinx"
  func fn1
    caption = "First Function"
    default = ident()
  endfunc
  func fn2
    caption = "Second Function"
    default = ident()
  endfunc
switch:
  type="sphinx2"
  p=#pixel
  fn1=fn1
  fn2=fn2
}

sphinx2 {  ; a formula by Konstantin Schwarze
init:
  ja=#pixel
  j=#pixel
loop:
  jx=fn1(1/fn2((j^2+ja+@p)))
  ja=j
  j=jx
bailout:
  |j|<4
default:
  title = "sphinx2"
  func fn1
    caption = "First Function"
    default = ident()
  endfunc
  func fn2
    caption = "Second Function"
    default = ident()
  endfunc
}
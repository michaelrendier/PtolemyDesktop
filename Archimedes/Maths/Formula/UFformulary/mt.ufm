mt-dynamic { ; Mark Townsend, 6 Jul 1999
init:
  x = real(#pixel) 
  y = imag(#pixel)
  a = real(@a)
  b = imag(@a) 
  xx = 0
  int iter = 0
loop:
  iter = iter + 1
  xx = x
  x = x - a * @fn1(y)
  y = y - b * @fn2(xx)
  z = x + flip(y)
bailout:
  iter < #maxiter
default:
  title = "Dynamic"
  maxiter = 20 
  magn = 0.15
  param a
    caption = "Parameter"
    default = (1,1)
  endparam  
}

mt-ring-j { ; Mark Townsend, 11 Jul 1999
init:

mt-newton4-julia { ; Mark Townsend, 20 Jul 1999
;
; Julia version of Newton Mset 1, from the Paul Carlson 
; formula.
;
init:
  c = @c
  #z = #pixel
loop:
  z2 = z * z
  z3 = z * z2
  z4 = z * z3
  err = (z4 + (c - 1)*z2 - c) / (4 * z3 + 2*(c - 1) * z)
  z = z - err
bailout:
  |Err| > @epsilon
default:
  title = "Newton Julia"
  maxiter = 3000
  periodicity = 0
  param c 
    caption = "Julia seed"
    default = (0,0)
  endparam  
  param epsilon
    caption = "Epsilon"
    default = 1e-6
  endparam  
switch:
  type = "CNewtonMset1"
  epsilon = epsilon
}


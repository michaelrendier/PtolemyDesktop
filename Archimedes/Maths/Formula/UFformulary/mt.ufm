loop:
  z = z^@n + @c + s
  s = |cabs(z)-@rad|
bailout:
  |z| < @bailout
default:
  title = "Ring Julia"
  param c
    caption = "Julia seed"
    default = (0,0)
  endparam  
  param n
    caption = "Exponent"
    default = 2.0
  endparam  

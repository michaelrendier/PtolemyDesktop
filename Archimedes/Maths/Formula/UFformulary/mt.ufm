    hint = "Determines the convergence required for \
           the orbit to bail out"
  endparam  
switch:
  type = "mt-newton-9904a-m"
  s = s
  epsilon = epsilon
}

mt-latoocarfian { ; Mark Townsend, 11 Apr 1999
;
; The Latoocarfian equations from Clifford A.
; Pickover's "Chaos in Wonderland".
;
init:
  if @map == 0
    float x = 0.01
    float y = 0.01
    float a = real(#pixel)
    float b = imag(#pixel)
    float c = real(@cd)
    float d = imag(@cd)
  elseif @map == 1
    float x = 0.01
    float y = 0.01
    float a = real(@ab)
    float b = imag(@ab)
    float c = real(#pixel)
    float d = imag(#pixel)
  else
    float x = real(#pixel)
    float y = imag(#pixel)
    float a = real(@ab)
    float b = imag(@ab)
    float c = real(@cd)
    float d = imag(@cd)
  endif
  float xx = 0
  z = 0    
loop:
  xx = x
  x = sin(y * b) + c * sin(x * b)
  y = sin(xx * a) + d * sin(y * a)
  z = x + flip(y)
bailout:
; no bailout  
  true
default:
  title = "Latoocarfian"
  param map
    caption = "Mapping"
    enum = "a, b" "c, d" "x, y"
  endparam  
  param ab
    caption = "a, b"
    default = (-0.966918,2.879879)
  endparam  
  param cd
    caption = "c, d"
    default = (0.765145,0.744728)
  endparam  
}

mt-pixel { ; Mark Townsend, 3 Apr 1999
; 
; Returns the unaltered pixel. 
;
init:
  z = #pixel
loop:
; Nothing here
bailout:
  @inside
default:
  title = "Pixel"
  param inside
    caption = "Inside"
    hint = "If this is enabled all of the pixels become inside."
    default = false
  endparam
}


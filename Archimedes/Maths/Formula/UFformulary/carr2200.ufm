    -flip(.1/pixel)
  c=(.3,.5825), d1=conj(.000255/pixel), d4 = 4*d1
  z1 = 1.5*z+d1, z2= 2.25*z+d1, z3 = 3.975*z+d1, z4 = 5.0625*z+d1
  l1=round(real(p1)), l2=round(imag(p1))

  ELSEIF (iter==l2)
    z=c=z2
  ELSEIF (iter==l3)
    z=c=z3
  ELSEIF (iter==l4)
    z=c=z4
  ELSE
    z = z - c/10
  ENDIF
  c = c + d4
  z = (z+d4)^2 + c
  iter = iter + 1
bailout:
  |real(z)| <= bailout
default:
  title = "Carr 2209"
  periodicity = 0
  maxiter = 500
  magn = .14
  center = (5,0)
  method = multipass
  param p1

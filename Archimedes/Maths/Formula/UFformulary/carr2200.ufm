comment {
  Carr2200.ufm Version 1.3
  Ultra Fractal conversions of Robert Carr's formulas Carr2200 - Carr2299
  by Erik Reckase / Lale Erguner, 12 December 2002

  History:  Version 1.4 - Fixes for UF3 compatibility by
                          Lale Erguner

            Version 1.3 - minor fixes, eliminated divide by zeros

            Version 1.2 - Global optimization effort (including 2223-2230!)
                          hints, cleanup

            Version 1.1 - Fixed bug in Carr2289

            Version 1.0 - Initial Release
                          Original formulas pulled from _rc2.frm
                          Carr2217 : adjusted cabs
                          Carr2223-2230 : extreme difficulty in conversion
                                          resulted in somewhat inefficient
                                          implementation
                          Carr2243,2247,2249 : pixel fix
                          Carr2255-2299
}

Carr2200 {; Updated for UF by Erik Reckase, March 2000
          ; Modified Sylvie Gallet frm. [101324,3444],1996
init:
  z=c=pixel-tanh(pixel) \
      /sqrt(log(tan(pixel)+sin(pixel-1)-2.75/pixel))
  d1=conj(.0002550/pixel), d4=4*d1
  z1=1.5*z+d1, z2=2.25*z+d1, z3=3.375*z+d1, z4=5.0625*z+d1
  l1=round(real(p1)), l2=round(imag(p1))
  l3=round(real(p2)), l4=round(imag(p2))
  float bailout=16, int iter=0
loop:
  IF (iter==l1)
    z=c=z1
  ELSEIF (iter==l2)
    z=c=z2
  ELSEIF (iter==l3)
    z=c=z3
  ELSEIF (iter==l4)
    z=c=z4
  ELSE
    z = z + c/8
  ENDIF
  c = c + d4
  z = (z+d4)^2 + c
  iter = iter + 1
bailout:
  |real(z)| <= bailout
default:
  title = "Carr 2200"
  periodicity = 0
  maxiter = 500
  magn = .9
  center = (-.5,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (200,250)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
}

Carr2201 (YAXIS) {; Updated for UF by Erik Reckase, March 2000
                  ; Modified Sylvie Gallet frm. [101324,3444],1996
init:
  z=c=pixel-tanh(pixel) \
    /sqrt(log(tan(pixel)+sin(pixel-1)-2.75/pixel))
  d1=conj(.0002550/pixel), d4=4*d1
  z1=1.5*z+d1, z2=2.25*z+d1, z3=3.375*z+d1, z4=5.0625*z+d1
  l1=round(real(p1)), l2=round(imag(p1))
  l3=round(real(p2)), l4=round(imag(p2))
  float bailout=16, int iter=0
loop:
  IF (iter==l1)
    z=c=z1
  ELSEIF (iter==l2)
    z=c=z2
  ELSEIF (iter==l3)
    z=c=z3
  ELSEIF (iter==l4)
    z=c=z4
  ELSE
    z = z + c/8
  ENDIF
  c = c + d4
  z = (z+d4)^2 + c
  iter = iter + 1
bailout:
  |real(z)| <= bailout
default:
  title = "Carr 2201"
  periodicity = 0
  maxiter = 500
  magn = .8
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (200,250)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
}

Carr2202 {; Updated for UF by Erik Reckase, March 2000
          ; Modified Sylvie Gallet frm. [101324,3444],1996
init:
  c=pixel*cabs(pixel) \
    /sqrt(log(tan(1-pixel)+sin(pixel-1)-2.75/pixel))
  z=-conj(.1/pixel)-tanh(.002525/pixel)
  d1=conj(.000255/pixel), d4=4*d1
  z1=1.5*z+d1, z2=2.25*z+d1, z3=3.375*z+d1, z4=5.0625*z+d1
  l1=round(real(p1)), l2=round(imag(p1))
  l3=round(real(p2)), l4=round(imag(p2))
  float bailout=16, int iter=0
loop:
  IF (iter==l1)
    z=c=z1
  ELSEIF (iter==l2)
    z=c=z2
  ELSEIF (iter==l3)
    z=c=z3
  ELSEIF (iter==l4)
    z=c=z4
  ELSE
    z = z + c/8
  ENDIF
  c = c + d4
  z = (z+d4)^2 + c - 1.15 - c/5
  iter = iter + 1
bailout:
  (|real(z)|) <= bailout
default:
  title = "Carr 2202"
  periodicity = 0
  maxiter = 500
  magn = .9
  center = (.4,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (200,250)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
}

Carr2203 {; Updated for UF by Erik Reckase, March 2000
          ; Modified Sylvie Gallet frm. [101324,3444],1996
init:
  c=pixel^2.3/sqrt(log(tan(1-pixel)+sin(pixel-1)-2.75/pixel))
  z=-conj(.1/pixel)-tanh(.002525/pixel)
  d1=(conj(0.0002550/pixel)), d4=4*d1
  z1=1.5*z+d1, z2=2.25*z+d1, z3=3.375*z+d1, z4=5.0625*z+d1
  l1=round(real(p1)), l2=round(imag(p1))
  l3=round(real(p2)), l4=round(imag(p2))
  float bailout=16, int iter=0
loop:
  IF (iter==l1)
    z=c=z1
  ELSEIF (iter==l2)
    z=c=z2
  ELSEIF (iter==l3)
    z=c=z3
  ELSEIF (iter==l4)
    z=c=z4
  ELSE
    z = z + c/8
  ENDIF
  c = c + d4
  z = (z+d4)^2 + c - 1.15 - c/5
  iter = iter + 1
bailout:
  |real(z)| <= bailout
default:
  title = "Carr 2203"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (.1,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (200,250)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
}

Carr2204 {; Updated for UF by Erik Reckase, March 2000
          ; Modified Sylvie Gallet frm. [101324,3444],1996
init:
  z=tan(pixel+.72)*conj(pixel)-1/log(pixel-1/sin(.001/pixel))
  c=pixel-conj(.01/pixel)-flip(.01/pixel)
  d1=conj(.000255/pixel), d4=4*d1
  z1=1.5*z+d1, z2=2.25*z+d1, z3=3.375*z+d1, z4=5.0625*z+d1
  l1=round(real(p1)), l2=round(imag(p1))
  l3=round(real(p2)), l4=round(imag(p2))
  float bailout=16, int iter=0
loop:
  IF (iter==l1)
    z=c=z1
  ELSEIF (iter==l2)
    z=c=z2
  ELSEIF (iter==l3)
    z=c=z3
  ELSEIF (iter==l4)
    z=c=z4
  ELSE
    z = z + c/8
  ENDIF
  c = c + d4
  z = (z+d4)^2 + c
  iter = iter + 1
bailout:
  |real(z)| <= bailout
default:
  title = "Carr 2204"
  periodicity = 0
  maxiter = 500
  magn = 1.1
  center = (-.5,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (200,250)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
}

Carr2205 {; Updated for UF by Erik Reckase, March 2000
          ; Modified Sylvie Gallet frm. [101324,3444],1996
init:
  z=sinh(pixel^2)-1/log(pixel-.1/pixel-flip(.001/pixel))
  c=sin((-.7896,.1309)), d1=conj(.000255/pixel), d4 = 4*d1
  z1 = 1.5*z+d1, z2= 2.25*z+d1, z3 = 3.375*z+d1, z4 = 5.0625*z+d1
  l1=round(real(p1)), l2=round(imag(p1))
  l3=round(real(p2)), l4=round(imag(p2))
  float bailout=16, int iter=0
loop:
  IF (iter==l1)
    z=c=z1
  ELSEIF (iter==l2)
    z=c=z2
  ELSEIF (iter==l3)
    z=c=z3
  ELSEIF (iter==l4)
    z=c=z4
  ENDIF
  c = c + d4
  z = (z+d4)^2 + c
  iter = iter + 1
bailout:
  |real(z)| <= bailout
default:
  title = "Carr 2205"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (-.6,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (200,250)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
}

Carr2206 {; Updated for UF by Erik Reckase, March 2000
          ; Modified Sylvie Gallet frm. [101324,3444],1996
init:
  p5=.001/pixel, c=(-.3159,-.63555)
  z=sinh(pixel^2)-1/log(pixel-100*p5-flip(p5))
  d1=conj(.0002550/pixel), d4=4*d1
  z1 = 1.5*z+d1, z2= 2.25*z+d1, z3 = 3.375*z+d1, z4 = 5.0625*z+d1
  l1=round(real(p1)), l2=round(imag(p1))
  l3=round(real(p2)), l4=round(imag(p2))
  float bailout=16, int iter=0
loop:
  IF (iter==l1)
    z=c=z1
  ELSEIF (iter==l2)
    z=c=z2
  ELSEIF (iter==l3)
    z=c=z3
  ELSEIF (iter==l4)
    z=c=z4
  ENDIF
  c = c + d4
  z = (z+d4)^2 + c + p5
  iter=iter+1
bailout:
  |real(z)| <= bailout
default:
  title = "Carr 2206"
  periodicity = 0
  maxiter = 500
  magn = .8
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (200,250)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
}

Carr2207 {; Updated for UF by Erik Reckase, March 2000
          ; Modified Sylvie Gallet frm. [101324,3444],1996
init:
  z=pixel*(pixel-.2)-1/log(.1/pixel)-cos(.01/pixel) \
    +conj(.1/pixel)+.45
  c=(-.8606,-.0959)
  d1=conj(.0002550/pixel), d4 = 4*d1
  z1 = 1.5*z+d1, z2= 2.25*z+d1, z3 = 3.375*z+d1, z4 = 5.0625*z+d1
  l1=round(real(p1)), l2=round(imag(p1))
  l3=round(real(p2)), l4=round(imag(p2))
  float bailout=16, int iter=0
loop:
  IF (iter==l1)
    z=c=z1
  ELSEIF (iter==l2)
    z=c=z2
  ELSEIF (iter==l3)
    z=c=z3
  ELSEIF (iter==l4)
    z=c=z4
  ELSE
    z = z - c/10
  ENDIF
  c = c + d4
  z = (z+d4)^2 + c
  iter=iter+1
bailout:
  |real(z)| <= bailout
default:
  title = "Carr 2207"
  periodicity = 0
  maxiter = 500
  magn = 1.2
  center = (.1,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (200,250)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
}

Carr2208 {; Updated for UF by Erik Reckase, March 2000
          ; Modified Sylvie Gallet frm. [101324,3444],1996
init:
  z=conj(pixel)*(pixel+1.25)-flip(asin(.01/pixel))\
    +conj(asin(.1/pixel))+.25
  c=(-.8606,-.1279)
  d1=conj(.0002550/pixel), d4 = 4*d1
  z1 = 1.5*z+d1, z2= 2.25*z+d1, z3 = 3.375*z+d1, z4 = 5.0625*z+d1
  l1=round(real(p1)), l2=round(imag(p1))
  l3=round(real(p2)), l4=round(imag(p2))
  float bailout=16, int iter=0
loop:
  IF (iter==l1)
    z=c=z1
  ELSEIF (iter==l2)
    z=c=z2
  ELSEIF (iter==l3)
    z=c=z3
  ELSEIF (iter==l4)
    z=c=z4
  ELSE
    z = z - c/10
  ENDIF
  z = (z+d4)^2 + c
  iter=iter+1
bailout:
  |real(z)| <= bailout
default:
  title = "Carr 2208"
  periodicity = 0
  maxiter = 500
  magn = 1.5 
  center = (-.65,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (200,250)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
}


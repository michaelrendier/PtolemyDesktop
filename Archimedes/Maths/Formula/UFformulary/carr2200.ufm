                  ; Modified Sylvie Gallet frm. [101324,3444],1996
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  b=.0005/pixel2-conj(.005/pixel2), p5=.05*pixel2
  z=3*pixel2+conj(pixel2-flip(.01/pixel2))+.3
  c=sin((-.655,.3589))
  d1=conj(.0002455/pixel2), d4 = 4*d1
  z1 = 1.5*z+d1, z2= 2.25*z+d1, z3 = 3.375*z+d1, z4 = 6.0625*z+d1
  l1=round(real(p1)), l2=round(imag(p1))
  l3=round(real(p2)), l4=round(imag(p2))
  float bailout=16, int iter=0
loop:
  IF (iter==l1)
    z=c=z1
  ELSEIF (iter==l2)
    z=c=z2
  ELSEIF (iter==l3)
    z=c=z3
  ELSEIF (iter==l4)
    z=c=z4
  ELSE
    z = z + b
  ENDIF
  c = c + d4
  z = (z+d4)^2 + c - p5
  iter=iter+1
bailout:
  |real(z)| <= bailout
default:
  title = "Carr 2243"
  periodicity = 0
  maxiter = 500
  magn = 3.3
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"

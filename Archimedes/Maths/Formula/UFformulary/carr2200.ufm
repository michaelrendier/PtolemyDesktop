  c=pixel-conj(0.10/pixel-flip(0.010/pixel))
  float compt=0, float limit=real(p1*cos(pixel/5))
  float bailout=4
loop:
  IF (compt>=limit)
    c = (-.743380900000982,-.131850030300002)
  ENDIF
  z=z*z+c
  compt=compt+1
bailout:
  |z|<=bailout
default:

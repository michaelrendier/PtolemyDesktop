mapping:
  center=25.5/25.5 magn=0.08
formula:
  maxiter=1 percheck=off filename="lkm.ufm" entry="pixel"
inside:
  transfer=none
outside:
  density=16 transfer=linear repeat=no filename="lkm-special.ucl"
  entry="may03-signature" p_seedtype="phi ~ 1.618" p_seed=1.73205080756888
  f_fn1=ident p_negate=no p_imin=1 p_imax=50 p_jmin=1 p_jmax=50
gradient:
  comments="Kerry Mitchell/n/nrainbow gradient with green negated/n"
  smooth=yes index=0 color=0 index=399 color=16777215
opacity:
  smooth=no index=0 opacity=255
}


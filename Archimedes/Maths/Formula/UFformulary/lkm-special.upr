comment {

Images using special formulas developed by Kerry Mitchell
All images copyright Kerry Mitchell

Note! These are experimental, beta tests, highly specialized, 
or worse. Not for the faint of heart or new to UF. In general, 
there's little to no support or documentation. In short, you're 
on your own.

Have fun! :-)
} 

aug0101-e { ; Copyright 2001 Kerry Mitchell
fractal:
  title="aug0101-e" width=640 height=480 author="Kerry Mitchell"
  created="August 1, 2001" numlayers=2
layer:
  method=multipass caption="New Layer 2" opacity=100 visible=yes alpha=no
  mergemode=difference
mapping:
  center=0/0 magn=1.6 angle=275
formula:
  filename="standard.ufm" entry="Julia" maxiter=2 percheck=off
  p_seed=0.384727430174991296/0.109283294449152736 p_power=2/0
  p_bailout=1E20
inside:
  filename="lkm-special.ucl" entry="aug01-tangent-rose" density=400 transfer=linear
  repeat=no p_a=1 p_b=4 p_nt=512 p_linetype="normal" p_updown="both"
outside:
  filename="lkm-special.ucl" entry="aug01-tangent-rose" density=400 transfer=linear
  repeat=no p_a=1 p_b=2 p_nt=1024 p_linetype="tangent" p_updown="both"
gradient:
  smooth=yes numnodes=2 index=0 color=4177727 index=399 color=0
layer:
  method=multipass caption="New Layer 1" visible=yes alpha=no
mapping:
  center=0/0 magn=1.6 angle=275
formula:
  filename="standard.ufm" entry="Julia" maxiter=2 percheck=off
  p_seed=0.384727430174991296/0.109283294449152736 p_power=2/0
  p_bailout=1E20
inside:
  filename="lkm-special.ucl" entry="aug01-tangent-rose" density=400 transfer=linear
  repeat=no p_a=1 p_b=4 p_nt=512 p_linetype="tangent" p_updown="both"
outside:
  filename="lkm-special.ucl" entry="aug01-tangent-rose" density=400 transfer=linear
  repeat=no p_a=1 p_b=2 p_nt=1024 p_linetype="tangent" p_updown="both"
gradient:
  smooth=yes numnodes=2 index=0 color=4243520 index=399 color=16777215
}


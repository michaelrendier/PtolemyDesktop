fiddling15 {;©1999 by Aubrey Minnick
init:
  z = 0
loop:
  z = sin(cos(15 * z ^ 8)) * cos(sin(15 * z ^ 8)) * #pixel
bailout:
  |z| < 2 
default:
  title = "fiddling15"
}

fiddling2 {;©1999 by Aubrey Minnick
init:
  z = 0
loop:
  z = sin(cos(z * 12)) * cos(sin(z * 8)) * #pixel
bailout:
  |z| < 2 
default:
  title = "fiddling2"
}


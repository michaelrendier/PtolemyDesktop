castaway {;©1999 by Aubrey Minnick
init:
  z = 0
loop:
  z = sin(cos(z ^ (z * z) ^ z ^ (z * z) ^ z)) * cos(sin(z ^ (z * z) ^ z ^\
(z * z) ^ z)) * #pixel
bailout:
  |z| < 2 
default:
  title = "castaway"
}

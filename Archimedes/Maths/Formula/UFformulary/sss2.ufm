Shapes1 {
;Copyright 2002, Sharon S. Schultz

init:
  Z = #pixel
  C = p1*Z
  x = z^4+real(c)

loop:
  Z = fn2(fn3(fn4(Z^3*((|z|*Z^3*c)/2*fn1(real(Z)+C/Z^3*C))+X)))
  z = z*@niter

bailout:
  |Z| < @bailout*(Z+C/X)


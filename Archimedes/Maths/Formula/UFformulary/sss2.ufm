Alien11 {
;Copyright 2002, Sharon S. Schultz

init:
  Z = @Start
  C = #pixel
  x = z+cos(c)

loop:
  Z = fn2((z*(Z^2)+c)*fn1(2*(|Z|+C*(Z^3-C)))*fn3(X+(Z*(C^2))))
  z = z*@niter

bailout:

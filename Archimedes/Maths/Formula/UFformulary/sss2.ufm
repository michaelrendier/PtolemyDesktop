13_Thirteen {
;Copyright 2002, Sharon S. Schultz

init:
  Z = #pixel
  C = p1*Z^6+p1^2
  x = z^4+cos(c)
  y = z+@Start

loop:
  Z = fn1(fn2(fn3(fn4(z^5/cos(X))*((z^3)*1.732+C)/y)))
  z = z*@niter

bailout:
  |Z| < @bailout*(Z+C*X)


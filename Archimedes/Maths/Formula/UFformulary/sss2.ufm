14_FourteenA {
;Copyright 2002, Sharon S. Schultz

init:
  Z = #pixel
  a = p1
  b = p2
  C = a^b+b^a
  x = z^cos(c)
  y = @Start

loop:
  Z = fn1(fn2(fn3(fn4(z^5/X)+((a^3)*1.732+c)/(y^3*b))))
  z = z*@niter

bailout:
  |Z| < @bailout*(Z+C*X)


1_OneA {
;Copyright 2002, Sharon S. Schultz

Init:
  z = @start
  c = #pixel

loop:
  z = fn1(fn2(fn3(fn4((z^5)-flip(c))/((z)+real(c))/(z^6+1))))
  z = z*@niter

bailout:
  z < @bailout*|z|^3

default:
  title = "1-One A"
  angle = 90
  maxiter = 5
  center = (2.6,0)
  magn = 0.1
  method = multipass
  periodicity = 0

heading
caption = "Formula Parameters"
endheading

Param start
  caption = "Start"
  default = (1,0)
  hint = "Select a starting value for the formula."
endparam

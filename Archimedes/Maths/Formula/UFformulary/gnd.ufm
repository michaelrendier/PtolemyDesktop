    caption = "fBm Parameters"
    visible = @fBm == true
  endheading

  param distortion
    caption = "Distortion Strength"
    default = 0.5
    hint = "This is the amount the noise distorts the image."
    visible = @fBm == true
  endparam
  param style
    caption = "Distortion Style"

    ENDIF
  ELSEIF (@zmode == 4)                  ; smallest |real(z)|*|imag(z)|
    d1 = abs(real(z1))*abs(imag(z1))    ; get current distances from i axis
    d2 = abs(real(z2))*abs(imag(z2))
    d3 = abs(real(z3))*abs(imag(z3))

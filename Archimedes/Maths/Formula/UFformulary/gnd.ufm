gnd-PhoenixBarnsley1M {
; Gilles Nadeau, June, 2005
;
init:
  complex z = @start  
  complex c = #pixel
  complex nz = (0,0)
  complex temp = (0,0) 
loop:
  temp = c * @fn1(@fn2(@fn3(z))) - c + @p*nz
  nz = z
  z = temp 
bailout:
  (@test == 0 && |z| <= @bailout) ||                                         \
  (@test == 1 && sqr(real(z)) <= @bailout) ||                                \
  (@test == 2 && sqr(imag(z)) <= @bailout) ||                                \
  (@test == 3 && (sqr(real(z)) <= @bailout && sqr(imag(z)) < @bailout)) ||   \
  (@test == 4 && (sqr(real(z)) <= @bailout || sqr(imag(z)) < @bailout)) ||   \
  (@test == 5 && (sqr(abs(real(z)) + abs(imag(z))) <= @bailout)) ||          \
  (@test == 6 && (sqr(real(z) + imag(z)) <= @bailout))
default:
  title = "Phoenix Barnsley 1 M Set"
  maxiter = 149
  periodicity = 0
  method = multipass
 float param version
   default = 1.0
   visible = false
 endparam
 param start
   caption = "Perturbation"
   default = (0.0, 0.0)
 endparam
 param p
   caption = "Phoenix Distortion"
   default = (0.5, 0.0)
 endparam
 param test
   caption = "Bailout Test"
   default = 0
   enum = "mod" "real" "imag" "or" "and" "manh" "manr"
 endparam
 param bailout 
   caption = "Bailout value"
   default = 4.0
   min = 1.0
 endparam
 func fn1
   caption = "First Function"
   default = ident()
  endfunc
 func fn2
   caption = "Second Function"
   default = sqrt()
  endfunc
 func fn3
   caption = "Third Function"
   default = sqr()
  endfunc
 switch:
 type = "gnd-PhoenixBarnsley1J"
 version = @version
 seed = #pixel
 p = @p
 test = @test
 bailout = @bailout
 fn1 = @fn1
 fn2 = @fn2
 fn3 = @fn3
}

gnd-PhoenixBarnsley1J {
; Gilles Nadeau, June, 2005
;
init:
  complex z = #pixel
  complex c = @seed
  complex nz = (0,0)
  complex temp = (0,0) 
loop:
  temp = c * @fn1(@fn2(@fn3(z))) - c + @p*nz
  nz = z
  z = temp   
bailout:
  (@test == 0 && |z| <= @bailout) ||                                         \
  (@test == 1 && sqr(real(z)) <= @bailout) ||                                \
  (@test == 2 && sqr(imag(z)) <= @bailout) ||                                \
  (@test == 3 && (sqr(real(z)) <= @bailout && sqr(imag(z)) < @bailout)) ||   \
  (@test == 4 && (sqr(real(z)) <= @bailout || sqr(imag(z)) < @bailout)) ||   \
  (@test == 5 && (sqr(abs(real(z)) + abs(imag(z))) <= @bailout)) ||          \
  (@test == 6 && (sqr(real(z) + imag(z)) <= @bailout))
default:
  title = "Phoenix Barnsley 1 J Set"
  maxiter = 149
  periodicity = 0
  method = multipass
 float param version
   default = 1.0
   visible = false
 endparam
 param seed
   caption = "Julia seed"
   default = (0.415, 1.2)
 endparam
 param p
   caption = "Phoenix Distortion"
   default = (0.5, 0.0)
 endparam
 param test
   caption = "Bailout Test"
   default = 0
   enum = "mod" "real" "imag" "or" "and" "manh" "manr"
 endparam
 param bailout 
   caption = "Bailout value"
   default = 4.0
   min = 1.0
 endparam
 func fn1
   caption = "First Function"
   default = ident()
  endfunc
 func fn2
   caption = "Second Function"
   default = sqrt()
  endfunc
 func fn3
   caption = "Third Function"
   default = sqr()
  endfunc
 switch:
 type = "gnd-PhoenixBarnsley1M"
 version = @version
 p = @p
 test = @test
 bailout = @bailout
 fn1 = @fn1
 fn2 = @fn2
 fn3 = @fn3
}

gnd-4D-Barnsley-Julia {
; Hypercomplex Barnsley Julia formula
; version 1.12, August 2005
; Gilles Nadeau, 12/08/2005
;
init:
  float xx = real(#pixel)
  float yy = imag(#pixel)
  float zz = real(@zjk)
  float ww = imag(@zjk)
  float cx = real(@c1i)
  float cy = imag(@c1i)
  float cz = real(@cjk)
  float cw = imag(@cjk)
  float zr = 0.0
  float zi = 0.0
  float zj = 0.0
  float zk = 0.0
  float cr = 0.0
  float ci = 0.0
  float cj = 0.0
  float ck = 0.0
  float rx = 0.0
  float ry = 0.0
  float rz = 0.0

; (yz plane rotation)
    ry = yy*cos(#pi*@rotx/180) - zz*sin(#pi*@rotx/180)
    rz = yy*sin(#pi*@rotx/180) + zz*cos(#pi*@rotx/180)
    yy = ry
    zz = rz

    ry = cy*cos(#pi*@rotx/180) - cz*sin(#pi*@rotx/180)
    rz = cy*sin(#pi*@rotx/180) + cz*cos(#pi*@rotx/180)
    cy = ry
    cz = rz

; (xz plane rotation)
    rx = zz*sin(#pi*@roty/180) + xx*cos(#pi*@roty/180)
    rz = zz*cos(#pi*@roty/180) - xx*sin(#pi*@roty/180)
    xx = rx
    zz = rz

    rx = cz*sin(#pi*@roty/180) + cx*cos(#pi*@roty/180)
    rz = cz*cos(#pi*@roty/180) - cx*sin(#pi*@roty/180)
    cx = rx
    cz = rz

; (xy plane rotation)
    rx = xx*cos(#pi*@rotz/180) - yy*sin(#pi*@rotz/180)
    ry = xx*sin(#pi*@rotz/180) + yy*cos(#pi*@rotz/180)
    xx = rx
    yy = ry

    rx = cx*cos(#pi*@rotz/180) - cy*sin(#pi*@rotz/180)
    ry = cx*sin(#pi*@rotz/180) + cy*cos(#pi*@rotz/180)
    cx = rx
    cy = ry

   if @fourthdim == 3
    zr = xx
    zi = yy
    zj = zz
    zk = ww
    cr = cx
    ci = cy
    cj = cz
    ck = cw
   elseif @fourthdim == 2
    zr = xx
    zi = yy
    zj = ww
    zk = zz
    cr = cx
    ci = cy
    cj = cw
    ck = cz
   elseif @fourthdim == 1
    zr = zz
    zi = ww
    zj = xx
    zk = yy
    cr = cz
    ci = cw
    cj = cx
    ck = cy
   else
    zr = ww
    zi = zz
    zj = xx
    zk = yy
    cr = cw
    ci = cz
    cj = cx
    ck = cy
   endif

   complex a = zr - zk + flip(zi + zj)
   complex b = zr + zk + flip(zi - zj)
   complex ca = cr - ck + flip(ci + cj)
   complex cb = cr + ck + flip(ci - cj)

loop:

 if (@var == 0)
  if real(a) >= 0
   a = (a - 1) * ca
  else
   a = (a + 1) * ca
  endif
  if real(b) >= 0
   b = (b - 1) * cb
  else
   b = (b + 1) * cb
  endif

 elseif (@var == 1)
  if real(a) * imag(ca) + real(ca) * imag(a) >= 0
   a = (a - 1) * ca
  else
   a = (a + 1) * ca
  endif
  if real(b) * imag(cb) + real(cb) * imag(b) >= 0
   b = (b - 1) * cb
  else
   b = (b + 1) * cb
  endif

 elseif (@var == 2)
  if real(a) >= 0
   a = sqr(a) - 1
  else
   a = sqr(a) - 1 + ca * real(a)
  endif
  if real(b) >= 0
   b = sqr(b) - 1
  else
   b = sqr(b) - 1 + cb * real(b)
  endif
 endif

   z = (a + b) / 2
bailout:
   (|a| + |b|) / 2 <= @bailout
default:
  title = "4-D Barnsley Julia"
  center = (0.0,0.0)
  magn = 1.0
  maxiter = 149
  method = multipass
  periodicity = 0
  param version
    caption = "Version"
    default = 1.12
    visible = false
  endparam
  param var
    caption = "Variation"
    enum = "First""Second""Third"
    default = 0
  endparam
  param fourthdim
    caption = "Fourth dimension"
    enum = "z1" "zi" "zj" "zk"
    default = 3
  endparam
  param c1i
    caption = "(c1, ci)"
    default = (0.0, 1.44)
  endparam
  param cjk
    caption = "(cj, ck)"
    default = (0.0, 0.0)
  endparam
  param zjk
    caption = "(zj, zk)"
    default = (0.0, 0.0)
  endparam
  param rotx
    caption="x-rotation"
    hint="Rotates yz-plane."
    default=0.0
    min=-360.0
    max=360.0
  endparam
  param roty
    caption="y-rotation"
    hint="Rotates zx-plane."
    default=0.0
    min=-360.0
    max=360.0
  endparam
  param rotz
    caption="z-rotation"
    hint="Rotates xy-plane."
    default=0.0
    min=-360.0
    max=360.0
  endparam
  param bailout
    caption = "Bailout Value"
    default = 16.0
    min = 0.0
  endparam
switch:
  type = "gnd-4D-Barnsley-Mandelbrot"
  version = @version
  cjk = @cjk
  var = @var
  fourthdim = @fourthdim
  rotx = @rotx
  roty = @roty
  rotz = @rotz
  bailout = @bailout

}

gnd-4D-Barnsley-Mandelbrot {
; Hypercomplex Barnsley Mandel formula
; version 1.12, August 2005
; Gilles Nadeau, 12/08/2005
;
init:
  float xx = 0.0
  float yy = 0.0
  float zz = 0.0
  float ww = 0.0
  float cx = real(#pixel)
  float cy = imag(#pixel)
  float cz = real(@cjk)
  float cw = imag(@cjk)
  float zr = 0.0
  float zi = 0.0
  float zj = 0.0
  float zk = 0.0
  float cr = 0.0
  float ci = 0.0
  float cj = 0.0
  float ck = 0.0
  float rx = 0.0
  float ry = 0.0
  float rz = 0.0

; (yz plane rotation)
    ry = cy*cos(#pi*@rotx/180) - cz*sin(#pi*@rotx/180)
    rz = cy*sin(#pi*@rotx/180) + cz*cos(#pi*@rotx/180)
    cy = ry
    cz = rz

; (xz plane rotation)
    rx = cz*sin(#pi*@roty/180) + cx*cos(#pi*@roty/180)
    rz = cz*cos(#pi*@roty/180) - cx*sin(#pi*@roty/180)
    cx = rx
    cz = rz

; (xy plane rotation)
    rx = cx*cos(#pi*@rotz/180) - cy*sin(#pi*@rotz/180)
    ry = cx*sin(#pi*@rotz/180) + cy*cos(#pi*@rotz/180)
    cx = rx
    cy = ry

   if @fourthdim == 3
    zr = xx + cx
    zi = yy + cy
    zj = zz + cz
    zk = ww + cw
    cr = cx
    ci = cy
    cj = cz
    ck = cw
   elseif @fourthdim == 2
    zr = xx + cx
    zi = yy + cy
    zj = ww + cw
    zk = zz + cz
    cr = cx
    ci = cy
    cj = cw
    ck = cz
   elseif @fourthdim == 1
    zr = zz + cz
    zi = ww + cw
    zj = xx + cx
    zk = yy + cy
    cr = cz
    ci = cw
    cj = cx
    ck = cy
   else
    zr = ww + cw
    zi = zz + cz
    zj = xx + cx
    zk = yy + cy
    cr = cw
    ci = cz
    cj = cx
    ck = cy
   endif

   complex a = zr - zk + flip(zi + zj)
   complex b = zr + zk + flip(zi - zj)
   complex ca = cr - ck + flip(ci + cj)
   complex cb = cr + ck + flip(ci - cj)

loop:

 if (@var == 0)
  if real(a) >= 0
   a = (a - 1) * ca
  else
   a = (a + 1) * ca
  endif
  if real(b) >= 0
   b = (b - 1) * cb
  else
   b = (b + 1) * cb
  endif

 elseif (@var == 1)
  if real(a) * imag(ca) + real(ca) * imag(a) >= 0
   a = (a - 1) * ca
  else
   a = (a + 1) * ca
  endif
  if real(b) * imag(cb) + real(cb) * imag(b) >= 0
   b = (b - 1) * cb
  else
   b = (b + 1) * cb
  endif

 elseif (@var == 2)
  if real(a) >= 0
   a = sqr(a) - 1
  else
   a = sqr(a) - 1 + ca * real(a)
  endif
  if real(b) >= 0
   b = sqr(b) - 1
  else
   b = sqr(b) - 1 + cb * real(b)
  endif
 endif

   z = (a + b) / 2
bailout:
   (|a| + |b|) / 2 <= @bailout
default:
  title = "4-D Barnsley Mandelbrot"
  center = (0.0,0.0)
  magn = 1.0
  maxiter = 149
  method = multipass
  periodicity = 0
  param version
    caption = "Version"
    default = 1.12
    visible = false
  endparam
  param var
    caption = "Variation"
    enum = "First""Second""Third"
    default = 0
  endparam
  param fourthdim
    caption = "Fourth dimension"
    enum = "z1" "zi" "zj" "zk"
    default = 3
  endparam
  param cjk
    caption = "(cj, ck)"
    default = (0.0, 0.0)
  endparam
  param rotx
    caption="x-rotation"
    hint="Rotates yz-plane."
    default=0.0
    min=-360.0
    max=360.0
  endparam
  param roty
    caption="y-rotation"
    hint="Rotates zx-plane."
    default=0.0
    min=-360.0
    max=360.0
  endparam
  param rotz
    caption="z-rotation"
    hint="Rotates xy-plane."
    default=0.0
    min=-360.0
    max=360.0
  endparam
  param bailout
    caption = "Bailout Value"
    default = 16.0
    min = 0.0
  endparam
 switch:
  type = "gnd-4D-Barnsley-Julia"
  version = @version
  c1i = #pixel
  cjk = @cjk
  var = @var
  fourthdim = @fourthdim
  rotx = @rotx
  roty = @roty
  rotz = @rotz
  bailout = @bailout
}

gnd-hyperikenaga {
; Gilles Nadeau, April, 2005
;
init:
  complex z = (0.0, 0.0) 
  complex w = (0.0, 0.0) 
  complex cz = #pixel
  complex cw = @cjk
  complex a = (0.0, 0.0)
  complex b = (0.0, 0.0)
  complex c = (0.0, 0.0)
  complex d = (0.0, 0.0)
  complex ca = (0.0, 0.0)
  complex cb = (0.0, 0.0)
  float z1 = 0.0
  float zi = 0.0
  float zj = 0.0
  float zk = 0.0
  float c1 = 0.0
  float ci = 0.0
  float cj = 0.0
  float ck = 0.0
  float rx = 0.0
  float ry = 0.0
  float rz = 0.0

; (yz plane rotation)   
    ry = imag(z)*cos(#pi*@rotx/180) - real(w)*sin(#pi*@rotx/180)
    rz = imag(z)*sin(#pi*@rotx/180) + real(w)*cos(#pi*@rotx/180)
    z = real(z) + ry*1i
    w = rz + imag(w)*1i
    
    ry = imag(cz)*cos(#pi*@rotx/180) - real(cw)*sin(#pi*@rotx/180)
    rz = imag(cz)*sin(#pi*@rotx/180) + real(cw)*cos(#pi*@rotx/180)
    cz = real(cz) + ry*1i
    cw = rz + imag(cw)*1i
    
; (xz plane rotation)   
    rx = real(w)*sin(#pi*@roty/180) + real(z)*cos(#pi*@roty/180)
    rz = real(w)*cos(#pi*@roty/180) - real(z)*sin(#pi*@roty/180)
    z = rx + imag(z)*1i
    w = rz + imag(w)*1i

    rx = real(cw)*sin(#pi*@roty/180) + real(cz)*cos(#pi*@roty/180)
    rz = real(cw)*cos(#pi*@roty/180) - real(cz)*sin(#pi*@roty/180)
    cz = rx + imag(cz)*1i
    cw = rz + imag(cw)*1i
    
; (xy plane rotation)   
    rx = real(z)*cos(#pi*@rotz/180) - imag(z)*sin(#pi*@rotz/180)
    ry = real(z)*sin(#pi*@rotz/180) + imag(z)*cos(#pi*@rotz/180)
    z = rx + ry*1i
    
    rx = real(cz)*cos(#pi*@rotz/180) - imag(cz)*sin(#pi*@rotz/180)
    ry = real(cz)*sin(#pi*@rotz/180) + imag(cz)*cos(#pi*@rotz/180)
    cz = rx + ry*1i
    
    if @fourthdim == 3
     z1 = real(z)
     zi = imag(z)
     zj = real(w)
     zk = imag(w)
     c1 = real(cz)
     ci = imag(cz)
     cj = real(cw)
     ck = imag(cw)
    elseif @fourthdim == 2
     z1 = real(z)
     zi = imag(z)
     zj = imag(w)
     zk = real(w)
     c1 = real(cz)
     ci = imag(cz)
     cj = imag(cw)
     ck = real(cw)
    elseif @fourthdim == 1
     z1 = real(w)
     zi = imag(w)
     zj = real(z)
     zk = imag(z)
     c1 = real(cw)
     ci = imag(cw)
     cj = real(cz)
     ck = imag(cz)
    else
     z1 = imag(w)
     zi = real(w)
     zj = real(z)
     zk = imag(z)
     c1 = imag(cw)
     ci = real(cw)
     cj = real(cz)
     ck = imag(cz)
    endif
  
  ca = c1 - ck + flip(ci + cj)
  cb = c1 + ck + flip(ci - cj) 

loop:
  a = z1 - zk + flip(zi + zj)
  b = z1 + zk + flip(zi - zj)
  c = a*a*a + a*ca - a - ca
  d = b*b*b + b*cb - b - cb  
  z1 = (real(c) + real(d)) / 2 
  zi = (imag(c) + imag(d)) / 2
  zj = (imag(c) - imag(d)) / 2 
  zk = (real(d) - real(c)) / 2
  z = z1 + flip(zi)
  w = zj + flip(zk)  
bailout:
  |z| + |w| <= @bailout
default:
  title = "Hypercomplex Ikenaga"
  maxiter = 500
  periodicity = 0
  method = multipass
 float param version
   default = 1.13
   visible = false
 endparam
 param fourthdim
   caption = "Fourth dimension"
   enum = "z1" "zi" "zj" "zk"
   default = 3
 endparam
 param cjk
   caption = "(cj, ck)"
   default = (0.0, 0.0)
 endparam
 param rotx
   caption="x-rotation"
   hint="Rotates yz-plane."
   default=0.0
   min=-360.0
   max=360.0
 endparam
 param roty
   caption="y-rotation"
   hint="Rotates zx-plane."
   default=0.0
   min=-360.0
   max=360.0
 endparam
 param rotz
   caption="z-rotation"
   hint="Rotates xy-plane."
   default=0.0
   min=-360.0
   max=360.0
 endparam
 param bailout
  caption = "Bailout value"
  default = 64.0
  min = 1
 endparam
switch:
 type = "gnd-hyperikenagaj"
 version = @version
 fourthdim = @fourthdim
 c1i = #pixel
 cjk = @cjk
 rotx = @rotx
 roty = @roty
 rotz = @rotz
 bailout = @bailout
}

gnd-hyperikenagaj {
; Gilles Nadeau, April, 2005
;
init:
  complex z = #pixel
  complex w = @zjk
  complex cz = @c1i
  complex cw = @cjk
  complex a = (0.0, 0.0)
  complex b = (0.0, 0.0)
  complex c = (0.0, 0.0)
  complex d = (0.0, 0.0)
  complex ca = (0.0, 0.0)
  complex cb = (0.0, 0.0)
  float z1 = 0.0
  float zi = 0.0
  float zj = 0.0
  float zk = 0.0
  float c1 = 0.0
  float ci = 0.0
  float cj = 0.0
  float ck = 0.0
  float rx = 0.0
  float ry = 0.0
  float rz = 0.0

; (yz plane rotation)   
    ry = imag(z)*cos(#pi*@rotx/180) - real(w)*sin(#pi*@rotx/180)
    rz = imag(z)*sin(#pi*@rotx/180) + real(w)*cos(#pi*@rotx/180)
    z = real(z) + ry*1i
    w = rz + imag(w)*1i
    
    ry = imag(cz)*cos(#pi*@rotx/180) - real(cw)*sin(#pi*@rotx/180)
    rz = imag(cz)*sin(#pi*@rotx/180) + real(cw)*cos(#pi*@rotx/180)
    cz = real(cz) + ry*1i
    cw = rz + imag(cw)*1i
    
; (xz plane rotation)   
    rx = real(w)*sin(#pi*@roty/180) + real(z)*cos(#pi*@roty/180)
    rz = real(w)*cos(#pi*@roty/180) - real(z)*sin(#pi*@roty/180)
    z = rx + imag(z)*1i
    w = rz + imag(w)*1i

    rx = real(cw)*sin(#pi*@roty/180) + real(cz)*cos(#pi*@roty/180)
    rz = real(cw)*cos(#pi*@roty/180) - real(cz)*sin(#pi*@roty/180)
    cz = rx + imag(cz)*1i
    cw = rz + imag(cw)*1i
    
; (xy plane rotation)   
    rx = real(z)*cos(#pi*@rotz/180) - imag(z)*sin(#pi*@rotz/180)
    ry = real(z)*sin(#pi*@rotz/180) + imag(z)*cos(#pi*@rotz/180)
    z = rx + ry*1i
    
    rx = real(cz)*cos(#pi*@rotz/180) - imag(cz)*sin(#pi*@rotz/180)
    ry = real(cz)*sin(#pi*@rotz/180) + imag(cz)*cos(#pi*@rotz/180)
    cz = rx + ry*1i
    
    if @fourthdim == 3
     z1 = real(z)
     zi = imag(z)
     zj = real(w)
     zk = imag(w)
     c1 = real(cz)
     ci = imag(cz)
     cj = real(cw)
     ck = imag(cw)
    elseif @fourthdim == 2
     z1 = real(z)
     zi = imag(z)
     zj = imag(w)
     zk = real(w)
     c1 = real(cz)
     ci = imag(cz)
     cj = imag(cw)
     ck = real(cw)
    elseif @fourthdim == 1
     z1 = real(w)
     zi = imag(w)
     zj = real(z)
     zk = imag(z)
     c1 = real(cw)
     ci = imag(cw)
     cj = real(cz)
     ck = imag(cz)
    else
     z1 = imag(w)
     zi = real(w)
     zj = real(z)
     zk = imag(z)
     c1 = imag(cw)
     ci = real(cw)
     cj = real(cz)
     ck = imag(cz)
    endif
  
  ca = c1 - ck + flip(ci + cj)
  cb = c1 + ck + flip(ci - cj) 

loop:
  a = z1 - zk + flip(zi + zj)
  b = z1 + zk + flip(zi - zj)
  c = a*a*a + a*ca - a - ca
  d = b*b*b + b*cb - b - cb  
  z1 = (real(c) + real(d)) / 2 
  zi = (imag(c) + imag(d)) / 2
  zj = (imag(c) - imag(d)) / 2 
  zk = (real(d) - real(c)) / 2
  z = z1 + flip(zi)
  w = zj + flip(zk)
bailout:
  |z| + |w| <= @bailout
default:
  title = "Hypercomplex Ikenaga Julia"
  maxiter = 500
  periodicity = 0
  method = multipass
 float param version
   default = 1.13
   visible = false
 endparam
 param fourthdim
   caption = "Fourth dimension"
   enum = "z1" "zi" "zj" "zk"
   default = 3
 endparam
 param c1i
   caption = "(c1, ci)"
   default = (0.012, 0.0)
 endparam
 param cjk
   caption = "(cj, ck)"
   default = (0.113, 0.0)
 endparam
 param zjk
   caption = "(zj, zk)"
   default = (0.0, 0.0)
 endparam
 param rotx
   caption="x-rotation"
   hint="Rotates yz-plane."
   default=0.0
   min=-360.0
   max=360.0
 endparam
 param roty
   caption="y-rotation"
   hint="Rotates zx-plane."
   default=0.0
   min=-360.0
   max=360.0
 endparam
 param rotz
   caption="z-rotation"
   hint="Rotates xy-plane."
   default=0.0
   min=-360.0
   max=360.0
 endparam
 param bailout
  caption = "Bailout value"
  default = 64.0
  min = 1
 endparam
switch:
 type = "gnd-hyperikenaga"
 version = @version
 fourthdim = @fourthdim
 cjk = @cjk
 rotx = @rotx
 roty = @roty
 rotz = @rotz
 bailout = @bailout
}

gnd-hypermandellambdapwr {
; Gilles Nadeau, July, 2005
; Based on the formula Mandel Lambda Power from Ron Barnett
;
init:
  complex z = (0.0, 0.0) 
  complex w = (0.0, 0.0) 
  complex cz = #pixel
  complex cw = @cjk
  complex a = (0.0, 0.0)
  complex b = (0.0, 0.0)
  complex c = (0.0, 0.0)
  complex d = (0.0, 0.0)
  complex ca = (0.0, 0.0)
  complex cb = (0.0, 0.0)
  float nx = 0.0
  float ny = 0.0
  float z1 = 0.0
  float zi = 0.0
  float zj = 0.0
  float zk = 0.0
  float c1 = 0.0
  float ci = 0.0
  float cj = 0.0
  float ck = 0.0
  float rx = 0.0
  float ry = 0.0
  float rz = 0.0
  
 if (@version < 1.14)
  z = z + (1/(@power+1))^(1/@power)
 else
  nx = real((1/(@power+1))^(1/@power))
  ny = imag((1/(@power+1))^(1/@power))
 endif
  
; (yz plane rotation)   
    ry = imag(z)*cos(#pi*@rotx/180) - real(w)*sin(#pi*@rotx/180)
    rz = imag(z)*sin(#pi*@rotx/180) + real(w)*cos(#pi*@rotx/180)
    z = real(z) + ry*1i
    w = rz + imag(w)*1i
    
    ry = imag(cz)*cos(#pi*@rotx/180) - real(cw)*sin(#pi*@rotx/180)
    rz = imag(cz)*sin(#pi*@rotx/180) + real(cw)*cos(#pi*@rotx/180)
    cz = real(cz) + ry*1i
    cw = rz + imag(cw)*1i
    
; (xz plane rotation)   
    rx = real(w)*sin(#pi*@roty/180) + real(z)*cos(#pi*@roty/180)
    rz = real(w)*cos(#pi*@roty/180) - real(z)*sin(#pi*@roty/180)
    z = rx + imag(z)*1i
    w = rz + imag(w)*1i

    rx = real(cw)*sin(#pi*@roty/180) + real(cz)*cos(#pi*@roty/180)
    rz = real(cw)*cos(#pi*@roty/180) - real(cz)*sin(#pi*@roty/180)
    cz = rx + imag(cz)*1i
    cw = rz + imag(cw)*1i
    
; (xy plane rotation)   
    rx = real(z)*cos(#pi*@rotz/180) - imag(z)*sin(#pi*@rotz/180)
    ry = real(z)*sin(#pi*@rotz/180) + imag(z)*cos(#pi*@rotz/180)
    z = rx + ry*1i
    
    rx = real(cz)*cos(#pi*@rotz/180) - imag(cz)*sin(#pi*@rotz/180)
    ry = real(cz)*sin(#pi*@rotz/180) + imag(cz)*cos(#pi*@rotz/180)
    cz = rx + ry*1i
    
    
   if @fourthdim == 3
     z1 = real(z) + nx
     zi = imag(z) + ny
     zj = real(w)
     zk = imag(w)
     c1 = real(cz)
     ci = imag(cz)
     cj = real(cw)
     ck = imag(cw)
    elseif @fourthdim == 2
     z1 = real(z) + nx
     zi = imag(z) + ny
     zj = imag(w)
     zk = real(w)
     c1 = real(cz)
     ci = imag(cz)
     cj = imag(cw)
     ck = real(cw)
    elseif @fourthdim == 1
     z1 = real(w) + nx
     zi = imag(w) + ny
     zj = real(z)
     zk = imag(z)
     c1 = real(cw)
     ci = imag(cw)
     cj = real(cz)
     ck = imag(cz)
    else
     z1 = imag(w) + nx
     zi = real(w) + ny
     zj = real(z)
     zk = imag(z)
     c1 = imag(cw)
     ci = real(cw)
     cj = real(cz)
     ck = imag(cz)
    endif
    
  ca = c1 - ck + flip(ci + cj)
  cb = c1 + ck + flip(ci - cj)
     
loop:
  a = z1 - zk + flip(zi + zj)
  b = z1 + zk + flip(zi - zj)
  c = ca * a * (1 - a ^ @power)
  d = cb * b * (1 - b ^ @power)
  z1 = (real(c) + real(d)) / 2 
  zi = (imag(c) + imag(d)) / 2
  zj = (imag(c) - imag(d)) / 2 
  zk = (real(d) - real(c)) / 2
  z = z1 + flip(zi)
  w = zj + flip(zk)
bailout:
  |z| + |w| <= @bailout
default:
  title = "Hypercomplex Lambda (Mandelbrot)"
  maxiter = 500
  periodicity = 0
  method = multipass
 float param version
   default = 1.14
   visible = false
 endparam
 param fourthdim
   caption = "Fourth dimension"
   enum = "z1" "zi" "zj" "zk"
   default = 3
 endparam
 param cjk
   caption = "(cj, ck)"
   default = (0.0, 0.0)
 endparam
 param rotx
    caption="x-rotation"
    hint="Rotates yz-plane."
    default=0.0
    min=-360.0
    max=360.0
  endparam
  param roty
    caption="y-rotation"
    hint="Rotates zx-plane."
    default=0.0
    min=-360.0
    max=360.0
  endparam
  param rotz
    caption="z-rotation"
    hint="Rotates xy-plane."
    default=0.0
    min=-360.0
    max=360.0
  endparam
 param power
   caption = "Exponent"
   default = (1.0, 0.0)
 endparam
 param bailout
  caption = "Bailout value"
  default = 64.0
  min = 1
 endparam
switch:
 type = "gnd-hyperlambdapwr"
 version = @version
 fourthdim = @fourthdim
 c1i = #pixel
 cjk = @cjk
 rotx = @rotx
 roty = @roty
 rotz = @rotz
 power = @power
 bailout = @bailout
}

gnd-hyperlambdapwr {
; Gilles Nadeau, July, 2005
; Based on the formula Lambda Power from Ron Barnett
;
init:
  z = #pixel
  w = @zjk
  cz = @c1i
  cw = @cjk
  complex a = (0.0, 0.0)
  complex b = (0.0, 0.0)
  complex c = (0.0, 0.0)
  complex d = (0.0, 0.0)
  complex ca = (0.0, 0.0)
  complex cb = (0.0, 0.0)
  float z1 = 0.0
  float zi = 0.0
  float zj = 0.0
  float zk = 0.0
  float c1 = 0.0
  float ci = 0.0
  float cj = 0.0
  float ck = 0.0
  float rx = 0.0
  float ry = 0.0
  float rz = 0.0

; (yz plane rotation)   
    ry = imag(z)*cos(#pi*@rotx/180) - real(w)*sin(#pi*@rotx/180)
    rz = imag(z)*sin(#pi*@rotx/180) + real(w)*cos(#pi*@rotx/180)
    z = real(z) + ry*1i
    w = rz + imag(w)*1i
    
    ry = imag(cz)*cos(#pi*@rotx/180) - real(cw)*sin(#pi*@rotx/180)
    rz = imag(cz)*sin(#pi*@rotx/180) + real(cw)*cos(#pi*@rotx/180)
    cz = real(cz) + ry*1i
    cw = rz + imag(cw)*1i
    
; (xz plane rotation)   
    rx = real(w)*sin(#pi*@roty/180) + real(z)*cos(#pi*@roty/180)
    rz = real(w)*cos(#pi*@roty/180) - real(z)*sin(#pi*@roty/180)
    z = rx + imag(z)*1i
    w = rz + imag(w)*1i

    rx = real(cw)*sin(#pi*@roty/180) + real(cz)*cos(#pi*@roty/180)
    rz = real(cw)*cos(#pi*@roty/180) - real(cz)*sin(#pi*@roty/180)
    cz = rx + imag(cz)*1i
    cw = rz + imag(cw)*1i
    
; (xy plane rotation)   
    rx = real(z)*cos(#pi*@rotz/180) - imag(z)*sin(#pi*@rotz/180)
    ry = real(z)*sin(#pi*@rotz/180) + imag(z)*cos(#pi*@rotz/180)
    z = rx + ry*1i
    
    rx = real(cz)*cos(#pi*@rotz/180) - imag(cz)*sin(#pi*@rotz/180)
    ry = real(cz)*sin(#pi*@rotz/180) + imag(cz)*cos(#pi*@rotz/180)
    cz = rx + ry*1i
    
   if @fourthdim == 3
     z1 = real(z)
     zi = imag(z)
     zj = real(w)
     zk = imag(w)
     c1 = real(cz)
     ci = imag(cz)
     cj = real(cw)
     ck = imag(cw)
    elseif @fourthdim == 2
     z1 = real(z)
     zi = imag(z)
     zj = imag(w)
     zk = real(w)
     c1 = real(cz)
     ci = imag(cz)
     cj = imag(cw)
     ck = real(cw)
    elseif @fourthdim == 1
     z1 = real(w)
     zi = imag(w)
     zj = real(z)
     zk = imag(z)
     c1 = real(cw)
     ci = imag(cw)
     cj = real(cz)
     ck = imag(cz)
    else
     z1 = imag(w)
     zi = real(w)
     zj = real(z)
     zk = imag(z)
     c1 = imag(cw)
     ci = real(cw)
     cj = real(cz)
     ck = imag(cz)
    endif
    
  ca = c1 - ck + flip(ci + cj)
  cb = c1 + ck + flip(ci - cj)
    
loop:
  a = z1 - zk + flip(zi + zj)
  b = z1 + zk + flip(zi - zj)
  c = ca * a * (1 - a ^ @power)
  d = cb * b * (1 - b ^ @power)
  z1 = (real(c) + real(d)) / 2 
  zi = (imag(c) + imag(d)) / 2
  zj = (imag(c) - imag(d)) / 2 
  zk = (real(d) - real(c)) / 2
  z = z1 + flip(zi)
  w = zj + flip(zk)  
bailout:
  |z| + |w| <= @bailout
default:
  title = "Hypercomplex Lambda (Julia)"
  maxiter = 500
  periodicity = 0
  method = multipass
 float param version
   default = 1.14
   visible = false
 endparam
 param fourthdim
   caption = "Fourth dimension"
   enum = "z1" "zi" "zj" "zk"
   default = 3
 endparam
 param c1i
   caption = "(c1, ci)"
   default = (-0.135, -0.92)
 endparam
 param cjk
   caption = "(cj, ck)"
   default = (0.113, 0.05)
 endparam
 param zjk
   caption = "(zj, zk)"
   default = (0.0, 0.0)
 endparam
 param rotx
    caption="x-rotation"
    hint="Rotates yz-plane."
    default=0.0
    min=-360.0
    max=360.0
  endparam
  param roty
    caption="y-rotation"
    hint="Rotates zx-plane."
    default=0.0
    min=-360.0
    max=360.0
  endparam
  param rotz
    caption="z-rotation"
    hint="Rotates xy-plane."
    default=0.0
    min=-360.0
    max=360.0
  endparam
 param power
   caption = "Exponent"
   default = (1.0, 0.0)
 endparam
 param bailout
  caption = "Bailout value"
  default = 64.0
  min = 1
 endparam
switch:
 type = "gnd-hypermandellambdapwr"
 version = @version
 fourthdim = @fourthdim
 cjk = @cjk
 rotx = @rotx
 roty = @roty
 rotz = @rotz
 power = @power
 bailout = @bailout
}

gnd-hypermanlam[fn||fn] {
; Gilles Nadeau, April, 2005
;
init:
  complex z = (0.0, 0.0) + #pixel
  complex w = (0.0, 0.0) + @cjk
  complex cz = #pixel
  complex cw = @cjk
  complex a = (0.0, 0.0)
  complex b = (0.0, 0.0)
  complex c = (0.0, 0.0)
  complex d = (0.0, 0.0)
  complex ca = (0.0, 0.0)
  complex cb = (0.0, 0.0)
  float z1 = 0.0
  float zi = 0.0
  float zj = 0.0
  float zk = 0.0
  float c1 = 0.0
  float ci = 0.0
  float cj = 0.0
  float ck = 0.0
  float rx = 0.0
  float ry = 0.0
  float rz = 0.0

; (yz plane rotation)   
    ry = imag(z)*cos(#pi*@rotx/180) - real(w)*sin(#pi*@rotx/180)
    rz = imag(z)*sin(#pi*@rotx/180) + real(w)*cos(#pi*@rotx/180)
    z = real(z) + ry*1i
    w = rz + imag(w)*1i
    
    ry = imag(cz)*cos(#pi*@rotx/180) - real(cw)*sin(#pi*@rotx/180)
    rz = imag(cz)*sin(#pi*@rotx/180) + real(cw)*cos(#pi*@rotx/180)
    cz = real(cz) + ry*1i
    cw = rz + imag(cw)*1i
    
; (xz plane rotation)   
    rx = real(w)*sin(#pi*@roty/180) + real(z)*cos(#pi*@roty/180)
    rz = real(w)*cos(#pi*@roty/180) - real(z)*sin(#pi*@roty/180)
    z = rx + imag(z)*1i
    w = rz + imag(w)*1i

    rx = real(cw)*sin(#pi*@roty/180) + real(cz)*cos(#pi*@roty/180)
    rz = real(cw)*cos(#pi*@roty/180) - real(cz)*sin(#pi*@roty/180)
    cz = rx + imag(cz)*1i
    cw = rz + imag(cw)*1i
    
; (xy plane rotation)   
    rx = real(z)*cos(#pi*@rotz/180) - imag(z)*sin(#pi*@rotz/180)
    ry = real(z)*sin(#pi*@rotz/180) + imag(z)*cos(#pi*@rotz/180)
    z = rx + ry*1i
    
    rx = real(cz)*cos(#pi*@rotz/180) - imag(cz)*sin(#pi*@rotz/180)
    ry = real(cz)*sin(#pi*@rotz/180) + imag(cz)*cos(#pi*@rotz/180)
    cz = rx + ry*1i
    
   if @fourthdim == 3
     z1 = real(z)
     zi = imag(z)
     zj = real(w)
     zk = imag(w)
     c1 = real(cz)
     ci = imag(cz)
     cj = real(cw)
     ck = imag(cw)
    elseif @fourthdim == 2
     z1 = real(z)
     zi = imag(z)
     zj = imag(w)
     zk = real(w)
     c1 = real(cz)
     ci = imag(cz)
     cj = imag(cw)
     ck = real(cw)
    elseif @fourthdim == 1
     z1 = real(w)
     zi = imag(w)
     zj = real(z)
     zk = imag(z)
     c1 = real(cw)
     ci = imag(cw)
     cj = real(cz)
     ck = imag(cz)
    else
     z1 = imag(w)
     zi = real(w)
     zj = real(z)
     zk = imag(z)
     c1 = imag(cw)
     ci = real(cw)
     cj = real(cz)
     ck = imag(cz)
    endif
    
  ca = c1 - ck + flip(ci + cj)
  cb = c1 + ck + flip(ci - cj) 

loop:
  a = z1 - zk + flip(zi + zj)
  b = z1 + zk + flip(zi - zj)
 if |a| < @shift
  c = ca * @fn1(a)
 else
  c = ca * @fn2(a)
 endif
 if |b| < @shift
  d = cb * @fn1(b)
 else
  d = cb * @fn2(b)
 endif  
  z1 = (real(c) + real(d)) / 2 
  zi = (imag(c) + imag(d)) / 2
  zj = (imag(c) - imag(d)) / 2 
  zk = (real(d) - real(c)) / 2
  z = z1 + flip(zi)
  w = zj + flip(zk)
bailout:
  |z| + |w| <= @bailout
default:
  title = "Mandel Lambda (fn || fn) (hypercomplex)"
  maxiter = 149
  periodicity = 0
  method = multipass
 float param version
   default = 1.1
   visible = false
 endparam
 param fourthdim
   caption = "Fourth dimension"
   enum = "z1" "zi" "zj" "zk"
   default = 3
 endparam
 param cjk
   caption = "(cj, ck)"
   default = (0.0, 0.0)
 endparam
 param rotx
   caption="x-rotation"
   hint="Rotates yz-plane."
   default=0.0
   min=-360.0
   max=360.0
 endparam
 param roty
   caption="y-rotation"
   hint="Rotates zx-plane."
   default=0.0
   min=-360.0
   max=360.0
 endparam
 param rotz
   caption="z-rotation"
   hint="Rotates xy-plane."
   default=0.0
   min=-360.0
   max=360.0
 endparam
 param bailout
   caption = "Bailout value"
   default = 64.0
   min = 1
 endparam
 param shift
   caption = "Function Shift"
   default = 10.0
   min = 0
 endparam
 func fn1
   caption = "First Function"
   default = sin()
 endfunc
 func fn2
   caption = "Second Function"
   default = sqr()
 endfunc
switch:
 type = "gnd-hyperlambda[fn||fn]"
 version = @version
 fourthdim = @fourthdim
 c1i = #pixel
 cjk = @cjk
 shift = @shift
 rotx = @rotx
 roty = @roty
 rotz = @rotz
 bailout = @bailout
 fn1 = @fn1
 fn2 = @fn2
}


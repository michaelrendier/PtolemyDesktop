; version 1.0, May 2005
; Gilles Nadeau, 18/05/2005
;
init:
  a = (0.0, 0.0)
  b = (0.0, 0.0)
  c = @ct
  ca = (0.0, 0.0)
  cb = (0.0, 0.0)
  cc = @c1
  
 if (@var == 0)
  a = real(#pixel)
  b = imag(#pixel)
  ca = real(@c0)
  cb = imag(@c0)

 elseif (@var == 1)
  a = flip(real(#pixel))
  b = flip(imag(#pixel))
  ca = flip(real(@c0))
  cb = flip(imag(@c0)) 
  
 elseif (@var == 2)

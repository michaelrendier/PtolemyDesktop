  a = cr + na - a - ca
  b = ci + nb - b - cb
  c = ct + nc - c - cc
  
 if (@flavor == 0) 
  z = a + flip(b)
 elseif (@flavor == 1)
  z = a + b 
 endif

bailout:
  |a| + |b| + |c| <= @bailout
default:

default:
  title = "Lambda (fn || fn) (hypercomplex)"
  maxiter = 149
  periodicity = 0
  method = multipass
 float param version
   default = 1.1
   visible = false
 endparam
 param fourthdim
   caption = "Fourth dimension"
   enum = "z1" "zi" "zj" "zk"
   default = 3
 endparam
 param c1i
   caption = "(c1, ci)"
   default = (1.0, 0.1)
 endparam
 param cjk
   caption = "(cj, ck)"
   default = (0.0, 0.0)
 endparam
 param zjk
   caption = "(zj, zk)"
   default = (0.0, 0.0)
 endparam
 param rotx
   caption="x-rotation"
   hint="Rotates yz-plane."
   default=0.0
   min=-360.0
   max=360.0
 endparam
 param roty
   caption="y-rotation"
   hint="Rotates zx-plane."
   default=0.0
   min=-360.0
   max=360.0
 endparam
 param rotz
   caption="z-rotation"
   hint="Rotates xy-plane."
   default=0.0
   min=-360.0
   max=360.0
 endparam
 param bailout
   caption = "Bailout value"
   default = 64.0
   min = 1
 endparam
 param shift
   caption = "Function Shift"
   default = 1.0
   min = 0
 endparam
 func fn1
   caption = "First Function"
   default = sin()
 endfunc
 func fn2
   caption = "Second Function"
   default = sqr()
 endfunc
switch:
 type = "gnd-hypermanlam[fn||fn]"
 version = @version
 fourthdim = @fourthdim
 cjk = @cjk
 shift = @shift
 rotx = @rotx
 roty = @roty
 rotz = @rotz
 bailout = @bailout
 fn1 = @fn1
 fn2 = @fn2
}

gnd-Julibrot_J {
; Gilles Nadeau, July, 2005
init:
  complex z = #pixel
  complex c = @p1
  float rx = 0.0
  float ry = 0.0
  float rz = 0.0
  float rw = 0.0
   
   ry=imag(z)*cos(#pi*@rotx/180)-real(c)*sin(#pi*@rotx/180)
   rz=imag(z)*sin(#pi*@rotx/180)+real(c)*cos(#pi*@rotx/180)
   z=real(z)+ry*1i
   c=rz+imag(c)*1i
 
     
   rx=real(c)*sin(#pi*@roty/180)+real(z)*cos(#pi*@roty/180)
   rz=real(c)*cos(#pi*@roty/180)-real(z)*sin(#pi*@roty/180)
   z=rx+imag(z)*1i
   c=rz+imag(c)*1i
   
   
   ry=real(z)*cos(#pi*@rotz/180)-imag(c)*sin(#pi*@rotz/180)
   rw=real(z)*sin(#pi*@rotz/180)+imag(c)*cos(#pi*@rotz/180)
   z=ry+imag(z)*1i
   c=real(c)+rw*1i
   
   
   rx=imag(c)*sin(#pi*@rotw/180)+imag(z)*cos(#pi*@rotw/180)
   rw=imag(c)*cos(#pi*@rotw/180)-imag(z)*sin(#pi*@rotw/180)
   z=real(z)+rx*1i
   c=real(c)+rw*1i
   
loop:
  z = @fn1(z)^@power + c
bailout:
  |z| < @bailout
default:
  title = "Julibrot J"
  maxiter = 149
  periodicity = 0
  method = multipass
 float param version
   default = 1.0
   visible = false
 endparam
 
 param p1
   caption = "Julibrot Parameter"
   default = (0.0, 0.0)
 endparam
 
 param rotx
   caption="x-rotation"
   hint="Rotates yz-plane."
   default=0.0
   min=-360.0
   max=360.0
 endparam
 param roty
   caption="y-rotation"
   hint="Rotates zx-plane."
   default=0.0
   min=-360.0
   max=360.0
 endparam
 param rotz
   caption="z-rotation"
   hint="Rotates yw-plane."
   default=0.0
   min=-360.0
   max=360.0
 endparam
 param rotw
   caption="w-rotation"
   hint="Rotates xw-plane."
   default=0.0
   min=-360.0
   max=360.0
 endparam
 param power
   caption = "Exponent"
   default = (3.0, 0.0)
 endparam
 param bailout
   caption = "Bailout value"
   default = 128.0
   min = 1
 endparam
 func fn1
   caption = "First Function"
   default = ident()
 endfunc
switch:
  type = "gnd-Julibrot_M"
  version = @version
  p1 = #pixel
  power = @power
  rotx = @rotx
  roty = @roty
  rotz = @rotz
  rotw = @rotw
  fn1 = @fn1
  bailout = @bailout
}

gnd-Julibrot_M {
; Gilles Nadeau, July, 2005
init:
  complex z = @p1 
  complex c = #pixel
  float rx = 0.0
  float ry = 0.0
  float rz = 0.0
  float rw = 0.0
   
   ry=imag(z)*cos(#pi*@rotx/180)-real(c)*sin(#pi*@rotx/180)
   rz=imag(z)*sin(#pi*@rotx/180)+real(c)*cos(#pi*@rotx/180)
   z=real(z)+ry*1i
   c=rz+imag(c)*1i
 
     
   rx=real(c)*sin(#pi*@roty/180)+real(z)*cos(#pi*@roty/180)
   rz=real(c)*cos(#pi*@roty/180)-real(z)*sin(#pi*@roty/180)
   z=rx+imag(z)*1i
   c=rz+imag(c)*1i
   
   
   ry=real(z)*cos(#pi*@rotz/180)-imag(c)*sin(#pi*@rotz/180)
   rw=real(z)*sin(#pi*@rotz/180)+imag(c)*cos(#pi*@rotz/180)
   z=ry+imag(z)*1i
   c=real(c)+rw*1i
   
   
   rx=imag(c)*sin(#pi*@rotw/180)+imag(z)*cos(#pi*@rotw/180)
   rw=imag(c)*cos(#pi*@rotw/180)-imag(z)*sin(#pi*@rotw/180)
   z=real(z)+rx*1i
   c=real(c)+rw*1i
   
loop:
  z = @fn1(z)^@power + c
bailout:
  |z| < @bailout
default:
  title = "Julibrot M"
  maxiter = 149
  periodicity = 0
  method = multipass
 float param version
   default = 1.0
   visible = false
 endparam
 
 param p1
   caption = "Julibrot Parameter"
   default = (0.0, 0.0)
 endparam
 
 param rotx
   caption="x-rotation"
   hint="Rotates yz-plane."
   default=0.0
   min=-360.0
   max=360.0
 endparam
 param roty
   caption="y-rotation"
   hint="Rotates zx-plane."
   default=0.0
   min=-360.0
   max=360.0
 endparam
 param rotz
   caption="z-rotation"
   hint="Rotates yw-plane."
   default=0.0
   min=-360.0
   max=360.0
 endparam
 param rotw
   caption="w-rotation"
   hint="Rotates xw-plane."
   default=0.0
   min=-360.0
   max=360.0
 endparam
 param power
   caption = "Exponent"
   default = (3.0, 0.0)
 endparam
 param bailout
   caption = "Bailout value"
   default = 128.0
   min = 1
 endparam
 func fn1
   caption = "First Function"
   default = ident()
 endfunc
switch:
  type = "gnd-Julibrot_J"
  version = @version
  p1 = #pixel
  power = @power
  rotx = @rotx
  roty = @roty
  rotz = @rotz
  rotw = @rotw
  fn1 = @fn1
  bailout = @bailout
}

gnd-3D-Julia-sets {
; Based on the models of formulas 3D by Gerald K. Dobiasovsky.
; Use the fractint ucl outside = summ
; Gilles Nadeau, July, 2007
;
init:
  complex zz = #pixel
  complex zh = @zh
  complex c0 = @c0
  complex d0 = @d0
  complex c1 = @c1
  complex d1 = @d1
  complex c2 = @c2
  complex d2 = @d2
  complex c3 = @c3
  complex d3 = @d3
  complex c4 = @c4
  complex d4 = @d4
  complex c5 = @c5
  complex d5 = @d5
  complex c6 = @c6
  complex d6 = @d6
  complex c7 = @c7
  complex d7 = @d7
  complex c8 = @c8
  complex d8 = @d8
  complex c9 = @c9
  complex d9 = @d9
  complex c10 = @c10
  complex d10 = @d10
  complex a = (0,0)
  complex b = (0,0)
  complex ca = (0,0)
  complex cb = (0,0)
  float x = real(zz)
  float y = imag(zz)
  float v = @v2
  float x0 = x
  float y0 = y
  float v0 = v
  float cx = 0.0
  float cy = 0.0
  float cv = 0.0
  float xx = x
  float zr = 0.0
  float zi = 0.0
  float zj = 0.0
  float zk = 0.0
  float cr = 0.0
  float ci = 0.0
  float cj = 0.0
  float ck = 0.0
  float ra = 0.0
  float ib = 0.0
  float jc = 0.0
  float kd = 0.0
  float na = 0.0
  float nb = 0.0
  float nc = 0.0
  float nd = 0.0
  float dr = 0.0
  float di = 0.0
  float dj = 0.0
  float dk = 0.0
  float dx = 0.0
  float dy = 0.0
  float dv = 0.0
  float n = 0.0
  float q = 0.0
  float rotx = @rotx
  float roty = @roty
  float rotz = @rotz
  float rotw = @rotw
  float rx = 0.0
  float ry = 0.0
  float rz = 0.0
  float rw = 0.0
  float zmod = 0.0
  float stepnum = @stepnum
  float maxiter = @maxiter
  complex delta = (@zh2 - zh) / stepnum
  float delta2 = (@v1 - v) / stepnum
  complex zz0 = zz
  complex zh0 = zh
  complex dzz = (0,0)
  complex dzh = delta
  float dxx = 0.0
  float dyy = 0.0
  float dvv = delta2
  int j = 0
  int m = 0
  int i = 0
 if @formula==0
  delta = (d0 - c0) / stepnum
 elseif @formula==1
  delta = (d1 - c1) / stepnum
 elseif @formula==2
  delta = (d2 - c2) / stepnum
 elseif @formula==3
  delta = (d3 - c3) / stepnum
 elseif @formula==4
  delta = (d4 - c4) / stepnum
 elseif @formula==5
  delta = (d5 - c5) / stepnum
 elseif @formula==6
  delta = (d6 - c6) / stepnum
 elseif @formula==7
  delta = (d7 - c7) / stepnum
 elseif @formula==8
  delta = (d8 - c8) / stepnum
 elseif @formula==9
  delta = (d9 - c9) / stepnum
 elseif @formula==10
  delta = (d10 - c10) / stepnum
 elseif @formula==11
  cr = real(@cri0)
  ci = imag(@cri0)
  cj = real(@cjk0)
  ck = imag(@cjk0)
 elseif @formula==12
  cr = real(@cri1)
  ci = imag(@cri1)
  cj = real(@cjk1)
  ck = imag(@cjk1)
 elseif @formula==13
  cr = real(@cri2)
  ci = imag(@cri2)
  cj = real(@cjk2)
  ck = imag(@cjk2)
 elseif @formula==14
  cr = real(@cri3)
  ci = imag(@cri3)
  cj = real(@cjk3)
  ck = imag(@cjk3)
  ca = cr - ck + flip(ci + cj)
  cb = cr + ck + flip(ci - cj)
 elseif @formula==15
  cr = real(@cri4)
  ci = imag(@cri4)
  cj = real(@cjk4)
  ck = imag(@cjk4)
  ca = cr - ck + flip(ci + cj)
  cb = cr + ck + flip(ci - cj)
 elseif @formula==16
  cr = real(@cri5)
  ci = imag(@cri5)
  cj = real(@cjk5)
  ck = imag(@cjk5)
  ca = cr - ck + flip(ci + cj)
  cb = cr + ck + flip(ci - cj)
 elseif @formula==17
  cr = real(@cri6)
  ci = imag(@cri6)
  cj = real(@cjk6)
  ck = imag(@cjk6)
  ca = cr - ck + flip(ci + cj)
  cb = cr + ck + flip(ci - cj)
 elseif @formula==18
  cr = real(@cri7)
  ci = imag(@cri7)
  cj = real(@cjk7)
  ck = imag(@cjk7)
  ca = cr - ck + flip(ci + cj)
  cb = cr + ck + flip(ci - cj)
 elseif @formula==19
  cr = real(@cri8)
  ci = imag(@cri8)
  cj = real(@cjk8)
  ck = imag(@cjk8)
 elseif @formula==20
  cr = real(@cri9)
  ci = imag(@cri9)
  cj = real(@cjk9)
  ck = imag(@cjk9)
 elseif @formula==21
  cr = real(@cri10)
  ci = imag(@cri10)
  cj = real(@cjk10)
  ck = imag(@cjk10)
 elseif @formula==22
  cr = real(@cri11)
  ci = imag(@cri11)
  cj = real(@cjk11)
  ck = imag(@cjk11)
 elseif @formula==23
  cr = real(@cri12)
  ci = imag(@cri12)
  cj = real(@cjk12)
  ck = imag(@cjk12)
  ca = cr - ck + flip(ci + cj)
  cb = cr + ck + flip(ci - cj)
 elseif @formula==24
  cr = real(@cri13)
  ci = imag(@cri13)
  cj = real(@cjk13)
  ck = imag(@cjk13)
  ca = cr - ck + flip(ci + cj)
  cb = cr + ck + flip(ci - cj)
 elseif @formula==25
  cr = real(@cri14)
  ci = imag(@cri14)
  cj = real(@cjk14)
  ck = imag(@cjk14)
  ca = cr - ck + flip(ci + cj)
  cb = cr + ck + flip(ci - cj)
 elseif @formula==26
  cx = real(@cz0)
  cy = imag(@cz0)
  cv = @cv0
 elseif @formula==27
  cx = real(@cz1)
  cy = imag(@cz1)
  cv = @cv1
 elseif @formula==28
  cx = real(@cz2)
  cy = imag(@cz2)
  cv = @cv2
 elseif @formula==29
  cx = real(@cz3)
  cy = imag(@cz3)
  cv = @cv3
 elseif @formula==30
  cx = real(@cz4)
  cy = imag(@cz4)
  cv = @cv4
 endif

  ry = imag(zz0)*cos(pi*rotx/180) - real(zh0)*sin(pi*rotx/180)
  rz = imag(zz0)*sin(pi*rotx/180) + real(zh0)*cos(pi*rotx/180)
  zz0 = real(zz0) + flip(ry)
  zh0 = rz + flip(imag(zh0))

  ry = imag(dzz)*cos(pi*rotx/180) - real(dzh)*sin(pi*rotx/180)
  rz = imag(dzz)*sin(pi*rotx/180) + real(dzh)*cos(pi*rotx/180)
  dzz = real(dzz) + flip(ry)
  dzh = rz + flip(imag(dzh))


  rx = real(zh0)*sin(pi*roty/180) + real(zz0)*cos(pi*roty/180)
  rz = real(zh0)*cos(pi*roty/180) - real(zz0)*sin(pi*roty/180)
  zz0 = rx + flip(imag(zz0))
  zh0 = rz + flip(imag(zh0))

  rx = real(dzh)*sin(pi*roty/180) + real(dzz)*cos(pi*roty/180)
  rz = real(dzh)*cos(pi*roty/180) - real(dzz)*sin(pi*roty/180)
  dzz = rx + flip(imag(dzz))
  dzh = rz + flip(imag(dzh))


  ry = real(zz0)*cos(pi*rotz/180) - imag(zh0)*sin(pi*rotz/180)
  rw = real(zz0)*sin(pi*rotz/180) + imag(zh0)*cos(pi*rotz/180)
  zz0 = ry + flip(imag(zz0))
  zh0 = real(zh0) + flip(rw)

  ry = real(dzz)*cos(pi*rotz/180) - imag(dzh)*sin(pi*rotz/180)
  rw = real(dzz)*sin(pi*rotz/180) + imag(dzh)*cos(pi*rotz/180)
  dzz = ry + flip(imag(dzz))
  dzh = real(dzh) + flip(rw)


  rx = imag(zh0)*sin(pi*rotw/180) + imag(zz0)*cos(pi*rotw/180)
  rw = imag(zh0)*cos(pi*rotw/180) - imag(zz0)*sin(pi*rotw/180)
  zz0 = real(zz0) + flip(rx)
  zh0 = real(zh0) + flip(rw)

  rx = imag(dzh)*sin(pi*rotw/180) + imag(dzz)*cos(pi*rotw/180)
  rw = imag(dzh)*cos(pi*rotw/180) - imag(dzz)*sin(pi*rotw/180)
  dzz = real(dzz) + flip(rx)
  dzh = real(dzh) + flip(rw)

  zz = zz0
  zh = zh0
  zr = real(zz)
  zi = imag(zz)
  zj = real(zh)
  zk = imag(zh)
  a = zr - zk + flip(zi + zj)
  b = zr + zk + flip(zi - zj)
  x = x0
  y = y0
  v = v0

loop:

 if @formula==0
   zz = zz^@power0 + c0
 elseif @formula==1
   zz = c1*zz*(1 - zz^@power1)
 elseif @formula==2
   zz = zz*zz*zz + zz*c2 - zz - c2
 elseif @formula==3
  if real(zz) >= 0
   zz = (zz - 1)*c3
  else
   zz = (zz + 1)*c3
  endif
 elseif @formula==4
  if real(zz)*imag(c4) + imag(zz)*real(c4) >= 0
   zz = (zz - 1)*c4
  else
   zz = (zz + 1)*c4
  endif
 elseif @formula==5
  if real(zz) >= 0
   zz = sqr(zz) - 1
  else
   zz = sqr(zz) - 1 + real(zz)*c5
  endif
 elseif @formula==6
   zz = @f0(zz) + c6
 elseif @formula==7
   zz = c7*@f1(zz)
 elseif @formula==8
  if (|zz| < @shift)
   zz = c8*@f2(zz)
  else
   zz = c8*@f3(zz)
  endif
 elseif @formula==9
  if (1 < |zz|)
   zz = @f4(zz) + c9
  endif
   zz = @f5(zz) + c9
 elseif @formula==10
   x = real(zz)
   y = imag(zz)
   xx = x
   x = x - @h * real(@pf1(y + @pf2(c10*y)))
   y = y - @h * real(@pf3(xx + @pf4(c10*xx)))
   zz = x + flip(y)
 elseif @formula==11
   ra = zr^2 - zi^2 - zj^2 - zk^2
   ib = 2*zr*zi
   jc = 2*zr*zj
   kd = 2*zr*zk
   zr = ra + cr
   zi = ib + ci
   zj = jc + cj
   zk = kd + ck
   zz = zr + flip(zi)
   zh = zj + flip(zk)
 elseif @formula==12
   n = zi^2 + zj^2 + zk^2
   q = 3*zr^2 - n
   ra = zr^3 - 3*zr*n
   ib = zi*q
   jc = zj*q
   kd = zk*q
   zr = ra + cr
   zi = ib + ci
   zj = jc + cj
   zk = kd + ck
   zz = zr + flip(zi)
   zh = zj + flip(zk)
 elseif @formula==13
   n = zi^2 + zj^2 + zk^2
   q = zr^2 - n
   ra = q^2 - 4*zr^2*n
   ib = 4*zr*zi*q
   jc = 4*zr*zj*q
   kd = 4*zr*zk*q
   zr = ra + cr
   zi = ib + ci
   zj = jc + cj
   zk = kd + ck
   zz = zr + flip(zi)
   zh = zj + flip(zk)
 elseif @formula==14
   a = a^@power2 + ca
   b = b^@power2 + cb
   zz = (a + b) / 2
 elseif @formula==15
   a = @f6(a) + ca
   b = @f6(b) + cb
   zz = (a + b) / 2
 elseif @formula==16
  if real(a) >= 0
   a = (a - 1)*ca
  else
   a = (a + 1)*ca
  endif
  if real(b) >= 0
   b = (b - 1)*cb
  else
   b = (b + 1)*cb
  endif
   zz = (a + b) / 2
 elseif @formula==17
  if real(a)*imag(ca) + real(ca)*imag(a) >= 0
   a = (a - 1)*ca
  else
   a = (a + 1)*ca
  endif
  if real(b)*imag(cb) + real(cb)*imag(b) >= 0
   b = (b - 1)*cb
  else
   b = (b + 1)*cb
  endif
   zz = (a + b) / 2
 elseif @formula==18
  if real(a) >= 0
   a = sqr(a) - 1
  else
   a = sqr(a) - 1 + ca*real(a)
  endif
  if real(b) >= 0
   b = sqr(b) - 1
  else
   b = sqr(b) - 1 + cb*real(b)
  endif
   zz = (a + b) / 2
 elseif @formula==19
   na = zr^2 - zi^2 - zj^2 - zk^2
   nb = 2*zr*zi
   nc = 2*zr*zj
   nd = 2*zr*zk
   ra = zr - na
   ib = zi - nb
   jc = zj - nc
   kd = zk - nd
   zr = cr*ra - ci*ib - cj*jc - ck*kd
   zi = ci*ra + cr*ib + ck*jc - cj*kd
   zj = cj*ra - ck*ib + cr*jc + ci*kd
   zk = ck*ra + cj*ib - ci*jc + cr*kd
   zz = zr + flip(zi)
   zh = zj + flip(zk)
 elseif @formula==20
   n = zi^2 + zj^2 + zk^2
   q = 3*zr^2 - n
   na = zr^3 - 3*zr*n
   nb = zi*q
   nc = zj*q
   nd = zk*q
   ra = zr - na
   ib = zi - nb
   jc = zj - nc
   kd = zk - nd
   zr = cr*ra - ci*ib - cj*jc - ck*kd
   zi = ci*ra + cr*ib + ck*jc - cj*kd
   zj = cj*ra - ck*ib + cr*jc + ci*kd
   zk = ck*ra + cj*ib - ci*jc + cr*kd
   zz = zr + flip(zi)
   zh = zj + flip(zk)
 elseif @formula==21
   n = zi^2 + zj^2 + zk^2
   q = zr^2 - n
   na = q^2 - 4*zr^2*n
   nb = 4*zr*zi*q
   nc = 4*zr*zj*q
   nd = 4*zr*zk*q
   ra = zr - na
   ib = zi - nb
   jc = zj - nc
   kd = zk - nd
   zr = cr*ra - ci*ib - cj*jc - ck*kd
   zi = ci*ra + cr*ib + ck*jc - cj*kd
   zj = cj*ra - ck*ib + cr*jc + ci*kd
   zk = ck*ra + cj*ib - ci*jc + cr*kd
   zz = zr + flip(zi)
   zh = zj + flip(zk)
 elseif @formula==22
   n = zi^2 + zj^2 + zk^2
   q = 3*zr^2 - n
   ra = zr^3 - 3*zr*n
   ib = zi*q
   jc = zj*q
   kd = zk*q
   dr = cr*zr - ci*zi - cj*zj - ck*zk
   di = ci*zr + cr*zi + ck*zj - cj*zk
   dj = cj*zr - ck*zi + cr*zj + ci*zk
   dk = ck*zr + cj*zi - ci*zj + cr*zk
   zr = ra + dr - zr - cr
   zi = ib + di - zi - ci
   zj = jc + dj - zj - cj
   zk = kd + dk - zk - ck
   zz = zr + flip(zi)
   zh = zj + flip(zk)
 elseif @formula==23
   a = ca*a*(1 - a^@power3)
   b = cb*b*(1 - b^@power3)
   zz = (a + b) / 2
 elseif @formula==24
   a = ca*@f7(a)
   b = cb*@f7(b)
   zz = (a + b) / 2
 elseif @formula==25
   a = a*a*a + a*ca - a - ca
   b = b*b*b + b*cb - b - cb
   zz = (a + b) / 2
 elseif @formula==26
   ra = x^2 + 2*y*v
   ib = v^2 + 2*x*y
   jc = y^2 + 2*x*v
   x = ra + cx
   y = ib + cy
   v = jc + cv
   zz = x + flip(y)
 elseif @formula==27
   ra = x^3 + y^3 + v^3 + 6*x*y*v
   ib = 3*(y*x^2 + v*y^2 + x*v^2)
   jc = 3*(v*x^2 + x*y^2 + y*v^2)
   x = ra + cx
   y = ib + cy
   v = jc + cv
   zz = x + flip(y)
 elseif @formula==28
   ra = x^2 + 2*y*v
   ib = v^2 + 2*x*y
   jc = y^2 + 2*x*v
   dx = x - ra
   dy = y - ib
   dv = v - jc
   x = cx*dx + cv*dy + cy*dv
   y = cy*dx + cx*dy + cv*dv
   v = cv*dx + cy*dy + cx*dv
   zz = x + flip(y)
 elseif @formula==29
   ra = x^3 + y^3 + v^3 + 6*x*y*v
   ib = 3*(y*x^2 + v*y^2 + x*v^2)
   jc = 3*(v*x^2 + x*y^2 + y*v^2)
   dx = x - ra
   dy = y - ib
   dv = v - jc
   x = cx*dx + cv*dy + cy*dv
   y = cy*dx + cx*dy + cv*dv
   v = cv*dx + cy*dy + cx*dv
   zz = x + flip(y)
 elseif @formula==30
   ra = x^3 + y^3 + v^3 + 6*x*y*v
   ib = 3*(y*x^2 + v*y^2 + x*v^2)
   jc = 3*(v*x^2 + x*y^2 + y*v^2)
   dx = x*cx + v*cy + y*cv
   dy = y*cx + x*cy + v*cv
   dv = v*cx + y*cy + x*cv
   x = ra + dx - x - cx
   y = ib + dy - y - cy
   v = jc + dv - v - cv
   zz = x + flip(y)
 endif

  if @formula==0 || @formula==1 || @formula==2 || @formula==3 || \
     @formula==4 || @formula==5 || @formula==6 || @formula==7 || \
     @formula==8 || @formula==9 || @formula==10
   zmod = |zz|
  elseif @formula==11 || @formula==12 || @formula==13 || @formula==19 || \
         @formula==20 || @formula==21 || @formula==22
   zmod = |zz| + |zh|
  elseif @formula==14 || @formula==15 || @formula==16 || @formula==17 || \
         @formula==18 || @formula==23 || @formula==24 || @formula==25
   zmod = (|a| + |b|) / 2
  elseif @formula==26 || @formula==27 || @formula==28 || @formula==29 || \
         @formula==30
   zmod = x^2 + y^2 + v^2
  endif

   IF (@bailout >= zmod)
     i = i + 1
   ELSEIF (stepnum >= m)
     i = 0
     m = m + 1

    if @formula==0
     c0 = c0 + delta
    elseif @formula==1
     c1 = c1 + delta
    elseif @formula==2
     c2 = c2 + delta
    elseif @formula==3
     c3 = c3 + delta
    elseif @formula==4
     c4 = c4 + delta
    elseif @formula==5
     c5 = c5 + delta
    elseif @formula==6
     c6 = c6 + delta
    elseif @formula==7
     c7 = c7 + delta
    elseif @formula==8
     c8 = c8 + delta
    elseif @formula==9
     c9 = c9 + delta
    elseif @formula==10
     c10 = c10 + delta
    elseif @formula==11 || @formula==12 || @formula==13 || @formula==14 || \
           @formula==15 || @formula==16 || @formula==17 || @formula==18 || \
           @formula==19 || @formula==20 || @formula==21 || @formula==22 || \
           @formula==23 || @formula==24 || @formula==25
     zz = zz0 = zz0 + dzz
     zh = zh0 = zh0 + dzh
     zr = real(zz)
     zi = imag(zz)
     zj = real(zh)
     zk = imag(zh)
     a = zr - zk + flip(zi + zj)
     b = zr + zk + flip(zi - zj)
    elseif @formula==26 || @formula==27 || @formula==28 || @formula==29 || \
           @formula==30
     x = x0 = x0 + dxx
     y = y0 = y0 + dyy
     v = v0 = v0 + dvv
    endif
     zz = #pixel
   ENDIF

  if (@coloring == 0)
   z = m - j
   j = j + 1
  else
   z = zz
  endif

bailout:
  (@method == 0 && stepnum >= m && maxiter >= i) ||                                         \
  (@method == 1 && maxiter >= i)
default:
  title = "3D Julia Sets"
  maxiter = 10000
  periodicity = 0

  float param version
    default = 1.45
    visible = false
  endparam
  param formula
    caption = "Formula"
    enum = "Julia" "Lambda" "Ikenaga" "Barnsley 1" "Barnsley 2" "Barnsley 3" \
           "Julia fn" "Lambda fn" "Lambda (fn || fn)" "Fender C" "Popcorn Jul" \
           "Quaternion" "Cubic Quat" "Quartic Quat" "Hypernion" "Hyper fn" \
           "Hyper Barnsley 1" "Hyper Barnsley 2" "Hyper Barnsley 3" "Quat Lambda" \
           "Quat Lambda 2" "Quat Lambda 3" "Quat Ikenaga" "Hyper Lambda pwr" \

    visible=@Formula==23
  endheading

heading
    caption="Requires Raytrace in spr.ucl"
  endheading
heading
    caption="or Texture Raytrace in reb.ucl"
  endheading

  title = "4D Julia (Raytrace)"
  method=multipass
  periodicity=0
  maxiter=10

  float param version
    default = 1.28
    visible = false
  endparam
  param formula
    enum= "Quaternion" "Hypernion" "Quaternion XY" "Hypernion XY" \
    "Hyper Fender" "Hyper Popcorn" "Hyper Dynamic" "Cubic Quat" \
    "Cubic Hyper" "Quat Phoenix" "Hyper Phoenix" "Quat Phoenix 2" \
    "Hyper Phoenix-fn" "Cubic Quat Phoenix" "Cubic Hyper Phoenix" \
    "Hyper Lambda-fn" "Hyper Barnsley 1" "Hyper Barnsley 2" "Hyper Barnsley 3" \
    "Quat Ikenaga" "Hyper Ikenaga" "Quat Lambda""Hyper Lambda""Sierpinski Triangle"
    default=0
    hint="type of formula for raytracing."
  endparam
  param power
    caption="power"
    default=2
    visible=@formula==0||@formula==1||@formula==21||@formula==22
  endparam
  param ph
    caption="Phoenix distortion"
    default=(0.5, 0.0)
    visible=@formula==9||@formula==10||@formula==11||@formula==12||@formula==13||@formula==14
  endparam
  param h
    caption="Step size"
    default=(0.05, 0.0)
    visible=@formula==5||@formula==6
  endparam
  param aa
    caption="Amplitude"
    default=(3.0, 0.0)
    visible=@formula==6
  endparam
  param ba
    caption="Frequency A"
    default=(2.0, 0.0)
    visible=@formula==6
  endparam
  param bb
    caption="Frequency B"
    default=(0.0, 0.0)
    visible=@formula==6
  endparam
  param cc
    caption="Constant C"
    default=(3.0, 0.0)
    visible=@formula==5
  endparam
  param cd
    caption="Constant D"
    default=(0.0, 0.0)
    visible=@formula==5
  endparam
  func fn
   caption="function"
   default=ident()
   visible=@formula==1
  endfunc
  func afn
   caption="First function"
   default=cosh()
   visible=@formula==4
  endfunc
  func bfn
   caption="Second function"
   default=sqr()
   visible=@formula==4
  endfunc
  func pfn
   caption="function"
   default=sqr()
   visible=@formula==12
  endfunc
  func lfn
   caption="function"
   default=sin()
   visible=@formula==15
  endfunc
  func fn1
   caption="First function"
   default=sin()
   visible=@formula==5||@formula==6
  endfunc
  func fn2
   caption="Second function"
   default=tan()
   visible=@formula==5||@formula==6
  endfunc
  func fn3
   caption="Third function"
   default=sin()
   visible=@formula==5||@formula==6
  endfunc
  func fn4
   caption="Fourth function"
   default=tan()
   visible=@formula==5||@formula==6
  endfunc
  param fourthdim
    enum="a-real or zr" "a-imag or zi" "b-real or zj" "b-imag or zk"
    default=3
    hint=" axis that points into the fourth dimension."
  endparam
  param fourthvalue
    caption="4-dim-value"
    default=0.0
    hint="value for the fourth axis."
  endparam
  param zorig
    caption="z-center"
    default=0.0
    hint="Center of z-axis."
  endparam
  param view
    enum="3-dim" "2-dim-center" "2-dim-screen"
    default=0
    hint="View-system. 3d or 2d from center or 2d from 'screentouch'."
  endparam
  param background
    enum="outside" "inside"
    default=1
    hint="What type of background-coloring you want. With inside only one colour or inside \
          coloring filter"
  endparam
  param touchscreen
    caption="Screen-touch"
    default=false
    hint="Those structures that goes out of the screen, or touches it, is colored with \
          inside colouring."
  endparam
  param cr
    caption="cr"
    default=-0.745
    visible=@formula==0||@formula==1||@formula==2||@formula==3||@formula==4||@formula==7||@formula==8 \
    ||@formula==9||@formula==10||@formula==11||@formula==12||@formula==13||@formula==14||@formula==15 \
    ||@formula==16||@formula==17||@formula==18||@formula==19||@formula==20||@formula==21||@formula==22
    hint="real constant for quaternions and hypercomplex calculations."
  endparam
  param ci
    caption="ci"
    default=0.0
    visible=@formula==0||@formula==1||@formula==2||@formula==3||@formula==4||@formula==7||@formula==8 \
    ||@formula==9||@formula==10||@formula==11||@formula==12||@formula==13||@formula==14||@formula==15 \
    ||@formula==16||@formula==17||@formula==18||@formula==19||@formula==20||@formula==21||@formula==22
    hint="imaginary constant for quaternions and hypercomplex calculations."
  endparam
  param cj
    caption="cj"
    default=0.0
    visible=@formula==0||@formula==1||@formula==2||@formula==3||@formula==4||@formula==7||@formula==8 \
    ||@formula==9||@formula==10||@formula==11||@formula==12||@formula==13||@formula==14||@formula==15 \
    ||@formula==16||@formula==17||@formula==18||@formula==19||@formula==20||@formula==21||@formula==22
    hint="Second imaginary constant for quaternions and hypercomplex calculations."
  endparam
  param ck
    caption="ck"
    default=0.0
    visible=@formula==0||@formula==1||@formula==2||@formula==3||@formula==4||@formula==7||@formula==8 \
    ||@formula==9||@formula==10||@formula==11||@formula==12||@formula==13||@formula==14||@formula==15 \
    ||@formula==16||@formula==17||@formula==18||@formula==19||@formula==20||@formula==21||@formula==22
    hint="Third imaginary constant for quaternions and hypercomplex calculations."
  endparam
  param xrot
    caption="x-rotation"
    default=0.0
    hint="Rotates the system through the x-axis."
  endparam
  param yrot
    caption="y-rotation"
    default=0.0
    hint="Rotates the system through the y-axis."
  endparam
  param zrot
    caption="z-rotation"
    default=0.0
    hint="Rotates the system through the z-axis."
  endparam
  param local
    caption="Local rotation"
    default=true
    hint="Sets local rotation. Otherwise location around zero."
  endparam
  param lightx
    caption="Light-x"
    default=10.0
    hint="x-coord of lightsource"
  endparam
  param lighty
    caption="Light-y"
    default=10.0
    hint="y-coord of lightsource"
  endparam
  param lightz
    caption="Light-z"
    default=-6.0
    hint="z-coord of lightsource"
  endparam
  param zscreen
    caption="Screen-depth"
    default=320.0
    hint="Screendepth in virtual pixels."
    min=0
  endparam
  param zdist
    caption="z-distance"
    default=4.0
    hint="Length of z-axis."
  endparam
  param zmagn
    caption="z-magnify"
    default=false
    hint="If set then the fractal will be magnified in the third dimension too."
  endparam
  param autoscale
    caption="Auto scaling"
    default=false
    hint="If set then the screendepth in virtual pixels will be set to hold the same scalar \
          proportions as the x-axis. Take it easy with this as you don´t have to \
          magnify the screensurface very much to get a very long z-axis in pixels. If \
          z-magnify is set too then there is no danger in overproportions."
  endparam
  param prec
    caption="Precision"
    default=10.0
    min=1.0
    hint="Precision for the fine tracing. The lower, the faster but with less precision. \
          Smallest value allowed is 1.0"
  endparam
  param delta
    caption="Delta"
    default=1.0
    hint="The difference between the points that builds the normal-plane to the lightsource. \
          Should normally be 1.0"
  endparam
  param bailout
    caption="Bailout"
    default=4.0
    hint="Breakvalue for iterations."
    min=0.0
  endparam

}

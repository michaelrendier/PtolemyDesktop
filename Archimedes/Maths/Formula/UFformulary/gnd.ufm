    ENDIF
  ELSEIF (@zmode == 8)                  ; smallest |function2(z)|
    d1 = cabs(fn1(z1))               ; get current distances
    d2 = cabs(fn1(z2))
    d3 = cabs(fn1(z3))
    IF (d1 < s1)                        ; update smallest distances

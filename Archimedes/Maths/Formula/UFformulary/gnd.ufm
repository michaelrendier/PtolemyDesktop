}

gnd-cubic-3D_Mset {
; Based on formula by Russell Walsmith
; version 1.0, May 2005
; Gilles Nadeau, 18/05/2005
;
init:
  a = (0.0, 0.0)
  b = (0.0, 0.0)
  c = (0.0, 0.0)
  x = (0.0, 0.0)
  y = (0.0, 0.0)
  t = (0.0, 0.0)
  ca = (0.0, 0.0)
  cb = (0.0, 0.0)
  cc = @c1
  
 if (@var == 0)
  ca = real(#pixel)
  cb = imag(#pixel)

 elseif (@var == 1)
  ca = flip(real(#pixel))
  cb = flip(imag(#pixel)) 
  
 elseif (@var == 2)
  ca = real(#pixel)
  cb = flip(imag(#pixel))
  
 elseif (@var == 3)
  ca = flip(real(#pixel))
  cb = imag(#pixel) 

 endif
 
loop:
  
  a1 = a^3 + b^3 + y^3 + 3*(a*x^2 + b*c^2 + y*t^2) + 6*(a*(b*y + c*t) + x*(b*t + y*c))
  a2 = x^3 + t^3 + c^3 + 3*(x*a^2 + c*b^2 + t*y^2) + 6*(a*(b*t + y*c) + x*(b*y + c*t))
  b1 = 3*(y*(b^2 + c^2) + a*(y^2 + t^2) + b*(a^2 + x^2)) + 6*(x*y*t + a*x*c + b*c*t)   
  b2 = 3*(b*(y^2 + t^2) + a*(b^2 + c^2) + y*(a^2 + x^2)) + 6*(x*b*c + c*y*t + a*x*t) 
  c1 = 3*(c*(a^2 + x^2) + x*(y^2 + t^2) + t*(b^2 + c^2)) + 6*(a*b*x + a*y*t + b*c*y)
  c2 = 3*(t*(a^2 + x^2) + x*(b^2 + c^2) + c*(y^2 + t^2)) + 6*(a*x*y + a*b*c + b*y*t)
  a = a1 + ca
  x = a2 - ca
  b = b1 + cb
  y = b2 - cb
  c = c1 + cc
  t = c2 - cc
  
 if (@flavor == 0) 
  z = a - x + flip(b - y)
 elseif (@flavor == 1)
  z = a - x + b - y
 endif
 
bailout:
  |a| + |b| + |c| + |x| + |y| + |t| <= @bailout
default:
  title = "Cubic-3D_Mset"
  center = (0.0,0.0)
  magn = 2.0
  maxiter = 149
  periodicity = 0
  
  param version
    caption = "Version"
    default = 1.0
    visible = false
  endparam
  
  param var 
   caption = "Variation"
   enum = "xy""zw""xw""yz"
   default = 0
  endparam
  
  param c1
    caption = "c1"
    default = (0.0, 0.0)
  endparam
  
  param flavor
   caption = "Combine flavor"
   enum = "1:(z=x+flip(y))" "2:(z=x+y)" 
  endparam
  
  param bailout
    caption = "Bailout Value"
    default = 64.0
    min = 0.0
  endparam
  
switch:
  type = "gnd-cubic-3D_Jset"
  version = @version
  c0 = #pixel
  c1 = @c1
  var = @var
  flavor = @flavor
  bailout = @bailout
}

gnd-cubic-3D_Jset {
; Based on formula by Russell Walsmith
; version 1.0, May 2005
; Gilles Nadeau, 18/05/2005
;
init:
  a = (0.0, 0.0)
  b = (0.0, 0.0)
  c = @ct
  x = (0.0, 0.0)
  y = (0.0, 0.0)
  t = -@ct
  ca = (0.0, 0.0)
  cb = (0.0, 0.0)
  cc = @c1
  
 if (@var == 0)
  a = real(#pixel)
  b = imag(#pixel)
  x = -real(#pixel)
  y = -imag(#pixel)
  ca = real(@c0)
  cb = imag(@c0)

 elseif (@var == 1)
  a = flip(real(#pixel))
  b = flip(imag(#pixel))
  x = -flip(real(#pixel))
  y = -flip(imag(#pixel))
  ca = flip(real(@c0))
  cb = flip(imag(@c0)) 
  
 elseif (@var == 2)
  a = real(#pixel)
  b = flip(imag(#pixel))
  x = -real(#pixel)
  y = -flip(imag(#pixel))
  ca = real(@c0)
  cb = flip(imag(@c0))
  
 elseif (@var == 3)
  a = flip(real(#pixel))
  b = imag(#pixel)
  x = -flip(real(#pixel))
  y = -imag(#pixel)
  ca = flip(real(@c0))
  cb = imag(@c0) 

 endif
  
loop:

  a1 = a^3 + b^3 + y^3 + 3*(a*x^2 + b*c^2 + y*t^2) + 6*(a*(b*y + c*t) + x*(b*t + y*c))
  a2 = x^3 + t^3 + c^3 + 3*(x*a^2 + c*b^2 + t*y^2) + 6*(a*(b*t + y*c) + x*(b*y + c*t))
  b1 = 3*(y*(b^2 + c^2) + a*(y^2 + t^2) + b*(a^2 + x^2)) + 6*(x*y*t + a*x*c + b*c*t)   
  b2 = 3*(b*(y^2 + t^2) + a*(b^2 + c^2) + y*(a^2 + x^2)) + 6*(x*b*c + c*y*t + a*x*t) 
  c1 = 3*(c*(a^2 + x^2) + x*(y^2 + t^2) + t*(b^2 + c^2)) + 6*(a*b*x + a*y*t + b*c*y)
  c2 = 3*(t*(a^2 + x^2) + x*(b^2 + c^2) + c*(y^2 + t^2)) + 6*(a*x*y + a*b*c + b*y*t)
  a = a1 + ca
  x = a2 - ca
  b = b1 + cb
  y = b2 - cb
  c = c1 + cc
  t = c2 - cc
  
 if (@flavor == 0) 
  z = a - x + flip(b - y)
 elseif (@flavor == 1)
  z = a - x + b - y
 endif

bailout:
  |a| + |b| + |c| + |x| + |y| + |t| <= @bailout
default:

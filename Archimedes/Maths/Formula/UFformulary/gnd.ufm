    default = (0.0, 0.0)
  endparam
  param ct
    caption = "c2"
    default = (0.0, 0.0)
  endparam
  
  param flavor
   caption = "Combine flavor"
   enum = "1:(z=x+flip(y))" "2:(z=x+y)" 
  endparam
  
  param bailout
    caption = "Bailout Value"
    default = 64.0
    min = 0.0
  endparam
  
switch:

           a = 2*real(a) + flip(2*imag(a)-1)
          elseif (real(a)>0.5)
           a = 2*real(a)-1 + flip(2*imag(a))
          else
           a = 2*real(a) + flip(2*imag(a))
          endif

          if (imag(b)>0.5)
           b = 2*real(b) + flip(2*imag(b)-1)
          elseif (real(b)>0.5)
           b = 2*real(b)-1 + flip(2*imag(b))
          else
           b = 2*real(b) + flip(2*imag(b))

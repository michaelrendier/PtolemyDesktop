     cj = real(cz)
     ck = imag(cz)
    endif
    
  ca = c1 - ck + flip(ci + cj)
  cb = c1 + ck + flip(ci - cj) 

loop:
  a = z1 - zk + flip(zi + zj)
  b = z1 + zk + flip(zi - zj)
 if |a| < @shift

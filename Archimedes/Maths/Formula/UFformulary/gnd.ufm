    default = 0.0
    visible = @formula==11 || @formula==12 || @formula==13 || @formula==14 || \
              @formula==15 || @formula==16 || @formula==17 || @formula==18 || \
              @formula==19 || @formula==20 || @formula==21 || @formula==22 || \
              @formula==23 || @formula==24 || @formula==25
  endparam
  float param rotz
    caption = "Rotation zj"
    default = 0.0
    visible = @formula==11 || @formula==12 || @formula==13 || @formula==14 || \
              @formula==15 || @formula==16 || @formula==17 || @formula==18 || \
              @formula==19 || @formula==20 || @formula==21 || @formula==22 || \
              @formula==23 || @formula==24 || @formula==25
  endparam

  ca = real(@c0)
  cb = flip(imag(@c0))
  
 elseif (@var == 3)
  a = flip(real(#pixel))
  b = imag(#pixel)
  ca = flip(real(@c0))
  cb = imag(@c0) 

 endif
  
loop:
  r = sqr(a)
  i = sqr(b)
  t = sqr(c)
  na = a*r + b*i + c*t + 6*a*b*c  
  nb = 3*(b*r + c*i + a*t)  
  nc = 3*(c*r + a*i + b*t)
  cr = a*ca + c*cb + b*cc 

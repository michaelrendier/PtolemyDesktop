  center = (0.0,0.0)
  magn = 2.0
  maxiter = 149
  periodicity = 0
  
  param version
    caption = "Version"
    default = 1.0
    visible = false
  endparam
  
  param var 
   caption = "Variation"
   enum = "xy""zw""xw""yz"
   default = 0
  endparam
  
  param c0
    caption = "c0"
    default = (0.0475, 0.45)
  endparam   
  param c1
    caption = "c1"
    default = (0.0, 0.0)
  endparam
  param ct
    caption = "c2"
    default = (0.0, 0.0)
  endparam
  
  param flavor
   caption = "Combine flavor"
   enum = "1:(z=x+flip(y))" "2:(z=x+y)" 
  endparam
  
  param bailout
    caption = "Bailout Value"
    default = 64.0
    min = 0.0
  endparam
  
switch:
  type = "gnd-cubic-3D_Mset"
  version = @version
  c1 = @c1
  var = @var
  flavor = @flavor
  bailout = @bailout
}


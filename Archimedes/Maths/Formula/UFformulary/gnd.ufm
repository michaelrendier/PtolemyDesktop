    caption = "Number of slices"
    default = 254
  endparam
  param coloring
    caption = "Coloring method"
    default = 0
    enum = "Fractint" "Ultra Fractal"
  endparam
  param method
    caption = "Bailout method"
    default = 0
    enum = "1" "2"
  endparam
  float param bailout
    caption = "Bailout value"
    default = 64.0
  endparam
}

gnd-4D-J-sets {
; Based on the models of formulas 3D by Gerald K. Dobiasovsky.
; Use the fractint ucl outside = summ
; Gilles Nadeau, July, 2007
;
init:
 float zr = real(#pixel)
 float zi = imag(#pixel)
 float zj = real(@p2)
 float zk = imag(@p2)
 float cr = real(@cri)
 float ci = imag(@cri)
 float cj = real(@cjk)
 float ck = imag(@cjk)
 float stepnum = @stepnum
 float maxiter = @maxiter
 complex delta = (@p1 - @p2) / stepnum
 float x0 = zr
 float y0 = zi
 float z0 = zj
 float w0 = zk
 float dx = 0.0
 float dy = 0.0
 float dz = real(delta)
 float dw = imag(delta)
 float rotx = @rotx
 float roty = @roty
 float rotz = @rotz
 float rotw = @rotw
 float rx = 0.0
 float ry = 0.0
 float rz = 0.0
 float rw = 0.0

; (xz plane rotation)

   ry = y0*cos(#pi*rotx/180) - z0*sin(#pi*rotx/180)
   rz = y0*sin(#pi*rotx/180) + z0*cos(#pi*rotx/180)
   y0 = ry
   z0 = rz

   ry = dy*cos(#pi*rotx/180) - dz*sin(#pi*rotx/180)
   rz = dy*sin(#pi*rotx/180) + dz*cos(#pi*rotx/180)
   dy = ry
   dz = rz

; (yz plane rotation)

   rx = z0*sin(#pi*roty/180) + x0*cos(#pi*roty/180)
   rz = z0*cos(#pi*roty/180) - x0*sin(#pi*roty/180)
   x0 = rx
   z0 = rz

   rx = dz*sin(#pi*roty/180) + dx*cos(#pi*roty/180)
   rz = dz*cos(#pi*roty/180) - dx*sin(#pi*roty/180)
   dx = rx
   dz = rz

; (yw plane rotation)

   rx = x0*cos(#pi*rotz/180) - w0*sin(#pi*rotz/180)
   rw = x0*sin(#pi*rotz/180) + w0*cos(#pi*rotz/180)
   x0 = rx
   w0 = rw

   rx = dx*cos(#pi*rotz/180) - dw*sin(#pi*rotz/180)
   rw = dx*sin(#pi*rotz/180) + dw*cos(#pi*rotz/180)
   dx = rx
   dw = rw

; (xw plane rotation)

   ry = w0*sin(#pi*rotw/180) + y0*cos(#pi*rotw/180)
   rw = w0*cos(#pi*rotw/180) - y0*sin(#pi*rotw/180)
   y0 = ry
   w0 = rw

   ry = dw*sin(#pi*rotw/180) + dy*cos(#pi*rotw/180)
   rw = dw*cos(#pi*rotw/180) - dy*sin(#pi*rotw/180)
   dy = ry
   dw = rw

   zr = x0
   zi = y0
   zj = z0
   zk = w0

 complex a = zr - zk + flip(zi + zj)
 complex b = zr + zk + flip(zi - zj)
 complex c = cr - ck + flip(ci + cj)
 complex d = cr + ck + flip(ci - cj)
 float ra = 0.0
 float ib = 0.0
 float jc = 0.0
 float kd = 0.0
 float na = 0.0
 float nb = 0.0
 float nc = 0.0
 float nd = 0.0
 float dr = 0.0
 float di = 0.0
 float dj = 0.0
 float dk = 0.0
 float n = 0.0
 float q = 0.0
 int j = 0
 int m = 0
 int i = 0
loop:

  if @formula==0
   ra = zr^2 - zi^2 - zj^2 - zk^2
   ib = 2*zr*zi
   jc = 2*zr*zj
   kd = 2*zr*zk
   zr = ra + cr
   zi = ib + ci
   zj = jc + cj
   zk = kd + ck
  elseif @formula==1
   n = zi^2 + zj^2 + zk^2
   q = 3*zr^2 - n
   ra = zr*zr^2 - 3*zr*n
   ib = zi*q
   jc = zj*q
   kd = zk*q
   zr = ra + cr
   zi = ib + ci
   zj = jc + cj
   zk = kd + ck
  elseif @formula==2
   n = zi^2 + zj^2 + zk^2
   q = zr^2 - n
   ra = q^2 - 4*zr^2*n
   ib = 4*zr*zi*q
   jc = 4*zr*zj*q
   kd = 4*zr*zk*q
   zr = ra + cr
   zi = ib + ci
   zj = jc + cj
   zk = kd + ck
  elseif @formula==3
   a = a^@power + c
   b = b^@power + d
   zr = (real(a) + real(b)) / 2
   zi = (imag(a) + imag(b)) / 2
   zj = (imag(a) - imag(b)) / 2
   zk = (real(b) - real(a)) / 2
  elseif @formula==4
   a = @fn1(a) + c
   b = @fn1(b) + d
   zr = (real(a) + real(b)) / 2
   zi = (imag(a) + imag(b)) / 2
   zj = (imag(a) - imag(b)) / 2
   zk = (real(b) - real(a)) / 2
  elseif @formula==5
  if real(a) >= 0
   a = (a - 1)*c
  else
   a = (a + 1)*c
  endif
  if real(b) >= 0
   b = (b - 1)*d
  else
   b = (b + 1)*d
  endif
   zr = (real(a) + real(b)) / 2
   zi = (imag(a) + imag(b)) / 2
   zj = (imag(a) - imag(b)) / 2
   zk = (real(b) - real(a)) / 2
  elseif @formula==6
  if real(a)*imag(c) + real(c)*imag(a) >= 0
   a = (a - 1)*c
  else
   a = (a + 1)*c
  endif
  if real(b)*imag(d) + real(d)*imag(b) >= 0
   b = (b - 1)*d
  else
   b = (b + 1)*d
  endif
   zr = (real(a) + real(b)) / 2
   zi = (imag(a) + imag(b)) / 2
   zj = (imag(a) - imag(b)) / 2
   zk = (real(b) - real(a)) / 2
  elseif @formula==7
  if real(a) >= 0
   a = sqr(a) - 1
  else
   a = sqr(a) - 1 + c*real(a)
  endif
  if real(b) >= 0
   b = sqr(b) - 1
  else
   b = sqr(b) - 1 + d*real(b)
  endif
   zr = (real(a) + real(b)) / 2
   zi = (imag(a) + imag(b)) / 2
   zj = (imag(a) - imag(b)) / 2
   zk = (real(b) - real(a)) / 2
  elseif @formula==8
   na = zr^2 - zi^2 - zj^2 - zk^2
   nb = 2*zr*zi
   nc = 2*zr*zj
   nd = 2*zr*zk
   ra = zr - na
   ib = zi - nb
   jc = zj - nc
   kd = zk - nd
   zr = cr*ra - ci*ib - cj*jc - ck*kd
   zi = ci*ra + cr*ib + ck*jc - cj*kd
   zj = cj*ra - ck*ib + cr*jc + ci*kd
   zk = ck*ra + cj*ib - ci*jc + cr*kd
  elseif @formula==9
   n = zi^2 + zj^2 + zk^2
   q = 3*zr^2 - n
   na = zr*zr^2 - 3*zr*n
   nb = zi*q
   nc = zj*q
   nd = zk*q
   ra = zr - na
   ib = zi - nb
   jc = zj - nc
   kd = zk - nd
   zr = cr*ra - ci*ib - cj*jc - ck*kd
   zi = ci*ra + cr*ib + ck*jc - cj*kd
   zj = cj*ra - ck*ib + cr*jc + ci*kd
   zk = ck*ra + cj*ib - ci*jc + cr*kd
  elseif @formula==10
   n = zi^2 + zj^2 + zk^2
   q = zr^2 - n
   na = q^2 - 4*zr^2*n
   nb = 4*zr*zi*q
   nc = 4*zr*zj*q
   nd = 4*zr*zk*q
   ra = zr - na
   ib = zi - nb
   jc = zj - nc
   kd = zk - nd
   zr = cr*ra - ci*ib - cj*jc - ck*kd
   zi = ci*ra + cr*ib + ck*jc - cj*kd
   zj = cj*ra - ck*ib + cr*jc + ci*kd
   zk = ck*ra + cj*ib - ci*jc + cr*kd
  elseif @formula==11
   n = zi^2 + zj^2 + zk^2
   q = 3*zr^2 - n
   ra = zr*zr^2 - 3*zr*n
   ib = zi*q
   jc = zj*q
   kd = zk*q
   dr = cr*zr - ci*zi - cj*zj - ck*zk
   di = ci*zr + cr*zi + ck*zj - cj*zk
   dj = cj*zr - ck*zi + cr*zj + ci*zk
   dk = ck*zr + cj*zi - ci*zj + cr*zk
   zr = ra + dr - zr - cr
   zi = ib + di - zi - ci
   zj = jc + dj - zj - cj
   zk = kd + dk - zk - ck
  elseif @formula==12
   a = c*a*(1 - a^@power)
   b = d*b*(1 - b^@power)
   zr = (real(a) + real(b)) / 2
   zi = (imag(a) + imag(b)) / 2
   zj = (imag(a) - imag(b)) / 2
   zk = (real(b) - real(a)) / 2
  elseif @formula==13
   a = c*@fn1(a)
   b = d*@fn1(b)
   zr = (real(a) + real(b)) / 2
   zi = (imag(a) + imag(b)) / 2
   zj = (imag(a) - imag(b)) / 2
   zk = (real(b) - real(a)) / 2
  elseif @formula==14
   a = a*a*a + a*c - a - c
   b = b*b*b + b*d - b - d
   zr = (real(a) + real(b)) / 2
   zi = (imag(a) + imag(b)) / 2
   zj = (imag(a) - imag(b)) / 2
   zk = (real(b) - real(a)) / 2
  elseif @formula==15
   n = sqrt(zi^2 + zj^2 + zk^2)
  if n == 0
   n = 1e-20
  endif
   ra = sin(zr)*cosh(n)
   ib = cos(zr)*sinh(n) / n*zi
   jc = cos(zr)*sinh(n) / n*zj
   kd = cos(zr)*sinh(n) / n*zk
   zr = ra + cr
   zi = ib + ci
   zj = jc + cj
   zk = kd + ck
  elseif @formula==16
   n = sqrt(zi^2 + zj^2 + zk^2)
  if n == 0
   n = 1e-20
  endif
   ra = cos(zr)*cosh(n)
   ib =-sin(zr)*sinh(n) / n*zi
   jc =-sin(zr)*sinh(n) / n*zj
   kd =-sin(zr)*sinh(n) / n*zk
   zr = ra + cr
   zi = ib + ci
   zj = jc + cj
   zk = kd + ck
  elseif @formula==17
   n = sqrt(zi^2 + zj^2 + zk^2)
  if n == 0
   n = 1e-20
  endif
   ra = exp(zr)*cos(n)
   ib = exp(zr)*sin(n) / n*zi
   jc = exp(zr)*sin(n) / n*zj
   kd = exp(zr)*sin(n) / n*zk
   zr = ra + cr
   zi = ib + ci
   zj = jc + cj
   zk = kd + ck
  endif

 IF (@bailout >= zr^2 + zi^2 + zj^2 + zk^2)
   i = i + 1
 ELSEIF (stepnum >= m)
   i = 0
   m = m + 1
   zr = x0 = x0 + dx
   zi = y0 = y0 + dy
   zj = z0 = z0 + dz
   zk = w0 = w0 + dw
   a = zr - zk + flip(zi + zj)
   b = zr + zk + flip(zi - zj)
 ENDIF
  if (@coloring == 0)
   z = m - j
   j = j + 1
  else
   z = zr + flip(zi)
  endif

bailout:
  (@method == 0 && stepnum >= m && maxiter >= i) ||                                         \
  (@method == 1 && maxiter >= i)
default:
  title = "4D Julia Sets"
  maxiter = 10000
  periodicity = 0
  float param version
    default = 1.24
    visible = false
  endparam
  param formula
    caption = "Formula"
    enum = "Quaternion" "Cubic Quat" "Quartic Quat" "Hypernion" "Hyper fn" \
          "Hyper Barnsley 1" "Hyper Barnsley 2" "Hyper Barnsley 3" "Quat Lambda" \
          "Quat Lambda 2" "Quat Lambda 3" "Quat Ikenaga" "Hyper Lambda pwr" \
          "Hyper Lambda fn" "Hyper Ikenaga" "Quat Sin" "Quat Cos" "Quat Exp"
    default = 0
  endparam
  param cri
    caption = "(c1, ci)"
    default = (-0.745, 0.0)
  endparam
  param cjk
    caption = "(cj, ck)"
    default = (0.0, 0.0)
  endparam
  param p1
    caption = "From (zj, zk)"
    default = (1.0, 0.0)
  endparam
  param p2
    caption = "To (zj, zk)"
    default = (-1.0, 0.0)
  endparam
  param power
    caption = "Exponent"
    default = (2.0, 0.0)
    visible = @formula==3 || @formula==12
  endparam
  func fn1
    caption = "Function"
    default = sin()
    visible = @formula==4 || @formula==13
  endfunc
  param rotx
    caption = "Rotation zr"
    default = 0.0
  endparam
  param roty
    caption = "Rotation zi"
    default = 0.0
  endparam
  param rotz
    caption = "Rotation zj"
    default = 0.0
  endparam
  param rotw
    caption = "Rotation zk"
    default = 0.0
  endparam
  float param maxiter
    caption = "Maxiter"
    default = 50
  endparam
  float param stepnum
    caption = "Number of slices"
    default = 254
  endparam
  param coloring
    caption = "Coloring method"
    default = 0
    enum = "Fractint" "Ultra Fractal"
  endparam
  param method
    caption = "Bailout method"
    default = 0
    enum = "1" "2"
  endparam
  float param bailout
    caption = "Bailout value"
    default = 128.0
  endparam
switch:
  type = "gnd-4D-M-sets"
  version = @version
  formula = @formula
  p1 = @p1
  p2 = @p2
  power = @power
  rotx = @rotx
  roty = @roty
  rotz = @rotz
  rotw = @rotw
  maxiter = @maxiter
  stepnum = @stepnum
  coloring = @coloring
  method = @method
  bailout = @bailout
  fn1 = @fn1
}

gnd-4D-M-sets {
; Based on the models of formulas 3D by Gerald K. Dobiasovsky.
; Use the fractint ucl outside = summ
; Gilles Nadeau, July, 2007
;
init:
 float zr = 0.0
 float zi = 0.0
 float zj = 0.0
 float zk = 0.0
 float cr = real(#pixel)
 float ci = imag(#pixel)
 float cj = real(@p2)
 float ck = imag(@p2)
 float stepnum = @stepnum
 float maxiter = @maxiter
 complex delta = (@p1 - @p2) / stepnum
 float x0 = cr
 float y0 = ci
 float z0 = cj
 float w0 = ck
 float dx = 0.0
 float dy = 0.0
 float dz = real(delta)
 float dw = imag(delta)
 if @formula==8
 zr = 0.5
 elseif @formula==9
 zr = (1/3)^0.5
 elseif @formula==10
 zr = 0.25^(1/3)
 elseif @formula==12
 zr = real((1/(@power+1))^(1/@power))
 zi = imag((1/(@power+1))^(1/@power))
 elseif @formula==13
 zr = 0.0 + cr
 zi = 0.0 + ci
 zj = 0.0 + cj
 zk = 0.0 + ck
 endif
 float rotx = @rotx
 float roty = @roty
 float rotz = @rotz
 float rotw = @rotw
 float rx = 0.0
 float ry = 0.0
 float rz = 0.0
 float rw = 0.0

; (xz plane rotation)

   ry = y0*cos(#pi*rotx/180) - z0*sin(#pi*rotx/180)
   rz = y0*sin(#pi*rotx/180) + z0*cos(#pi*rotx/180)
   y0 = ry
   z0 = rz

   ry = dy*cos(#pi*rotx/180) - dz*sin(#pi*rotx/180)
   rz = dy*sin(#pi*rotx/180) + dz*cos(#pi*rotx/180)
   dy = ry
   dz = rz

; (yz plane rotation)

   rx = z0*sin(#pi*roty/180) + x0*cos(#pi*roty/180)
   rz = z0*cos(#pi*roty/180) - x0*sin(#pi*roty/180)
   x0 = rx
   z0 = rz

   rx = dz*sin(#pi*roty/180) + dx*cos(#pi*roty/180)
   rz = dz*cos(#pi*roty/180) - dx*sin(#pi*roty/180)
   dx = rx
   dz = rz

; (yw plane rotation)

   rx = x0*cos(#pi*rotz/180) - w0*sin(#pi*rotz/180)
   rw = x0*sin(#pi*rotz/180) + w0*cos(#pi*rotz/180)
   x0 = rx
   w0 = rw

   rx = dx*cos(#pi*rotz/180) - dw*sin(#pi*rotz/180)
   rw = dx*sin(#pi*rotz/180) + dw*cos(#pi*rotz/180)
   dx = rx
   dw = rw

; (xw plane rotation)

   ry = w0*sin(#pi*rotw/180) + y0*cos(#pi*rotw/180)
   rw = w0*cos(#pi*rotw/180) - y0*sin(#pi*rotw/180)
   y0 = ry
   w0 = rw

   ry = dw*sin(#pi*rotw/180) + dy*cos(#pi*rotw/180)
   rw = dw*cos(#pi*rotw/180) - dy*sin(#pi*rotw/180)
   dy = ry
   dw = rw

   cr = x0
   ci = y0
   cj = z0
   ck = w0

 complex a = zr - zk + flip(zi + zj)
 complex b = zr + zk + flip(zi - zj)
 complex c = cr - ck + flip(ci + cj)
 complex d = cr + ck + flip(ci - cj)
 float ra = 0.0
 float ib = 0.0
 float jc = 0.0
 float kd = 0.0
 float na = 0.0
 float nb = 0.0
 float nc = 0.0
 float nd = 0.0
 float dr = 0.0
 float di = 0.0
 float dj = 0.0
 float dk = 0.0
 float n = 0.0
 float q = 0.0
 int j = 0
 int m = 0
 int i = 0
loop:

  if @formula==0
   ra = zr^2 - zi^2 - zj^2 - zk^2
   ib = 2*zr*zi
   jc = 2*zr*zj
   kd = 2*zr*zk
   zr = ra + cr
   zi = ib + ci
   zj = jc + cj
   zk = kd + ck
  elseif @formula==1
   n = zi^2 + zj^2 + zk^2
   q = 3*zr^2 - n
   ra = zr*zr^2 - 3*zr*n
   ib = zi*q
   jc = zj*q
   kd = zk*q
   zr = ra + cr
   zi = ib + ci
   zj = jc + cj
   zk = kd + ck
  elseif @formula==2
   n = zi^2 + zj^2 + zk^2
   q = zr^2 - n
   ra = q^2 - 4*zr^2*n
   ib = 4*zr*zi*q
   jc = 4*zr*zj*q
   kd = 4*zr*zk*q
   zr = ra + cr
   zi = ib + ci
   zj = jc + cj
   zk = kd + ck
  elseif @formula==3
   a = a^@power + c
   b = b^@power + d
   zr = (real(a) + real(b)) / 2
   zi = (imag(a) + imag(b)) / 2
   zj = (imag(a) - imag(b)) / 2
   zk = (real(b) - real(a)) / 2
  elseif @formula==4
   a = @fn1(a) + c
   b = @fn1(b) + d
   zr = (real(a) + real(b)) / 2
   zi = (imag(a) + imag(b)) / 2
   zj = (imag(a) - imag(b)) / 2
   zk = (real(b) - real(a)) / 2
  elseif @formula==5
  if real(a) >= 0
   a = (a - 1)*c
  else
   a = (a + 1)*c
  endif
  if real(b) >= 0
   b = (b - 1)*d
  else
   b = (b + 1)*d
  endif
   zr = (real(a) + real(b)) / 2
   zi = (imag(a) + imag(b)) / 2
   zj = (imag(a) - imag(b)) / 2
   zk = (real(b) - real(a)) / 2
  elseif @formula==6
  if real(a)*imag(c) + real(c)*imag(a) >= 0
   a = (a - 1)*c
  else
   a = (a + 1)*c
  endif
  if real(b)*imag(d) + real(d)*imag(b) >= 0
   b = (b - 1)*d
  else
   b = (b + 1)*d
  endif
   zr = (real(a) + real(b)) / 2
   zi = (imag(a) + imag(b)) / 2
   zj = (imag(a) - imag(b)) / 2
   zk = (real(b) - real(a)) / 2
  elseif @formula==7
  if real(a) >= 0
   a = sqr(a) - 1
  else
   a = sqr(a) - 1 + c*real(a)
  endif
  if real(b) >= 0
   b = sqr(b) - 1
  else
   b = sqr(b) - 1 + d*real(b)
  endif
   zr = (real(a) + real(b)) / 2
   zi = (imag(a) + imag(b)) / 2
   zj = (imag(a) - imag(b)) / 2
   zk = (real(b) - real(a)) / 2
  elseif @formula==8
   na = zr^2 - zi^2 - zj^2 - zk^2
   nb = 2*zr*zi
   nc = 2*zr*zj
   nd = 2*zr*zk
   ra = zr - na
   ib = zi - nb
   jc = zj - nc
   kd = zk - nd
   zr = cr*ra - ci*ib - cj*jc - ck*kd
   zi = ci*ra + cr*ib + ck*jc - cj*kd
   zj = cj*ra - ck*ib + cr*jc + ci*kd
   zk = ck*ra + cj*ib - ci*jc + cr*kd
  elseif @formula==9
   n = zi^2 + zj^2 + zk^2
   q = 3*zr^2 - n
   na = zr*zr^2 - 3*zr*n
   nb = zi*q
   nc = zj*q
   nd = zk*q
   ra = zr - na
   ib = zi - nb
   jc = zj - nc
   kd = zk - nd
   zr = cr*ra - ci*ib - cj*jc - ck*kd
   zi = ci*ra + cr*ib + ck*jc - cj*kd
   zj = cj*ra - ck*ib + cr*jc + ci*kd
   zk = ck*ra + cj*ib - ci*jc + cr*kd
  elseif @formula==10
   n = zi^2 + zj^2 + zk^2
   q = zr^2 - n
   na = q^2 - 4*zr^2*n
   nb = 4*zr*zi*q
   nc = 4*zr*zj*q
   nd = 4*zr*zk*q
   ra = zr - na
   ib = zi - nb
   jc = zj - nc
   kd = zk - nd
   zr = cr*ra - ci*ib - cj*jc - ck*kd
   zi = ci*ra + cr*ib + ck*jc - cj*kd
   zj = cj*ra - ck*ib + cr*jc + ci*kd
   zk = ck*ra + cj*ib - ci*jc + cr*kd
  elseif @formula==11
   n = zi^2 + zj^2 + zk^2
   q = 3*zr^2 - n
   ra = zr*zr^2 - 3*zr*n
   ib = zi*q
   jc = zj*q
   kd = zk*q
   dr = cr*zr - ci*zi - cj*zj - ck*zk
   di = ci*zr + cr*zi + ck*zj - cj*zk
   dj = cj*zr - ck*zi + cr*zj + ci*zk
   dk = ck*zr + cj*zi - ci*zj + cr*zk
   zr = ra + dr - zr - cr
   zi = ib + di - zi - ci
   zj = jc + dj - zj - cj
   zk = kd + dk - zk - ck
  elseif @formula==12
   a = c*a*(1 - a^@power)
   b = d*b*(1 - b^@power)
   zr = (real(a) + real(b)) / 2
   zi = (imag(a) + imag(b)) / 2
   zj = (imag(a) - imag(b)) / 2
   zk = (real(b) - real(a)) / 2
  elseif @formula==13
   a = c*@fn1(a)
   b = d*@fn1(b)
   zr = (real(a) + real(b)) / 2
   zi = (imag(a) + imag(b)) / 2
   zj = (imag(a) - imag(b)) / 2
   zk = (real(b) - real(a)) / 2
  elseif @formula==14
   a = a*a*a + a*c - a - c
   b = b*b*b + b*d - b - d
   zr = (real(a) + real(b)) / 2
   zi = (imag(a) + imag(b)) / 2
   zj = (imag(a) - imag(b)) / 2
   zk = (real(b) - real(a)) / 2
  elseif @formula==15
   n = sqrt(zi^2 + zj^2 + zk^2)
  if n == 0
   n = 1e-20
  endif
   ra = sin(zr)*cosh(n)
   ib = cos(zr)*sinh(n) / n*zi
   jc = cos(zr)*sinh(n) / n*zj
   kd = cos(zr)*sinh(n) / n*zk
   zr = ra + cr
   zi = ib + ci
   zj = jc + cj
   zk = kd + ck
  elseif @formula==16
   n = sqrt(zi^2 + zj^2 + zk^2)
  if n == 0
   n = 1e-20
  endif
   ra = cos(zr)*cosh(n)
   ib =-sin(zr)*sinh(n) / n*zi
   jc =-sin(zr)*sinh(n) / n*zj
   kd =-sin(zr)*sinh(n) / n*zk
   zr = ra + cr
   zi = ib + ci
   zj = jc + cj
   zk = kd + ck
  elseif @formula==17
   n = sqrt(zi^2 + zj^2 + zk^2)
  if n == 0
   n = 1e-20
  endif
   ra = exp(zr)*cos(n)
   ib = exp(zr)*sin(n) / n*zi
   jc = exp(zr)*sin(n) / n*zj
   kd = exp(zr)*sin(n) / n*zk
   zr = ra + cr
   zi = ib + ci
   zj = jc + cj
   zk = kd + ck
  endif

 IF (@bailout >= zr^2 + zi^2 + zj^2 + zk^2)
   i = i + 1
 ELSEIF (stepnum >=  m)
   i = 0
   m = m + 1
   cr = x0 = x0 + dx
   ci = y0 = y0 + dy
   cj = z0 = z0 + dz
   ck = w0 = w0 + dw
   zr = 0.0
   zi = 0.0
   zj = 0.0
   zk = 0.0
 if @formula==8
   zr = 0.5
 elseif @formula==9
   zr = (1/3)^0.5
 elseif @formula==10
   zr = 0.25^(1/3)
 elseif @formula==12
   zr = real((1/(@power+1))^(1/@power))
   zi = imag((1/(@power+1))^(1/@power))
 elseif @formula==13
   zr = 0.0 + cr
   zi = 0.0 + ci
   zj = 0.0 + cj
   zk = 0.0 + ck
 endif
   a = zr - zk + flip(zi + zj)
   b = zr + zk + flip(zi - zj)
   c = cr - ck + flip(ci + cj)
   d = cr + ck + flip(ci - cj)
 ENDIF
  if (@coloring == 0)
   z = m - j
   j = j + 1
  else
   z = zr + flip(zi)
  endif

bailout:
  (@method == 0 && stepnum >= m && maxiter >= i) ||                                         \
  (@method == 1 && maxiter >= i)
default:
  title = "4D Mandelbrot Sets"
  maxiter = 10000
  periodicity = 0
  float param version
    default = 1.24
    visible = false
  endparam
  param formula
    caption = "Formula"
    enum = "Quaternion" "Cubic Quat" "Quartic Quat" "Hypernion" "Hyper fn" \
          "Hyper Barnsley 1" "Hyper Barnsley 2" "Hyper Barnsley 3" "Quat Lambda" \
          "Quat Lambda 2" "Quat Lambda 3" "Quat Ikenaga" "Hyper Lambda pwr" \
          "Hyper Lambda fn" "Hyper Ikenaga" "Quat Sin" "Quat Cos" "Quat Exp"
    default = 0
  endparam
  param p1
    caption = "From (cj, ck)"
    default = (1.0, 0.0)
  endparam
  param p2
    caption = "To (cj, ck)"
    default = (-1.0, 0.0)
  endparam
  param power
    caption = "Exponent"
    default = (2.0, 0.0)
    visible = @formula==3 || @formula==12
  endparam
  func fn1
    caption = "Function"
    default = sin()
    visible = @formula==4 || @formula==13
  endfunc
  param rotx
    caption = "Rotation zr"
    default = 0.0
  endparam
  param roty
    caption = "Rotation zi"
    default = 0.0
  endparam
  param rotz
    caption = "Rotation zj"
    default = 0.0
  endparam
  param rotw
    caption = "Rotation zk"
    default = 0.0
  endparam
  float param maxiter
    caption = "Maxiter"
    default = 50
  endparam
  float param stepnum
    caption = "Number of slices"
    default = 254
  endparam
  param coloring
    caption = "Coloring method"
    default = 0
    enum = "Fractint" "Ultra Fractal"
  endparam
  param method
    caption = "Bailout method"
    default = 0
    enum = "1" "2"
  endparam
  param bailout
    caption = "Bailout value"
    default = 128.0
  endparam
switch:
  type = "gnd-4D-J-sets"
  version = @version
  formula = @formula
  cri = #pixel
  p1 = @p1
  p2 = @p2
  power = @power
  rotx = @rotx
  roty = @roty
  rotz = @rotz
  rotw = @rotw
  maxiter = @maxiter
  stepnum = @stepnum
  coloring = @coloring
  method = @method
  bailout = @bailout
  fn1 = @fn1
}

gnd-gnarly-convolution {
; Based on the method "Convolution" by Mark Townsend.
; "Exponential smoothing" method from Ron Barnett.
; Use coloring algorithms include: Magnitude in mt.ucl,
; Exponential Smoothing in standard.ucl,
; Basic in lkm.ucl or Basic in standard.ucl.
; Gilles Nadeau, January 4 2008
init:
  complex z = (0,0)
  complex z1 = (0,0)
  complex z2 = (0,0)
  complex c = exp(1i * #pi * @rot / 180.0)
  float x = 0.0
  float y = 0.0
  float xx = 0.0
  float sx = 0.0
  float cz = 0.0
  float ez = 0.0
  float vd = 0.0
  float e1 = 0.0
  float e2 = 0.0
  float iter1 = 0.0
  float iter2 = 0.0
  int i = 0
  int j = 0
  int iter = 0
  int maxiter = @maxiter

 if @convolution == false
  z = #pixel / @scale + @offset
 else
  z1 = #pixel / @scale + @offset
  z2 = #pixel / @scale + @dis*c + @offset
 endif

if @version <= 1.2
 if @convolution == false

  x = real(z)
  y = imag(z)

  while i < maxiter
    xx = x
  if @formula == 0
    x = x - @h * real(@pn1(y + @pn2(@c * y)))
    y = y - @h * real(@pn3(xx + @pn4(@c * xx)))
  elseif @formula == 1
      if @flavor == 0
        x = x - @h * real(@vn1(y + @vn2(@a * y )))
        y = y + @h * real(@vn3(xx + @vn4(@a * xx)))
      elseif @flavor == 1
        x = x - @h * real(@vn1(y^@b + @vn2(@a * y)))
        y = y + @h * real(@vn3(xx^@b + @vn4(@a * xx)))
      elseif @flavor == 2
       x = x - @h * real(@vn1(y + @vn2(@a * (y + @vn3(@a * y)))))
       y = y + @h * real(@vn4(xx + @vn5(@a * (xx + @vn6(@a * xx)))))
      else
        float newx = y
        float newy = x
        int j = 0
        while j < @flavor
          j = j + 1
          newx = y + real(@vn7(@a * newx))
          newy = x + real(@vn8(@a * newy))
        endwhile
        x = x - @h * real(@vn9(newx))
        y = y + @h * real(@vn10(newy))
      endif
  elseif @formula == 2
    x = x - @h * real(@gn1(y + @gn2(@a * (y + @gn3(@b * y)))))
    y = y + @h * real(@gn4(xx + @gn5(@a * (xx + @gn6(@b * xx)))))
  elseif @formula == 3
    x = x - @h * real(@dn1(y + @a * @dn2(@b * y)))
    y = y + @h * real(@dn3(xx + @a * @dn4(@b * xx)))
  elseif @formula == 4
    x = y - real(@mn1(x))
    y = @a - xx
  elseif @formula == 5
    sx = 1.0
   if (x < 0.0)
    sx = -1.0
   endif
    x = y - sx * sqrt(abs(@b2 * x - @c2))
    y = @a2 - xx
  endif
    i = i + 1
  endwhile
    z = x + flip(y)

 else

    x = real(z1)
    y = imag(z1)
    i = 0

  while i < maxiter
    xx = x
  if @formula == 0
    x = x - @h * real(@pn1(y + @pn2(@c * y)))
    y = y - @h * real(@pn3(xx + @pn4(@c * xx)))
  elseif @formula == 1
      if @flavor == 0
        x = x - @h * real(@vn1(y + @vn2(@a * y )))
        y = y + @h * real(@vn3(xx + @vn4(@a * xx)))
      elseif @flavor == 1
        x = x - @h * real(@vn1(y^@b + @vn2(@a * y)))
        y = y + @h * real(@vn3(xx^@b + @vn4(@a * xx)))
      elseif @flavor == 2
       x = x - @h * real(@vn1(y + @vn2(@a * (y + @vn3(@a * y)))))
       y = y + @h * real(@vn4(xx + @vn5(@a * (xx + @vn6(@a * xx)))))
      else
        float newx = y
        float newy = x
        int j = 0
        while j < @flavor
          j = j + 1
          newx = y + real(@vn7(@a * newx))
          newy = x + real(@vn8(@a * newy))
        endwhile
        x = x - @h * real(@vn9(newx))
        y = y + @h * real(@vn10(newy))
      endif
  elseif @formula == 2
    x = x - @h * real(@gn1(y + @gn2(@a * (y + @gn3(@b * y)))))
    y = y + @h * real(@gn4(xx + @gn5(@a * (xx + @gn6(@b * xx)))))
  elseif @formula == 3
    x = x - @h * real(@dn1(y + @a * @dn2(@b * y)))
    y = y + @h * real(@dn3(xx + @a * @dn4(@b * xx)))
  elseif @formula == 4
    x = y - real(@mn1(x))
    y = @a - xx
  elseif @formula == 5
    sx = 1.0
   if (x < 0.0)
    sx = -1.0
   endif
    x = y - sx * sqrt(abs(@b2 * x - @c2))
    y = @a2 - xx
  endif
    i = i + 1
  endwhile
    z1 = x + flip(y)

    x = real(z2)
    y = imag(z2)
    i = 0

  while i < maxiter
    xx = x
  if @formula == 0
    x = x - @h * real(@pn1(y + @pn2(@c * y)))
    y = y - @h * real(@pn3(xx + @pn4(@c * xx)))
  elseif @formula == 1
      if @flavor == 0
        x = x - @h * real(@vn1(y + @vn2(@a * y )))
        y = y + @h * real(@vn3(xx + @vn4(@a * xx)))
      elseif @flavor == 1
        x = x - @h * real(@vn1(y^@b + @vn2(@a * y)))
        y = y + @h * real(@vn3(xx^@b + @vn4(@a * xx)))
      elseif @flavor == 2
       x = x - @h * real(@vn1(y + @vn2(@a * (y + @vn3(@a * y)))))
       y = y + @h * real(@vn4(xx + @vn5(@a * (xx + @vn6(@a * xx)))))
      else
        float newx = y
        float newy = x
        int j = 0
        while j < @flavor
          j = j + 1
          newx = y + real(@vn7(@a * newx))
          newy = x + real(@vn8(@a * newy))
        endwhile
        x = x - @h * real(@vn9(newx))
        y = y + @h * real(@vn10(newy))
      endif
  elseif @formula == 2
    x = x - @h * real(@gn1(y + @gn2(@a * (y + @gn3(@b * y)))))
    y = y + @h * real(@gn4(xx + @gn5(@a * (xx + @gn6(@b * xx)))))
  elseif @formula == 3
    x = x - @h * real(@dn1(y + @a * @dn2(@b * y)))
    y = y + @h * real(@dn3(xx + @a * @dn4(@b * xx)))
  elseif @formula == 4
    x = y - real(@mn1(x))
    y = @a - xx
  elseif @formula == 5
    sx = 1.0
   if (x < 0.0)
    sx = -1.0
   endif
    x = y - sx * sqrt(abs(@b2 * x - @c2))
    y = @a2 - xx
  endif
    i = i + 1
  endwhile
    z2 = x + flip(y)

 if @zmod == 0
  iter1 = log(exp(-cabs(z1)))
  iter2 = log(exp(-cabs(z2)))
 else
  iter1 = cabs(z1)
  iter2 = cabs(z2)
 endif
  e1 = iter1 * 0.5 * @w
  e2 = iter2 * 0.5 * @w
  ez = e2 - e1
  cz = @dis
  z = ez / cz + 0.5
 endif
endif

loop:
  iter = iter + 1

if @version > 1.2
 if @convolution == false

  x = real(z)
  y = imag(z)
  xx = x
  if @formula == 0
    x = x - @h * real(@pn1(y + @pn2(@c * y)))
    y = y - @h * real(@pn3(xx + @pn4(@c * xx)))
  elseif @formula == 1
      if @flavor == 0
        x = x - @h * real(@vn1(y + @vn2(@a * y )))
        y = y + @h * real(@vn3(xx + @vn4(@a * xx)))
      elseif @flavor == 1
        x = x - @h * real(@vn1(y^@b + @vn2(@a * y)))
        y = y + @h * real(@vn3(xx^@b + @vn4(@a * xx)))
      elseif @flavor == 2
       x = x - @h * real(@vn1(y + @vn2(@a * (y + @vn3(@a * y)))))
       y = y + @h * real(@vn4(xx + @vn5(@a * (xx + @vn6(@a * xx)))))
      else
        float newx = y
        float newy = x
        int j = 0
        while j < @flavor
          j = j + 1
          newx = y + real(@vn7(@a * newx))
          newy = x + real(@vn8(@a * newy))
        endwhile
        x = x - @h * real(@vn9(newx))
        y = y + @h * real(@vn10(newy))
      endif
  elseif @formula == 2
    x = x - @h * real(@gn1(y + @gn2(@a * (y + @gn3(@b * y)))))
    y = y + @h * real(@gn4(xx + @gn5(@a * (xx + @gn6(@b * xx)))))
  elseif @formula == 3
    x = x - @h * real(@dn1(y + @a * @dn2(@b * y)))
    y = y + @h * real(@dn3(xx + @a * @dn4(@b * xx)))
  elseif @formula == 4
    x = y - real(@mn1(x))
    y = @a - xx
  elseif @formula == 5
    sx = 1.0
   if (x < 0.0)
    sx = -1.0
   endif
    x = y - sx * sqrt(abs(@b2 * x - @c2))
    y = @a2 - xx
  endif
    z = x + flip(y)

 else

    x = real(z1)
    y = imag(z1)
    xx = x
  if @formula == 0
    x = x - @h * real(@pn1(y + @pn2(@c * y)))
    y = y - @h * real(@pn3(xx + @pn4(@c * xx)))
  elseif @formula == 1
      if @flavor == 0
        x = x - @h * real(@vn1(y + @vn2(@a * y )))
        y = y + @h * real(@vn3(xx + @vn4(@a * xx)))
      elseif @flavor == 1
        x = x - @h * real(@vn1(y^@b + @vn2(@a * y)))
        y = y + @h * real(@vn3(xx^@b + @vn4(@a * xx)))
      elseif @flavor == 2
       x = x - @h * real(@vn1(y + @vn2(@a * (y + @vn3(@a * y)))))
       y = y + @h * real(@vn4(xx + @vn5(@a * (xx + @vn6(@a * xx)))))
      else
        float newx = y
        float newy = x
        int j = 0
        while j < @flavor
          j = j + 1
          newx = y + real(@vn7(@a * newx))
          newy = x + real(@vn8(@a * newy))
        endwhile
        x = x - @h * real(@vn9(newx))
        y = y + @h * real(@vn10(newy))
      endif
  elseif @formula == 2
    x = x - @h * real(@gn1(y + @gn2(@a * (y + @gn3(@b * y)))))
    y = y + @h * real(@gn4(xx + @gn5(@a * (xx + @gn6(@b * xx)))))
  elseif @formula == 3
    x = x - @h * real(@dn1(y + @a * @dn2(@b * y)))
    y = y + @h * real(@dn3(xx + @a * @dn4(@b * xx)))
  elseif @formula == 4
    x = y - real(@mn1(x))
    y = @a - xx
  elseif @formula == 5
    sx = 1.0
   if (x < 0.0)
    sx = -1.0
   endif
    x = y - sx * sqrt(abs(@b2 * x - @c2))
    y = @a2 - xx
  endif
    z1 = x + flip(y)

    x = real(z2)
    y = imag(z2)
    xx = x
  if @formula == 0
    x = x - @h * real(@pn1(y + @pn2(@c * y)))
    y = y - @h * real(@pn3(xx + @pn4(@c * xx)))
  elseif @formula == 1
      if @flavor == 0
        x = x - @h * real(@vn1(y + @vn2(@a * y )))
        y = y + @h * real(@vn3(xx + @vn4(@a * xx)))
      elseif @flavor == 1
        x = x - @h * real(@vn1(y^@b + @vn2(@a * y)))
        y = y + @h * real(@vn3(xx^@b + @vn4(@a * xx)))
      elseif @flavor == 2
       x = x - @h * real(@vn1(y + @vn2(@a * (y + @vn3(@a * y)))))
       y = y + @h * real(@vn4(xx + @vn5(@a * (xx + @vn6(@a * xx)))))
      else
        float newx = y
        float newy = x
        int j = 0
        while j < @flavor
          j = j + 1
          newx = y + real(@vn7(@a * newx))
          newy = x + real(@vn8(@a * newy))
        endwhile
        x = x - @h * real(@vn9(newx))
        y = y + @h * real(@vn10(newy))
      endif
  elseif @formula == 2
    x = x - @h * real(@gn1(y + @gn2(@a * (y + @gn3(@b * y)))))
    y = y + @h * real(@gn4(xx + @gn5(@a * (xx + @gn6(@b * xx)))))
  elseif @formula == 3
    x = x - @h * real(@dn1(y + @a * @dn2(@b * y)))
    y = y + @h * real(@dn3(xx + @a * @dn4(@b * xx)))
  elseif @formula == 4
    x = y - real(@mn1(x))
    y = @a - xx
  elseif @formula == 5
    sx = 1.0
   if (x < 0.0)
    sx = -1.0
   endif
    x = y - sx * sqrt(abs(@b2 * x - @c2))
    y = @a2 - xx
  endif
    z2 = x + flip(y)

 if @zmod == 0
  iter1 = iter1 + exp(-cabs(z1))
  iter2 = iter2 + exp(-cabs(z2))
 else
  iter1 = cabs(z1)
  iter2 = cabs(z2)
 endif

 if @zmod == 0
  e1 = log(iter1) * @w
  e2 = log(iter2) * @w
 else
  e1 = iter1 * 0.5 * @w
  e2 = iter2 * 0.5 * @w
 endif
  ez = e2 - e1
  cz = @dis
  vd = sqrt(sqr(ez) + sqr(cz))
  z = ez / vd + 0.5
 endif
endif
bailout:
  (@version <= 1.2 && iter < 2) || \
  (@version > 1.2 && iter < #maxiter)
default:
  title = "Embossed Gnarly (Convolution)"
  maxiter = 20
  method = multipass
  periodicity = 0
  float param version
    caption = "Version"
    default = 1.21
    visible = false
  endparam
  heading
    caption = "Global Settings"
  endheading
  param formula
    caption = "Formula"
    enum = "Popcorn" "Vine" "Gnarl" "Dynamic" "Martin" "Hopalong"
    default = 0
  endparam
  float param scale
    caption = "Scale"
    default = 0.2
  endparam
  int param maxiter
    caption = "Iterations"
    default = 20
    min = 1
    visible = @version <= 1.2
  endparam
  complex param offset
  caption = "Offset"
    default = (0.0, 0.0)
  endparam
  heading
  caption = "Formula Parameters"
  endheading
  float param h
    caption = "Step Size"
    default = 0.05
    visible = @formula == 0 || @formula == 1  || @formula == 2  || @formula == 3
  endparam
  int param flavor
    caption = "Vine Flavor"
    default = 2
    min = 0
    visible = @formula == 1
  endparam
  float param a
    caption = "A"
    default = 3
    visible = @formula == 1 || @formula == 2  || @formula == 3  || @formula == 4
  endparam
  float param b
    caption = "B"
    default = 2
    visible = @formula == 1  && @flavor == 1 || @formula == 2  || @formula == 3
  endparam
  float param c
    caption = "C"
    default = 3
    visible = @formula == 0
  endparam
  float param a2
    caption = "A"
    default = 0.4
    visible = @formula == 5
  endparam
  float param b2
    caption = "B"
    default = 1
    visible = @formula == 5
  endparam
  float param c2
    caption = "C"
    default = 0
    visible = @formula == 5
  endparam
  heading
  caption = "Popcorn Functions"
  visible = @formula == 0
  endheading
  func pn1
    caption = "Popcorn #1"
    default = sin()
    visible = @formula == 0
  endfunc
  func pn2
    caption = "Popcorn #2"
    default = tan()
    visible = @formula == 0
  endfunc
  func pn3
    caption = "Popcorn #3"
    default = sin()
    visible = @formula == 0
  endfunc
  func pn4
    caption = "Popcorn #4"
    default = tan()
    visible = @formula == 0
  endfunc
  heading
  caption = "Vine Functions"
  visible = @formula == 1
  endheading
  func vn1
    caption = "Vine #1"
    default = sin()
    visible = @formula == 1 && @flavor < 3
  endfunc
  func vn2
    caption = "Vine #2"
    default = sin()
    visible = @formula == 1 && @flavor < 3
  endfunc
  func vn3
    caption = "Vine #3"
    default = sin()
    visible = @formula == 1 && @flavor < 3
  endfunc
  func vn4
    caption = "Vine #4"
    default = sin()
    visible = @formula == 1 && @flavor < 3
  endfunc
  func vn5
    caption = "Vine #5"
    default = sin()
    visible = @formula == 1 && @flavor == 2
  endfunc
  func vn6
    caption = "Vine #6"
    default = sin()
    visible = @formula == 1 && @flavor == 2
  endfunc
  func vn7
    caption = "Vine #7"
    default = sin()
    visible = @formula == 1 && @flavor > 2
  endfunc
  func vn8
    caption = "Vine #8"
    default = sin()
    visible = @formula == 1 && @flavor > 2
  endfunc
  func vn9
    caption = "Vine #9"
    default = sin()
    visible = @formula == 1 && @flavor > 2
  endfunc
  func vn10
    caption = "Vine #10"
    default = sin()
    visible = @formula == 1 && @flavor > 2
  endfunc
  heading
  caption = "Gnarl Functions"
  visible = @formula == 2
  endheading
  func gn1
    caption = "Gnarl #1"
    default = sin()
    visible = @formula == 2
  endfunc
  func gn2
    caption = "Gnarl #2"
    default = sin()
    visible = @formula == 2
  endfunc
  func gn3
    caption = "Gnarl #3"
    default = sin()
    visible = @formula == 2
  endfunc
  func gn4
    caption = "Gnarl #4"
    default = sin()
    visible = @formula == 2
  endfunc
  func gn5
    caption = "Gnarl #5"
    default = sin()
    visible = @formula == 2
  endfunc
  func gn6
    caption = "Gnarl #6"
    default = sin()
    visible = @formula == 2
  endfunc
  heading
  caption = "Dynamic Functions"
  visible = @formula == 3
  endheading
  func dn1
    caption = "Dynamic #1"
    default = sin()
    visible = @formula == 3
  endfunc
  func dn2
    caption = "Dynamic #2"
    default = sin()
    visible = @formula == 3
  endfunc
  func dn3
    caption = "Dynamic #3"
    default = sin()
    visible = @formula == 3
  endfunc
  func dn4
    caption = "Dynamic #4"
    default = sin()
    visible = @formula == 3
  endfunc
  func mn1
    caption = "Martin Function"
    default = sin()
    visible = @formula == 4
  endfunc
  bool param convolution
    caption = "Convolution"
    default = true
  endparam
  heading
    caption = "Convolution Parameters"
    visible = @convolution == true
  endheading
  param zmod
    caption = "Height Value"
    enum = "Exponential Smoothing" "Magnitude"
    default = 0
    visible = @convolution == true
  endparam
  float param w
    caption = "Weight"
    default = 0.1
    visible = @convolution == true
  endparam
  float param dis
    caption = "Distance"
    default = 0.01
    visible = @convolution == true
  endparam
  float param rot
    caption = "Light Rotation"
    default = 0.0
    visible = @convolution == true
  endparam
}

gnd-MandelJulia {
init:
  z = (0,0)
 if @method == 0
  c = #pixel
  d = @seed - c
 else
  c = @seed
  d = #pixel - c
 endif
  int i = 0
  int j = 0
  int k = 0
 if @method == 1
  while j < 2 && k == 0
   z = #pixel
   c = c + d
   j = j + 1
  while |z| <= @bailout && i <= #maxiter
   z = z^@power + c
   i = i + 1
  endwhile
  if |z| <= @bailout
   k = 1
  endif
  endwhile
   z = #pixel
   c = c - d
 endif
loop:
   z = z^@power + c

 if @method == 0
  if |z| <= @bailout
  else
   z = #pixel
   c = c + d
   j = j + 1
  endif
 endif
bailout:
 (@method == 0 && j < 2) ||        \
 (@method == 1 && |z| <= @bailout)

default:
  title = "Mandel Julia"
  maxiter = 500
  periodicity = 0
  method = multipass
  float param version
    caption = "Version"
    default = 1.1
    visible = false
  endparam
  param seed
    caption = "Julia seed"
    default = (0.26,0)
  endparam
  param power
    caption = "Exponent"
    default = (2,0)
  endparam
  param method
    caption = "Method"
    default = 0
    enum = "1" "2"
  endparam
  float param bailout
    caption = "Bailout value"
    default = 4.0
    min = 1
  endparam
}

gnd-slope_3d-julibrot {
; based upon the slope (Julia)
; formula of Damien Jones
; Julibrot formula
; compound with the models of slope formulas from Ron Barnett.
; 3d method based on the Quaternion formula by Stig Pettersson.
; Gilles Nadeau, 11/11/2007
;
init:
  complex z1 = #pixel
  complex z2 = #pixel + @offset; horizontally offset point
  complex z3 = #pixel + flip(@offset); vertically offset point
  complex c1 = @seed
  complex c2 = c1
  complex c3 = c1
  complex c0 = c1
  complex c1 = c0
  float rx = 0.0
  float ry = 0.0
  float rz = 0.0
  float rw = 0.0
  int done = 2
  float e1 = 0.0; potentials
  float e2 = 0.0
  float e3 = 0.0
  float vx = 0.0; normal vector
  float vy = 0.0
  float vz = 0.0
  float vd = 0.0
  float iterexp1 = 0.0
  float iterexp2 = 0.0
  float iterexp3 = 0.0
  bool set1 = false

 if (@dim3 == true)
  int stepnum = @stepnum
  complex delta = (@seed2 - c1) / stepnum
  int n = 0
  int i = 0

  while (n < stepnum) && (set1 == false)
   z1 = #pixel
   z2 = #pixel + @offset
   z3 = #pixel + flip(@offset)
   c1 = c0 = c0 + delta
   c2 = c1
   c3 = c1

   ry = imag(z1)*cos(#pi*@rotx/180) - real(c1)*sin(#pi*@rotx/180)
   rz = imag(z1)*sin(#pi*@rotx/180) + real(c1)*cos(#pi*@rotx/180)
   z1 = real(z1) + ry*1i
   c1 = rz + imag(c1)*1i

   rx = real(c1)*sin(#pi*@roty/180) + real(z1)*cos(#pi*@roty/180)
   rz = real(c1)*cos(#pi*@roty/180) - real(z1)*sin(#pi*@roty/180)
   z1 = rx + imag(z1)*1i
   c1 = rz + imag(c1)*1i

   ry = real(z1)*cos(#pi*@rotz/180) - imag(c1)*sin(#pi*@rotz/180)
   rw = real(z1)*sin(#pi*@rotz/180) + imag(c1)*cos(#pi*@rotz/180)
   z1 = ry + imag(z1)*1i
   c1 = real(c1) + rw*1i

   rx = imag(c1)*sin(#pi*@rotw/180) + imag(z1)*cos(#pi*@rotw/180)
   rw = imag(c1)*cos(#pi*@rotw/180) - imag(z1)*sin(#pi*@rotw/180)
   z1 = real(z1) + rx*1i
   c1 = real(c1) + rw*1i


 if (@slope)

   ry = imag(z2)*cos(#pi*@rotx/180) - real(c2)*sin(#pi*@rotx/180)
   rz = imag(z2)*sin(#pi*@rotx/180) + real(c2)*cos(#pi*@rotx/180)
   z2 = real(z2) + ry*1i
   c2 = rz + imag(c2)*1i

   ry = imag(z3)*cos(#pi*@rotx/180) - real(c3)*sin(#pi*@rotx/180)
   rz = imag(z3)*sin(#pi*@rotx/180) + real(c3)*cos(#pi*@rotx/180)
   z3 = real(z3) + ry*1i
   c3 = rz + imag(c3)*1i

   rx = real(c2)*sin(#pi*@roty/180) + real(z2)*cos(#pi*@roty/180)
   rz = real(c2)*cos(#pi*@roty/180) - real(z2)*sin(#pi*@roty/180)
   z2 = rx + imag(z2)*1i
   c2 = rz + imag(c2)*1i

   rx = real(c3)*sin(#pi*@roty/180) + real(z3)*cos(#pi*@roty/180)
   rz = real(c3)*cos(#pi*@roty/180) - real(z3)*sin(#pi*@roty/180)
   z3 = rx + imag(z3)*1i
   c3 = rz + imag(c3)*1i

   ry = real(z2)*cos(#pi*@rotz/180) - imag(c2)*sin(#pi*@rotz/180)
   rw = real(z2)*sin(#pi*@rotz/180) + imag(c2)*cos(#pi*@rotz/180)
   z2 = ry + imag(z2)*1i
   c2 = real(c2) + rw*1i

   ry = real(z3)*cos(#pi*@rotz/180) - imag(c3)*sin(#pi*@rotz/180)
   rw = real(z3)*sin(#pi*@rotz/180) + imag(c3)*cos(#pi*@rotz/180)
   z3 = ry + imag(z3)*1i
   c3 = real(c3) + rw*1i

   rx = imag(c2)*sin(#pi*@rotw/180) + imag(z2)*cos(#pi*@rotw/180)
   rw = imag(c2)*cos(#pi*@rotw/180) - imag(z2)*sin(#pi*@rotw/180)
   z2 = real(z2) + rx*1i
   c2 = real(c2) + rw*1i

   rx = imag(c3)*sin(#pi*@rotw/180) + imag(z3)*cos(#pi*@rotw/180)
   rw = imag(c3)*cos(#pi*@rotw/180) - imag(z3)*sin(#pi*@rotw/180)
   z3 = real(z3) + rx*1i
   c3 = real(c3) + rw*1i
 endif

     while (i < #maxiter) && (|z1| < @bailout)
       z1 = z1^@power + c1
      if (@slope)
       z2 = z2^@power + c2
       z3 = z3^@power + c3
      endif
       i = i + 1
     endwhile
       i = 0
       n = n + 1

     if (|z1| < @bailout)
       set1 = true
     endif

  endwhile
  if (@solid == false)
   z1 = #pixel
   z2 = #pixel + @offset
   z3 = #pixel + flip(@offset)
   c1 = c0 = c0 - delta
   c2 = c1
   c3 = c1
  elseif (set1 == true)
   z1 = #pixel
   z2 = #pixel + @offset
   z3 = #pixel + flip(@offset)
   c1 = c0 = c0 - delta
   c2 = c1
   c3 = c1
  else
   z1 = (0,0)
   z2 = (0,0)
   z3 = (0,0)
   c1 = (0,0)
   c2 = (0,0)
   c3 = (0,0)
  endif
 endif

   ry = imag(z1)*cos(#pi*@rotx/180) - real(c1)*sin(#pi*@rotx/180)
   rz = imag(z1)*sin(#pi*@rotx/180) + real(c1)*cos(#pi*@rotx/180)
   z1 = real(z1) + ry*1i
   c1 = rz + imag(c1)*1i

   rx = real(c1)*sin(#pi*@roty/180) + real(z1)*cos(#pi*@roty/180)
   rz = real(c1)*cos(#pi*@roty/180) - real(z1)*sin(#pi*@roty/180)
   z1 = rx + imag(z1)*1i
   c1 = rz + imag(c1)*1i

   ry = real(z1)*cos(#pi*@rotz/180) - imag(c1)*sin(#pi*@rotz/180)
   rw = real(z1)*sin(#pi*@rotz/180) + imag(c1)*cos(#pi*@rotz/180)
   z1 = ry + imag(z1)*1i
   c1 = real(c1) + rw*1i

   rx = imag(c1)*sin(#pi*@rotw/180) + imag(z1)*cos(#pi*@rotw/180)
   rw = imag(c1)*cos(#pi*@rotw/180) - imag(z1)*sin(#pi*@rotw/180)
   z1 = real(z1) + rx*1i
   c1 = real(c1) + rw*1i


 if (@slope)

   ry = imag(z2)*cos(#pi*@rotx/180) - real(c2)*sin(#pi*@rotx/180)
   rz = imag(z2)*sin(#pi*@rotx/180) + real(c2)*cos(#pi*@rotx/180)
   z2 = real(z2) + ry*1i
   c2 = rz + imag(c2)*1i

   ry = imag(z3)*cos(#pi*@rotx/180) - real(c3)*sin(#pi*@rotx/180)
   rz = imag(z3)*sin(#pi*@rotx/180) + real(c3)*cos(#pi*@rotx/180)
   z3 = real(z3) + ry*1i
   c3 = rz + imag(c3)*1i

   rx = real(c2)*sin(#pi*@roty/180) + real(z2)*cos(#pi*@roty/180)
   rz = real(c2)*cos(#pi*@roty/180) - real(z2)*sin(#pi*@roty/180)
   z2 = rx + imag(z2)*1i
   c2 = rz + imag(c2)*1i

   rx = real(c3)*sin(#pi*@roty/180) + real(z3)*cos(#pi*@roty/180)
   rz = real(c3)*cos(#pi*@roty/180) - real(z3)*sin(#pi*@roty/180)
   z3 = rx + imag(z3)*1i
   c3 = rz + imag(c3)*1i

   ry = real(z2)*cos(#pi*@rotz/180) - imag(c2)*sin(#pi*@rotz/180)
   rw = real(z2)*sin(#pi*@rotz/180) + imag(c2)*cos(#pi*@rotz/180)
   z2 = ry + imag(z2)*1i
   c2 = real(c2) + rw*1i

   ry = real(z3)*cos(#pi*@rotz/180) - imag(c3)*sin(#pi*@rotz/180)
   rw = real(z3)*sin(#pi*@rotz/180) + imag(c3)*cos(#pi*@rotz/180)
   z3 = ry + imag(z3)*1i
   c3 = real(c3) + rw*1i

   rx = imag(c2)*sin(#pi*@rotw/180) + imag(z2)*cos(#pi*@rotw/180)
   rw = imag(c2)*cos(#pi*@rotw/180) - imag(z2)*sin(#pi*@rotw/180)
   z2 = real(z2) + rx*1i
   c2 = real(c2) + rw*1i

   rx = imag(c3)*sin(#pi*@rotw/180) + imag(z3)*cos(#pi*@rotw/180)
   rw = imag(c3)*cos(#pi*@rotw/180) - imag(z3)*sin(#pi*@rotw/180)
   z3 = real(z3) + rx*1i
   c3 = real(c3) + rw*1i
 endif

loop:

   z1 = z1^@power + c1

 if (@slope == true)

   z2 = z2^@power + c2
   z3 = z3^@power + c3

   iterexp1 = iterexp1 + exp(-cabs(z1))
   iterexp2 = iterexp2 + exp(-cabs(z2))
   iterexp3 = iterexp3 + exp(-cabs(z3))
   done = done + 1; increment iteration counter

  IF (@bailout < |z1| ||                \
      @everyiter ||\
      done == #maxit + 2); done, or every iteration, or last
    ; determine continuous iteration (height) for each point

      e1 = iterexp1 * @zscale
      e2 = iterexp2 * @zscale
      e3 = iterexp3 * @zscale

    ; apply transfer function
    ; a function is not used because these are floats
    ; and not all functions apply to floats
    IF (@xfer == 1); log
      e1 = log(e1)
      e2 = log(e2)
      e3 = log(e3)
    ELSEIF (@xfer == 2); sqrt
      e1 = sqrt(e1)
      e2 = sqrt(e2)
      e3 = sqrt(e3)
    ELSEIF (@xfer == 3); cuberoot
      e1 = (e1)^(1/3)
      e2 = (e2)^(1/3)
      e3 = (e3)^(1/3)
    ELSEIF (@xfer == 4); exp
      e1 = exp(e1)
      e2 = exp(e2)
      e3 = exp(e3)
    ELSEIF (@xfer == 5); sqr
      e1 = sqr(e1)
      e2 = sqr(e2)
      e3 = sqr(e3)
    ELSEIF (@xfer == 6); cube
      e1 = (e1)^3
      e2 = (e2)^3
      e3 = (e3)^3
    ELSEIF (@xfer == 7); sin
      e1 = sin(e1)
      e2 = sin(e2)
      e3 = sin(e3)
    ELSEIF (@xfer == 8); cos
      e1 = cos(e1)
      e2 = cos(e2)
      e3 = cos(e3)
    ELSEIF (@xfer == 9); tan
      e1 = tan(e1)
      e2 = tan(e2)
      e3 = tan(e3)
    ENDIF

    ; apply post-scale
    e1 = e1 * @zscale2
    e2 = e2 * @zscale2
    e3 = e3 * @zscale2

      vx = e2-e1
      vy = e3-e1
      vz = -@offset
      ; normalize vector
      vd = 1/sqrt(sqr(vx)+sqr(vy)+sqr(vz))
      vx = vx*vd
      vy = vy*vd
      vz = vz*vd
      z = vx + flip(vy); fudge z from vector
  ELSE; didn't compute z this time
    z = z1; use primary iteration value to keep periodicity working
  ENDIF
 else
    z = z1
 endif
  IF (@bailout < |z1|)                  ; we're done
    done = 0
  ENDIF

bailout:
  (done > 0)

default:
  title = "Slope 3D Julibrot"
  maxiter = 149

  param version
    caption = "Version"
    default = 1.12
    visible = false
  endparam

  param seed2
    caption = "From C"
    default = (-0.83, 0.25)
    visible = @dim3 == true
  endparam

  param seed
    caption = "To C"
    default = (-0.83, -0.25)
  endparam

  param rotx
    caption = "X Rotation"
    hint = "Rotates yz-plane."
    default = 0.0
    min = -360.0
    max = 360.0
  endparam

  param roty
    caption = "Y Rotation"
    hint = "Rotates xz-plane."
    default = 0.0
    min = -360.0
    max = 360.0
  endparam

  param rotz
    caption = "Z Rotation"
    hint = "Rotates yw-plane."
    default = 0.0
    min = -360.0
    max = 360.0
  endparam

  param rotw
    caption = "W Rotation"
    hint = "Rotates xw-plane."
    default = 0.0
    min = -360.0
    max = 360.0
  endparam

  param power
    caption = "Exponent"
    default = (2.0, 0.0)
  endparam

  param bailout
    caption = "Bailout Value"
    default = 128.0
    min = 0.0
    hint = "Defines how soon an orbit bails out, i.e. doesn't \
            belong to the set anymore."
  endparam

  bool param dim3
    caption = "3D"
    default = true
  endparam

  bool param solid
    caption = "Solid Color"
    default = true
    visible = @dim3 == true
  endparam

  param stepnum
    caption = "Number Of Slices"
    default = 250
    visible = @dim3 == true
  endparam

  bool param slope
    caption = "Slope"
    default = true
  endparam

  heading
    caption = "Slope Parameters"
    visible = @slope == true
  endheading

  param offset
    caption = "Orbit Separation"
    default = 0.00000001
    hint = "Defines how far apart the simultaneous orbits are.  Smaller \
            distances will produce more accurate results."
    visible = @slope==true
  endparam

  param xfer
    caption = "Height Transfer"
    default = 0
    enum = "linear" "log" "sqrt" "cuberoot" "exp" "sqr" "cube" "sin" "cos" "tan"
    hint = "This function will be applied to the height value \
            before a slope is calculated."
    visible = @slope==true
  endparam

  param zscale
    caption = "Height Pre-Scale"
    default = 1.0
    hint = "Specifies the ratio between height and distance.  Higher \
            values will exaggerate differences between high and low. \
    In general, you will want to use smaller numbers here."
    visible = @slope==true
  endparam

  param zscale2
    caption = "Height Post-Scale"
    default = 0.025
    hint = "Specifies the ratio between height and distance; like \
            Height Pre-Scale, except that this value is applied after \
    the transfer function."
    visible = @slope==true
  endparam

  param everyiter
    caption = "Every Iteration"
    default = false
    hint = "If set, the surface normal will be computed at every \
            iteration.  If you are using a coloring algorithm which \
    processes every iteration, you will need this."
    visible = @slope==true
  endparam
}

gnd-4D-Julia(Raytrace) {
;
;Based on the formula Raytrace from Stig Pettersson.
;To use this module you will need the
;coloring-algoritm Raytrace in spr.ucl

init:
  bool setflag=true
  bool tflag=false
  int iter=0
  int m=0
  int mm=0
  int count2=0
  int n=0
  complex z=0
  complex zri=0
  complex zjk=0
  complex na=0
  complex nb=0
  complex cri=0
  complex cjk=0
  complex a=0
  complex b=0
  complex c=0
  complex d=0
  complex ca=0
  complex cb=0
  float zr=0
  float zi=0
  float zj=0
  float zk=0
  float cr=0
  float ci=0
  float cj=0
  float ck=0
  float x1=0
  float y1=0
  float z1=0
  float w1=0
  float x2=0
  float y2=0
  float z2=0
  float w2=0
  float ra=0
  float ib=0
  float jc=0
  float kd=0
  float xa=0
  float ya=0
  float xb=0
  float yb=0
  float xc=0
  float yc=0
  float xd=0
  float yd=0
  float q=0
  float s=0
  float t=0
  float color1=-1.23456789e20
  float color2=1.23456789e20
  float temp0=0
  float lightdx=0
  float lightdy=0
  float lightdz=0
  float lightlength=0
  float flength=0
  float fx=0
  float fy=0
  float fz=0
  float tangle=0
  float buff0=0
  float buff1=0
  float buff2=0
  float buff3=0
  float buff4=0
  float diffx=0
  float diffy=0
  float count=0
  float count0=0
  float xx=0
  float yy=0
  float zz=0
  float ww=0
  float length=0.0
  float xscreen=real(#screenmax)
  float yscreen=imag(#screenmax)
  float zscreen=@zscreen
  float xmin=0
  float ymin=0
  float xmax=0
  float ymax=0
  if xscreen/yscreen>4/3
    temp0=3/#magn
    float temp0=-3/#magn
    ymin=imag(#center)-temp0/2
    ymax=ymin+temp0
    temp0=-xscreen/yscreen*temp0
    xmin=real(#center)-temp0/2
    xmax=xmin+temp0
  else
    temp0=4/#magn
    xmin=real(#center)-temp0/2
    xmax=xmin+temp0
    temp0=-yscreen/xscreen*temp0
    ymin=imag(#center)-temp0/2
    ymax=ymin+temp0
  endif
  float zmax=@zorig+@zdist/2
  float zmin=zmax-@zdist
  if @view==1
    zmax=@zorig
    zmin=@zorig
  elseif @view==2
    zmax=@zorig-@zdist/2
    zmin=zmax
  endif
  if @zmagn==true
    zmax=@zorig+@zdist/2/#magn
    zmin=zmax-@zdist/#magn
  endif
  if (@autoscale==true)&&(@view==0)
    zscreen=xscreen/(xmax-xmin)*(zmax-zmin)
  endif
  float dx=(xmax-xmin)/xscreen
  float dy=(ymax-ymin)/yscreen
  float dz=(zmax-zmin)/zscreen
  float origx=real(#center)
  float origy=imag(#center)
  float origz=@zorig
  float vx=@xrot/180.0*#pi
  float vy=@yrot/180.0*#pi
  float vz=@zrot/180.0*#pi
  float cosx=0
  float cosy=0
  float cosz=0
  float sinx=0
  float siny=0
  float sinz=0
  if @xrot==90.0
    sinx=1.0
    cosx=0
  elseif @xrot==-90
    sinx=-1.0
    cosx=0
  elseif abs(@xrot)==180
    sinx=0
    cosx=-1
  else
    cosx=cos(vx)
    sinx=sin(vx)
  endif
  if @yrot==90.0
    siny=1.0
    cosy=0
  elseif @yrot==-90
    siny=-1.0
    cosy=0
  elseif abs(@yrot)==180
    siny=0
    cosy=-1
  else
    cosy=cos(vy)
    siny=sin(vy)
  endif
  if @zrot==90.0
    sinz=1.0
    cosz=0
  elseif @zrot==-90
    sinz=-1.0
    cosz=0
  elseif abs(@zrot)==180
    sinz=0
    cosz=-1
  else
    cosz=cos(vz)
    sinz=sin(vz)
  endif
  float rminx=0
  float rminy=0
  float rminz=0
  float xy=0
  float xz=0
  float yx=0
  float yz=0
  float zx=0
  float zy=0
  float tempx=0
  float tempy=0
  float tempz=0
  float dxx=0
  float dxy=0
  float dxz=0
  float dyx=0
  float dyy=0
  float dyz=0
  float dzx=0
  float dzy=0
  float dzz=0
  float dzx=0
  float dzy=0
  float dzz=0
  float dzx1=0
  float dzy1=0
  float dzz1=0
; rotating the space and creation of unit-vectors
  xx=rminx=xmin
  yy=rminy=ymin
  zz=rminz=zmin
if @local==true
  xx=xx-origx
  yy=yy-origy
  zz=zz-origz
endif
  xy=yy*cosx-zz*sinx
  xz=yy*sinx+zz*cosx
  yy=xy
  zz=xz
  yx=xx*cosy+zz*siny
  yz=-xx*siny+zz*cosy
  xx=yx
  zz=yz
  zx=xx*cosz-yy*sinz
  zy=xx*sinz+yy*cosz
  xx=zx
  yy=zy
if @local==true
  xx=xx+origx
  yy=yy+origy
zz=zz+origz
  endif
  rminx=xx
  rminy=yy
  rminz=zz
  xx=tempx=xmax
  yy=tempy=ymin
  zz=tempz=zmin
if @local==true
  xx=xx-origx
  yy=yy-origy
  zz=zz-origz
endif
  xy=yy*cosx-zz*sinx
  xz=yy*sinx+zz*cosx
  yy=xy
  zz=xz
  yx=xx*cosy+zz*siny
  yz=-xx*siny+zz*cosy
  xx=yx
  zz=yz
  zx=xx*cosz-yy*sinz
  zy=xx*sinz+yy*cosz
  xx=zx
  yy=zy
if @local==true
  xx=xx+origx
  yy=yy+origy
  zz=zz+origz
endif
  tempx=xx
  tempy=yy
  tempz=zz
  dxx=(tempx-rminx)/xscreen
  dxy=(tempy-rminy)/xscreen
  dxz=(tempz-rminz)/xscreen
  xx=tempx=xmin
  yy=tempy=ymax
  zz=tempz=zmin
if @local==true
  xx=xx-origx
  yy=yy-origy
  zz=zz-origz
endif
  xy=yy*cosx-zz*sinx
  xz=yy*sinx+zz*cosx
  yy=xy
  zz=xz
  yx=xx*cosy+zz*siny
  yz=-xx*siny+zz*cosy
  xx=yx
  zz=yz
  zx=xx*cosz-yy*sinz
  zy=xx*sinz+yy*cosz
  xx=zx
  yy=zy
if @local==true
  xx=xx+origx
  yy=yy+origy
  zz=zz+origz
endif
  tempx=xx
  tempy=yy
  tempz=zz
  dyx=(tempx-rminx)/yscreen
  dyy=(tempy-rminy)/yscreen
  dyz=(tempz-rminz)/yscreen
  xx=tempx=xmin
  yy=tempy=ymin
  zz=tempz=zmax
if @local==true
  xx=xx-origx
  yy=yy-origy
  zz=zz-origz
endif
  xy=yy*cosx-zz*sinx
  xz=yy*sinx+zz*cosx
  yy=xy
  zz=xz
  yx=xx*cosy+zz*siny
  yz=-xx*siny+zz*cosy
  xx=yx
  zz=yz
  zx=xx*cosz-yy*sinz
  zy=xx*sinz+yy*cosz
  xx=zx
  yy=zy
if @local==true
  xx=xx+origx
  yy=yy+origy
  zz=zz+origz
endif
  tempx=xx
  tempy=yy
  tempz=zz
  dzx=(tempx-rminx)/zscreen
  dzy=(tempy-rminy)/zscreen
  dzz=(tempz-rminz)/zscreen
  dzx1=dzx/@prec
  dzy1=dzy/@prec
  dzz1=dzz/@prec
; end rotation and creating unit-vectors 'puuh'
if @formula==0
  count0=0
  repeat
    diffx=0
    diffy=0
    if count0==1
      diffx=-@delta
    elseif count0==2
      diffx=@delta
    elseif count0==3
      diffy=@delta
    elseif count0==4
      diffy=-@delta
    endif
    tempx=rminx+(real(#screenpixel)+diffx)*dxx+(imag(#screenpixel)+diffy)*dyx
    tempy=rminy+(real(#screenpixel)+diffx)*dxy+(imag(#screenpixel)+diffy)*dyy
    tempz=rminz+(real(#screenpixel)+diffx)*dxz+(imag(#screenpixel)+diffy)*dyz
      if @fourthdim==3
        xx=tempx
        yy=tempy
        zz=tempz
        ww=@fourthvalue
      elseif @fourthdim==2
        xx=tempx
        yy=tempy
        zz=@fourthvalue
        ww=tempz
      elseif @fourthdim==1
        xx=tempz
        yy=@fourthvalue
        zz=tempx
        ww=tempy
      else
        xx=@fourthvalue
        yy=tempz
        zz=tempx
        ww=tempy
      endif
      count=0.0
      repeat
        if @fourthdim==3
          xx=xx+dzx
          yy=yy+dzy
          zz=zz+dzz
        elseif @fourthdim==2
          xx=xx+dzx
          yy=yy+dzy
          ww=ww+dzz
        elseif @fourthdim==1
          xx=xx+dzz
          zz=zz+dzx
          ww=ww+dzy
        else
          yy=yy+dzz
          zz=zz+dzx
          ww=ww+dzy
        endif

 endif
 if |b| < @shift
  d = cb * @fn1(b)
 else
  d = cb * @fn2(b)
 endif  
  z1 = (real(c) + real(d)) / 2 
  zi = (imag(c) + imag(d)) / 2
  zj = (imag(c) - imag(d)) / 2 
  zk = (real(d) - real(c)) / 2
  z = z1 + flip(zi)
  w = zj + flip(zk) 
bailout:

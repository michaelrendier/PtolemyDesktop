class KCC_CochleoidTrap( KCC_PlaneCurveTrapBase ) {
; The Cochleoid trap.
; <p>
; For an example of what this trap looks like,
; <a href="../additional/kcc5/Cochleoid Trap.jpg">click here</a>.
;
public:
  import "common.ulb"

  ; constructor
  func KCC_CochleoidTrap( Generic pparent )
    KCC_PlaneCurveTrapBase( pparent )
  endfunc


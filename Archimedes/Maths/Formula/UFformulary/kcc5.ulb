    pz = ApplyRatioAndSize( pz )

    x = real( pz )
    y = imag( pz )

    ; Compute the Dürer's Conchoid Curve.
    pz = @fn1(2*@fn2(y^(1+@shapeAdjust3))*(@fn3(x^(1+@shapeAdjust4))+ \
         @fn4(y^2*@shapeAdjust5))-2*@shapeAdjust2* \

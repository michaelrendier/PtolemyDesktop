class KCC_SerpentineCurveTrap( KCC_PlaneCurveTrapBase ) {
; The Serpentine Curve trap.
; <p>
; For an example of what this trap looks like,
; <a href="../additional/kcc5/Serpentine Curve Trap.jpg">click here</a>.
;
public:
  import "common.ulb"

  ; constructor
  func KCC_SerpentineCurveTrap( Generic pparent )
    KCC_PlaneCurveTrapBase( pparent )
  endfunc

  ; call this before each sequence of values to be trapped
  func Init( complex pz )
    KCC_PlaneCurveTrapBase.Init( pz )
  endfunc

  ; call this for each iteration being trapped
  float func Iterate( complex pz )
    pz = ApplyRatioAndSize( pz )

    x = real( pz )
    y = imag( pz )

    ; Compute the Serpentine Curve.
    pz = @fn1(@shapeAdjust1*@shapeAdjust2*@fn2(x^@shapeAdjust3)/ \
         @fn3((x+1-@shapeAdjust3)^2+@shapeAdjust1^2)- \
         @fn4(y^@shapeAdjust4))-@distort

    ; Check to see if the point is trapped.
    return KCC_PlaneCurveTrapBase.Iterate( pz )
  endfunc

  float func GetTextureValue()
    return m_Texture
  endfunc


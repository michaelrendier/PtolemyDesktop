   default=false
endparam

heading
   caption="Functions"
endheading

func Fn1
   caption="Function 1"
   default=ident()
endfunc 

func Fn2
   caption="Function 2"
   default=ident()
endfunc

switch:
   type="IntoTheFantasy-M"
   @seed=#pixel
   bailout=@bailout
   invert=@invert
   P1=@P1
   P2=P2
   fn1=@fn1
   fn2=@fn2
}


Lonelyness{

; Copyright Miriana Penzo 2003
; Credits to Andrea Spinozzi

init:

z=@startseed
c=#pixel
q=(1,1)


if @mode=="mandelbrot" 
 z=@startseed
 c=#pixel
endif
if @mode=="Julia"
 z=#pixel
 c=@startseed
endif


loop:

x=(fn4(z^@d)+z)*(@fn5(z)+@fn6(z))
y=fn1(@c*fn2(z^@a)*cabs(q))+fn3(c)
j=@fn7(c)*z


if @op=="1"
 z=x^y+j
 elseif @op=="2"
 z=x^y+j+y
 elseif @op=="3"
 z=x^y+j-y
 elseif @op=="4"
 z=x^y+j*y
 elseif @op=="5"
 z=x^y+j/y
 elseif @op=="6"
 z=x^y+j^y
endif
 
bailout:
   |z|<@bailout
   
default:
   title="Lonelyness"
   center=(-0.5,0.0)
   magn=1.0
   angle=90
   
float param bailout
   caption="Bailout"
   default=4
endparam

param mode
 caption="Current Mode"
 enum="Mandelbrot""Julia"
 default=0
endparam
param switchmode
 caption="Switch To"
 enum="Mandelbrot""Julia"
 default=1
endparam

heading
   caption="Parameters"
endheading

param op
 caption="Select Mode"
 enum="1""2""3""4""5""6"
 default = 2
endparam
 
complex param startseed
   caption="Init z/Seed Value"
   default=(0.55,8.253489038e-19)
endparam
 
param a
   caption="Param. 1"
   default=(0.5,0.0)
endparam
 
param b
   caption="Param. 2"
   default=(0.5,0.0)
endparam
 
param c
   caption="Param. 3"
   default=(0.5,0.0)
endparam 

param d
   caption="Param. 4"
   default=(0.5,0.0)
endparam 

 
heading
   caption="Functions"
endheading
 
func Fn1
   caption="Function 1"
   default=ident()
endfunc
 
func Fn2
   caption="Function 2"
   default=log()
endfunc
 
func Fn3
   caption="Function 3"
   default=atanh()
endfunc

func Fn4
   caption="Function 4"
   default=cotan()
endfunc

func Fn5
   caption="Function 5"
   default=cos()
endfunc

func Fn6
   caption="Function 6"
   default=sqrt()
endfunc

func Fn7
   caption="Function 7"
   default=atanh()
endfunc

switch:
   type="Lonelyness"
   @startseed=#pixel
   bailout=@bailout
   a=@a
   b=@b
   c=@c
   d=@d
   op=@op
   fn1=@fn1                              
   fn2=@fn2
   fn3=@fn3
   fn4=@fn4

   fn5=@fn5
   fn6=@fn6
   fn7=@fn7
   mode=@switchmode
   switchmode=@mode

}
IntoTheFantasy-M {

; Copyright Miriana Penzo 2003
; Credits to Andrea Spinozzi

Init:

z=@start
c=#pixel

loop:

if @invert==true
   z=1/(z+pixel)
endif

z=fn1(fn2((z*z-z+P1)/(z+P2)+c))


bailout:
   |z|<@bailout
   
default:

y = fn2(c-@h*sin(z+tan(3^z)))

if @op == "+"
 if @type == "+"
 z = c+(x+y)
 elseif @type == "-"
 z = c-(x+y)
 elseif @type == "*"
 z = c*(x+y)
 elseif @type == "/"
 z = c/(x+y)
 elseif @type == "^"
 z = c^(x+y)
endif
 elseif @op == "-"
  if @type == "+"
 z = c+(x-y)
 elseif @type == "-"
 z = c-(x-y)
 elseif @type == "*"
 z = c*(x-y)
 elseif @type == "/"
 z = c/(x-y)
 elseif @type == "^"
 z = c^(x-y)
endif
elseif @op == "*"
 if @type == "+"
 z = c+(x*y)
 elseif @type == "-"
 z = c-(x*y)
 elseif @type == "*"
 z = c*(x*y)
 elseif @type == "/"
 z = c/(x*y)
 elseif @type == "^"
 z = c^(x*y)
endif
elseif @op == "/"
 if @type == "+"
 z = c+(x/y)
 elseif @type == "-"
 z = c-(x/y)
 elseif @type == "*"
 z = c*(x/y)
 elseif @type == "/"
 z = c/(x/y)
 elseif @type == "^"
 z = c^(x/y)
endif
elseif @op == "^"
 if @type == "+"
 z = c+(x^y)
 elseif @type == "-"
 z = c-(x^y)
 elseif @type == "*"
 z = c*(x^y)
 elseif @type == "/"
 z = c/(x^y)
 elseif @type == "^"
 z = c^(x^y)
endif
endif

bailout:

|z| < @bailout


IntoTheFantasy-J {

; Copyright Miriana Penzo 2003
; Credits to Andrea Spinozzi

Init:

z=#pixel
c=@seed

loop:

if @invert==true
   z=1/(z+pixel)
endif

z=fn1(fn2((z*z-z+P1)/(z+P2)+c))

bailout:
   |z|<@bailout
   
default:
   title="IntoTheFantasy-J"
   center=(0.7796875,0.409375)
   
param Bailout
   caption="Valore del Bailout"
   default=0
   min=4
  endparam

heading
   caption="Parameters"
endheading


  per = per
}


Mutate001m {
; by Marcelo Anelli C.
; Original formula is wiltetrate.
; Caracas, March 1999
init:
  if (@modini==0)
    #z = #pixel + @per
  elseif (@modini==1)
    #z = ( #pixel + @per ) * ( #pixel + @per )
  elseif (@modini==2)
    #z = exp(#pixel + @per )
  elseif (@modini==3)
    #z = exp(#pixel + @per ) / ( #pixel + @per )
  elseif (@modini==4)
    #z = (1.0,0.0) / ( #pixel + @per )
  endif
  complex c = #z
loop:
  #z = #z ^ ( @fn1( #z ^ @exp )) + c
bailout:
  (@bto == 0 && |#z| <= @bail) ||                                    \
  (@bto == 1 && sqr(real(#z)) <= @bail) ||                           \
  (@bto == 2 && sqr(imag(#z)) <= @bail) ||                           \
  (@bto == 3 && (sqr(real(#z)) <= @bail && sqr(imag(#z)) < @bail)) || \
  (@bto == 4 && (sqr(real(#z)) <= @bail || sqr(imag(#z)) < @bail)) || \
  (@bto == 5 && (sqr(abs(real(#z)) + abs(imag(#z))) <= @bail)) ||     \
  (@bto == 6 && (sqr(real(#z) + imag(#z)) <= @bail))
default:
  title = "Generic Wiltetrate Mandel"
  param exp
    caption = "Exponent"
	default = (0.5, 0.0)
  endparam
  param bail
    caption = "Bailout"
    hint = "Select your bailout value."
    default = 4.0
    min = 1.0
  endparam
  param per
    caption = "Perturbation"
	default = (0.0, 0.0)
  endparam
  param bto
    caption = "Bailout Test"
    default = 0
    enum = "mod" "real" "imag" "or" "and" "manh" "manr"
  endparam
  param modini
    caption = "Init method"
    default = 0
    enum = "pixel" "pixel^2" "exp(pixel)" "exp(#pixel)/#pixel" "1/#pixel"
  endparam
  func fn1
    caption = "Function 1"
	default = cotanh()
  endfunc
switch:
  type = "Mutate001j"
  c1 = #pixel
  bail = bail
  per = per
  exp = exp
  bto = bto
  modini = modini
  fn1 = fn1
}


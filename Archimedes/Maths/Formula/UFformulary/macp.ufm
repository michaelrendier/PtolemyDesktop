Mutate002j {
; Original formulas are mind_2, mind_3, mind_4 and mind_5.
; Michael G. Wareman
; Mutated by Marcelo Anelli C.
; Caracas, March 1999
init:
  if (@modini==0)
    #z = #pixel + @per
  elseif (@modini==1)
    #z = ( #pixel + @per ) * ( #pixel + @per )
  elseif (@modini==2)
    #z = exp(#pixel + @per )
  elseif (@modini==3)
    #z = exp(#pixel + @per ) / ( #pixel + @per )
  elseif (@modini==4)
    #z = (1.0,0.0) / ( #pixel + @per )
  endif
  complex c = @c1
loop:
  #z = c * @fn1( 1 / #z )
  if (@square==1)
    #z = #z * #z
  elseif (@square==2)
    #z = #z * #z + c
  endif
bailout:
  (@bto == 0 && |#z| <= @bail) ||                                    \
  (@bto == 1 && sqr(real(#z)) <= @bail) ||                           \
  (@bto == 2 && sqr(imag(#z)) <= @bail) ||                           \
  (@bto == 3 && (sqr(real(#z)) <= @bail && sqr(imag(#z)) < @bail)) || \
  (@bto == 4 && (sqr(real(#z)) <= @bail || sqr(imag(#z)) < @bail)) || \
  (@bto == 5 && (sqr(abs(real(#z)) + abs(imag(#z))) <= @bail)) ||     \
  (@bto == 6 && (sqr(real(#z) + imag(#z)) <= @bail))
default:
  title = "Generic Mind_2, Julia set"
  param bail
    caption = "Bailout"
    hint = "Select your bailout value."
    default = 4.0
    min = 1.0
  endparam
  param per
    caption = "Perturbation"
	default = (0.0, 0.0)
  endparam
  param bto
    caption = "Bailout Test"
    default = 0
    enum = "mod" "real" "imag" "or" "and" "manh" "manr"
  endparam
  param modini
    caption = "Init method"
    default = 0
    enum = "pixel" "pixel^2" "exp(pixel)" "exp(#pixel)/#pixel" "1/#pixel"
  endparam
  param square
    default = 0
	enum = "No apply" "Apply" "Apply with c"
	caption = "Apply square"
  endparam
  param c1
    caption = "Julia constant"
    default = (2.0, 0.0)
  endparam
  func fn1
    caption = "Function 1"
	default = sin()
  endfunc
switch:
  type = "Mutate002m"
  bail = bail
  per = per
  bto = bto
  modini = modini
  square = square
  fn1 = fn1
}

Mutate002m {
; Original formulas are mind_2, mind_3, mind_4 and mind_5.
; Michael G. Wareman
; Mutated by Marcelo Anelli C.
; Caracas, March 1999
init:
  if (@modini==0)
    #z = #pixel + @per
  elseif (@modini==1)
    #z = ( #pixel + @per ) * ( #pixel + @per )
  elseif (@modini==2)
    #z = exp(#pixel + @per )
  elseif (@modini==3)
    #z = exp(#pixel + @per ) / ( #pixel + @per )
  elseif (@modini==4)
    #z = (1.0,0.0) / ( #pixel + @per )
  endif
  complex c = #z
loop:
  #z = c * @fn1( 1 / #z )
  if (@square==1)
    #z = #z * #z
  elseif (@square==2)
    #z = #z * #z + c
  endif
bailout:
  (@bto == 0 && |#z| <= @bail) ||                                    \
  (@bto == 1 && sqr(real(#z)) <= @bail) ||                           \
  (@bto == 2 && sqr(imag(#z)) <= @bail) ||                           \
  (@bto == 3 && (sqr(real(#z)) <= @bail && sqr(imag(#z)) < @bail)) || \
  (@bto == 4 && (sqr(real(#z)) <= @bail || sqr(imag(#z)) < @bail)) || \
  (@bto == 5 && (sqr(abs(real(#z)) + abs(imag(#z))) <= @bail)) ||     \
  (@bto == 6 && (sqr(real(#z) + imag(#z)) <= @bail))
default:
  title = "Generic Mind_2, Mandel set"
  param bail
    caption = "Bailout"
    hint = "Select your bailout value."
    default = 4.0
    min = 1.0
  endparam
  param per
    caption = "Perturbation"
	default = (0.0, 0.0)
  endparam
  param bto
    caption = "Bailout Test"
    default = 0
    enum = "mod" "real" "imag" "or" "and" "manh" "manr"
  endparam
  param modini
    caption = "Init method"
    default = 0
    enum = "pixel" "pixel^2" "exp(pixel)" "exp(#pixel)/#pixel" "1/#pixel"
  endparam
  param square
    default = 0
	enum = "No apply" "Apply" "Apply with c"
	caption = "Apply square"
  endparam
  func fn1
    caption = "Function 1"
	default = sin()
  endfunc
switch:
  type = "Mutate002j"
  c1 = #pixel
  bail = bail
  per = per
  bto = bto
  modini = modini
  square = square
  fn1 = fn1
}

Mutate003j {
; Original formula is Kapetanov 7
; Kapetanov Milan
; Mutated by Marcelo Anelli C.
; Caracas, March 1999
init:
  if (@modini==0)
    #z = #pixel + @per
  elseif (@modini==1)
    #z = ( #pixel + @per ) * ( #pixel + @per )
  elseif (@modini==2)
    #z = exp(#pixel + @per )
  elseif (@modini==3)
    #z = exp(#pixel + @per ) / ( #pixel + @per )
  elseif (@modini==4)
    #z = (1.0,0.0) / ( #pixel + @per )
  endif
  complex c = @c1
loop:
  #z = @fn1( #z ) + #pixel / c
  #z = c ^ 2 / #z
bailout:
  (@bto == 0 && |#z| <= @bail) ||                                    \
  (@bto == 1 && sqr(real(#z)) <= @bail) ||                           \
  (@bto == 2 && sqr(imag(#z)) <= @bail) ||                           \
  (@bto == 3 && (sqr(real(#z)) <= @bail && sqr(imag(#z)) < @bail)) || \
  (@bto == 4 && (sqr(real(#z)) <= @bail || sqr(imag(#z)) < @bail)) || \
  (@bto == 5 && (sqr(abs(real(#z)) + abs(imag(#z))) <= @bail)) ||     \
  (@bto == 6 && (sqr(real(#z) + imag(#z)) <= @bail))
default:
  title = "Kapetanov 7, Julia set"
  param bail
    caption = "Bailout"
    hint = "Select your bailout value."
    default = 14.0
    min = 1.0
  endparam
  param per
    caption = "Perturbation"
	default = (0.0, 0.0)
  endparam
  param bto
    caption = "Bailout Test"
    default = 0
    enum = "mod" "real" "imag" "or" "and" "manh" "manr"
  endparam
  param modini
    caption = "Init method"
    default = 0
    enum = "pixel" "pixel^2" "exp(pixel)" "exp(#pixel)/#pixel" "1/#pixel"
  endparam
  param c1
    caption = "Julia constant"
    default = (2.0, 0.0)
  endparam
  func fn1
    caption = "Function 1"
	default = sqr()
  endfunc
switch:
  type = "Mutate003m"
  bail = bail
  per = per
  bto = bto
  modini = modini
  fn1 = fn1
}


Icon_3{
; Original by Ramiro Perez
; Translated for UF by Mac
init:
  complex z1 = #pixel
  #z = (0.0, 0.0)
loop:
  complex zm = z1 * z1
  complex fac = @l + @a * |z1| + @b * real( z1 * zm )
  z1 = fac * z1 + @g * conj( zm )
  #z = #z + ( z1 - #pixel )
bailout:
  |z1| < @bail
default:
  title = "Icons 3"
  param bail
    caption = "Bailout"
    hint = "Select your bailout value."
    default = 200.0
    min = 1.0
  endparam
  param a
    default = 0.0
  endparam
  param b
    default = 0.0
  endparam
  param g
    default = 0.0
  endparam
  param l
    default = 0.0
  endparam
}

Zeppo { ; Mutation of 'Liar4'. Mutated by Bradley Beacham [74223,2745]
  ; Original formula by Chuck Ebbert [76306,1226]
  ; For 'Liar4' set FN1 & FN2 =IDENT and P1 & P2 = default
  ; p1 & p2 = Parameters (default 1,0 and 0,0)
  ; Translated for UF by Marcelo Anelli, April 1999
init:
  #z = #pixel
loop:
  #z = @fn1(1-abs(imag(#z)*@p1-real(#z)))+flip(@fn2(1-abs(1-real(#z)-imag(#z))))-@p2
bailout:
    |z| <= @bail
default:
  title = "Zeppo"
  param bail
    caption = "Bailout"
    hint = "Select your bailout value."
    default = 1.0
    min = 1.0
  endparam
  param p1
    default = 1.0
	caption = "Parameter 1"
  endparam
  param p2
    default = (0.0, 0.0)
	caption = "Parameter 2"
  endparam
  func fn1
    caption = "Function 1"
	default = sin()
  endfunc
  func fn2
    caption = "Function 2"
	default = sin()
  endfunc
}

IslandOfChaosm {
    ; Edited for Fractint v. 20 by George Martin, 10/98
	; Translated by Marcelo Anelli For UltraFractal
init:
  #z = @p1
  float x = 1.0
  complex c = #pixel
loop:
  #z = @fn1( #z ) + #pixel
  if (@forma==0)
    #z = @fn2( #z ) / conj(cos( #z )) + c
  elseif (@forma==1)
    #z = @fn2( #z ) / conj(cos( #z * x )) + c
  elseif (@forma==2)
    #z = @fn2( #z * x ) / conj(cos( #z )) + c
  elseif (@forma==3)
    #z = @fn2( #z * x ) / conj(cos( #z * x )) + c
  endif
  x = x + 1
bailout:
  |z| <= @bail
default:
  title = "Island of Chaos, Mandel set"
  param bail
    caption = "Bailout"
    hint = "Select your bailout value."
    default = 4.0
    min = 1.0
  endparam
  param forma
    caption = "Form of calculation"
	enum = "Original" "Form 2" "Form 3"	"Form 4"
	default = 0
  endparam
  func fn1
    default = sqr()
	caption = "Function 1"
	hint = "Original is sqr()"
  endfunc
  func fn2
    default = sin()
	caption = "Function 2"
	hint = "Original is sin()"
  endfunc
switch:
  type = "IslandOfChaosj"
  bail = bail
  c = #pixel
  forma = forma
  fn1 = fn1
  fn2 = fn2
}

IslandOfChaosj {
    ; Edited for Fractint v. 20 by George Martin, 10/98
	; Translated by Marcelo Anelli For UltraFractal
init:
  #z = @p1
  float x = 1.0
  complex c = @c
loop:
  #z = @fn1( #z ) + #pixel
  if (@forma==0)
    #z = @fn2( #z ) / conj(cos( #z )) + c
  elseif (@forma==1)
    #z = @fn2( #z ) / conj(cos( #z * x )) + c
  elseif (@forma==2)
    #z = @fn2( #z * x ) / conj(cos( #z )) + c
  elseif (@forma==3)
    #z = @fn2( #z * x ) / conj(cos( #z * x )) + c
  endif
  x = x + 1
bailout:
  |z| <= @bail
default:
  title = "Island of Chaos, Julia set"
  param c
    default = (0.0, 0.0)
	caption = "Julia constant"
  endparam
  param bail
    caption = "Bailout"
    hint = "Select your bailout value."
    default = 4.0
    min = 1.0
  endparam
  param forma
    caption = "Form of calculation"
	enum = "Original" "Form 2" "Form 3" "Form 4"
	default = 0
  endparam
  func fn1
    default = sqr()
	caption = "Function 1"
	hint = "Original is sqr()"
  endfunc
  func fn2
    default = sin()
	caption = "Function 2"
	hint = "Original is sin()"
  endfunc
switch:
  type = "IslandOfChaosm"
  bail = bail
  forma = forma
  fn1 = fn1
  fn2 = fn2
}

MandelBubs1 {; Paul W. Carlson
init:
    bool done = FALSE
    complex w = (0,0)
    complex c = #pixel
    float index_factor = 249.0/@max_min_w
    float min_w = 1.0e20
    #z = 0.0
loop:
    if (@formula == 0)
      w = w * w + c
	elseif (@formula == 1)
	  w = w * w * w + c
	elseif (@formula == 2)
	  w = @fn1( w * w ) + c
	elseif (@formula == 3)
	  w = @fn1( w * w * w ) + c
	elseif (@formula == 4)
	  w =  w * w + #pixel * c
	elseif (@formula == 5)
	  w =  @fn1(w * w) + #pixel * c
	endif
    float temp = cabs(w)
    IF (temp < min_w)
       min_w = temp
    ENDIF
    IF (|w| > @max_w)
  done = TRUE
  IF (min_w < @max_min_w)
      #z = index_factor * min_w
  ELSE
      #z = 253.0
  ENDIF
    ENDIF
bailout:
    done == FALSE
default:
    title="Mandel Bubbles 1"

    param max_min_w
    caption="Bubble radius"
    default=0.188 
    endparam

	param formula
	  caption = "Formula applied"
	  default = 0
	  enum = "Mandel" "Cubic" "fn1 to Mandel" "fn1 to Cubic" "Mandel II" "fn1 to Mandel II"
	endparam

    param max_w
    caption="Bailout radius squared"
    default=16
    endparam
}

sierpinskiim {
; Written by Luke Plant
; Modified by Frederik Slijkerman
; Generalized by Marcelo Anelli
; Caracas, Septiembre de 1999
init:
  complex z = pixel

loop:
  IF (imag(z)>@corte)
    z = @factor*real(z) - flip(@factor*imag(z)-1)
  ELSEIF (real(z)>@corte)
    z = @factor*real(z)-1 - flip(@factor*imag(z))
  ELSE
    z = @factor*real(z) - flip(@factor*imag(z))
	z = @fn1( z )
  ENDIF

bailout:
  |z| < @bailout

default:
  title = "Sierpinksi i Triangle, Mandel"
  center = (0.4, 0.4)
  magn = 1.1538
  maxiter = 149
  param bailout
    caption = "Bailout value"
    default = 127
    min = 1
  endparam
  param factor
    caption = "Factor Transformation"
	default = 2.0
  endparam
  param corte
    caption = "Cutting edges"
	default = 0.5
  endparam
  func fn1
    caption = "Function applied"
	default = ident()
  endfunc
switch:
  type = "sierpinskiij"
  c = #pixel
  factor = factor
  bailout = bailout
  corte = corte
  fn1 = fn1
}

sierpinskiij {
; Written by Luke Plant
; Modified by Frederik Slijkerman
; Generalized by Marcelo Anelli
; Caracas, Septiembre de 1999
init:
  complex z = pixel

loop:
  IF (imag(z)>@corte)
    z = @factor*real(z) - flip(@factor*imag(z)-1)
  ELSEIF (real(z)>@corte)
    z = @factor*real(z)-1 - flip(@factor*imag(z))
  ELSE
    z = @factor*real(z) - flip(@factor*imag(z))
  ENDIF
  z = z + @c
  z = @fn1( z )

bailout:
  |z| < @bailout

default:
  title = "Sierpinksi i Triangle, Julia"
  center = (0.4, 0.4)
  magn = 1.1538
  maxiter = 149
  param bailout
    caption = "Bailout value"
    default = 127
    min = 1
  endparam
  param factor
    caption = "Factor Transformation"
	default = 2.0
  endparam
  param corte
    caption = "Cutting edges"
	default = 0.5
  endparam
  param c
    caption = "Julia constant"
	default = (0.0, 0.0)
  endparam
  func fn1
    caption = "Function applied"
	default = ident()
  endfunc
switch:
  type = "sierpinskiim"
  factor = factor
  bailout = bailout
  corte = corte
  fn1 = fn1
}

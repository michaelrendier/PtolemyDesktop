range-sample-1 { ; copyright Kerry Mitchell 21feb99
;
; sample of "Range" coloring scheme
;
fractal:
  title="Range Sample 1" width=640 height=480 author="Kerry Mitchell"
  created="February 21, 1999" numlayers=1
layer:
  insolid=16777215 outsolid=16777215 method=multipass caption="New Layer 1"
  visible=yes alpha=no
mapping:
  center=-0.5/0 magn=1.25 angle=0
formula:
  filename="Standard.ufm" entry="FastMandel" maxiter=100 percheck=normal
  p_Start=0/0 p_Bailout=1000000000000
inside:
  filename="lkm.ucl" entry="range" transfer=linear repeat=no
  p_rangecenter=-1 p_rangewidth=0.5 p_rangevar="real f(z)"
  p_colorvar="imag f(z)" p_slope=0.5 p_offset=0.5
  p_colorby="fraction in range" f_scalefunc=tanh f_rangefunc=sqr
  f_colorfunc=sqr
outside:
  filename="lkm.ucl" entry="range" transfer=linear repeat=no
  p_rangecenter=-1 p_rangewidth=0.5 p_rangevar="real(z)"
  p_colorvar="imag(z)" p_slope=0.5 p_offset=0.5
  p_colorby="fraction in range" f_scalefunc=tanh f_rangefunc=sqr
  f_colorfunc=sqr
gradient:
  smooth=yes numnodes=5 index=0 color=0 index=99 color=16711680 index=199
  color=65535 index=299 color=255 index=399 color=16777215
}


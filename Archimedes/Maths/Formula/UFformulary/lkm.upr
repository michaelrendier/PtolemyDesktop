  p_scale=0.9 p_tdeg=0 p_fliptype="none" p_setcolor=8
transform:
  filename="lkm.uxf" entry="pentomino-color" p_type="P" p_origin=-0.9/-2.7
  p_scale=0.9 p_tdeg=90 p_fliptype="none" p_setcolor=4
transform:
  filename="lkm.uxf" entry="pentomino-color" p_type="I" p_origin=-4.5/-2.7
  p_scale=0.9 p_tdeg=0 p_fliptype="none" p_setcolor=1
transform:
  filename="lkm.uxf" entry="pentomino-color" p_type="L" p_origin=-2.7/2.7
  p_scale=0.9 p_tdeg=0 p_fliptype="both x & y" p_setcolor=9
transform:
  filename="lkm.uxf" entry="pentomino-color" p_type="T" p_origin=0/-0.9
  p_scale=0.9 p_tdeg=90 p_fliptype="none" p_setcolor=2
transform:
  filename="lkm.uxf" entry="pentomino-color" p_type="N" p_origin=-2.7/2.7
  p_scale=0.9 p_tdeg=270 p_fliptype="none" p_setcolor=3

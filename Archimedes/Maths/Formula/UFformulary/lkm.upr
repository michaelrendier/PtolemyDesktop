  mergemode=difference
mapping:
  center=-1.4/0 magn=2.8 angle=90
formula:
  filename="lkm.ufm" entry="predictor-general-mandelbrot" maxiter=100
  percheck=off p_manparam=0/0 p_bailout=1000 p_nexp=2
  p_ztype="average relative error" p_npp="3" f_f1ofz=sinh f_f2ofz=cosh
  f_f3ofz=ident

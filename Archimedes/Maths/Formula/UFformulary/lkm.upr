superstar { ; copyright Kerry Mitchell 25nov98
;
; demonstrates "5 Point Star" coloring
;
fractal:
  title="SuperStar" width=320 height=240 author="Kerry Mitchell"
  created="November 25, 1998" numlayers=1
layer:
  method=linear caption="Layer 1" visible=yes alpha=no
mapping:
  center=0/0.1 magn=1.25 angle=24
formula:
  filename="Fractint.ufm" entry="julzpower" maxiter=100 percheck=normal
  p_seed=0.843808295835287031/0.584133372841093019 p_exp=5/0
  p_test="mod" p_bailout=1e20
inside:
  transfer=none repeat=yes
outside:
  filename="lkm.ucl" entry="5star" density=0.5 transfer=log repeat=yes
  p_center=0/0 p_r=2 p_phiangle=18 p_colorby="minimum distance"
gradient:
  smooth=yes position=40 numnodes=9 index=23 color=4128768 index=73
  color=127 index=123 color=16638 index=173 color=65535 index=174
  color=327679 index=223 color=12582910 index=268 color=16711551 index=323
  color=16695296 index=373 color=16646144
}


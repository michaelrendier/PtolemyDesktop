  filename="standard.ufm" entry="FastJulia" maxiter=100 percheck=normal
  p_Seed=0.39/0.44 p_Bailout=1000000000000
inside:
  transfer=none repeat=yes
outside:
  filename="lkm.ucl" entry="2-sections" transfer=linear repeat=yes
  p_type1="circle" p_center1=0.9/0 p_theta1=45 p_radius1=1 p_xaxis1=1
  p_yaxis1=1 p_type2="circle" p_center2=1.1/0 p_theta2=0 p_radius2=1
  p_xaxis2=1 p_yaxis2=1 p_metrictype="x^2 + y^2" p_colorby="2 curve angle"
gradient:

  color=16711680 index=276 color=8323072 index=326 color=0 index=376
  color=32639
}

four-by-three { ; copyright Kerry Mitchell 20dec98
;
; illustrates the use of "conic lite" coloring formulas
;
fractal:
  title="Four by Three" width=320 height=240 author="Kerry Mitchell"
  created="December 20, 1998" numlayers=1
layer:
  method=linear caption="Layer 1" visible=yes alpha=no
mapping:
  center=0/0 magn=1.5 angle=45
formula:
  filename="lkm.ufm" entry="z^n+1=0-newton" maxiter=1000 percheck=off
  p_nexp=4 p_bailout=1000000
inside:
  transfer=none repeat=yes
outside:
  filename="lkm.ucl" entry="conic-lite" density=0.0625 transfer=linear
  repeat=yes p_type="circle" p_center=1/1 p_theta=45 p_radius=2 p_xaxis=1.5
  p_yaxis=0.75 p_colorby="minimum distance"
gradient:
  smooth=yes position=-95 numnodes=5 index=38 color=65535 index=39
  color=327679 index=114 color=12976123 index=381 color=16711679 index=388
  color=16638
}


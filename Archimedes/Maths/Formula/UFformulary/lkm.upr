  p_scale=0.9 p_tdeg=270 p_fliptype="none" p_setcolor=10
formula:
  filename="lkm.ufm" entry="Null" maxiter=1 percheck=off
inside:
  filename="lkm.ucl" entry="passthru" transfer=none repeat=yes p_xytype="y"
  p_m=1 p_n=4
outside:
  filename="lkm.ucl" entry="passthru" transfer=linear repeat=no
  p_xytype="x" p_m=1 p_n=12
gradient:
  smooth=no numnodes=3 index=0 color=16711680 index=199 color=16777215
  index=399 color=255
}


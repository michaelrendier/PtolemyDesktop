comment {

Here are some samples images that
illustrate the use of various formulas
and coloring schemes that I've developed.
All images copyright Kerry Mitchell.

Compilation dated 15jul2001.

}

embossed-mandelbrot { ; copyright Kerry Mitchell 15sep98
;
; sample image to illustrate
; embossing effect
;
fractal:
  title="Embossed Mandelbrot" width=320 height=240 numlayers=1
  author="Kerry Mitchell" created="September 15, 1998"
layer:
  method=linear caption="Layer 1" visible=yes alpha=no
mapping:
  center=-0.814575442175006/0.202046546731385 magn=212.907337481817
  angle=34.1618809829249
formula:
  filename="lkm.ufm" entry="embossed-mandelbrot" maxiter=1000
  percheck=off p_lightangle=90 p_sizefac=1.0 p_xfac=1.1 p_yfac=1.1
inside:
  transfer=none repeat=yes
outside:
  filename="lkm.ucl" entry="emboss" transfer=linear repeat=yes
gradient:
  smooth=no numnodes=5 index=0 color=0 index=100 color=0 index=200
  color=8355711 index=300 color=16777215 index=390 color=16777215
}

embossed-julia { ; copyright Kerry Mitchell 15sep98
;
; sample image to illustrate
; embossing effect
;
fractal:
  title="Embossed Julia" width=320 height=240 numlayers=1
  author="Kerry Mitchell" created="September 15, 1998"
layer:
  method=linear caption="Layer 1" visible=yes alpha=no
mapping:
  center=0/0 magn=1.22605363984674 angle=0
formula:
  filename="lkm.ufm" entry="embossed-julia" maxiter=100 percheck=off
  p_julparam=-0.818147826049305/0.198841738771242 p_lightangle=45
  p_sizefac=1.2 p_xfac=1.1 p_yfac=1.1
inside:
  transfer=none repeat=yes
outside:
  filename="lkm.ucl" entry="emboss" transfer=linear repeat=yes
gradient:
  smooth=no numnodes=5 index=0 color=0 index=100 color=0 index=200
  color=8355711 index=300 color=16777215 index=390 color=16777215
}

embossed-4th-order-newton { ; copyright Kerry Mitchell 15sep98
;
; sample image to illustrate
; embossing effect
;
fractal:
  title="Embossed 4th order Newton" width=320 height=240 numlayers=1
  author="Kerry Mitchell" created="September 15, 1998"
layer:
  method=linear caption="Layer 1" visible=yes alpha=no
mapping:
  center=0/-0.8 magn=6.5 angle=0
formula:
  filename="lkm.ufm" entry="embossed-z^n-newton" maxiter=1000
  percheck=off p_nexp=4 p_bailout=1000 p_lightangle=90 p_sizefac=1.0
inside:
  transfer=none repeat=yes
outside:
  filename="lkm.ucl" entry="emboss" transfer=linear repeat=yes
gradient:
  smooth=no numnodes=5 index=0 color=0 index=100 color=0 index=200
  color=8355711 index=300 color=16777215 index=390 color=16777215
}

quasi-contours { ; copyright Kerry Mitchell 15sep98
;
; sample image to illustrate
; embossing effect
;
fractal:
  title="Quasi-Contours" width=320 height=240 numlayers=4
  author="Kerry Mitchell" created="September 15, 1998"
layer:
  method=linear caption="Layer 4" opacity=100 visible=yes alpha=no
  mergemode=difference
mapping:
  center=0/0 magn=1 angle=0
formula:
  filename="lkm.ufm" entry="embossed-general-julia" maxiter=100
  percheck=off p_julparam=-1.25992/0 p_nexp=4 p_bailout=28.4
  p_lightangle=270 p_sizefac=2.5
inside:
  transfer=none repeat=yes
outside:
  filename="lkm.ucl" entry="emboss" transfer=linear repeat=yes
gradient:
  smooth=no position=-100 numnodes=5 index=0 color=0 index=100
  color=8355711 index=200 color=16777215 index=290 color=16777215 index=300
  color=0
layer:
  method=linear caption="Layer 3" opacity=100 visible=yes alpha=no
  mergemode=difference
mapping:
  center=0/0 magn=1 angle=0
formula:
  filename="lkm.ufm" entry="embossed-general-julia" maxiter=100
  percheck=off p_julparam=-1.25992/0 p_nexp=4 p_bailout=13.4
  p_lightangle=180 p_sizefac=2.5
inside:
  transfer=none repeat=yes
outside:
  filename="lkm.ucl" entry="emboss" transfer=linear repeat=yes
gradient:
  smooth=no position=-100 numnodes=5 index=0 color=0 index=100
  color=8355711 index=200 color=16777215 index=290 color=16777215 index=300
  color=0
layer:
  method=linear caption="Layer 2" opacity=100 visible=yes alpha=no
  mergemode=difference
mapping:
  center=0/0 magn=1 angle=0
formula:
  filename="lkm.ufm" entry="embossed-general-julia" maxiter=100
  percheck=off p_julparam=-1.25992/0 p_nexp=4 p_bailout=6.34
  p_lightangle=90 p_sizefac=2.5
inside:
  transfer=none repeat=yes
outside:
  filename="lkm.ucl" entry="emboss" transfer=linear repeat=yes
gradient:
  smooth=no position=-100 numnodes=5 index=0 color=0 index=100
  color=8355711 index=200 color=16777215 index=290 color=16777215 index=300
  color=0
layer:
  method=linear caption="Layer 1" visible=yes alpha=yes
mapping:
  center=0/0 magn=1 angle=0
formula:
  filename="lkm.ufm" entry="embossed-general-julia" maxiter=100
  percheck=off p_julparam=-1.25992/0 p_nexp=4 p_bailout=3 p_lightangle=0
  p_sizefac=2.5
inside:
  transfer=none repeat=yes
outside:
  filename="lkm.ucl" entry="emboss" transfer=linear repeat=yes
gradient:
  smooth=no numnodes=5 index=0 color=0 index=100 color=0 index=200
  color=8355711 index=300 color=16777215 index=390 color=16777215
}

knocker { ; copyright Kerry Mitchell 09oct98
;
; sample image to illustrate
; embossing effect
;
fractal:
  title="Knocker" width=240 height=320 author="Kerry Mitchell"
  created="October 9, 1998" numlayers=1
layer:
  method=linear caption="Layer 1" visible=yes alpha=no
mapping:
  center=0.7/0 magn=10 angle=90
formula:
  filename="lkm.ufm" entry="embossed-explog-newton" maxiter=1000
  percheck=off p_bailout=100 p_lightangle=180 p_sizefac=0.7
inside:
  transfer=none repeat=yes
outside:
  filename="lkm.ucl" entry="emboss" transfer=linear repeat=yes
gradient:
  smooth=no numnodes=5 index=0 color=0 index=100 color=0 index=200
  color=8355711 index=300 color=16777215 index=390 color=16777215
}

gaussian0 { ; copyright Kerry Mitchell 20sep98
;
; Sample of "Gaussian Integer" coloring.
; Colors by "maximum distance" to integer.
; 4 layers averaged together to smooth image.
;
fractal:
  title="Gaussian0" width=320 height=240 author="Kerry Mitchell"
  created="September 20, 1998" numlayers=4
layer:
  method=linear caption="Layer 4" opacity=25 visible=yes alpha=no
mapping:
  center=-0.34/0.6 magn=30 angle=0
formula:
  filename="lkm.ufm" entry="elliptical-bailout-julia" maxiter=100
  percheck=off p_julparam=-0.1/1 p_xfac=1e7 p_yfac=1e7
inside:
  transfer=none repeat=yes
outside:
  filename="lkm.ucl" entry="gauss" density=2 transfer=linear repeat=yes
  p_colorby="maximum distance" p_norm="factor" p_fac=2/1
gradient:
  smooth=yes numnodes=4 index=0 color=16777215 index=100 color=12615455
  index=200 color=0 index=300 color=4161472
layer:
  method=linear caption="Layer 3" opacity=33 visible=yes alpha=no
mapping:
  center=-0.34/0.6 magn=30 angle=0
formula:
  filename="lkm.ufm" entry="elliptical-bailout-julia" maxiter=100
  percheck=off p_julparam=-0.1/1 p_xfac=1e6 p_yfac=1e6
inside:
  transfer=none repeat=yes
outside:
  filename="lkm.ucl" entry="gauss" density=2 transfer=linear repeat=yes
  p_colorby="maximum distance" p_norm="factor" p_fac=2/1
gradient:
  smooth=yes numnodes=4 index=0 color=16777215 index=100 color=12615455
  index=200 color=0 index=300 color=4161472
layer:
  method=linear caption="Layer 2" visible=yes alpha=no
mapping:
  center=-0.34/0.6 magn=30 angle=0
formula:
  filename="lkm.ufm" entry="elliptical-bailout-julia" maxiter=100
  percheck=off p_julparam=-0.1/1 p_xfac=1e5 p_yfac=1e5
inside:
  transfer=none repeat=yes
outside:
  filename="lkm.ucl" entry="gauss" density=2 transfer=linear repeat=yes
  p_colorby="maximum distance" p_norm="factor" p_fac=2/1
gradient:
  smooth=yes numnodes=4 index=0 color=16777215 index=100 color=12615455
  index=200 color=0 index=300 color=4161472
layer:
  method=linear caption="Layer 1" opacity=100 visible=yes alpha=no
  mergemode=difference
mapping:
  center=-0.34/0.6 magn=30 angle=0
formula:
  filename="lkm.ufm" entry="elliptical-bailout-julia" maxiter=100
  percheck=off p_julparam=-0.1/1 p_xfac=10000 p_yfac=10000
inside:
  transfer=none repeat=yes
outside:
  filename="lkm.ucl" entry="gauss" density=2 transfer=linear repeat=yes
  p_colorby="maximum distance" p_norm="factor" p_fac=2/1
gradient:
  smooth=yes numnodes=4 index=0 color=16777215 index=100 color=12615455
  index=200 color=0 index=300 color=4161472
}

gaussian6 { ; copyright Kerry Mitchell 20sep98
;
; Sample of "Gaussian Integer" coloring.
; Illustrates the "average distance" to integer
; coloring.  4 layers used to smooth the image.
;
fractal:
  title="Gaussian6" width=320 height=240 author="Kerry Mitchell"
  created="September 20, 1998" numlayers=4
layer:
  method=linear caption="Layer 4" opacity=25 visible=yes alpha=no
mapping:
  center=-0.522/0.172 magn=70 angle=0
formula:
  filename="standard.ufm" entry="FastJulia" maxiter=1000 percheck=normal
  p_Seed=0.28/0.005 p_Bailout=1e7
inside:
  transfer=none repeat=yes
outside:
  filename="lkm.ucl" entry="gauss" density=16 transfer=linear repeat=yes
  p_colorby="average distance" p_norm="none" p_fac=2/1
gradient:
  smooth=yes numnodes=9 index=33 color=127 index=83 color=16638 index=133
  color=65535 index=134 color=327679 index=183 color=12582910 index=228
  color=16711551 index=283 color=16695296 index=333 color=16646144
  index=383 color=4128768
layer:
  method=linear caption="Layer 3" opacity=33 visible=yes alpha=no
mapping:
  center=-0.522/0.172 magn=70 angle=0
formula:
  filename="standard.ufm" entry="FastJulia" maxiter=1000 percheck=normal
  p_Seed=0.28/0.005 p_Bailout=1e6
inside:
  transfer=none repeat=yes
outside:
  filename="lkm.ucl" entry="gauss" density=16 transfer=linear repeat=yes
  p_colorby="average distance" p_norm="none" p_fac=2/1
gradient:
  smooth=yes numnodes=9 index=33 color=127 index=83 color=16638 index=133
  color=65535 index=134 color=327679 index=183 color=12582910 index=228
  color=16711551 index=283 color=16695296 index=333 color=16646144
  index=383 color=4128768
layer:
  method=linear caption="Layer 2" visible=yes alpha=no
mapping:
  center=-0.522/0.172 magn=70 angle=0
formula:
  filename="standard.ufm" entry="FastJulia" maxiter=1000 percheck=normal
  p_Seed=0.28/0.005 p_Bailout=1e5
inside:
  transfer=none repeat=yes
outside:
  filename="lkm.ucl" entry="gauss" density=16 transfer=linear repeat=yes
  p_colorby="average distance" p_norm="none" p_fac=2/1
gradient:
  smooth=yes numnodes=9 index=33 color=127 index=83 color=16638 index=133
  color=65535 index=134 color=327679 index=183 color=12582910 index=228
  color=16711551 index=283 color=16695296 index=333 color=16646144
  index=383 color=4128768
layer:
  method=linear caption="Layer 1" visible=yes alpha=no
mapping:
  center=-0.522/0.172 magn=70 angle=0
formula:
  filename="standard.ufm" entry="FastJulia" maxiter=1000 percheck=normal
  p_Seed=0.28/0.005 p_Bailout=10000
inside:
  transfer=none repeat=yes
outside:
  filename="lkm.ucl" entry="gauss" density=16 transfer=linear repeat=yes
  p_colorby="average distance" p_norm="none" p_fac=2/1
gradient:
  smooth=yes numnodes=9 index=33 color=127 index=83 color=16638 index=133
  color=65535 index=134 color=327679 index=183 color=12582910 index=228
  color=16711551 index=283 color=16695296 index=333 color=16646144
  index=383 color=4128768
}

polar-curves-1 { ; copyright Kerry Mitchell 15nov98
;
; sample of "Polar Curves" coloring
;
fractal:
  title="Polar Curves 1" width=320 height=240 author="Kerry Mitchell"
  created="November 15, 1998" numlayers=1
layer:
  caption="Layer 1" visible=yes alpha=no
mapping:
  center=0/0 magn=1.2 angle=0
formula:
  filename="standard.ufm" entry="FastJulia" maxiter=100 percheck=normal
  p_Seed=-0.778/0.201 p_Bailout=1000
inside:
  transfer=none repeat=yes
outside:
  filename="lkm.ucl" entry="polar-curves" density=0.33
  transfer=log repeat=yes p_a=2 p_b=2 p_n=1 p_r0=0.4428474
  p_rneg="ignore r<0" p_colorby="minimum distance" f_fn1=sin
gradient:
  smooth=yes numnodes=4 index=43 color=0 index=143 color=78079 index=243
  color=131071 index=343 color=16711680
}

polar-curves-2 { ; copyright Kerry Mitchell 15nov98
;
; sample of "Polar Curves" coloring
;
fractal:
  title="Polar Curves 2" width=240 height=240 author="Kerry Mitchell"
  created="November 15, 1998" numlayers=1
layer:
  method=linear caption="Layer 1" visible=yes alpha=no
mapping:
  center=-0.75/0 magn=1.5 angle=90
formula:
  filename="standard.ufm" entry="FastMandel" maxiter=32 percheck=normal
  p_Start=0/0 p_Bailout=1000
inside:
  filename="lkm.ucl" entry="polar-curves" density=0.5 transfer=log
  repeat=yes p_a=0.5 p_b=2 p_n=1 p_r0=0 p_rneg="treat as r>0"
  p_colorby="minimum distance" f_fn1=cos
outside:
  filename="lkm.ucl" entry="polar-curves" density=0.5 transfer=log
  offset=150 repeat=yes p_a=0.5 p_b=2 p_n=1 p_r0=0 p_rneg="treat as r>0"
  p_colorby="minimum distance" f_fn1=cos
gradient:
  smooth=yes numnodes=4 index=0 color=0 index=100 color=78079 index=200
  color=131071 index=300 color=16711680
}

polar-curves-3 { ; copyright Kerry Mitchell 15nov98
;
; sample of "Polar Curves" coloring
;
fractal:
  title="Polar Curves 3" width=320 height=240 author="Kerry Mitchell"
  created="November 15, 1998" numlayers=1
layer:
  caption="Layer 1" visible=yes alpha=no
mapping:
  center=0/-0.85 magn=5.4 angle=0
formula:
  filename="lkm.ufm" entry="z^n+1=0-newton" maxiter=100 percheck=off
  p_nexp=4 p_bailout=1000000
inside:
  transfer=none repeat=yes
outside:
  filename="lkm.ucl" entry="polar-curves" transfer=linear repeat=yes
  p_a=2 p_b=4 p_n=1 p_r0=0 p_rneg="ignore r<0" p_colorby="in fraction"
  f_fn1=cos
gradient:
  smooth=yes numnodes=9 index=18 color=4128768 index=68 color=16646144
  index=118 color=16695296 index=173 color=16711551 index=218
  color=12582910 index=267 color=327679 index=268 color=65535 index=318
  color=16638 index=368 color=127
}

astroid1 { ; copyright Kerry Mitchell 15nov98
;
; sample of "Astroid" coloring
;
fractal:
  title="Astroid 1" width=320 height=240 author="Kerry Mitchell"
  created="November 15, 1998" numlayers=1
layer:
  caption="Layer 1" visible=yes alpha=no
mapping:
  center=-0.85/0.85 magn=3.5 angle=0
formula:
  filename="standard.ufm" entry="FastJulia" maxiter=6 percheck=normal
  p_Seed=0/1 p_Bailout=1000
inside:
  filename="lkm.ucl" entry="astroid" density=0.3
  transfer=linear repeat=yes p_a=0.666666 p_n=0.333333 p_rotangle=0
  p_center=-2/0 p_colorby="minimum distance"
outside:
  filename="lkm.ucl" entry="astroid" density=0.3
  transfer=linear repeat=yes p_a=0.666666 p_n=0.333333 p_rotangle=0
  p_center=-2/0 p_colorby="minimum distance"
gradient:
  smooth=yes numnodes=8 index=11 color=0 index=61 color=8323072 index=111
  color=16711680 index=161 color=16744319 index=211 color=16777215
  index=261 color=8388607 index=311 color=65535 index=361 color=32639
}

astroid2 { ; copyright Kerry Mitchell 15nov98
;
; sample of "Astroid" coloring
;
fractal:

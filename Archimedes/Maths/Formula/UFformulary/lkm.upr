;
fractal:
  title="Ring Toss" width=320 height=240 author="Kerry Mitchell"
  created="December 20, 1998" numlayers=1
layer:
  method=linear caption="Layer 1" visible=yes alpha=no
mapping:
  center=0/0 magn=1.35 angle=11
formula:
  filename="lkm.ufm" entry="gap-julia" maxiter=1000 percheck=off p_n=2
  p_julparam=-0.044662513058/0.64384933724 p_type="between 2 circles"
  p_c1=-0.1 p_c2=0.1 p_theta=45 p_center=-0.044662513058/0.64384933724
  p_radius1=0.233633551 p_radius2=0.265903379
inside:
  transfer=none repeat=yes
outside:
  filename="lkm.ucl" entry="basic" transfer=linear repeat=yes
  p_colorby="magnitude"
gradient:
  smooth=yes numnodes=8 index=0 color=0 index=50 color=1065088 index=100
  color=4227252 index=150 color=9420765 index=200 color=16777215 index=250
  color=9420765 index=300 color=4227252 index=350 color=1065088
}

fishing-lines { ; copyright Kerry Mitchell 20dec98
;
; illustrates "gap between 2 lines" coloring
;
fractal:
  title="Fishing Lines" width=320 height=240 author="Kerry Mitchell"
  created="December 20, 1998" numlayers=1
layer:
  method=linear caption="Layer 1" visible=yes alpha=no
mapping:
  center=-0.393749921/-0.58111714 magn=750 angle=155
formula:
  filename="lkm.ufm" entry="gap-mandelbrot" maxiter=256 percheck=off
  p_n=2 p_type="between 2 lines" p_c1=-0.001 p_c2=0.001 p_theta=56.2
  p_center=0/0 p_radius1=0.9 p_radius2=1.1
inside:
  transfer=none repeat=yes
outside:
  filename="lkm.ucl" entry="basic" transfer=linear repeat=yes
  p_colorby="magnitude"
gradient:
  smooth=yes position=200 numnodes=8 index=0 color=0 index=50 color=7356450
  index=100 color=12549963 index=150 color=15712127 index=200
  color=16777215 index=250 color=15712127 index=300 color=12549963
  index=350 color=7356450
}

crown { ; copyright Kerry Mitchell 20dec98
;
; illustrates the use of "2 Sections" coloring formulas
;
fractal:
  title="Crown" width=320 height=240 author="Kerry Mitchell"
  created="December 20, 1998" numlayers=1
layer:
  caption="Layer 1" visible=yes alpha=no
mapping:
  center=-0.7125/0 magn=1.1 angle=90
formula:
  filename="standard.ufm" entry="FastMandel" maxiter=100 percheck=normal
  p_Start=0/0 p_Bailout=4
inside:
  filename="lkm.ucl" entry="2-sections" density=3 transfer=linear
  repeat=yes p_type1="line" p_center1=-0.75/0 p_theta1=90 p_radius1=1
  p_xaxis1=1 p_yaxis1=1 p_type2="line" p_center2=0/0 p_theta2=0 p_radius2=1
  p_xaxis2=1 p_yaxis2=1 p_metrictype="x^2 + y^2" p_colorby="2 curve angle"
outside:
  filename="lkm.ucl" entry="2-sections" density=3 transfer=linear
  repeat=yes p_type1="line" p_center1=-0.75/0 p_theta1=90 p_radius1=1
  p_xaxis1=1 p_yaxis1=1 p_type2="line" p_center2=0/0 p_theta2=0 p_radius2=1
  p_xaxis2=1 p_yaxis2=1 p_metrictype="x^2 + y^2" p_colorby="2 curve angle"
gradient:
  smooth=yes numnodes=4 index=97 color=675176 index=249 color=14736366
  index=330 color=3158085 index=399 color=9043968
}

offsetting { ; copyright Kerry Mitchell 20dec98
;
; illustrates the use of "2 Sections" coloring formulas
;

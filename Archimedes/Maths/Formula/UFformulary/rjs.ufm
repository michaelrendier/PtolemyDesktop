===========================================================


;Analasys of the kspirals1
;Original Author unknown
;with added function
;And morph z

;Ronnie Jay
;Novenber 2003

spirals+rjs1 {

init:
z = pixel

loop:

aa = (.9,.5)
bb = z^2
z = 0.25*bb^2+(aa/3)*bb*z-0.5*bb+aa*z
z=@Function(z)

if(@Morph==true)
z=z-imag(z)
else
z=z
endif
 
bailout:
|z-pixel|<@bailout  
default:
  title = "spirals+rjs1"

param bailout
caption="Bailout value"
default=4
endparam

param morph
caption="Morph to minus imag Z"
default=false
endparam

func @Function
caption="Z Function"
default=ident()
endfunc

}


 ;No loop required...
bailout:
  @Turnaround
default:
  title = "B_Pixel"
  
heading
caption="Checkmark inside for most UCL's"
endheading

param turnaround
caption="Inside or out"
default= false
endparam
  
}

C_Pixel {
;Ronnie Jay
;A pixel based formula with four functions


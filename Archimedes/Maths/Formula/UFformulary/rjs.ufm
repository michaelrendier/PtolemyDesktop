  z=pixel
  f=z
  loop:
z=z*z+pixel^4+f
  f=fn1(f)+@power
  
  if(@Morph==true)
z=z-imag(z)
else
z=z
endif
  
  if (@invert==true)
  z=1/z
  else
  z=z

  endif
  

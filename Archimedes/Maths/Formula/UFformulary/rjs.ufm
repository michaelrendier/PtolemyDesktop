loop:

  zold=z
  z=((p1-1)*z^p1)/(p1*z^(p1-1))
  z=z^p1+@seed 
 
 if(@Morph==true)
z=z-imag(z)
else
z=z
endif
 
  if(@invert==true)
  z=1/z
  else
  z=z
  endif
 
if(@op=="+")
 z=z+c
elseif(@op=="-")
 z=z-c

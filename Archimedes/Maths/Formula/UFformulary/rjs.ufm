caption="Morph to imag -Z"
default=false
endparam

  
  param invert
  caption="Z inversion"
  default=false
  endparam
 
  func @Zfunction
  Caption="Z Function"
  default=asin()
  endfunc

  func @Zfunction2
  Caption="Z Function 2"
  default=ident()
  endfunc


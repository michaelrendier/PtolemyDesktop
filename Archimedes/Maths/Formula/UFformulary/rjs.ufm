  caption="Bail"
  default=8
  min=0
  endparam

  param power

  caption="Exponent"
  default=(2,0)
  endparam

 switch:
type="ClusterJ"
bailout=bailout
power=power
@Zfunction=@Zfunction
@Zfunction2=@Zfunction2
@ZFunction3=@ZFunction3
@invert=@invert
seed=pixel
@start=@start
@morph=@morph

}





Lale'sDelightJ{
;Original fomula called Bubbles by Ronnie Jay
;This is an adaptation of the bubbles formula
;That is a work between myself and Lale Erguner
;My thanks to Lale for the building blocks :-)

init:
  z=pixel

loop:
  z=z^@power+@seed+fn1(z^2)
  z=z^@seed+fn2(z)

if(@Morph==true)
z=z-imag(z)
else
z=z
endif
    
  if (@invert==true)
  z=1/z
  else
  z=z
  endif
  
bailout:
  |z|<@bailout
default:
  title = "Lale'sDelightJ"

heading
 caption = "F7 or spacebar to switch"
endheading


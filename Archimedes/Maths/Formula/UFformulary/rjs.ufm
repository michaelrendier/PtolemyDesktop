caption = "exponent"

default = (1,0)
endparam
 
param seed

caption = "Julia Seed"
default = (-0.3,-0.05)
endparam
 
Func fn1
caption = "function1"
default = tanh()
endfunc
 
float param bailout
caption = "bailout Value"
default = 20
endparam

switch:
type="SpirosM"
bailout=bailout
power=power

fn1=fn1
@morph=@morph

seed=pixel
}


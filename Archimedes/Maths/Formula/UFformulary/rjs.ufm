Paragon5M{
;Ronnie Jay
;For my friends Vicky and William Stroud


init:
  z=@start
  f=z
  g=f

loop:
  z=z*z+(pixel)
  z=z+sin(f+g)
  f=fn1(f)+pixel
  g=fn2(z)
  
  if(@Morph==true)
z=z-imag(z)
else
z=z
endif

bailout:

 |z|<@bailout
default:
  title = "Paragon5M"

center=(-0.5,0)
magn=2
maxiter=250

heading
 caption = "F7 or spacebar to switch"
endheading

param morph
caption="Morph to imag -Z"
default=false
endparam

float param start
caption="Zinit"
default=0.5
endparam

param bailout
 caption="Bailout Value"
 default=4.0
 min=0
 endparam

param power
 caption="Exponent"
 default=(2,0)
 endparam
 
 func fn1
 caption="Function 1"
 default=asin()
 endfunc
 
 func fn2
 caption="Function 2"
 default=cos()
 endfunc
 
switch:
type="Paragon5J"
power=power
seed=pixel
bailout=bailout
fn1=fn1
fn2=fn2
@morph=@morph


}


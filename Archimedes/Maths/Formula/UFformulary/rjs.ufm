JigsawM{
;Ronnie Jay
;A switchable twinset with the
;JigsawJ and vice versa
;Also the functions are useful
;You can also mess with the,
;Exponents seed and Bailout
init:
  z=0
  c=z
  sf=c
loop:
  Z=z*z+pixel-c+sf
  c=fn1(z)
  sf=fn2(c)
  
  if(@Morph==true)
z=z-imag(z)
else
z=z
endif
  
  if (@invert==true)
  z=1/z
  else

  z=z
  endif

  

bailout:

  |z|<@bailout
default:

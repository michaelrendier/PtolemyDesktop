;similar to the Julia wheel but a little
;different in some aspects

init:
  z=pixel^6

  f=z
loop:
  z=z^@power+@seed+f

  f=fn1(f)



  if(@Morph==true)
z=z-imag(z)
else
z=z
endif
  
  if(@invert==true)
  z=1/z
  else
  z=z
  endif
  


elseif @op=="Divide"
z=fn1(cabs(z)*pixel+fn2(pixel)/p1-sqr(z))-fn3(pixel)
elseif @op=="Elevate"
z=fn1(cabs(z)*pixel+fn2(pixel)^p1-sqr(z))-fn3(pixel)
endif
Elseif @op1=="3"

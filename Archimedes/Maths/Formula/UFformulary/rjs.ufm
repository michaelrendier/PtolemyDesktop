Emmy's Newton chains{
;Ronnie Jay

init:
  z=z+@Function1(pixel)
  z=z+@Function2(pixel)  
loop:


if(@Morph==true)
z=z-imag(z)
else
z=z
endif

if(@invert==true)
z=1/z
else
z=z
endif

  zold=z
  z=((p1-1)*z^p1+@r)/(p1*z^(p1-1))
  
bailout:
|z-zold|>=0.00001
default:
  title = "Emmy's Newton chains"
  
  maxiter=100
  center=(0.06,0.050)
  magn=0.5
  
  param p1
  caption="Exponent"
  default=(3,0)
  endparam
  
  param r
  caption="Root value"
  default=(1,0)
  endparam
  
  param morph
caption="Morph to imag -Z"
default=false
endparam
  
  param invert
  caption="Z inversion"

  default=false
  endparam

}
;endformula


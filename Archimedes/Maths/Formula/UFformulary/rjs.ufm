GenesisJ{
;Ronnie Jay
;Inverting the brot first then 
;switching gives some nice results

init:
  z=@Function1(pixel)
  z=@function2(z*cos(z))
loop:

  z=z^@power+@seed+tan(z)
  
  if(@Morph==true)
z=z-imag(z)
else
z=z
endif
    
  if(@invert==true)
  z=1/z
  else
  z=z
  endif
bailout:
  |z|<@bailout
default:

;Then make a switch

init:
  z=pixel
  p=@AdditionalZ(pixel)
loop:
 z=z^@power+pixel -@FuncZInit(z+p)
 
 if(@Morph==true)
z=z-imag(z)
else
z=z
endif
 
 if(@invert==true)
 z=1/z
 else
 z=z
 endif

bailout:

  |z|<@bailout
default:
  title = "ShatteredM"
  
 heading
 caption = "F7 or spacebar to switch"
 endheading

Center=(-0.09,0.44)
magn=0.70
maxiter=100


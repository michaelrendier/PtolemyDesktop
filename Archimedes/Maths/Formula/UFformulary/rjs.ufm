seed=pixel
bailout= bailout
power=power
fn1=fn1
@morph=@morph
fn2=fn2
invert=@invert

}
Superchaos2{

;Ronnie Jay
init:
  z=Pixel
  f=z
  g=f

loop:

  z=z+sin(e)*0.2-f^g
  f=fn1(f)
  g=fn2(z)
  
  if(@Morph==true)
z=z-imag(z)
else
z=z
endif
  
  if (@invert==true)
  z=1/z
  else
  z=z
  endif
  
  bailout:
  |z|<@bailout
default:
  title = "Superchaos2"
  
  heading
 caption = "F7 or spacebar to switch"
endheading
  
  center=(0.017,0.017)
  magn=0.6
  
param bailout
 caption="Bailout"
 default =4.0
  min =0
 endparam
 
 func fn1
 default=asin()
 endfunc
 

 func fn2
 default=asinh()

 endfunc
 
 param morph
caption="Morph to imag -Z"
default=false
endparam
 
 param invert
caption="Z inversion"
 default=false
 endparam
 

switch:
type="Superchaos1"
seed=pixel
bailout=bailout
power=power
fn1=fn1
fn2=fn2
invert=@invert
@morph=@morph
}

;endformula

Julijewels{
;Ronnie Jay
init:
  z=pixel^@seed
  c=z
  sf=c


loop:

  z=z^@power+@seed+c*sf

  c=fn1(z)
  sf=fn2(z^c)
  
  if(@Morph==true)
z=z-imag(z)
else
z=z
endif
  
  if (@invert==true)
  z=1/z
  else
  z=z
  endif
  
bailout:
  |z|<@bailout
default:
  title = "Julijewels"
  magn=0.29
  center=(-0.139,0.022)
 
  param seed
  caption="Julia seed"
  default=(-1.25,0)
  endparam
  
  param power
  caption="Exponent"
  default=(2,0)
  endparam
  
  param bailout
  caption="Bail"
  default=4.0
  min=0
  endparam
  
  param morph
caption="Morph to imag -Z"
default=false
endparam
  
  param invert
  caption="Z inversion"
  default=false
  endparam
}

;endformula


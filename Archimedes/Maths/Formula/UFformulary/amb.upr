  title="AgusVertMan Primer parámetro" width=800 height=600
  author="Agustín Martín" numlayers=1
layer:
  caption="Layer 1" visible=yes alpha=no
mapping:
  center=-1.264225/0.3279875 magn=50.4572690003153664 angle=0
formula:
  filename="amb.ufm" entry="AgusVertMan" maxiter=1000 percheck=normal
  p_vfactor=0.35 p_bailout=4 p_offset=2
inside:
  filename="Standard.ucl" entry="Default" transfer=linear repeat=yes
outside:
  filename="Standard.ucl" entry="Default" transfer=log repeat=yes
gradient:
  smooth=yes numnodes=3 index=18 color=6962251 index=178 color=15856854
  index=309 color=3892577
}


AgusVertManAnillosChulos {
fractal:
  title="AgusVertMan Anillos chulos" width=800 height=600
  author="Agustín Martín" numlayers=2
layer:
  method=multipass caption="Layer 1" opacity=100 visible=yes alpha=no
  mergemode=lighten
mapping:
  center=-1.2540100295837712/1.99996090581597024 magn=244.674492674492736
  angle=92.4366588305018496
formula:
  filename="agus.ufm" entry="AgusVertMan" maxiter=1000 percheck=normal
  p_vfactor=1 p_bailout=4 p_offset=2
inside:
  filename="lkm.ucl" entry="statistics" density=4 transfer=linear
  offset=100 repeat=yes p_vartype="magnitude"
  p_stattype="fractal dimension"
outside:
  filename="lkm.ucl" entry="2-sections" transfer=log repeat=yes
  p_type1="line" p_center1=0/0 p_theta1=45 p_radius1=1 p_xaxis1=1
  p_yaxis1=1 p_type2="circle" p_center2=0/0 p_theta2=0 p_radius2=1
  p_xaxis2=1 p_yaxis2=1 p_metrictype="x^2 + y^2" p_colorby="2 curve min"
gradient:
  smooth=yes numnodes=3 index=18 color=6962251 index=178 color=15856854
  index=309 color=3892577
layer:
  method=multipass caption="New Layer 1" opacity=100 visible=yes alpha=no
  mergemode=overlay
mapping:
  center=-1.2540100295837712/1.99996090581597024 magn=244.674492674492736
  angle=92.4366588305018496
formula:
  filename="agus.ufm" entry="AgusVertMan" maxiter=1000 percheck=normal
  p_vfactor=1 p_bailout=4 p_offset=2
inside:
  filename="lkm.ucl" entry="statistics" transfer=linear repeat=yes
  p_vartype="magnitude" p_stattype="fractal dimension"
outside:
  filename="lkm.ucl" entry="range-lite" transfer=log repeat=yes
  p_rangecenter=1 p_rangewidth=0.1 p_colorby="last mag"
gradient:
  smooth=yes numnodes=6 index=2 color=6110544 index=18 color=6962251
  index=178 color=15856854 index=309 color=3892577 index=388 color=5586245
  index=399 color=0
alpha:
  smooth=yes numnodes=4 index=0 alpha=0 index=15 alpha=248 index=394
  alpha=255 index=396 alpha=0
}


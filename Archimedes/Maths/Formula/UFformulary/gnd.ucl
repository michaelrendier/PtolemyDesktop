      z1 = aa^@exp3+@nufunc5(ff-gg)^@exp1-@nufunc3(oo+hh)^@exp2
     elseif @mmode3 == "z-|z|"
      z1 = aa^@exp3+@nufunc5(ff-gg)^@exp1-@nufunc3(oo-hh)^@exp2

      endif
     elseif @mmode2 == "z/|z|"
      if @mmode3 == "z+|z|"
       z1 = aa^@exp3+@nufunc2(kk/dd)^@exp1+@nufunc3(oo+hh)^@exp2
      elseif @mmode3 == "z-|z|"
       z1 = aa^@exp3+@nufunc2(kk/dd)^@exp1+@nufunc3(oo-hh)^@exp2

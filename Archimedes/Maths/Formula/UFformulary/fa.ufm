              else           
                 ainit = 1
              endif
            elseif (aflag==true)&&(nflag==false)           
               ainit = 0
            else
              aflag=true
              nflag=false
            endif
          endif
        endif
      endif     
      m=0
      nn=nn+1
    until nn==2
    nn=0
    n=n+1
  endwhile
  if @inside==false
    if nflag==true    
      if ainit ==1 
        ccolscale=@colscale2
      elseif ainit == 0
        ccolscale=@colscale
      else
        ccolscale=@colscale3
  
      endif 
      b=(scale*(n-1)*ccolscale+zlow)*1i+@ucoord
    if (@rotx!=0)||(@roty!=0)||(@rotz!=0)
      a=#pixel
       if @rotx!=0
         y1=imag(a)
         z1=imag(b)
         ry=y1*cosrotx-z1*sinrotx
         rz=y1*sinrotx+z1*cosrotx
         a=real(a)+ry*1i
         b=rz*1i+@ucoord
       endif
       if @roty!=0
         z1=imag(b)
         x1=real(a)
         rz=z1*cosroty-x1*sinroty
         rx=z1*sinroty+x1*cosroty
         b=rz*1i+@ucoord
         a=rx+1i*imag(a)
       endif
       if @rotz!=0
         x1=real(a)
         y1=imag(a)
         rx=x1*cosrotz-y1*sinrotz
         ry=x1*sinrotz+y1*cosrotz
         a=rx+1i*ry
       endif
     endif
    endif
  endif
  if (nflag==false)&&(@solid==true)&&(@dim2==false)
    b=0
    a=0
    z=0
  endif
elseif @fdim==1
  while (n<nmax)&&(nflag==false)
    a=scale*n+zlow+@ucoord*1i
    if (@rotx!=0)||(@roty!=0)||(@rotz!=0)
      b=#pixel
       if @rotx!=0
         if @rotx==90.0
           sinrotx=1.0

              endif
            elseif (aflag==true)&&(nflag==false)           
               ainit = 0
            else
              aflag=true
              nflag=false
            endif
          endif
        endif
      endif     
      m=0
      nn=nn+1
    until nn==2
    nn=0
    n=n+1
  endwhile
  if @inside==false
    if nflag==true    
      if ainit ==1 
        ccolscale=@colscale2
      elseif ainit == 0
        ccolscale=@colscale
      else
        ccolscale=@colscale3
  
      endif 
      a=scale*(n-1)*ccolscale+zlow+@ucoord*1i
    if (@rotx!=0)||(@roty!=0)||(@rotz!=0)
      b=#pixel
       if @rotx!=0
         y1=imag(b)
         z1=real(a)
         ry=y1*cosrotx-z1*sinrotx
         rz=y1*sinrotx+z1*cosrotx
         b=real(b)+ry*1i
         a=rz+1i*@ucoord
       endif
       if @roty!=0
         z1=real(a)
         x1=real(b)
         rz=z1*cosroty-x1*sinroty
         rx=z1*sinroty+x1*cosroty
         a=rz+1i*@ucoord
         b=rx+1i*imag(b)
       endif
       if @rotz!=0
         x1=real(b)
         y1=imag(b)
         rx=x1*cosrotz-y1*sinrotz
         ry=x1*sinrotz+y1*cosrotz
         b=rx+1i*ry
       endif
     endif
    endif
  endif
  if (nflag==false)&&(@solid==true)&&(@dim2==false)
    a=0
    b=0
    z=0
  endif
else
  while (n<nmax)&&(nflag==false)
    a=@ucoord+(scale*n+zlow)*1i
    if (@rotx!=0)||(@roty!=0)||(@rotz!=0)
      b=#pixel
       if @rotx!=0
         if @rotx==90.0
           sinrotx=1.0
           cosrotx=0
         elseif @rotx==-90
           sinrotx=-1.0
           cosrotx=0
         elseif abs(@rotx)==180
           sinrotx=0
           cosrotx=-1
         else

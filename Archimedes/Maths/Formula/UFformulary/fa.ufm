         x1=real(b)
         rz=z1*cosroty-x1*sinroty
         rx=z1*sinroty+x1*cosroty
         a=rz*1i+@ucoord
         b=rx+1i*imag(b)
       endif
       if @rotz!=0
         x1=real(b)
         y1=imag(b)
         rx=x1*cosrotz-y1*sinrotz
         ry=x1*sinrotz+y1*cosrotz
         b=rx+1i*ry
       endif
     endif
    endif
  endif
  if (nflag==false)&&(@solid==true)&&(@dim2==false)
    a=0
    b=0
    z=0
  endif
endif
if @zinit==0
  z=a
elseif @zinit==1
  z=-a
elseif @zinit == 2
  z= 0 
elseif @zinit>2
  if ainit==0
      z=a
  elseif ainit == 1
    z=-a
  elseif ainit == 2
    z=0
  
  endif
endif

loop:
  z=z*z*z*z-2*a*a*z*z+b
  
bailout:
  |z|<@bailout
  
default:
  title = "3DQuadric2"
  
  param fdim
    enum="a-real" "a-imag" "b-real" "b-imag"
    hint="The axis that shall point into the fourth dimension"
    default=3
    max=3
    min=0
  endparam
  
  param dim2
    caption="2-dimensional"
    hint="Renders 2-dimensional cubic"
    default=false
  endparam
  
  param localdim2
    caption="Local dim2-pos."
    default=false
  endparam
  
  param zvalue
    caption="z-value"
    hint="The midpoint at the z-axis. Default is 0."
    default=0.0
  endparam
  
  param ucoord
    caption="u-coord"
    hint="The coordinat of the fourth dimensions axis."
    default=0.0
  endparam
  
  param rotx
    caption="x-rot"
    hint="Rotates yz-plane."
    default=0.0
    min=-360.0
    max=360.0
  endparam
  
  param roty
    caption="y-rot"
    hint="Rotates zx-plane."
    default=0.0
    min=-360.0
    max=360.0
  endparam
  
  param rotz
    caption="z-rot"
    hint="Rotates xy-plane."
    default=0.0
    min=-360.0
    max=360.0
  endparam
  
  param zinit
    enum="+a" "-a" "0" "all" "CCL"
    default=3
  endparam
  
  
  param Magnification
    enum="auto" "z-low locked" "z-high locked" "free"
    default=0
    max=3
    min=0
  endparam
  
  param inside
    caption="Inside filter."
    default=false
  endparam
  
  param colscale
    caption="Color scaling."
    default=0.97
    max=1.0
    min=0
  endparam
  
  param colscale2
    caption="Color scaling 2."
    default=0.83
    max=1.0
    min=0
  endparam
  
  param colscale3
    caption="Color scaling 3."
    default=0.9
    max=1.0
    min=0
  endparam

  
  param solid
    caption="Solid outer color"
    default=true
  endparam
  
  param dist
    caption="z-dist"
    default=4.0
  endparam
  
  param zaxis
    enum="Screen-width" "Screen-height" "Free"
    default=1
  endparam
  
  param zlength
    caption="z-length-factor"
    default=2.0
    min=1e-10
  endparam  
  
  param bailout
    caption="bailout"
    hint="bailout"
    default=100
  endparam
}

volterra-lotka2a{
; Written by Luke Plant
; Modified by Frederik Slijkerman
; Inspired by Paul Carlson
; Modified by Frits Alsen

init:
  bool done = FALSE
  float x = real(#pixel)
  float y = imag(#pixel)
  float size = @width
  float num_ranges = real(@RangesColors)
  float colors_in_range = imag(@RangesColors)
  float index_factor= (colors_in_range -1)/size
  float range_num = 0
  int skip_iters = @skip
  int iter = 0
  #z = 254
  float f = 0.0
  float g = 0.0
  float x2 = 0.0
  float y2 = 0.0
  float x3 = 0.0
  float y3 = 0.0
  
loop:
  f = sqrt(abs(x*y))-x
  g = -sqrt(abs(x*y))+ y*cos(@a*y)
  x2 = x + @p * f
  y2 = y + @p * g 
  x3 =sqrt(abs(x2*y2))-x2
  y3 =-sqrt(abs(x2*y2))+ y2*cos(@a*@a*y2) 
  x = x + @h/2 * (f + x3)
  y = y + @h/2 * (g + y3)
  float dist = abs(x-y)  
  IF (dist < size && iter > skip_iters)
     done = TRUE
     #z = index_factor*dist + range_num * colors_in_range
  ELSEIF (iter == #maxiter -2)
     done = TRUE
     #z = 251   
  ENDIF  
  range_num = range_num +1
  IF (range_num > num_ranges - 0.05)
     range_num = 0.0
  ENDIF
  iter = iter +1
bailout:
  done = FALSE && abs(x*x+y*y) < 1.0e20      
default:
  title = "Volterra-Lotka2a"
  maxiter = 256
  center = (1.37,4.00)
  magn = 0.77
  param width
    caption = "Width Factor"
    default = 0.3
  endparam
  param skip
    caption = "Iterations to Skip"
    default = 0
  endparam

  param h
    caption = "Parameter h"
    default = 0.04
  endparam
  param p
    caption = "Parameter p"
    default = 0.86
  endparam
  param a    
    caption = "Parameter a"
    default = 4.0
  endparam 
  
}

Volterra-LotkaVar3 {;variation by Frits Alsen
init:
  float x = real(#pixel)
  float y = imag(#pixel)
  z = #pixel

loop:
  f  = x-p1*@func1(y+@func2(p2*x)+@func3(p3*y))
  g  = y-p1*@func1(x+@func1(p2*y)+@func3(p3*x))
  x2 = x + @p*f
  y2 = y + @p*g
  x3 = x2-p1*@func1(y2+@func2(p2*x2)+@func3(p3*y2))
  y3 = y2-p1*@func1(x2+@func1(p2*y2)+@func3(p3*x2))
  x1 = x + @h/2*(f+x3)
  y1 = y + @h/2*(g*y3)
  z  = x1+flip(y1)
  
bailout:
  |z| < @bailout
default:
  title = "Volterra-LotkaVar3"
  maxiter = 250 
  magn   = 0.1
  param h
    caption = "Parameter h"
    default = 1.0 
  endparam
  param p    
    caption = "Parameter p"
    default = 1.0 
  endparam  
  param p1    
    caption = "Parameter p1"
    default = 3.1415926
  endparam
  param p2    
    caption = "Parameter p2"
    default = 3.1415926
  endparam  
  param p3    
    caption = "Parameter p3"
    default = 2.7181
  endparam  


  param bailout
    caption = "Bailout value"
    default = 256.0
    min     = 1.0
  endparam
}

Volterra-Lotkavar7 {
; Written by Luke Plant
; Modified by Frederik Slijkerman
; Inspired by Paul Carlson
; Modified by Frits Alsen
init:
  bool done               = FALSE
  complex w               = #pixel
  float size              = @width
  float num_ranges        = real(@RangeColors)
  float colors_in_range   = imag(@RangeColors)
  float index_factor      = (colors_in_range -1) / size
  float range_num         = 0.0
  int skip_iters          = @skip
  int iter                = 0
  #z                      = 254
  float x                 = real(#pixel)
  float y                 = imag(#pixel)
  float f                 = 0.0
  float g                 = 0.0
  float x2                = 0.0
  float y2                = 0.0
  

loop:
  x = real(@func1(x))
  y = real(@func2(y))
  f = x - x * y
  g = -y + x * y
  x2 = x + @p * f
  y2 = y + @p * g 
  x = x + @h/2 * (f + ( x2 - x2*y2))
  y = y + @h/2 * (g + (-y2 + x2*y2))
  w = x + flip(y)
  a = atan(y/x)
  
  float dist = abs(|w|-|a|)
  IF (dist < size && iter >skip_iters)
     done = TRUE
     #z = index_factor*dist +range_num*colors_in_range
  ELSEIF (iter == #maxiter -2)
     done = TRUE
     #z = 251
  ENDIF      
  range_num = range_num +1
  IF (range_num > num_ranges -0.05)
    range_num =0.0
  ENDIF
  iter = iter +1  
  

bailout:
  done == FALSE && |w| < 1.0e20
default:
  title = "Volterra-LotkaVar7"
  maxiter = 149
  center = (3.0,2.25)
  magn = 0.666666666666
  param h
    caption = "Parameter h"
    default = 0.739
  endparam
  param p
    caption = "Parameter p"
    default = 0.739
  endparam
  param width    
    caption = "Width Factor"
    default = 0.3    
  endparam
  param skip    
    caption = "Iterations to skip"
    default = 0   
  endparam
  param RangeColors
    caption = "Ranges and Colors"
    default = (2,125)
  endparam  
  func func1
    caption = "func1"
    default = ident()
  endfunc
  func func2
    caption = "func2"
    default = ident()
  endfunc    
}

QuadricJulia {;a variation of Stig Pettersons formula CubicJulia
init:
  a=@areal+@aimag*1i
  b=@breal+@bimag*1i
  z=#pixel
loop:
  z=z*z*z*z-4*a*a*a*z+b  
bailout:
  |z|<@bailout
default:
  title = "Quadric Julia"
  
  param areal
    caption="a-real"
    hint="Real part of a-parameter"
    default=0.0
  endparam
  
   param aimag
    caption="a-imag"
    hint="Imaginary part of a-parameter"
    default=0.0
  endparam
  
   param breal
    caption="b-real"
    hint="Real part of b-parameter"
    default=0.0
  endparam
  
    
   param bimag
    caption="b-imag"
    hint="Imaginary part of b-parameter"
    default=0.0
  endparam
  
    
   param bailout
    caption="bailout"
    hint="Value of bailout"
    default=100  
  endparam
  
}

QuadricJulia2 {
;a second variation on Stig Pettersons formula CubicJulia
init:
  a=@areal+@aimag*1i
  b=@breal+@bimag*1i
  z=#pixel
loop:
  z=z*z*z*z-2*a*a*z*z+b  
bailout:
  |z|<@bailout
default:
  title = "Quadric Julia2"
  
  param areal
    caption="a-real"
    hint="Real part of a-parameter"
    default=0.0
  endparam
  
   param aimag
    caption="a-imag"
    hint="Imaginary part of a-parameter"
    default=0.0
  endparam
  
   param breal
    caption="b-real"
    hint="Real part of b-parameter"
    default=0.0
  endparam
  
    
   param bimag
    caption="b-imag"
    hint="Imaginary part of b-parameter"
    default=0.0
  endparam
  
    
   param bailout
    caption="bailout"
    hint="Value of bailout"
    default=100  
  endparam
  
}

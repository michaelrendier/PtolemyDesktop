           sinrotx=sin(rotx)
           cosrotx=cos(rotx)
         endif
         y1=imag(b)
         z1=imag(a)
         ry=y1*cosrotx-z1*sinrotx
         rz=y1*sinrotx+z1*cosrotx
         b=real(b)+ry*1i
         a=rz*1i+@ucoord
       endif
       if @roty!=0

               nflag=true
            elseif (nflag==false)&&(aflag==false)
              if |z|<zstore           
                 ainit =1
              else            
                 ainit = 0
            endif
            else           
               ainit = 1 
            endif
          elseif @zinit==4
            if (aflag==true)&&(nflag==true)
              if |z|<zstore           
                 ainit = 1
              else           
                 ainit = 0
              endif
            elseif (aflag==false)&&(nflag==false)
              if |z|<zstore           
                 ainit = 0
              else           

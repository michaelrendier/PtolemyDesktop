ExtraFoamExample3 {
fractal:
  title="Extra Foam example 3" width=800 height=640 layers=1
  credits="Kerry Mitchell;6/12/2021" antialiasing=yes
layer:
  caption="Background" opacity=100
mapping:
  center=-0.0951694952/0.1234249344 magn=313000 angle=-33
formula:
  maxiter=1000 percheck=off filename="lkm3.ufm" entry="extra-foam"
  p_pixel_type="all in" p_wq=yes p_zc=yes p_circuit_type=series
  p_bailout=1000 p_qinit=1/0 p_cinit=1/0 p_winit=0/0 p_zinit=0/0
  p_wpowerinw=-2/0 p_zpowerinw=2/0 p_wpowerinz=2/0 p_zpowerinz=2/0
inside:
  transfer=none
outside:
  transfer=linear filename="lkm3.ucl" entry="smooth-tanh" p_power=2/0
  p_bailout=1000000 p_mode=log p_density=1 p_minskip=0
gradient:
  smooth=yes rotation=-50 index=50 color=2129886 index=150
  color=16777215 index=250 color=10387296 index=-50 color=0
opacity:
  smooth=no index=0 opacity=255
}

RoundAndTransformExample1 {
fractal:
  title="Round and Transform example 1" width=800 height=600 layers=1
  credits="Kerry Mitchell;11/26/2021"
layer:
  caption="Background" opacity=100 method=multipass
mapping:
  center=0/0 magn=1e-3
formula:
  maxiter=100 percheck=off filename="lkm3.ufm"
  entry="round-and-transform" p_pixel_type="initial z"
  p_z_type="sum unit residuals" p_bailout=1000 p_q_roundbase=1/2
  p_base_transform=yes f_basefn=ident p_q_base_amp=1.6/-1.2
  p_q_base_freq=1/0 p_q_base_power=1/0 p_q_base_offset=0/0
  p_q_z_initial=0/1 p_use_mod=rounded f_zfn=ident p_q_z_amp=1/0
  p_q_z_freq=1/0 p_q_z_power=1/0 p_q_z_offset=0/0
inside:
  transfer=linear filename="lkm.ucl" entry="basic"
  p_colorby="polar angle"
outside:
  transfer=none solid=4294901760 filename="lkm3.ucl" entry="basic-3"
  p_vartype=z p_const=0/0 p_colorby=iterations f_fofvar=log
gradient:
  smooth=yes rotation=-160 index=40 color=16777215 index=140
  color=12484416 index=-160 color=0 index=-60 color=4227006
opacity:
  smooth=no index=0 opacity=255
}

RoundAndTransformExample2 {
fractal:
  title="Round and Transform example 2" width=800 height=600 layers=1
  credits="Kerry Mitchell;11/26/2021"
layer:
  caption="Background" opacity=100 method=multipass
mapping:
  center=-0.5/0 magn=1
formula:
  maxiter=100 percheck=off filename="lkm3.ufm"
  entry="round-and-transform" p_pixel_type="z offset"
  p_z_type="sum unit residuals" p_bailout=100 p_q_roundbase=0.01/0.02
  p_base_transform=no f_basefn=ident p_q_base_amp=0.25/0.75
  p_q_base_freq=1/0 p_q_base_power=1/0 p_q_base_offset=0/0
  p_q_z_initial=0/0 p_use_mod=rounded f_zfn=sqr p_q_z_amp=1/0
  p_q_z_freq=1/0 p_q_z_power=1/0 p_q_z_offset=0/0
inside:
  transfer=linear filename="lkm.ucl" entry="basic"
  p_colorby="polar angle"
outside:
  transfer=linear solid=4294901760 filename="lkm3.ucl" entry="basic-3"
  p_vartype=z p_const=0/0 p_colorby=iterations f_fofvar=log
gradient:
  comments="Kerry Mitchell/n /nrainbow gradient of all hues, full/nsat\
  uration and lightness" smooth=yes rotation=-50 index=0 color=82175
  index=50 color=127 index=100 color=4194305 index=150 color=16646144
  index=200 color=16760833 index=250 color=16711551 index=300
  color=12648447 index=349 color=458751 index=-50 color=65535
opacity:
  smooth=no index=0 opacity=255
}

RoundAndTransformExample3 {

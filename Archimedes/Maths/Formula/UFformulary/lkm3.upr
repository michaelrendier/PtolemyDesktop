4DAttractorsExample1 {
; Yu-Wang attractor, custom view, midpoint integration
fractal:
  title="4D Attractors example 1" width=800 height=800 layers=1
  credits="Kerry Mitchell;5/22/2021"
layer:
  caption="Layer 1" opacity=100 method=multipass
mapping:
  center=0/0 magn=0.0125
formula:
  maxiter=1 percheck=off filename="lkm.ufm" entry="pixel"
inside:
  transfer=none
outside:
  density=0.125 transfer=linear filename="lkm3.ucl"
  entry="4d-attractors" p_attractor=Yu-Wang p_samplefac=125
  p_transfac=1 p_integration=midpoint p_scaletype=logarithmic
  p_density=0.125 p_solidbg=no p_view_type=custom p_nrealc=2
  p_realc1=x p_realw1=1 p_realop1=+ p_realc2=y p_realw2=1
  p_realop2="*" p_realc3=z p_realw3=1 p_realop3=/ p_realc4=w
  p_realw4=1 p_nimagc=2 p_imagc1=z p_imagw1=1 p_imagop1=+ p_imagc2=w
  p_imagw2=1 p_imagop2="*" p_imagc3=ydot p_imagw3=1 p_imagop3=/
  p_imagc4=zdot p_imagw4=1 p_initialx=1 p_initialy=1 p_initialz=1
  p_initialw=1 p_dt=0.001 p_boualpha=-2 p_boubeta=1 p_bougamma=0.2
  p_bounu=1 p_chena=35 p_chenb=3 p_chenc=12 p_chend=7 p_chenr=0.3
  p_rossa=0.25 p_rossb=3 p_rossc=0.5 p_rossd=0.05 p_thoma=0.2
  p_thomb=0.2 p_thomc=0.2 p_thomd=0.2 p_ywa=8 p_ywb=5 p_ywc=13
  p_ywd=55 p_ywe=3
gradient:
  smooth=yes rotation=-200 index=0 color=16777215 index=100
  color=10387296 index=-200 color=0 index=-100 color=2129886
opacity:
  smooth=no index=0 opacity=255
}

4DAttractorsExample2 {
; Bouali attractor, z-w view, Euler integration
fractal:
  title="4D Attractors example 2" width=800 height=400 layers=1
  credits="Kerry Mitchell;5/22/2021"
layer:
  caption="Layer 1" opacity=100 method=multipass
mapping:
  center=-0.10971970644/-1.92332363475 magn=4 angle=89
formula:
  maxiter=1 percheck=off filename="lkm.ufm" entry="pixel"
inside:
  transfer=none
outside:
  density=0.25 transfer=linear filename="lkm3.ucl"
  entry="4d-attractors" p_attractor=Bouali p_samplefac=200
  p_transfac=1 p_integration=Euler p_scaletype=logarithmic p_density=1
  p_solidbg=yes p_view_type=z-w p_nrealc=1 p_realc1=x p_realw1=1
  p_realop1=+ p_realc2=y p_realw2=1 p_realop2="*" p_realc3=z
  p_realw3=1 p_realop3=/ p_realc4=w p_realw4=1 p_nimagc=1 p_imagc1=w
  p_imagw1=1 p_imagop1=+ p_imagc2=xdot p_imagw2=1 p_imagop2="*"
  p_imagc3=ydot p_imagw3=1 p_imagop3=/ p_imagc4=zdot p_imagw4=1
  p_initialx=1 p_initialy=1 p_initialz=1 p_initialw=1 p_dt=0.005
  p_boualpha=-2 p_boubeta=1 p_bougamma=0.2 p_bounu=1 p_chena=35
  p_chenb=3 p_chenc=12 p_chend=7 p_chenr=0.3 p_rossa=0.25 p_rossb=3
  p_rossc=0.5 p_rossd=0.05 p_thoma=0.2 p_thomb=0.2 p_thomc=0.2
  p_thomd=0.2 p_ywa=8 p_ywb=5 p_ywc=12 p_ywd=60 p_ywe=4
gradient:
  smooth=yes rotation=-175 index=25 color=16777215 index=125
  color=14581536 index=-175 color=0 index=-75 color=10387296
opacity:
  smooth=no index=0 opacity=255
}

4DAttractorsExample3 {
; Rossler attractor, custom view, Runge-Kutta integration
fractal:
  title="4D Attractors example 3" width=900 height=600 layers=1
  credits="Kerry Mitchell;5/22/2021"
layer:
  caption="Layer 1" opacity=100 method=multipass
mapping:
  center=-2/0.2 magn=0.14
formula:
  maxiter=1 percheck=off filename="lkm.ufm" entry="pixel"
inside:
  transfer=none
outside:
  transfer=linear repeat=no filename="lkm3.ucl" entry="4d-attractors"
  p_attractor=Rossler p_samplefac=200 p_transfac=1
  p_integration=Runge-Kutta p_scaletype="hyperbolic tangent"
  p_density=0.01 p_solidbg=yes p_view_type=custom p_nrealc=2
  p_realc1=x p_realw1=0.1 p_realop1="*" p_realc2=xdot p_realw2=0.1
  p_realop2="*" p_realc3=z p_realw3=1 p_realop3=/ p_realc4=w
  p_realw4=1 p_nimagc=2 p_imagc1=y p_imagw1=0.1 p_imagop1="*"
  p_imagc2=ydot p_imagw2=0.1 p_imagop2="*" p_imagc3=ydot p_imagw3=1
  p_imagop3=/ p_imagc4=zdot p_imagw4=1 p_initialx=-10 p_initialy=-6
  p_initialz=0 p_initialw=10 p_dt=0.01 p_boualpha=-2 p_boubeta=1
  p_bougamma=0.2 p_bounu=1 p_chena=35 p_chenb=3 p_chenc=12 p_chend=7
  p_chenr=0.3 p_rossa=0.25 p_rossb=3 p_rossc=0.5 p_rossd=0.05
  p_thoma=0.2 p_thomb=0.2 p_thomc=0.2 p_thomd=0.2 p_ywa=8 p_ywb=5
  p_ywc=12 p_ywd=60 p_ywe=4
gradient:
  smooth=yes index=0 color=0 index=100 color=8257599 index=399
  color=16777215
opacity:
  smooth=no index=0 opacity=255
}


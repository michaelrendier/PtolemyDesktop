comment {

Here are some samples images that
illustrate the use of various formulas
and coloring schemes that I've developed.
These images and their parameters work in
version 3, but not in version 2.

All images copyright Kerry Mitchell.

Compilation dated 12 June 2021.

}

ChaoticFlower {
; Copyright © 2002 by Kerry Mitchell.
fractal:
  title="Chaotic Flower" width=480 height=480 layers=1
  credits="Kerry Mitchell;9/8/2002"
layer:
  method=multipass caption="Layer 1" opacity=100
mapping:
  center=0/0 magn=2.75
formula:
  maxiter=1 percheck=off filename="mt.ufm" entry="mt-pixel" p_inside=yes
inside:
  transfer=sqrt filename="lkm3.ucl" entry="symmetric-icons" p_lambda=-2.5
  p_alpha=5 p_beta=-1.9 p_gamma=1 p_omega=0.188 p_delta=0.0 p_n=5 p_p=0
  p_samplefac=20 p_ntrans=100 p_scaletype="linear" p_solidbg=yes
outside:
  transfer=linear
gradient:
  smooth=yes rotation=140 index=17 color=65535 index=217 color=255
opacity:
  smooth=no index=0 opacity=255
}

SymmetricIconsExample {
; Copyright © 2002 by Kerry Mitchell.
fractal:
  title="Symmetric Icons Example" width=480 height=480 layers=1
  credits="Kerry Mitchell;9/8/2002"
layer:
  method=multipass caption="Layer 1" opacity=100
mapping:
  center=0/0 magn=1.3559322
formula:
  maxiter=1 percheck=off filename="mt.ufm" entry="mt-pixel" p_inside=yes
inside:
  transfer=linear repeat=no filename="lkm3.ucl" entry="symmetric-icons"
  p_lambda=-2.4 p_alpha=1.2 p_beta=-0.1 p_gamma=0.1 p_omega=0.2
  p_delta=0.05 p_n=6 p_p=5 p_samplefac=10 p_ntrans=100
  p_scaletype="hyperbolic tangent" p_solidbg=no
outside:
  transfer=linear
gradient:
  comments="Kerry Mitchell/n /nrainbow gradient with green negated"
  smooth=yes index=0 color=16777215 index=399 color=8388608
opacity:
  smooth=no index=0 opacity=255
}

SymmetricIconsExample2 {
; Copyright © 2002 by Kerry Mitchell.
fractal:
  title="Symmetric Icons Example 2" width=480 height=480 layers=1
  credits="Kerry Mitchell;9/8/2002"
layer:
  method=multipass caption="Layer 1" opacity=100
mapping:
  center=0.047456436/0.1686500118 magn=2.25 angle=30.2851
formula:
  maxiter=1 percheck=off filename="mt.ufm" entry="mt-pixel" p_inside=yes
inside:
  density=3 transfer=cuberoot filename="lkm3.ucl" entry="symmetric-icons"
  p_lambda=-2 p_alpha=2.5 p_beta=-1 p_gamma=1 p_omega=-0.2 p_delta=0.2
  p_n=3 p_p=3 p_samplefac=10 p_ntrans=100 p_scaletype="logarithmic"
  p_solidbg=yes
outside:
  transfer=linear
gradient:
  comments="Kerry Mitchell/n /nrainbow gradient with green negated"
  smooth=yes rotation=-60 index=140 color=0 index=340 color=16777215
opacity:
  smooth=no index=0 opacity=255
}

RotatedJuliaSample {
; Copyright © 2002 by Kerry Mitchell.
fractal:
  title="Rotated Julia Sample" width=480 height=480 layers=1
  credits="Kerry Mitchell;10/6/2002"
layer:
  method=multipass caption="Background" opacity=100
mapping:
  center=0/0 magn=1.8 angle=45
formula:
  maxiter=10000 percheck=off filename="lkm3.ufm" entry="rotated-julia"
  p_julparam=-0.480240884475/0.0477148441278 p_power=2/0 p_bailout=1000000
  p_rottype="before iterating" p_rotfac=1 p_angletype="z"
inside:
  transfer=none
outside:
  transfer=sqrt filename="Standard.ucl" entry="Smooth" p_power=2/0
  p_bailout=1e6
gradient:
  comments="Kerry Mitchell" smooth=yes rotation=-30 index=70 color=4243584
  index=170 color=16777215 index=270 color=4243584 index=370 color=0
opacity:
  smooth=no index=0 opacity=255
}

RotatedMandelbrotSample {
; Copyright © 2002 by Kerry Mitchell.
fractal:
  title="Rotated Mandelbrot Sample" width=640 height=480 layers=1
  credits="Kerry Mitchell;10/6/2002"
layer:
  method=multipass caption="Layer 1" opacity=100
mapping:
  center=-0.375/0.255 magn=60 angle=-45
formula:
  maxiter=10000 percheck=off filename="lkm3.ufm" entry="rotated-mandelbrot"
  p_manparam=0/0 p_power=2/0 p_bailout=1000000 p_rottype="before & after"
  p_rotfac=1 p_angletype="z"
inside:
  transfer=none
outside:
  transfer=sqrt filename="Standard.ucl" entry="Smooth" p_power=2/0
  p_bailout=1e6
gradient:
  comments="Kerry Mitchell/n/nsorta mimics Fractint's good32.map/n"
  smooth=yes rotation=150 index=49 color=16711680 index=149 color=131071
  index=249 color=78079 index=349 color=0
opacity:
  smooth=no index=0 opacity=255
}

RotatedMandelbrotSample2 {
; Copyright © 2002 by Kerry Mitchell.
fractal:
  title="Rotated Mandelbrot Sample 2" width=480 height=480 layers=1
  credits="Kerry Mitchell;10/6/2002"
layer:
  method=multipass caption="Layer 1" opacity=100
mapping:
  center=0/0 magn=10 angle=0.01
formula:
  maxiter=250 percheck=off filename="lkm3.ufm" entry="rotated-mandelbrot"
  p_manparam=0/0 p_power=2/0 p_bailout=1000000 p_rottype="+before, -after"
  p_rotfac=3 p_angletype="z"
inside:
  transfer=sqrt filename="lkm.ucl" entry="statistics" p_vartype="magnitude"
  p_stattype="fractal dimension"
outside:
  transfer=none filename="Standard.ucl" entry="Basic" p_type="Iteration"
gradient:
  smooth=yes index=73 color=16645116 index=173 color=13812134 index=273
  color=2101559 index=373 color=337170
opacity:
  smooth=no index=0 opacity=255
}


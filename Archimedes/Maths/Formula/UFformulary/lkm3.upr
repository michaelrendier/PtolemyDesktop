mapping:
  center=-0.27/-0.38 magn=0.4
formula:
  maxiter=32 percheck=off filename="lkm3.ufm" entry="caramel-popcorn-3axis"
  p_control="more" p_bailout=1000 p_bailtype="any argument"
  p_ztype="x1 and x2" p_h=1/0 p_b=1/0 f_outerfn=sin f_innerfn=ident
  p_x1init=0/0 p_h1=0.125/0 p_a1=1/0 p_b1=1/0 p_vartype1="x2"
  f_varfn1=ident f_outerfn1=cos f_innerfn1=cos p_x2init=0/0 p_h2=0.125/0
  p_a2=1/0 p_b2=1/0 p_vartype2="x1" f_varfn2=ident f_outerfn2=sin
  f_innerfn2=sin p_x3init=1/0 p_h3=0.125/0 p_a3=1/0 p_b3=1/0
  p_vartype3="all 3" f_varfn3=ident f_outerfn3=ident f_innerfn3=cos
inside:
  transfer=linear solid=4294967295 filename="lkm.ucl"
  entry="rose-range-lite" p_scale=1 p_rangewidth=0.1
  p_colorby="first magnitude" p_ac=1 p_bc=0 p_as=1 p_bs=7 p_curvecenter=1/0
  p_rot=14
outside:
  transfer=none solid=4294901760 filename="lkm.ucl" entry="basic"
  p_colorby="iteration"
gradient:
  smooth=yes index=0 color=16777215 index=200 color=0
opacity:
  smooth=no index=0 opacity=255
}


SmoothTanhSample {
fractal:
  title="Smooth Tanh Sample" width=640 height=480 layers=1
  credits="Kerry Mitchell;10/19/2003"
layer:
  method=multipass caption="Background" opacity=100
mapping:
  center=-0.4193816908639/0.57713557127815 magn=539.51962 angle=29.1444
formula:
  maxiter=10000 percheck=off filename="Standard.ufm" entry="Mandelbrot"
  p_start=0/0 p_power=2/0 p_bailout=1e6
inside:
  transfer=none
outside:
  transfer=linear repeat=no filename="lkm3.ucl" entry="smooth-tanh"
  p_power=2/0 p_bailout=1e6 p_density=0.05 p_minskip=0
gradient:
  smooth=yes index=0 color=0 index=300 color=8355711 index=399
  color=16777215
opacity:
  smooth=no index=0 opacity=255
}

CaramelPopcorn3AxisSample1 {
; Copyright © 2003 by Kerry Mitchell.
fractal:
  title="Caramel Popcorn 3 Axis Sample 1" width=576 height=480 layers=1
  credits="Kerry Mitchell;10/26/2003"
layer:

  uration and lightness" smooth=yes rotation=50 index=400
  color=12648447 index=449 color=458751 index=50 color=65535 index=100
  color=82175 index=150 color=127 index=200 color=4194305 index=250
  color=16646144 index=300 color=16760833 index=350 color=16711551
opacity:
  smooth=no index=0 opacity=255
}


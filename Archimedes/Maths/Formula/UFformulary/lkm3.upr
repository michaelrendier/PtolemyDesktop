FourierPopcornSample1 {
; square wave, basic
fractal:
  title="Fourier Popcorn sample 1" width=800 height=800 layers=1
  credits="Kerry Mitchell;5/17/2015"
layer:
  caption="Layer 1" opacity=100 method=multipass
mapping:
  center=0/0 magn=0.27
formula:
  maxiter=50 percheck=off filename="lkm3.ufm" entry="fourier-popcorn"
  p_control_type=basic p_bailout=1000 p_hall=0.05/0
  p_functypeall="sin odd pos" p_powerall=1/0 p_ntermall=10
  p_slopeall=1/0 f_funcall=tan p_hx=0.1/0 p_vartypexin=y
  p_functypexin="cos odd pos" p_powerxin=1/0 p_ntermxin=10
  f_funcxin=cos p_vartypexout=y p_functypexout="cos odd pos"
  p_powerxout=1/0 p_ntermxout=10 p_slopexout=1/0 f_funcxout=cos
  p_hy=0.1/0 p_vartypeyin=x p_functypeyin="sin odd pos" p_poweryin=1/0
  p_ntermyin=10 f_funcyin=sin p_vartypeyout=x
  p_functypeyout="sin odd pos" p_poweryout=1/0 p_ntermyout=10
  p_slopeyout=1/0 f_funcyout=sin
inside:
  transfer=linear filename="lkm3.ucl" entry="basic-3"
  p_vartype="z - pixel" p_const=0/0 p_colorby="polar angle"
  f_fofvar=ident
outside:
  transfer=linear
gradient:
  smooth=yes index=0 color=0 index=100 color=32766 index=200
  color=16777215 index=300 color=8273664
opacity:
  smooth=no index=0 opacity=255
}


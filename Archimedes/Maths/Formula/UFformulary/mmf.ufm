  endparam
  param cx4
    caption = "Co. of x^4"
    default = (0,0)
    hint = "The coefficients of x^4 in F(x,y) and G(x,y), \
            please note that the real part sets the value in F() \
            to use for the calculation of the new x part of z \
            and the imaginary part sets the value in G() to use for \

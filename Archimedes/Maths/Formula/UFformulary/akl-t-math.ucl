          textureSumDiv = abs(reSumDiv_R)/500
        endif
      elseif (@txtr_SumDiv_col == 7)
        if abs(imSumDiv_R) < abs(reSumDiv_R)
          textureSumDiv = abs(imSumDiv_R/reSumDiv_R)
        else
          textureSumDiv = abs(reSumDiv_R/imSumDiv_R)

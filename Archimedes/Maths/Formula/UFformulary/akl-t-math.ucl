    if (@txtr_MLAB!= 0)
      float   txtrB_ux   = 0.0
      float   txtrB_uy   = 0.0

      float   txtrB_scax = 0.0
      float   txtrB_scay = 0.0

      float   txtrB_ax   = 0.0
      float   txtrB_ay   = 0.0

      float   txtrB_mx   = 0.0
      float   txtrB_my   = 0.0
      float   txtrB_mr   = 0.0

      int     txtrB_i    = 0
      bool    txtrB_done = false

      bool    txtrB_ix   = false
      bool    txtrB_iy   = false

      ;----------------------------------

      complex zMLAB = _zz

      if (@txtr_MLAB_lattice == 0)
        zMLAB = zMLAB*@txtr_MLAB_scale
      elseif (@txtr_MLAB_lattice == 1)
        zMLAB = zMLAB-trunc(zMLAB*@txtr_MLAB_scale)/@txtr_MLAB_scale
      elseif (@txtr_MLAB_lattice == 2)
        zMLAB = zMLAB-trunc(zMLAB*@txtr_MLAB_scale*10)
      elseif (@txtr_MLAB_lattice == 3)
        zMLAB = zMLAB-trunc(@txtr_MLAB_scale/zMLAB)
      elseif (@txtr_MLAB_lattice == 4)

      float x = real(zGnarl)
      float y = imag(zGnarl)
      float xOld = 0

      int iter3 = @txtr_gnarl_octaves
      while (iter3 > 0)
        iter3 = iter3-1
        xOld = x

        x = x - sin(y    + sin(y))
        y = y - sin(xOld + sin(xOld))
      endwhile

      float textureGnarl = 0
      if     (@txtr_gnarl_type == 0)
        textureGnarl = abs(x)
      elseif (@txtr_gnarl_type == 1)

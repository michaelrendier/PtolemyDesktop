          float txtr_v_center = (txtr_v_rigt+txtr_v_left)/2
          if (txtr_v_xPos<=txtr_v_left || txtr_v_xPos>=txtr_v_rigt)
            txtr_v_verlauf = 0
          elseif (txtr_v_xPos<txtr_v_center) ; below center
            txtr_v_verlauf = 2*(txtr_v_xPos-txtr_v_left)/txtr_v_width
          elseif (txtr_v_xPos>txtr_v_center) ; above center
            txtr_v_verlauf = 2*(txtr_v_rigt-txtr_v_xPos)/txtr_v_width

        txtr_v_verlauf = abs(txtr_v_verlauf)
        if (@txtr_verlauf_exponent != 1)
          txtr_v_verlauf = txtr_v_verlauf^@txtr_verlauf_exponent
        endif
        txtr_v_verlauf = txtr_v_verlauf + @f_SumDiv_verlaufOffset

      endif

      to_index = to_index + @txtr_SumDiv*txtr_v_verlauf*textureSumDiv


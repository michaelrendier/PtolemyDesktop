    caption = "T: SumDiv Color Mode"
    enum    = "Real" "Imag" "Sum" "Abs Sum" "Diff" "Min" "Max" "MinQuot" "MaxQuot" "Prod" "Prod/Sum" "11" "12" "13"
    default = 2
  endparam

  param txtr_SumDiv_mode

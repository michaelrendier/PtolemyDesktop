y=(p1-#pixel)*((p2-#pixel^2)*(real(#pixel)*imag(#pixel)-real(#pixel)-#pixel*imag(#pixel))-p2*(-real(#pixel)-#pixel*imag(#pixel))-p3*#pixel)
#pixel=fn1(#pixel^2*(p2-#pixel^2)*(x^2+y^2))

Hypermorph {
;Part of this is based on 'Hyperbolic mapping' by Ron Barnett (reb.uxf)
transform:
f=(0,0)

if @V==0
f=fn2((#pixel)/(sqrt(p1^2-|#pixel|)))
elseif @V==1
f=fn2((#pixel)/(sqrt(p1^2+|#pixel|)))
elseif @V==2
f=fn2((#pixel)/(ceil(sqrt(p1^2-|#pixel|))))
elseif @V==3
f=fn2((#pixel)/(round(sqrt(p1^2+|#pixel|))))
endif

f = f*4/p2
#pixel=p3*fn1((f-sqrt(-1))/(f+sqrt(-1)))^@pow

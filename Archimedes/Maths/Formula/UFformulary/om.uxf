  endparam
}

Hypermorph2 {
; A modification of "Hyperbolic tilings" by Samuel Monnier (sam.uxf)
transform:
  z=fn1(#pixel)
  a=0
  b=0
  float c=sqrt(cos(pi/7)^2/(cos(pi/7)^2-sin(pi/3)^2))
  float d=sqrt(c^2-1)
  float f=0
  int i=0
  while i<1000
  i=i+1
  f=atan2(z)
  f=-round(f/(2*pi)*3)/3*(2*pi)
  a=fn2(z*exp(1i*f))
  if cabs(a-c)>d
  b=z
  i=1000
  else
  z=p1*fn3(c+d^2/(a-c))
  endif
  endwhile
  b = b*p2
  #pixel=fn4(b)+p3
default:
  title="Hypermorph 2"
   func fn1
   default=ident()
   endfunc
   func fn2
   default=ident()
   endfunc
   func fn3
   default=ident()
   endfunc
   func fn4
   default=sqrt()
   endfunc
  param p1
  caption="Parameter 1"
  default=1.0
  endparam
  param p2
  caption="Parameter 2"
  default=1.0
  endparam
  param p3
  caption="Parameter 3"
  default=0.0
  endparam

}


  default=ident()
  endfunc
}

ThreeKleinTransform{
; Adapted and modified from Morgan_L_Owens.frm
global:

transform:
a=2*pi/3
c1=p3*fn2(exp((0,0)*a))
c2=p3*fn2(exp((0,1)*a))
c3=p3*fn2(exp((0,2)*a))
r=fn3(sqrt(p4)/2)

if |#pixel-c1|<|r|
         #pixel=p1*fn1(r*conj(r/(#pixel-c1))+c1)^@pow+p2

elseif |#pixel-c2|<|r|
         #pixel=p1*fn1(r*conj(r/(#pixel-c2))+c2)^@pow+p2

elseif |#pixel-c3|<|r|
         #pixel=p1*fn1(r*conj(r/(#pixel-c3))+c3)^@pow+p2
else
#pixel=p1*fn1(r*conj(r/(#pixel)))^@pow+p2

endif

default:
 title="Three Klein Transform"
  param p1
 default=(1,0)
 endparam
 param p2
 default=(0,0)
 endparam
 param p3
 default=(1,0)
 endparam
 param p4
 caption="Parameter 4"
 default=3.0
 endparam
 func fn1
 default=ident()
 endfunc

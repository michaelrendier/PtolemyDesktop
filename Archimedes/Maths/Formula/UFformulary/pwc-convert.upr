MetallicAnodizedMset {
; Paul Carlson 
; This one does not duplicate exactly.
fractal:
  title="Metallic Anodized Mset" width=640 height=480 numlayers=2
layer:
  method=linear caption="Original" opacity=100 visible=no alpha=no
  mergemode=difference
mapping:
  center=-2.170178301/-4.30828E-6 magn=328.28655 angle=90
formula:
  filename="pwc.ufm" entry="Cosh_Tan_Mset" maxiter=500 percheck=off
  p_width=16
inside:
  filename="pwc.ucl" entry="ZtoIndex" transfer=linear repeat=yes
  p_forma="Real" p_rango=256 p_sele=256 f_fn1=ident
outside:
  filename="pwc.ucl" entry="ZtoIndex" transfer=linear repeat=yes
  p_forma="Real" p_rango=256 p_sele=256 f_fn1=ident
gradient:
  smooth=no numnodes=9 index=0 color=0 index=1 color=16777085 index=142
  color=4737032 index=195 color=4210688 index=197 color=16777085 index=337
  color=4737032 index=391 color=4210688 index=392 color=0 index=399 color=0
layer:
  method=linear caption="Modified" visible=yes alpha=no
mapping:
  center=-2.170178301/-4.30828E-6 magn=328.28655 angle=90
formula:
  filename="pwc-convert.ufm" entry="CoshTan-bare" maxiter=500 percheck=off
  p_bailout=1E200
inside:
  filename="pwc.ucl" entry="AtanMethods" transfer=linear repeat=yes
  p_Variant="Normal" p_MaxReal=16 p_skip=0 p_RangesColors=2/125
  p_back_color=254 p_solid=no
outside:
  filename="pwc.ucl" entry="AtanMethods" transfer=linear repeat=yes
  p_Variant="Normal" p_MaxReal=16 p_skip=0 p_RangesColors=2/125
  p_back_color=254 p_solid=no
gradient:
  smooth=no numnodes=9 index=0 color=0 index=1 color=16777085 index=142
  color=4737032 index=195 color=4210688 index=197 color=16777085 index=337
  color=4737032 index=391 color=4210688 index=392 color=0 index=399 color=0
}


3RDIMMagnet2  {
; Ron Barnett December 31, 2004
init:
   #z = @p1*real(@start)+flip(imag(@start))
   complex c = @p2+real(#pixel)+flip(imag(#pixel)*@p1)
   complex num = 0
   complex denom = 0
loop:  
   num = #z^3 + 3*(c-1)*#z + (c-1)*(c-2)
   denom = 3*#z^2 + 3*(c-2)*#z + (c-1)*(c-2) + 1
   #z = (num/denom)^2      
bailout:
   |#z| <= @bailout && |#z-1| > @bailout2                                         
default:
  title = "4D Magnet2 3RDIM"
  maxiter = 1000
  periodicity = 0
  method = multipass
  center = (1, 0)

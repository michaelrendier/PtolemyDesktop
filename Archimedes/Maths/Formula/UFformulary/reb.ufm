  endheading         
  heading
    caption="3D Texturizer III is needed for"
  endheading
  heading
    caption="the non-slope color options."
  endheading 
$endif
  title="Slope 4D Quadratic ODE G Attractor"
  maxiter=1000
  method=multipass
  periodicity=0
  float param version
    caption = "Version number"
    default = 1.1

  param bailout
    caption = "Bailout (div)"
    default = 100.0
    min = 1
  endparam
  param bailout2
    caption = "Bailout (conv)"
    default = 0.000001
  endparam
  param p1
    caption = "Plane rotation"
    default = (0.5,0.0)
  endparam
  param p2

  dxz=(tempz-rminz)/xscreen
  xx=tempx=xmin
  yy=tempy=ymax
  zz=tempz=zmin
if @local==true
  xx=xx-origx
  yy=yy-origy
  zz=zz-origz
endif
  xy=yy*cosx-zz*sinx

    sinz=1.0
    cosz=0
  elseif @zrot==-90
    sinz=-1.0
    cosz=0
  elseif abs(@zrot)==180
    sinz=0
    cosz=-1
  else
    cosz=cos(vz)
    sinz=sin(vz)
  endif
  float rminx=0
  float rminy=0
  float rminz=0
  float xy=0
  float xz=0
  float yx=0
  float yz=0
  float zx=0
  float zy=0
  float tempx=0
  float tempy=0
  float tempz=0
  float dxx=0
  float dxy=0
  float dxz=0
  float dyx=0
  float dyy=0
  float dyz=0
  float dzx=0
  float dzy=0
  float dzz=0
  float dzx=0
  float dzy=0
  float dzz=0
  float dzx1=0
  float dzy1=0
  float dzz1=0
; rotating the space and creation of unit-vectors
  xx=rminx=xmin
  yy=rminy=ymin
  zz=rminz=zmin
if @local==true

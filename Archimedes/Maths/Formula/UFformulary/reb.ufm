  endparam
switch:
  type = "FrameRobertRoots-Mandel"
  bailout = @bailout
  p1 = #pixel
  init = @init
}

IkenagaRoots-Julia { ; Ron Barnett, September 2000
; Another Newton with mini-julias
; Based on the Ikenaga formula
init:
  #z = #pixel

endif
  tempx=xx
  tempy=yy
  tempz=zz
  dzx=(tempx-rminx)/zscreen
  dzy=(tempy-rminy)/zscreen
  dzz=(tempz-rminz)/zscreen
  dzx1=dzx/@prec
  dzy1=dzy/@prec
  dzz1=dzz/@prec
; end rotation and creating unit-vectors 'puuh'
if @formula==0   
  count0=0
  repeat
    diffx=0
    diffy=0
    if count0==1
      diffx=-@delta
    elseif count0==2
      diffx=@delta
    elseif count0==3
      diffy=@delta

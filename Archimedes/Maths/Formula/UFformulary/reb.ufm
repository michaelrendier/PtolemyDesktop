  a = a
}

MandelGopalsamy3 { ; Ron Barnett, October 2006
init:
   #z = @start
loop:
   x = real(#z)
   y = imag(#z)
   x1 = 3*x*y*y - x*x*x + #pixel
   y = y*y*y - 3*x*x*y
   #z = x1 + flip(y)

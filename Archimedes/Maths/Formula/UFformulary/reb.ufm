  float b25 = 0
  float b26 = 0
  float b27 = 0
  float b28 = 0
  float b29 = 0
  float b30 = 0
  int iter = 0
  int px = 0
  int py = 0
  float cy = imag(#center)
  float cx = real(#center)
  float txmax = 4.0/#magn
  float tymax = txmax*#height/#width
  float tzmax = sqrt(txmax^2+tymax^2)
  float xmin = cx - txmax/2
  float ymin = cy - tymax/2
  float zmin = sqrt(xmin^2 + ymin^2)
  float iterate = @density*10000000
  float maxnhit = 0
;
; initialize hit array
;
  while(h < #height)
    while(w < #width)
      hits[w,h] = 0
      hits2[w,h] = 0
      hits3[w,h] = 0
      w = w + 1
    endwhile
    w = 0
    h = h + 1
  endwhile
;
; initialize presets
;
s[1,1]=1.0,s[1,2]=-1.1,s[1,3]=-0.6,s[1,4]=-1.0,s[1,5]=0.2,s[1,6]=0.4,s[1,7]=1.0,s[1,8]=0.8,s[1,9]=0.5,s[1,10]=-0.8,s[1,11]=0.1,s[1,12]=-0.1,s[1,13]=-1.2,s[1,14]=-0.9,s[1,15]=0.3,s[1,16]=1.0,s[1,17]=-0.9,s[1,18]=-0.5,s[1,19]=1.1,s[1,20]=1.0,s[1,21]=0.1,s[1,22]=-1.0,s[1,23]=1.0,s[1,24]=-0.9,s[1,25]=-0.4,s[1,26]=-0.6,s[1,27]=0.3,s[1,28]=-0.6,s[1,29]=0.1,s[1,30]=0.7

    default = 0
    enum = "mod" "real" "imag" "or" "and" "manh" "manr"
  endparam
  float param bailout
    caption = "Bailout value"
    default = 10000
    min = 1
  endparam
  param p1
    caption = "Parameter 1"
    default = (-0.23, -0.1)
  endparam
  func fn1
     caption = "First Function"
     default = asin()
  endfunc
  func fn2
     caption = "Second Function"
     default = cos()
  endfunc
  func fn3
     caption = "Third Function"
     default = cosh()
  endfunc
  func fn4
     caption = "Fourth Function"
     default = atan()
  endfunc
switch:
  type = "MandelGopalsamyFn"
  bailout = @bailout
  fn1 = @fn1
  fn2 = @fn2
  fn3 = @fn3
  fn4 = @fn4
}


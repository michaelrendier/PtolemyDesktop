  float tymax = txmax*#height/#width
  float tzmax = sqrt(txmax^2+tymax^2)
  float xmin = cx - txmax/2
  float ymin = cy - tymax/2
  float zmin = sqrt(xmin^2 + ymin^2)
  float iterate = @density*10000000
  float maxnhit = 0
;
; initialize hit array
;

if @local==true
  xx=xx+origx
  yy=yy+origy
zz=zz+origz
  endif
  rminx=xx
  rminy=yy
  rminz=zz
  xx=tempx=xmax
  yy=tempy=ymin
  zz=tempz=zmin
if @local==true
  xx=xx-origx
  yy=yy-origy
  zz=zz-origz
endif
  xy=yy*cosx-zz*sinx
  xz=yy*sinx+zz*cosx
  yy=xy
  zz=xz

         xx=xx-dzx1
         yy=yy-dzy1
         zz=zz-dzz1
          m=0
          z1=xx+flip(yy)
          zh=zz+flip(ww)
          z=z1
          repeat
          xf = real(z)
          yf = imag(z)
          zf = real(zh)
          z = (xf^2+yf^2+zf^2-@a*@c^2)^2-@b*((zf-@c)^2-2*xf^2)*((zf+@c)^2-2*yf^2)
            length=|z|
            m=m+1
          until m>=#maxiter || length>@bailout
          count2=count2+1
        until length>=@bailout
        if count0==0
          buff0=zmin+count*dz-(count2-1)*dz/@prec
        elseif count0==1

    min=1e-12
    visible=@formula=="Magnet1"||@formula=="Magnet2"||@formula=="Cayley"
  endparam
  func hyperfun
    caption="HyperFunction"
    default = sqr()
    visible=@formula=="HyperFnJulia"
  endfunc  
  param fourthdim
    enum="a-real or zr" "a-imag or zi" "b-real or zj" "b-imag or zk"
    default=3

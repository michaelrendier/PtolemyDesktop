            ||@formula=="QuatFrame-Robert"||@formula=="QuatIkenaga"||@formula=="QuatManowar"||@formula=="QuatSpider"||@formula=="HyperManowar" \
            ||@formula=="HyperSpider"||@formula=="QuatExpJulia"||@formula=="QuatPowerJulia"||@formula=="QuatSinJulia"||@formula=="QuatCosJulia" \
            ||@formula=="HyperPowerJulia"||@formula=="QuatLambdaPower"
  endparam
  param bailout2
    caption="Convergent Bailout"
    default=0.000001
    hint="Breakvalue for iterations."

               12*(1-zf)*zf*(27*(xf^2+yf^2)^2-24*zf^2*(xf^2+yf^2)+ \
               36*sqrt(2)*yf*zf*(yf^2-3*xf^2)+4*zf^4)+ \
               (9*xf^2+9*yf^2-2*zf^2)*(-81*(xf^2+yf^2)^2-72*zf^2*(xf^2+yf^2)+ \
               108*sqrt(2)*xf*zf*(xf^2-3*yf^2)+4*zf^4)
            length=|z|
            m=m+1
          until m>=#maxiter || length>@bailout
          count2=count2+1
        until length>=@bailout
        if count0==0

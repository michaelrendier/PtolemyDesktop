    text = "Use the location tab XY Plane Rotation."
  endheading
$endif
  param xangle
    caption = "YZ Plane Rotation"
    default = 0.0
    hint = "This is equivalent of a X Axis rotation in 3 Dimensions. \
            It is performed after the normal fractal rotation(s) \
            (XY Plane Rotation) and zooms." 
  endparam   
  param zangle
    caption = "XZ Plane Rotation"
    default = 0.0
    hint = "This is equivalent of a Y Axis rotation in 3 Dimensions. \
            It is performed after the normal fractal rotation(s) \

Carr1509 { ; Updated for UF2 by Erik Reckase, Jan 2000
           ; Julia?
init:
  z=0.1/(pixel+pixel)/(flip(1/pixel*0.88/pixel))
  c=conj(pixel*pixel)-(0.5456,0.2)
loop:
  z=sqr(z)
  z=z+sin(z)+c
  c=z+c/2
  c=((1+flip(imag(sqrt(c))))*real(sqrt(c))/9+z)
bailout:
  |z| <=4
default:
  title = "Carr 1509"
  periodicity = 0
  maxiter = 500
  magn = 2.2
  center = (0,0)
  method = multipass
}

Carr1510 { ; Updated for UF2 by Erik Reckase, Jan 2000
           ; Julia?
init:
  z=0.1/(pixel+pixel)/(flip(1/pixel*0.88/pixel))
  c=conj(pixel*pixel)/flip(pixel)/conj(cos(pixel))
loop:
  z=z*z+c
  c=((1+flip(imag(sqrt(c))))*real(sqrt(c))/9+z)
bailout:
  |z| <=4
default:
  title = "Carr 1510"
  periodicity = 0
  maxiter = 500
  magn = .07
  center = (0,0)
  method = multipass
}

Carr1511 { ; Updated for UF2 by Erik Reckase, Jan 2000
           ; Julia?
init:
  z=0.1/(pixel+pixel)/(flip(1/pixel*0.88/pixel))
  c=exp(flip((pixel+pixel)-1.5)/(z-1.2/(4/flip(pixel))))
loop:
  z=z*z+c
  c=((1+flip(imag(sqrt(c))))*real(sqrt(c))/9+z)
bailout:
  |z| <=4
default:
  title = "Carr 1511"

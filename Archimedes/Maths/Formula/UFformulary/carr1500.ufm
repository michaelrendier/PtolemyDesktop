Carr1542 { ; Updated for UF2 by Erik Reckase, Jan 2000
           ; Spider type.
init:
  z=flip(pixel*pixel)
  c=pixel^(z-1)
loop:
  z=z*z+c
  c=z+c/2.125
bailout:

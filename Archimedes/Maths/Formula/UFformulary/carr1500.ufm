  maxiter = 500
  magn = .07
  center = (0,0)
  method = multipass
}

Carr1512 { ; Updated for UF2 by Erik Reckase, Jan 2000
           ; Julia?
init:
  z1=(pixel-0.5)^(sqrt(5)^1/pixel)
  z=z1/conj(cos(pixel))
  c=conj(1-pixel)
loop:
  z=z*z+c
  c=((1+flip(imag(sqrt(sin(c-0.1/pixel)))))*real(sqrt(tan(c)))/9+(z))
bailout:
  |z| <=4
default:
  title = "Carr 1512"
  periodicity = 0
  maxiter = 500
  magn = 2.8
  center = (.7,0)
  method = multipass
}

Carr1513 { ; Updated for UF2 by Erik Reckase, Jan 2000

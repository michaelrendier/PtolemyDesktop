Carr1505 { ; Updated for UF2 by Erik Reckase, Jan 2000
           ; Julia?
init:
  z=0.1/(pixel+pixel)/(flip(1/pixel))
  c=conj(pixel-1.5)/(z-1.2/(1/flip(pixel)))
loop:
  z=(z*z+c)/1.3
  c=((1+flip(imag(sqrt(sin(c)))))*real(sqrt(tan(c)))/9+z)
bailout:
  |z| <=4
default:
  title = "Carr 1505"
  periodicity = 0
  maxiter = 500
  magn = .5
  center = (-.3,.5)
  method = multipass
}


comment {
  Carr1500.ufm Version 1.0
  Ultra Fractal conversions of Robert Carr's formulas Carr1500 - Carr1599
  by Erik Reckase / Lale Erguner, December 12, 2002

  History:  Version 1.1 - Fixes for UF3 compatibility by
                          Lale Erguner

            Version 1.0 - Initial Release
                          Original formulas pulled from _rc1.frm

                          Carr1501-1503,1506,1510,
                              1512,1516,1531,1537,
                              1558-1563,1569,1585,
                              1586-1587,1594-1598  : cosxx fix
            
}

Carr1500 { ; Updated for UF2 by Erik Reckase, Jan 2000
           ; Julia?
init:
  z=0.1/(pixel+pixel)/(flip(1/pixel))
  c=conj(pixel-1.5)/(z-1.2/pixel)
loop:
  z=z*z+c
  c=((1+flip(imag(sqrt(sin(c)))))*real(sqrt(tan(c)))/9+z)
bailout:
  |z| <=4
default:
  title = "Carr 1500"
  periodicity = 0
  maxiter = 500
  magn = 1.3
  center = (.75,0)
  method = multipass
}

Carr1501 { ; Updated for UF2 by Erik Reckase, Jan 2000
           ; Julia?
init:
  z=0.1/(pixel+pixel)/(flip(1/pixel*0.88/pixel))
  c=((-0.7456,0.2)-1.9/pixel)/conj(cos(z*z-1.2/pixel))
loop:
  z=z*z+c
  c=((1+flip(imag(sqrt(sin(c)))))*real(sqrt(tan(c)))/9+z)
bailout:
  |z|<=4
default:
  title = "Carr 1501"
  periodicity = 0
  maxiter = 500
  magn = 4
  center = (0,0)
  method = multipass
}


JAW2002-11 {
;(c)2002 JulieAnne Wilt
    INIT:
       z=#pixel       
       a=@Ja
       b=@Jb
       c=@Jc
       x=z+1
    LOOP:
        z=((a*z^c+ 0.25*real(z)-b*1)+(2*x^2-6-c*x-1)*(cos(x)+2))
    BAILOUT:
         z<4
    DEFAULT:     
        title="JAW2002-11"
        angle=0 
    PARAM Ja
        Default=(1.0,0.0)
        caption="Coeff a"
        hint= "a in a*z^c+ 0.25*real(z)-b*z"
    endparam
    PARAM Jb
        Default=(1.0,0.0)
        caption="Coeff b"
        hint="b in a*z^c+ 0.25*real(z)-b*z"
    endparam
    PARAM Jc
        Default=(1.0,0.0)
        caption="Coeff c"
        hint="c in 2*x^2-6-c*x-1"    
    endparam       
        }


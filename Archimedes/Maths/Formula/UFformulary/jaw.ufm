JAW2002-18{
;(c)2002 JulieAnne Wilt  
init:
   z = pixel
  float x = real(pixel)
  float y = imag(pixel)
  float a=real(x)
  float b=imag(x)
  float f = 0.0
  float g = 0.0
  float x2 = 0.0
  float y2 = 0.0
  

loop:
  f = x - x * y^b
  g = -y + x * y*a
  x2 = x + @place * f
  y2 = y + @place * g 
  x = x + @home/2 * (f + ( x2 - x2*y2))
  y = y + @home/2 * (g + (-y2 + x2*y2))
  z = x + flip(y)* a + b

bailout:
  |z| < @bailout

  default:
  title = "JAW2002-18"
  maxiter = 160
  center = (1.05937242808394083,0.0319251025513407308)
   magn = 13
   method=multipass
    
     param home
    caption = "Parameter Home"
    default = 0.25
    min = 0
    max = 1
  endparam
  param place
    caption = "Parameter Place"
    default = 250
    min = 0
    max = 1
  endparam
  param p1
    caption="P1"
    default=(0,0)
  endparam
  param p2
    caption="P2"
    default=(0,0)
  endparam
  param bailout
    caption="bailout"
    default=4
  endparam  
         
      }

JAW2002-19 {
;(c)2002 JulieAnne Wilt  
init:
   z = pixel
    x = real(pixel)
    y = imag(pixel)
    a=real(x)
    b=imag(x)
   f = 0.0
    g = 0.0
  x2 = 0.0
    y2 = 0.0
  

loop:
  f = x -x * y^b
  g = -y + x * y*a
  x2 = x + @place * f
  y2 = y + @place * g 
  x = x + @home/2 * (f - ( x2 + x2*y2))
  y = y + @home/2 * (g + (-y2 + x2*y2))
  z = x + flip(y)* a + b

bailout:
  |z| < @bailout

  default:
  title = "JAW2002-19"
  maxiter = 500
    center = (1.05937242808394083,0.0319251025513407308)

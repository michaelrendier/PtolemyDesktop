FirstJW {;(c) 2002 JulieAnne Wilt
;this is my first try. very simple
   Init:
       z=#pixel
       c=p1
   Loop:
        z=z^cos(c)+ 4*tan(z)+1
   Bailout:
         z<4
         }     

Julie241 {;(c) 2002 JulieAnne Wilt
; changing loop last number 
;from 1 to a smaller number
   Init:
       z=#pixel
       c=p1
   Loop:
        z=z^cos(c)+ 4*tan(z)+0.25
   Bailout:
         z<4
         }

Julie341 {;(c) 2002 JulieAnne Wilt
    Init:
       z=#pixel
       c=p1
   Loop:
        z=(z^tanh(c)+ 0.6*tan(z)+0.25) + (c^5 -c+1)
   Bailout:
         z<4
         }

Julie441 {;(c) 2002 JulieAnne Wilt
    Init:
       z=#pixel
       c=p1
   Loop:
        z=(z^8+ 0.6*tan(z)+0.25) + (c^5 -c+1)
   Bailout:
         z<4
         }

Julie541 {;(c) 2002 JulieAnne Wilt
    Init:
       z=#pixel
       c=p1
   Loop:
        z=(z^8+ 0.6*real(z)+0.25) + (c^2 -1)
   Bailout:
         z<4
         }

Julie641 {;(c) 2002 JulieAnne Wilt
    Init:
       z=#pixel
       c=p1
    Loop:
        z=(z^2+ 0.25*real(z)+0.25) + (c^imag(c)-2)
    Bailout:
         z<4
         }

Julie741 {;(c) 2002 JulieAnne Wilt
    Init:
       z=#pixel
       c=p1
    Loop:
        z=(z^2+ 0.25*real(z)+0.25)+0.2687  
    Bailout:
         z<4
         }

Julie841 {;(c) 2002 JulieAnne Wilt
    Init:
       z=#pixel
       c=p1
    Loop:
        z=((z^c+ 0.25*real(z)+0.25)+ (tan(c)*3)+1)         
    Bailout:
         z<4
    Default:
         title="Julie841"
         angle =45
    Param p1
         caption="Param 1"
         default= (3.0,0)
    endparam
         }

Julie941 {;(c) 2002 JulieAnne Wilt
    INIT:
       z=#pixel
       c=p1
    LOOP:
        z=((z^c+ 0.25*real(z)+0.25)+ (sin(c)*3)+1)         
    BAILOUT:
         z<4
    DEFAULT:     
        title="Julie941"
        angle=0 
    PARAM p1
        caption="Param 1"
        Default =(0,5.0)
    endparam
        }
Julie1041 {;(c) 2002 JulieAnne Wilt
    INIT:
       z=#pixel
       c=p1
       D=P2
    LOOP:
        z=((z^c+ 0.25*real(z)-1)+ (tan(c)*3)+1)*(cos(D)+2)         
    BAILOUT:
         z<4
    DEFAULT:     
        title="Julie1041"
        angle=0 
    PARAM p1
        caption="Param 1"
        Default =(0,2.0)
    endparam
    
    PARAM p2
        caption="Param 2"
        Default= (5.0,4.0)
    endparam
        }

Julie1141A {;(c) 2002 JulieAnne Wilt
    INIT:
       z=c=#pixel
       b=p2
       c=p1       
       x=z+1
    LOOP:
        z=((z^c+ 0.25*real(z)-b*1)+(2*x^2-6*x-1)*(cos(x)+2))
    BAILOUT:
         z<4
    DEFAULT:     
        title="Julie1141A"
        angle=0 
    PARAM p1
        caption="Param 1"
        Default =(0,2.0)
    endparam
    
    PARAM p2
        caption="Param 2"
        Default= (5.0,4.0)
    endparam
        }
Julie1141b {;(c) 2002 JulieAnne Wilt
    INIT:
       z=#pixel
       b=p2
       c=p1       
       x=2    
    LOOP:
        z=((z^c+ 0.25*b+real(z)-1)+(2*x^2-6*x-1)*(cos(x)+2))+ @seed
    BAILOUT:
         z<=4
    DEFAULT:     
        title="Julie1141b"
        angle=0
        magn=1.95314 
    PARAM seed
        caption="Julia Seed"
        default=(-0.98,-0.35)
    endparam
    PARAM p1
        caption="Param 1"
        Default =(0.0,2.0)
    endparam
    
    PARAM p2
        caption="Param 2"
        Default= (5.0,0.0)
    endparam
    PARAM bailout
        caption="Bailout"
        default=1e20
        hint="High bailout means more\ 
              iterations done on each point"
    endparam
        }
Julie1341 {;(c) 2002 JulieAnne Wilt
    INIT:
       z=#pixel
       c=p1
       x=z+1    
    LOOP:
        z=2*x*(z^2+x^2)+(2 * x^3)-c*2  
    BAILOUT:
         z<4
    DEFAULT:     
        title="Julie1341"
        angle=0 
    PARAM p1
        caption="Param 1"
        Default =(2.0,0.0)
    endparam
    
    PARAM p2
        caption="Param 2"
        Default= (5.0,4.0)
    endparam
        }
 
Julie1441 {;(c) 2002 JulieAnne Wilt
    INIT:
       z=#pixel
       x=z+1    
    LOOP:
        z=2*z^z+ 0.25*real(z)-1/x+z^3
      
    BAILOUT:
         z<4
    DEFAULT:     
        title="Julie1441"
        angle=90 
             }
Julie1541 {;(c) 2002 JulieAnne Wilt
    INIT:
       z=#pixel
       c=p1
       x=z+1
        
         
    LOOP:
        z=(2*z^c+ 0.25*real(z)-1)+(z^c-x^2)     
    BAILOUT:
         z<4
    DEFAULT:     
        title="Julie1541"
        angle=0 
    PARAM p1
        caption="Param 1"
        Default =(0,2.0)
    endparam
    
                
    Param bailout
        caption="Bailout Value"
        Default=4.0
        Min=1
        Hint="Defines bailout."
    endparam
    
              
        }
 

Julie1541A  {;(c) 2002 JulieAnne Wilt
    INIT:
       z=#pixel
       c=p1
       x=z+1
    LOOP:
        z=(z*z+4-tan(c)/2*4)+(2*sin(x)-4)     
    BAILOUT:
         z<4
    DEFAULT:     
        title="Julie1541A"
        angle=0 
    PARAM p1
        caption="Param 1"
        Default =(1.0,0)
    endparam
    
    Param bailout
        caption="Bailout Value"
        Default=4.0
        Min=1
        Hint="Defines bailout."
    endparam
    }
Julie1241 {;(c)2002 JulieAnne Wilt
    INIT:
       z=pixel
       c=p1
       x=z+1    
    LOOP:
        z=2*x*(z^2+x^2)+2 * (x^3*(c^2+x^2)-3) 
    BAILOUT:
         z<4
    DEFAULT:     
        title="Julie1241"
        angle=0 
    PARAM p1
        caption="Param 1"
        Default =(0,2.0)
    endparam
    
    PARAM p2
        caption="Param 2"
        Default= (5.0,4.0)
    endparam
        }


Julie1241A {;(c) 2002 JulieAnne Wilt
    INIT:
       z=#pixel        
       x=z+1    
    LOOP:
        z=2*x*(z^2+x^2/1.7)+2 * (x^3*(z^2+x^2)-3) 
    BAILOUT:
         z<4
    DEFAULT:     
        title="Julie1241A"
        angle=90             }

Julie741a {;(c) 2002 JulieAnne Wilt
 ; JulieAnne Wilt
    Init:
       z=#pixel
       x=z+1
    Loop:
        z=(z^2+ 0.25*real(z)+0.25)+(x^2-0.2687)  

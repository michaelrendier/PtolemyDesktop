}


JAW2002-20{
;(c)2002 JulieAnne Wilt  
init:
   z = pixel
  float x = real(pixel)
  float y = imag(pixel)
  float a=real(x)
  float b=imag(x)
  float f = 0.0
  float g = 0.0
  float x3 = 0.0
  float y3 = 0.0
  

loop:
  f = x - x * y^b
  g = -y + x * y*a
  x3 = x + @p1 * f
  y3 = y + @p1 * g 
  x =  x *a + @p1/2 *(f *( x3 - x3*y3)) 
  y =  y * b + @p2/2 *(g + (-y3 + x3*y3))
  z = x + abs(y)* a + b

bailout:
  |z| < @bailout

  default:
  title = "JAW2002-20"
  maxiter = 160
  center = (0.99996675823907718,9.38291906169997212E-5 )
   magn = 524.641      
   param p1
    caption = "Parameter 1"
    default = 0.25
    min = 0
    max = 1
  endparam
  param p2      
  caption = "Parameter 2"
    default = 250.0
    min = 0
    max = 1
  endparam
     param bailout
    caption = "Bailout value"
    default = 100
     min = 1
  endparam
}

JAW2002-21  {
;(c)2002 JulieAnne Wilt
    INIT:
       z=pixel       
       b=p2
       c=p1
       x=z+1*real(c)
    LOOP:
        z=(z*z+4-tan(c)/2*4-x)+(2*sin(x)*-4/2+b)     
    BAILOUT:
         z<4
    DEFAULT:     
        title="JAW2002-21"
        angle=0 
    PARAM p1
        caption="Param 1"
        Default =(1.0,0)
    endparam
    PARAM p2
        caption="Param 2"
        Default=(0,2.0)
    endparam
    PARAM power        
        caption="Power"
        Default=2.0
    endparam
    
    Param bailout
        caption="Bailout Value"
        Default=4.0
        Min=1
        Hint="Defines bailout."
    endparam
    }



JAW2002-22{
;(c)2002 JulieAnne Wilt 
init:
   z = #pixel

loop:
  z = @param2 * @fn1(z)*@root^@fn2(z)+z* @param2 - @param1 * @fn3(z) *@root^@fn4(z)+@start

bailout:
     |z| < @bailout

default:
     title = "JAW2002-22"
     center = (3.109,0.3409)
     angle = 90
     magn = 0.45
param start
     default = (2.0,-1.0)
endparam

param root
     default = (2,0)
endparam

param bailout
     default = (100,0)
endparam

param param1
     default = (0.5,0)
endparam

param param2
     default = (1,0)
endparam 

func fn1
     default = sin()
endfunc

func fn2
     default = sin()
endfunc



func fn3
     default = abs()
endfunc

func fn4
     default = cos()
endfunc

}


JAW2002-23 {
;(c)2002 JulieAnne Wilt
Init:
     z = pixel:  
      z = (cosh(p1 * sqr(z)) - sinh(p2 * sqr(z))/(p2 * sqr(z))/z )
    
     |z|<= 4   
      
     Default:
      title="JAW2002-23"
      center=(.04166666,.04166666)
      magn=1
      method=multipass
      periodicity=0
      maxiter=100
 
Param p1
      
      caption="P1"
      default=(1,0)
endparam
}

Cherryh-conic-julia {
;lkm fractint formula
;rewritten by jaw and lkm
 init:
   cc=@seed
   zc=#pixel
   float x=0.0
   float y=0.0
loop:
   zc=sqr(zc)+cc
   x=real(zc)
   y=imag(zc)
   t=x*(@aconic+x+@bconic)+y*(@cconic*y+@dconic)
   t=t+@econic*x*y+@fconic
   z=cos(t)+flip(sin(t))
bailout:
   |zc|<@bailout
default:
   title="Cherryh's conic Julia"
   param seed
     caption="Julia seed"
     default=(-2,0)
   endparam
   param bailout
     caption="bailout"
     default=4.0
   endparam
   param aconic
     caption="conic section a"
     default=0.0
   endparam
   param bconic
     caption="conic section b"
     default=0.0
   endparam
   param cconic
     caption="conic section c"
     default=0.0
   endparam
   param dconic
     caption="conic section d"
     default=0.0
   endparam
   param econic
     caption="conic section e"
     default=0.0
   endparam
   param fconic
     caption="conic section f"
     default=0.0
   endparam
}

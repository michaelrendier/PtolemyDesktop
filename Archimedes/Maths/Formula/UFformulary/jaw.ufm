         }
Julie1641  {;(c) 2002 JulieAnne Wilt
    INIT:
       z=#pixel
       c=p1
       x=z+1*real(c)
    LOOP:
        z=(z*z+4-tan(c)/2*4-x)+(2*sin(x)-4)     
    BAILOUT:
         z<4
    DEFAULT:     
        title="Julie1641"
        angle=0 
    PARAM p1
        caption="Param 1"
        Default =(1.0,0)
    endparam
    
    Param bailout
        caption="Bailout Value"
        Default=4.0
        Min=1
        Hint="Defines bailout."
    endparam
    }
Julie1641a  {;(c) 2002 JulieAnne Wilt
    INIT:
       z=#pixel
       b=p2
       c=p1
       x=z+1*real(c)
    LOOP:
        z=(z*z+4-tan(c)/2*4-x)+(2*sin(x)-4/2+b)     
    BAILOUT:
         z<4
    DEFAULT:     
        title="Julie1641a"
        angle=0 
    PARAM p1
        caption="Param 1"
        Default =(1.0,0)
    endparam
    PARAM p2
        caption="Param 2"
        Default=(0,2.0)
    endparam
    
    Param bailout
        caption="Bailout Value"
        Default=4.0
        Min=1
        Hint="Defines bailout."
    endparam
    }

Julie1741  {;(c) 2002 JulieAnne Wilt
    INIT:
       z=#pixel       
       c=p1
       x=z+1*real(c)
    LOOP:
        z=(z*z+4-tan(c)/2*4-x)+(2*sin(x)*-4/2)     
    BAILOUT:
         z<4
    DEFAULT:     
        title="Julie1741"
        angle=0 
    PARAM p1
        caption="Param 1"
        Default =(1.0,0)
    endparam
         
    Param bailout
        caption="Bailout Value"
        Default=4.0
        Min=1
        Hint="Defines bailout."
    endparam
    }

JAWF1 {;JulieAnne Wilt 2002 (c)
;written feb 27,2002
   INIT:
      z=#pixel
      x=z+1
   LOOP:
      z=sqrt(z)
      z=(z^2+2*1.5+p1)-((z^3*p2)+@fn1(x)*(@fn2(z)-p3))
   BAILOUT:
      z<9
      
   DEFAULT:
     title = "JAWF1"
     param bailout
        caption="Bailout"
        default=9
        min=1
     endparam
     param p1
        caption="Parameter 1"
        default=(1.0,0.0)
     endparam
     param p2
        caption="Parameter 2"
        default=(1.0,0.0)
     endparam
         SWITCH:
     type="JAW F1"
     bailout=@bailout
     p1=@p1
     p2=@p2
     fn1=@fn1
     fn2=@fn2
     }

Simple11  {;(c) 2002 JulieAnne Wilt
     INIT:
           Z=C=Pixel
           
     LOOP:
            Z=Z^7+cotanh(Z)+cotanh(C)
 
      BAILOUT:
            Z<4

      DEFAULT:
             Title="Simple 11"

}

Simple8 {;(c) 2002 JulieAnne Wilt
     INIT:
           Z=C=Pixel
           
     LOOP:
            Z=Z^7+6/C*sin(Z)+C
 
      BAILOUT:
            Z<4

      DEFAULT:
             Title="Simple 8"

}

Julie1141 {;(c) 2002 JulieAnne Wilt
    INIT:
       z=#pixel
       b=p2
       c=p1       
       x=2    
    LOOP:
        z=((z^c+ 0.25*b+real(z)-1)+(2*x^2-6*x-1)*(cos(x)+2))
    BAILOUT:

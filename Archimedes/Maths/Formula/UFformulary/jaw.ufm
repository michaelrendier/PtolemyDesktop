JAW2002-13 {
;(c)2002 JulieAnne Wilt
Init:
     z =#pixel:  
     z = (cotan(p1 * sqr(z)) - sinh(p2 * sqr(z))/(p3 * sqr(z))/z )
    
     |z|<= 4   
      
     Default:
      title="JAW2002-13"
      center=(.04166666,.04166666)
      magn=1
      method=multipass
      periodicity=0
      maxiter=100
 
Param p1
      
      caption="P1"
      default=(1,0)
endparam
 
Param p2
      caption="P2"
      default=(0,0)
endparam

Param p3
      caption="P3"
      default=(0,0)
endparam
}


JAW2002-14 {
;(c)2002 JulieAnne Wilt
    INIT:
       z=pixel
       c=p1
       x=z+1    
    LOOP:
        z=2*x*(z^2+x^2)+(7.50234*c^2 * x^3)  
    BAILOUT:
         z<4
    DEFAULT:     
        title="JAW2002-14"
        angle=0 
    PARAM p1
        caption="Param 1"
        Default =(0,2.0)
    endparam
    
    PARAM p2
        caption="Param 2"
        Default= (5.0,4.0)
    endparam
        }

JAW2002-15 {
;(c)2002 JulieAnne Wilt
    INIT:
       z=#pixel
       c=p1
       x=z+1    
    LOOP:
        z=(2*z^c+ 0.25*real(z))-(1*x^3/z)
      
    BAILOUT:
         z<4
    DEFAULT:     
        title="JAW2002-15"
        angle=0 
    PARAM p1
        caption="Param 1"
        Default =(0.0,2.0)
    endparam
    
    PARAM p2
        caption="Param 2"
        Default= (1.0,0.0)
    endparam
    
        }

JAW2002-16 {

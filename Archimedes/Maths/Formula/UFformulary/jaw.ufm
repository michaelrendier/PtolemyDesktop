JAW2002-4{
;(c)2002 JulieAnne Wilt
    INIT:
       z=#pixel
       c=p1
       d=p2
       x=c^5*real(z)/d
    LOOP:
      z=fn1(z^c+d*real(z)-1/x)+(tan(c)*3*fn1(real(z)+1)/(sin(d)*+2))  
          BAILOUT:
          real(z)<real(z)+c*x
    DEFAULT:     
        title="JAW2002-4"
        method=multipass
        angle=45
        maxiter=1000
        center=(0.1679,-0.7513)
        periodicity=0
        magn=2
    PARAM p1
        caption="Param 1"
        Default =(1.0,2.0)
    endparam
    
    PARAM p2
        caption="Param 2"
        Default= (5.0,4.0)
    endparam
    
    func fn1
    caption = "Function 1"
    default = ident()
    endfunc     
    }


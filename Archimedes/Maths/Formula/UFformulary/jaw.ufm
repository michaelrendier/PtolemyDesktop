    endparam
        }

JAW2002-1 {
;(c)2002 JulieAnne Wilt  
    INIT:
       z=#pixel
       c=p1
       D=P2
    LOOP:
        z=fn1((z^c+D*real(z)^c-1)+(cos(c)*3*fn1(real(z)+1))/(sin(D)+2))   
    BAILOUT:
          real(z)<real(z)+c
    DEFAULT:     
        title="JAW2002-1"
        method=multipass
        angle=45
        maxiter=1000
        center=(0,0)
        periodicity=0
        
    PARAM p1
        caption="Param 1"
        Default =(2.0,2.0)
    endparam
    
    PARAM p2
        caption="Param 2"
        Default= (5.0,4.0)
    endparam
    
    func fn1
    caption = "Function 1"
    default = ident()
    endfunc
    }


JAW2002-7{
;(c)2002 JulieAnne Wilt
    INIT:
       z=#pixel
       c=p1
       d=p2
       x=c^5*real(z)/d
    LOOP:
      z=fn1((z^c*z^4/d*real(z)-1/x)+(log(c)*3*fn1(real(z)+1))/(sin(d)/fn2(real(z)+2)))
    BAILOUT:
          real(z)<real(z)+c*x
    DEFAULT:     
        title="JAW2002-7"
        method=multipass
        angle=270
        maxiter=100         
        center=(0.5637625 ,0.78903481 )
        periodicity=0
        magn= 0.723345    
      PARAM p1
        caption="Param 1"
        Default =(1.0,2.0)
    endparam
    
    PARAM p2
        caption="Param 2"
        Default= (1.0,2.0)
    endparam
    
    func fn1
    caption = "Function 1"
    default = ident()
    endfunc
    
    func fn2
    caption ="Function 2"
    default =flip()
    endfunc
    }

JAW2002-8{
;(c)2002 JulieAnne Wilt
    INIT:
       z=#pixel
       c=p1*z
       d=p2*(log(z)/4)
       x=(c^5*real(z)/d)
    LOOP:
        z=fn1((z^c*z^4/d*real(z)-1/x)+(log(c)*3*c+fn1(real(z)+1))/(sin(d)/fn2(real(z)+2)))
    BAILOUT:
          real(z)<real(z)+c*x
    DEFAULT:     
        title="JAW2002-8"
        method=multipass
        angle=60     
        maxiter=100 
        center=(0.08882,-0.67759)
        periodicity=0
        magn=35
    PARAM p1
        caption="Param 1"
        Default =(1.0,2.0)
    endparam
    
    PARAM p2
        caption="Param 2"
        Default= (2.0,4.0)
    endparam
    
    func fn1
    caption = "Function 1"
    default = flip()
    endfunc
    
    func fn2
    caption ="Function 2"
    default =flip()
    endfunc
    }


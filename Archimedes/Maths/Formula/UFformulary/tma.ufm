ENDIF
ELSEIF (@op2 == 2); subtract
IF (@op1 == 0); divide
z = fn1(aa) / qq - vv * ww
ELSEIF (@op1 == 1); multiply
z = fn1(aa) * qq - vv * ww
ELSEIF (@op1 == 2); subtract
z = fn1(aa) - qq - vv * ww
ELSEIF (@op1 == 3); add
z = fn1(aa) + qq - vv * ww
ELSEIF (@op1 == 4); exponent
z = fn1(aa) ^ qq - vv * ww
ENDIF
ELSEIF (@op2 == 3); add
IF (@op1 == 0); divide
z = fn1(aa) / qq + vv * ww
ELSEIF (@op1 == 1); multiply
z = fn1(aa) * qq + vv * ww
ELSEIF (@op1 == 2); subtract

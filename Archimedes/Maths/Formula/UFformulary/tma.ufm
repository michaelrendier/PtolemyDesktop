DragonAtom01zJulia {
;Toby Marshall, Dec. 2001 

;Special thanks to Ken Childress,  
;Jos Leys, Erik Nathan Reckase, 
;Mark Townsend and Frederik Slijkerman  
;for their suggestions and advice.

;Please see tma.txt for help and hints.

;Have fun!

init:
  z = #pixel
loop:
aa = @seed/(z-@kludge)/fn2(@seed^@exp1-@power)
ww = @fn5(real(@seed^@exp2+@power))
xx = @fn6(imag(@seed^@exp3-@power))
yy = fn3(z-@budge)^@fn7(z)
qq = fn4(@seed^@exp4)-@nudge
IF (@group2 == 0); inner
IF (@group == 0); inner
IF (@op3 == 0)
IF (@op == 0)
IF (@op2 == 0)
 z = fn1(aa)/yy/ww^xx/qq
 ELSEIF (@op2 == 1)
 z = fn1(aa)/yy*ww^xx/qq
 ELSEIF (@op2 == 2)
 z = fn1(aa)/yy-ww^xx/qq
 ELSEIF (@op2 == 3)
 z = fn1(aa)/yy+ww^xx/qq
 ELSEIF (@op2 == 4)
  z = fn1(aa)/yy^ww^xx/qq
 ENDIF
 ELSEIF (@op == 1)
 IF (@op2 == 0)
 z = fn1(aa)*yy/ww^xx/qq
 ELSEIF (@op2 == 1)
 z = fn1(aa)*yy*ww^xx/qq
  ELSEIF (@op2 == 2)
 z = fn1(aa)*yy-ww^xx/qq
 ELSEIF (@op2 == 3)
 z = fn1(aa)*yy+ww^xx/qq
 ELSEIF (@op2 == 4)
 z = fn1(aa)*yy^ww^xx/qq
 ENDIF
 ELSEIF (@op == 2)
 IF (@op2 == 0)
 z = fn1(aa)-yy/ww^xx/qq
 ELSEIF (@op2 == 1)
 z = fn1(aa)-yy*ww^xx/qq
 ELSEIF (@op2 == 2)
  z = fn1(aa)-yy-ww^xx/qq
  ELSEIF (@op2 == 3)
  z = fn1(aa)-yy+ww^xx/qq
 ELSEIF (@op2 == 4)
 z = fn1(aa)-yy^ww^xx/qq

  fn1 = @fn1
  fn2 = @fn2
  fn3 = @fn3
  fn4 = @fn4
  fn5 = @fn5
  fn6 = @fn6
  fn7 = @fn7
  budge = @budge
  nudge = @nudge
  op = @op
  op2 = @op2
  op3 = @op3
  group = @group 
  group2 = @group2
  exp1 = @exp1
  exp2 = @exp2
  exp3 = @exp3
  exp4 = @exp4 

default:
  title = "Grand Atom 02z Julia"
  param seed
  default = (.95,-1)
  endparam
  param bailout
  default = (2.0,0)
  endparam
  param power 
  default = (0,0)
  endparam
  param op 
  caption = "operator 1"
  default = 1
  enum = "/""*""-""+""^"
  endparam
  param op2 
  caption = "operator 2"
  default = 0
  enum = "/""*""-""+""^"
  endparam
  param op3
  caption = "operator 3"
  default = 1
   enum = "/""*""-""+""^"
  endparam
  param group
  caption = "grouping 1"
  default = 0
  enum = "inner""outer"
  endparam
  param group2
  caption = "grouping 2"
  default = 0
  enum = "inner""outer"
  endparam
  param exp1
  caption = "exponent 1"
  default = (1.0,0)
  endparam
  param exp2
  caption = "exponent 2"
  default = (1.0,0)
  endparam
  param exp3
  caption = "exponent 3"
  default = (1.0,0)
  endparam
  param exp4
  caption = "exponent 4"
  default = (1.0,0)
  endparam


  func fn1
  caption = "Function 1"
  default = atan()
  endfunc
  func fn2
  caption = "Function 2"
  default = abs()
  endfunc
  func fn3
  caption = "Function 3"
  default = tan()
  endfunc
  func fn4
  caption = "Function 4"
  default = ident()
  endfunc
  func fn5
  caption = "Function 5"
  default = ident()
  endfunc
  func fn6
  caption = "Function 6"
  default = ident()
  endfunc
  func fn7  
  caption = "Function 7"
  default = ident()
  endfunc

  periodicity = 0
}

******************************************************************************************
DragonAtom01z {
;Toby Marshall, Dec. 2001

;Similar structure to its non-z counterpart
;but with quite different behavior.

;Choose your parameter and function values 
;then explore the resulting figure with 
;the Julia switch.

;Special thanks to Ken Childress,  
;Jos Leys, Erik Nathan Reckase, 
;Mark Townsend and Frederik Slijkerman  
;for their suggestions and advice.

;Please see tma.txt for help and hints.

;Have fun!

init:
  z = @start
loop:
aa = #pixel/(z-@kludge)/fn2(#pixel^@exp1-@power)
ww = @fn5(real(#pixel^@exp2+@power))
xx = @fn6(imag(#pixel^@exp3-@power))
yy = fn3(z-@budge)^@fn7(z)
qq = fn4(#pixel^@exp4)-@nudge
IF (@group2 == 0); inner
IF (@group == 0); inner
IF (@op3 == 0)
  IF (@op == 0)
IF (@op2 == 0)
 z = fn1(aa)/yy/ww^xx/qq
 ELSEIF (@op2 == 1)
 z = fn1(aa)/yy*ww^xx/qq
 ELSEIF (@op2 == 2)
 z = fn1(aa)/yy-ww^xx/qq
 ELSEIF (@op2 == 3)
 z = fn1(aa)/yy+ww^xx/qq
 ELSEIF (@op2 == 4)

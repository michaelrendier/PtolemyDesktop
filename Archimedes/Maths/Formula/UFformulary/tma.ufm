bailout:
  |z| < real(@bailout)
switch:
  type = "GrandAtom01"
  bailout = bailout
  power = @power
  fn1 = @fn1
  fn2 = @fn2
  fn3 = @fn3
  fn4 = @fn4
  fn5 = @fn5
  fn6 = @fn6
  budge = @budge
  nudge = @nudge
  op = @op
  op2 = @op2
  op3 = @op3
  group = @group
  exp1 = @exp1
  exp2 = @exp2  
  exp3 = @exp3
  exp4 = @exp4  

default:
  title = "Grand Atom 01 Julia"
  param seed
  default = (-1,-.1875)
  endparam
  param bailout
  default = (2.0,0)
  endparam
  param power 
  default = (0,0)
  endparam
  param op 
  caption = "operator 1"
  default = 1
  enum = "/""*""-""+""^"
  endparam
  param op2 
  caption = "operator 2"
  default = 0
  enum = "/""*""-""+""^"
  endparam
  param op3
  caption = "operator 3"
  default = 1
   enum = "/""*""-""+""^"
  endparam
  param group
  caption = "grouping"
  default = 0
  enum = "inner""outer"
  endparam
    param exp1
  caption = "exponent 1"
  default = (1.0,0)
  endparam
  param exp2
  caption = "exponent 2"
  default = (1.0,0)
  endparam
  param exp3
  caption = "exponent 3"
  default = (1.0,0)
  endparam
  param exp4
  caption = "exponent 4"
  default = (1.0,0)
  endparam

  func fn1
  caption = "Function 1"
  default = atan()
  endfunc
  func fn2
  caption = "Function 2"
  default = abs()
  endfunc
  func fn3
  caption = "Function 3"
  default = tan()
  endfunc
  func fn4
  caption = "Function 4"
  default = ident()
  endfunc
  func fn5
  caption = "Function 5"
  default = ident()
  endfunc
  func fn6
  caption = "Function 6"
  default = ident()
  endfunc
  periodicity = 0
}

  endparam

  func fn1
  caption = "Function 1"
  default = atan()
  endfunc
  func fn2
  caption = "Function 2"
  default = abs()
  endfunc
  func fn3
  caption = "Function 3"
  default = tan()
  endfunc
  func fn4
  caption = "Function 4"
  default = ident()
  endfunc
  func fn5

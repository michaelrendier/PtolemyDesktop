mandalaEta {
;Toby Marshall, Jan 2002
;This differs from "mandala gamma" by one arithmetical
;operator.  
;Use the switch to explore the perimeter of the M set.
;The three functions can be set while using the switch.
;Parameters can be incremented in either formula. The
;real component of "exponent1" determines the number of
;arms in the julia figure.
init:
  z = 2
loop:
  z = fn1(fn2(z^@power1^(fn4(#pixel^@power3)-@kludge))-@budge)^fn3(@pow/((#pixel^@power2)-@nudge))
bailout:
  |z| < @bailout

switch:
  type = "mandalaetajulia"
  seed = #pixel
  bailout = bailout
  fn1 = @fn1
  fn2 = @fn2
  fn3 = @fn3

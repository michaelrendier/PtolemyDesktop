
MightyAtom {
;Toby Marshall, Nov. 2001

;This formula has been updated to carry over
;values in the Julia switch. Mighty Atom Mk II
;is the same formula with added parameters.

;Choose your parameter and function values 
;then explore the resulting figure with 
;the Julia switch.

;Special thanks to Ken Childress,  
;Jos Leys, Erik Nathan Reckase, 
;Mark Townsend and Frederik Slijkerman  
;for their suggestions and advice.

;Please see tma.txt for help and hints.

;Have fun!

init:
  z = @start
loop:
  z = fn1(fn2(#pixel)*fn3(z*@power))/fn4(real(#pixel))^imag(#pixel)
bailout:
  |z|<real(@bailout)
switch:
  type = "MightyAtomJulia"
  seed = #pixel
  bailout = bailout
  fn1 = @fn1
  fn2 = @fn2
  fn3 = @fn3
  fn4 = @fn4
  power = @power
  
    
default:
  title = "Mighty Atom"
  param start
  default = (2.0,0)
  endparam
  param bailout
  default = (2.0,0)
  endparam
  param power 
  default = (1.0,0)
  endparam
  
  func fn1
  caption = "Function 1"
  default = atan()
  endfunc
  func fn2
  caption = "Function 2"
  default = abs()
  endfunc
  func fn3
  caption = "Function 3"
  default = tan()
  endfunc
  func fn4
  caption = "Function 4"
  default = ident()
  endfunc
  periodicity = 0
  method = multipass
}


MightyAtomJulia {
;Toby Marshall, Nov./Dec. 2001 

;Special thanks to Ken Childress,  
;Jos Leys, Erik Nathan Reckase, 
;Mark Townsend and Frederik Slijkerman  
;for their suggestions and advice.

;Please see tma.txt for help and hints.

;Have fun!


init:
  z = #pixel
loop:
  z = fn1(fn2(@seed)*fn3(z*@power))/fn4(real(@seed))^imag(@seed)
bailout:
  |z| < real(@bailout)
switch:
  type = "MightyAtom"
  bailout = bailout
  fn1 = @fn1
  fn2 = @fn2
  fn3 = @fn3
  fn4 = @fn4
  power = @power

default:
  title = "Mighty Atom Julia"
  param seed
  default = (.85,-.7875)
  endparam
  param bailout
  default = (2.0,0)
  endparam
  param power 
  default = (1.0,0)
  endparam

  
  func fn1
  caption = "Function 1"
  default = atan()
  endfunc
  func fn2
  caption = "Function 2"
  default = abs()
  endfunc
  func fn3
  caption = "Function 3"
  default = tan()
  endfunc
  func fn4
  caption = "Function 4"
  default = ident()
  endfunc
  
  periodicity = 0
  method = multipass
  }


*********************************************************************************************************

MightyAtomMkII{
;Toby Marshall, Dec. 2001, rev.1
;A new version of "Mighty Atom" with
;improved functionality in the power
;parameter, five added parameters, 
;and an extra enumeration in the 
;"grouping" parameter.

;Choose your parameter and function values 
;then explore the resulting figure with 
;the Julia switch.

;Special thanks to Ken Childress,  
;Jos Leys, Erik Nathan Reckase, 
;Mark Townsend and Frederik Slijkerman  
;for their suggestions and advice.

;Please see tma.txt for help and hints.

;Have fun!

init:
  z = @start
loop:
aa = #pixel^@exp1-@power
qq = fn3(z-@budge)
ww = fn4(real(#pixel^@exp2*@power))
yy = @fn5(imag(#pixel^@exp3/@power))-@nudge
IF (@op3 == 0)
IF (@group == 0); inner
IF (@op2 == 0)
IF (@op1 == 0)
  z = fn1(fn2(aa)/qq)/ww/yy
  ELSEIF (@op1 == 1)
  z = fn1(fn2(aa)*qq)/ww/yy
  ELSEIF (@op1 == 2)
  z = fn1(fn2(aa)-qq)/ww/yy
  ELSEIF (@op1 == 3)
  z = fn1(fn2(aa)+qq)/ww/yy
  ELSEIF (@op1 == 4)
  z = fn1(fn2(aa)/qq)/ww/yy
  ENDIF
  ELSEIF (@op2 == 1)
IF (@op1 == 1)
  z = fn1(fn2(aa)/qq)*ww/yy
  ELSEIF (@op1 == 1)
  z = fn1(fn2(aa)*qq)*ww/yy
  ELSEIF (@op1 == 2)
  z = fn1(fn2(aa)-qq)*ww/yy
  ELSEIF (@op1 == 3)
  z = fn1(fn2(aa)+qq)*ww/yy
  ELSEIF (@op1 == 4)
  z = fn1(fn2(aa)/qq)*ww/yy

  ELSEIF (@op1 == 1)
  z = fn1(fn2(aa)*qq)-xx/ww
  ELSEIF (@op1 == 2)
  z = fn1(fn2(aa)-qq)-xx/ww
  ELSEIF (@op1 == 3)
  z = fn1(fn2(aa)+qq)-xx/ww
  ELSEIF (@op1 == 4)
  z = fn1(fn2(aa)/qq)-xx/ww
  ENDIF
ELSEIF (@op2 ==3)
IF (@op1 == 0)
  z = fn1(fn2(aa)/qq)+xx/ww
  ELSEIF (@op1 == 1)
  z = fn1(fn2(aa)*qq)+xx/ww
  ELSEIF (@op1 == 2)
  z = fn1(fn2(aa)-qq)+xx/ww
  ELSEIF (@op1 == 3)
  z = fn1(fn2(aa)+qq)+xx/ww
  ELSEIF (@op1 == 4)
  z = fn1(fn2(aa)/qq)+xx/ww
  ENDIF
ELSEIF (@op2 ==4)
IF (@op1 == 0)
  z = fn1(fn2(aa)/qq)^xx/ww
  ELSEIF (@op1 == 1)
  z = fn1(fn2(aa)*qq)^xx/ww
  ELSEIF (@op1 == 2)
  z = fn1(fn2(aa)-qq)^xx/ww
  ELSEIF (@op1 == 3)
  z = fn1(fn2(aa)+qq)^xx/ww
  ELSEIF (@op1 == 4)
  z = fn1(fn2(aa)/qq)^xx/ww

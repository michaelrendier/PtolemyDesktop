  exp1 = @exp1
  exp2 = @exp2
  exp3 = @exp3
  exp4 = @exp4  

default:
  title = "Grand Atom 01z Julia"
  center = (-0.695, -0.174)
  magn = .538
  param seed
  default = (-1.45,-.37)
  endparam
  param bailout
  default = (2.0,0)
  endparam
  param power 
  default = (0,0)
  endparam
  param op 
  caption = "operator 1"
  default = 1
  enum = "/""*""-""+""^"
  endparam
  param op2 

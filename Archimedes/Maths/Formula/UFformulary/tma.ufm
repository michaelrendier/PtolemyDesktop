StrangeBrew {
  ; Toby Marshall, Jan. 2002
  ; Use with the Julia switch. All functions
  ; and parameters can be varied to explore
  ; different Julia sets. Some parameter
  ; combinations give black M sets, but they
  ; too sometimes yield interesting results 
  ; with the switch.
  ;
  ; Thanks to Jos Leys and Rui Parracho
  ; for their explanations and patience.

  
init:
  
  z = @start
  complex frog = @frog*(0.0,1.0)
  
loop:
aa = fn2(real(fn3(z^@exp1) + @eye))
qq = fn4(imag (@fn5(z^@exp2) + frog))
vv = @fn6(#pixel^@exp4 +@hen)
ww = @fn7(z^@exp3 + @bat)
IF (@group == 0); inner
IF (@op3 == 0); divide
IF (@op2 == 0); divide
IF (@op1 == 0); divide
z = fn1(aa) / qq / vv / ww
ELSEIF (@op1 == 1); multiply
z = fn1(aa) * qq / vv / ww
ELSEIF (@op1 == 2); subtract
z = fn1(aa) - qq / vv / ww
ELSEIF (@op1 == 3); add
z = fn1(aa) + qq / vv / ww
ELSEIF (@op1 == 4); exponent
z = fn1(aa) ^ qq / vv / ww
ENDIF
ELSEIF (@op2 == 1); multiply
IF (@op1 == 0); divide
z = fn1(aa) / qq * vv / ww
ELSEIF (@op1 == 1); multiply
z = fn1(aa) * qq * vv / ww
ELSEIF (@op1 == 2); subtract
z = fn1(aa) - qq * vv / ww
ELSEIF (@op1 == 3); add
z = fn1(aa) + qq * vv / ww
ELSEIF (@op1 == 4); exponent
z = fn1(aa) ^ qq * vv / ww
ENDIF
ELSEIF (@op2 == 2); subtract
IF (@op1 == 0); divide
z = fn1(aa) / qq - vv / ww
ELSEIF (@op1 == 1); multiply
z = fn1(aa) * qq - vv / ww
ELSEIF (@op1 == 2); subtract
z = fn1(aa) - qq - vv / ww
ELSEIF (@op1 == 3); add
z = fn1(aa) + qq - vv / ww
ELSEIF (@op1 == 4); exponent
z = fn1(aa) ^ qq - vv / ww
ENDIF
ELSEIF (@op2 == 3); add
IF (@op1 == 0); divide
z = fn1(aa) / qq + vv / ww
ELSEIF (@op1 == 1); multiply
z = fn1(aa) * qq + vv / ww
ELSEIF (@op1 == 2); subtract
z = fn1(aa) - qq + vv / ww
ELSEIF (@op1 == 3); add
z = fn1(aa) + qq + vv / ww
ELSEIF (@op1 == 4); exponent
z = fn1(aa) ^ qq + vv / ww
ENDIF
ELSEIF (@op2 == 4); exponent
IF (@op1 == 0); divide
z = fn1(aa) / qq ^ vv / ww
ELSEIF (@op1 == 1); multiply
z = fn1(aa) * qq ^ vv / ww
ELSEIF (@op1 == 2); subtract
z = fn1(aa) - qq ^ vv / ww
ELSEIF (@op1 == 3); add
z = fn1(aa) + qq ^ vv / ww
ELSEIF (@op1 == 4); exponent
z = fn1(aa) ^ qq ^ vv / ww
ENDIF
ENDIF
ELSEIF (@op3 == 1); multiply
IF (@op2 == 0); divide
IF (@op1 == 0); divide
z = fn1(aa) / qq / vv * ww
ELSEIF (@op1 == 1); multiply
z = fn1(aa) * qq / vv * ww
ELSEIF (@op1 == 2); subtract
z = fn1(aa) - qq / vv * ww
ELSEIF (@op1 == 3); add
z = fn1(aa) + qq / vv * ww
ELSEIF (@op1 == 4); exponent
z = fn1(aa) ^ qq / vv * ww
ENDIF
ELSEIF (@op2 == 1); multiply
IF (@op1 == 0); divide
z = fn1(aa) / qq * vv * ww
ELSEIF (@op1 == 1); multiply
z = fn1(aa) * qq * vv * ww
ELSEIF (@op1 == 2); subtract
z = fn1(aa) - qq * vv * ww
ELSEIF (@op1 == 3); add
z = fn1(aa) + qq * vv * ww
ELSEIF (@op1 == 4); exponent
z = fn1(aa) ^ qq * vv * ww
ENDIF
ELSEIF (@op2 == 2); subtract
IF (@op1 == 0); divide
z = fn1(aa) / qq - vv * ww
ELSEIF (@op1 == 1); multiply
z = fn1(aa) * qq - vv * ww
ELSEIF (@op1 == 2); subtract
z = fn1(aa) - qq - vv * ww
ELSEIF (@op1 == 3); add
z = fn1(aa) + qq - vv * ww
ELSEIF (@op1 == 4); exponent
z = fn1(aa) ^ qq - vv * ww
ENDIF
ELSEIF (@op2 == 3); add
IF (@op1 == 0); divide
z = fn1(aa) / qq + vv * ww
ELSEIF (@op1 == 1); multiply
z = fn1(aa) * qq + vv * ww
ELSEIF (@op1 == 2); subtract
z = fn1(aa) - qq + vv * ww
ELSEIF (@op1 == 3); add
z = fn1(aa) + qq + vv * ww
ELSEIF (@op1 == 4); exponent
z = fn1(aa) ^ qq + vv * ww
ENDIF
ELSEIF (@op2 == 4); exponent
IF (@op1 == 0); divide
z = fn1(aa) / qq ^ vv * ww

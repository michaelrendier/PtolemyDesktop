  fn3 = @fn3
  fn4 = @fn4
  fn5 = @fn5
  fn6 = @fn6
  budge = @budge
  nudge = @nudge
  op = @op
  op2 = @op2
  op3 = @op3
  group = @group 
  group2 = @group2
  exp1 = @exp1
  exp2 = @exp2
  exp3 = @exp3
  exp4 = @exp4 

default:
  title = "Grand Atom 02 Julia"
  param seed
  default = (-1.05,-.4625)
  endparam
  param bailout
  default = (2.0,0)
  endparam
  param power 
  default = (0,0)
  endparam
  param op 
  caption = "operator 1"
  default = 1
  enum = "/""*""-""+""^"
  endparam
  param op2 
  caption = "operator 2"
  default = 0
  enum = "/""*""-""+""^"
  endparam
  param op3
  caption = "operator 3"
  default = 1
   enum = "/""*""-""+""^"
  endparam

  group2 = @group2
  exp1 = @exp1
  exp2 = @exp2
  exp3 = @exp3
  exp4 = @exp4 

default:
  title = "Dragon Atom 01 Julia"
  magn = 1.79
  param seed
  default = (-2.345,1.26)
  endparam
  param bailout
  default = (2.0,0)
  endparam
  param power 
  default = (0,0)
  endparam
  param op 

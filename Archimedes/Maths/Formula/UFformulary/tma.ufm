*********************************************************************************************************
DragonAtom02z {
;Toby Marshall, Dec. 2001

;Similar structure to its non-z counterpart
;but with quite different behavior.

;Choose your parameter and function values 
;then explore the resulting figure with 
;the Julia switch.

;Special thanks to Ken Childress,  
;Jos Leys, Erik Nathan Reckase, 
;Mark Townsend and Frederik Slijkerman  
;for their suggestions and advice.

;Please see tma.txt for help and hints.

;Have fun!

init:
  z = @start
loop:
aa = #pixel/fn4(z-@kludge)
bb = #pixel*fn4(z-@kludge)
cc = #pixel-fn4(z-@kludge)
dd = #pixel+fn4(z-@kludge)
ff = #pixel^fn4(z-@kludge)
qq = fn2(#pixel^@exp1-@power)*fn3(z-@budge)^@fn7(z)
ww = @fn5(real(#pixel^@exp2*@power))
xx = @fn6(imag(#pixel^@exp3/@power))-@nudge
IF (@op4 == 0)
IF (@op3 == 0)
IF (@op2 == 0)
IF (@op1 == 0)
   z = fn1(aa)/qq/ww/xx
   ELSEIF (@op1 == 1)
   z = fn1(bb)/qq/ww/xx
   ELSEIF (@op1 == 2)
   z = fn1(cc)/qq/ww/xx
   ELSEIF (@op1 == 3)
   z = fn1(dd)/qq/ww/xx
   ELSEIF (@op1 == 4)
   z = fn1(ff)/qq/ww/xx
   ENDIF
   ELSEIF (@op2 == 1)
   IF (@op1 == 0)
   z = fn1(aa)*qq/ww/xx
   ELSEIF (@op1 == 1)
   z = fn1(bb)*qq/ww/xx
   ELSEIF (@op1 == 2)
   z = fn1(cc)*qq/ww/xx
   ELSEIF (@op1 == 3)
   z = fn1(dd)*qq/ww/xx
   ELSEIF (@op1 == 4)
   z = fn1(ff)*qq/ww/xx
   ENDIF
   ELSEIF (@op2 == 2)
   IF (@op1 == 0)
   z = fn1(aa)-qq/ww/xx
   ELSEIF (@op1 == 1)
   z = fn1(bb)-qq/ww/xx
   ELSEIF (@op1 == 2)
   z = fn1(cc)-qq/ww/xx
   ELSEIF (@op1 == 3)
   z = fn1(dd)-qq/ww/xx
   ELSEIF (@op1 == 4)
   z = fn1(ff)-qq/ww/xx
   ENDIF
   ELSEIF (@op2 == 3)
   IF (@op1 == 0)
   z = fn1(aa)+qq/ww/xx
   ELSEIF (@op1 == 1)
   z = fn1(bb)+qq/ww/xx
   ELSEIF (@op1 == 2)
   z = fn1(cc)+qq/ww/xx
   ELSEIF (@op1 == 3)
   z = fn1(dd)+qq/ww/xx
   ELSEIF (@op1 == 4)
   z = fn1(ff)+qq/ww/xx
   ENDIF
   ELSEIF (@op2 == 4)

  caption = "bailout"
  default = 7.0
  endparam
  param power1
  caption = "exponent1"
  hint = "The real component determines the number \
   of arms in the figure. The imaginary component \
   changes the scale of the elements moving around the figure."
  default = (3.0,0.0)
  endparam
  param power2
  caption = "exponent2"
  default = (1.0,0.0)
  endparam
  param power3
  caption = "exponent3"
  default = (1.0,0.0)
  endparam
  param budge
  caption = "budge"
  default = (0.0,0.0)
  endparam
  param kludge
  caption = "kludge"
  default = (0.0,0.0)
  endparam
  param nudge
  caption = "nudge"
  default = (0.0,0.0)
  endparam
  param pow
  caption = "power"
  default = (1.0,0.0)
  endparam

  func fn1
  caption = "function 1"
  default = flip ()
  endfunc
  func fn2
  caption = "function 2"
  default = conj ()
  endfunc
  func fn3
  caption = "function 3"
  default = log ()
  endfunc
   func fn4
  caption = "function 4"
  default = ident ()
  endfunc
}


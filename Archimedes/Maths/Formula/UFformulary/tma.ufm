bailout:
  |z| < @bailout
  switch:
  type = "StrangeBrewJulia"
  seed = #pixel
  bailout = @bailout
  fn1 = @fn1
  fn2 = @fn2
  fn3 = @fn3
  fn4 = @fn4
  fn5 = @fn5
  fn6 = @fn6
  fn7 = @fn7
  eye = @eye
  frog = @frog
  hen = @hen
  op1 = @op1
  op2 = @op2
  op3 = @op3
  exp1 = @exp1
  exp2 = @exp2
  exp3 = @exp3
  exp4 = @exp4
  start = @start
  group = @group
  

 
default:
  title = "Strange Brew"
  maxiter = 1000
  method = multipass
  periodicity = 0
  magn = 0.29
  center = (-0.9575,0.0)

  param bailout
  caption = "bailout"
  default = 20.0
  hint = "It is worth your while to check higher \
  (and lower) bailouts as this will definitely \
   affect the character of the image elements by \
   determining how completely they are drawn"
  endparam
  param start
  caption = "init z"
  default = 1.0
  endparam
  param eye
  caption = "eye of newt"
  default = -1.0
  endparam
  param frog
  caption = "frog's breath"
  default = 0.0
  endparam
  param hen
  caption = "henbane"
  default = (-.5,0)
  endparam
  param bat
  caption = "bat wings"
  default = (0,0)
  endparam
  param exp1
  caption = "exponent 1"
  default = (1,0)
  endparam
  param exp2
  caption = "exponent 2"
  default = (1,0)
  endparam
 param exp3
  caption = "exponent 3"
  default = (1,0)
  endparam
 param exp4
  caption = "exponent 4"
  default = (1,0)
  endparam
  param op1
  caption = "operator 1"
  enum = "/""*""-""+""^"
  default = 1
  endparam
  param op2
  caption = "operator 2"
  enum = "/""*""-""+""^"
  default = 3
  endparam
  param op3
  caption = "operator 3"
  enum = "/""*""-""+""^"
  default = 1
  endparam
  param group
  caption = "grouping"
  default = 0
  enum = "1""2""3""4""5"
  endparam




  
  
  func fn1
  Caption = "function 1"
  default = exp ()
  endfunc
  func fn2
  Caption = "function 2"
  default = ident ()
  endfunc
  func fn3
  Caption = "function 3"
  default = ident ()
  endfunc
  func fn4
  Caption = "function 4"
  default = ident ()
  endfunc
  func fn5
  Caption = "function 5"
  default = ident ()
  endfunc
  func fn6
  Caption = "function 6"
  default = ident ()
  endfunc
  func fn7
  Caption = "function 7"
  default = ident ()
  endfunc
}

~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

StrangeBrewJulia {
  ; Toby Marshall, Jan. 2002
  ; Functions and parameters can be changed
  ; to change the shapes and relations of 
  ; the fractal elements.
  ; 
  ; Thanks to Jos Leys and Rui Parracho 
  ; for their explanations and patience.
init:
 
  z = 2*pixel
  complex frog = @frog*(0.0,1.0)
  
loop:
aa = fn2(real(fn3(z^@exp1) + @eye))
qq = fn4(imag (@fn5(z^@exp2) + frog))
vv = @fn6(@seed^@exp4 +@hen)
ww = @fn7(z^@exp3 + @bat)
IF (@group == 0); inner
IF (@op3 == 0); divide
IF (@op2 == 0); divide
IF (@op1 == 0); divide
z = fn1(aa) / qq / vv / ww
ELSEIF (@op1 == 1); multiply
z = fn1(aa) * qq / vv / ww
ELSEIF (@op1 == 2); subtract
z = fn1(aa) - qq / vv / ww
ELSEIF (@op1 == 3); add
z = fn1(aa) + qq / vv / ww
ELSEIF (@op1 == 4); exponent
z = fn1(aa) ^ qq / vv / ww
ENDIF
ELSEIF (@op2 == 1); multiply
IF (@op1 == 0); divide
z = fn1(aa) / qq * vv / ww
ELSEIF (@op1 == 1); multiply
z = fn1(aa) * qq * vv / ww
ELSEIF (@op1 == 2); subtract
z = fn1(aa) - qq * vv / ww
ELSEIF (@op1 == 3); add
z = fn1(aa) + qq * vv / ww
ELSEIF (@op1 == 4); exponent
z = fn1(aa) ^ qq * vv / ww
ENDIF
ELSEIF (@op2 == 2); subtract
IF (@op1 == 0); divide
z = fn1(aa) / qq - vv / ww
ELSEIF (@op1 == 1); multiply
z = fn1(aa) * qq - vv / ww
ELSEIF (@op1 == 2); subtract
z = fn1(aa) - qq - vv / ww
ELSEIF (@op1 == 3); add
z = fn1(aa) + qq - vv / ww
ELSEIF (@op1 == 4); exponent
z = fn1(aa) ^ qq - vv / ww
ENDIF
ELSEIF (@op2 == 3); add
IF (@op1 == 0); divide
z = fn1(aa) / qq + vv / ww
ELSEIF (@op1 == 1); multiply
z = fn1(aa) * qq + vv / ww
ELSEIF (@op1 == 2); subtract
z = fn1(aa) - qq + vv / ww
ELSEIF (@op1 == 3); add
z = fn1(aa) + qq + vv / ww
ELSEIF (@op1 == 4); exponent
z = fn1(aa) ^ qq + vv / ww
ENDIF
ELSEIF (@op2 == 4); exponent
IF (@op1 == 0); divide
z = fn1(aa) / qq ^ vv / ww
ELSEIF (@op1 == 1); multiply
z = fn1(aa) * qq ^ vv / ww
ELSEIF (@op1 == 2); subtract
z = fn1(aa) - qq ^ vv / ww
ELSEIF (@op1 == 3); add
z = fn1(aa) + qq ^ vv / ww
ELSEIF (@op1 == 4); exponent
z = fn1(aa) ^ qq ^ vv / ww
ENDIF
ENDIF
ELSEIF (@op3 == 1); multiply
IF (@op2 == 0); divide
IF (@op1 == 0); divide
z = fn1(aa) / qq / vv * ww
ELSEIF (@op1 == 1); multiply
z = fn1(aa) * qq / vv * ww
ELSEIF (@op1 == 2); subtract
z = fn1(aa) - qq / vv * ww
ELSEIF (@op1 == 3); add

bailout:
  |z| < real(@bailout)
switch:
  type = "MightyAtomMkII"
  bailout = bailout
  power = @power
  exp1 = @exp1
  exp2 = @exp2
  exp3 = @exp3
  fn1 = @fn1
  fn2 = @fn2
  fn3 = @fn3
  fn4 = @fn4
  fn5 = @fn5
  budge = @budge
  nudge = @nudge
  op1 = @op1
  op2 = @op2
  op3 = @op3
  group = @group 
default:
  title = "Mighty Atom Mk II Julia"
  param seed
  default = (1.05,-1)
  endparam
  param bailout
  default = (2.0,0)
  endparam
  param power 
  default = (1.0,0)
  endparam
  param op1 
  caption = "operator 1"
  default = 1
  enum = "/""*""-""+""^"
  endparam
   param op2 
  caption = "operator 2"
  default = 0
  enum = "/""*""-""+""^"
  endparam
  param group
  caption = "grouping"
  default = 0
  enum = "inner""outer""middle"
  endparam
  param op3 
  caption = "operator 3"
  default = 4
  enum = "/""*""-""+""^"
  endparam
  param exp1
  caption = "exponent 1"
  default = (1.0,0)
  endparam
  param exp2
  caption = "exponent 2"
  default = (1.0,0)
  endparam
  param exp3
  caption = "exponent 3"
  default = (1.0,0)
  endparam
  func fn1
  caption = "Function 1"
  default = atan()
  endfunc
  func fn2
  caption = "Function 2"
  default = abs()
  endfunc
  func fn3
  caption = "Function 3"
  default = tan()
  endfunc
  func fn4
  caption = "Function 4"
  default = ident()
  endfunc
  func fn5  
  caption = "Function 5"
  default = ident()
  endfunc
  periodicity = 0
}

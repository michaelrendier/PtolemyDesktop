DragonAtom03z {
;Toby Marshall, Dec. 2001

;Similar structure to its non-z counterpart
;but with quite different behavior.

;Differs from Dragon Atom 2z in that 
;"operator 4" modifies a different term
;in the equation. Adds a "grouping" 
;function.

;Choose your parameter and function values 
;then explore the resulting figure with 
;the Julia switch.

;Special thanks to Ken Childress,  
;Jos Leys, Erik Nathan Reckase, 
;Mark Townsend and Frederik Slijkerman  
;for their suggestions and advice.

;Please see tma.txt for help and hints.

;Have fun!

init:
  z = @start
loop:
aa = fn1(#pixel/fn4(z-@kludge))
bb = fn1(#pixel*fn4(z-@kludge))
cc = fn1(#pixel-fn4(z-@kludge))
dd = fn1(#pixel+fn4(z-@kludge))
ff = fn1(#pixel^fn4(z-@kludge))
qq = fn2(#pixel^@exp1-@power)/fn3(z-@budge)^@fn7(z)
qr = fn2(#pixel^@exp1-@power)*fn3(z-@budge)^@fn7(z)
qs = fn2(#pixel^@exp1-@power)-fn3(z-@budge)^@fn7(z)
qt = fn2(#pixel^@exp1-@power)+fn3(z-@budge)^@fn7(z)
qv = fn2(#pixel^@exp1-@power)^fn3(z-@budge)^@fn7(z)
ww = (@fn5(real(#pixel^@exp2*@power)))
xx = @fn6(imag(#pixel^@exp3/@power))-@nudge
IF (@op5 == 0); group 1
IF (@op4 == 0)
IF (@op3 == 0)
IF (@op2 == 0)
IF (@op1 == 0)
   z = aa/(qq)/ww^xx
   ELSEIF (@op1 == 1)
   z = bb/(qq)/ww^xx
   ELSEIF (@op1 == 2)
   z = cc/(qq)/ww^xx
   ELSEIF (@op1 == 3)
   z = dd/(qq)/ww^xx
   ELSEIF (@op1 == 4)
   z = ff/(qq)/ww^xx
   ENDIF
   ELSEIF (@op2 == 1)
   IF (@op1 == 0)
   z = aa*(qq)/ww^xx
   ELSEIF (@op1 == 1)
   z = bb*(qq)/ww^xx
   ELSEIF (@op1 == 2)
   z = cc*(qq)/ww^xx
   ELSEIF (@op1 == 3)
   z = dd*(qq)/ww^xx
   ELSEIF (@op1 == 4)
   z = ff*(qq)/ww^xx
   ENDIF
   ELSEIF (@op2 == 2)
   IF (@op1 == 0)
   z = aa-(qq)/ww^xx
   ELSEIF (@op1 == 1)
   z = bb-(qq)/ww^xx
   ELSEIF (@op1 == 2)
   z = cc-(qq)/ww^xx
   ELSEIF (@op1 == 3)
   z = dd-(qq)/ww^xx
   ELSEIF (@op1 == 4)
   z = ff-(qq)/ww^xx
   ENDIF
   ELSEIF (@op2 == 3)
   IF (@op1 == 0)
   z = aa+(qq)/ww^xx
   ELSEIF (@op1 == 1)
   z = bb+(qq)/ww^xx
   ELSEIF (@op1 == 2)
   z = cc+(qq)/ww^xx
   ELSEIF (@op1 == 3)
   z = dd+(qq)/ww^xx
   ELSEIF (@op1 == 4)
   z = ff+(qq)/ww^xx
   ENDIF
   ELSEIF (@op2 == 4)
   IF (@op1 == 0)
   z = aa^(qq)/ww^xx
   ELSEIF (@op1 == 1)
   z = bb^(qq)/ww^xx
   ELSEIF (@op1 == 2)
   z = cc^(qq)/ww^xx
   ELSEIF (@op1 == 3)
   z = dd^(qq)/ww^xx
   ELSEIF (@op1 == 4)
   z = ff^(qq)/ww^xx
   ENDIF
   ENDIF
   ELSEIF (@op3 == 1)
IF (@op2 == 0)
IF (@op1 == 0)
   z = aa/(qq)*ww^xx

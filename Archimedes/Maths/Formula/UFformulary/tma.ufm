;Have fun!



init:
  z = #pixel
loop:
aa = @seed^@exp1-@power
qq = fn3(z-@budge)
ww = fn4(real(@seed^@exp2*@power))
yy = @fn5(imag(@seed^@exp3/@power))-@nudge 
IF (@op3 == 0)
IF (@group == 0); inner
IF (@op2 == 0)
IF (@op1 == 0)
  z = fn1(fn2(aa)/qq)/ww/yy

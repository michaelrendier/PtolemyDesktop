 *********************************************************************


mandalaAlpha {
;Toby Marshall, Jan 2002
;Use the switch to explore the perimeter of the M set.
;The three functions can be set while using the switch.
;Parameters can be incremented in either formula. The
;real component of "exponent1" determines the number of
;arms in the julia figure.
init:
  z = 2
loop:
  z = fn1(fn2(z^@power1)-@budge)^fn3(@pow/((#pixel^@power2)-@nudge))
bailout:
  |z| < @bailout

switch:
  type = "mandalaalphajulia"
  seed = #pixel
  bailout = bailout
  fn1 = @fn1
  fn2 = @fn2
  fn3 = @fn3
  budge = @budge
  nudge = @nudge
  power1 = @power1
  power2 = @power2
  pow = @pow
  default:
  periodicity = 0
  title = "mandala alpha"
  param bailout
  caption = "bailout"
  default = 7.0
  endparam
  param power1
  caption = "exponent1"
  default = (3.0,0.0)
  hint = "The real component determines the number \
   of arms in the figure. The imaginary component \
   changes the scale of the elements moving around the figure."
  endparam
  param power2
  caption = "exponent2"
  default = (1.0,0.0)
  endparam
  param budge
  caption = "budge"
  default = (0.0,0.0)
  endparam
  param nudge
  caption = "nudge"
  default = (0.0,0.0)
  endparam
  param pow
  caption = "power"
  default = (1.0,0.0)
  endparam

  func fn1
  caption = "function 1"
  default = flip ()
  endfunc
  func fn2
  caption = "function 2"
  default = conj ()
  endfunc
  func fn3
  caption = "function 3"
  default = log ()
  endfunc
}

mandalaAlphaJulia {
; Toby Marshall, Jan 2002
init:
  z = #pixel
loop:
z = fn1(fn2(z^@power1)-@budge)^fn3(@pow/((@seed^@power2)-@nudge))


bailout:
  |z| < @bailout
  switch:
  type = "mandalaalpha"
  bailout = bailout
  fn1 = @fn1
  fn2 = @fn2
  fn3 = @fn3
  budge = @budge
  nudge = @nudge
  power1 = @power1
  power2 = @power2
  pow = @pow


  default:
  periodicity = 0
  title = "mandala alpha julia"
  param bailout
  caption = "bailout"
  default = 7.0
  endparam
  param seed
  caption = "seed"
  default = (1.4125, .075)
  endparam 
  param power1
  caption = "exponent1"
  default = (3.0,0.0)
  hint = "The real component determines the number\
  of arms in the figure. The imaginary component\
  changes the scale of the elements moving around the figure."
  endparam
  param power2
  caption = "exponent2"
  default = (1.0,0.0)
  endparam
  param budge
  caption = "budge"
  default = (0.0,0.0)
  endparam
  param nudge
  caption = "nudge"
  default = (0.0,0.0)
  endparam
  param pow
  caption = "power"
  default = (1.0,0.0)
  endparam

  func fn1
  caption = "function 1"
  default = flip ()
  endfunc
  func fn2
  caption = "function 2"
  default = conj ()
  endfunc
func fn3
  caption = "function 3"
  default = log ()
  endfunc
}

***********************************************************************

mandalaBeta {
;Toby Marshall, Jan 2002
;This differs from "mandala alpha" by the substitution 
;of the reciprocal of one expression in the equation.
;I've set the three functions to different defaults, 
;but it is worth your while to try different ones (try 
;fn1 = flip, fn2 = conj, fn3 = log for similar behavior to
;the "mandala alpha" default).
;Use the switch to explore the perimeter of the M set.
;The three functions can be set while using the switch.
;Parameters can be incremented in either formula. The
;real component of "exponent1" determines the number of
;arms in the julia figure.
init:
  z = 2
  loop:
  z = fn1(fn2(z^@power1)-@budge)^fn3((#pixel^@power2)-@nudge)
bailout:
  |z| < @bailout
  

switch:
  type = "mandalabetajulia"
  seed = #pixel
  bailout = bailout
  fn1 = @fn1
  fn2 = @fn2
  fn3 = @fn3
  budge = @budge
  nudge = @nudge
  power1 = @power1
  power2 = @power2
  default:
  periodicity = 0
  title = "mandala beta"
  param bailout
  caption = "bailout"
  default = 7.0
  endparam
  param power1
  caption = "exponent1"
  default = (3.0,0.0)
  hint = "The real component determines the number \
   of arms in the figure. The imaginary component \
   changes the scale of the elements moving around the figure."
  endparam
  param power2
  caption = "exponent2"
  default = (1.0,0.0)
  endparam
  param budge
  caption = "budge"
  default = (0.0,0.0)
  endparam
  param nudge

mandalaEpsilon {
;Toby Marshall, Jan 2002
;This formula differs from "mandala gamma" by virtue
;of splitting an extra expression into real and 
;imaginary components and adding functions (fn4 & fn5)
;which control these independently, as well as parameters
;(exponents 3 & 4, "fudge" and "kludge") which change
;them independently.
;Use the switch to explore the perimeter of the M set.
;The three functions can be set while using the switch.
;Parameters can be incremented in either formula. The
;real component of "exponent1" determines the number of
;arms in the julia figure.
init:
  z = 2
  complex fudge = @fudge*(0.0,1.0)
 
loop:
  z = fn1(fn2(z^@e1-@budge)*fn4(imag(#pixel^@e3-fudge)))^@fn5(real(#pixel^@e4-@kludge))^fn3(@pow/((#pixel^@e2)-@nudge))
bailout:
  |z| < @bailout

switch:
  type = "mandalaepsilonjulia"
  seed = #pixel
  bailout = bailout
  fn1 = @fn1
  fn2 = @fn2
  fn3 = @fn3
  fn4 = @fn4
  fn5 = @fn5
  budge = @budge
  nudge = @nudge
  kludge = @kludge
  fudge = @fudge
  e1 = @e1
  e2 = @e2
  e3 = @e3
  e4 = @e4
  pow = @pow
  default:
  title = "mandala epsilon"
  periodicity = 0
  param bailout
  caption = "bailout"
  default = 7.0
  endparam
 
  param e1
  caption = "exponent1"
  default = (3.0,0.0)
  hint = "The real component determines the number \
   of arms in the figure. The imaginary component \
   changes the scale of the elements moving around the figure."
  endparam
  param e2
  caption = "exponent2"
  default = (1.0,0.0)
  endparam
  param e3
  caption = "exponent3"
  default = (1.0,0.0)
  endparam
  param e4
  caption = "exponent4"
  default = (1.0,0.0)
  endparam
  param budge
  caption = "budge"
  default = (0.0,0.0)
  endparam
  param fudge
  caption = "fudge"
  default = 0.0
  endparam
  param kludge
  caption = "kludge"
  default = 0.0
  endparam
  param nudge
  caption = "nudge"
  default = (0.0,0.0)
  endparam
  param pow
  caption = "power"
  default = (1.0,0.0)
  endparam


  func fn1
  caption = "function 1"
  default = flip ()
  endfunc
  func fn2
  caption = "function 2"
  default = conj ()
  endfunc
  func fn3
  caption = "function 3"
  default = log ()
  endfunc
  func fn4
  caption = "function 4"
  default = ident ()
  endfunc
  func fn5
  caption = "function 5"
  default = ident ()
  endfunc
}


bailout:
  |z| < real(@bailout)
switch:
  type = "MightyAtomMkIIzJulia"
  seed = #pixel
  bailout = bailout
  power = @power
  exp1 = @exp1
  exp2 = @exp2
  exp3 = @exp3
  fn1 = @fn1
  fn2 = @fn2
  fn3 = @fn3
  fn4 = @fn4
  fn5 = @fn5
  fn6 = @fn6
  budge = @budge
  nudge = @nudge
  op1 = @op1
  op2 = @op2
  op3 = @op3
  group = @group  
  
default:
  title = "Mighty Atom Mk IIz"
  param start
  default = (2.0,0)
  endparam
  param bailout
  default = (2.0,0)
  endparam
  param power 
  default = (1.0,0)
  endparam
  param op1 
  caption = "operator 1"
  default = 1
  enum = "/""*""-""+""^"
  endparam
   param op2 
  caption = "operator 2"
  default = 0
  enum = "/""*""-""+""^"
  endparam
  param group
  caption = "grouping"
  default = 0
  enum = "inner""outer""middle"
  endparam
  param op3 
  caption = "operator 3"
  default = 4
  enum = "/""*""-""+""^"
  endparam
  param exp1
  caption = "exponent 1"
  default = (1.0,0)
  endparam
  param exp2
  caption = "exponent 2"
  default = (1.0,0)
  endparam
  param exp3
  caption = "exponent 3"
  default = (1.0,0)
  endparam


  func fn1
  caption = "Function 1"
  default = atan()
  endfunc
  func fn2
  caption = "Function 2"
  default = abs()
  endfunc
  func fn3
  caption = "Function 3"
  default = tan()
  endfunc
  func fn4
  caption = "Function 4"
  default = ident()
  endfunc
  func fn5  
  caption = "Function 5"
  default = ident()
  endfunc
  func fn6  
  caption = "Function 6"
  default = ident()
  endfunc

  periodicity = 0
}
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

MightyAtomMkIIzJulia {
;Toby Marshall, Dec. 2001 

;Special thanks to Ken Childress,  
;Jos Leys, Erik Nathan Reckase, 
;Mark Townsend and Frederik Slijkerman  
;for their suggestions and advice.

;Please see tma.txt for help and hints.

;Have fun!



init:
  z = #pixel
loop:
aa = @seed^@exp1-@power
qq = fn3(z-@budge)^@fn6(z)
xx = fn4(real(@seed^@exp2*@power))
ww = @fn5(imag(@seed^@exp3/@power))-@nudge
IF (@op3 == 0)
IF (@group == 0); inner
IF (@op2 == 0)
IF (@op1 == 0)
  z = fn1(fn2(aa)/qq)/xx/ww
  ELSEIF (@op1 == 1)
  z = fn1(fn2(aa)*qq)/xx/ww
  ELSEIF (@op1 == 2)
  z = fn1(fn2(aa)-qq)/xx/ww
  ELSEIF (@op1 == 3)
  z = fn1(fn2(aa)+qq)/xx/ww
  ELSEIF (@op1 == 4)
  z = fn1(fn2(aa)/qq)/xx/ww
  ENDIF
  ELSEIF (@op2 == 1)
IF (@op1 == 1)
  z = fn1(fn2(aa)/qq)*xx/ww
  ELSEIF (@op1 == 1)
  z = fn1(fn2(aa)*qq)*xx/ww
  ELSEIF (@op1 == 2)

SzegediButterfly1 {
init:
   z = #pixel
loop:
   x = real(z)
   y = imag(z)
   z = sqr(y) - sqrt(abs(x)) + 1i * (sqr(x) - sqrt(abs(y))) + #pixel
bailout:
   |z| <= @Bailout
default:
  title = "Szegedi Butterfly 1"
  helpfile = "https://szegedi.live/blog/fractals"
  method = multipass
  center = (-0.234482758620689568, -0.289655172413793216)
  magn = 0.611814345991561088
  angle = 0

  param Bailout
    caption = "Bailout Value"
    default = 127.0
  endparam
switch:
  type = "SzegediButterflyJulia1"
  seed = #pixel
  Bailout = Bailout
}


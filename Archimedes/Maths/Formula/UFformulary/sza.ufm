SzegediBioform {
init:
   z = #pixel
loop:
   x = real(z)
   y = imag(z)
   z = (2-sqr(x)-sqr(y)) * (y + 1i * x) + #pixel
bailout:
   |z| <= @Bailout
default:
  title = "Szegedi Bioform"
  helpfile = "https://szegedi.live/blog/fractals"
  method = multipass
  center = (0, 0)
  magn = 0.611814345991561088
  angle = 0

  param Bailout
    caption = "Bailout Value"
    default = 127.0
  endparam
switch:
  type = "SzegediBioformJulia"
  seed = #pixel
  Bailout = Bailout
}

SzegediBioformJulia {
init:
   z = #pixel
loop:
   x = real(z)
   y = imag(z)
   d = (2-sqr(x)-sqr(y))
   z = (2-sqr(x)-sqr(y)) * (y + 1i * x) + @seed
bailout:
   |z| <= @Bailout
default:
  title = "Szegedi Bioform Julia"
  helpfile = "https://szegedi.live/blog/fractals"
  method = multipass
  center = (-0.234482758620689568, -0.289655172413793216)
  magn = 0.611814345991561088
  angle = 0

  param Bailout
    caption = "Bailout Value"
    default = 127.0
  endparam
  param seed
    caption = "Julia seed"
    default = (1.17525862068965547, -0.636982758620689821)
  endparam
switch:
  type = "SzegediBioform"
  seed = #pixel
  Bailout = Bailout
}

SzegediButterflyJulia1 {
init:
   z = #pixel
loop:
   x = real(z)
   y = imag(z)
   z = sqr(y) - sqrt(abs(x)) + 1i * (sqr(x) - sqrt(abs(y))) + @seed
bailout:
   |z| <= @Bailout
default:
  title = "Szegedi Butterfly Julia 1"
  helpfile = "https://szegedi.live/blog/fractals"
  method = multipass
  center = (0, 0)
  magn = 1
  angle = 0

    param Bailout
    caption = "Bailout Value"
    default = 127.0
  endparam
  param seed
    caption = "Julia seed"
    default = (1.17525862068965547, -0.636982758620689821)
  endparam
switch:
  type = "SzegediButterfly1"
  Bailout = Bailout
}


Carr1695 { ; Updated for UF2 by Erik Reckase, Jan 2000
           ; Julia
init:
  z=1/(pixel+5*pixel)
  c=1/pixel-conj(pixel)
loop:
  z=z*z+c
  c=((1+flip(imag(sqrt(sin(c)))))*real(sqrt(tan(c)))/9+z)
bailout:
  |real(z)| <= 4
default:
  title = "Carr 1695"
  periodicity = 0
  maxiter = 500
  magn = .8
  center = (0,0)
}


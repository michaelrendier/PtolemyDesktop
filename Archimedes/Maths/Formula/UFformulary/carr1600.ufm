comment {
  Carr1600.ufm Version 1.0
  Ultra Fractal conversions of Robert Carr's formulas Carr1600 - Carr1699
  by Erik Reckase / Lale Erguner, December 12, 2002

  History:  Version 1.1 - Fixes for UF3 compatibility by
                          Lale Erguner

            Version 1.0 - Initial Release
                          Original formulas pulled from _rc1.frm

                          Carr1610,1625-1626,1637,
                              1649,1652-1653,1660,
                              1662-1663,1672,1674  : cosxx fix

            
}

Carr1600 { ; Updated for UF2 by Erik Reckase, Jan 2000
           ; Julia
init:
  z=acos(exp(1/atanh(pixel-0.5)))
  c=sqr(1+asin(pixel))
loop:
  z = z^2 + c
  c=((1+flip(imag(sqrt(sin(c-0.1/pixel)))))*real(sqrt(tan(c)))/9+z)
bailout:
  |real(z)| <= 4
default:
  title = "Carr 1600"
  periodicity = 0
  maxiter = 500
  magn = 1.5
  center = (-1.65,0)
}

Carr1601 { ; Updated for UF2 by Erik Reckase, Jan 2000
           ; Julia
init:
  z=(1/log(pixel/0.2)-conj(1/pixel))/(acos(pixel))
  c=pixel*pixel/(asin(pixel))
loop:
  z = z^2 + c
  c=((1+flip(imag(sqrt(sin(c-0.1/pixel)))))*real(sqrt(tan(c)))/9+z)
bailout:
  |real(z)| <= 4
default:
  title = "Carr 1601"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (-.3,0)
}


Carr1602 { ; Updated for UF2 by Erik Reckase, Jan 2000
           ; Spider
init:
  z=(1/log(pixel/0.2)-conj(1/pixel))/(acos(pixel))
  c=pixel*pixel/(asin(pixel))
loop:
  z = z^2 + c
  c=z+c/2.125
bailout:

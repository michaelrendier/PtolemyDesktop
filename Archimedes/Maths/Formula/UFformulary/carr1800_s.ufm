  op = 1/#pixel
  z1 = conj(#pixel)-sqrt(op)-log(op)-.9
  z = (1/(#pixel-conj(z1)-exp(1/exp(#pixel+.45))))/@scale
  c = 1/(#pixel+sqrt(op)/log(op)-conj(1/z1))


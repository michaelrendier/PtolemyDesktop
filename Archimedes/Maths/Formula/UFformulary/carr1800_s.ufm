Carr1873S { 
; A "Modified Carr" formula, based on the original with permission.
; Functionality added by Sharon S. Schultz, May, 2003.
; Updated for UF2 by Erik Reckase, March 2000

init:
  c1 = 1/(#pixel-sin(op))
  z1 = c1-conj(op)
  z = (1/(#pixel-(c-cos(z1))/z1/c1))/@scale
  op = 1/#pixel
  c = 1/(#pixel-(z1+c1)*op)

loop:
  z = fn1(fn2(fn3(z*z+c)))

bailout:
  |real(z)| <= @bailout

default:
  title = "Carr 1873S"
  method = multipass
  periodicity = 0
  maxiter = 100
  magn = .7
  center = (1,0)


Carr1874S { 
; A "Modified Carr" formula, based on the original with permission.
; Functionality added by Sharon S. Schultz, May, 2003.
; Updated for UF2 by Erik Reckase, March 2000
; Modified Lee Skinner formula

init:
  p = 1/(#pixel-conj(1/#pixel)-flip(1/#pixel))
  t3 = 3*cos(p)
  t2 = p*p
  a = (t2+1)/t3
  b = 2*a^3+(t2-2)/t3
  aa3 = a*a*3
  z = (-a)/@scale
  
loop:
  z = fn1(fn2(fn3(z*z-aa3*z+b)))

bailout:
  |real(z)| <= @bailout

default:
  title = "Carr 1874S"
  method = multipass
  periodicity = 0
  maxiter = 100
  magn = .5
  center = (0,0)

heading 
  caption = "Parameters"
endheading

param scale

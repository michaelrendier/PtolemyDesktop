Carr1887S { 
; A "Modified Carr" formula, based on the original with permission.
; Functionality added by Sharon S. Schultz, May, 2003.
; Updated for UF2 by Erik Reckase, March 2000 

init:
  z = #pixel/@scale
  c = 1/(#pixel-conj(1/#pixel)-flip(1/#pixel))

loop:
  z = fn1(fn2(fn3(z^3/5/#pixel+conj(z^2)+c+(.39776,-.009))))

bailout:
  |z| <= @bailout

default:
  title = "Carr 1887S"
  method = multipass
  periodicity = 0
  maxiter = 100
  magn = 1
  center = (0,0)


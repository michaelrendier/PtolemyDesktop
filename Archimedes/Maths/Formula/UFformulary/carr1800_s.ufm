Carr1821S { 
; A "Modified Carr" formula, based on the original with permission.
; Functionality added by Sharon S. Schultz, May, 2003.
; Updated for UF2 by Erik Reckase, March 2000
; Julia

init:
  op = #pixel-flip(1/#pixel)-conj(1/#pixel)
  z = (1/op)/@scale
  c = 1/#pixel/op 

loop:
  z = fn1(fn2(fn3(z^2+c)))
  c = (1+flip(imag(sqrt(sin(c)))))*real(sqrt(tan(c)))/9+z

bailout:
  |real(z)| <= @bailout

default:

          gt[gnt,2] = gtemp[0]*@t26r0c2 + gtemp[1]*@t26r1c2 + gtemp[2]*@t26r2c2
          gt[gnt,3] = gtemp[3]*@t26r0c0 + gtemp[4]*@t26r1c0 + gtemp[5]*@t26r2c0
          gt[gnt,4] = gtemp[3]*@t26r0c1 + gtemp[4]*@t26r1c1 + gtemp[5]*@t26r2c1

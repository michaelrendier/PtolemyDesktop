      gp[0] = 3
      gp[1] = 4
      gp[2] = 5
      gp[3] = 6
      gp[4] = 7
      gp[5] = 8
      gp[6] = 1
      gp[7] = 2
      gp[8] = 0
      gp[9] = 9

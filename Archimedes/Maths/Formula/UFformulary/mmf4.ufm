          gj = gp[gi]
          gk = gi
        endif
      until (gi=gi-1)<0
      if gj<100
        gp[gk] = 100
        if gk==0
          if @deform
            gx = 0.01*(@sx11+@sx32)
          else
            gx = 0.01*@sx11
          endif
          gt[gnt,0] = gx*gt[gnt,0]
          gt[gnt,3] = gx*gt[gnt,3]

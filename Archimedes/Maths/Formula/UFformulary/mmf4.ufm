    endif
    if @usetotal10
      gcount1[gnt] = @total10
    else
      gcount1[gnt] = @igen + 1
    endif
    gus[gnt] = @us10
    gnt = gnt + 1
   endif
  endif ; @use10

  if @use11 && (@view==0 || @viewall==0 || @showtrans==0 || @showtrans==11)
    if @useskips
      gj = 1073741824
      gi = 30

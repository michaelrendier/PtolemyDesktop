      gt[gnt,9]  = gt[gnt,9] +@itx12*gt[gnt,0]+@ity12*gt[gnt,3]+@itz12*gt[gnt,6]
      gt[gnt,10] = gt[gnt,10]+@itx12*gt[gnt,1]+@ity12*gt[gnt,4]+@itz12*gt[gnt,7]
      gt[gnt,11] = gt[gnt,11]+@itx12*gt[gnt,2]+@ity12*gt[gnt,5]+@itz12*gt[gnt,8]

          gt[gnt,1] = gtemp[0]*@t28r0c1 + gtemp[1]*@t28r1c1 + gtemp[2]*@t28r2c1
          gt[gnt,2] = gtemp[0]*@t28r0c2 + gtemp[1]*@t28r1c2 + gtemp[2]*@t28r2c2
          gt[gnt,3] = gtemp[3]*@t28r0c0 + gtemp[4]*@t28r1c0 + gtemp[5]*@t28r2c0
          gt[gnt,4] = gtemp[3]*@t28r0c1 + gtemp[4]*@t28r1c1 + gtemp[5]*@t28r2c1
          gt[gnt,5] = gtemp[3]*@t28r0c2 + gtemp[4]*@t28r1c2 + gtemp[5]*@t28r2c2
          gt[gnt,6] = gtemp[6]*@t28r0c0 + gtemp[7]*@t28r1c0 + gtemp[8]*@t28r2c0

  if @use17 && (@view==0 || @viewall==0 || @showtrans==0 || @showtrans==17)
    if @useskips
      gj = 1073741824
      gi = 30
      gk = @skip17mask1
      repeat
        if gk>=gj
          df[gnt,gi] = false
          gk = gk - gj
        endif
        gj = round(0.5*gj)
      until (gi=gi-1)<0
      gj = 1073741824
      gi = 61
      gk = @skip17mask2
      repeat
        if gk>=gj

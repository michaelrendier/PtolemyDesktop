      gt[gnt,9]  = gt[gnt,9] +@itx20*gt[gnt,0]+@ity20*gt[gnt,3]+@itz20*gt[gnt,6]
      gt[gnt,10] = gt[gnt,10]+@itx20*gt[gnt,1]+@ity20*gt[gnt,4]+@itz20*gt[gnt,7]
      gt[gnt,11] = gt[gnt,11]+@itx20*gt[gnt,2]+@ity20*gt[gnt,5]+@itz20*gt[gnt,8]

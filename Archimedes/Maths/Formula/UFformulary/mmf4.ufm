          gt[gnt,4] = gt[gnt,4]*ca
          gt[gnt,6] = gt[gnt,6] - gt[gnt,7]*sa
          gt[gnt,7] = gt[gnt,7]*ca
        elseif gk==9
          gj = 8
          repeat
            gtemp[gj] = gt[gnt,gj]
          until (gj=gj-1)<0
          gt[gnt,0] = gtemp[0]*@t20r0c0 + gtemp[1]*@t20r1c0 + gtemp[2]*@t20r2c0
          gt[gnt,1] = gtemp[0]*@t20r0c1 + gtemp[1]*@t20r1c1 + gtemp[2]*@t20r2c1
          gt[gnt,2] = gtemp[0]*@t20r0c2 + gtemp[1]*@t20r1c2 + gtemp[2]*@t20r2c2
          gt[gnt,3] = gtemp[3]*@t20r0c0 + gtemp[4]*@t20r1c0 + gtemp[5]*@t20r2c0
          gt[gnt,4] = gtemp[3]*@t20r0c1 + gtemp[4]*@t20r1c1 + gtemp[5]*@t20r2c1
          gt[gnt,5] = gtemp[3]*@t20r0c2 + gtemp[4]*@t20r1c2 + gtemp[5]*@t20r2c2
          gt[gnt,6] = gtemp[6]*@t20r0c0 + gtemp[7]*@t20r1c0 + gtemp[8]*@t20r2c0
          gt[gnt,7] = gtemp[6]*@t20r0c1 + gtemp[7]*@t20r1c1 + gtemp[8]*@t20r2c1
          gt[gnt,8] = gtemp[6]*@t20r0c2 + gtemp[7]*@t20r1c2 + gtemp[8]*@t20r2c2
        endif
      endif
    until gj>=100

    gt[gnt,0] = 1.0
    gt[gnt,1] = 0.0
    gt[gnt,2] = 0.0
    gt[gnt,3] = 0.0
    gt[gnt,4] = 1.0
    gt[gnt,5] = 0.0
    gt[gnt,6] = 0.0
    gt[gnt,7] = 0.0
    gt[gnt,8] = 1.0
    if @deform
      gt[gnt,9] = @tx17 + @tx32
      gt[gnt,10] = @ty17 + @ty32
      gt[gnt,11] = @tz17 + @tz32
    else

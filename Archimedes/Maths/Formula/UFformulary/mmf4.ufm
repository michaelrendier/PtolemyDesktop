      gt[gnt,10] = gt[gnt,10]+@itx10*gt[gnt,1]+@ity10*gt[gnt,4]+@itz10*gt[gnt,7]
      gt[gnt,11] = gt[gnt,11]+@itx10*gt[gnt,2]+@ity10*gt[gnt,5]+@itz10*gt[gnt,8]
    endif
    if @usecount10
      gcount[gnt] = @count10
    else

complex func DJfn2
    caption = "Double Julia Function 2"
    default = ident()
  visible = @DJulia == True
endfunc
complex func DJfn3
    caption = "Double Julia Function 3"
    default = ident()
  visible = @DJulia == True
endfunc
complex func DJfn4
    caption = "Double Julia Function 4"
    default = ident()
  visible = @DJulia == True
endfunc

heading
 caption = "Function Controls"
endheading
func fn1
  caption = "Function"
  default = acos ()
endfunc
func fn2
  caption = "Function 2"
  default = round ()
endfunc
func fn3
  caption = "Function 3"
  default = ident ()
endfunc
func fn4
  caption = "Function 4"
  default = flip ()
endfunc
complex func myfn1
    caption = "Function 5"
    default = sqr()
endfunc
complex func myfn2
    caption = "Function 6"

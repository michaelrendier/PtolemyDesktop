if @realy == true
if real(z)<@bs
     z=@p+(c+z*(fn1(z)*fn2(z)*fn3(z)*fn4(z)*@fn5(z)))*z
 elseif real(z)<(@bs-(@bs*@ba01))
     z=@p-(c+z*(fn1(z)*fn2(z)*fn3(z)*fn4(z)*@fn5(z)))*z
 elseif real(z)<(@bs-(@bs*@ba02))

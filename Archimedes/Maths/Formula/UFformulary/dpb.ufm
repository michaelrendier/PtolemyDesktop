       z = fn1(fn2(z^@power)/@indetailer + fn3(@seed))
       z = fn1(fn2(z^@power)/@indetailer - fn3(@seed))
     elseif @set_scattered == 3
       z = fn1(fn2(z^@power)/@indetailer - fn3(@seed))

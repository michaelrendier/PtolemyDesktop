Carr2882 {; Updated for UF2 by Erik Reckase, Feb 2000
          ; Modified Sylvie Gallet frm. [101324,3444],1996
          ; Very Slow Render : You Have Been Warned
init:
  b3=|sin(pixel^30.5)|
  c=.15/log(exp(pixel^450-b3-.4)-.8)
  z=(-.7564,.21978)*(-1.099,-.2249)/(-.8606,-.0959) \
    -flip(.001/pixel)
  IF (@p3==0)
    c = -c, z = -z
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -c, z = -z
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = (-.7546,-.132)
  ct = c/10 - .0035/c/21 + k
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0, float zro = 0
loop:
  IF (iter==l1)
    ct = c1/10 - .0035/c1/21 + k, z=z*zro
  ELSEIF (iter==l2)
    ct = c2/10 - .0035/c2/21 + k, z=z*zro
  ELSEIF (iter==l3)
    ct = c3/10 - .0035/c3/21 + k, z=z*zro
  ELSEIF (iter==l4)
    ct = c4/10 - .0035/c4/21 + k, z=z*zro
  ENDIF
  z = z*z + ct
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 2882"
  periodicity = 0
  maxiter = 500
  magn = 1.2
  center = (.001,.001)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (200,250)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}


  b3=|sin(pixel^3.5)|
  c=.15/log(exp(pixel^7-b3-.4)-.8)
  z=pixel-conj(.1/pixel)-flip(.01/pixel)
  IF (@p3==0)
    c = -c, z = -z
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -c, z = -z
    ENDIF
  ENDIF
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = (-.7546,-.132)
  ct = c/10 - .0035/c/21 + k
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    ct = c1/10 - .0035/c1/21 + k, z = 0
  ELSEIF (iter==l2)
    ct = c2/10 - .0035/c2/21 + k, z = 0
  ELSEIF (iter==l3)
    ct = c3/10 - .0035/c3/21 + k, z = 0

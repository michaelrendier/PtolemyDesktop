Carr2861 {; Updated for UF2 by Erik Reckase, Feb 2000
          ; Modified Sylvie Gallet frm. [101324,3444],1996
init:
  z=pixel/2-conj(.1/pixel-flip(.01/pixel))
  c=1-z
  IF (@p3==0)
    c = -c, z = -z
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -c, z = -z
    ENDIF
  ENDIF
  k = (-.7564,-.132)
  ct = c/10 + k
  c1=1.5*z^1.2, c2=2.25*conj(z)
  c3=3.375*flip(z), c4=5.0625*flip(z)
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0
loop:
  IF (iter==l1)
    ct = c1/10 + k, z = 0
  ELSEIF (iter==l2)
    ct = c2/10 + k, z = 0
  ELSEIF (iter==l3)
    ct = c3/10 + k, z = 0
  ELSEIF (iter==l4)
    ct = c4/10 + k, z = 0
  ENDIF
  mz = |z|
  z = mz/15 + z*z + ct
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 2861"
  periodicity = 0
  maxiter = 500
  magn = .6
  center = (-.1,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"

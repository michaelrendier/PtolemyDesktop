  ELSEIF (iter==l2)
    ct = c2/8 + k, z = 0
  ELSEIF (iter==l3)
    ct = c3/8 + k, z = 0
  ELSEIF (iter==l4)
    ct = c4/8 + k, z = 0
  ENDIF
  z = z*z + ct
  iter=iter+1
bailout:
  |z|<=bailout
default:
  title = "Carr 2859"
  periodicity = 0
  maxiter = 500
  magn = 1.1

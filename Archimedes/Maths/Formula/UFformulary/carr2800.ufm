Carr2821 {; Updated for UF2 by Erik Reckase, Feb 2000
          ; Modified Sylvie Gallet frm. [101324,3444],1996
          ; Converted to if.else by Sylvie Gallet
          ; and George Martin 3/97
init: 
  z=pixel-conj(.1/pixel)
  c=pixel-flip(.1/pixel)-conj(.001/pixel)
  IF (@p3==0)
    c = -c, z = -z
  ELSEIF (@p3==2)
    IF (whitesq)
      c = -c, z = -z
    ENDIF
  ENDIF
  k = .09/pixel
  ct = c - k
  c1=1.5*z^1.2, c2=2.25*conj(z)
  c3=3.375*flip(z), c4=5.0625*flip(z)
  l1=round(real(p1)),l2=round(imag(p1))
  l3=round(real(p2)),l4=round(imag(p2))
  float bailout=16,int iter=0, float zro=0
loop:
  IF (iter==l1)
    ct = c1 - k, z = z*zro
  ELSEIF (iter==l2)
    ct = c2 - k, z = z*zro
  ELSEIF (iter==l3)
    ct = c3 - k, z = z*zro
  ELSEIF (iter==l4)
    ct = c4 - k, z = z*zro
  ENDIF
  z = .2*|z| + z^2 + ct
  iter = iter + 1
bailout:
  |z| <= bailout
default:
  title = "Carr 2821"
  periodicity = 0
  maxiter = 500
  magn = 1.2
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (200,250)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p3
    caption = "Layer Option"
    enum = "Option 1" "Option 2" "Original"
    default = 2
    hint = "Options 1 and 2 are the two separate layers of this \
            formula.  The 'Original' option uses the original \
            PHC formula."
  endparam
}


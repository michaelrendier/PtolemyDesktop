     ang > 96*segs && ang < 97*segs || \
     ang > 98*segs && ang < 99*segs || \
     ang > 100*segs && ang < 101*segs

    if sqrt(x^2+y^2) > 0*rings && sqrt(x^2+y^2) < 1*rings
      if #x < #width/2
        z = @shrink2*fn2(z)+p-flip(@split2)-@split2a
      else
        z = -@shrink2*fn2(z)+p+flip(@split2)+@split2a

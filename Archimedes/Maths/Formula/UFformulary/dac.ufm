  row12 = y > 11*b+@borderH/2 && y <= 12*b-@borderH/2
  row13 = y > 12*b+@borderH/2 && y <= 13*b-@borderH/2
  row14 = y > 13*b+@borderH/2 && y <= 14*b-@borderH/2
  row15 = y > 14*b+@borderH/2 && y <= 15*b-@borderH/2
  row16 = y > 15*b+@borderH/2 && y <= 16*b-@borderH/2
  row17 = y > 16*b+@borderH/2 && y <= 17*b-@borderH/2
  row18 = y > 17*b+@borderH/2 && y <= 18*b-@borderH/2

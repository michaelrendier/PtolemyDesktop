  caption = " - slope 3"
  default = 0
  enabled = @waves == 2
  visible = @waves == 2
endparam
float param splitwav
  caption = " - split"
  default = 0.15
  enabled = @setwavefn == 1
  visible = @setwavefn == 1
endparam
float param shrinkwav
  caption = " - shrink"
  default = 3
  enabled = @setwavefn == 1
  visible = @setwavefn == 1
endparam
param Switchwave
  enum = "Point in" "Point out"
  default = 1
  caption = " - orientation"

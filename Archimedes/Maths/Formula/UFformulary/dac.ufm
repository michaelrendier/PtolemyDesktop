Diag-Only {
init:
  float w = #width/@checksH
  float h = #height/@checksV
  w2 = #width/2
  h2 = #height/2
  x1 = #x
  y1 = #y
  x = #x
  y = #y
  z = (0,0)
  complex p = #pixel
  float ratio = h/w
  if #width > #height && #width - #height > #height/3
    float lti = 1.5
    float ltr = #width/#height*lti
  else
    float ltr = 2
    float lti = #height/#width*ltr
  endif

loop:
if @switch1 == 0
  s1 = 1
else
  s1 = -1
endif
if @switch2 == 0
  s2 = 1
else
  s2 = -1
endif

if y <= h*1      ;row 1
  if x <= w*1       ;col 1

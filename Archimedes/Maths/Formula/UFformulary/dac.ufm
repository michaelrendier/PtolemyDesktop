  row26 = y > 25*b+@borderH/2 && y <= 26*b-@borderH/2
  row27 = y > 26*b+@borderH/2 && y <= 27*b-@borderH/2
  row28 = y > 27*b+@borderH/2 && y <= 28*b-@borderH/2
  row29 = y > 28*b+@borderH/2 && y <= 29*b-@borderH/2
  row30 = y > 29*b+@borderH/2 && y <= 30*b-@borderH/2
  row31 = y > 30*b+@borderH/2 && y <= 31*b-@borderH/2
  row32 = y > 31*b+@borderH/2 && y <= 32*b-@borderH/2
  col1 = x <= a-@borderV/2
  col2 = x > a+@borderV/2 && x <= 2*a-@borderV/2
  col3 = x > 2*a+@borderV/2 && x <= 3*a-@borderV/2
  col4 = x > 3*a+@borderV/2 && x <= 4*a-@borderV/2
  col5 = x > 4*a+@borderV/2 && x <= 5*a-@borderV/2
  col6 = x > 5*a+@borderV/2 && x <= 6*a-@borderV/2
  col7 = x > 6*a+@borderV/2 && x <= 7*a-@borderV/2
  col8 = x > 7*a+@borderV/2 && x <= 8*a-@borderV/2
  col9 = x > 8*a+@borderV/2 && x <= 9*a-@borderV/2

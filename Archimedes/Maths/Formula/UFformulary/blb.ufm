    caption = "Bailout value"
    default = 10
    min = .001  
  endparam
  func CFunc
    caption = "C Function"
    default = ident()
  endfunc
  func LoopFuncX
    caption = "Real Loop Function"
    default = ident()
  endfunc
  func LoopFuncY
    caption = "Imag Loop Function"
    default = ident()
  endfunc

switch:
  type = "UF-OK-43"
  ThisMode = NextMode
  NextMode = ThisMode
  seed = #pixel

UF-OK-37 {
;
; Another dissected Mandelbrot
; See blb.txt for comments.
; 18 April 2003
;
init:
  if @ThisMode == "Mandelbrot"
    z = #pixel
    c = @Func1(@Func2(#Pixel))
  else ;Julia
    z = #pixel
    c = @Func1(@Func2(@seed))
  endif

  complex cr = real(c)
  complex ci = imag(c)

  complex zr = (0,0)
  complex zi = (0,0)
  complex x = (0,0)
  complex y = (0,0)

  float k = 2 + @Fudge

loop:
  zr = @Func3(real(z))
  zi = @Func4(imag(z))
  x = zr^2 - zi^2 + cr
  y = k*zr*zi + ci
  z = x + flip(y)

bailout:
  |z| <= @bailout


UF-OK-09 {
;
; See blb.txt for comments.
; 18 April 2003
;
init:
  if @ThisMode == "Mandelbrot"
    z = c = #pixel
  else ;Julia
    z = #pixel
    c = @seed
  endif

  complex d = @InitFunc(c)
  complex k = @Fudge + 1

loop:
  z = @LoopFunc(d / (z^c * k))

bailout:   
  |z| <= @bailout

default:

UF-OK-38 {

;
; Dissected Cubic Mandelbrot
; See blb.txt for comments.
; 18 April 2003
;
init:
  if @ThisMode == "Mandelbrot"
    z = c = #pixel
  else ;Julia
    z = #pixel
    c = @seed
  endif

  complex zr = (0,0)
  complex zi = (0,0)
  complex cr = @CFuncR(real(c))
  complex ci = @CFuncI(imag(c))
  float k = 3 + @Fudge
  complex x = (0,0)
  complex y = (0,0)

loop:
  zr = real(z)
  zi = imag(z)
  x = @LoopFuncX(zr^3 - k*zr*zi^2) + cr
  y = @LoopFuncY(k*zr^2*zi - zi^3) + ci
  z = x + flip(y)

bailout:   
  |z| <= @bailout


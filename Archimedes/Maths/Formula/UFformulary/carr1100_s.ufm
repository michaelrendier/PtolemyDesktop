; SOURCE: 24Carr.frm

init:
  z = (sqrt((1.099,0)+pixel)/(1.099,0))/@scale
  c = sqr(pixel)/sqr(1/(1.099,0))
  
loop:
  z = Fn1(fn2(fn3(pixel-(c-z*(1.099,0)))))
  z = (1.099,0)-(c-z*pixel)


Carr1109S {
; A "Modified Carr" formula, based on the original with permission.
; Functionality added by Sharon S. Schultz, May, 2003.
; Converted for UF by Erik Reckase, February 22, 2000
; SOURCE: 24Carr.frm

init:
  z = ((1/pixel)/(1.099,0))/@scale
  c = pixel/(1.099,0)
  
loop:
  z = fn1(fn2(fn3((z*z/(sinh(z)))*1/c)))
  
bailout:
  |z| <= @bailout

default:
title = "Carr-1109S"
method = multipass
periodicity = 0


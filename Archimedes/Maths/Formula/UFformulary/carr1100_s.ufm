Carr1111S {
; Converted for UF by Erik Reckase, February 22, 2000
; SOURCE: 24Carr.frm
; Functionality added by Sharon S. Schultz, May, 2003

init:
  z = (1/pixel*0.91/pixel)/@scale
  c = cabs(1/pixel)/cotanh(1.099)
  
loop:
  z = fn1(fn2(fn3((sqr(conj(z*1/c))+(pixel)))))

bailout:
  |real(z)| <= @bailout
  

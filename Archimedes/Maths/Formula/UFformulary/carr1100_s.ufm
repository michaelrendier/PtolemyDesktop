Carr1106S {
; A "Modified Carr" formula, based on the original with permission.
; Functionality added by Sharon S. Schultz, May, 2003.
; Converted for UF by Erik Reckase, February 22, 2000
; SOURCE: 24Carr.frm

init:
  z = (sinh((2.5/pixel)/(1.095,0)))/@scale
  c = conj(cos((2.5/pixel)/(1.095,0)))
  
loop:
  z = fn1(fn2(fn3(z*z+c)))
  z = (pixel-(z*1/c-1/pixel))/(pixel-c*c)

bailout:
  |real(z)| <= @bailout
  

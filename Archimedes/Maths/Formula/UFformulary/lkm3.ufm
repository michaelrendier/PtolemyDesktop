      fun2type=9
    elseif(@fn2=="Newton J 2")
      fun2type=10
    elseif(@fn2=="Popcorn C 2")
      fun2type=11
    elseif(@fn2=="Popcorn R 2")
      fun2type=12
    endif
    if(@fn3=="Mandelbrot 1")
      fun3type=1
    elseif(@fn3=="Julia 1")
      fun3type=2
    elseif(@fn3=="Newton M 1")
      fun3type=3
    elseif(@fn3=="Newton J 1")
      fun3type=4
    elseif(@fn3=="Popcorn C 1")
      fun3type=5
    elseif(@fn3=="Popcorn R 1")
      fun3type=6
    elseif(@fn3=="Mandelbrot 2")
      fun3type=7
    elseif(@fn3=="Julia 2")

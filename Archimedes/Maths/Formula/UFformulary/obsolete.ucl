        fi = (i*4/#width-2)/@fmag+real(fcenter)
        while j < #height
          fj = asp*(j*4/#height - 2)/@fmag + imag(fcenter)
          fij = fj + flip(fi)
          while k < @miter
            phx = fij*fij + real(@phseed) + imag(@phseed)*phy
            phy = fij
            fij = phx
            if |fij| > @bailout
              k = @miter
            endif

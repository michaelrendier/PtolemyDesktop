                endif
              endif
              if closest >mxi
                mxi = closest
              endif
            endif
          else
            frac[i,j] = 0
          endif
          j = j + 1
          k = 0
          expiter = 0
          closest = 1e318
        endwhile
        i = i + 1
        j = 0
      endwhile
    elseif @fctltype == "Cayley Julia"
      closest = 1e318
      fcenter = @fccenter
      while i < #width
        fi = (i*4/#width-2)/@fmag+real(fcenter)
        while j < #height
          fj = asp*(j*4/#height - 2)/@fmag + imag(fcenter)
          fij = fi + flip(fj)

            oldf = fij
            fz = fij^3 - @cseed*fij - @cseed + 1
            fzp = 3*fij^2 - @cseed
            fij = fij - fz/fzp
            btest = (cabs(oldf-fij) < isnear)
            if !(|fij - oldf| >= 1/@bailout)
               k = @miter
            endif
            k = k + 1

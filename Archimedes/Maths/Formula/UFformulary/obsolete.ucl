                trap = cabs(fij) - cabs(rr*(theta-sin(theta)) - flip(rr*(1-cos(theta))))
              elseif @traptype == "Archimedes"
                theta = atan(imag(fij)/real(fij))
                rr = @pa*theta
                trap = cabs(fij) -cabs(rr*cos(theta) + flip(rr*sin(theta)))

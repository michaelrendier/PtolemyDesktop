drandom1 {
; Version 2.0 5-25-04 Added multiplier and c, also
; added func1 to c for greater flexibility
; Seed function does not show unless p3 <> 0.
; Randomly Generated Fractal Formula
; Try Function 1 = exp and 2 = atan
; Parameter 1 (Re) = 1,Parameter 1 (Im) = 1 
; Parameter 2 (Re) = 0,Parameter 2 (Im) = 1.1
; Parameter 4 (Re) = 1.1,Parameter 4 (Im) = 0 
; fn1 = recip, fn2 = trunc, p1 = 0.1,6  p2 = 0.2,0  p4 = 2,0.7
 
  init:

  z = #pixel
  c = @seed
  
  loop:
  
  If @version < 3.0
    z = (1 * 3 - (p4 )^ ((fn1 ( 3 * z * p2 )- ((fn2 ( 4 ^ \
    (fn1 ( 3 - (3 - (z / p1 )+ #random ))))))))) + (p3)*fn1(c)

  else

  float x = Real(z)
  float y = Imag(z)
  float g = real(@seed)

    z = (1 * 3 - (p4 )^ ((fn1 ( 3 * z * p2 )- ((fn2 ( 4 ^ \
    (fn1 ( 3 - (3 - (z / p1 )+ #random ))))))))) + (p3)*fn1(c)

  if @style == "z"
    z = fn3((z-p5)*p6)
  elseif @style == "fn(z^(2+power))"
    z = fn3((z-p5)*p6)^@fn4(2+ @p7) + fn4(c)
  elseif @style == "fn(x-y)"
    z = fn3((z-p5)*p6)^@fn4(2+ @p7) + fn3(x-y) + fn4(c)
  elseif @style == "(fn(y-x))"
    z = fn3((z-p5)*p6)^@fn4(2+ @p7+ fn3(y-x)) + fn4(c)
  elseif @style =="(fn(x^2-y^2))"
    z = fn3((z-p5)*p6)^@fn4(2+ @p7+ fn3(y^2-x^2)) + fn4(c)
  elseif @style =="fn(x^2-y^2)"
    z = fn3((z-p5)*p6)^@fn4(2+ @p7)+ fn3(y^2-x^2) + fn4(c)
  elseif @style =="fn(x^e)"
    z = fn3(x)^@fn4(e) + fn4(c)
  elseif @style =="fn(y^e)"
    z = fn3(y)^@fn4(e) + fn4(c)
  elseif @style =="fn(x^pi)"
    z = fn3(x)^@fn4(#pi)+fn4(c)
  elseif @style =="fn(y^pi)"
    z = fn3(y)^@fn4(#pi) +fn4(c)
  elseif @style =="fn(z-x)^fn(z-y)"
    z = fn3(z-x)^@fn4(z-y)+fn4(c)
  elseif @style =="fn(z+x)^fn(z+y)"
    z = fn3(z+x)^@fn4(z+y)+fn4(c)
  endif  

  if @ztweaker == "z=orig"
    z = fn3(z)
  elseif @ztweaker == "z=z+c"
    z = fn3(z) + fn4(c)
  elseif @ztweaker == "z=z+x"
    z = fn3(z) + fn4(x)
  elseif @ztweaker == "z=z+y"
    z = fn3(z) + fn4(y)
  elseif @ztweaker == "z=z+g"
    z = fn3(z) + fn4(g)
  elseif @ztweaker == "z=z*c"
    z = fn3(z) * fn4(c)
  elseif @ztweaker == "z=z*x"
    z = fn3(z) * fn4(x)
  elseif @ztweaker == "z=z*y"
    z = fn3(z) * fn4(y)  
  elseif @ztweaker == "z=z*g"
    z = fn3(z) * fn4(g)
  elseif @ztweaker == "z=z/c"
    z = fn3(z) / fn4(c) 
  elseif @ztweaker == "z=z/x"
    z = fn3(z) / fn4(x)
  elseif @ztweaker == "z=z/g"
    z = fn3(z) / fn4(g) 
  elseif @ztweaker == "z=z/c+z"
    z = fn3(z) / fn4(c) + fn4(z)
  elseif @ztweaker == "z=z/x+z"
    z = fn3(z) / fn4(x) + fn4(z)
  elseif @ztweaker == "z=z/c+c"
    z = fn3(z) / fn4(c) + fn4(c)
  elseif @ztweaker == "z=z/x+c"
    z = fn3(z) / fn4(x) + fn4(c)
  elseif @ztweaker == "z=z/g+c"
    z = fn3(z) / fn4(g) + fn4(c)
  elseif @ztweaker == "z=z-c"
    z = fn3(z) - fn4(c)
  elseif @ztweaker == "z=z-x"
    z = fn3(z) - fn4(x)
  elseif @ztweaker == "z=z-g"
    z = fn3(z) - fn4(g)
  elseif @ztweaker == "z=c-z"
    z = fn3(c) - fn4(z) 
  elseif @ztweaker == "z=x-z"
    z = fn3(x) - fn4(z)
  elseif @ztweaker == "z=g-z"
    z = fn3(g) - fn4(z) 
  elseif @ztweaker == "z=z/c-z"
    z = fn3(z) / fn4(c) - fn4(z)
  elseif @ztweaker == "z=z/x-z"
    z = fn3(z) / fn4(x) - fn4(z)
  elseif @ztweaker == "z=z/g-z"
    z = fn3(z) / fn4(g) - fn4(z)
  elseif @ztweaker == "z=z/c-c"
    z = fn3(z) / fn4(c) - fn4(c)
  elseif @ztweaker == "z=z/x-c"
    z = fn3(z) / fn4(x) - fn4(c)
  elseif @ztweaker == "z=z/g-c"
    z = fn3(z) / fn4(g) - fn4(c)  
  elseif @ztweaker == "z=z-z/c"
    z = fn3(z) - fn4(z) / fn4(c) 
  elseif @ztweaker == "z=z-z/x"
    z = fn3(z) - fn4(z) / fn4(x) 
  elseif @ztweaker == "z=z-z/g"
    z = fn3(z) - fn4(z) / fn4(g)
  elseif @ztweaker == "z=c-z/c"
    z = fn3(c) - fn4(z) / fn4(c) 
  elseif @ztweaker == "z=c-z/g"
    z = fn3(c) - fn4(z) / fn4(g) 
  elseif @ztweaker == "z=c-z/x"
    z = fn3(c) - fn4(z) / fn4(x) 
  elseif @ztweaker == "z=c/z"
    z = fn3(c) / fn4(z)   
  elseif @ztweaker == "z=x/z"
    z = fn3(x) / fn4(z)   
  elseif @ztweaker == "z*z+c"
    z = fn3(z) * fn4(z) + fn4(c)
  elseif @ztweaker == "z*c+z"
    z = fn3(z) * fn4(c) + fn4(z)
  elseif @ztweaker == "z=g/z"
    z = fn3(g) / fn4(z) 
  elseif @ztweaker == "ezz"
    z = e^fn3(z)* fn4(z)  
  elseif @ztweaker == "ez/z"
    z = e^fn3(z)/ fn4(z)   
  elseif @ztweaker == "ex/z"
    z = e^fn3(x)/ fn4(z)
  elseif @ztweaker == "exz"
    z = e^fn3(x)* fn4(z)  
  elseif @ztweaker == "ey/z"
    z = e^fn3(y)/ fn4(z)
  elseif @ztweaker == "eyz"
    z = e^fn3(y)* fn4(z)    
  elseif @ztweaker == "z/1-z"
    z = fn3(z)/(1- fn4(z))
  elseif @ztweaker == "z/1-x"
    z = fn3(z)/(1-fn4(x)) 
  elseif @ztweaker == "z/1-y"
    z = fn3(z)/(1-fn4(y))  
  elseif @ztweaker == "zpi"
    z = fn3(z) ^ #pi  
  elseif @ztweaker == "zpi/z"
    z = fn3(z) ^ #pi / fn4(z)^2   
  elseif @ztweaker == "z^pi/z^z"
    z = fn3(z) ^ #pi / fn4(z^z)  
  elseif @ztweaker == "z/pixel"
    z = fn4(fn3(z) / #pixel)
  elseif @ztweaker == "zpixel"
    z = fn4(fn3(z) * #pixel)  
  elseif @ztweaker == "z^pixel/z+pixel"
    z = fn3(z) ^ #pixel /fn4(z) + pixel  
  elseif @ztweaker == "ez/zpixel"
    z = e^fn3(z) /(fn4(z)+ #pixel) 
  elseif @ztweaker == "ez/pixel"
    z = fn4(e^fn3(z) /#pixel)
  elseif @ztweaker == "piz/pixel"
    z = fn4(fn3(z)^#pi / #pixel)  
  elseif @ztweaker == "piz/zpixel"
    z = fn3(z)^#pi /(fn4(z) + #pixel)  
  elseif @ztweaker == "z+zpixel"
    z = fn4(fn3(z) + #pixel)   
  elseif @ztweaker == "z-zpixel"
    z = fn4(fn3(z) - #pixel) 
  elseif @ztweaker == "z/zpixel"
    z = fn3(z) /(fn4(z) + #pixel)
  elseif @ztweaker == "z/pixelz"
    z = fn3(z) /#pixel^fn4(z)
  elseif @ztweaker == "ez/pixel"
    z = fn4(e^fn3(z)/#pixel)
  elseif @ztweaker == "c/ez"
    z  = fn3(c / (#e * fn4(z)))
  elseif @ztweaker == "z+c/g"
    z  = fn3(fn4(z) + c / g )
  elseif @ztweaker == "x+z/y+c"
    z  = (fn3(x) + z) / (fn4(y) + c)
  elseif @ztweaker == "g^z-c"
    z  = fn4(g ^ (fn3(z) )) - c
  elseif @ztweaker == "z-x+y/x-y"
    z  = fn3(z) - p2 + fn4((x+y)/(x-y))
  elseif @ztweaker == "g/c-z"
    z  = fn3(( g )/ (c - fn4(z)))
  elseif @ztweaker == "y+c/g"
    z  = fn3(fn4(y) + c / g )
  elseif @ztweaker == "x+y/y+c"
    z  = (fn3(x) + y) / (fn4(y) + c)
  elseif @ztweaker == "g^y-c"
    z  = fn4(g ^ (fn3(y) )) - c
  elseif @ztweaker == "y-x+y/x-y"
    z  = fn3(y) - p2 + fn4((x+y)/(x-y))
  elseif @ztweaker == "g/c-y"
    z  = fn3(( g )/ (c - fn4(y)))
  elseif @ztweaker == "c/ex"
    z  = fn3(c / (#e * fn4(x)))
  elseif @ztweaker == "x+c/g"
    z  = fn3(fn4(x) + c / g )
  elseif @ztweaker == "g^x-c"
    z  = fn4(g ^(fn3(x))) - c
  endif 
  
    if @inv == true
    z = 1/z
  else
    z = z
  endif
  
  if @zpix == true
    z = ((pixel-p5)*p6)^(2+ @p7)  
  else
    z = z
  endif
  
  if @xplus == true
     z = ((z-p5)*p6)^(2+ @p7) + x
  else
    z = z
  endif

  if @yplus == true
    z = ((z-p5)*p6)^(2+ @p7) + y
  else
    z = z
  endif

  if @zpower == true
    z = ((z-p5)*p6)^(2+ @p7) ^ z
  else
    z = z
  endif

  if @xpower == true
    z = ((z-p5)*p6)^(2+ @p7)^x
  else
    z = z
  endif

  if @ypower == true
    z = ((z-p5)*p6)^(2+ @p7)^y
  else
    z = z
  endif

  if @gpower == true ; hpower showed no effect
    z = ((z-p5)*p6)^(2+ @p7)^g
  else
    z = z
  endif
  
  if @gplus == true ; hplus showed no effect
    z = ((z-p5)*p6)^(2+ @p7) + g
  else
    z = z
  endif

  if @func1 == true
    z = fn3((z-p5)*p6)
  else
    z = z
  endif
 
  if @func2 == true
    z = @fn4(fn3((z-p5)*p6))
  else
    z = z
  endif

  if @func3 == true
    z = @fn2(@fn4(fn3((z-p5)*p6)))
  else
    z = z
  endif

  if @funcpowerz == true
    z = ((z-p5)*p6)^fn3(z)
  else
    z = z
  endif

  if @funcpowerx == true
    z = ((z-p5)*p6)^fn3(x)
  else
    z = z
  endif

  if @funcpowery == true
    z = ((z-p5)*p6)^fn3(y)
  else
    z = z
  endif

  if @funcpowerg == true ; funcpowerh no effect
    z = ((z-p5)*p6)^fn3(g)
  else
    z = z
  endif
  
  if @ez == true 
    z = e^z
  else
    z = z
  endif

  if @zpi == true 
    z = z^#pi
  else
    z = z
  endif
  
  if @ztopidivzpi == true 
    z = z^#pi/(z*#pi)
  else
    z = z
  endif

  if @zpidivztopi == true 
    z = z*#pi/(z^#pi)
  else
    z = z
  endif

  if @flavor == "z"
    z = fn3((z-p5)*p6)
  elseif @flavor == "z^2 + c"
    z = fn3((z-p5)*p6)^@fn4(2+ @p7) + @fn4(c)
  elseif @flavor == "z^(z/c)"
    z = fn3((z-p5)*p6)^@fn4((z-p5)*p6) + @fn4(@p7/c)
  elseif @flavor == "z/(z-1)"
    z = fn3((z-p5)*p6)/@fn4(((z-p5)*p6) -1) + @fn4(@p7*c)
  elseif @flavor == "z^2/(z-1)"
    z = fn3((z-p5)*p6)^(2+ @p7)/@fn4(((z-p5)*p6) -1) + @fn4(@p7*c)
  elseif @flavor == "z^3/(z^2-1)"
    z = fn3((z-p5)*p6)^(3+ @p7)/@fn4(((z-p5)*p6)^(2+ @p7) -1)\
     +@fn4(@p7*c)
  elseif @flavor == "z^3*c/(z^2-c)"
    z = fn3((z-p5)*p6)^(3+ @p7)*c/@fn4(((z-p5)*p6)^(2+@p7) - c)\
     - @fn4(@p7*c) 
  elseif @flavor == "z^3+z^2+z+c"
    z = fn3((z-p5)*p6)^(3+ @p7)+((z-p5)*p6)^(2+ @p7)+@fn4((z-p5)*p6)\
    ^(2+ @p7)+ @fn4(@p7*c) 
  elseif @flavor == "fnzfnzfnz"
    z = fn3((z-p5)*p6)*@fn4((z-p5)*p6)*@fn4((z-p5)*p6) + @p7*c  
  elseif @flavor == "fnzpfnzpfnzp"
    z = fn3((z-p5)*p6)^(2+ @p7)*@fn4((z-p5)*p6)^(2+ @p7)*@fn4((z-p5)\
    ^(2+ @p7)*p6) + @p7*c
  elseif @flavor == "fnzfnz/fnz"
    z = fn3((z-p5)*p6)*@fn4((z-p5)*p6)/@fn4((z-p5)*p6) + @p7*c  
  elseif @flavor == "fnzpfnzp/fnzp"
    z = fn3((z-p5)*p6)^(2+ @p7)*@fn4((z-p5)*p6)^(2+ @p7)/@fn4((z-p5)\
    ^(2+ @p7)*p6) + @p7*c
   elseif @flavor == "zzz"
    z = fn3((z-p5)*p6)*@fn4((z-p5)*p6)*@fn4((z-p5)*p6) + @p7*c  
  elseif @flavor == "z^pz^pz^p"
    z = fn3((z-p5)*p6)^(2+ @p7)*@fn4((z-p5)*p6)^(2+ @p7)*@fn4((z-p5)\
    ^(2+ @p7)*p6) + @p7*c
  elseif @flavor == "zz/z"
    z = fn3((z-p5)*p6)*@fn4((z-p5)*p6)/@fn4(z-p5)+ @p7*c
  elseif @flavor == "z^pz^p/z^p"
    z = fn3((z-p5)*p6)^(2+ @p7)*@fn4((z-p5)*p6)^(2+ @p7)/@fn4((z-p5)\
    ^(2+ @p7)*p6) + @p7*c
  elseif @flavor == "z^3-z^2+c"
    z = fn3((z-p5)*p6)^(3+ @p7)-@fn4((z-p5)*p6)^(2+ @p7)+ @fn4(@p7*c) 
  endif
  endif
  
  bailout:
 
   |z| <= @bailout
  
  default:
  title = "drandom1 "
  periodicity = 0
  
  complex param p1
   caption = "Param 1"
   default = (0.1,6)
  endparam

  complex param p2
   caption = "Param 2"
   default = (0.2,0)
  endparam

  param p3
    caption = "C Multiplier"
    default = 0
  endparam  

  complex param p4
   caption = "Param 4"
   default = (2,0)
  endparam
  
  param p5
    caption = "Subtracter"
    default = (0,0)
  endparam

  param p6
    caption = "Mulitplier"
    default = (1,0)
  endparam    

  param p7
    caption = "Power"
    default = (0,0)
  endparam   

  param seed
    caption = "Seed"
    default = (-1.25,0)
    visible = @p3 < 0  || @p3 > 0
  endparam
  
   heading
    caption = "Affecters of Z"
  endheading

  bool param inv
    caption = "Invert Z"
    default = false
  endparam  

  bool param zpix
    caption = "Z=Pixel"
    default = false
  endparam  

  bool param xplus
    caption = "Add X"
    default = false
  endparam 

  bool param yplus
    caption = "Add Y"
    default = false
  endparam 

  bool param Zpower
    caption = "Z^Z"
    default = false
  endparam 

  bool param Xpower
    caption = "Z^X"
    default = false
  endparam 

  bool param Ypower
    caption = "Z^Y"
    default = false
  endparam 

  bool param Gpower
    caption = "Z^G"
    default = false
  endparam 

  bool param Gplus
    caption = "Z+G"
    default = false
  endparam 

  bool param func1
    caption = "Fn(Z)"
    default = false
  endparam 

  bool param func2
    caption = "@fn4(fn3(Z))"
    default = false
  endparam 
  
  bool param func3
    caption = "@fn4(@fn4(fn3(Z)))"
    default = false
  endparam 
  
  bool param funcpowerz
    caption = "Function Power"
    default = false
  endparam  

  bool param funcpowerx
    caption = "Function Power of X"
    default = false
  endparam 

  bool param funcpowery
    caption = "Function Power of Y"
    default = false
  endparam  

  bool param funcpowerg
    caption = "Function Power of G"
    default = false
  endparam 
  
  bool param ez 
    caption = "Euler times Z"
   default = false
  endparam 

  bool param zpi  
   caption = "Pi times Z"
   default = false
  endparam 

  bool param ztopidivzpi  
   caption = "Z^Pi/Z*Pi"
   default = false
  endparam 
  
  bool param zpidivztopi
   caption = "Z*Pi/Z^Pi"
   default = false
  endparam 
  
  param ztweaker
    caption = "Z Tweaker"
    enum = "z=orig""z=z+c""z=z+x""z=z+y""z=z+g"\
    "z=z*c""z=z*x""z=z*y""z=z*g""z=z/c""z=z/x""z=z/g"\
    "z=z/c+z""z=z/x+z""z=z/c+c""z=z/x+c"\
    "z=z/g+c""z=z-c""z=z-x""z=z-g""z=c-z""z=x-z"\
    "z=g-z""z=z/c-z""z=z/x-z""z=z/g-z""z=z/c-c""z=z/x-c"\
    "z=z/g-c""z=z-z/c""z=z-z/x""z=z-z/g""z=c-z/c"\
    "z=c-z/x""z=c-z/g""z=c/z""z=x/z""z=g/z""z*z+c""z*c+z"\
    "ezz""ez/z""exz""ex/z""eyz""ey/z""z/1-z""z/1-x""z/1-y"\
    "zpi""zpi/z""z^pi/z^z""zpixel""z/pixelz"\
    "z/zpixel""z^pixel/z+pixel""ez/zpixel""z/pixel""piz/pixel"\
    "piz/zpixel""z-zpixel""ez/pixel""z+zpixel"\
    "c/ez""z+c/g""x+z/y+c""g^z-c""z-x+y/x-y""g/c-z"\
    "y+c/g""x+y/y+c""g^y-c""y-x+y/x-y""g/c-y"\    
    "g/c-x""g^x-c""x+c/g""c/ex"
    default = 0
  endparam
  
  param style
    caption = "Variation in Style"
    enum = "z""fn(z^(2+power))""fn(x-y)""fn(y-x)"\
    "fn(x^2-y^2)""(fn(y-x))" "(fn(x^2-y^2))"\
    "fn(x^e)""fn(y^e)""fn(x^pi)""fn(y^pi)"\
    "fn(z-x)^fn(z-y)""fn(z+x)^fn(z+y)"   
    default = 0
  endparam 

  param flavor
    caption = "Formula Flavor"
    enum = "z""z^2 + c""z^(z/c)""z/(z-1)""z^2/(z-1)""z^3/(z^2-1)"\
    "z^3*c/(z^2-c)""z^3+z^2+z+c""fnzfnzfnz""fnzpfnzpfnzp"\
    "fnzfnz/fnz""fnzpfnzp/fnzp""zzz""z^pz^pz^p"\
    "zz/z""z^pz^p/z^p""z^3-z^2+c"
    default = 0
  endparam
  
  func fn1
    caption = "Function 1"
    default = recip()
  endfunc

  func fn2
    caption = "Function 2"
    default = trunc()
  endfunc

  func fn3
    caption = "Function(3) of Z"
    default = ident()
    visible = @ztweaker != "z=orig"
  endfunc

  func fn4
    caption = "Functions(4) of z"
    default = ident()
    visible = @ztweaker != "z=orig"
  endfunc

  float param bailout
    caption = "Bail-out value"
    hint = "This is the bail-out value"
    default = 8.9999999999999
  endparam
  
  param version
    caption = "Version"
    default = 3.0
  endparam

} 
==========================================================
 
drandom2 {
; A Randomly Generated Fractal Formula
; Version 3.0 Added tweakers etc. 6-5-04
; Version 2.0 5-25-04 Added multiplier and c, also
; added func1 to p3 and fn2 to c fro greater flexibility
; Seed function does not show unless p3 <> 0.

  init:
  
    z = #pixel
    c = @seed
      
  loop:

 If @version < 3.0 
 
   z = z ^ z + fn1 ( p3 / (z ^ fn2 ( 3 + (z - p5 )+ \
   (p6 )+ p4 )+ 3 ^ 4 )) + fn1(p2) * fn2(c)

 else

  float x = Real(z)
  float y = Imag(z)
  float g = real(@seed) 

   z = z ^ z + fn1 ( p3 / (z ^ fn2 ( 3 + (z - p5 )+ \
   (p6 )+ p4 )+ 3 ^ 4 )) + fn1(p2) * fn2(c)

  if @style == "z"
    z = fn3((z-p5)*p6)
  elseif @style == "fn(z^(2+power))"
    z = fn3((z-p5)*p6)^@fn4(2+ @p7) + fn4(c)
  elseif @style == "fn(x-y)"
    z = fn3((z-p5)*p6)^@fn4(2+ @p7) + fn3(x-y) + fn4(c)
  elseif @style == "(fn(y-x))"
    z = fn3((z-p5)*p6)^@fn4(2+ @p7+ fn3(y-x)) + fn4(c)
  elseif @style =="(fn(x^2-y^2))"
    z = fn3((z-p5)*p6)^@fn4(2+ @p7+ fn3(y^2-x^2)) + fn4(c)
  elseif @style =="fn(x^2-y^2)"
    z = fn3((z-p5)*p6)^@fn4(2+ @p7)+ fn3(y^2-x^2) + fn4(c)
  elseif @style =="fn(x^e)"
    z = fn3(x)^@fn4(e) + fn4(c)
  elseif @style =="fn(y^e)"
    z = fn3(y)^@fn4(e) + fn4(c)
  elseif @style =="fn(x^pi)"
    z = fn3(x)^@fn4(#pi)+fn4(c)
  elseif @style =="fn(y^pi)"
    z = fn3(y)^@fn4(#pi) +fn4(c)
  elseif @style =="fn(z-x)^fn(z-y)"
    z = fn3(z-x)^@fn4(z-y)+fn4(c)
  elseif @style =="fn(z+x)^fn(z+y)"
    z = fn3(z+x)^@fn4(z+y)+fn4(c)
  endif  

  if @ztweaker == "z=orig"
    z = fn3(z)
  elseif @ztweaker == "z=z+c"
    z = fn3(z) + fn4(c)
  elseif @ztweaker == "z=z+x"
    z = fn3(z) + fn4(x)
  elseif @ztweaker == "z=z+y"
    z = fn3(z) + fn4(y)
  elseif @ztweaker == "z=z+g"
    z = fn3(z) + fn4(g)
  elseif @ztweaker == "z=z*c"
    z = fn3(z) * fn4(c)
  elseif @ztweaker == "z=z*x"
    z = fn3(z) * fn4(x)
  elseif @ztweaker == "z=z*y"
    z = fn3(z) * fn4(y)  
  elseif @ztweaker == "z=z*g"
    z = fn3(z) * fn4(g)
  elseif @ztweaker == "z=z/c"
    z = fn3(z) / fn4(c) 
  elseif @ztweaker == "z=z/x"
    z = fn3(z) / fn4(x)
  elseif @ztweaker == "z=z/g"
    z = fn3(z) / fn4(g) 
  elseif @ztweaker == "z=z/c+z"
    z = fn3(z) / fn4(c) + fn4(z)
  elseif @ztweaker == "z=z/x+z"
    z = fn3(z) / fn4(x) + fn4(z)
  elseif @ztweaker == "z=z/c+c"
    z = fn3(z) / fn4(c) + fn4(c)
  elseif @ztweaker == "z=z/x+c"
    z = fn3(z) / fn4(x) + fn4(c)
  elseif @ztweaker == "z=z/g+c"
    z = fn3(z) / fn4(g) + fn4(c)
  elseif @ztweaker == "z=z-c"
    z = fn3(z) - fn4(c)
  elseif @ztweaker == "z=z-x"
    z = fn3(z) - fn4(x)
  elseif @ztweaker == "z=z-g"
    z = fn3(z) - fn4(g)
  elseif @ztweaker == "z=c-z"
    z = fn3(c) - fn4(z) 
  elseif @ztweaker == "z=x-z"
    z = fn3(x) - fn4(z)
  elseif @ztweaker == "z=g-z"
    z = fn3(g) - fn4(z) 
  elseif @ztweaker == "z=z/c-z"
    z = fn3(z) / fn4(c) - fn4(z)
  elseif @ztweaker == "z=z/x-z"
    z = fn3(z) / fn4(x) - fn4(z)
  elseif @ztweaker == "z=z/g-z"
    z = fn3(z) / fn4(g) - fn4(z)
  elseif @ztweaker == "z=z/c-c"
    z = fn3(z) / fn4(c) - fn4(c)
  elseif @ztweaker == "z=z/x-c"
    z = fn3(z) / fn4(x) - fn4(c)
  elseif @ztweaker == "z=z/g-c"
    z = fn3(z) / fn4(g) - fn4(c)  
  elseif @ztweaker == "z=z-z/c"
    z = fn3(z) - fn4(z) / fn4(c) 
  elseif @ztweaker == "z=z-z/x"
    z = fn3(z) - fn4(z) / fn4(x) 
  elseif @ztweaker == "z=z-z/g"
    z = fn3(z) - fn4(z) / fn4(g)
  elseif @ztweaker == "z=c-z/c"
    z = fn3(c) - fn4(z) / fn4(c) 
  elseif @ztweaker == "z=c-z/g"
    z = fn3(c) - fn4(z) / fn4(g) 
  elseif @ztweaker == "z=c-z/x"
    z = fn3(c) - fn4(z) / fn4(x) 
  elseif @ztweaker == "z=c/z"
    z = fn3(c) / fn4(z)   
  elseif @ztweaker == "z=x/z"
    z = fn3(x) / fn4(z)   
  elseif @ztweaker == "z*z+c"
    z = fn3(z) * fn4(z) + fn4(c)
  elseif @ztweaker == "z*c+z"
    z = fn3(z) * fn4(c) + fn4(z)
  elseif @ztweaker == "z=g/z"
    z = fn3(g) / fn4(z) 
  elseif @ztweaker == "ezz"
    z = e^fn3(z)* fn4(z)  
  elseif @ztweaker == "ez/z"
    z = e^fn3(z)/ fn4(z)   
  elseif @ztweaker == "ex/z"
    z = e^fn3(x)/ fn4(z)
  elseif @ztweaker == "exz"
    z = e^fn3(x)* fn4(z)  
  elseif @ztweaker == "ey/z"
    z = e^fn3(y)/ fn4(z)
  elseif @ztweaker == "eyz"
    z = e^fn3(y)* fn4(z)    
  elseif @ztweaker == "z/1-z"
    z = fn3(z)/(1- fn4(z))
  elseif @ztweaker == "z/1-x"
    z = fn3(z)/(1-fn4(x)) 
  elseif @ztweaker == "z/1-y"
    z = fn3(z)/(1-fn4(y))  
  elseif @ztweaker == "zpi"
    z = fn3(z) ^ #pi  
  elseif @ztweaker == "zpi/z"
    z = fn3(z) ^ #pi / fn4(z)^2   
  elseif @ztweaker == "z^pi/z^z"
    z = fn3(z) ^ #pi / fn4(z^z)  
  elseif @ztweaker == "z/pixel"
    z = fn4(fn3(z) / #pixel)
  elseif @ztweaker == "zpixel"
    z = fn4(fn3(z) * #pixel)  
  elseif @ztweaker == "z^pixel/z+pixel"
    z = fn3(z) ^ #pixel /fn4(z) + pixel  
  elseif @ztweaker == "ez/zpixel"
    z = e^fn3(z) /(fn4(z)+ #pixel) 
  elseif @ztweaker == "ez/pixel"
    z = fn4(e^fn3(z) /#pixel)
  elseif @ztweaker == "piz/pixel"
    z = fn4(fn3(z)^#pi / #pixel)  
  elseif @ztweaker == "piz/zpixel"
    z = fn3(z)^#pi /(fn4(z) + #pixel)  
  elseif @ztweaker == "z+zpixel"
    z = fn4(fn3(z) + #pixel)   
  elseif @ztweaker == "z-zpixel"
    z = fn4(fn3(z) - #pixel) 
  elseif @ztweaker == "z/zpixel"
    z = fn3(z) /(fn4(z) + #pixel)
  elseif @ztweaker == "z/pixelz"
    z = fn3(z) /#pixel^fn4(z)
  elseif @ztweaker == "ez/pixel"
    z = fn4(e^fn3(z)/#pixel)
  elseif @ztweaker == "c/ez"
    z  = fn3(c / (#e * fn4(z)))
  elseif @ztweaker == "z+c/g"
    z  = fn3(fn4(z) + c / g )
  elseif @ztweaker == "x+z/y+c"
    z  = (fn3(x) + z) / (fn4(y) + c)
  elseif @ztweaker == "g^z-c"
    z  = fn4(g ^ (fn3(z) )) - c
  elseif @ztweaker == "z-x+y/x-y"
    z  = fn3(z) - @p8 + fn4((x+y)/(x-y))
  elseif @ztweaker == "g/c-z"
    z  = fn3(( g )/ (c - fn4(z)))
  elseif @ztweaker == "y+c/g"
    z  = fn3(fn4(y) + c / g )
  elseif @ztweaker == "x+y/y+c"
    z  = (fn3(x) + y) / (fn4(y) + c)
  elseif @ztweaker == "g^y-c"
    z  = fn4(g ^ (fn3(y) )) - c
  elseif @ztweaker == "y-x+y/x-y"
    z  = fn3(y) - @p8 + fn4((x+y)/(x-y))
  elseif @ztweaker == "g/c-y"
    z  = fn3(( g )/ (c - fn4(y)))
  elseif @ztweaker == "c/ex"
    z  = fn3(c / (#e * fn4(x)))
  elseif @ztweaker == "x+c/g"
    z  = fn3(fn4(x) + c / g )
  elseif @ztweaker == "g^x-c"
    z  = fn4(g ^(fn3(x))) - c
  endif 
  
    if @inv == true
    z = 1/z
  else
    z = z
  endif
  
  if @zpix == true
    z = ((pixel-p5)*p6)^(2+ @p7)  
  else
    z = z
  endif
  
  if @xplus == true
     z = ((z-p5)*p6)^(2+ @p7) + x
  else
    z = z
  endif

  if @yplus == true
    z = ((z-p5)*p6)^(2+ @p7) + y
  else
    z = z
  endif

  if @zpower == true
    z = ((z-p5)*p6)^(2+ @p7) ^ z
  else
    z = z
  endif

  if @xpower == true
    z = ((z-p5)*p6)^(2+ @p7)^x
  else
    z = z
  endif

  if @ypower == true
    z = ((z-p5)*p6)^(2+ @p7)^y
  else
    z = z
  endif

  if @gpower == true ; hpower showed no effect
    z = ((z-p5)*p6)^(2+ @p7)^g
  else
    z = z
  endif
  
  if @gplus == true ; hplus showed no effect
    z = ((z-p5)*p6)^(2+ @p7) + g
  else
    z = z
  endif

  if @func1 == true
    z = fn3((z-p5)*p6)
  else
    z = z
  endif
 
  if @func2 == true
    z = @fn4(fn3((z-p5)*p6))
  else
    z = z
  endif

  if @func3 == true
    z = @fn2(@fn4(fn3((z-p5)*p6)))
  else
    z = z
  endif

  if @funcpowerz == true
    z = ((z-p5)*p6)^fn3(z)
  else
    z = z
  endif

  if @funcpowerx == true
    z = ((z-p5)*p6)^fn3(x)
  else
    z = z
  endif

  if @funcpowery == true
    z = ((z-p5)*p6)^fn3(y)
  else
    z = z
  endif

  if @funcpowerg == true ; funcpowerh no effect
    z = ((z-p5)*p6)^fn3(g)
  else
    z = z
  endif
  
  if @ez == true 
    z = e^z
  else
    z = z
  endif

  if @zpi == true 
    z = z^#pi
  else
    z = z
  endif
  
  if @ztopidivzpi == true 
    z = z^#pi/(z*#pi)
  else
    z = z
  endif

  if @zpidivztopi == true 
    z = z*#pi/(z^#pi)
  else
    z = z
  endif

  if @flavor == "z"
    z = fn3((z-p5)*p6)
  elseif @flavor == "z^2 + c"
    z = fn3((z-p5)*p6)^@fn4(2+ @p7) + @fn4(c)
  elseif @flavor == "z^(z/c)"
    z = fn3((z-p5)*p6)^@fn4((z-p5)*p6) + @fn4(@p7/c)
  elseif @flavor == "z/(z-1)"
    z = fn3((z-p5)*p6)/@fn4(((z-p5)*p6) -1) + @fn4(@p7*c)
  elseif @flavor == "z^2/(z-1)"
    z = fn3((z-p5)*p6)^(2+ @p7)/@fn4(((z-p5)*p6) -1) + @fn4(@p7*c)
  elseif @flavor == "z^3/(z^2-1)"
    z = fn3((z-p5)*p6)^(3+ @p7)/@fn4(((z-p5)*p6)^(2+ @p7) -1)\
     +@fn4(@p7*c)
  elseif @flavor == "z^3*c/(z^2-c)"
    z = fn3((z-p5)*p6)^(3+ @p7)*c/@fn4(((z-p5)*p6)^(2+@p7) - c)\
     - @fn4(@p7*c) 
  elseif @flavor == "z^3+z^2+z+c"
    z = fn3((z-p5)*p6)^(3+ @p7)+((z-p5)*p6)^(2+ @p7)+@fn4((z-p5)*p6)\
    ^(2+ @p7)+ @fn4(@p7*c) 
  elseif @flavor == "fnzfnzfnz"
    z = fn3((z-p5)*p6)*@fn4((z-p5)*p6)*@fn4((z-p5)*p6) + @p7*c  
  elseif @flavor == "fnzpfnzpfnzp"
    z = fn3((z-p5)*p6)^(2+ @p7)*@fn4((z-p5)*p6)^(2+ @p7)*@fn4((z-p5)\
    ^(2+ @p7)*p6) + @p7*c
  elseif @flavor == "fnzfnz/fnz"
    z = fn3((z-p5)*p6)*@fn4((z-p5)*p6)/@fn4((z-p5)*p6) + @p7*c  
  elseif @flavor == "fnzpfnzp/fnzp"
    z = fn3((z-p5)*p6)^(2+ @p7)*@fn4((z-p5)*p6)^(2+ @p7)/@fn4((z-p5)\
    ^(2+ @p7)*p6) + @p7*c
   elseif @flavor == "zzz"
    z = fn3((z-p5)*p6)*@fn4((z-p5)*p6)*@fn4((z-p5)*p6) + @p7*c  
  elseif @flavor == "z^pz^pz^p"
    z = fn3((z-p5)*p6)^(2+ @p7)*@fn4((z-p5)*p6)^(2+ @p7)*@fn4((z-p5)\
    ^(2+ @p7)*p6) + @p7*c
  elseif @flavor == "zz/z"
    z = fn3((z-p5)*p6)*@fn4((z-p5)*p6)/@fn4(z-p5)+ @p7*c
  elseif @flavor == "z^pz^p/z^p"
    z = fn3((z-p5)*p6)^(2+ @p7)*@fn4((z-p5)*p6)^(2+ @p7)/@fn4((z-p5)\
    ^(2+ @p7)*p6) + @p7*c
  elseif @flavor == "z^3-z^2+c"
    z = fn3((z-p5)*p6)^(3+ @p7)-@fn4((z-p5)*p6)^(2+ @p7)+ @fn4(@p7*c) 
  endif
  endif
  
  bailout:
 
   |z| <= @bailout
  
  default:
  
    title = "drandom2"
    periodicity = 0

  complex param p1
   caption = "Param 1"
   default = (0.1,6)
  endparam

  param p2
     caption = "C Multiplier P2"
     default = 0
  endparam

  complex param p3
     caption = "Param 3"
     default = (4,0)
  endparam

  complex param p4
     caption = "Param 4"
     default = (1,0)
  endparam

  complex param p5
     caption = "Param 5"
     default = (0,0)
  endparam

  complex param p6
     caption = "Param 6"
     default = (1,0)
  endparam
 
  param p7
    caption = "Power P7"
    default = (0,0)
  endparam  
  
  complex param @p8
   caption = "Param "
   default = (1,0)
  endparam  
 
  param seed
    caption = "Seed"
    default = (-1.25,0)
    visible = @p2 < 0  || @p2 > 0
  endparam

   heading
    caption = "Affecters of Z"
  endheading

  bool param inv
    caption = "Invert Z"
    default = false
  endparam  

  bool param zpix
    caption = "Z=Pixel"
    default = false
  endparam  

  bool param xplus
    caption = "Add X"
    default = false
  endparam 

  bool param yplus
    caption = "Add Y"
    default = false
  endparam 

  bool param Zpower
    caption = "Z^Z"
    default = false
  endparam 

  bool param Xpower
    caption = "Z^X"
    default = false
  endparam 

  bool param Ypower
    caption = "Z^Y"
    default = false
  endparam 

  bool param Gpower
    caption = "Z^G"
    default = false
  endparam 

  bool param Gplus
    caption = "Z+G"
    default = false
  endparam 

  bool param func1
    caption = "Fn(Z)"
    default = false
  endparam 

  bool param func2
    caption = "@fn4(fn3(Z))"
    default = false
  endparam 
  
  bool param func3
    caption = "@fn4(@fn4(fn3(Z)))"
    default = false
  endparam 
  
  bool param funcpowerz
    caption = "Function Power"
    default = false
  endparam  

  bool param funcpowerx
    caption = "Function Power of X"
    default = false
  endparam 

  bool param funcpowery
    caption = "Function Power of Y"
    default = false
  endparam  

  bool param funcpowerg
    caption = "Function Power of G"
    default = false
  endparam 
  
  bool param ez 
    caption = "Euler times Z"
   default = false
  endparam 

  bool param zpi  
   caption = "Pi times Z"
   default = false
  endparam 

  bool param ztopidivzpi  
   caption = "Z^Pi/Z*Pi"
   default = false
  endparam 
  
  bool param zpidivztopi
   caption = "Z*Pi/Z^Pi"
   default = false
  endparam 
  
  param ztweaker
    caption = "Z Tweaker"
    enum = "z=orig""z=z+c""z=z+x""z=z+y""z=z+g"\
    "z=z*c""z=z*x""z=z*y""z=z*g""z=z/c""z=z/x""z=z/g"\
    "z=z/c+z""z=z/x+z""z=z/c+c""z=z/x+c"\
    "z=z/g+c""z=z-c""z=z-x""z=z-g""z=c-z""z=x-z"\
    "z=g-z""z=z/c-z""z=z/x-z""z=z/g-z""z=z/c-c""z=z/x-c"\
    "z=z/g-c""z=z-z/c""z=z-z/x""z=z-z/g""z=c-z/c"\
    "z=c-z/x""z=c-z/g""z=c/z""z=x/z""z=g/z""z*z+c""z*c+z"\
    "ezz""ez/z""exz""ex/z""eyz""ey/z""z/1-z""z/1-x""z/1-y"\
    "zpi""zpi/z""z^pi/z^z""zpixel""z/pixelz"\
    "z/zpixel""z^pixel/z+pixel""ez/zpixel""z/pixel""piz/pixel"\
    "piz/zpixel""z-zpixel""ez/pixel""z+zpixel"\
    "c/ez""z+c/g""x+z/y+c""g^z-c""z-x+y/x-y""g/c-z"\
    "y+c/g""x+y/y+c""g^y-c""y-x+y/x-y""g/c-y"\    
    "g/c-x""g^x-c""x+c/g""c/ex"
    default = 0
  endparam
  
  param style
    caption = "Variation in Style"
    enum = "z""fn(z^(2+power))""fn(x-y)""fn(y-x)"\
    "fn(x^2-y^2)""(fn(y-x))" "(fn(x^2-y^2))"\
    "fn(x^e)""fn(y^e)""fn(x^pi)""fn(y^pi)"\
    "fn(z-x)^fn(z-y)""fn(z+x)^fn(z+y)"   
    default = 0
  endparam 

  param flavor
    caption = "Formula Flavor"
    enum = "z""z^2 + c""z^(z/c)""z/(z-1)""z^2/(z-1)""z^3/(z^2-1)"\
    "z^3*c/(z^2-c)""z^3+z^2+z+c""fnzfnzfnz""fnzpfnzpfnzp"\
    "fnzfnz/fnz""fnzpfnzp/fnzp""zzz""z^pz^pz^p"\
    "zz/z""z^pz^p/z^p""z^3-z^2+c"
    default = 0
  endparam
  
  heading
    caption = "Functions"
  endheading

  func fn1
    caption = "Function 1"
    default = ident()
  endfunc

  func fn2
    caption = "Function 2"
    default = ident()
  endfunc

  func fn3
    caption = "Function(3) of Z"
    default = ident()
    visible = @ztweaker != "z=orig"
  endfunc

  func fn4
    caption = "Functions(4) of z"
    default = ident()
    visible = @ztweaker != "z=orig"
  endfunc

  float param bailout
    caption = "Bail-out value"
    hint = "This is the bail-out value"
    default = 4.0
    endparam
   
  param version
    caption = "Version"
    default = 3.0
  endparam  
    
   }

===============================================================

JosephJulia{
; Ver 2.0 Sean Pratz bailout system has been modified for bailchoice.
; By Dolf De Rovira 2-18-04 - Based off of Jayce Cruel's Random Generator and 
; the standard Julia Formulation in  Ultra Fractal (R) Standard Formula.
; With considerable help from Toby Marshall. 
; Parameter 3 1,0 and 1,1 yield interesting results with Function 1 = asin and 
; Function 4 =sqr.
; Also, Leaving Parameter 3 as 1,1,  Parameter 4 as 1,0 and 1,1 also yield very 
; interesting results.
; As well as Parameter 3 1,1, Parameter 4  1,1 and Parameter 6 = 1,0  

  init:

  z = pixel
  c = @seed

  loop:

  float x = Real(z)
  float y = Imag(z)
  float g = real(@seed)
  
  if @version > 2.0
  if @style == "z"
    z = fn4((z-p4)*@p5)
  elseif @style == "fn(z^(2+power))"
    z = fn4((z-p4)*@p5)^@fn5(2+ @p6) + @fn6(c)
  elseif @style == "fn(x-y)"
    z = fn4((z-p4)*@p5)^@fn5(2+ @p6) + fn4(x-y) + @fn6(c)
  elseif @style == "(fn(y-x))"
    z = fn4((z-p4)*@p5)^@fn5(2+ @p6+ fn4(y-x)) + @fn6(c)

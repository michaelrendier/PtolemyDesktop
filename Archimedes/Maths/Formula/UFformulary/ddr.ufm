  elseif @op == "ident"
    z = ident(3 / ident(fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 ))))))))))) + c
  elseif @op == "zero"
    z = zero(3 /zero (fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 ))))))))))) + c
  elseif @op == "recip"
    z = recip(3 / recip(fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 ))))))))))) + c
  elseif @op == "ceil"
    z = ceil(3 /ceil (fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 ))))))))))) + c
  elseif @op == "floor"
    z = floor(3 / floor(fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 ))))))))))) + c
  elseif @op == "trunc"
    z = trunc(3 /trunc (fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 ))))))))))) + c
  elseif @op == "round"
    z = round(3 /round (fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 ))))))))))) + c
  endif

  
  bailout:
 
    (@bailchoice == 0 && |z| <= @bailout) ||                                         \
    (@bailchoice == 1 && real(sqr(z)) <= @bailout) ||                                \
    (@bailchoice == 2 && imag(sqr(z)) <= @bailout) ||                                \
    (@bailchoice == 3 && sqr(real(z)) <= @bailout) ||                                \
    (@bailchoice == 4 && sqr(imag(z)) <= @bailout) ||                                \
    (@bailchoice == 5 && (sqr(real(z)) <= @bailout && sqr(imag(z)) < @bailout)) ||   \
    (@bailchoice == 6 && (sqr(real(z)) <= @bailout || sqr(imag(z)) < @bailout)) ||   \
    (@bailchoice == 7 && (sqr(abs(real(z)) + abs(imag(z))) <= @bailout)) ||          \
    (@bailchoice == 8 && (sqr(real(z) + imag(z)) <= @bailout))

  default:
    title = "JosephJulia" 
    periodicity = 0
    angle = 0.01
    
  heading
    caption = "Parameters"
  endheading       
  
  int param bailout
    caption = "Bailout value"
    default = 122
    min = 1
  endparam

  param bailchoice
    caption = "Bailout Choice"
    default = 0
    enum = "|z|" "Real(Z^2)""Imag(Z^2)""Real(Z)^2""Imag(Z)^2"\
     "Real & Imag""Real or Imag""Sqr(Abs(Real&Imag)" "Sqr(Real&Imag)"
  endparam

  param op
    caption = "Operator"
    enum = "+""-""*""/""^""sin""sinh""asin""asinh"\
    "cos""cosh""acos""acosh""tan""tanh""atan""atanh"\
    "cotan""cotanh""sqr""sqrt""log""exp"\
    "abs""cabs""conj""flip""ident""zero""recip" \
    "ceil""floor""trunc" "round"
    default = 0
  endparam 
    
  complex param p1
    caption = "Param 1"
    default = (0,0)
  endparam

  complex param p2
    caption = "Param 2"
    default = (0,0)
  endparam

 complex param p3
    caption = "Param 3"
    default = (0,0)
  endparam  

  param p4
    caption = "Subtracter"
    default = (0,0)
  endparam

  param @p5
    caption = "Mulitplier"
    default = (1,0)
  endparam    

  param @p6
    caption = "Power"
    default = (0,0)
  endparam   

  param seed
    caption= "Julia seed"
    default = (0,0)
  endparam
 
  heading
    caption = "Affecters of Z"
  endheading

  bool param inv
    caption = "Invert Z"
    default = false
  endparam  

  bool param zpix
    caption = "Z=Pixel"
    default = false
  endparam  

  bool param xplus
    caption = "Add X"
    default = false
  endparam 

  bool param yplus
    caption = "Add Y"
    default = false
  endparam 

  bool param Zpower
    caption = "Z^Z"
    default = false
  endparam 

  bool param Xpower
    caption = "Z^X"
    default = false
  endparam 

  bool param Ypower
    caption = "Z^Y"
    default = false
  endparam 

  bool param Gpower
    caption = "Z^G"
    default = false
  endparam 

  bool param Gplus
    caption = "Z+G"
    default = false
  endparam 

  bool param func1
    caption = "Fn(Z)"
    default = false
  endparam 

  bool param func2
    caption = "@fn5(fn4(Z))"
    default = false
  endparam 
  
  bool param func3
    caption = "@fn6(@fn5(fn4(Z)))"
    default = false
  endparam 
  
  bool param funcpowerz
    caption = "Function Power"
    default = false
  endparam  

  bool param funcpowerx
    caption = "Function Power of X"
    default = false
  endparam 

  bool param funcpowery
    caption = "Function Power of Y"
    default = false
  endparam  

  bool param funcpowerg
    caption = "Function Power of G"
    default = false
  endparam 
  
  bool param ez 
    caption = "Euler times Z"
   default = false
  endparam 

  bool param zpi  
   caption = "Pi times Z"
   default = false
  endparam 

  bool param ztopidivzpi  
   caption = "Z^Pi/Z*Pi"
   default = false
  endparam 
  
  bool param zpidivztopi
   caption = "Z*Pi/Z^Pi"
   default = false
  endparam 

  param cchange
    caption = "Nuance of C"
    enum = "Orig""Real""Imag""Sign""Squared"\
    "Exponent""Inverse""Inv/Exp""C/Exp"\
    "SQRPixel""CPower""EPower""ZPower"\
    "CPower3""CFunction""Function"
    default = 0
  endparam
  
  func fnc
    caption = "C Function"
    default = sqr()
    visible = @cchange == "Function" ||\
    @cchange == "CFunction"
  endfunc

  float param expC
    caption = "Power of C"
    default = 1.0
  endparam
  
  param ztweaker
    caption = "Z Tweaker"
    enum = "z=orig""z=z+c""z=z+x""z=z+y""z=z+g"\
    "z=z*c""z=z*x""z=z*y""z=z*g""z=z/c""z=z/x""z=z/g"\
    "z=z/c+z""z=z/x+z""z=z/c+c""z=z/x+c"\
    "z=z/g+c""z=z-c""z=z-x""z=z-g""z=c-z""z=x-z"\
    "z=g-z""z=z/c-z""z=z/x-z""z=z/g-z""z=z/c-c""z=z/x-c"\
    "z=z/g-c""z=z-z/c""z=z-z/x""z=z-z/g""z=c-z/c"\
    "z=c-z/x""z=c-z/g""z=c/z""z=x/z""z=g/z""z*z+c""z*c+z"\
    "ezz""ez/z""exz""ex/z""eyz""ey/z""z/1-z""z/1-x""z/1-y"\
    "zpi""zpi/z""z^pi/z^z""zpixel""z/pixelz"\
    "z/zpixel""z^pixel/z+pixel""ez/zpixel""z/pixel""piz/pixel"\
    "piz/zpixel""z-zpixel""ez/pixel""z+zpixel"\
    "c/ez""z+c/g""x+z/y+c""g^z-c""z-x+y/x-y""g/c-z"\
    "y+c/g""x+y/y+c""g^y-c""y-x+y/x-y""g/c-y"\    
    "g/c-x""g^x-c""x+c/g""c/ex"
    default = 0
  endparam

  param flavor
    caption = "Formula Flavor"
    enum = "z""z^2 + c""z^(z/c)""z/(z-1)""z^2/(z-1)""z^3/(z^2-1)"\
    "z^3*c/(z^2-c)""z^3+z^2+z+c""fnzfnzfnz""fnzpfnzpfnzp"\
    "fnzfnz/fnz""fnzpfnzp/fnzp""zzz""z^pz^pz^p"\
    "zz/z""z^pz^p/z^p""z^3-z^2+c"
    default = 0
  endparam

  param style
    caption = "Variation in Style"
    enum = "z""fn(z^(2+power))""fn(x-y)""fn(y-x)"\
    "fn(x^2-y^2)""(fn(y-x))" "(fn(x^2-y^2))"\
    "fn(x^e)""fn(y^e)""fn(x^pi)""fn(y^pi)"\
    "fn(z-x)^fn(z-y)""fn(z+x)^fn(z+y)"   
    default = 0
  endparam 

  heading
    caption = "Functions"
  endheading

  func fn1
    caption = "Function 1"
    default = sqr()
  endfunc

  func fn2
    caption = "Function 2"
    default = round()
  endfunc    

  func fn3
    caption = "Function 3"
    default = sin()
  endfunc  

  func fn4
    caption = "Function(1) of Z"
    default = ident()
  endfunc

  func @fn5
    caption = "Functions(2) of z"
    default = ident()
  endfunc

  func @fn6
    caption = "Functions(3) of z"
    default = ident()
  endfunc

  param version
    caption = "Version"
    default = 3.0
  endparam  

  switch:
    type = "JosephMandelbrot"
    p1 = #pixel
    bailout = @bailout 
    inv = @inv 
    fn1 = @fn1
    fn2 = @fn2
    fn3 = @fn3
    fn4 = @fn4
    @fn5 = @fn5
    @fn6 = @fn6
    xpower = @xpower
    ypower = @ypower
    zpower = @zpower
    gpower = @gpower
    x = @x
    y = @y
    g = @g
    gplus = @gplus
    xplus = @xplus
    yplus = @yplus
    func1 = @func1
    func2 = @func2
    func3 = @func3
    ;p1 = @p1
    p2 = @p2
    p3 = @p3
    p4 = @p4
    @p5 = @p5
    @p6 = @p6
    funcpowerx = @funcpowerx
    funcpowery = @funcpowery
    funcpowerz = @funcpowerz
    funcpowerg = @funcpowerg
    fnc = @fnc
    expC = @expC
    style = @style
    ztweaker = @ztweaker
    bailchoice = @bailchoice
    cchange = @cchange
    flavor = @flavor
    zpix = @zpix
    inv = @inv
    ez = @ez
    zpi = @zpi
    ztopidivzpi = ztopidivzpi
    zpidivztopi = @zpidivztopi
   }

JosephMandelbrot{
; Ver 3.0 6-7-04 fixed switch errors. Also added style, etc.
; Ver 2.0 Sean Pratz bailout system has been modified for bailchoice. 
; By Dolf De Rovira 2-18-04 - Based off of Jayce Cruel's Random Generator and 
; the standard Julia Formulation in  Ultra Fractal (R) Standard Formula.
; Parameter 3 1,0 and 1,1 yield interesting results with Function 1 = asin and 
; Function 4 =sqr.
; Also, Leaving Parameter 3 as 1,1,  Parameter 4 as 1,0 and 1,1 also yield very 
; interesting results.
; As well as Parameter 3 1,1, Parameter 4  1,1 and Parameter 6 = 1,0  

  init:

  z = @start
  c = #pixel

  loop:
   
  float x = Real(z)
  float y = Imag(z)
  float g = real(#pixel)
  
  if @version > 2.0
  if @style == "z"
    z = fn4((z-p4)*@p5)
  elseif @style == "fn(z^(2+power))"
    z = fn4((z-p4)*@p5)^@fn5(2+ @p6) + @fn6(c)
  elseif @style == "fn(x-y)"
    z = fn4((z-p4)*@p5)^@fn5(2+ @p6) + fn4(x-y) + @fn6(c)
  elseif @style == "(fn(y-x))"
    z = fn4((z-p4)*@p5)^@fn5(2+ @p6+ fn4(y-x)) + @fn6(c)
  elseif @style =="(fn(x^2-y^2))"
    z = fn4((z-p4)*@p5)^@fn5(2+ @p6+ fn4(y^2-x^2)) + @fn6(c)
  elseif @style =="fn(x^2-y^2)"
    z = fn4((z-p4)*@p5)^@fn5(2+ @p6)+ fn4(y^2-x^2) + @fn6(c)
  elseif @style =="fn(x^e)"
    z = fn4(x)^@fn5(e) + @fn6(c)
  elseif @style =="fn(y^e)"
    z = fn4(y)^@fn5(e) + @fn6(c)
  elseif @style =="fn(x^pi)"
    z = fn4(x)^@fn5(#pi)+@fn6(c)
  elseif @style =="fn(y^pi)"
    z = fn4(y)^@fn5(#pi) +@fn6(c)
  elseif @style =="fn(z-x)^fn(z-y)"
    z = fn4(z-x)^@fn5(z-y)+@fn6(c)
  elseif @style =="fn(z+x)^fn(z+y)"
    z = fn4(z+x)^@fn5(z+y)+@fn6(c)
  endif  
 
  if @ztweaker == "z=orig"
    z = fn4(z)
  elseif @ztweaker == "z=z+c"
    z = fn4(z) + @fn5(c)
  elseif @ztweaker == "z=z+x"
    z = fn4(z) + @fn5(x)
  elseif @ztweaker == "z=z+y"
    z = fn4(z) + @fn5(y)
  elseif @ztweaker == "z=z+g"
    z = fn4(z) + @fn5(g)
  elseif @ztweaker == "z=z*c"
    z = fn4(z) * @fn5(c)
  elseif @ztweaker == "z=z*x"
    z = fn4(z) * @fn5(x)
  elseif @ztweaker == "z=z*y"
    z = fn4(z) * @fn5(y)  
  elseif @ztweaker == "z=z*g"
    z = fn4(z) * @fn5(g)
  elseif @ztweaker == "z=z/c"
    z = fn4(z) / @fn5(c) 
  elseif @ztweaker == "z=z/x"
    z = fn4(z) / @fn5(x)
  elseif @ztweaker == "z=z/g"
    z = fn4(z) / @fn5(g) 
  elseif @ztweaker == "z=z/c+z"
    z = fn4(z) / @fn5(c) + @fn6(z)
  elseif @ztweaker == "z=z/x+z"
    z = fn4(z) / @fn5(x) + @fn6(z)
  elseif @ztweaker == "z=z/c+c"
    z = fn4(z) / @fn5(c) + @fn6(c)
  elseif @ztweaker == "z=z/x+c"
    z = fn4(z) / @fn5(x) + @fn6(c)
  elseif @ztweaker == "z=z/g+c"
    z = fn4(z) / @fn5(g) + @fn6(c)
  elseif @ztweaker == "z=z-c"
    z = fn4(z) - @fn5(c)
  elseif @ztweaker == "z=z-x"
    z = fn4(z) - @fn5(x)
  elseif @ztweaker == "z=z-g"
    z = fn4(z) - @fn5(g)
  elseif @ztweaker == "z=c-z"
    z = fn4(c) - @fn5(z) 
  elseif @ztweaker == "z=x-z"
    z = fn4(x) - @fn5(z)
  elseif @ztweaker == "z=g-z"
    z = fn4(g) - @fn5(z) 
  elseif @ztweaker == "z=z/c-z"
    z = fn4(z) / @fn5(c) - @fn6(z)
  elseif @ztweaker == "z=z/x-z"
    z = fn4(z) / @fn5(x) - @fn6(z)
  elseif @ztweaker == "z=z/g-z"
    z = fn4(z) / @fn5(g) - @fn6(z)
  elseif @ztweaker == "z=z/c-c"
    z = fn4(z) / @fn5(c) - @fn6(c)
  elseif @ztweaker == "z=z/x-c"
    z = fn4(z) / @fn5(x) - @fn6(c)
  elseif @ztweaker == "z=z/g-c"
    z = fn4(z) / @fn5(g) - @fn6(c)  
  elseif @ztweaker == "z=z-z/c"
    z = fn4(z) - @fn5(z) / @fn6(c) 
  elseif @ztweaker == "z=z-z/x"
    z = fn4(z) - @fn5(z) / @fn6(x) 
  elseif @ztweaker == "z=z-z/g"
    z = fn4(z) - @fn5(z) / @fn6(g)
  elseif @ztweaker == "z=c-z/c"
    z = fn4(c) - @fn5(z) / @fn6(c) 
  elseif @ztweaker == "z=c-z/g"
    z = fn4(c) - @fn5(z) / @fn6(g) 
  elseif @ztweaker == "z=c-z/x"
    z = fn4(c) - @fn5(z) / @fn6(x) 
  elseif @ztweaker == "z=c/z"
    z = fn4(c) / @fn5(z)   
  elseif @ztweaker == "z=x/z"
    z = fn4(x) / @fn5(z)   
  elseif @ztweaker == "z*z+c"
    z = fn4(z) * @fn5(z) + @fn6(c)
  elseif @ztweaker == "z*c+z"
    z = fn4(z) * @fn5(c) + @fn6(z)
  elseif @ztweaker == "z=g/z"
    z = fn4(g) / @fn5(z) 
  elseif @ztweaker == "ezz"
    z = e^fn4(z)* @fn5(z)  
  elseif @ztweaker == "ez/z"
    z = e^fn4(z)/ @fn5(z)   
  elseif @ztweaker == "ex/z"
    z = e^fn4(x)/ @fn5(z)
  elseif @ztweaker == "exz"
    z = e^fn4(x)* @fn5(z)  
  elseif @ztweaker == "ey/z"
    z = e^fn4(y)/ @fn5(z)
  elseif @ztweaker == "eyz"
    z = e^fn4(y)* @fn5(z)    
  elseif @ztweaker == "z/1-z"
    z = fn4(z)/(1- @fn5(z))
  elseif @ztweaker == "z/1-x"
    z = fn4(z)/(1-@fn5(x)) 
  elseif @ztweaker == "z/1-y"
    z = fn4(z)/(1-@fn5(y))  
  elseif @ztweaker == "zpi"
    z = fn4(z) ^ #pi  
  elseif @ztweaker == "zpi/z"
    z = fn4(z) ^ #pi / @fn5(z)^2   
  elseif @ztweaker == "z^pi/z^z"
    z = fn4(z) ^ #pi / @fn5(z^z)  
  elseif @ztweaker == "z/pixel"
    z = @fn5(fn4(z) / #pixel)
  elseif @ztweaker == "zpixel"
    z = @fn5(fn4(z) * #pixel)  
  elseif @ztweaker == "z^pixel/z+pixel"
    z = fn4(z) ^ #pixel /@fn5(z) + pixel  
  elseif @ztweaker == "ez/zpixel"
    z = e^fn4(z) /(@fn5(z)+ #pixel) 
  elseif @ztweaker == "ez/pixel"
    z = @fn5(e^fn4(z) /#pixel)
  elseif @ztweaker == "piz/pixel"
    z = @fn5(fn4(z)^#pi / #pixel)  
  elseif @ztweaker == "piz/zpixel"
    z = fn4(z)^#pi /(@fn5(z) + #pixel)  
  elseif @ztweaker == "z+zpixel"
    z = @fn5(fn4(z) + #pixel)   
  elseif @ztweaker == "z-zpixel"
    z = @fn5(fn4(z) - #pixel) 
  elseif @ztweaker == "z/zpixel"
    z = fn4(z) /(@fn5(z) + #pixel)
  elseif @ztweaker == "z/pixelz"
    z = fn4(z) /#pixel^@fn5(z)
  elseif @ztweaker == "ez/pixel"
    z = @fn5(e^fn4(z)/#pixel)
  elseif @ztweaker == "c/ez"
    z  = fn4(c / (#e * @fn5(z)))
  elseif @ztweaker == "z+c/g"
    z  = fn4(@fn5(z) + c / g )
  elseif @ztweaker == "x+z/y+c"
    z  = (fn4(x) + z) / (@fn5(y) + c)
  elseif @ztweaker == "g^z-c"
    z  = @fn5(g ^ (fn4(z) )) - c
  elseif @ztweaker == "z-x+y/x-y"
    z  = fn4(z) - @p5 + @fn5((x+y)/(x-y))
  elseif @ztweaker == "g/c-z"
    z  = fn4(( g )/ (c - @fn5(z)))
  elseif @ztweaker == "y+c/g"
    z  = fn4(@fn5(y) + c / g )
  elseif @ztweaker == "x+y/y+c"
    z  = (fn4(x) + y) / (@fn5(y) + c)
  elseif @ztweaker == "g^y-c"
    z  = @fn5(g ^ (fn4(y) )) - c
  elseif @ztweaker == "y-x+y/x-y"
    z  = fn4(y) - @p5 + @fn5((x+y)/(x-y))
  elseif @ztweaker == "g/c-y"
    z  = fn4(( g )/ (c - @fn5(y)))
  elseif @ztweaker == "c/ex"
    z  = fn4(c / (#e * @fn5(x)))
  elseif @ztweaker == "x+c/g"
    z  = fn4(@fn5(x) + c / g )
  elseif @ztweaker == "g^x-c"
    z  = @fn5(g ^(fn4(x))) - c
  endif 
  
  if @inv == true
    z = 1/z
  else
    z = z
  endif
  
  if @zpix == true
    z = ((pixel-p4)*@p5)^(2+ @p6)  
  else
    z = z
  endif
  
  if @xplus == true
     z = ((z-p4)*@p5)^(2+ @p6) + x
  else
    z = z
  endif

  if @yplus == true
    z = ((z-p4)*@p5)^(2+ @p6) + y
  else
    z = z
  endif

  if @zpower == true
    z = ((z-p4)*@p5)^(2+ @p6) ^ z
  else
    z = z
  endif

  if @xpower == true
    z = ((z-p4)*@p5)^(2+ @p6)^x
  else
    z = z
  endif

  if @ypower == true
    z = ((z-p4)*@p5)^(2+ @p6)^y
  else
    z = z
  endif

  if @gpower == true ; hpower showed no effect
    z = ((z-p4)*@p5)^(2+ @p6)^g
  else
    z = z
  endif
  
  if @gplus == true ; hplus showed no effect
    z = ((z-p4)*@p5)^(2+ @p6) + g
  else
    z = z
  endif

  if @func1 == true
    z = fn4((z-p4)*@p5)
  else
    z = z
  endif
 
  if @func2 == true
    z = @fn5(fn4((z-p4)*@p5))
  else
    z = z
  endif

  if @func3 == true
    z = @fn6(@fn5(fn4((z-p4)*@p5)))
  else
    z = z
  endif

  if @funcpowerz == true
    z = ((z-p4)*@p5)^fn4(z)
  else
    z = z
  endif

  if @funcpowerx == true
    z = ((z-p4)*@p5)^fn4(x)
  else
    z = z
  endif

  if @funcpowery == true
    z = ((z-p4)*@p5)^fn4(y)
  else
    z = z
  endif

  if @funcpowerg == true ; funcpowerh no effect
    z = ((z-p4)*@p5)^fn4(g)
  else
    z = z
  endif
  
  if @ez == true 
    z = e^z
  else
    z = z
  endif

  if @zpi == true 
    z = z^#pi
  else
    z = z
  endif
  
  if @ztopidivzpi == true 
    z = z^#pi/(z*#pi)
  else
    z = z
  endif

  if @zpidivztopi == true 
    z = z*#pi/(z^#pi)
  else
    z = z
  endif

  if @flavor == "z"
    z = fn4((z-p4)*@p5)
  elseif @flavor == "z^2 + c"
    z = fn4((z-p4)*@p5)^@fn6(2+ @p6) + @fn6(c)
  elseif @flavor == "z^(z/c)"
    z = fn4((z-p4)*@p5)^@fn5((z-p4)*@p5) + @fn6(@p6/c)
  elseif @flavor == "z/(z-1)"
    z = fn4((z-p4)*@p5)/@fn5(((z-p4)*@p5) -1) + @fn6(@p6*c)
  elseif @flavor == "z^2/(z-1)"
    z = fn4((z-p4)*@p5)^(2+ @p6)/@fn5(((z-p4)*@p5) -1) + @fn6(@p6*c)
  elseif @flavor == "z^3/(z^2-1)"
    z = fn4((z-p4)*@p5)^(3+ @p6)/@fn5(((z-p4)*@p5)^(2+ @p6) -1)\
     +@fn6(@p6*c)
  elseif @flavor == "z^3*c/(z^2-c)"
    z = fn4((z-p4)*@p5)^(3+ @p6)*c/@fn5(((z-p4)*@p5)^(2+@p6) - c)\
     - @fn6(@p6*c) 
  elseif @flavor == "z^3+z^2+z+c"
    z = fn4((z-p4)*@p5)^(3+ @p6)+((z-p4)*@p5)^(2+ @p6)+@fn5((z-p4)*@p5)\
    ^(2+ @p6)+ @fn6(@p6*c) 
  elseif @flavor == "fnzfnzfnz"
    z = fn4((z-p4)*@p5)*@fn5((z-p4)*@p5)*@fn6((z-p4)*@p5) + @p6*c  
  elseif @flavor == "fnzpfnzpfnzp"
    z = fn4((z-p4)*@p5)^(2+ @p6)*@fn5((z-p4)*@p5)^(2+ @p6)*@fn6((z-p4)\
    ^(2+ @p6)*@p5) + @p6*c
  elseif @flavor == "fnzfnz/fnz"
    z = fn4((z-p4)*@p5)*@fn5((z-p4)*@p5)/@fn6((z-p4)*@p5) + @p6*c  
  elseif @flavor == "fnzpfnzp/fnzp"
    z = fn4((z-p4)*@p5)^(2+ @p6)*@fn5((z-p4)*@p5)^(2+ @p6)/@fn6((z-p4)\
    ^(2+ @p6)*@p5) + @p6*c
   elseif @flavor == "zzz"
    z = fn4((z-p4)*@p5)*@fn5((z-p4)*@p5)*@fn6((z-p4)*@p5) + @p6*c  
  elseif @flavor == "z^pz^pz^p"
    z = fn4((z-p4)*@p5)^(2+ @p6)*@fn5((z-p4)*@p5)^(2+ @p6)*@fn6((z-p4)\
    ^(2+ @p6)*@p5) + @p6*c
  elseif @flavor == "zz/z"
    z = fn4((z-p4)*@p5)*@fn5((z-p4)*@p5)/@fn6(z-p4)+ @p6*c
  elseif @flavor == "z^pz^p/z^p"
    z = fn4((z-p4)*@p5)^(2+ @p6)*@fn5((z-p4)*@p5)^(2+ @p6)/@fn6((z-p4)\
    ^(2+ @p6)*@p5) + @p6*c
  elseif @flavor == "z^3-z^2+c"
    z = fn4((z-p4)*@p5)^(3+ @p6)-@fn5((z-p4)*@p5)^(2+ @p6)+ @fn6(@p6*c) 
  endif
  
  if @cchange == "Orig"
    c = c^@expC 
  elseif @cchange == "Real"
    c = real(c)^@expC
  elseif @cchange == "Imag"
    c = imag(c)^@expC
  elseif @cchange == "Sign"
    c = -c^@expC
  elseif @cchange == "Squared"
    c = c^2+@expC  
  elseif @cchange == "Exponent"
    c = e^c^@expC
  elseif @cchange == "Inverse"
    c = 1 / c^@expC
  elseif @cchange == "Inv/Exp"  
    c = 1 / e^c^@expC
  elseif @cchange == "C/Exp"
    c = c^@expC / e^c^@expC
  elseif @cchange == "SQRPixel"
    c = sqr(pixel)/3 
  elseif @cchange == "CPower"
    c = c^c  
  elseif @cchange == "EPower"
    c = c^(e+c)   
  elseif @cchange == "ZPower"
    c = c^z   
  elseif @cchange == "CPower3"
    c = c^c^c   
  elseif @cchange == "CFunction"
    c = c^((z-@p4)*@p5)^@fnc(2 + @p6)  
  elseif @cchange == "Function"
    c = @fnc(c^@expC)  
  endif  
  endif

  if @op == "+"
    z = 3 / (fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 )))))))))) + c 
  elseif @op == "-"
    z = 3 / (fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )- ((@fn2 ( z + p2 )- (p2)-\
    (4 ^ z ^ (sqrt (p1 )))))))))) + c
  elseif @op == "*"
    z = 3 / (fn1 ( fn1 ( z - @fn2 ( z * (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 )))))))))) + c
  elseif @op == "/"
    z = 3 / (fn1 ( fn1 ( z - @fn2 ( z / (fn1 ( z ^ p1 )/ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 )))))))))) + c
  elseif @op == "^"
    z = 3 / (fn1 ( fn1 ( z - @fn2 ( z ^ (fn1 ( z ^ p1 )^ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 )))))))))) + c  
  elseif @op == "sin"
    z = sin(3 /sin (fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 ))))))))))) + c
  elseif @op == "sinh"
    z = sinh(3 / sinh(fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 ))))))))))) + c
  elseif @op == "asin"
    z = asin(3 / asin(fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 ))))))))))) + c
  elseif @op == "asinh"
    z = asinh(3 / asinh(fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 ))))))))))) + c
  elseif @op == "cos"
    z = cos(3 /cos (fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 ))))))))))) + c
  elseif @op == "cosh"
    z = cosh(3 / cosh(fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 ))))))))))) + c
  elseif @op == "acos"
    z = acos(3 /acos (fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 ))))))))))) + c
  elseif @op == "acosh"
    z = acosh(3 / acosh(fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 ))))))))))) + c
  elseif @op == "tan"
    z = tan( 3 / tan(fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 ))))))))))) + c
  elseif @op == "atan"
    z = atan(3 /atan (fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 ))))))))))) + c
  elseif @op == "tanh"
    z = tanh( 3 /tanh (fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 ))))))))))) + c
  elseif @op == "atanh"
    z = atanh(3 /atanh (fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 ))))))))))) + c
  elseif @op == "cotan"
    z = cotan(3 / cotan(fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 ))))))))))) + c
  elseif @op == "cotanh"
    z = cotanh(3 /cotanh (fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 ))))))))))) + c
  elseif @op == "sqr"
    z = sqr(3 /sqr (fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 ))))))))))) + c
  elseif @op == "sqrt"
    z = sqrt(3 /sqrt (fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 ))))))))))) + c
  elseif @op == "log"
    z = log(3 /log (fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 ))))))))))) + c
  elseif @op == "exp"
    z = exp(3 /exp (fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 ))))))))))) + c
  elseif @op == "abs"
    z = abs(3 /abs (fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 ))))))))))) + c
  elseif @op == "cabs"
    z = cabs(3 / cabs(fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 ))))))))))) + c
  elseif @op == "conj"
    z = conj(3 / conj(fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 ))))))))))) + c
  elseif @op == "flip"
    z = flip(3 /flip (fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 ))))))))))) + c
  elseif @op == "ident"
    z = ident(3 / ident(fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 ))))))))))) + c
  elseif @op == "zero"
    z = zero(3 /zero (fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 ))))))))))) + c
  elseif @op == "recip"
    z = recip(3 / recip(fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 ))))))))))) + c
  elseif @op == "ceil"
    z = ceil(3 /ceil (fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 ))))))))))) + c
  elseif @op == "floor"
    z = floor(3 / floor(fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 ))))))))))) + c
  elseif @op == "trunc"
    z = trunc(3 /trunc (fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 ))))))))))) + c
  elseif @op == "round"
    z = round(3 /round (fn1 ( fn1 ( z - @fn2 ( z + (fn1 ( z ^ p1 )+ ((@fn2 ( z - p2 )+ (p2)-\
    (4 ^ z ^ (sqrt (p1 ))))))))))) + c
  endif
  
  bailout:
 
    (@bailchoice == 0 && |z| <= @bailout) ||                                         \
    (@bailchoice == 1 && real(sqr(z)) <= @bailout) ||                                \
    (@bailchoice == 2 && imag(sqr(z)) <= @bailout) ||                                \
    (@bailchoice == 3 && sqr(real(z)) <= @bailout) ||                                \
    (@bailchoice == 4 && sqr(imag(z)) <= @bailout) ||                                \
    (@bailchoice == 5 && (sqr(real(z)) <= @bailout && sqr(imag(z)) < @bailout)) ||   \
    (@bailchoice == 6 && (sqr(real(z)) <= @bailout || sqr(imag(z)) < @bailout)) ||   \
    (@bailchoice == 7 && (sqr(abs(real(z)) + abs(imag(z))) <= @bailout)) ||          \
    (@bailchoice == 8 && (sqr(real(z) + imag(z)) <= @bailout))
  
  default:
    title = "JosephMandelbrot"
    periodicity = 0 
    angle = 0.01
  
  heading
    caption = "Parameters"
  endheading   
  
  param start
    caption = "Start Parameter"
    default = (0,0)
  endparam      
    
  int param bailout
    caption = "Bailout value"
    default = 16
    max = 122
    min = 1
  endparam
    
  param bailchoice
    caption = "Bailout Choice"
    default = 0
    enum = "|z|" "Real(Z^2)""Imag(Z^2)""Real(Z)^2""Imag(Z)^2"\
     "Real & Imag""Real or Imag""Sqr(Abs(Real&Imag)" "Sqr(Real&Imag)"
  endparam
      
  param op
    caption = "Operator"
    enum = "+""-""*""/""^""sin""sinh""asin""asinh"\
    "cos""cosh""acos""acosh""tan""tanh""atan""atanh"\
    "cotan""cotanh""sqr""sqrt""log""exp"\
    "abs""cabs""conj""flip""ident""zero""recip" \
    "ceil""floor""trunc" "round"
    default = 0
  endparam 
    
  complex param p1
    caption = "Param 1"
    default = (0,0)
  endparam

  complex param p2
    caption = "Param 2"
    default = (0,0)
  endparam  

  complex param p3
    caption = "Param 3"
    default = (0,0)
  endparam  

  param p4
    caption = "Subtracter"
    default = (0,0)
  endparam

  param @p5
    caption = "Mulitplier"
    default = (1,0)
  endparam    

  param @p6
    caption = "Power"
    default = (0,0)
  endparam   

  heading
    caption = "Affecters of Z"
  endheading

  bool param inv
    caption = "Invert Z"
    default = false
  endparam  

  bool param zpix
    caption = "Z=Pixel"
    default = false
  endparam  

  bool param xplus
    caption = "Add X"
    default = false
  endparam 

  bool param yplus
    caption = "Add Y"
    default = false
  endparam 

  bool param Zpower
    caption = "Z^Z"
    default = false
  endparam 

  bool param Xpower
    caption = "Z^X"
    default = false
  endparam 

  bool param Ypower
    caption = "Z^Y"
    default = false
  endparam 

  bool param Gpower
    caption = "Z^G"
    default = false
  endparam 

  bool param Gplus
    caption = "Z+G"
    default = false
  endparam 

  bool param func1
    caption = "Fn(Z)"
    default = false
  endparam 

  bool param func2
    caption = "@fn5(fn4(Z))"
    default = false
  endparam 
  
  bool param func3
    caption = "@fn6(@fn5(fn4(Z)))"
    default = false
  endparam 
  
  bool param funcpowerz
    caption = "Function Power"
    default = false
  endparam  

  bool param funcpowerx
    caption = "Function Power of X"
    default = false
  endparam 

  bool param funcpowery
    caption = "Function Power of Y"
    default = false
  endparam  

  bool param funcpowerg
    caption = "Function Power of G"
    default = false
  endparam 
  
  bool param ez 
    caption = "Euler times Z"
   default = false
  endparam 

  bool param zpi  
   caption = "Pi times Z"
   default = false
  endparam 

  bool param ztopidivzpi  
   caption = "Z^Pi/Z*Pi"
   default = false
  endparam 
  
  bool param zpidivztopi
   caption = "Z*Pi/Z^Pi"
   default = false
  endparam 

  param cchange
    caption = "Nuance of C"
    enum = "Orig""Real""Imag""Sign""Squared"\
    "Exponent""Inverse""Inv/Exp""C/Exp"\
    "SQRPixel""CPower""EPower""ZPower"\
    "CPower3""CFunction""Function"
    default = 0
  endparam
  
  func fnc
    caption = "C Function"
    default = sqr()
    visible = @cchange == "Function" ||\
    @cchange == "CFunction"
  endfunc

  float param expC
    caption = "Power of C"
    default = 1.0
  endparam
  
  param ztweaker
    caption = "Z Tweaker"
    enum = "z=orig""z=z+c""z=z+x""z=z+y""z=z+g"\
    "z=z*c""z=z*x""z=z*y""z=z*g""z=z/c""z=z/x""z=z/g"\
    "z=z/c+z""z=z/x+z""z=z/c+c""z=z/x+c"\
    "z=z/g+c""z=z-c""z=z-x""z=z-g""z=c-z""z=x-z"\
    "z=g-z""z=z/c-z""z=z/x-z""z=z/g-z""z=z/c-c""z=z/x-c"\
    "z=z/g-c""z=z-z/c""z=z-z/x""z=z-z/g""z=c-z/c"\
    "z=c-z/x""z=c-z/g""z=c/z""z=x/z""z=g/z""z*z+c""z*c+z"\
    "ezz""ez/z""exz""ex/z""eyz""ey/z""z/1-z""z/1-x""z/1-y"\
    "zpi""zpi/z""z^pi/z^z""zpixel""z/pixelz"\
    "z/zpixel""z^pixel/z+pixel""ez/zpixel""z/pixel""piz/pixel"\
    "piz/zpixel""z-zpixel""ez/pixel""z+zpixel"\
    "c/ez""z+c/g""x+z/y+c""g^z-c""z-x+y/x-y""g/c-z"\
    "y+c/g""x+y/y+c""g^y-c""y-x+y/x-y""g/c-y"\    
    "g/c-x""g^x-c""x+c/g""c/ex"
    default = 0
  endparam

  param flavor
    caption = "Formula Flavor"
    enum = "z""z^2 + c""z^(z/c)""z/(z-1)""z^2/(z-1)""z^3/(z^2-1)"\
    "z^3*c/(z^2-c)""z^3+z^2+z+c""fnzfnzfnz""fnzpfnzpfnzp"\
    "fnzfnz/fnz""fnzpfnzp/fnzp""zzz""z^pz^pz^p"\
    "zz/z""z^pz^p/z^p""z^3-z^2+c"
    default = 0
  endparam

  param style
    caption = "Variation in Style"
    enum = "z""fn(z^(2+power))""fn(x-y)""fn(y-x)"\
    "fn(x^2-y^2)""(fn(y-x))" "(fn(x^2-y^2))"\
    "fn(x^e)""fn(y^e)""fn(x^pi)""fn(y^pi)"\
    "fn(z-x)^fn(z-y)""fn(z+x)^fn(z+y)"   
    default = 0
  endparam 

  heading
    caption = "Functions"
  endheading

  func fn1
    caption = "Function 1"
    default = exp()
  endfunc

  func fn2
    caption = "Function 2"
    default = tanh()
  endfunc    

  func fn3
    caption = "Function 3"
    default = sin()
  endfunc  

  func fn4
    caption = "Function(1) of Z"
    default = ident()
  endfunc

  func @fn5
    caption = "Functions(2) of z"
    default = ident()
  endfunc

  func @fn6
    caption = "Functions(3) of z"
    default = ident()
  endfunc

  param version
    caption = "Version"
    default = 3.0
  endparam  

  switch:
    type = "JosephJulia"
    seed = #pixel
    bailout = @bailout 
    inv = @inv 
    fn1 = @fn1
    fn2 = @fn2
    fn3 = @fn3
    fn4 = @fn4
    @fn5 = @fn5
    @fn6 = @fn6
    xpower = @xpower
    ypower = @ypower
    zpower = @zpower
    gpower = @gpower
    x = @x
    y = @y
    g = @g
    gplus = @gplus
    xplus = @xplus
    yplus = @yplus
    func1 = @func1
    func2 = @func2
    func3 = @func3
    p1 = @p1
    p2 = @p2
    p3 = @p3
    p4 = @p4
    @p5 = @p5
    @p6 = @p6
    funcpowerx = @funcpowerx
    funcpowery = @funcpowery
    funcpowerz = @funcpowerz
    funcpowerg = @funcpowerg
    fnc = @fnc
    expC = @expC
    style = @style
    ztweaker = @ztweaker
    bailchoice = @bailchoice
    cchange = @cchange
    flavor = @flavor
    zpix = @zpix
    inv = @inv
    ez = @ez
    zpi = @zpi
    ztopidivzpi = ztopidivzpi
    zpidivztopi = @zpidivztopi 
  }

==============================================================

JuliaPlus4 {
; Version 2.0 Added ztweaker cchange, style, flavor etc.
; By Dolf De Rovira With help from Toby Marshall and Bob Margolis
; Interesting spirals with Bailout of 4,
; and functions of ident, conj, log, acosh and asinh.
; Cabs, abs, cotanh, tan, asinh and cosh also yield very
; interesting results.  Increased bailout values yield complex
; images try 8, 16 as alternate bailout values.

  init:

  z = pixel
  c = @seed

  loop:
  
  float x = Real(z)
  float y = Imag(z)
  float g = real(@seed)
  
  if @ztweaker == "z=orig"
    z = z
  elseif @ztweaker == "z=z+c"
    z = fn1(z) + fn2(c)
  elseif @ztweaker == "z=z+x"
    z = fn1(z) + fn2(x)
  elseif @ztweaker == "z=z+y"
    z = fn1(z) + fn2(y)
  elseif @ztweaker == "z=z+g"
    z = fn1(z) + fn2(g)
  elseif @ztweaker == "z=z*c"
    z = fn1(z) * fn2(c)
  elseif @ztweaker == "z=z*x"
    z = fn1(z) * fn2(x)
  elseif @ztweaker == "z=z*g"
    z = fn1(z) * fn2(g)
  elseif @ztweaker == "z=z/c"
    z = fn1(z) / fn2(c) 
  elseif @ztweaker == "z=z/g"
    z = fn1(z) / fn2(g) 
  elseif @ztweaker == "z=z/x+z"
    z = fn1(z) / fn2(x) + fn3(z)
  elseif @ztweaker == "z=z/c+c"
    z = fn1(z) / fn2(c) + fn3(c)
  elseif @ztweaker == "z=z/g+c"
    z = fn1(z) / fn2(g) + fn3(c)
  elseif @ztweaker == "z=z-c"
    z = fn1(z) - fn2(c)
  elseif @ztweaker == "z=z-g"
    z = fn1(z) - fn2(g)
  elseif @ztweaker == "z=c-z"
    z = fn1(c) - fn2(z) 
  elseif @ztweaker == "z=g-z"
    z = fn1(g) - fn2(z) 
  elseif @ztweaker == "z=z/c-z"
    z = fn1(z) / fn2(c) - fn3(z)
  elseif @ztweaker == "z=z/g-z"
    z = fn1(z) / fn2(g) - fn3(z)
  elseif @ztweaker == "z=z/c-c"
    z = fn1(z) / fn2(c) - fn3(c)
  elseif @ztweaker == "z=z/g-c"
    z = fn1(z) / fn2(g) - fn3(c)  
  elseif @ztweaker == "z=z-z/c"
    z = fn1(z) - fn2(z) / fn3(c) 
  elseif @ztweaker == "z=z-z/x"
    z = fn1(z) - fn2(z) / fn3(x) 
  elseif @ztweaker == "z=z-z/g"
    z = fn1(z) - fn2(z) / fn3(g)
  elseif @ztweaker == "z=c-z/c"
    z = fn1(c) - fn2(z) / fn3(c) 
  elseif @ztweaker == "z=c-z/g"
    z = fn1(c) - fn2(z) / fn3(g) 
  elseif @ztweaker == "z=c/z"
    z = fn1(c) / fn2(z)   
  elseif @ztweaker == "z*z+c"
    z = fn1(z) * fn2(z) + fn3(c)
  elseif @ztweaker == "z=g/z"
    z = fn1(g) / fn2(z) 
  elseif @ztweaker == "ezz"
    z = e^fn1(z)* fn2(z)  
  elseif @ztweaker == "ez/z"
    z = e^fn1(z)/ fn2(z)   
  elseif @ztweaker == "ey/z"
    z = e^fn1(y)/ fn2(z)
  elseif @ztweaker == "eyz"
    z = e^fn1(y)* fn2(z)    
  elseif @ztweaker == "z/1-z"
    z = fn1(z)/(1- fn2(z))
  elseif @ztweaker == "z/1-x"
    z = fn1(z)/(1-fn2(x)) 
  elseif @ztweaker == "z/1-y"
    z = fn1(z)/(1-fn2(y))  
  elseif @ztweaker == "zpi"
    z = z ^ #pi  
  elseif @ztweaker == "zpi/z"
    z = z ^ #pi / z^2   
  elseif @ztweaker == "z^pi/z^z"
    z = z ^ #pi / z^z  
  elseif @ztweaker == "z/pixel"
    z = z / #pixel  
  elseif @ztweaker == "zpixel"
    z = z * #pixel  
  elseif @ztweaker == "z^pixel/z+pixel"
    z = z ^ #pixel /z + pixel  
  elseif @ztweaker == "ez/zpixel"
    z = e^z /(z+ #pixel) 
  elseif @ztweaker == "ez/pixel"
    z = e^z /#pixel
  elseif @ztweaker == "piz/pixel"
    z = z^#pi / #pixel  
  elseif @ztweaker == "piz/zpixel"
    z = z^#pi /(z + #pixel)  
  elseif @ztweaker == "z+zpixel"
    z = z + #pixel   
  elseif @ztweaker == "z-zpixel"
    z = z - #pixel 
  elseif @ztweaker == "z/zpixel"
    z = z /(z+#pixel)
  elseif @ztweaker == "z/pixelz"
    z = z /#pixel^z
  elseif @ztweaker == "ez/pixel"
    z = e^z/#pixel
  elseif @ztweaker == "c/ez"
    z  = fn1(c / (#e * fn2(z)))
  elseif @ztweaker == "z+c/g"
    z  = fn1(fn2(z) + c / g )
  elseif @ztweaker == "x+z/y+c"
    z  = (fn1(x) + z) / (fn2(y) + c)
  elseif @ztweaker == "g^z-c"
    z  = fn2(g ^ (fn1(z) )) - c
  elseif @ztweaker == "z-x+y/x-y"
    z  = fn1(z) - p2 + fn2((x+y)/(x-y))
  elseif @ztweaker == "g/c-z"
    z  = fn1(( g )/ (c - fn2(z)))
  elseif @ztweaker == "y+c/g"
    z  = fn1(fn2(y) + c / g )
  elseif @ztweaker == "x+y/y+c"
    z  = (fn1(x) + y) / (fn2(y) + c)
  elseif @ztweaker == "g^y-c"
    z  = fn2(g ^ (fn1(y) )) - c
  elseif @ztweaker == "y-x+y/x-y"
    z  = fn1(y) - p2 + fn2((x+y)/(x-y))
  elseif @ztweaker == "g/c-y"
    z  = fn1(( g )/ (c - fn2(y)))
  elseif @ztweaker == "c/ex"
    z  = fn1(c / (#e * fn2(x)))
  elseif @ztweaker == "x+c/g"
    z  = fn1(fn2(x) + c / g )
  elseif @ztweaker == "g^x-c"
    z  = fn2(g ^(fn1(x))) - c
  endif   

  if @version > 1.0
 
  if @style == "z"
    z = fn1((z-p1)*p2)
  elseif @style == "fn(z^(2+power))"
    z = fn1((z-p1)*p2)^fn2(2+ @p3) + fn3(c)
  elseif @style == "fn(x-y)"
    z = fn1((z-p1)*p2)^fn2(2+ @p3) + fn1(x-y) + fn3(c)
  elseif @style == "(fn(y-x))"
    z = fn1((z-p1)*p2)^fn2(2+ @p3+ fn1(y-x)) + fn3(c)
  elseif @style =="(fn(x^2-y^2))"
    z = fn1((z-p1)*p2)^fn2(2+ @p3+ fn1(y^2-x^2)) + fn3(c)
  elseif @style =="fn(x^2-y^2)"
    z = fn1((z-p1)*p2)^fn2(2+ @p3)+ fn1(y^2-x^2) + fn3(c)
  elseif @style =="fn(x^e)"
    z = fn1(x)^fn2(e) + fn3(c)
  elseif @style =="fn(y^e)"
    z = fn1(y)^fn2(e) + fn3(c)
  elseif @style =="fn(x^pi)"
    z = fn1(x)^fn2(#pi)+fn3(c)
  elseif @style =="fn(y^pi)"
    z = fn1(y)^fn2(#pi) +fn3(c)
  elseif @style =="fn(z-x)^fn(z-y)"
    z = fn1(z-x)^fn2(z-y)+fn3(c)
  elseif @style =="fn(z+x)^fn(z+y)"
    z = fn1(z+x)^fn2(z+y)+fn3(c)
  endif  

 if @inv == true
    z = 1/z
  else
    z = z
  endif
  
  if @zpix == true
    z = ((pixel-p1)*p2)^(2+ @p3)  
  else
    z = z
  endif
  
  if @xplus == true
     z = ((z-p1)*p2)^(2+ @p3) + x
  else
    z = z
  endif

  if @yplus == true
    z = ((z-p1)*p2)^(2+ @p3) + y
  else
    z = z
  endif

  if @zpower == true
    z = ((z-p1)*p2)^(2+ @p3) ^ z
  else
    z = z
  endif

  if @xpower == true
    z = ((z-p1)*p2)^(2+ @p3)^x
  else
    z = z
  endif

  if @ypower == true
    z = ((z-p1)*p2)^(2+ @p3)^y
  else
    z = z
  endif

  if @gpower == true ; hpower showed no effect
    z = ((z-p1)*p2)^(2+ @p3)^g
  else
    z = z
  endif
  
  if @gplus == true ; hplus showed no effect
    z = ((z-p1)*p2)^(2+ @p3) + g
  else
    z = z
  endif

  if @func1 == true
    z = fn1((z-p1)*p2)
  else
    z = z
  endif
 
  if @func2 == true
    z = fn2(fn1((z-p1)*p2))
  else
    z = z
  endif

  if @func3 == true
    z = fn3(fn2(fn1((z-p1)*p2)))
  else
    z = z
  endif

  if @funcpowerz == true
    z = ((z-p1)*p2)^fn1(z)
  else
    z = z
  endif

  if @funcpowerx == true
    z = ((z-p1)*p2)^fn1(x)
  else
    z = z
  endif

  if @funcpowery == true
    z = ((z-p1)*p2)^fn1(y)
  else
    z = z
  endif

  if @funcpowerg == true ; funcpowerh no effect
    z = ((z-p1)*p2)^fn1(g)
  else
    z = z
  endif
  
  if @ez == true 
    z = e^z
  else
    z = z
  endif

  if @zpi == true 
    z = z^#pi
  else
    z = z
  endif
  
  if @ztopidivzpi == true 
    z = z^#pi/(z*#pi)
  else
    z = z
  endif

  if @zpidivztopi == true 
    z = z*#pi/(z^#pi)
  else
    z = z
  endif

  if @flavor == "z"
    z = fn1((z-p1)*p2)
  elseif @flavor == "z^2 + c"
    z = fn1((z-p1)*p2)^fn3(2+ @p3) + fn3(c)
  elseif @flavor == "z^(z/c)"
    z = fn1((z-p1)*p2)^fn2((z-p1)*p2) + fn3(@p3/c)
  elseif @flavor == "z/(z-1)"
    z = fn1((z-p1)*p2)/fn2(((z-p1)*p2) -1) + fn3(@p3*c)
  elseif @flavor == "z^2/(z-1)"
    z = fn1((z-p1)*p2)^(2+ @p3)/fn2(((z-p1)*p2) -1) + fn3(@p3*c)
  elseif @flavor == "z^3/(z^2-1)"
    z = fn1((z-p1)*p2)^(3+ @p3)/fn2(((z-p1)*p2)^(2+ @p3) -1)\
     +fn3(@p3*c)
  elseif @flavor == "z^3*c/(z^2-c)"
    z = fn1((z-p1)*p2)^(3+ @p3)*c/fn2(((z-p1)*p2)^(2+@p3) - c)\
     - fn3(@p3*c) 
  elseif @flavor == "z^3+z^2+z+c"
    z = fn1((z-p1)*p2)^(3+ @p3)+((z-p1)*p2)^(2+ @p3)+fn2((z-p1)*p2)\
    ^(2+ @p3)+ fn3(@p3*c) 
  elseif @flavor == "fnzfnzfnz"
    z = fn1((z-p1)*p2)*fn2((z-p1)*p2)*fn3((z-p1)*p2) + @p3*c  
  elseif @flavor == "fnzpfnzpfnzp"
    z = fn1((z-p1)*p2)^(2+ @p3)*fn2((z-p1)*p2)^(2+ @p3)*fn3((z-p1)\
    ^(2+ @p3)*p2) + @p3*c
  elseif @flavor == "fnzfnz/fnz"
    z = fn1((z-p1)*p2)*fn2((z-p1)*p2)/fn3((z-p1)*p2) + @p3*c  
  elseif @flavor == "fnzpfnzp/fnzp"
    z = fn1((z-p1)*p2)^(2+ @p3)*fn2((z-p1)*p2)^(2+ @p3)/fn3((z-p1)\
    ^(2+ @p3)*p2) + @p3*c
   elseif @flavor == "zzz"
    z = fn1((z-p1)*p2)*fn2((z-p1)*p2)*fn3((z-p1)*p2) + @p3*c  
  elseif @flavor == "z^pz^pz^p"
    z = fn1((z-p1)*p2)^(2+ @p3)*fn2((z-p1)*p2)^(2+ @p3)*fn3((z-p1)\
    ^(2+ @p3)*p2) + @p3*c
  elseif @flavor == "zz/z"
    z = fn1((z-p1)*p2)*fn2((z-p1)*p2)/fn3(z-p1)+ @p3*c
  elseif @flavor == "z^pz^p/z^p"
    z = fn1((z-p1)*p2)^(2+ @p3)*fn2((z-p1)*p2)^(2+ @p3)/fn3((z-p1)\
    ^(2+ @p3)*p2) + @p3*c
  elseif @flavor == "z^3-z^2+c"
    z = fn1((z-p1)*p2)^(3+ @p3)-fn2((z-p1)*p2)^(2+ @p3)+ fn3(@p3*c) 
  endif
  
  if @cchange == "Orig"
    c = c^@expC 
  elseif @cchange == "Real"
    c = real(c)^@expC
  elseif @cchange == "Imag"
    c = imag(c)^@expC
  elseif @cchange == "Sign"
    c = -c^@expC
  elseif @cchange == "Squared"
    c = c^2+@expC  
  elseif @cchange == "Exponent"
    c = e^c^@expC
  elseif @cchange == "Inverse"
    c = 1 / c^@expC
  elseif @cchange == "Inv/Exp"  
    c = 1 / e^c^@expC
  elseif @cchange == "C/Exp"
    c = c^@expC / e^c^@expC
  elseif @cchange == "SQRPixel"
    c = sqr(pixel)/3 
  elseif @cchange == "CPower"
    c = c^c  
  elseif @cchange == "EPower"
    c = c^(e+c)   
  elseif @cchange == "ZPower"
    c = c^z   
  elseif @cchange == "CPower3"
    c = c^c^c   
  elseif @cchange == "CFunction"
    c = c^((z-@p1)*@p2)^@fnc(2 + @p3)  
  elseif @cchange == "Function"
    c = @fnc(c^@expC)  
  endif  
  endif 
 
  if @op == "+"
    z = @fn3(c/(z^@power + c + z^@fn1(z)+ @fn2(c)))
  elseif @op == "-"
    z = @fn3(c/(z^@power + c + z^@fn1(z)- @fn2(c)))
  elseif @op == "*"
    z = @fn3(c/(z^@power + c + z^@fn1(z)* @fn2(c)))
  elseif @op == "/"
    z = @fn3(c/(z^@power + c + z^@fn1(z)/ @fn2(c)))
  elseif @op == "^"
    z = @fn3(c/(z^@power + c + z^@fn1(z)^ @fn2(c)))
  elseif @op == "sin"
   z = @fn3(c/(z^@power + c + z^@fn1(z)^ sin(@fn2(c))))
  elseif @op == "sinh"
   z = @fn3(c/(z^@power + c + z^@fn1(z)^ sinh(@fn2(c))))
  elseif @op == "asin"
   z = @fn3(c/(z^@power + c + z^@fn1(z)^ asin(@fn2(c))))
  elseif @op == "asinh"
   z = @fn3(c/(z^@power + c + z^@fn1(z)^ asinh(@fn2(c))))
  elseif @op == "cos"
   z = @fn3(c/(z^@power + c + z^@fn1(z)^ cos(@fn2(c))))
  elseif @op == "cosh"
   z = @fn3(c/(z^@power + c + z^@fn1(z)^ cosh(@fn2(c))))
  elseif @op == "acos"
   z = @fn3(c/(z^@power + c + z^@fn1(z)^ acos(@fn2(c))))
  elseif @op == "acosh"
   z = @fn3(c/(z^@power + c + z^@fn1(z)^ acosh(@fn2(c))))
  elseif @op == "tan"
   z = @fn3(c/(z^@power + c + z^@fn1(z)^ tan(@fn2(c))))
  elseif @op == "atan"
   z = @fn3(c/(z^@power + c + z^@fn1(z)^ atan(@fn2(c))))
  elseif @op == "tanh"
   z = @fn3(c/(z^@power + c + z^@fn1(z)^ tanh(@fn2(c))))
  elseif @op == "atanh"
    z = @fn3(c/(z^@power + c + z^@fn1(z)^ atanh(@fn2(c))))
  elseif @op == "cotan"
    z = @fn3(c/(z^@power + c + z^@fn1(z)^ cotan(@fn2(c))))
  elseif @op == "cotanh"
    z = @fn3(c/(z^@power + c + z^@fn1(z)^ cotanh(@fn2(c))))
  elseif @op == "sqr"
   z = @fn3(c/(z^@power + c + z^@fn1(z)^ sqr(@fn2(c))))
  elseif @op == "sqrt"
   z = @fn3(c/(z^@power + c + z^@fn1(z)^ sqrt(@fn2(c))))
  elseif @op == "log"
   z = @fn3(c/(z^@power + c + z^@fn1(z)^ log(@fn2(c))))
  elseif @op == "exp"
    z = @fn3(c/(z^@power + c + z^@fn1(z)^ exp(@fn2(c))))
  elseif @op == "abs"
   z = @fn3(c/(z^@power + c + z^@fn1(z)^ abs(@fn2(c))))
  elseif @op == "cabs"
   z = @fn3(c/(z^@power + c + z^@fn1(z)^ cabs(@fn2(c))))
  elseif @op == "conj"
   z = @fn3(c/(z^@power + c + z^@fn1(z)^ conj(@fn2(c))))
  elseif @op == "flip"
   z = @fn3(c/(z^@power + c + z^@fn1(z)^ flip(@fn2(c))))
  elseif @op == "ident"
   z = @fn3(c/(z^@power + c + z^@fn1(z)^ ident(@fn2(c))))
  elseif @op == "zero"
   z = @fn3(c/(z^@power + c + z^@fn1(z)^ zero(@fn2(c))))
  elseif @op == "recip"
   z = @fn3(c/(z^@power + c + z^@fn1(z)^ recip(@fn2(c))))
  elseif @op == "ceil"
   z = @fn3(c/(z^@power + c + z^@fn1(z)^ ceil(@fn2(c)))) 
  elseif @op == "floor"
   z = @fn3(c/(z^@power + c + z^@fn1(z)^ floor(@fn2(c))))
  elseif @op == "trunc"
   z = @fn3(c/(z^@power + c + z^@fn1(z)^ trunc(@fn2(c))))
  elseif @op == "round"
   z = @fn3(c/(z^@power + c + z^@fn1(z)^ round(@fn2(c))))
  endif

  bailout:

    (@bailchoice == 0 && |z| <= @bailout) ||                                         \
    (@bailchoice == 1 && real(sqr(z)) <= @bailout) ||                                \
    (@bailchoice == 2 && imag(sqr(z)) <= @bailout) ||                                \
    (@bailchoice == 3 && sqr(real(z)) <= @bailout) ||                                \
    (@bailchoice == 4 && sqr(imag(z)) <= @bailout) ||                                \
    (@bailchoice == 5 && (sqr(real(z)) <= @bailout && sqr(imag(z)) < @bailout)) ||   \
    (@bailchoice == 6 && (sqr(real(z)) <= @bailout || sqr(imag(z)) < @bailout)) ||   \
    (@bailchoice == 7 && (sqr(abs(real(z)) + abs(imag(z))) <= @bailout)) ||          \
    (@bailchoice == 8 && (sqr(real(z) + imag(z)) <= @bailout))

  default:
    title = "Julia Plus 4"
    periodicity = 0    
  
  param bailout
    caption = "Bailout value"
    default = 4.0
    min = 1.0
  endparam
  
    param bailchoice
    caption = "Bailout Choice"
    default = 0
    enum = "|z|" "Real(Z^2)""Imag(Z^2)""Real(Z)^2""Imag(Z)^2"\
     "Real & Imag""Real or Imag""Sqr(Abs(Real&Imag)" "Sqr(Real&Imag)"
  endparam

  param seed
    caption= "Julia seed"
    default = (-1.25,0)
  endparam

  param power
    caption = "Power"
    default = (2,0)
  endparam
  
  param p1
    caption = "Subtracter"
    default = (0,0)
  endparam

  param p2
    caption = "Mulitplier"
    default = (1,0)
  endparam    

  param p3
    caption = "Power"
    default = (0,0)
  endparam  

  param op
    caption = "Operator"
      enum = "+""-""*""/""^""sin""sinh""asin""asinh"\
    "cos""cosh""acos""acosh""tan""tanh""atan""atanh"\
    "cotan""cotanh""sqr""sqrt""log""exp"\
    "abs""cabs""conj""flip""ident""zero""recip" \
    "ceil""floor""trunc" "round"
    default = 3
  endparam

  param ztweaker
    caption = "Z Tweaker"
    enum = "z=orig""z=z+c""z=z+x""z=z+y""z=z+g"\
    "z=z*c""z=z*x""z=z*g""z=z/c""z=z/g"\
    "z=z/x+z""z=z/c+c""z=z/g+c""z=z-c""z=z-g""z=c-z"\
    "z=g-z""z=z/c-z""z=z/g-z""z=z/c-c""z=z/x-c"\
    "z=z/g-c""z=z-z/c""z=z-z/x""z=z-z/g""z=c-z/c"\
    "z=c-z/g""z=c/z""z=g/z""z*z+c"\
    "ezz""ez/z""exz""eyz""ey/z""z/1-z""z/1-x""z/1-y"\
    "zpi""zpi/z""z^pi/z^z""zpixel""z/pixelz"\
    "z/zpixel""z^pixel/z+pixel""ez/zpixel""z/pixel""piz/pixel"\
    "piz/zpixel""z-zpixel""ez/pixel""z+zpixel"\
    "c/ez""z+c/g""x+z/y+c""g^z-c""z-x+y/x-y""g/c-z"\
    "y+c/g""x+y/y+c""g^y-c""y-x+y/x-y""g/c-y"\    
    "g/c-x""g^x-c""x+c/g""c/ex"
    default = 0
  endparam
  
  param style
    caption = "Variation in Style"
    enum = "z""fn(z^(2+power))""fn(x-y)""fn(y-x)"\
    "fn(x^2-y^2)""(fn(y-x))" "(fn(x^2-y^2))"\
    "fn(x^e)""fn(y^e)""fn(x^pi)""fn(y^pi)"\
    "fn(z-x)^fn(z-y)""fn(z+x)^fn(z+y)"   
    default = 0
  endparam 

 bool param inv
    caption = "Invert Z"
    default = false
  endparam  

  bool param zpix
    caption = "Z=Pixel"
    default = false
  endparam  

  bool param xplus
    caption = "Add X"
    default = false
  endparam 

  bool param yplus
    caption = "Add Y"
    default = false
  endparam 

  bool param Zpower
    caption = "Z^Z"
    default = false
  endparam 

  bool param Xpower
    caption = "Z^X"
    default = false
  endparam 

  bool param Ypower
    caption = "Z^Y"
    default = false
  endparam 

  bool param Gpower
    caption = "Z^G"
    default = false
  endparam 

  bool param Gplus
    caption = "Z+G"
    default = false
  endparam 

  bool param func1
    caption = "Fn(Z)"
    default = false
  endparam 

  bool param func2
    caption = "Fn2(Fn1(Z))"
    default = false
  endparam 
  
  bool param func3
    caption = "Fn3(Fn2(Fn1(Z)))"
    default = false
  endparam 
  
  bool param funcpowerz
    caption = "Function Power"
    default = false
  endparam  

  bool param funcpowerx
    caption = "Function Power of X"
    default = false
  endparam 

  bool param funcpowery
    caption = "Function Power of Y"
    default = false
  endparam  

  bool param funcpowerg
    caption = "Function Power of G"
    default = false
  endparam 
  
  bool param ez 
    caption = "Euler times Z"
   default = false
  endparam 

  bool param zpi  
   caption = "Pi times Z"
   default = false
  endparam 

  bool param ztopidivzpi  
   caption = "Z^Pi/Z*Pi"
   default = false
  endparam 
  
  bool param zpidivztopi
   caption = "Z*Pi/Z^Pi"
   default = false
  endparam 

  param cchange
    caption = "Nuance of C"
    enum = "Orig""Real""Imag""Sign""Squared"\
    "Exponent""Inverse""Inv/Exp""C/Exp"\
    "SQRPixel""CPower""EPower""ZPower"\
    "CPower3""CFunction""Function"
    default = 0
  endparam
  
  func fnc
    caption = "C Function"
    default = sqr()
    visible = @cchange == "Function" ||\
    @cchange == "CFunction"
  endfunc

  float param expC
    caption = "Power of C"
    default = 1.0
  endparam
  
    param flavor
    caption = "Formula Flavor"
    enum = "z""z^2 + c""z^(z/c)""z/(z-1)""z^2/(z-1)""z^3/(z^2-1)"\
    "z^3*c/(z^2-c)""z^3+z^2+z+c""fnzfnzfnz""fnzpfnzpfnzp"\
    "fnzfnz/fnz""fnzpfnzp/fnzp""zzz""z^pz^pz^p"\
    "zz/z""z^pz^p/z^p""z^3-z^2+c"
    default = 0
  endparam
  
  heading
    caption = "Functions"
  endheading

  func fn1
    caption = "Function 1"
    default = ident()
  endfunc

  func fn2
    caption = "Function 2"
    default = ident()
  endfunc

  func fn3
    caption = "Function 3"
    default = ident()
  endfunc

  param version
    caption = "Version"
    default = 2.0
  endparam  

  switch:
    type = "MandelbrotPlus4"
    bailout = @bailout 
    op = @op
    fn1 = @fn1
    fn2 = @fn2
    fn3 = @fn3
    power = #pixel
    inv = @inv 
    fn1 = @fn1
    fn2 = @fn2
    fn3 = @fn3
    xpower = @xpower
    ypower = @ypower
    zpower = @zpower
    gpower = @gpower
    x = @x
    y = @y
    g = @g
    gplus = @gplus
    xplus = @xplus
    yplus = @yplus
    func1 = @func1
    func2 = @func2
    func3 = @func3
    p1 = @p1
    p2 = @p2
    p3 = @p3
    funcpowerx = @funcpowerx
    funcpowery = @funcpowery
    funcpowerz = @funcpowerz
    funcpowerg = @funcpowerg
    fnc = @fnc
    expC = @expC
    style = @style
    ztweaker = @ztweaker
    bailchoice = @bailchoice
    cchange = @cchange
    flavor = @flavor
    zpix = @zpix
    inv = @inv
    ez = @ez
    zpi = @zpi
    ztopidivzpi = ztopidivzpi
    zpidivztopi = @zpidivztopi 

  }

=============================================================

MandelbrotPlus4{
; Version 2.0 Added ztweaker
; By Dolf De Rovira 2-18-04 
; With much thanks from Toby Marshall and Bob Margolis 

  init:

  z = @start
  c = #pixel
  
  loop:
  
  float x = Real(z)
  float y = Imag(z)
  float g = real(#pixel)
  
  if @ztweaker == "z=orig"
    z = z
  elseif @ztweaker == "z=z+c"
    z = fn1(z) + fn2(c)
  elseif @ztweaker == "z=z+x"
    z = fn1(z) + fn2(x)
  elseif @ztweaker == "z=z+y"
    z = fn1(z) + fn2(y)
  elseif @ztweaker == "z=z+g"
    z = fn1(z) + fn2(g)
  elseif @ztweaker == "z=z*c"
    z = fn1(z) * fn2(c)
  elseif @ztweaker == "z=z*x"
    z = fn1(z) * fn2(x)
  elseif @ztweaker == "z=z*g"
    z = fn1(z) * fn2(g)
  elseif @ztweaker == "z=z/c"
    z = fn1(z) / fn2(c) 
  elseif @ztweaker == "z=z/g"
    z = fn1(z) / fn2(g) 
  elseif @ztweaker == "z=z/x+z"
    z = fn1(z) / fn2(x) + fn3(z)
  elseif @ztweaker == "z=z/c+c"
    z = fn1(z) / fn2(c) + fn3(c)
  elseif @ztweaker == "z=z/g+c"
    z = fn1(z) / fn2(g) + fn3(c)
  elseif @ztweaker == "z=z-c"
    z = fn1(z) - fn2(c)
  elseif @ztweaker == "z=z-g"
    z = fn1(z) - fn2(g)
  elseif @ztweaker == "z=c-z"
    z = fn1(c) - fn2(z) 
  elseif @ztweaker == "z=g-z"
    z = fn1(g) - fn2(z) 
  elseif @ztweaker == "z=z/c-z"
    z = fn1(z) / fn2(c) - fn3(z)
  elseif @ztweaker == "z=z/g-z"
    z = fn1(z) / fn2(g) - fn3(z)
  elseif @ztweaker == "z=z/c-c"
    z = fn1(z) / fn2(c) - fn3(c)
  elseif @ztweaker == "z=z/g-c"
    z = fn1(z) / fn2(g) - fn3(c)  
  elseif @ztweaker == "z=z-z/c"
    z = fn1(z) - fn2(z) / fn3(c) 
  elseif @ztweaker == "z=z-z/x"
    z = fn1(z) - fn2(z) / fn3(x) 
  elseif @ztweaker == "z=z-z/g"
    z = fn1(z) - fn2(z) / fn3(g)
  elseif @ztweaker == "z=c-z/c"
    z = fn1(c) - fn2(z) / fn3(c) 
  elseif @ztweaker == "z=c-z/g"
    z = fn1(c) - fn2(z) / fn3(g) 
  elseif @ztweaker == "z=c/z"
    z = fn1(c) / fn2(z)   
  elseif @ztweaker == "z*z+c"
    z = fn1(z) * fn2(z) + fn3(c)
  elseif @ztweaker == "z=g/z"
    z = fn1(g) / fn2(z) 
  elseif @ztweaker == "ezz"
    z = e^fn1(z)* fn2(z)  
  elseif @ztweaker == "ez/z"
    z = e^fn1(z)/ fn2(z)   
  elseif @ztweaker == "ey/z"
    z = e^fn1(y)/ fn2(z)
  elseif @ztweaker == "eyz"
    z = e^fn1(y)* fn2(z)    
  elseif @ztweaker == "z/1-z"
    z = fn1(z)/(1- fn2(z))
  elseif @ztweaker == "z/1-x"
    z = fn1(z)/(1-fn2(x)) 
  elseif @ztweaker == "z/1-y"
    z = fn1(z)/(1-fn2(y))  
  elseif @ztweaker == "zpi"
    z = z ^ #pi  
  elseif @ztweaker == "zpi/z"
    z = z ^ #pi / z^2   
  elseif @ztweaker == "z^pi/z^z"
    z = z ^ #pi / z^z  
  elseif @ztweaker == "z/pixel"
    z = z / #pixel  
  elseif @ztweaker == "zpixel"
    z = z * #pixel  
  elseif @ztweaker == "z^pixel/z+pixel"
    z = z ^ #pixel /z + pixel  
  elseif @ztweaker == "ez/zpixel"
    z = e^z /(z+ #pixel) 
  elseif @ztweaker == "ez/pixel"
    z = e^z /#pixel
  elseif @ztweaker == "piz/pixel"
    z = z^#pi / #pixel  
  elseif @ztweaker == "piz/zpixel"
    z = z^#pi /(z + #pixel)  
  elseif @ztweaker == "z+zpixel"
    z = z + #pixel   
  elseif @ztweaker == "z-zpixel"
    z = z - #pixel 
  elseif @ztweaker == "z/zpixel"
    z = z /(z+#pixel)
  elseif @ztweaker == "z/pixelz"
    z = z /#pixel^z
  elseif @ztweaker == "ez/pixel"
    z = e^z/#pixel
  elseif @ztweaker == "c/ez"
    z  = fn1(c / (#e * fn2(z)))
  elseif @ztweaker == "z+c/g"
    z  = fn1(fn2(z) + c / g )
  elseif @ztweaker == "x+z/y+c"
    z  = (fn1(x) + z) / (fn2(y) + c)
  elseif @ztweaker == "g^z-c"
    z  = fn2(g ^ (fn1(z) )) - c
  elseif @ztweaker == "z-x+y/x-y"
    z  = fn1(z) - p2 + fn2((x+y)/(x-y))
  elseif @ztweaker == "g/c-z"
    z  = fn1(( g )/ (c - fn2(z)))
  elseif @ztweaker == "y+c/g"
    z  = fn1(fn2(y) + c / g )
  elseif @ztweaker == "x+y/y+c"
    z  = (fn1(x) + y) / (fn2(y) + c)
  elseif @ztweaker == "g^y-c"
    z  = fn2(g ^ (fn1(y) )) - c
  elseif @ztweaker == "y-x+y/x-y"
    z  = fn1(y) - p2 + fn2((x+y)/(x-y))
  elseif @ztweaker == "g/c-y"
    z  = fn1(( g )/ (c - fn2(y)))
  elseif @ztweaker == "c/ex"
    z  = fn1(c / (#e * fn2(x)))
  elseif @ztweaker == "x+c/g"
    z  = fn1(fn2(x) + c / g )
  elseif @ztweaker == "g^x-c"
    z  = fn2(g ^(fn1(x))) - c
  endif 

 if @version > 1.0
 
  if @style == "z"
    z = fn1((z-p1)*p2)
  elseif @style == "fn(z^(2+power))"
    z = fn1((z-p1)*p2)^fn2(2+ @p3) + fn3(c)
  elseif @style == "fn(x-y)"
    z = fn1((z-p1)*p2)^fn2(2+ @p3) + fn1(x-y) + fn3(c)
  elseif @style == "(fn(y-x))"
    z = fn1((z-p1)*p2)^fn2(2+ @p3+ fn1(y-x)) + fn3(c)
  elseif @style =="(fn(x^2-y^2))"
    z = fn1((z-p1)*p2)^fn2(2+ @p3+ fn1(y^2-x^2)) + fn3(c)
  elseif @style =="fn(x^2-y^2)"
    z = fn1((z-p1)*p2)^fn2(2+ @p3)+ fn1(y^2-x^2) + fn3(c)
  elseif @style =="fn(x^e)"
    z = fn1(x)^fn2(e) + fn3(c)
  elseif @style =="fn(y^e)"
    z = fn1(y)^fn2(e) + fn3(c)
  elseif @style =="fn(x^pi)"
    z = fn1(x)^fn2(#pi)+fn3(c)
  elseif @style =="fn(y^pi)"
    z = fn1(y)^fn2(#pi) +fn3(c)
  elseif @style =="fn(z-x)^fn(z-y)"
    z = fn1(z-x)^fn2(z-y)+fn3(c)
  elseif @style =="fn(z+x)^fn(z+y)"
    z = fn1(z+x)^fn2(z+y)+fn3(c)
  endif  

 if @inv == true
    z = 1/z
  else
    z = z
  endif
  
  if @zpix == true
    z = ((pixel-p1)*p2)^(2+ @p3)  
  else
    z = z
  endif
  
  if @xplus == true
     z = ((z-p1)*p2)^(2+ @p3) + x
  else
    z = z
  endif

  if @yplus == true
    z = ((z-p1)*p2)^(2+ @p3) + y
  else
    z = z
  endif

  if @zpower == true
    z = ((z-p1)*p2)^(2+ @p3) ^ z
  else
    z = z
  endif

  if @xpower == true
    z = ((z-p1)*p2)^(2+ @p3)^x
  else
    z = z
  endif

  if @ypower == true
    z = ((z-p1)*p2)^(2+ @p3)^y
  else
    z = z
  endif

  if @gpower == true ; hpower showed no effect
    z = ((z-p1)*p2)^(2+ @p3)^g
  else
    z = z
  endif
  
  if @gplus == true ; hplus showed no effect
    z = ((z-p1)*p2)^(2+ @p3) + g
  else
    z = z
  endif

  if @func1 == true
    z = fn1((z-p1)*p2)
  else
    z = z
  endif
 
  if @func2 == true
    z = fn2(fn1((z-p1)*p2))
  else
    z = z
  endif

  if @func3 == true
    z = fn3(fn2(fn1((z-p1)*p2)))
  else
    z = z
  endif

  if @funcpowerz == true
    z = ((z-p1)*p2)^fn1(z)
  else
    z = z
  endif

  if @funcpowerx == true
    z = ((z-p1)*p2)^fn1(x)
  else
    z = z
  endif

  if @funcpowery == true
    z = ((z-p1)*p2)^fn1(y)
  else
    z = z
  endif

  if @funcpowerg == true ; funcpowerh no effect
    z = ((z-p1)*p2)^fn1(g)
  else
    z = z
  endif
  
  if @ez == true 
    z = e^z
  else
    z = z
  endif

  if @zpi == true 
    z = z^#pi
  else
    z = z
  endif
  
  if @ztopidivzpi == true 
    z = z^#pi/(z*#pi)
  else
    z = z
  endif

  if @zpidivztopi == true 
    z = z*#pi/(z^#pi)
  else
    z = z
  endif

  if @flavor == "z"
    z = fn1((z-p1)*p2)
  elseif @flavor == "z^2 + c"
    z = fn1((z-p1)*p2)^fn3(2+ @p3) + fn3(c)
  elseif @flavor == "z^(z/c)"
    z = fn1((z-p1)*p2)^fn2((z-p1)*p2) + fn3(@p3/c)
  elseif @flavor == "z/(z-1)"
    z = fn1((z-p1)*p2)/fn2(((z-p1)*p2) -1) + fn3(@p3*c)
  elseif @flavor == "z^2/(z-1)"
    z = fn1((z-p1)*p2)^(2+ @p3)/fn2(((z-p1)*p2) -1) + fn3(@p3*c)
  elseif @flavor == "z^3/(z^2-1)"
    z = fn1((z-p1)*p2)^(3+ @p3)/fn2(((z-p1)*p2)^(2+ @p3) -1)\
     +fn3(@p3*c)
  elseif @flavor == "z^3*c/(z^2-c)"
    z = fn1((z-p1)*p2)^(3+ @p3)*c/fn2(((z-p1)*p2)^(2+@p3) - c)\
     - fn3(@p3*c) 
  elseif @flavor == "z^3+z^2+z+c"
    z = fn1((z-p1)*p2)^(3+ @p3)+((z-p1)*p2)^(2+ @p3)+fn2((z-p1)*p2)\
    ^(2+ @p3)+ fn3(@p3*c) 
  elseif @flavor == "fnzfnzfnz"
    z = fn1((z-p1)*p2)*fn2((z-p1)*p2)*fn3((z-p1)*p2) + @p3*c  
  elseif @flavor == "fnzpfnzpfnzp"
    z = fn1((z-p1)*p2)^(2+ @p3)*fn2((z-p1)*p2)^(2+ @p3)*fn3((z-p1)\
    ^(2+ @p3)*p2) + @p3*c
  elseif @flavor == "fnzfnz/fnz"
    z = fn1((z-p1)*p2)*fn2((z-p1)*p2)/fn3((z-p1)*p2) + @p3*c  
  elseif @flavor == "fnzpfnzp/fnzp"
    z = fn1((z-p1)*p2)^(2+ @p3)*fn2((z-p1)*p2)^(2+ @p3)/fn3((z-p1)\
    ^(2+ @p3)*p2) + @p3*c
   elseif @flavor == "zzz"
    z = fn1((z-p1)*p2)*fn2((z-p1)*p2)*fn3((z-p1)*p2) + @p3*c  
  elseif @flavor == "z^pz^pz^p"
    z = fn1((z-p1)*p2)^(2+ @p3)*fn2((z-p1)*p2)^(2+ @p3)*fn3((z-p1)\
    ^(2+ @p3)*p2) + @p3*c
  elseif @flavor == "zz/z"
    z = fn1((z-p1)*p2)*fn2((z-p1)*p2)/fn3(z-p1)+ @p3*c
  elseif @flavor == "z^pz^p/z^p"
    z = fn1((z-p1)*p2)^(2+ @p3)*fn2((z-p1)*p2)^(2+ @p3)/fn3((z-p1)\
    ^(2+ @p3)*p2) + @p3*c
  elseif @flavor == "z^3-z^2+c"
    z = fn1((z-p1)*p2)^(3+ @p3)-fn2((z-p1)*p2)^(2+ @p3)+ fn3(@p3*c) 
  endif
  
  if @cchange == "Orig"
    c = c^@expC 
  elseif @cchange == "Real"
    c = real(c)^@expC
  elseif @cchange == "Imag"
    c = imag(c)^@expC
  elseif @cchange == "Sign"
    c = -c^@expC
  elseif @cchange == "Squared"
    c = c^2+@expC  
  elseif @cchange == "Exponent"
    c = e^c^@expC
  elseif @cchange == "Inverse"
    c = 1 / c^@expC
  elseif @cchange == "Inv/Exp"  
    c = 1 / e^c^@expC
  elseif @cchange == "C/Exp"
    c = c^@expC / e^c^@expC
  elseif @cchange == "SQRPixel"
    c = sqr(pixel)/3 
  elseif @cchange == "CPower"
    c = c^c  
  elseif @cchange == "EPower"
    c = c^(e+c)   
  elseif @cchange == "ZPower"
    c = c^z   
  elseif @cchange == "CPower3"
    c = c^c^c   
  elseif @cchange == "CFunction"
    c = c^((z-@p1)*@p2)^@fnc(2 + @p3)  
  elseif @cchange == "Function"
    c = @fnc(c^@expC)  
  endif  
  endif 

  if @op == "+"
    z = @fn3(c/(z^@power + c + z^@fn1(z)+ @fn2(c)))
  elseif @op == "-"
    z = @fn3(c/(z^@power + c + z^@fn1(z)- @fn2(c)))
  elseif @op == "*"
    z = @fn3(c/(z^@power + c + z^@fn1(z)* @fn2(c)))
  elseif @op == "/"
    z = @fn3(c/(z^@power + c + z^@fn1(z)/ @fn2(c)))
  elseif @op == "^"
    z = @fn3(c/(z^@power + c + z^@fn1(z)^ @fn2(c)))
  elseif @op == "sin"
    z = @fn3(c/(z^@power + c + z^@fn1(z)^ sin(@fn2(c))))
  elseif @op == "sinh"
    z = @fn3(c/(z^@power + c + z^@fn1(z)^ sinh(@fn2(c))))  
  elseif @op == "asin"
    z = @fn3(c/(z^@power + c + z^@fn1(z)^ asin(@fn2(c))))
  elseif @op == "asinh"
    z = @fn3(c/(z^@power + c + z^@fn1(z)^ asinh(@fn2(c))))
  elseif @op == "cos"
    z = @fn3(c/(z^@power + c + z^@fn1(z)^ cos(@fn2(c))))
  elseif @op == "cosh"
    z = @fn3(c/(z^@power + c + z^@fn1(z)^ cosh(@fn2(c))))
  elseif @op == "acos"
    z = @fn3(c/(z^@power + c + z^@fn1(z)^ acos(@fn2(c))))
  elseif @op == "acosh"
    z = @fn3(c/(z^@power + c + z^@fn1(z)^ acosh(@fn2(c))))
  elseif @op == "tan"
    z = @fn3(c/(z^@power + c + z^@fn1(z)^ tan(@fn2(c))))
  elseif @op == "atan"
    z = @fn3(c/(z^@power + c + z^@fn1(z)^ atan(@fn2(c))))
  elseif @op == "tanh"
    z = @fn3(c/(z^@power + c + z^@fn1(z)^ tanh(@fn2(c))))
  elseif @op == "atanh"
    z = @fn3(c/(z^@power + c + z^@fn1(z)^ atanh(@fn2(c))))
  elseif @op == "cotan"
    z = @fn3(c/(z^@power + c + z^@fn1(z)^ cotan(@fn2(c))))
  elseif @op == "cotanh"
    z = @fn3(c/(z^@power + c + z^@fn1(z)^ cotanh(@fn2(c))))
  elseif @op == "sqr"
    z = @fn3(c/(z^@power + c + z^@fn1(z)^ sqr(@fn2(c))))
  elseif @op == "sqrt"
    z = @fn3(c/(z^@power + c + z^@fn1(z)^ sqrt(@fn2(c))))
  elseif @op == "log"
    z = @fn3(c/(z^@power + c + z^@fn1(z)^ log(@fn2(c))))
  elseif @op == "exp"
    z = @fn3(c/(z^@power + c + z^@fn1(z)^ exp(@fn2(c))))
  elseif @op == "abs"
    z = @fn3(c/(z^@power + c + z^@fn1(z)^ abs(@fn2(c))))
  elseif @op == "cabs"
    z = @fn3(c/(z^@power + c + z^@fn1(z)^ cabs(@fn2(c))))
  elseif @op == "conj"
    z = @fn3(c/(z^@power + c + z^@fn1(z)^ conj(@fn2(c))))
  elseif @op == "flip"
    z = @fn3(c/(z^@power + c + z^@fn1(z)^ flip(@fn2(c))))
  elseif @op == "ident"
    z = @fn3(c/(z^@power + c + z^@fn1(z)^ ident(@fn2(c))))
  elseif @op == "zero"
    z = @fn3(c/(z^@power + c + z^@fn1(z)^ zero(@fn2(c))))
  elseif @op == "recip"
    z = @fn3(c/(z^@power + c + z^@fn1(z)^ recip(@fn2(c))))
  elseif @op == "ceil"
    z = @fn3(c/(z^@power + c + z^@fn1(z)^ ceil(@fn2(c))))
  elseif @op == "floor"
    z = @fn3(c/(z^@power + c + z^@fn1(z)^ floor(@fn2(c))))
  elseif @op == "trunc"
    z = @fn3(c/(z^@power + c + z^@fn1(z)^ trunc(@fn2(c))))
  elseif @op == "round"
  z = @fn3(c/(z^@power + c + z^@fn1(z)^ round(@fn2(c))))
  endif  

  bailout:
 
    (@bailchoice == 0 && |z| <= @bailout) ||                                         \
    (@bailchoice == 1 && real(sqr(z)) <= @bailout) ||                                \
    (@bailchoice == 2 && imag(sqr(z)) <= @bailout) ||                                \
    (@bailchoice == 3 && sqr(real(z)) <= @bailout) ||                                \
    (@bailchoice == 4 && sqr(imag(z)) <= @bailout) ||                                \
    (@bailchoice == 5 && (sqr(real(z)) <= @bailout && sqr(imag(z)) < @bailout)) ||   \
    (@bailchoice == 6 && (sqr(real(z)) <= @bailout || sqr(imag(z)) < @bailout)) ||   \
    (@bailchoice == 7 && (sqr(abs(real(z)) + abs(imag(z))) <= @bailout)) ||          \
    (@bailchoice == 8 && (sqr(real(z) + imag(z)) <= @bailout))


  default:
    title = "MandelbrotPlus4"
    periodicity = 0     
   
  heading
    caption = "Parameters"
  endheading       
  
  int param bailout
    caption = "Bailout value"
    default = 4
    min = 1
    max = 8
  endparam
 
  param bailchoice
    caption = "Bailout Choice"
    default = 0
    enum = "|z|" "Real(Z^2)""Imag(Z^2)""Real(Z)^2""Imag(Z)^2"\
     "Real & Imag""Real or Imag""Sqr(Abs(Real&Imag)" "Sqr(Real&Imag)"
  endparam

  param start
    caption= "Start"
    default = (1,0)
  endparam

  param power  
    caption = "Power"
    default = (2,0)
  endparam  

  param p1
    caption = "Subtracter"
    default = (0,0)
  endparam

  param p2
    caption = "Mulitplier"
    default = (1,0)
  endparam    

  param p3
    caption = "Power"
    default = (0,0)
  endparam  

  param op
    caption = "Operator"
    enum = "+""-""*""/""^""sin""sinh""asin""asinh"\
    "cos""cosh""acos""acosh""tan""tanh""atan""atanh"\
    "cotan""cotanh""sqr""sqrt""log""exp"\
    "abs""cabs""conj""flip""ident""zero""recip" \
    "ceil""floor""trunc" "round"
    default = 3
  endparam
 
  param ztweaker
    caption = "Z Tweaker"
    enum = "z=orig""z=z+c""z=z+x""z=z+y""z=z+g"\
    "z=z*c""z=z*x""z=z*g""z=z/c""z=z/g"\
    "z=z/x+z""z=z/c+c""z=z/g+c""z=z-c""z=z-g""z=c-z"\
    "z=g-z""z=z/c-z""z=z/g-z""z=z/c-c""z=z/x-c"\
    "z=z/g-c""z=z-z/c""z=z-z/x""z=z-z/g""z=c-z/c"\
    "z=c-z/g""z=c/z""z=g/z""z*z+c"\
    "ezz""ez/z""exz""eyz""ey/z""z/1-z""z/1-x""z/1-y"\
    "zpi""zpi/z""z^pi/z^z""zpixel""z/pixelz"\
    "z/zpixel""z^pixel/z+pixel""ez/zpixel""z/pixel""piz/pixel"\
    "piz/zpixel""z-zpixel""ez/pixel""z+zpixel"\
    "c/ez""z+c/g""x+z/y+c""g^z-c""z-x+y/x-y""g/c-z"\
    "y+c/g""x+y/y+c""g^y-c""y-x+y/x-y""g/c-y"\    
    "g/c-x""g^x-c""x+c/g""c/ex"    
    default = 0
  endparam

  param style
    caption = "Variation in Style"
    enum = "z""fn(z^(2+power))""fn(x-y)""fn(y-x)"\
    "fn(x^2-y^2)""(fn(y-x))" "(fn(x^2-y^2))"\
    "fn(x^e)""fn(y^e)""fn(x^pi)""fn(y^pi)"\
    "fn(z-x)^fn(z-y)""fn(z+x)^fn(z+y)"   
    default = 0
  endparam 

 bool param inv
    caption = "Invert Z"
    default = false
  endparam  

  bool param zpix
    caption = "Z=Pixel"
    default = false
  endparam  

  bool param xplus
    caption = "Add X"
    default = false

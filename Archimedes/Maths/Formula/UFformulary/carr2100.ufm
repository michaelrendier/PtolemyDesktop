  z=sqr(flip(2*(1-pixel))-(3*pixel-.1/pixel-flip(.01/pixel))^.25)
  c=sin((-.5545,.30009))
  d1=conj(.00255/pixel), d4=4*d1
  z1=1.5*z+d1, z2=2.25*z+d1, z3=3.375*z+d1, z4=11.0625*z+d1
  l1=round(real(p1)), l2=round(imag(p1))
  l3=round(real(p2)), l4=round(imag(p2))
  float bailout=16, int iter=0
loop:
  IF (iter==l1)
    z=c=z1
  ELSEIF (iter==l2)
    z=c=z2
  ELSEIF (iter==l3)
    z=c=z3
  ELSEIF (iter==l4)
    z=c=z4
  ELSE
    z=z-c/10 
  ENDIF
  c = c + d4
  z=z^2+(-.3,-.613)+c/6
  iter=iter+1
bailout:
  |real(z)| <= bailout
default:
  title = "Carr 2189"
  periodicity = 0
  maxiter = 500
  magn = 2.4
  center = (1.1,-0.7)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (200,250)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
}

Carr2190 {; Updated for UF2 by Erik Reckase, March 2000
          ; Modified Sylvie Gallet frm. [101324,3444],1996
init:
  z=2*pixel+.72-1/log(pixel-1/sin(.01/pixel))
  c=sin((-.81256,.3095))
  d1=conj(.000255/pixel), d4=4*d1
  z1=1.5*z+d1, z2=2.25*z+d1, z3=3.375*z+d1, z4=11.0625*z+d1
  l1=round(real(p1)), l2=round(imag(p1))
  l3=round(real(p2)), l4=round(imag(p2))
  float bailout=16, int iter=0
loop:
  IF (iter==l1)
    z = z1+d4, c = 1.5*(z1+d4)
  ELSEIF (iter==l2)
    z = z2+d4, c = 1.5*(z2+d4)
  ELSEIF (iter==l3)
    z = z3+d4, c = 1.5*(z3+d4)
  ELSEIF (iter==l4)
    z = z4+d4, c = 1.5*(z4+d4)
  ELSE
    z = z - c/10 + d4, c = c + 1.5*d4
  ENDIF
  z = z*z + c
  iter=iter+1
bailout:
  |real(z)| <= bailout
default:
  title = "Carr 2190"
  periodicity = 0
  maxiter = 500
  magn = 2.7
  center = (-.3,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (200,250)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
}


  iter=iter+1
bailout:
  |real(z)| <= bailout
default:
  title = "Carr 2113"
  periodicity = 0
  maxiter = 500
  magn = 15
  center = (-.017,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \

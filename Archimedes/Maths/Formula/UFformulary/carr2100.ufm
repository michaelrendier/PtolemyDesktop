  z=cotanh(1-pixel)^1.5*pixel^4-log(conj(.1/pixel+1.25))^-2.5
  z1=1.5*z, z2=2.25*z, z3=3.375*z, z4=11.0625*z
  l1=round(real(p1)), l2=round(imag(p1))

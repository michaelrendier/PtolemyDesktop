tetrasin1 { ; jam 010509
  ; generalization of exp/sin/cos functions defined by Taylor series.
  ; tetrasin1(z) = z-(1/5!)z^5+(1/9!)z^9-...

  init:
  float factorial5 = 120.0
  float factorial9 = 362880.0
  float factorial13 = 6.227020800e09
  float factorial17 = 3.55687428096000e14
  float factorial21 = 5.109094217170944e19
  complex c5 = -1/factorial5, complex c9 = 1/factorial9, complex c13 = -1/factorial13
  complex c17 = 1/factorial17, complex c21 = -1/factorial21

  if ( @plottype == 0 )
    z = @perturbation, jc = #pixel
  else
    z = #pixel, jc = @jconstant

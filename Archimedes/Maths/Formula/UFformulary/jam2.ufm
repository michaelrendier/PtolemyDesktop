      elseif  @formula3 == 69
        z = 1/cos( 1/z )
      elseif  @formula3 == 70
        z = 1/sin( 1/z )
      elseif  @formula3 == 71
        z = cotanh( z )
      elseif  @formula3 == 72
        z = 1/cosh( z )
      elseif  @formula3 == 73
        z = 1/sinh( z )
      elseif  @formula3 == 74
        z = atanh( 1/z )
      elseif  @formula3 == 75
        z = acosh( 1/z )
      elseif  @formula3 == 76
        z = asinh( 1/z )
      elseif @formula3 == 77
        z = @coeff3a * z^@exponent3a + @coeff3b * z^@exponent3b + \
              @coeff3c * z^@exponent3c
      elseif  @formula3 == 78
        zextra = sinh(z)
        z = zextra * zextra
      elseif  @formula3 == 79
        zextra = cosh( z )

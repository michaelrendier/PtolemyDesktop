      elseif  @formula3 == 87
        z = cotanh(1/z)
      elseif  @formula3 == 88
        z = (1,0)/cosh(1/z)
      elseif  @formula3 == 89
        z = (1,0)/sinh(1/z)
      elseif  @formula3 == 90
        z = sin( z ) * tan(z)
      elseif  @formula3 == 91
        z = sinh(z) * tanh(z)
      elseif  @formula3 == 92
        z = sinh(z) * cosh(z)
      elseif  @formula3 == 93
        ztemp = sinh(z), zextra = cosh(z)

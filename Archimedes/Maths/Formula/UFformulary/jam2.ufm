          @coeff4 * temp1 * z^@power4 + @coeffp * jc
  endif ; remainder

  if @blend
    z = @weightzfn * z + @weightzpwr * (zblend^@zpower + jc)
  endif ; @blend

  bailout:
  |z| < @bail

  default:
  title = "N-cycle Trinom1*Fn +p"
  center = (0,0)
  maxiter = 100
  method = multipass
  periodicity = 0

  param cycle
    caption = "Cycle Length"
    default = 5
    min = 2
    hint = "Frequency of execution of B-series formulas. The A-series formulas \
          are executed except on iterations divisible by N (i.e., 0 mod N), when \
          the B-series formulas are executed"
  endparam
  param power3

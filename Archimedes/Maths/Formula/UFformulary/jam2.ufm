  loop:
  iter = iter + 1
  ztemp = z

  if @mode == 0
    z = jc * iter
  elseif @mode == 1
    z = jc * iter
    z = z + ztemp
  elseif @mode == 2
    z = jc * iter
    z = (z + ztemp)/iter
  elseif @mode == 3
    z = (jc * iter) + (ztemp/iter)
  else
    z = jc
  endif ; @mode

  if @flavor == 1
    z = z + #pixel
  elseif @flavor == 2
    z = z * #pixel
  elseif @flavor == 3
    z = z + #pixel*ztemp
  elseif @flavor == 4
    z = z + (#pixel*ztemp)/iter
  elseif @flavor == 5
    z = #pixel*z - #pixel
  endif ; @flavor

  if @grid
    z = (real(z) % @modulus) + (flip(imag(z) % @modulus))
  endif ; grid

  bailout:
  iter < @bailiter


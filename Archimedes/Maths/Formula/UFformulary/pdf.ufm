pgd_Freaky03JMod {
; Mandelbrot from a two-parameter family of rational functions.
init:
     complex r = @r
     complex dr = 2*r
     complex r2 = sqr(r)
     complex s = @s
     z = pixel
     z1 = r
     zr = sqrt(9 - 8*s)
     za = r/4 * (3 + zr)
     zb = r/4 * (3 - zr)
     bool b
     b2 = 1/@bail
     bool d = |z - z1| > 0.1 && |z - za| > 0.1 && |z - zb| > 0.1
     d = |real(z) - 3*r/4| > 0.1
loop:
     IF (d)
          z1 = ((z1 - dr)*sqr(z1) + r2*z1)/(r - s*z1)
          z = ((z - dr)*sqr(z) + r2*z)/(r - s*z)
          za = ((za - dr)*sqr(za) + r2*za)/(r - s*za)
          zb = ((zb - dr)*sqr(zb) + r2*zb)/(r - s*zb)
          b = |z - z1| > b2 && |z - za| > b2 && |z - zb| > b2 && |z| < @bail
     ELSE
         z = sqr(z)
     ENDIF
bailout:
        b
default:
        title = "Freaky 03 Julia 2"
        maxiter = 1000
        param r
              caption = "Parameter r"
              default = (1.5,0.1)
        endparam
        param s
              caption = "Parameter s"
              default = (2.0,0.0)
        endparam
        param bail
              caption = "Bailout"
              default = 1000.0
        endparam
}


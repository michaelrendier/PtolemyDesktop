
rsp-pop {
;Rui Parracho 2002
transform:
  int n = 0
  x = real(fn1(#pixel))
  y = imag(fn2(#pixel))
  while n < @iter
    ox = x
    x = x - @h*sin( y+tan(@c*y))
    y = y + @h*sin( ox+tan(@c*ox))
    n = n+1
  endwhile
  #pixel = x + flip(y)
default:
  title = "rsp-pop"
  param iter, caption = "iterations", default = 5, endparam
  param h, caption = "incriment", default = 0.05, endparam
  param c, caption = "c", default = 3.0, endparam
  
  
}

    default = (200,250)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
}

Carr2010 (XAXIS) {; Updated for UF2 by Erik Reckase, March 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pp1=1/pixel, z=1/(pixel-real(pp1)+flip(imag(pp1)*2.924))
  c=1/(pixel-conj(pp1)-flip(pp1))
  c1=1.5*z, c3=3.375*z
  l1=round(real(p1)), l3=round(real(p2))
  float bailout=16, int iter=0, pp2 = pixel/imag(p2)
loop:
  IF (iter==l1)
    c = c1, z = 0
  ELSEIF (iter==l3)
    c = c3, z = 0
  ENDIF
  c = c + pp2
  z=z*z + c + (-.3,.6)
  iter=iter+1
bailout:
  |real(z)| <= bailout
default:
  title = "Carr 2010"
  periodicity = 0
  maxiter = 500
  magn = 0.3
  center = (-.233,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (200,250)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
}

Carr2011 (XAXIS) {; Updated for UF2 by Erik Reckase, March 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pp1=1/pixel, c=1/(pixel-conj(pp1)-flip(pp1))
  z=1/(pixel-3/c+c/4-conj(pp1))
  c1=1.5*z, c3=3.375*z
  l1=round(real(p1)), l3=round(real(p2))
  float bailout=16, int iter=0, pp2 = pixel/imag(p2)
loop:
  IF (iter==l1)
    c = c1, z = 0
  ELSEIF (iter==l3)
    c = c3, z = 0
  ENDIF
  c = c + pp2
  z=z*z + c + (.35776,-.08294)
  iter=iter+1
bailout:
  |real(z)| <= bailout
default:
  title = "Carr 2011"
  periodicity = 0
  maxiter = 500
  magn = .2
  center = (-4.6,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (200,250)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
}


  c=sinh(pixel)^5/conj(pixel)^1.5
  z=pixel^3-conj(.1/pixel)^2-flip(.01/pixel)
  z1 = 1.5*z, z2 = 2.25*z, z3 = 3.375*z, z4 = 5.0625*z
  l1=round(real(p1)), l2=round(imag(p1))
  l3=round(real(p2)), l4=round(imag(p2))
  float bailout=16, int iter=0
  d4 = 4*tanh(.01/z), d1 = conj(.00001/c)
loop:
  IF (iter==l1)
    z=c=z1
  ELSEIF (iter==l2)
    z=c=z2
  ELSEIF (iter==l3)
    z=c=z3
  ELSEIF (iter==l4)
    z=c=z4
  ENDIF
  c = c + d1  
  z=(z+d4)^2+c
  iter=iter+1
bailout:
  |real(z)| <= bailout
default:
  title = "Carr 2085"
  periodicity = 0
  maxiter = 500
  magn = 1.4
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (200,250)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
}

Carr2086 {; Updated for UF2 by Erik Reckase, March 2000
          ; Modified Sylvie Gallet frm. 
init: 
  c=conj(pixel-.33)
  z=c*pixel^2-conj(.1/pixel)+flip(.01/pixel)^2
  z1 = 2.25*z, z2 = 3.25*z, z3 = 5.375*z, z4 = 10.0625*z
  l1=round(real(p1)), l2=round(imag(p1))
  l3=round(real(p2)), l4=round(imag(p2))
  float bailout=16, int iter=0, d=.0125/conj(z)
loop:
  IF (iter==l1)
    z=c=z1
  ELSEIF (iter==l2)
    z=c=z2
  ELSEIF (iter==l3)
    z=c=z3
  ELSEIF (iter==l4)
    z=c=z4
  ENDIF
  z = (z-d)^2 + c
  iter=iter+1
bailout:
  |real(z)| <= bailout
default:
  title = "Carr 2086"
  periodicity = 0
  maxiter = 500
  magn = 1.4
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \

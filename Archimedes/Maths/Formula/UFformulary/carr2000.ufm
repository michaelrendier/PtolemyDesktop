Carr2009 (XAXIS) {; Updated for UF2 by Erik Reckase, March 2000
                  ; Modified Sylvie Gallet frm. 
init:
  c=pixel+1/log(pixel)
  z=pixel-1/log(pixel-1/log(tan(1/pixel))-1/log(2/pixel))
  c1=1.5*z, c3=3.375*z
  l1=round(real(p1)), l3=round(real(p2))
  float bailout=16, int iter=0, pp2 = pixel/imag(p2)
loop:
  IF (iter==l1)
    c = c1, z = 0
  ELSEIF (iter==l3)
    c = c3, z = 0
  ENDIF
  c = c + pp2
  z = z*z + c
  iter = iter + 1
bailout:
  |real(z)| <= bailout
default:
  title = "Carr 2009"
  periodicity = 0
  maxiter = 500
  magn = 1.25
  center = (-.233,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"

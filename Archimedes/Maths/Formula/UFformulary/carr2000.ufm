init:
  op = sqrt(.1/pixel)
  d=conj(op)/cos(op), d1=d^pixel, z=pixel-d/d1, c=(-.7456,-.171)
  c1=(1.5*z), c2=(2.25*z), c3=(3.375*z), c4=(5.0625*z)
  l1=round(real(p1)), l2=round(imag(p1))
  l3=round(real(p2)), l4=round(imag(p2))
  float bailout=16, int iter=0, pp2 = pixel/l4
loop:
  IF (iter==l1)
    c = c1, z = 0
  ELSEIF (iter==l2)
    c = c2, z = 0
  ELSEIF (iter==l3)
    c = c3, z = 0
  ELSEIF (iter==l4)
    c = c4, z = 0
  ENDIF
  c = c + pp2
  z=z*z+c-.087
  iter=iter+1
bailout:
  |real(z)| <= bailout
default:
  title = "Carr 2033"
  periodicity = 0
  maxiter = 500
  magn = 1
  center = (.2,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (200,250)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
}

Carr2034 {; Updated for UF2 by Erik Reckase, March 2000
          ; Modified Sylvie Gallet frm. 
init:
  p01=.1/pixel, sq=sqrt(p01), d2=tan(p01)/sq, d=conj(sq)/cos(sq)
  d1=d^(pixel-1), z=pixel-conj(.1*d1)+d2, c=(-.7456,-.171)
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  l1=round(real(p1)), l2=round(imag(p1))
  l3=round(real(p2)), l4=round(imag(p2))
  float bailout=16, int iter=0, pp2 = pixel/imag(p2)
loop:
  IF (iter==l1)
    c = c1, z = 0
  ELSEIF (iter==l2)
    c = c2, z = 0
  ELSEIF (iter==l3)
    c = c3, z = 0
  ELSEIF (iter==l4)
    c = c4, z = 0
  ENDIF
  c = c + pp2
  z=z*z+c-.087
  iter=iter+1
bailout:
  |real(z)| <= bailout
default:
  title = "Carr 2034"
  periodicity = 0
  maxiter = 500
  magn = 1.2
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150)

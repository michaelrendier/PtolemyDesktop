Carr2018 {; Updated for UF2 by Erik Reckase, March 2000
          ; Modified Sylvie Gallet frm. 
init:
  z=pixel+1/log(.1*pixel)*(sinh(.1/pixel))
  c=sqrt(pixel-conj(.135/pixel))+pixel 
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  l1=round(real(p1)), l2=round(imag(p1))
  l3=round(real(p2)), l4=round(imag(p2))
  float bailout=16, int iter=0, k = cos(.1345/pixel)
loop:
  IF (iter==l1)
    c = c1, z = 0
  ELSEIF (iter==l2)
    c = c2, z = 0
  ELSEIF (iter==l3)
    c = c3, z = 0
  ELSEIF (iter==l4)
    c = c4, z = 0
  ENDIF
  z=z*z+c-k
  iter=iter+1
bailout:
  |real(z)| <= bailout
default:
  title = "Carr 2018"
  periodicity = 0
  maxiter = 500
  magn = 2.5
  center = (.15,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \

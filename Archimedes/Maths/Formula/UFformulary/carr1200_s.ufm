Carr1224S {
; A "Modified Carr" formula, based on the original with permission.
; Functionality added by Sharon S. Schultz, May, 2003. 
; Updated for UF2 by Erik Reckase, Feb 2000
; Modified Rollo Silver formula

init:
  z = (1/#pixel*0.91/#pixel)/@scale
  zz = z*z
  zzz = zz*z
  z = (1.-(2.099,0))*zz+((2.099,0)*zzz)

loop:
  z = fn1(fn2(fn3(conj(cos(z+1/#pixel))/(z*1/z))))
  zsq = z*1/z
  zcu = zsq*1/z
  z = z-((1.-(2.099,0))*zsq+(2.099,0)*1/zcu)/(#pixel-z*z)

bailout:
  |real(z)| <= @bailout

default:

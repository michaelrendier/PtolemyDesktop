Carr1219S { 
; A "Modified Carr" formula, based on the original with permission.
; Functionality added by Sharon S. Schultz, May, 2003.
; Updated for UF2 by Erik Reckase, Feb 2000

init:
  z = (1/(#pixel*#pixel))/@scale
  c = imag(conj(cos(1/#pixel)))

loop:
  z = fn1(fn2(fn3(z-(#pixel-z*z)/(#pixel-c*c))))
  c = (1+flip(imag(c)))*real(c)/2+z

bailout:
  |real(z)| <= @bailout 

default:

Carr1204S {
; A "Modified Carr" formula, based on the original with permission.
; Functionality added by Sharon S. Schultz, May, 2003. 
; Updated for UF2 by Erik Reckase, Feb 2000

init:
  z = (conj(cos(1/#pixel)))/@scale
  z2 = abs(real(z))
  z3 = abs(imag(z))
  c = cotanh(1/#pixel)

loop:
  z = fn1(fn2(fn3(sqr(sqr(z*c))+c+1.224)))
  z2 = conj(z2^z3)/c
  z3 = conj(z3^z2)

bailout:
  |real(z)| <= @bailout


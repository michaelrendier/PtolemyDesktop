;;------------------------------------------
;; bills_diff_delt series
;;------------------------------------------

bills_diff_delt1  { ; Apr-13-98
                   ; p1 = offset for y var
                   ; real p2 = base real exponent
                   ; imag p2 = base imag exponent
                   ; real p3 = exponent real delta
                   ; imag p3 = exponent imag delta
                   ;
init:
  c = x = pixel, y = pixel + p1
  splus = real(p2) + real(p3) + flip(imag(p2) + imag(p3))
  sminus = real(p2) - real(p3) + flip(imag(p2) - imag(p3))
loop:
  xtemp = x^splus +c
  x = fn1(xtemp) 
  ytemp = y^sminus +c
  y = fn1(ytemp) 
  d = |x-y|
  z = d^2
bailout:
  |z| < 2
default:
  title = "bills_diff_delt1"
  center = (0,0)
  param P1
    caption = "Parameter P1"
    default = (0,0)
  endparam
  param P2
    caption = "Parameter P2"
    default = (-4,2)
  endparam
  param P3
    caption = "Parameter P3"
    default = (0,0.002)
  endparam
  func Fn1
    caption = "First function"
    default = log()
  endfunc  
}


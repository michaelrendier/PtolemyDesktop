bills_xy-trade5  {
init:
  a = real(@p1), b = imag(@p1)
  c = real(@p2), d = imag(@p2)
  g = real(@p3), f = imag(@p3)
  z = #pixel+c/#pixel
  zold = #pixel^g
loop:
  x = (real(z)-real(zold))^a
  y = (imag(z)-imag(zold))^b
  zold = z
  z = (y +flip(x))
  z = ( (@fn1(z))^c - (@fn2(zold)) )^d
bailout:
  |z| < f
default:
  title = "bills_xy-trade5"
  center = (0,0)
  param P1
    caption = "Parameter P1"
    default = (2,2)
  endparam
  param P2
    caption = "Parameter P2"
    default = (2,2)
  endparam
  param P3
    caption = "Parameter P3"
    default = (2,4)
  endparam
  func Fn1
    caption = "First function"
    default = sin()
  endfunc  
  func Fn2
    caption = "Second function"
    default = sin()
  endfunc  
} 
  

JuliaPie-Beaks {
; Wee! I'm a turtle.
fractal:
  title="Julia Pie - Beaks" width=1024 height=576 layers=1
  credits="MG;8/1/2007"
layer:
  caption="Background" opacity=100
mapping:
  center=-0.08886718746/0.44104455972445 magn=3.3882353
formula:
  maxiter=1000 filename="dpm.ufm" entry="J-Pie" p_seed=0.483741/0
  p_seed2=0.281825/0.563649 p_radius=-0.688302/0.00542 p_power=2/0
  p_bailout=128
inside:
  density=.25 transfer=sqrt filename="Standard.ucl" entry="OrbitTraps"
  p_trapshape=point p_diameter=1.0 p_traporder=4.0 p_trapfreq=1.0
  p_trapcolor=distance p_traptype=closest p_threshold=0.25
  p_trapcenter=0/0 p_aspect=1.0 p_angle=0.0 p_solidcolor=no
outside:
  density=.25 transfer=sqrt filename="Standard.ucl" entry="Smooth"
  p_power=2/0 p_bailout=128.0
gradient:
  comments="Simple grayscale gradient." smooth=yes rotation=-85
  index=29 color=0 index=115 color=16777215 index=194 color=0
  index=-191 color=0 index=315 color=10592673
opacity:
  smooth=no index=0 opacity=255
}


gpm-ca04-21 {;chby21 / ca04-21 formula by Morgan L. Owens
             ;Translated from .frm to .ufm
             ;and slightly modified by Gedeon Peteri, November 1999
init:
   a=p1
   b=a*(a+1)/2
   c=4*(a+2)
   d=(a+3)/3
   t=real(p2)
   z=pixel
loop:
   x=real(z), y=imag(z)
   xx=x*x
   y=y+t*(fn1(b*(c*xx*(d*xx-1)+1)))
   yy=y*y
   x=x-t*(fn2(b*(c*yy*(d*yy-1)+1)))
   z=x+fn3(y)
bailout:
   |z|<=@bailout
default:
   title="gpm-ca04-21"
param p1
   caption="Parameter 1"
   default=(0.4,0.0)
   endparam
param p2
   caption="Parameter 2"
   default=(1.0,0.0)
   endparam
param bailout
   caption="Bailout"
   default=4.0
   endparam

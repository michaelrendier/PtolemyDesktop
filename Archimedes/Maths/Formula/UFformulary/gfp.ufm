;The polar equation of the LIMACON OF PASCAL is
;r=2a*cos(t)+b

gfplop01    {;Formula by Gedeon Peteri, 1999
             ;Based on equation of Limacon of Pascal
init:
   z=fn1(pixel)
loop:
   z=fn2(z^p1) + fn3(2*p2*cos(z)+p3)
bailout:
   |z|<=@bailout
default:
   title="gfplop01"
param p1
   caption="Exponent"
   default=(1.0,0.0)
   endparam
param p2
   caption="Parameter 1"
   default=(1.0,0.0)
   endparam
param p3
   caption="Parameter 2"
   default=(2.0,0.0)
   endparam
param bailout
   caption="Bailout"
   default=4.0
   endparam
func fn1
  caption="Function 1"
  default = ident()
  endfunc
func fn2
  caption="Function 2"
  default = ident()
  endfunc
func fn3
  caption="Function 3"
  default = ident()
  endfunc
}

;LOGARITHMIC SPIRAL r=e^(a*t) and first derivative r'=e^(a*t) * log e * a

gfplsp01    {;Formula by Gedeon Peteri, 1999
             ;Based on equation of Logarithmic spiral
init:
   z=fn1(pixel)
loop:
   z=fn2(z^p1) + p2*fn3(exp(p3*z))
bailout:
   |z|<=@bailout

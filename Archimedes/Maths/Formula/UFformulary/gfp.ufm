}

gp-bas02             {;Gedeon Peteri, January 2000
init:
z = @pfunc(#pixel ^ @pexp)
loop:
z = @lfunc((z^@exp1 + @const1)^@exp2) + @const2
bailout:
   (@test == 0 && |z| <= @bailout) ||                                       \
   (@test == 1 && sqr(real(z)) <= @bailout) ||                              \
   (@test == 2 && sqr(imag(z)) <= @bailout) ||                              \
   (@test == 3 && (sqr(real(z)) <= @bailout && sqr(imag(z)) < @bailout)) || \

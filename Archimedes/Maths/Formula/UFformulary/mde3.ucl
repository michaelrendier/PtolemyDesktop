    max = 255
    visible = (@clspace == 0 && @pick_hsl == 15 && @automask)
  endparam
  Heading
    caption = "Red Range"
    visible = (@clspace == 1 && @automask)
  endheading 
  int param rouge_min
    caption="Minimum"
    default = -1

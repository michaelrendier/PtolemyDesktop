    caption="Minimum"
    default = -1
    min=-1
    max=255
    visible = (@clspace == 0 && @automask)
    ; borne inférieure de l'intervalle
  endparam
  int param satur_max
    caption="Maximum"
    default = -1
    min=-1
    max=255
    visible = (@clspace == 0 && @automask)
    ; borne supérieure de l'intervalle
  endparam
  Heading

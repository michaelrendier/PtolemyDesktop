    default = -1
    min=-1
    max=255
    visible = (@clspace == 0 && @automask)
    ; borne inférieure de l'intervalle
  endparam
  int param lumin_max
    caption = "Maximum"
    default = -1
    min=-1
    max=255
    visible = (@clspace == 0 && @automask)
    ; borne supérieure de l'intervalle
  endparam
  Heading
    caption = "Use for Mask"
    visible = (@clspace == 0 && @automask)
  endheading 
  int param pick_hsl
    caption= "Use"
    enum = "H value" "S value" "L value" "Average HS" "Average HL" "Average SL" \
           "Average HSL" "Max H/S" "Max H/L" "Max S/L" "Max H/S/L" "Min H/S" "Min H/L" \
           "Min S/L" "Min H/S/L" "Custom"
    default = 2
    visible = (@clspace == 0 && @automask)
  endparam
  int param val_hsl
    caption = "Value"

ZZ_Brahmabrot_Stars {
; On resize increase sample density (hit count).  
; 480x360 =   172 800 pixels
; 1280x960 = 1 228 800 pixels
; 1 228 800 /  172 800=  7 times more
; So when increasing from 480x360 to 1280x960
; sample density must be increased 7 times.
; But it will take 7x7 longer to render.
; Anyway it's the fastest (non)buddhabrot.
fractal:
  title="ZZ_Brahmabrot_Stars" width=740 height=520 layers=1
  credits="Alef;9/3/2013"
layer:
  caption="Background" opacity=100 transparent=yes
mapping:
  center=0.1/-0.0375 magn=1.1320755
formula:
  maxiter=100 filename="Standard.ufm" entry="Pixel"
inside:
  transfer=none
outside:
  transfer=linear filename="em.ucl" entry="Brahmabrot"
  p_sampleDensity=4000 p_maxiter=200 p_seedinput=-8 p_formula=Starbrot
  p_power=5 p_starpower=7 p_stargeom=0.5 p_unitvector=-0.5
  p_talisadd=1 p_quadfactor=2 p_frequency=1 p_spin=1
  p_centralorbit=0.25/0 p_settype=Mset p_julia=-0.4/0.25 p_srcWidth=5
  p_srcHeight=4 p_switchRGB="Switch Red and Blue" p_ambient=0.13
  p_postfn="5- Accentuate RGB" p_palette="Direct Colouring"
  p_equalisation=no p_sigmoidlight=5 p_lightR=0.38 p_scalarR=0.7
  p_lightG=0.98 p_scalarG=1.6 p_lightB=0.14 p_scalarB=0.3
gradient:
  smooth=yes index=0 color=8716288 index=100 color=16121855 index=200
  color=46591 index=300 color=156
opacity:
  smooth=no index=0 opacity=255
}

ZZ_gradient_brahmabrot_quadgen {
; Could take some time.
; 
; On resize increase sample density (hit count).  
; 480x360 =   172 800 pixels
; 1280x960 = 1 228 800 pixels
; 1 228 800 /  172 800=  7 times more
; So when increasing from 480x360 to 1280x960
; sample density must be increased 7 times.
; But it will take 7x7 longer to render.
; Anyway it's the fastest (non)buddhabrot.
fractal:
  title="ZZ_gradient_brahmabrot_quadgen" width=740 height=520 layers=1
  credits="Alef;9/3/2013"
layer:
  caption="Background" opacity=100 transparent=yes
mapping:
  center=-0.5/0 magn=1
formula:
  maxiter=100 filename="Standard.ufm" entry="Pixel"
inside:
  transfer=none
outside:
  transfer=linear filename="em.ucl" entry="Brahmabrot"
  p_sampleDensity=7500 p_maxiter=250 p_seedinput=-8
  p_formula="Quadratic General" p_power=2 p_starpower=7 p_stargeom=0.5
  p_unitvector=-0.5 p_talisadd=1 p_quadfactor=2 p_frequency=1 p_spin=1
  p_centralorbit=0.25/0 p_settype=QuasiJulia p_julia=-1.5/0
  p_srcWidth=5 p_srcHeight=4 p_switchRGB="Switch Red and Blue"
  p_ambient=0.25 p_postfn="11- Triangle (periodic)"
  p_palette="Gradient Based" p_equalisation=yes p_sigmoidlight=17
  p_lightR=0.38 p_scalarR=0.7 p_lightG=0.98 p_scalarG=1.6
  p_lightB=0.14 p_scalarB=0.3
gradient:
  comments="from Kerry Mitchell" smooth=yes rotation=100 index=400
  color=5247953 index=100 color=132124 index=200 color=1061587
  index=300 color=12845055
opacity:
  smooth=no index=0 opacity=255
}


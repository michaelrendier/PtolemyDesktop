comment{
Examples of my fractal and 
colour formulas. Last star are made 
by colour method of others.

http://edo555.deviantart.com/
 
You may use these whatever you like.
Just if unmodified don't atribute as your own work;)

by Edgars Malinovskis  20.01.2012.
http://www.youtube.com/user/Antifacio
}

Mandelbrot_Structure {
fractal:
  title="Mandelbrot_Structure" width=640 height=640 layers=1
  credits="Asdam;11/17/2012"
layer:
  caption="Background" opacity=100 transparent=yes
mapping:
  center=-0.8400979967029668235922269/0.224386202997573917515045
  magn=1.0180486E15
formula:
  maxiter=1000 filename="Standard.ufm" entry="Mandelbrot" p_start=0/0
  p_power=2/0 p_bailout=777000
inside:
  transfer=linear filename="em.ucl" entry="WaveTrichrome"
  p_palette="Fractal Explorer like" p_seed=2.1 p_orbits=None
  p_switchRB=no p_colmethod="With counter" p_naturalise=no
  p_postfn="9- Solarisation" p_lightR=0.7 p_scalarR=0.7 p_lightG=1.2
  p_scalarG=1.2 p_lightB=0.25 p_scalarB=0.25
outside:
  transfer=linear filename="em.ucl" entry="WaveTrichrome"
  p_palette="Fractal Explorer like" p_seed=2.1 p_orbits=None
  p_switchRB=no p_colmethod="With counter" p_naturalise=no
  p_postfn="9- Solarisation" p_lightR=0.7 p_scalarR=0.7 p_lightG=1.2
  p_scalarG=1.2 p_lightB=0.25 p_scalarB=0.25
gradient:
  comments="My favorite and my original creation." smooth=yes index=0
  color=15202559 index=66 color=4194432 index=133 color=15202559
  index=199 color=4618495 index=266 color=1646882 index=332
  color=55717
opacity:
  smooth=no index=0 opacity=255
}

Navalis_Ignis_Pauldebroti {
fractal:
  title="Navalis_Ignis_Pauldebroti" width=640 height=480 layers=1
  credits="Asdam;1/27/2013;Edgar;1/24/2013"
layer:
  caption="Background" opacity=100
mapping:
  center=-0.525/-0.3625 magn=1.0169492
formula:
  maxiter=500 percheck=off filename="em.ufm" entry="Pauldebrot"
  p_seed=0.0001/0 p_seed2=0.00000000001/0 p_wfactor=0.6
  p_bailout=1000000.0 p_settype=Mandelbrot p_switchsettype=Julia
  p_julia=0.3/0.6 f_func_post=ident p_zfunction="Burning Ship"
  p_inverted=no
inside:
  transfer=none
outside:
  transfer=linear filename="em.ucl" entry="Pauldebrots_Smooth"
  p_convergent=no p_esm=no p_alt=no p_perfix=1.0 p_zmax=100 p_power=2
  p_fit=yes p_fittimes=1.0 p_fitminit=1 p_fitmaxit=500 p_transfer=Log
  p_transpower=3.0 p_bailout=1000000.0
gradient:
  comments="my original creation." smooth=yes index=30 color=24800
  index=130 color=9164785 index=262 color=10176512 index=363
  color=5998
opacity:
  smooth=no index=0 opacity=255
}


    elseif @m == 22 || @m == 23  ;N,O
      y = g1^2-abs((ff-g1)/s1)
    elseif @m == 24 || @m == 25  ;P,Q
      y = g1^2-s1
    elseif @m == 26 || @m == 27  ;R,S
      y = ff
    else                         ;T,U

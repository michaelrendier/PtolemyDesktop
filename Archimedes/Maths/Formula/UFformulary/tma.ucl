          @fn4Q(yzyQ^7)))-zzortQ

   elseif @trapTypeQ == "Swallow Curve"

     zzQ = @fn1Q(@fn2Q((xzxQ^2*shapeAdjust2Q))-@fn3Q((yzyQ^2)))^2-4*@fn4Q\
           ((xzxQ^yzyQ^2)*@fn5Q(yzyQ^2))-zzortQ

   elseif @trapTypeQ == "Stretched Oval Curve"

     zzQ = @fn1Q(shapeAdjust1Q^4+@fn2Q((yzyQ^2)/(xzxQ^2))-shapeAdjust2Q^2* \

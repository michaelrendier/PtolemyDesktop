   dist2 = cabs(@fncorr(z2a - ptp))
   dist3 = cabs(@fncorr(z3a - ptp))
   dist4 = cabs(@fncorr(z4a - ptp))
   dist5 = cabs(@fncorr(z5 - ptp))
   dist6 = cabs(@fncorr(z6 - ptp))
   dist7 = cabs(@fncorr(z7 - ptp))
   dist8 = cabs(@fncorr(z8 - ptp))

  endif
 endif


 if @ipat == false

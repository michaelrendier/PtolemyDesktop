   elseif @trapTypeQ == "Ovate Waves 2"

     zzQ = @fn1Q(@fn2Q(yzyQ^4)-1*@fn3Q(yzyQ^2)-@fn4Q((xzxQ*shapeAdjust4Q)^ \

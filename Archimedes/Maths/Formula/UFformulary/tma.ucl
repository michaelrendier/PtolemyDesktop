     zzQ = @fn1Q(atan(@fn4Q((xzxQ^(2*shapeAdjust1Q))-@fn3Q(yzyQ^2)))+@fn2Q\
          (xzxQ^-6*shapeAdjust3Q))-zzortQ

   elseif @trapTypeQ == "Ornate Curve"

     zzQ = @fn1Q((@fn2Q(yzyQ^2)/(xzxQ^2+1))*(xzxQ-yzyQ)* (shapeAdjust1Q-xzxQ)\
           -4*(@fn3Q(xzxQ^2*shapeAdjust3Q)+@fn4Q(yzyQ^2)-2*@fn5Q \
          (xzxQ^shapeAdjust2Q))^2*shapeAdjust1Q)-zzortQ

   elseif @trapTypeQ == "Ovals"

     zzQ = @fn1Q(@fn2Q(xzxQ*shapeAdjust1Q-@fn6Q(yzyQ))- \

          (@fn5Q(xzxQ^2*shapeAdjust6Q)+@fn6Q(yzyQ^2)))-zzortQ

   elseif @trapTypeQ == "Line"

     zzQ = @fn1Q(yzyQ)-zzortQ

   elseif @trapTypeQ == "Links Curve"

     zzQ = @fn1Q((@fn2Q(xzxQ^2*shapeAdjust1Q)+@fn3Q(yzyQ^2)-3* \
          @fn4Q(xzxQ^shapeAdjust2Q))^2-4*@fn5Q(xzxQ^(2*shapeAdjust3Q))* \
          (2-abs(@fn6Q(xzxQ^shapeAdjust4Q))))-zzortQ

   elseif @trapTypeQ == "Maltese Cross Curve"

     zzQ = @fn1Q(@fn2Q(xzxQ^2*shapeAdjust1Q)+@fn3Q(yzyQ^2)-abs \

  elseif @distyp6 == "Zero"
    gh = 0
  elseif @distyp6 == "Function"
    gh = cabs(@fncorr6(z6-ptp))
  endif

  if @distyp7 == "Normal"
    jk = cabs(z7-ptp)
  elseif @distyp7 == "Modulus"
    jk = |z7-ptp|
  elseif @distyp7 == "Real"
    jk = real(abs(z7-ptp))
  elseif @distyp7 == "Imag"
    jk = imag(abs(z7-ptp))
  elseif @distyp7 == "Zero"
    jk = 0
  elseif @distyp7 == "Function"

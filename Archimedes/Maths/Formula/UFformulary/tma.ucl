  ELSEIF @opadd == "-(Y/X)"
    w = w - (flip(@nufuncxty((y-@xtra1y)*@xtra2y)^@xtra3y / \
         @nufuncxtx((x-@xtra1x)*@xtra2x)^@xtra3x))
  ELSEIF @opadd == "+(X^Y)"
    w = w + (@nufuncxtx((x-@xtra1x)*@xtra2x)^@xtra3x ^ \
         flip(@nufuncxty((y-@xtra1y)*@xtra2y)^@xtra3y))
  ELSEIF @opadd == "-(X^Y)"
    w = w - (@nufuncxtx((x-@xtra1x)*@xtra2x)^@xtra3x ^ \
         flip(@nufuncxty((y-@xtra1y)*@xtra2y)^@xtra3y))
  ELSEIF @opadd == "+(Y^X)"
    w = w + (flip(@nufuncxty((y-@xtra1y)*@xtra2y)^@xtra3y ^ \
         @nufuncxtx((x-@xtra1x)*@xtra2x)^@xtra3x))
  ELSEIF @opadd == "-(Y^X)"
    w = w - (flip(@nufuncxty((y-@xtra1y)*@xtra2y)^@xtra3y ^ \
         @nufuncxtx((x-@xtra1x)*@xtra2x)^@xtra3x))
  ENDIF
 ENDIF

 complex zq = (0,0)

    IF @ztype == "Normal"
      zq = z1
    ELSEIF @ztype == "Modulus"
      zq = |z1|
    ELSEIF @ztype == "Atan2"

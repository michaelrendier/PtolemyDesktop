  func nufny
    caption = "Y Function"
    default = ident ()
    visible = @newStuff
  endfunc

  bool param nuflav2
     caption = "Change Y Fn Flavor"
     default = false
     visible = @newStuff
   endparam

  complex param px1
    caption = "X Offset"
    default = (0,0)
    visible = @newStuff
  endparam

  complex param py1
    caption = "Y Offset"
    default = (0,0)
    visible = @newStuff
  endparam


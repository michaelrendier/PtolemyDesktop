   && @tw == (0,0) && @tw2 == (0,0) && @tw3 == (0,0) && @th2 == false)
endheading

heading
  caption = "Morph Parameters  [active]"
  visible = (@change != 0 || @exp1 != (1,0) || @exp2 != (1,0) || @exp1 != (1,0) \
   || @tw != (0,0) || @tw2 != (0,0) || @tw3 != (0,0) || @th2 == true)
endheading

  param adv
    caption = "Morph Parameters"
    hint = "Additional shaping parameters and functions."

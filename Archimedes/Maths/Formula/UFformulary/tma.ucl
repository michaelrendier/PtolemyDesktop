   elseif @trapTypeQ == "Taurus Curve"

     zzQ = @fn1Q(@fn2Q(xzxQ^(shapeAdjust2Q)))-@fn3Q(yzyQ^2)\
          -@fn4Q((xzxQ^(2*shapeAdjust5Q))+ \

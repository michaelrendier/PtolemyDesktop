  elseif @pct == "Soft Gnarly"
   if @flav == true
     zz = @tn3(@tn1(real(z1-@zparam1)) + flip(@tn2(imag(z1-flip(@zparam2)))))
   else
     zz = @tn3(real(@tn1(z1-@zparam1)) + flip(imag(@tn2(z1-flip(@zparam2)))))
   endif

   z1a = zz + -@spread + flip(-@spread)
   z2a = zz + flip(-@spread)
   z3a = zz + @spread + flip(-@spread)
   z4a = zz + -@spread
   z5 = zz + @spread
   z6 = zz + -@spread + flip(@spread)
   z7 = zz + flip(@spread)

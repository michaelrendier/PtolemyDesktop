          shapeAdjust4Q)))-zzortQ

   elseif @trapTypeQ == "Quadrifolium"

     zzQ = @fn1Q((@fn2Q(xzxQ^(2*shapeAdjust1Q))+yzyQ^2)^3-4* \
          (xzxQ^2+1)*@fn5Q(yzyQ^3))-zzortQ

   elseif @trapTypeQ == "Rose Curve"

     complex tz = atan2(xzxQ + flip(yzyQ))
     zzQ = @fn1Q(shapeAdjust1Q*cos(@fn2Q(tz^shapeAdjust2Q)) + \
          sin(@fn3Q(tz^shapeAdjust3Q)))-zzortQ

   elseif @trapTypeQ == "Serpentine Curve"

     zzQ = @fn1Q(shapeAdjust1Q*shapeAdjust2Q*@fn2Q(xzxQ^shapeAdjust3Q)/ \

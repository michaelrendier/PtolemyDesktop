heading
  caption = "Morph Parameters"
  visible = (@change == 0 && @exp1 == (1,0) && @exp2 == (1,0) \
            && @exp3 == (1,0) && @tw == (0,0) && @tw2 == (0,0) && @tw3 == \
            (0,0) && @tha2 == false)
endheading

heading
  caption = "Morph Parameters  [active]"
  visible = (@change != 0 || @exp1 != (1,0) || @exp2 != (1,0) || \
            @exp3 != (1,0) || @tw != (0,0) || @tw2 != (0,0) || @tw3 != (0,0) \
            || @tha2 == true)
endheading

  param showm
    caption = "Morph Parameters"
    hint = "Additional shaping parameters and functions."

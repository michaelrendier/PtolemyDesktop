          (@fn5Q(xzxQ-(shapeAdjust5Q-1))-shapeAdjust1Q)+@fn6Q\
          (yzyQ))-4*(abs(@fn7Q(xzxQ))-shapeAdjust1Q)*@fn8Q(yzyQ^2)-zzortQ


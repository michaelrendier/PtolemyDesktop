    default = (0,0)
    visible = @tha2
  endparam

  complex param tw5
    caption = "Twist Z2"
    default = (0,0)
    visible = @tha2 && @change > 0
  endparam

  complex param tw6
    caption = "Twist Z3"
    default = (0,0)
    visible = @tha2 && @change > 5
  endparam

  param op
    caption = "Operator"
    enum = "+""-""*""/""^"
    default = 0
    visible = @change > 5
    endparam

  func nufunc

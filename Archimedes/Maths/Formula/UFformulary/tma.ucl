          2*shapeAdjust3Q)))-zzortQ

   elseif @trapTypeQ == "Pisces Curve"

     zzQ = @fn1Q((@fn2Q(xzxQ^(2*shapeAdjust1Q))-1)^2-@fn3Q(.6*yzyQ^2+ \

     visible = @light == true && @pct == 1 && @lightPar
  endfunc

   complex param ltexp
     caption = "Fill Light Intensity"
     default = (2,0)
     visible = @light == true && @pct == 1 && @lightPar
   endparam

   complex param ztt1
     caption = "Fill Light Offset"
     default = (0,0)
     visible = @light == true && @pct == 1 && @lightPar && @begex == 1
   endparam

   complex param ztt2
     caption = "Fill Light Strength"
     default = (1,0)
     visible = @light == true && @pct == 1 && @lightPar && @begex == 1
   endparam

   complex param ztt3
     caption = "Fill Light Power"
     default = (1,0)
     visible = @light == true && @pct == 1 && @lightPar && @begex == 1

   endparam

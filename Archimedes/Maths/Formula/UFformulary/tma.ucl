    elseif ( @realfront == 12 )
      tempx = atan( ftemp )
    elseif ( @realfront == 13 )
      tempx = sinh( ftemp )
    elseif ( @realfront == 14 )
      tempx = cosh( ftemp )
    elseif ( @realfront == 15 )
      tempx = tanh( ftemp )
    elseif ( @realfront == 16 )

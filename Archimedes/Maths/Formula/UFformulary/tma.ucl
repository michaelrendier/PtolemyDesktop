      dave = dsum/(i+1)
    elseif @mode_change == 2
      dsum = cabs(log(dist +(dsum)))
      dave = dsum/(i+1)
    elseif @mode_change == 3
      dsum = |log(dist +(dsum))|
      dave = dsum/(i+1)

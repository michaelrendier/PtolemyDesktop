   elseif @trapTypeQ == "Thorned Cross"

     zzQ = @fn1Q(@fn2Q((yzyQ)^yzyQ* \
          xzxQ)+@fn3Q(xzxQ+(1-shapeAdjust1Q)))-zzortQ

   elseif @trapTypeQ == "Three Point Curve"

     zzQ = @fn1Q((@fn2Q(xzxQ^2)-shapeAdjust1Q^2)*@fn3Q(xzxQ^2-shapeAdjust3Q)^2+\
          @fn4Q(yzyQ^4-shapeAdjust2Q^2)^2)- zzortQ


                (z5-ptp) + (z6-ptp) + (z7-ptp) + (z8-ptp)
 endif

  float sum = 0
  int points = @points


if @trapping == "Closest"
 if @trapMode == "Straight"
  if @sumMode == "Normal"
    if @center
      if dist0 < min_dist0
        min_dist0 = dist0 + @edge/3
        trap_i = i
        trap_z = ((z1-@distz1)*@distz2)^@distz
        trap2_z = ((zz-@distz1)*@distz2)^@distz
        trap3_z = ((zq-@distz1)*@distz2)^@distz

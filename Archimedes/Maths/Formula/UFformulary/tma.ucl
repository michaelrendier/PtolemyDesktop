    if @fbminit == 0
      pfb = (@fntx9(@fntx8(tz))^@exad8)* @fbmscale * r1 + @fbmoffset
    elseif @fbminit == 1
      pfb = (@fntx8(real(tz))^@exad8+@fntx9(imag(tz))^@exad9)* @fbmscale * r1 + \
             @fbmoffset
    elseif @fbminit == 2
      pfb = (@fntx8(real(tz))^@exad8-@fntx9(imag(tz))^@exad9)* @fbmscale * r1 + \
             @fbmoffset
    elseif @fbminit == 3
      pfb = (@fntx8(real(tz))^@exad8*@fntx9(imag(tz))^@exad9)* @fbmscale * r1 + \
             @fbmoffset
    elseif @fbminit == 4
      pfb = (@fntx8(imag(tz))^@exad8-@fntx9(real(tz))^@exad9)* @fbmscale * r1 + \
             @fbmoffset
    elseif @fbminit == 5
      pfb = (@fntx9(@fntx8(x))^@exad8)* @fbmscale * r1 + @fbmoffset
    elseif @fbminit == 6

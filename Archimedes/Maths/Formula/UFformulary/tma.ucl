   elseif @op == "*"
    z1 = z1q * z1p
   elseif @op == "/"
    z1 = z1q / z1p
   elseif @op == "^"
    z1 = z1q ^ z1p
   endif

  elseif @change == "9"
   if @mmode3 == "z+|z|"
     z1q  =  @nufunc3(oo+hh)^@exp2
   elseif @mmode3 == "z-|z|"
    z1q = @nufunc3(oo-hh)^@exp2
   elseif @mmode3 == "|z|-z"
    z1q = @nufunc6(jj^@exp6-pp)^@exp2
   elseif @mmode3 == "z*|z|"

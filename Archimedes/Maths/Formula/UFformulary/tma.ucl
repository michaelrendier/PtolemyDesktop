   elseif @op == "/"
    z1 = z1q / z1p
   elseif @op == "^"
    z1 = z1q ^ z1p
   endif
  endif
 endif


  p = fn1(z1 + @start)
  x = real(p-@xp) * 1/@scale
  y = imag(p-flip(@yp)) * 1/@scale

; Iterate the Popcorn formula
  pop_iter = 0
  while pop_iter < @max_iterations
    xxx = x

 if @style == 0

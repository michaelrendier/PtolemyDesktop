   elseif @trapTypeQ == "Lemniscate Corrected"

     zzQ = @fn1Q(@fn2Q(xzxQ^4+(1-shapeAdjust2Q))+yzyQ^4+3* xzxQ^2*yzyQ^2-2* \
          shapeAdjust1Q^2*(@fn3Q(xzxQ^(2*shapeAdjust3Q))-@fn4Q(yzyQ)))-zzortQ


          (@osc31amp != 0.0) && (@osc32amp != 0.0) && (@osc33amp != 0.0)
  endparam
  param osc33sin
    caption = "SetC Osc3 Sine?"
    default = FALSE
    hint = "If enabled, then the sine function, rather than cosine, is used \

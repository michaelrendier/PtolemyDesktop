    endif
    y = real(@fn9(y - @tad/10))
    if @sa < 0 && sn == -1
      y = y * (-@sa+5)/5
      vsa = sn*@sa/20
    endif
    if @sb > 0
      y = y % vsb
    endif
    if @m % 2 == 0
      x = zz - @mul*(real(abs(@fn1(y - abs(@fn2(y))))))
    else
      if @mc < 0
        x = zz - @mul*(real(@fn1(y + @fn2(y))))/2
      else
        x = zz - @mul*y
      endif
    endif
    if @sb < 0

    visible = @draw == "Separate" && @begex == 1 && @distyp4 == "Function"
  endfunc

  int param distyp5
    caption = "Trap 5"
    enum = "Normal""Modulus""Real""Imag""Zero""Function"
    default = 0
    hint = "Determines the mode of the 5th trap"
    visible = @draw == "Separate" && @begex == 1

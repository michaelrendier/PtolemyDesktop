    endif ; @absolutei

    zangle = atan2(z1)
    if zangle < 0
      zangle = zangle + twopi
    endif ; zangle

    ; Initialize front end real, front end imag, if desired

    ftemp = @rfscale * real(ztemp)

    if @absoluter2
      ftemp = abs(ftemp)
    endif ; @absoluter2

    if ( @realfront == 0 )
      tempx = ftemp
    elseif ( @realfront == 1 )
      tempx = 1/ftemp
    elseif ( @realfront == 2 )
      tempx = ftemp * ftemp
    elseif ( @realfront == 3 )
      tempx = 1 / ( ftemp * ftemp )
    elseif ( @realfront == 4 )
      tempx = log(ftemp)
    elseif ( @realfront == 5 )

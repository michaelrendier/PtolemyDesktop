          "log(r)^2" "sin(r)sin(2r)" "e^2r" "e^-2r" "sinh(1/r)cosh(1/r)" \
          "sinh(1/r)^2" "sinh(r)cosh(1/r)" "sinh(r)sinh(1/r)" "sin(r)sinh(r)" \
          "sin(r)cosh(r)" "sin(r)^2*sinh(r)^2" "sin(r)e^r" "cos(r)e^r" \
          "sinh(r)e^r" "cosh(r)e^r" "sin(r)log(r)" "cos(r)log(r)" "sinh(r)log(r)" \
          "cosh(r)log(r)" \
          "e^(r^2)"  "e^(1/(r^2))"  "abs(r)"  "round(r)" "trunc(r)" \
          "ceil(r)"  "floor(r)" "r/log(r)" "log(r)/r" "(e^r)/r" "(e^(1/r))/r" \
          "(e^(r^2))/r" "(e^(1/(r^2))/r" "r*e^(r^2)" "r*e^(1/(r^2))" \
          "e^(-r^2)"  "e^(-1/(r^2))" "(e^(-r^2))/r" "(e^(-1/(r^2))/r" \
          "r*e^(-r^2)" "r*e^(-1/(r^2))"
    default = 0
    hint = "This function can warp the initial value of real(z) before input to \
          the 'Z Initialization' function. For 'r^power' set param 'FrontEndReal \
          Power'"
    visible = @showmodulators
  endparam
  param rfpower
    caption = "FrontEndReal Power"
    default = 4.0
    hint = "Real(z) exponent if param 'FrontEndReal Warp' is set to 'r^power'"
    visible = (@realfront == "r^power") && @showmodulators
  endparam
  param rfscale

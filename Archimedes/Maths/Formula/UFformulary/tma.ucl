    default = ident()
    visible = @adv
  endfunc

  func nufunc2
    caption = "Morph function 2"
    default = ident ()
    visible = @adv && @change > 0
  endfunc

  func nufunc3
    caption = "Morph function 3"
    default = ident ()
    visible = @adv && @change > 5
  endfunc

  func nufunc4

            endif
          endwhile
        endif
      endif
       if @pattern != 0
        patnum = patnum + 1
       endif
    endif
    
  if (@trapalliterations == false || trapping) ; if we're checking for traps...
    if @edges == "Closest"
     if temp < min_dist
      min_dist = temp + @edge*.1
      trap_z = z1
      trap2_z = #z
      trap_iter = iter
      trap_point = a
      trapped = true
    endif

   elseif @edges == "First"
    if temp < @threshold

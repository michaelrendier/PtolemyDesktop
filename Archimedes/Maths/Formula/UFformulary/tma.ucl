      zz = acosh(@fnzzz(acos(zz*@zval-@zval3)^@zval2))
    elseif @zchoice == "Outerlight"
      zz = acosh(@fnzzz(acosh(zz*@zval-@zval3)^@zval2))
    elseif @zchoice == "Glow"
      zz = log(@fnzzz(zz*@zval-@zval3)^@zval2)
    elseif @zchoice == "Diffuse Glow"
      zz = log(atan(@fnzzz(zz*@zval-@zval3)^@zval2))
    elseif @zchoice == "Function"
      zz = @zchfn(@fnzzz(zz*@zval-@zval3)^@zval2)
    endif
  else

  if @ztraptyp == "Normal"
    ztt = z1
  elseif @ztraptyp == "Modulus"
    ztt = |z1|
  elseif @ztraptyp == "Atan2"
    ztt = atan2(z1)
  elseif @ztraptyp == "Real"
    ztt = real(z1)
  elseif @ztraptyp == "Imag"
    ztt = imag(z1)
  endif

  ztu = @fnztt(((ztt-@ztt1)*@ztt2)^@ztt3)

  if @lighttyp == false
    if @zchoice == "Toplight"
      zz = ztu-cabs(@gofn((flip(@fnzzz(zz*@zval-@zval3)^@zval2))^@ltexp))
    elseif @zchoice == "Edgelight"
      zz = ztu-cabs(@gofn((atan(atanh(@fnzzz(zz*@zval-@zval3)^@zval2)))^@ltexp))
    elseif @zchoice == "Dark Edgelight"
      zz = ztu-cabs(@gofn((atanh(@fnzzz(zz*@zval-@zval3)^@zval2))^@ltexp))

     elseif @opxy == "X-Y"
       xb = (@fn8((@nufnx(x-@px1)*@px2)^@px3 - \
             @nufny(flip(y-@py1)*@py2)^@py3))^@pwr
     elseif @opxy == "Y-X"
       xb = (@fn8(@nufny((flip(y-@py1)*@py2)^@py3) - \
             @nufnx(x-@px1)*@px2)^@px3)^@pwr
     endif

   else
     if @opxy == "X+Y"

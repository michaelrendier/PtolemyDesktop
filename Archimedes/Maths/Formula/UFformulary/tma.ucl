  elseif @distyp2 == "Imag"
    ty = imag(abs(z2a-ptp))
  elseif @distyp2 == "Zero"
    ty = 0
  elseif @distyp2 == "Function"
    ty = cabs(@fncorr2(z2a-ptp))
  endif

  if @distyp3 == "Normal"
    ui = cabs(z3a-ptp)
  elseif @distyp3 == "Modulus"
    ui = |z3a-ptp|
  elseif @distyp3 == "Real"

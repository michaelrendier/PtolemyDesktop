   caption  = "Init Function 2"
   default = ident()
   hint = "Modifies the 2nd variable defined in \
     'Geometrix Initialization'"
   visible = @advt && @advtr
  endfunc

  complex param txia5
    caption = "Pattern 1"
    default = (0.0,0.0)

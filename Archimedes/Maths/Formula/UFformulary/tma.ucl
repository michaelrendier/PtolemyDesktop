    default = (1,0)
  endparam

  complex param exp3
    caption = "Bias 2"
    default = (1,0)
    visible = @change > 0
  endparam

  complex param exp2
    caption = "Bias 3"
    default = (1,0)
    visible = @change > 5
  endparam

  complex param exp4
    caption = "Bias Z1"
    default = (1,0)
    visible = @tha2
  endparam

  complex param exp5
    caption = "Bias Z2"
    default = (1,0)
    visible = @tha2 &&  @change > 0
  endparam

  complex param exp6
    caption = "Bias Z3"
    default = (1,0)
    visible = @tha2 && @change > 5
  endparam

  complex param tw

          (@fn5Q(xzxQ-(shapeAdjust5Q-1))-shapeAdjust2Q)+ \
          @fn6Q(yzyQ))-4*shapeAdjust1Q* \
          (abs(@fn7Q(xzxQ+(shapeAdjust6Q-1))-shapeAdjust2Q))* \
          @fn8Q(xzxQ^(2*shapeAdjust7Q))-zzortQ

   elseif @trapTypeQ == "Miscellanea"

     zzQ = @fn1Q(yzyQ^(2))-@fn3Q(xzxQ^2+(1-shapeAdjust2Q)*(xzxQ^shapeAdjust3Q)\
           -(yzyQ)*(shapeAdjust1Q*@fn2Q(yzyQ^xzxQ)-shapeAdjust2Q)+4*(@fn3Q\

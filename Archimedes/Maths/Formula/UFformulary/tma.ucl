   elseif @mmode2 == "|z|/z"
     z1p =  nuvar^@exp3/@nufunc5(ff/gg)^@exp1
   endif

   if @op == "+"
    z1 = z1q + z1p
   elseif @op == "-"
    z1 = z1q - z1p
   elseif @op == "*"
    z1 = z1q * z1p
   elseif @op == "/"
    z1 = z1q / z1p
   elseif @op == "^"
    z1 = z1q ^ z1p
   endif

 elseif @change == "11"
   if @mmode3 == "z+|z|"

   elseif @trapTypeQ == "Mousehead Curve"

     zzQ = @fn1Q(((@fn2Q(xzxQ^shapeAdjust2Q)-shapeAdjust1Q)^2+ \
          @fn3Q(yzyQ^2+(1-shapeAdjust3Q)))*(@fn4Q(xzxQ+(1-shapeAdjust4Q))* \
          (@fn5Q(xzxQ-(shapeAdjust5Q-1))-shapeAdjust1Q)+ \
          @fn6Q(yzyQ^1))-4*(abs(xzxQ)-shapeAdjust1Q)*@fn7Q(yzyQ^2))-zzortQ

   elseif @trapTypeQ == "Nested Ovals"

     zzQ = @fn1Q(@fn2Q(yzyQ^2)*(shapeAdjust1Q^2- \

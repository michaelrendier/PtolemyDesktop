                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  z=c=1/pixel2-log(pixel2-1/cos(.1/pixel2))^-2.5 \
      -conj(.1/pixel2)
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = pixel2/imag(p2) + .00895
  l1=round(real(p1)), l2=round(imag(p1))
  l3=round(real(p2)), l4=round(imag(p2))
  float bailout=16, int iter=0
loop:
  IF (iter==l1)
    c = c1, z=0
  ELSEIF (iter==l2)
    c = c2, z=0
  ELSEIF (iter==l3)
    c = c3, z=0
  ELSEIF (iter==l4)
    c = c4, z=0
  ENDIF
  c = c + k
  z = z^2 + c
  iter=iter+1
bailout:
  |real(z)| <= bailout
default:
  title = "Carr 2507"
  periodicity = 0
  maxiter = 500
  magn = .13
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (200,250)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
}

Carr2508 (YAXIS) {; Updated for UF by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. [101324,3444],1996
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  z=flip(conj(abs(pixel2*sin(pixel2+1))))
  c=flip(conj(abs(pixel2^2)))-conj(.1/pixel2)
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = pixel2/imag(p2) + .000995
  l1=round(real(p1)), l2=round(imag(p1))
  l3=round(real(p2)), l4=round(imag(p2))
  float bailout=16, int iter=0
loop:
  IF (iter==l1)
    z=-.1/c, c=c1
  ELSEIF (iter==l2)
    z=-.1/c, c=c2
  ELSEIF (iter==l3)
    z=-.1/c, c=c3
  ELSEIF (iter==l4)
    z=-.1/c, c=c4
  ELSE
    z=z-.1/c
  ENDIF
  c = c + k
  z = z^2 + c
  iter=iter+1
bailout:
  |real(z)| <= bailout
default:
  title = "Carr 2508"
  periodicity = 0
  maxiter = 500
  magn = 1.4
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (200,250)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
}

Carr2509 (YAXIS) {; Updated for UF by Erik Reckase, February 2000
                  ; Modified Sylvie Gallet frm. 
init:
  pixel2=-abs(real(pixel))+flip(imag(pixel))
  z=flip(conj(abs(pixel2*conj(cos(pixel2-1)))))+.3
  c=flip(conj(abs(pixel2^3)))-conj(.1/pixel2)
  c1=1.5*z, c2=2.25*z, c3=3.375*z, c4=5.0625*z
  k = pixel2/imag(p2) + .000995
  l1=round(real(p1)), l2=round(imag(p1))
  l3=round(real(p2)), l4=round(imag(p2))
  float bailout=16, int iter=0
loop:
  IF (iter==l1)
    z=-.1/c, c=c1
  ELSEIF (iter==l2)
    z=-.1/c, c=c2
  ELSEIF (iter==l3)
    z=-.1/c, c=c3
  ELSEIF (iter==l4)
    z=-.1/c, c=c4
  ELSE
    z=z-.1/c
  ENDIF
  c = c + k
  z = z^2 + c
  iter=iter+1
bailout:
  |real(z)| <= bailout
default:
  title = "Carr 2509"
  periodicity = 0
  maxiter = 500
  magn = 1.5
  center = (0,0)
  method = multipass
  param p1
    caption = "Iter Limits 1,2"
    default = (100,150)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
  param p2
    caption = "Iter Limits 3,4"
    default = (200,250)
    hint = "0< Re(P1) < Im(P1) < Re(P2) < Im(P2) <maxiter \
            for best results"
  endparam
}


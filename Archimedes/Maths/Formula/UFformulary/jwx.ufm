Formula1 {
init:
  z=1
loop:
  z=(1 / z^3) -0.5 + #pixel
bailout:
 |z| < 100
default:
  title = "jwx.ufm:Formula1"
}

Formula2 {
init:
  z=1
loop:
  z=(1 / z^2) +1 + #pixel
bailout:
 |z| < 5
default:
  title = "jwx.ufm:Formula2"
}

Modes{
init:
z=1
loop:
z= sqrt((1/(z^5)))-0.5+ #pixel
bailout:
|z|< 100
default:
title = "jwx.ufm:Modes"
}


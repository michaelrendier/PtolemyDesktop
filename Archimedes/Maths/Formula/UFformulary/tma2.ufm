 IF @opx == "+"
  r = (x^@eex1*@mx1+@px1)+@fn6(y^@eey1*@my1+@py1)
 ELSEIF @opx == "-"
  r = (x^@eex1*@mx1+@px1)-@fn6(y^@eey1*@my1+@py1)
 ELSEIF @opx == "*"
  r = (x^@eex1*@mx1+@px1)*@fn6(y^@eey1*@my1+@py1)
 ELSEIF @opx == "/"
  r = (x^@eex1*@mx1+@px1)/@fn6(y^@eey1*@my1+@py1)
 ELSEIF @opx == "^"
  r = (x^@eex1*@mx1+@px1)^@fn6(y^@eey1*@my1+@py1)
 ENDIF
 
 IF @opy == "+"
  s = (y^@eey2*@my2+@py2)+@fn7(x^@eex2*@mx2+@px2)
 ELSEIF @opy == "-"
  s = (y^@eey2*@my2+@py2)-@fn7(x^@eex2*@mx2+@px2)
 ELSEIF @opy == "*"
  s = (y^@eey2*@my2+@py2)*@fn7(x^@eex2*@mx2+@px2)
 ELSEIF @opy == "/"

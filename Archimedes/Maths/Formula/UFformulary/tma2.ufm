   if @vinV7 == true
      vv7 = ((xx-@v7a)*@v7b)^@v7c
    else
      vv7 = ((y-@v7a)*@v7b)^@v7c
    endif

   if @vinV8 == true
      vv8 = ((y-@v8a)*@v8b)^@v8c
    else
      vv8 = ((xx-@v8a)*@v8b)^@v8c
    endif

   if @vinOp1 == "1"
    if @vinFlavor == true
     if @flavor == 0
       x = cabs(@vinfnx1(vv1)) - @h2r * cabs(@vinfn1(vv2 + @vinfn3 \
           (@va * vv3 )))
       y = cabs(@vinfny1(vv4)) + @h2i * cabs(@vinfn2(vv5 + @vinfn4 \

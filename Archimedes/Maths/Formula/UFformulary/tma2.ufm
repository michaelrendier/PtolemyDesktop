  endfunc
    
  func fny
    caption = "Global Y Fn"
    default = ident()
  endfunc   

switch:
  type = "mandyGlyph"
  startseed = pixel
  flavor = @flavor
  a1= @a1
  a2 = @a2
  h1a = @h1a
  h1b = @h1b

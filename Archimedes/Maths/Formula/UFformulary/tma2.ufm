        newx = real(@vinfny1(y)) + real(@vinfn11(@va * newx))
        newy = real(@vinfnx1(x)) - real(@vinfn11(@va * newy))
       elseif @vinOp3r == "3"
        newx = real(@vinfny1(y)) - real(@vinfn11(@va * newx))
        newy = real(@vinfnx1(x)) + real(@vinfn11(@va * newy))

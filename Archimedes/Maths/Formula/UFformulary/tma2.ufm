  endparam
 param exp7
  caption = "exponent 7"
  default = (1,0)
  endparam
  param op1
  caption = "operator 1"
  enum = "*""-""+"
  default = 0
  endparam
  param op2
  caption = "operator 2"
  enum = "/""*""-""+"
  default = 1
  endparam
  param op3
  caption = "operator 3"
  enum = "/""*""-""+"
  default = 1
  endparam
  param op4
  caption = "operator 4"
  enum = "/""*""-""+""^"
  default = 3
  endparam
  param group
  caption = "grouping"
  default = 4
  enum = "none""first2""first3""first4""first5""second2""second3"\
  "second4""second5""third2""third3""fourth2""combo1""combo2"
  endparam

        y = w + imag(@h1 * @popfn3(qc - @popfn4(imag(@popc) * qd)))
      endif
     endif

  elseif @formula == "Vine"

   if @vinV1 == true
     vv1 = ((y-@v1a)*@v1b)^@v1c
      vv4 = ((x-@v4a)*@v4b)^@v4c
   else
     vv1 = ((x-@v1a)*@v1b)^@v1c
      vv4 = ((y-@v4a)*@v4b)^@v4c
   endif

   if @vinV2 == true
      vv2 = ((xx-@v2a)*@v2b)^@v2c
    else
      vv2 = ((y-@v2a)*@v2b)^@v2c
    endif

   if @vinV3 == true
      vv3 = ((xx-@v3a)*@v3b)^@v3c
    else
      vv3 = ((y-@v3a)*@v3b)^@v3c
    endif

   if @vinV5 == true
      vv5 = ((y-@v5a)*@v5b)^@v5c
    else
      vv5 = ((xx-@v5a)*@v5b)^@v5c
    endif

   if @vinV6 == true
      vv6 = ((y-@v6a)*@v6b)^@v6c
    else

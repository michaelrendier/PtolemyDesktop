ELSEIF (@op2 == 3)
IF (@op1 == 0)
z = aa - qq * vv + ww / xx / yy
ELSEIF (@op1 == 1)
z = aa - qq - vv + ww / xx / yy
ENDIF
ENDIF
ELSEIF (@op3 == 1)

ENDIF
ELSEIF (@op2 == 4)
IF (@op1 == 0)
z = aa* (qq) * vv ^ ww * xx
ELSEIF (@op1 == 1)
z = aa* (qq) - vv ^ ww * xx
ELSEIF (@op1 == 2)
z = aa* (qq) + vv ^ ww * xx

ELSEIF (@op1 == 3)
z = aa* (qq) ^ vv ^ ww * xx
ENDIF
ENDIF
ELSEIF (@op3 == 2)
IF (@op2 == 0)
IF (@op1 == 0)
z = aa* (qq) * vv / ww - xx
ELSEIF (@op1 == 1)
z = aa* (qq) - vv / ww - xx
ELSEIF (@op1 == 2)
z = aa* (qq) + vv / ww - xx
ELSEIF (@op1 == 3)

CoolBrew {
  ; Toby Marshall, May 2002
  ; Use with the Julia switch. All functions
  ; and parameters can be varied to explore
  ; different Julia sets. Some parameter
  ; combinations give black M sets, but they
  ; too sometimes yield interesting results 
  ; with the switch. Try a higher value for 
  ; "init z" if you encounter a black M set
  ; after setting operators, it might help.
  ; Bailout values are especially critical 
  ; with this formula--experiment with them.

    
init:
  
  z = @start
  complex frog = @frog*(0.0,1.0)
  

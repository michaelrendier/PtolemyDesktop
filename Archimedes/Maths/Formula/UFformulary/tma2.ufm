SpiralsRedux2 {
    ; Toby Marshall, Sept. 2002
  ; This formula has a built-in Julia switch
  ; All functions and parameters can be varied 
  ; to explore different Julia sets. 
  ; Many thanks to Dave Makin for his extended
  ; switching and switch parameters.    
      
init:
  
  complex c = #pixel
  complex z = @startSeed
   IF (@mode == "Mandelbrot") 
     z = @startSeed
       ENDIF
   IF @mode == "Julia"
     z = #pixel
     c = @startSeed
   IF @scale != 1.0
    z = z/@scale
      ENDIF
   IF @center != (0,0)
    z = z + @center
     ENDIF
     ENDIF

loop:
  aa = fn1 (z-@p1)
  bb = fn2 (c-@p2)
  cc = fn3 (z-@p3)
  dd = fn4 (c-@p4)
  ee = @fn5 (z-@p5)


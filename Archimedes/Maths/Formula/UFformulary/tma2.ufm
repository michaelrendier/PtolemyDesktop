  (@bail == 6 && (sqr(real(z) + imag(z)) <= @bailout) ||                     \
  (@bail == 7 && real(@bailfunc(z)) <=@bailout))

switch:
  type = "MandalaNuova"
  startSeed = #pixel
  bailout = bailout
  fn1 = @fn1
  fn2 = @fn2
  fn3 = @fn3
  fn4 = @fn4

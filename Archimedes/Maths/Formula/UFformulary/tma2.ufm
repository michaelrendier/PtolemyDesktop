   x = x + @h1 * real(@fn1a(a^@ex1 + @fn2a(@a1 * (c^@ex3 + @fn3a(@b1 - g^@ex6)))))
   y = y + @h2 * real(@fn1b(b^@ex2 + @fn2b(@a2 * (d^@ex4 + @fn3b(@b2 / f^@ex5)))))

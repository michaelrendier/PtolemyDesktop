    caption = "Y Strength"
    default = (1,0)
  endparam

  complex param pary3
    caption = "Y Power"
    default = (1,0)
  endparam
  complex param zpar1
    caption = "Z Offset"
    default = (0,0)
  endparam

  complex param zpar2
    caption = "Z Strength"
    default = (1,0)
  endparam

  complex param zpar3
    caption = "Z Power"
    default = (1,0)
  endparam

  complex param cpar1

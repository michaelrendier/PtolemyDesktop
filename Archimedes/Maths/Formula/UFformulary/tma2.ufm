    z = (@fnz(z-@zg)*@ezg*@fnc((c-@cg)*@cmg)^@ecg)+(real(z)+imag(z))
    z = @fnz(z-@zg)*@ezg / @fnc((c-@cg)*@cmg)^@ecg           

  z = @start
loop:
IF (@op == 0)
z = @fn1(z^@fn4(1/#pixel))/ (fn2((@fn5(#pixel^@p4)*@p3)^@p1)+fn3((@fn6(#pixel^@p4)*@p3)^@p1))/@p2
 ELSEIF (@op == 1)
 z = @fn1(z^@fn4(1/#pixel))^ (fn2((@fn5(#pixel^@p4)*@p3)^@p1)+fn3((@fn6(#pixel^@p4)*@p3)^@p1))/@p2
 ENDIF
  
  bailout:

    caption = "Start/Seed"
    default = (0.0,0.0)
  endparam

  int param bail
    caption = "Bailout"
    default = 20
  endparam

  int param flavor
    caption = "Flavor"
    default = 2
    min = 0
  endparam 

  complex param parx
    caption = "X Offset"
    default = (0,0)
  endparam
  
  complex param parx2
    caption = "X Strength"
    default = (1,0)

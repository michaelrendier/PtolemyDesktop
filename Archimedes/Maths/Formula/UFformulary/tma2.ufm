  endfunc

  func fn3b
    caption = "Function 3b"
    default = sin()
  endfunc  
    
  func fn6
    caption = "Shading function 1"
    default = ident()
  endfunc  

  func fn7
    caption = "Shading Function 2"
    default = ident()
  endfunc      
  
  func fn4
    caption = "Global Function 1"
    default = flip()
  endfunc  

  func fn5
    caption = "Global Function 2"
    default = ident()
  endfunc   

 }


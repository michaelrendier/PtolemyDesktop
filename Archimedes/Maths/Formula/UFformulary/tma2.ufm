        y = w + imag(@h1 * @popfn3(qc + @popfn4(imag(@popc) * qd)))
      endif
     elseif @popflavor1 == "2"
      if @popFlavor2 == "1"
        x = v - real(@h1 * @popfn1(qa + @popfn2(real(@popc) * qb)))
        y = w - imag(@h1 * @popfn3(qc - @popfn4(imag(@popc) * qd)))
      elseif @popFlavor2 == "2"
        x = v - real(@h1 * @popfn1(qa + @popfn2(real(@popc) * qb)))
        y = w + imag(@h1 * @popfn3(qc - @popfn4(imag(@popc) * qd)))
      elseif @popFlavor2 == "3"
        x = v + real(@h1 * @popfn1(qa + @popfn2(real(@popc) * qb)))
        y = w - imag(@h1 * @popfn3(qc - @popfn4(imag(@popc) * qd)))
      elseif @popFlavor2 == "4"
        x = v + real(@h1 * @popfn1(qa + @popfn2(real(@popc) * qb)))
        y = w + imag(@h1 * @popfn3(qc - @popfn4(imag(@popc) * qd)))
      endif
     elseif @popflavor1 == "3"
      if @popFlavor2 == "1"
        x = v - real(@h1 * @popfn1(qa - @popfn2(real(@popc) * qb)))
        y = w - imag(@h1 * @popfn3(qc + @popfn4(imag(@popc) * qd)))
      elseif @popFlavor2 == "2"
        x = v - real(@h1 * @popfn1(qa - @popfn2(real(@popc) * qb)))
        y = w + imag(@h1 * @popfn3(qc + @popfn4(imag(@popc) * qd)))

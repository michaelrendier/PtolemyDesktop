  if @moderi3 == "+"; R/I combination Z3
   if @opri3=="+";    Z3 param operator
     zri3 = (@fna3(real(ari3-@riz3)*@rzm3)+@priz3)+(@fnb3(imag(ari3-imz3)*@izm3)+@pimz3)
   elseif @opri3=="-"
     zri3 = (@fna3(real(ari3-@riz3)*@rzm3)-@priz3)+(@fnb3(imag(ari3-imz3)*@izm3)+@pimz3)
   elseif @opri3=="*"
     zri3 = (@fna3(real(ari3-@riz3)*@rzm3)*@priz3)+(@fnb3(imag(ari3-imz3)*@izm3)+@pimz3)
   elseif @opri3=="/"
     zri3 = (@fna3(real(ari3-@riz3)*@rzm3)/@priz3)+(@fnb3(imag(ari3-imz3)*@izm3)+@pimz3)
   elseif @opri3=="^"
     zri3 = (@fna3(real(ari3-@riz3)*@rzm3)^@priz3)+(@fnb3(imag(ari3-imz3)*@izm3)+@pimz3)
   endif

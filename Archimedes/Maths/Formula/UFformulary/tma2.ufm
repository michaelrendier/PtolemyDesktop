     newx = y - real(@h2a)*@fn1(@a1 * newx) - imag(@h2a)*@fn3(@a2 * newx)
     newy = x - real(@h2b)*@fn2(@a3 * newy) - imag(@h2b)*@fn4(@a4 * newy)
   endwhile
   x = x - real(@h1a)*@fn5(newx) - imag(@h1a)*@fn7(newx)
   y = y - real(@h1b)*@fn6(newy) - imag(@h1b)*@fn8(newy)
 ENDIF
ENDIF

 IF @op == "x+y"
  z = @fna((x-@parx)*@parx2)^@parx3 + flip(@fnb((y-@pary)*@pary2)^@pary3)
 ELSEIF @op == "x-y"
  z = @fna((x-@parx)*@parx2)^@parx3 - flip(@fnb((y-@pary)*@pary2)^@pary3)
 ELSEIF @op == "y-x"
  z = flip(@fnb((y-@pary)*@pary2)^@pary3) - @fna((x-@parx)*@parx2)^@parx3
 ENDIF
 
  IF @loop == "Simple"
    z = @fnz((z-@zpar1)*@zpar2)^@zpar3 * @fnc((c-@cpar1)*@cpar2)^@cpar3
  ELSEIF @loop == "Complex"
   IF @op4 == "+"
    IF @op3 == "+"
       z = @fnz((z-@zpar1)*@zpar2)^@zpar3 + @fnc((c-@cpar1)*@cpar2)^@cpar3 + \
        @fnzz((z-@zzpar1)*@zzpar2)^@zzpar3 + @fncc((c-@ccpar1)*@ccpar2)^@ccpar3
    ELSEIF @op3 == "-"
       z = @fnz((z-@zpar1)*@zpar2)^@zpar3 - @fnc((c-@cpar1)*@cpar2)^@cpar3 + \
        @fnzz((z-@zzpar1)*@zzpar2)^@zzpar3 + @fncc((c-@ccpar1)*@ccpar2)^@ccpar3
    ELSEIF @op3 == "*"
       z = @fnz((z-@zpar1)*@zpar2)^@zpar3 * @fnc((c-@cpar1)*@cpar2)^@cpar3 + \
        @fnzz((z-@zzpar1)*@zzpar2)^@zzpar3 + @fncc((c-@ccpar1)*@ccpar2)^@ccpar3
    ELSEIF @op3 == "/"
       z = @fnz((z-@zpar1)*@zpar2)^@zpar3 / @fnc((c-@cpar1)*@cpar2)^@cpar3 + \
        @fnzz((z-@zzpar1)*@zzpar2)^@zzpar3 + @fncc((c-@ccpar1)*@ccpar2)^@ccpar3
    ELSEIF @op3 == "^"
       z = @fnz((z-@zpar1)*@zpar2)^@zpar3 ^ @fnc((c-@cpar1)*@cpar2)^@cpar3 + \
        @fnzz((z-@zzpar1)*@zzpar2)^@zzpar3 + @fncc((c-@ccpar1)*@ccpar2)^@ccpar3
    ENDIF

   ELSEIF @op4 == "+"
    IF @op3 == "+"
       z = @fnz((z-@zpar1)*@zpar2)^@zpar3 + @fnc((c-@cpar1)*@cpar2)^@cpar3 + \
        @fnzz((z-@zzpar1)*@zzpar2)^@zzpar3 - @fncc((c-@ccpar1)*@ccpar2)^@ccpar3
    ELSEIF @op3 == "-"
       z = @fnz((z-@zpar1)*@zpar2)^@zpar3 - @fnc((c-@cpar1)*@cpar2)^@cpar3 + \
        @fnzz((z-@zzpar1)*@zzpar2)^@zzpar3 - @fncc((c-@ccpar1)*@ccpar2)^@ccpar3
    ELSEIF @op3 == "*"
       z = @fnz((z-@zpar1)*@zpar2)^@zpar3 * @fnc((c-@cpar1)*@cpar2)^@cpar3 + \
        @fnzz((z-@zzpar1)*@zzpar2)^@zzpar3 - @fncc((c-@ccpar1)*@ccpar2)^@ccpar3
    ELSEIF @op3 == "/"
       z = @fnz((z-@zpar1)*@zpar2)^@zpar3 / @fnc((c-@cpar1)*@cpar2)^@cpar3 + \
        @fnzz((z-@zzpar1)*@zzpar2)^@zzpar3 - @fncc((c-@ccpar1)*@ccpar2)^@ccpar3
    ELSEIF @op3 == "^"
       z = @fnz((z-@zpar1)*@zpar2)^@zpar3 ^ @fnc((c-@cpar1)*@cpar2)^@cpar3 + \
        @fnzz((z-@zzpar1)*@zzpar2)^@zzpar3 - @fncc((c-@ccpar1)*@ccpar2)^@ccpar3
    ENDIF

   ELSEIF @op4 == "*"
    IF @op3 == "+"
       z = @fnz((z-@zpar1)*@zpar2)^@zpar3 + @fnc((c-@cpar1)*@cpar2)^@cpar3 + \
        @fnzz((z-@zzpar1)*@zzpar2)^@zzpar3 * @fncc((c-@ccpar1)*@ccpar2)^@ccpar3
    ELSEIF @op3 == "-"
       z = @fnz((z-@zpar1)*@zpar2)^@zpar3 - @fnc((c-@cpar1)*@cpar2)^@cpar3 + \
        @fnzz((z-@zzpar1)*@zzpar2)^@zzpar3 * @fncc((c-@ccpar1)*@ccpar2)^@ccpar3
    ELSEIF @op3 == "*"
       z = @fnz((z-@zpar1)*@zpar2)^@zpar3 * @fnc((c-@cpar1)*@cpar2)^@cpar3 + \
        @fnzz((z-@zzpar1)*@zzpar2)^@zzpar3 * @fncc((c-@ccpar1)*@ccpar2)^@ccpar3
    ELSEIF @op3 == "/"
       z = @fnz((z-@zpar1)*@zpar2)^@zpar3 / @fnc((c-@cpar1)*@cpar2)^@cpar3 + \
        @fnzz((z-@zzpar1)*@zzpar2)^@zzpar3 * @fncc((c-@ccpar1)*@ccpar2)^@ccpar3
    ELSEIF @op3 == "^"
       z = @fnz((z-@zpar1)*@zpar2)^@zpar3 ^ @fnc((c-@cpar1)*@cpar2)^@cpar3 + \
        @fnzz((z-@zzpar1)*@zzpar2)^@zzpar3 * @fncc((c-@ccpar1)*@ccpar2)^@ccpar3
    ENDIF

   ELSEIF @op4 == "/"
    IF @op3 == "+"
       z = @fnz((z-@zpar1)*@zpar2)^@zpar3 + @fnc((c-@cpar1)*@cpar2)^@cpar3 + \
        @fnzz((z-@zzpar1)*@zzpar2)^@zzpar3 / @fncc((c-@ccpar1)*@ccpar2)^@ccpar3
    ELSEIF @op3 == "-"
       z = @fnz((z-@zpar1)*@zpar2)^@zpar3 - @fnc((c-@cpar1)*@cpar2)^@cpar3 + \
        @fnzz((z-@zzpar1)*@zzpar2)^@zzpar3 / @fncc((c-@ccpar1)*@ccpar2)^@ccpar3
    ELSEIF @op3 == "*"
       z = @fnz((z-@zpar1)*@zpar2)^@zpar3 * @fnc((c-@cpar1)*@cpar2)^@cpar3 + \
        @fnzz((z-@zzpar1)*@zzpar2)^@zzpar3 / @fncc((c-@ccpar1)*@ccpar2)^@ccpar3
    ELSEIF @op3 == "/"
       z = @fnz((z-@zpar1)*@zpar2)^@zpar3 / @fnc((c-@cpar1)*@cpar2)^@cpar3 + \
        @fnzz((z-@zzpar1)*@zzpar2)^@zzpar3 / @fncc((c-@ccpar1)*@ccpar2)^@ccpar3
    ELSEIF @op3 == "^"
       z = @fnz((z-@zpar1)*@zpar2)^@zpar3 ^ @fnc((c-@cpar1)*@cpar2)^@cpar3 + \
        @fnzz((z-@zzpar1)*@zzpar2)^@zzpar3 / @fncc((c-@ccpar1)*@ccpar2)^@ccpar3
    ENDIF

   ELSEIF @op4 == "^"
    IF @op3 == "+"
       z = @fnz((z-@zpar1)*@zpar2)^@zpar3 + @fnc((c-@cpar1)*@cpar2)^@cpar3 + \
        @fnzz((z-@zzpar1)*@zzpar2)^@zzpar3 ^ @fncc((c-@ccpar1)*@ccpar2)^@ccpar3
    ELSEIF @op3 == "-"
       z = @fnz((z-@zpar1)*@zpar2)^@zpar3 - @fnc((c-@cpar1)*@cpar2)^@cpar3 + \
        @fnzz((z-@zzpar1)*@zzpar2)^@zzpar3 ^ @fncc((c-@ccpar1)*@ccpar2)^@ccpar3
    ELSEIF @op3 == "*"
       z = @fnz((z-@zpar1)*@zpar2)^@zpar3 * @fnc((c-@cpar1)*@cpar2)^@cpar3 + \
        @fnzz((z-@zzpar1)*@zzpar2)^@zzpar3 ^ @fncc((c-@ccpar1)*@ccpar2)^@ccpar3
    ELSEIF @op3 == "/"
       z = @fnz((z-@zpar1)*@zpar2)^@zpar3 / @fnc((c-@cpar1)*@cpar2)^@cpar3 + \
        @fnzz((z-@zzpar1)*@zzpar2)^@zzpar3 ^ @fncc((c-@ccpar1)*@ccpar2)^@ccpar3
    ELSEIF @op3 == "^"
       z = @fnz((z-@zpar1)*@zpar2)^@zpar3 ^ @fnc((c-@cpar1)*@cpar2)^@cpar3 + \
        @fnzz((z-@zzpar1)*@zzpar2)^@zzpar3 ^ @fncc((c-@ccpar1)*@ccpar2)^@ccpar3
    ENDIF
   ENDIF
  ENDIF
 
bailout:
  iter <= @bail
  
default:
  title = "Mandy Glyph"
  
  param version
    caption = "Version"
    default = 1.0
    visible = false
  endparam

heading
 caption = "Switch Parameters"
 visible = @show
endheading

  param mode
    caption = "Current Mode"
    enum = "Mandelbrot""Julia"
    default = 0
    enabled = false
  endparam

  param SwitchMode
    caption = "Switch to"
    enum = "Mandelbrot""Julia"
    default = 1
    enabled = false
    visible = false
  endparam

  param show

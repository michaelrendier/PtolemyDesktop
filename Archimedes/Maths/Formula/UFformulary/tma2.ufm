   endif         
  endif

; Process Zri3 variable with a C section
  if @act3 == "none"  
    zri3a = zri3 
  elseif @act3 == "+"  
    zri3a = zri3 + @fnact3(c-@act13)^@act23
  elseif @act3 == "-"
    zri3a = zri3 - @fnact3(c-@act13)^@act23
  elseif @act3 == "invert-"
    zri3a = @fnact3(c-@act13)^@act23 - zri3
  elseif @act3 == "*"
    zri3a = zri3 * @fnact3(c-@act13)^@act23
  elseif @act3 == "/"
    zri3a = zri3 / @fnact3(c-@act13)^@act23
  elseif @act3 == "invert/"
    zri3a = @fnact3(c-@act13)^@act23 / zri3
  elseif @act3 == "^"
    zri3a = zri3 ^ @fnact3(c-@act13)^@act23
  elseif @act3 == "invert^"
    zri3a = @fnact3(c-@act13)^@act23 ^ zri3
  endif
  
; Defines Z (mode and variables) for Z1 and Z3 sections
 if @rienable == "1:Z,3:Z"
  if @xz1 == "z"
    a1 = z
  elseif @xz1 == "|z|"
    a1 = |z|
  elseif @xz1 == "atan2(z)"

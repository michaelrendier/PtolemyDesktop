niftyGlyph {
; Original by Samuel Monnier, 19.3.00
; Modified Vine formula (from Mark Townsend)
; Major tweaks by Toby Marshall
; 11.11.2004, v 1.0

init:
  z = #pixel
  x = 0 
  y = 0 
  newx = 0
  newy = 0
  int iter = 0
  int i = 0
   
loop:
  iter = iter + 1
   
  x = real(@fnx(z)) + flip(real(@start/100))
  y = imag(@fny(z)) + flip(imag(@start/100))
  newx = y
  newy = x
  i = 0
IF @op2 == "++++"  
 IF @op1 == "++++"  
   while i < @flavor
     i = i + 1
     newx = y + real(@h2a)*@fn1(@a1 * newx) + imag(@h2a)*@fn3(@a2 * newx)
     newy = x + real(@h2b)*@fn2(@a3 * newy) + imag(@h2b)*@fn4(@a4 * newy)
   endwhile
   x = x + real(@h1a)*@fn5(newx) + imag(@h1a)*@fn7(newx)
   y = y + real(@h1b)*@fn6(newy) + imag(@h1b)*@fn8(newy)
   z = x + flip(y)
 ELSEIF @op1 == "+++-"  
   while i < @flavor
     i = i + 1
     newx = y + real(@h2a)*@fn1(@a1 * newx) + imag(@h2a)*@fn3(@a2 * newx)
     newy = x + real(@h2b)*@fn2(@a3 * newy) - imag(@h2b)*@fn4(@a4 * newy)
   endwhile
   x = x + real(@h1a)*@fn5(newx) + imag(@h1a)*@fn7(newx)
   y = y + real(@h1b)*@fn6(newy) + imag(@h1b)*@fn8(newy)
 ELSEIF @op1 == "++-+"  
   while i < @flavor
     i = i + 1
     newx = y + real(@h2a)*@fn1(@a1 * newx) + imag(@h2a)*@fn3(@a2 * newx)
     newy = x - real(@h2b)*@fn2(@a3 * newy) + imag(@h2b)*@fn4(@a4 * newy)
   endwhile
    x = x + real(@h1a)*@fn5(newx) + imag(@h1a)*@fn7(newx)
    y = y + real(@h1b)*@fn6(newy) + imag(@h1b)*@fn8(newy)
 ELSEIF @op1 == "+-++"  
   while i < @flavor
     i = i + 1
     newx = y + real(@h2a)*@fn1(@a1 * newx) - imag(@h2a)*@fn3(@a2 * newx)
     newy = x + real(@h2b)*@fn2(@a3 * newy) + imag(@h2b)*@fn4(@a4 * newy)
   endwhile
   x = x + real(@h1a)*@fn5(newx) + imag(@h1a)*@fn7(newx)
   y = y + real(@h1b)*@fn6(newy) + imag(@h1b)*@fn8(newy)

 ELSEIF @op1 == "-+++"  
   while i < @flavor
     i = i + 1
     newx = y - real(@h2a)*@fn1(@a1 * newx) + imag(@h2a)*@fn3(@a2 * newx)
     newy = x + real(@h2b)*@fn2(@a3 * newy) + imag(@h2b)*@fn4(@a4 * newy)
   endwhile
   x = x + real(@h1a)*@fn5(newx) + imag(@h1a)*@fn7(newx)
   y = y + real(@h1b)*@fn6(newy) + imag(@h1b)*@fn8(newy)

 ELSEIF @op1 == "++--"  
   while i < @flavor
     i = i + 1
     newx = y + real(@h2a)*@fn1(@a1 * newx) + imag(@h2a)*@fn3(@a2 * newx)
     newy = x - real(@h2b)*@fn2(@a3 * newy) - imag(@h2b)*@fn4(@a4 * newy)
   endwhile
   x = x + real(@h1a)*@fn5(newx) + imag(@h1a)*@fn7(newx)
   y = y + real(@h1b)*@fn6(newy) + imag(@h1b)*@fn8(newy)

 ELSEIF @op1 == "+--+"  
   while i < @flavor
     i = i + 1
     newx = y + real(@h2a)*@fn1(@a1 * newx) - imag(@h2a)*@fn3(@a2 * newx)
     newy = x - real(@h2b)*@fn2(@a3 * newy) + imag(@h2b)*@fn4(@a4 * newy)
   endwhile
   x = x + real(@h1a)*@fn5(newx) + imag(@h1a)*@fn7(newx)
   y = y + real(@h1b)*@fn6(newy) + imag(@h1b)*@fn8(newy)

 ELSEIF @op1 == "--++"  
   while i < @flavor
     i = i + 1
     newx = y - real(@h2a)*@fn1(@a1 * newx) - imag(@h2a)*@fn3(@a2 * newx)
     newy = x + real(@h2b)*@fn2(@a3 * newy) + imag(@h2b)*@fn4(@a4 * newy)
   endwhile
   x = x + real(@h1a)*@fn5(newx) + imag(@h1a)*@fn7(newx)
   y = y + real(@h1b)*@fn6(newy) + imag(@h1b)*@fn8(newy)

 ELSEIF @op1 == "-++-"  
   while i < @flavor
     i = i + 1
     newx = y - real(@h2a)*@fn1(@a1 * newx) + imag(@h2a)*@fn3(@a2 * newx)
     newy = x + real(@h2b)*@fn2(@a3 * newy) - imag(@h2b)*@fn4(@a4 * newy)
   endwhile
   x = x + real(@h1a)*@fn5(newx) + imag(@h1a)*@fn7(newx)
   y = y + real(@h1b)*@fn6(newy) + imag(@h1b)*@fn8(newy)

 ELSEIF @op1 == "+-+-"  
   while i < @flavor
     i = i + 1
     newx = y + real(@h2a)*@fn1(@a1 * newx) - imag(@h2a)*@fn3(@a2 * newx)
     newy = x + real(@h2b)*@fn2(@a3 * newy) - imag(@h2b)*@fn4(@a4 * newy)
   endwhile
   x = x + real(@h1a)*@fn5(newx) + imag(@h1a)*@fn7(newx)
   y = y + real(@h1b)*@fn6(newy) + imag(@h1b)*@fn8(newy)

 ELSEIF @op1 == "-+-+"  
   while i < @flavor
     i = i + 1
     newx = y - real(@h2a)*@fn1(@a1 * newx) + imag(@h2a)*@fn3(@a2 * newx)
     newy = x - real(@h2b)*@fn2(@a3 * newy) + imag(@h2b)*@fn4(@a4 * newy)
   endwhile
   x = x + real(@h1a)*@fn5(newx) + imag(@h1a)*@fn7(newx)
   y = y + real(@h1b)*@fn6(newy) + imag(@h1b)*@fn8(newy)

 ELSEIF @op1 == "+---"  

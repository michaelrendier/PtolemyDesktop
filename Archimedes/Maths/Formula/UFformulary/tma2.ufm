    default = (0,0)
    visible = @loop == "Complex"
  endparam

  complex param ccpar2
    caption = "C2 Strength"
    default = (1,0)
    visible = @loop == "Complex"
  endparam

  complex param ccpar3
    caption = "C2 Power"
    default = (1,0)
    visible = @loop == "Complex"
  endparam

  float param a1
    caption = "Alpha 1"
    default = 2.7
  endparam  

  float param a2
    caption = "Alpha 2"
    default = 2.7
  endparam  
  
  float param a3
    caption = "Alpha 3"
    default = 2.7
  endparam  
  
  float param a4
    caption = "Alpha 4"
    default = 2.7
  endparam  
    
  complex param h1a
    caption = "Step size Ia"
    default = (.05,.05)
  endparam 
   
  complex param h1b
    caption = "Step size Ib"

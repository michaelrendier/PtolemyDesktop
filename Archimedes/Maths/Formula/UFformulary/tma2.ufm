    default = false
  endparam

  float param swscale
     caption = "Scale"
     default = 1
     visible = @show
  endparam

  complex param swcenter
     caption = "Switch Center"
     default = (0,0)
     visible = @show
  endparam

  float param scale
    caption = "Scale Reset"
    default = 1
    visible = @show
  endparam

  complex param center
    caption = "Center Reset"
    default = (0,0)
    visible = @show
  endparam

heading
  caption = "Parameters"
endheading

  param loop
    caption = "Loop Type"

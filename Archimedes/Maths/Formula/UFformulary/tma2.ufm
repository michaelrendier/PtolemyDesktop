       y = cabs(@vinfny2(y)) - @h3i * cabs(@vinfn10(newy))
     elseif @vinOp2c == "4"
       x = cabs(@vinfnx2(x)) + @h3r * cabs(@vinfn9(newx))
       y = cabs(@vinfny2(y)) + @h3i * cabs(@vinfn10(newy))
    endif
   endif

  else
   if @flavor == 0
     x = real(@vinfnx1(vv1)) - @h2r * real(@vinfn1(vv2 + @vinfn3 \

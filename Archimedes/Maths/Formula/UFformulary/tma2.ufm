    caption = "Exponent 6"
    default = (1.0 , 0.0)
    visible = @exp
  endparam
      
  param exp
    caption = "Exponential Parameters"
    default = false
  endparam  
    
heading
 caption = "Functions"
endheading  
  
  func fn1a
    caption = "Function 1a"
    default = sin()
  endfunc  

  func fn1b
    caption = "Function 1b"
    default = sin()
  endfunc  
    
  func fn2a
    caption = "Function 2a"

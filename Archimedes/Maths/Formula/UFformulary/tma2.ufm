     zri1 = (@fna(real(ari1-@riz1)*@rzm1)+@priz1)+(@fnb(imag(ari1-imz1)*@izm1)+@pimz1)
   elseif @opri1=="-"
     zri1 = (@fna(real(ari1-@riz1)*@rzm1)-@priz1)+(@fnb(imag(ari1-imz1)*@izm1)+@pimz1)
   elseif @opri1=="*"
     zri1 = (@fna(real(ari1-@riz1)*@rzm1)*@priz1)+(@fnb(imag(ari1-imz1)*@izm1)+@pimz1)
   elseif @opri1=="/"
     zri1 = (@fna(real(ari1-@riz1)*@rzm1)/@priz1)+(@fnb(imag(ari1-imz1)*@izm1)+@pimz1)
   elseif @opri1=="^"
     zri1 = (@fna(real(ari1-@riz1)*@rzm1)^@priz1)+(@fnb(imag(ari1-imz1)*@izm1)+@pimz1)
   endif
  elseif @moderi1 == "-"
   if @opri1=="+"
     zri1 = (@fna(real(ari1-@riz1)*@rzm1)+@priz1)-(@fnb(imag(ari1-imz1)*@izm1)+@pimz1)
   elseif @opri1=="-"
     zri1 = (@fna(real(ari1-@riz1)*@rzm1)-@priz1)-(@fnb(imag(ari1-imz1)*@izm1)+@pimz1)
   elseif @opri1=="*"
     zri1 = (@fna(real(ari1-@riz1)*@rzm1)*@priz1)-(@fnb(imag(ari1-imz1)*@izm1)+@pimz1)
   elseif @opri1=="/"
     zri1 = (@fna(real(ari1-@riz1)*@rzm1)/@priz1)-(@fnb(imag(ari1-imz1)*@izm1)+@pimz1)
   elseif @opri1=="^"
     zri1 = (@fna(real(ari1-@riz1)*@rzm1)^@priz1)-(@fnb(imag(ari1-imz1)*@izm1)+@pimz1)     
   endif
  elseif @moderi1 == "invert-"
   if @opri1=="+"
     zri1 = (@fnb(imag(ari1-imz1)*@izm1)+@pimz1)-(@fna(real(ari1-@riz1)*@rzm1)+@priz1)
   elseif @opri1=="-"
     zri1 = (@fnb(imag(ari1-imz1)*@izm1)+@pimz1)-(@fna(real(ari1-@riz1)*@rzm1)-@priz1)
   elseif @opri1=="*"
     zri1 = (@fnb(imag(ari1-imz1)*@izm1)+@pimz1)-(@fna(real(ari1-@riz1)*@rzm1)*@priz1)
   elseif @opri1=="/"
     zri1 = (@fnb(imag(ari1-imz1)*@izm1)+@pimz1)-(@fna(real(ari1-@riz1)*@rzm1)/@priz1)
   elseif @opri1=="^"
     zri1 = (@fnb(imag(ari1-imz1)*@izm1)+@pimz1)-(@fna(real(ari1-@riz1)*@rzm1)/@priz1)     
   endif   
  elseif @moderi1 == "*"
   if @opri1=="+"
     zri1 = (@fna(real(ari1-@riz1)*@rzm1)+@priz1)*(@fnb(imag(ari1-imz1)*@izm1)+@pimz1)
   elseif @opri1=="-"
     zri1 = (@fna(real(ari1-@riz1)*@rzm1)-@priz1)*(@fnb(imag(ari1-imz1)*@izm1)+@pimz1)
   elseif @opri1=="*"
     zri1 = (@fna(real(ari1-@riz1)*@rzm1)*@priz1)*(@fnb(imag(ari1-imz1)*@izm1)+@pimz1)
   elseif @opri1=="/"
     zri1 = (@fna(real(ari1-@riz1)*@rzm1)/@priz1)*(@fnb(imag(ari1-imz1)*@izm1)+@pimz1)

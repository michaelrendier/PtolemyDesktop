if @plane == 0
float a = real(z)
float b = imag(z)
float c = real(fn1(@dim34))
float d = imag(fn1(@dim34))

elseif @plane == 1
 b = real(z)
 c = imag(z)
 a = real(fn1(@dim34))
 d = imag(fn1(@dim34))

elseif @plane == 2
 c = real(z)
 d = imag(z)
 a = real(fn1(@dim34))
 b = imag(fn1(@dim34))

elseif @plane == 3
 d = real(z)
 a = imag(z)
 b = real(fn1(@dim34))
 c = imag(fn1(@dim34))

elseif @plane == 4
 a = real(z)

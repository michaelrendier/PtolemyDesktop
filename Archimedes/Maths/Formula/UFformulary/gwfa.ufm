gwfa-Der1 {
; first derivative of Phi
init:
complex   z = Pixel 
complex c = Pixel 
loop:
  z = fn1(z)
  a = exp(z)
  b = z * z
IF ( |z| > 0 )
  z = ( (z-1)*a + 1 ) / b - 0.5 + @PixelWeight * c
ELSE
  z = @PixelWeight * c
ENDIF

z = fn2(z)

bailout:
    |z| <= @bailout  

default:
  title = "1st derivative of Phi"
  maxiter = 1000
  periodicity = 2
  center = (0,0)
  magn = 0.5
  
  param bailout
    caption = "Bailout Value"
    default = (100,0)
  endparam


  param PixelWeight
    caption = "Pixel Weight"
    default = (1,0)
  endparam


 func fn1
    caption = "Pre function"
    default = ident()
  endfunc  

 func fn2
    caption = "Post function"
    default = ident()
  endfunc  

switch:
  type = "gwfa-Der1_Jul"
  seed = #pixel
  shift1 = @shift1
  fn1 = fn1
  fn2 = fn2
 PixelWeight = @PixelWeight
  
  bailout = @bailout

}


gwfa-Der1_Jul {
; first derivative of Phi /Julia variant
complex   z = Pixel 

loop:
  z = fn1(z)
  a = exp(z)
  b = z * z
IF ( |z| > 0 )
  z = ( (z-1)*a + 1 ) / b - 0.5 +  @PixelWeight *@seed
ELSE
  z = @PixelWeight * @seed
ENDIF

z = fn2(z)

bailout:
    |z| <= @bailout  

default:
  title = "1st derivative of Phi / Julia"
  maxiter = 1000
  periodicity = 2
  center = (0,0)
  magn = 0.5
  
  param bailout

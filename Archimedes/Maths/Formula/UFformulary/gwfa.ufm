endif

z  = fn2(z) * @blow1

bailout:
  |z| <= @bailout
default:
  title = "Phi 8apn2 Julia Variant"
  maxiter = 1000
  periodicity = 2
  center = (0,0)
  magn = 0.5
  
 param seed

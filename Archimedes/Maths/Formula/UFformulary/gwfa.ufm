    caption = "Blow Up"
    default = (1.0,0.0)
  endparam


 func fn1
    caption = "Pre function"
    default = ident()
  endfunc  


 func fn2
    caption = "Post function"
    default = ident()
  endfunc  
    



switch:
  type = "gwfa-8apn_1"
 fn1 = fn1
  fn2 = fn2
  shift1 = @shift1
  blow1 = @blow2
  bailout = @bailout


}





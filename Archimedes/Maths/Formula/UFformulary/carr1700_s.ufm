Carr1760S { 
; A "Modified Carr" formula, based on the original with permission.
; Functionality added by Sharon S. Schultz, May, 2003.
; Updated for UF2 by Erik Reckase, Oct 1999
; Julia

init:
  z = ((1/(#pixel-flip(1/#pixel)-conj(1/#pixel))))/@scale
  c = (atan(real(1/#pixel)))
  
loop:
  z = fn1(fn2(fn3(z*z+c)))
  c = ((1+flip(imag(sqrt(sin(c)))))*real(sqrt(tan(c)))/9+z)


; Updated for UF2 by Erik Reckase, Oct 1999
; Mandelbrot

init:
  z = (1/log(1/(1/(1/cos(4.9/#pixel)))))/@scale
  c = 1/(conj(cos(#pixel)-conj(1/#pixel)))
  
loop:
  z = fn1(fn2(fn3(z*z+c)))

bailout:
  |real(z)| <= @bailout

default:
  title = "Carr 1769S"
  method = multipass
  periodicity = 0
  maxiter = 100
  magn = .6
  center = (0,0)

heading 
  caption = "Parameters"
endheading

param scale
  caption = "Scale"
  default = 1.0
  hint = "Select a value to scale the image elements."
endparam
param bailout
  caption = "Bailout"
  default = 4
  hint = "Select a bailout value for the formula."

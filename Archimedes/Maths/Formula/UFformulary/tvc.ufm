  s = s1
  if @sheet == 0
    s = s0
  elseif @sheet == 1
    s = s1
  elseif @sheet == 2
    s = s2
  elseif @sheet == 4
    if imag(t) > 0
      s = s0
    endif
  else
    if imag(t) > 0
      s = s2
    endif
  endif
  complex s = s - ca2/3
  complex u = (2*sqr(s) - 3*s)/(3*s - 6)
  complex p = sqrt(6*t/(3*u - 1))
  complex a3 = 0.3333333333333333333
  complex a2 = -0.5*(1 + u)*p
  complex a1 = u*sqr(p)
  z = #pixel
loop:

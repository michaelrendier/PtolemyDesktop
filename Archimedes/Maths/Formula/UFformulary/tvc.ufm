Disct1001 {
; Generic Mandelbrot set
init:
  complex u = #pixel
  float hr = real(@hypcent)
  float hi = imag(@hypcent)
  u = ((hr + 1)*u + (hr - 1))/((hr - 1)*u + (hr + 1))
  u = ((hi + 1)*u + flip(hi - 1))/(-flip(hi - 1)*u + (hi + 1))
  if |u| > 1
    u = 1/u
  endif
  complex fu00 = (1.77690860944722, 0)
  complex fu01 = (1.46881047324958, 0)
  complex fu02 = (1.46881047324958, 0)
  complex fu03 = (1.77690860944722, 0)
  complex fu10 = (3.94588866140397, 0)
  complex fu11 = (1.85030181832271, 3.33862554194208)
  complex fu12 = (1.85030181832271, -3.33862554194208)
  complex fu13 = (3.94588866140397, 0)
  complex fu20 = (2.46378306900086, 0)
  complex fu21 = (0, 2.25171645885873)
  complex fu22 = (0, -2.25171645885873)
  complex fu23 = (2.46378306900086, 0)

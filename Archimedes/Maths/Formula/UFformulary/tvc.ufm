            for the standard Mandelbrot set."
  endparam
  param bailout
    caption = "Bailout value"
    default = 20.0
    min = 1.0
    hint = "Defines how soon an orbit bails out, i.e. doesn't belong \
            to the Mandelbrot set anymore."
  endparam
switch:
  type = "Phree2two"
  seed = #pixel
  power = power
  bailout = bailout
}



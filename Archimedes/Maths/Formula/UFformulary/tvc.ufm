    if |t| < |u|
      better = true
      u = t
    endif
    t = (fu50*u + fu51)/(fu52*u + fu53)
    if |u - ffun| < ffnm
      better = true
      u = t
    endif
    t = (fu60*u + fu61)/(fu62*u + fu63)
    if |t| < |u|
      better = true
      u = t
    endif
    t = (fu70*u + fu71)/(fu72*u + fu73)
    if |u + conj(ffun)| < ffnm
      better = true
      u = t
    endif
  endwhile

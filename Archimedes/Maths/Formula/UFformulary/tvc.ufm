Critper3 {
; Generic Mandelbrot set
init:
  complex s = #pixel
;  s = 1 - 1/s
;  s = 1 - 1/s
  complex a3 = 0.3333333333333333333
  complex pp = (1/(s - s*s) - s)*3/s
  complex a0 = sqrt(pp)
  complex a2 = a0*((s - 1)/pp - a3)
  z = -2*a2
loop:
  z = (a3*z + a2)*sqr(z) + a0
bailout:
  |z| <= @bailout
default:
  title = "Critper3"
  center = (0, 0)
  param start

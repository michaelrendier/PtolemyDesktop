    min = 1.0
    hint = "Defines how soon an orbit bails out, i.e. doesn't belong \
            to the Mandelbrot set anymore."
  endparam
switch:
  type = "Jarabper2"
  seed = #pixel
  bailout = bailout
  lambda = lambda
  start = start
  cfrac1 = cfrac1




  cfrac2 = cfrac2
}




    t = (fu20*u + fu21)/(fu22*u + fu23)




    if |t| < |u|
      better = true
      u = t
    endif
    t = (fu30*u + fu31)/(fu32*u + fu33)
    if |u - conj(ffun)| < ffnm
      better = true
      u = t
    endif

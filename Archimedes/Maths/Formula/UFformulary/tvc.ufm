Meet100_1_0 {
; Generic Mandelbrot set
init:
  complex u = 1/#pixel - 1
  complex uu = sqr(u)
  complex u3i = 1/((2*u - 3)*uu + 1)
  complex s = ((2*uu - 3*u)*uu + 1.5)*u3i
  complex p = sqrt((9 - 6*u)*u3i)
  complex a3 = 0.3333333333333333333
  complex a2 = -0.5*p
  complex a0 = s*p
  z = a0
loop:

Meet100_n_0 {
; Generic Mandelbrot set
init:
  complex u = #pixel
  if @insout
    u = 1/u + 1
  endif
  complex an2 = 1/(@n + 2)
  complex an1 = 1/(@n + 1)
  complex t = ((@n + 1)*u - (@n + 2))*u^(@n + 1)
  complex s = (@n + 2 + (@n + 1)*u*t)/((@n + 1)*(1 + t))
  complex p = ((@n + 1)*(@n + 2)*(s - u))^(1/(@n + 1))
  an1 = -an1*p
  complex a0 = s*p
  z = a0

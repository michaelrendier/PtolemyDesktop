Dualies {
; Generic Mandelbrot set
init:
  z = @start*sqrt(@power/3)
loop:
  z = z*(sqr(z) + @power) + #pixel
bailout:
  |z| <= @bailout
default:
  title = "Dualies"
  center = (0, 0)
  param start
    caption = "Starting point"
    default = (0,1)
    hint = "Perturbation. Use (0,1) for the standard Mandelbrot set."
  endparam
  param power
    caption = "Power"

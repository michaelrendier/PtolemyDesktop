  endparam
  
  complex param p7
    caption = "p7"
    default = 2
  endparam
  
  complex param p8
    caption = "p8"
    default = 1
  endparam
  
  complex param p9
    caption = "p9"
    default = 1
  endparam
  
  complex param ex1
    caption = "Exponent 1"

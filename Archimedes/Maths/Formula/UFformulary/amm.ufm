General_Sterling_22 {

; Original: 

init:
  float zds
  complex z1
  complex z2
  
if @usepixel
    z = #pixel*@seed
  else
    ;Original From Sterling
    z = @seed
  endif
  
loop:
  z1 = z
  z2 = sqr(z)
  
  z = z - (@p1*z2*z2*#pixel + @p2*z2*z*#pixel + @p3*z + @p4*#pixel - @p5*@fn1(z))/(@p6*z2*z*#pixel + @p7*z2*#pixel + @p8 - @p9*@fn2(z))
  zds = |z1-z|
  
bailout:
  (zds > 1e-25) && (zds < 1e20)
  
default:
  title = "General_Sterling_22"
  periodicity = 0
  maxiter = 250
  center = (-0.68972369,0.171140295) 
  magn = 0.094292948

  
  float param Seed
    caption = "Seed"
    default = -0.5
  endparam
  

General_Sterling_30 {

; Original: z - (z4*z4*z + z4*z4*c + c - zsin)/(9*z4*z4 + 8*z4*z3*c - zcos)

init:
  float zds
  complex z1
  complex z3
  complex z4
  complex z8
  complex zcos
  complex zsin
  
if @usepixel
    z = #pixel*@seed
  else
    ;Original From Sterling
    z = @seed
  endif
  
loop:
  z1 = z
  z3 = z^3
  z4 = z^4
  z8 = z4*z4
  zcos = (1e-15+cos(z))/@strands
zsin = (1e-15+sin(z))/@strands

  z = z - (@p1*z8*z + @p2*z8*#pixel + @p3*#pixel - @p4*zsin)/(@p5*z8 + @p6*z4*z3*#pixel - @p7*zcos)
  zds = |z1-z|
  
bailout:
  (zds > 1e-25) && (zds < 1e20)
  
default:

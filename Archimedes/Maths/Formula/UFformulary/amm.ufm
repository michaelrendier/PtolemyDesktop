  float zds
  complex z1
  
if @usepixel
    z = #pixel*@seed
  else
    ;Original From Sterling
    z = @seed
  endif
  
loop:
  
  z1 = z
  z = z - (@p1*z^@ex1 + @p2*#pixel*z^@ex2 + @p3*z^@ex3 + @p4*#pixel^@ex4 + @p5*@fn1(z))/(@p6*z^@ex5 + @p7*#pixel*z^@ex6 + @p8 + @p9*@fn2(z))
  zds = |z1-z|
  
bailout:
  (zds > 1e-25) && (zds < 1e20)
  

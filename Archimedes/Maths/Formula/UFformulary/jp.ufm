pixeljp { ; based on Kerry Mitchell's formula
; When Max Iters = 1, all pixels are "inside"
; When Max Iters = 2, all pixels are "outside"
; Two iterations so Orbit Traps (trap only) will
; work with this formula
;
init:
  z = #pixel
  int i = 0
loop:
  i = i + 1
bailout:
  i < 2
default:
  title = "Pixel (jp)"
  maxiter = 2
  method = multipass
  periodicity = 0
}

    elseif (@enShape == "Shape #44")
      a=1, b=1, m=1, n1=0.3,  n2=0.3, n3=0.3
    elseif (@enShape == "Shape #45")
      a=1, b=1, m=2, n1=0.3,  n2=0.3, n3=0.3
    elseif (@enShape == "Shape #46")
      a=1, b=1, m=3, n1=0.3,  n2=0.3, n3=0.3
    elseif (@enShape == "Shape #47")

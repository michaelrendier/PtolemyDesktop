    elseif (@enShape == "Shape #26")
      a=1, b=1, m=7, n1=10,  n2=6, n3=6
    elseif (@enShape == "Shape #27")
      a=0.3, b=1, m=-8.5, n1=1,  n2=1, n3=140, s=4
    elseif (@enShape == "Shape #28")

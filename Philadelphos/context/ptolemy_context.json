{
  "_hyperwebster": {
    "index": "ptolemy_context",
    "type": "ptolemy_master_context",
    "version": "1.0",
    "description": "Top-level Ptolemy context index — aggregates Claude, Gemini, and runtime I/O",
    "schema": "ptolemy_master_context_v1",
    "child_indexes": [
      "claude_context.json",
      "gemini_context.json"
    ]
  },

  "ptolemy": {
    "project": "Ptolemy",
    "author": "michaelrendier",
    "repo": "github.com/michaelrendier/Ptolemy",
    "branch": "main",
    "root": "/home/rendier/Ptolemy",
    "python": "3.12",
    "license": "MIT",
    "modules": {
      "Alexandria":   {"path": "Alexandria/",   "role": "geo / mapping"},
      "Anaximander":  {"path": "Anaximander/",  "role": "navigation"},
      "Archimedes":   {"path": "Archimedes/",   "role": "math engine — UFformulary"},
      "Callimachus":  {"path": "Callimachus/",  "role": "database / HyperWebster"},
      "Kryptos":      {"path": "Kryptos/",      "role": "cipher engines"},
      "Mouseion":     {"path": "Mouseion/",     "role": "OpenGL GUI"},
      "Phaleron":     {"path": "Phaleron/",     "role": "browser / web tools"},
      "Pharos":       {"path": "Pharos/",       "role": "main shell UI"},
      "Philadelphos": {"path": "Philadelphos/", "role": "AI / LLM layer"},
      "Tesla":        {"path": "Tesla/",        "role": "networking / sockets"},
      "Ptolemy++":    {"path": "Ptolemy++/",    "role": "C++ companion (Gemini-ncurses)"}
    }
  },

  "env_vars": {
    "tokens": {
      "PTOL_TOKEN":  "GitHub PAT — github.com/michaelrendier/Ptolemy (full git management)",
      "AINUR_TOKEN": "GitHub PAT — github.com/michaelrendier/Ainulindale"
    },
    "api_keys": {
      "ANTHROPIC_API_KEY": "Anthropic — Claude (Philadelphos.Ainur)",
      "GEMINI_API_KEY":    "Google AI — Gemini (Philadelphos.Gemini)"
    },
    "note": "Tokens and API keys are separate. *_TOKEN = GitHub PAT. *_API_KEY = AI service key."
  },

  "ai_features": {
    "claude": {
      "context_file": "claude_context.json",
      "module": "Philadelphos.Ainur",
      "model": "claude-opus-4-6",
      "provider": "Anthropic",
      "sdk": "anthropic",
      "api_key_env": "ANTHROPIC_API_KEY",
      "repl": "python3 -m Philadelphos.Ainur.ainur",
      "slash_command": "/ainur",
      "last_status": null
    },
    "gemini": {
      "context_file": "gemini_context.json",
      "module": "Philadelphos.Gemini",
      "model": "gemini-2.5-flash",
      "provider": "Google",
      "sdk": "google-genai",
      "sdk_version": "1.73.1",
      "api_key_env": "GEMINI_API_KEY",
      "repl": "python3 -m Philadelphos.Gemini.gemini",
      "slash_command": "/gemini",
      "last_status": null
    }
  },

  "smnnip": {
    "full_name": "Standard Model of Neural Network Information Propagation",
    "repo": "github.com/michaelrendier/Ainulindale",
    "ptolemy_path": "Philadelphos/Ainulindale/",
    "algebra_tower": "R -> C -> H -> O -> S",
    "gauge_group": "U(1) x SU(2) x SU(3)",
    "reference": "Dixon 1994 — Cayley-Dickson construction",
    "console": {
      "launcher": "python3 derivation.py",
      "module": "python3 -m Philadelphos.Ainulindale.console.smnnip_proof_engine_console",
      "slash_command": "/derivation"
    },
    "verified_results": {
      "noether_violation": 0.0,
      "conserved": true,
      "engine_available": true
    }
  },

  "runtime": {
    "io_streams": {
      "stdin": {
        "log": [],
        "max_entries": 200,
        "description": "Captured stdin from Ptolemy runtime and AI sessions"
      },
      "stdout": {
        "log": [],
        "max_entries": 200,
        "description": "Captured stdout from Ptolemy runtime and AI sessions"
      },
      "stderr": {
        "log": [],
        "max_entries": 200,
        "description": "Captured stderr — errors, warnings, engine diagnostics"
      }
    },
    "events": [],
    "active_modules": []
  },

  "session_log": [],

  "metadata": {
    "created": "2026-04-18",
    "last_updated": null,
    "total_sessions": 0,
    "active_ai": []
  }
}

# Ptolemy Environment Variables
# Copy this file to .env and fill in real values
# Never commit .env to git

# ── GitHub fine-grained PATs (repository access) ──────────────────────────────
PTOL_TOKEN=your_ptolemy_github_pat_here       # github.com/michaelrendier/Ptolemy
AINUR_TOKEN=your_ainulindale_github_pat_here  # github.com/michaelrendier/Ainulindale

# ── AI Service API keys ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...   # Claude (Philadelphos/Ainur)
GEMINI_API_KEY=AIza...         # Gemini (Philadelphos/Gemini — coming)
